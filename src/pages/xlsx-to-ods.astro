---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="xlsx-to-ods">
  <ArchiveConvert slug="xlsx-to-ods" from="xlsx" to="ods" noun="spreadsheet" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free XLSX to ODS converter converts Excel XLSX spreadsheets to OpenDocument ODS used by LibreOffice.
    </p>
    <p>
      Conversion is handled on our servers, because these
      spreadsheet formats can't be read reliably in a browser. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const VECTOR_TARGETS = ['svg', 'pdf', 'png', 'eps'];
---

<ToolLayout slug="vector-converter">
  <ArchiveConvert slug="vector-converter" targets={VECTOR_TARGETS} noun="vector file" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online vector converter converts between vector graphics formats —
      including proprietary ones like Adobe Illustrator AI, CorelDRAW CDR, Visio
      VSD, and Windows metafiles EMF and WMF — plus SVG and EPS. Upload a file, pick
      a target format (SVG, PDF, PNG or EPS), and convert.
    </p>
    <p>
      Proprietary vector formats can't be read reliably in a browser, so conversion
      is handled on our servers. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import RasterBatch from '../components/RasterBatch.astro';
---

<ToolLayout slug="jpg-to-bmp">
  <RasterBatch to="bmp" accept="image/jpeg,.jpg,.jpeg,.jfif" fromLabel="JPG" matte={true} />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free JPG to BMP converter encodes each JPG as an uncompressed 24-bit Windows Bitmap (.bmp) — the raw-pixel format some legacy and imaging software requires. Everything runs
      entirely in your browser — your images are never uploaded to a server.
    </p>
    <p>
      Drop a single image or a whole batch at once, optionally resize by the longest side,
      and preview each result before you download. Conversions happen offline through the
      browser's canvas, so the tool works without a network connection and nothing leaves your device.
    </p>
  </div>
</ToolLayout>

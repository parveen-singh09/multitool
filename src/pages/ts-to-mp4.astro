---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="ts-to-mp4">
  <ArchiveConvert slug="ts-to-mp4" from="ts" to="mp4" noun="video" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free TS to MP4 converter converts MPEG transport stream TS videos to widely-compatible MP4.
    </p>
    <p>
      Conversion is handled on our servers, because these
      broadcast and proprietary video formats can't be decoded in a browser. Your
      file is uploaded to our servers, converted on their
      servers, and returned as a download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="protein-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Units">
      <button type="button" data-unit="metric" class="pro-tab btn btn-primary" aria-selected="true">Metric</button>
      <button type="button" data-unit="imperial" class="pro-tab btn btn-secondary" aria-selected="false">Imperial</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sex
        <select id="pro-sex" class="field">
          <option value="male">Male</option>
          <option value="female">Female</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Age (years)
        <input id="pro-age" type="number" min="1" class="field" value="30" inputmode="numeric" />
      </label>
    </div>

    <div id="pro-metric" class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (cm)
        <input id="pro-cm" type="number" min="0" class="field" value="175" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight (kg)
        <input id="pro-kg" type="number" min="0" class="field" value="70" inputmode="decimal" />
      </label>
    </div>

    <div id="pro-imperial" class="hidden grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (ft)
        <input id="pro-ft" type="number" min="0" class="field" value="5" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (in)
        <input id="pro-in" type="number" min="0" class="field" value="9" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight (lb)
        <input id="pro-lb" type="number" min="0" class="field" value="154" inputmode="decimal" />
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Activity level
        <select id="pro-act" class="field">
          <option value="sedentary">Sedentary (little or no exercise)</option>
          <option value="light">Light (1–3 days/week)</option>
          <option value="moderate" selected>Moderate (3–5 days/week)</option>
          <option value="active">Active (6–7 days/week)</option>
          <option value="athlete">Athlete (hard training / physical job)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Goal
        <select id="pro-goal" class="field">
          <option value="lose">Lose fat (keep muscle)</option>
          <option value="maintain" selected>Maintain / general health</option>
          <option value="gain">Build muscle</option>
        </select>
      </label>
    </div>

    <div class="panel panel-lift p-6 text-center">
      <div id="pro-value" class="font-display text-4xl font-semibold text-primary-hover">—</div>
      <div class="mt-2 text-sm text-ink-subtle">grams of protein per day (recommended)</div>
      <div id="pro-range" class="mt-1 text-[13px] text-ink-tertiary"></div>
    </div>

    <div class="grid grid-cols-1 gap-3 text-center sm:grid-cols-3">
      <div class="panel p-4"><div id="pro-perkg" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Per kg body weight</div></div>
      <div class="panel p-4"><div id="pro-cals" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Calories from protein</div></div>
      <div class="panel p-4">
        <div class="flex items-center justify-center gap-2">
          <div id="pro-permeal" class="font-mono text-lg text-ink">—</div>
          <select id="pro-meals" class="field w-auto py-0.5 text-sm">
            <option value="3">3 meals</option>
            <option value="4" selected>4 meals</option>
            <option value="5">5 meals</option>
            <option value="6">6 meals</option>
          </select>
        </div>
        <div class="mt-1 text-[13px] text-ink-subtle">Per meal</div>
      </div>
    </div>

    <div class="panel p-5">
      <div class="mb-3 text-sm text-ink-muted">Hit your target with roughly</div>
      <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
        <div><div id="pro-egg" class="font-mono text-lg text-ink">—</div><div class="text-[13px] text-ink-subtle">Large eggs</div></div>
        <div><div id="pro-chicken" class="font-mono text-lg text-ink">—</div><div class="text-[13px] text-ink-subtle">Chicken breast</div></div>
        <div><div id="pro-whey" class="font-mono text-lg text-ink">—</div><div class="text-[13px] text-ink-subtle">Whey scoops</div></div>
        <div><div id="pro-yogurt" class="font-mono text-lg text-ink">—</div><div class="text-[13px] text-ink-subtle">Greek yogurt cups</div></div>
      </div>
      <div class="mt-3 text-[11px] text-ink-tertiary">Large egg ≈ 6 g · 100 g chicken breast ≈ 31 g · whey scoop ≈ 25 g · Greek yogurt cup ≈ 20 g</div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free protein calculator estimates how many grams of protein you should
      eat per day from your age, sex, height, weight, activity level and goal, in
      metric or imperial units. Unlike a single fixed number, it gives a
      sensible daily range with a recommended target, scales that target to your
      training load and whether you want to lose fat, maintain or build muscle,
      and then splits it across your meals and into everyday food equivalents.
      All calculations run in your browser.
    </p>
    <p>
      Recommendations are based on body weight: around 0.8 g/kg for sedentary
      adults (the RDA), rising to 1.4–2.0 g/kg for active people and those
      building muscle, and 1.8–2.4 g/kg when losing fat to protect lean mass.
      These are healthy-adult estimates, not medical advice — check with a doctor
      or dietitian if you have kidney concerns, are pregnant, or have specific
      medical needs.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const sel = (id: string) => document.getElementById(id) as unknown as HTMLSelectElement;
  let unit: 'metric' | 'imperial' = 'metric';

  // g/kg [low, high] ranges by goal, indexed by activity level.
  // ponytail: table over formula — the science IS a lookup, not an equation.
  const RANGES: Record<string, Record<string, [number, number]>> = {
    lose:     { sedentary: [1.2, 1.6], light: [1.4, 1.8], moderate: [1.6, 2.0], active: [1.8, 2.2], athlete: [2.0, 2.4] },
    maintain: { sedentary: [0.8, 1.0], light: [1.0, 1.4], moderate: [1.2, 1.6], active: [1.4, 1.8], athlete: [1.6, 2.0] },
    gain:     { sedentary: [1.4, 1.8], light: [1.6, 2.0], moderate: [1.6, 2.2], active: [1.8, 2.2], athlete: [1.8, 2.4] },
  };

  function calc() {
    let kg: number;
    if (unit === 'metric') {
      kg = Number($('pro-kg').value);
    } else {
      kg = Number($('pro-lb').value) * 0.45359237;
    }
    const age = Number($('pro-age').value);
    const goal = sel('pro-goal').value;
    const act = sel('pro-act').value;

    const ids = ['pro-value', 'pro-perkg', 'pro-cals', 'pro-permeal', 'pro-egg', 'pro-chicken', 'pro-whey', 'pro-yogurt'];
    if (!(kg > 0) || !(age > 0)) {
      ids.forEach((id) => (document.getElementById(id)!.textContent = '—'));
      document.getElementById('pro-range')!.textContent = '';
      return;
    }

    const [lo, hi] = RANGES[goal][act];
    const gLo = Math.round(lo * kg);
    const gHi = Math.round(hi * kg);
    const rec = Math.round(((lo + hi) / 2) * kg);
    const perKg = (lo + hi) / 2;

    document.getElementById('pro-value')!.textContent = rec + ' g';
    document.getElementById('pro-range')!.textContent = `healthy range ${gLo}–${gHi} g/day`;
    document.getElementById('pro-perkg')!.textContent = perKg.toFixed(1) + ' g/kg';
    document.getElementById('pro-cals')!.textContent = rec * 4 + ' kcal';

    const meals = Number(sel('pro-meals').value);
    document.getElementById('pro-permeal')!.textContent = Math.round(rec / meals) + ' g';

    document.getElementById('pro-egg')!.textContent = Math.round(rec / 6).toString();
    document.getElementById('pro-chicken')!.textContent = Math.round((rec / 31) * 100) + ' g';
    document.getElementById('pro-whey')!.textContent = Math.round(rec / 25).toString();
    document.getElementById('pro-yogurt')!.textContent = Math.round(rec / 20).toString();
  }

  document.querySelectorAll<HTMLButtonElement>('.pro-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      unit = tab.dataset.unit as 'metric' | 'imperial';
      document.querySelectorAll('.pro-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('pro-metric')!.classList.toggle('hidden', unit !== 'metric');
      document.getElementById('pro-metric')!.classList.toggle('grid', unit === 'metric');
      document.getElementById('pro-imperial')!.classList.toggle('hidden', unit !== 'imperial');
      document.getElementById('pro-imperial')!.classList.toggle('grid', unit === 'imperial');
      calc();
    });
  });

  document.querySelectorAll('#pro-sex, #pro-age, #pro-cm, #pro-kg, #pro-ft, #pro-in, #pro-lb, #pro-act, #pro-goal, #pro-meals').forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

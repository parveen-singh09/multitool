---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="rar-to-zip">
  <ArchiveConvert slug="rar-to-zip" from="rar" to="zip" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free RAR to ZIP converter Convert RAR archives to universally-supported ZIP files that open on any OS without extra software.
    </p>
    <p>
      Conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

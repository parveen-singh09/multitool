---
import ToolLayout from '../layouts/ToolLayout.astro';
import AudioConvert from '../components/AudioConvert.astro';
---

<ToolLayout slug="audio-converter">
  <AudioConvert slug="audio-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online audio converter converts between all the common audio
      formats — MP3, WAV, FLAC, AAC (M4A), OGG, Opus, AIFF and AC3. Drop one file
      or a whole batch, choose your target format, and convert.
    </p>
    <p>
      Everything runs entirely in your browser using ffmpeg compiled to
      WebAssembly — your audio is never uploaded to a server, so conversions are
      private and work even offline once the page has loaded. Convert several
      files at once and download them individually or all together as a ZIP.
    </p>
  </div>
</ToolLayout>

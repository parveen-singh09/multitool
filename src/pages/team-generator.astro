---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="team-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Names (one per line)
        <div class="copy-wrap">
          <textarea id="tg-names" class="field min-h-48 resize-y text-sm">Alice
Bob
Charlie
Dana
Eli
Farah
Grace
Hugo</textarea>
          <button type="button" class="copy-icon" data-copy-target="#tg-names" aria-label="Copy"></button>
        </div>
      </label>
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Split by
          <select id="tg-mode" class="field w-40"><option value="teams">Number of teams</option><option value="size">People per team</option></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Value
          <input id="tg-value" type="number" min="1" max="50" value="2" class="field w-24" />
        </label>
        <button id="tg-gen" class="btn btn-primary">Generate</button>
      </div>
    </div>

    <div id="tg-out" class="flex flex-col gap-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free team generator randomly splits a list of names into balanced teams
      — either a set number of teams or a fixed number of people per team. It
      shuffles the names first so the split is fair, and distributes any remainder
      evenly. Great for sports, group projects, classrooms and games. Runs entirely
      in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { shuffle } from '../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('tg-out')!;

  function generate() {
    const names = ($('tg-names') as HTMLTextAreaElement).value.split('\n').map((s) => s.trim()).filter(Boolean);
    const mode = ($('tg-mode') as HTMLSelectElement).value;
    const value = Math.max(1, Number(($('tg-value') as HTMLInputElement).value) || 1);
    if (!names.length) { out.innerHTML = ''; return; }
    const shuffled = shuffle(names);
    const numTeams = mode === 'teams' ? Math.min(value, names.length) : Math.ceil(names.length / value);
    const teams: string[][] = Array.from({ length: numTeams }, () => []);
    shuffled.forEach((name, i) => teams[i % numTeams].push(name));
    out.innerHTML = teams.map((team, i) => `
      <div class="panel panel-lift flex flex-col gap-2 p-4">
        <span class="text-sm font-semibold text-primary-hover">Team ${i + 1} <span class="text-ink-tertiary">(${team.length})</span></span>
        <ul class="flex flex-col gap-1">${team.map((n) => `<li class="text-[15px] text-ink">${n}</li>`).join('')}</ul>
      </div>`).join('');
  }

  ['tg-names', 'tg-mode', 'tg-value'].forEach((id) => $(id).addEventListener('input', generate));
  $('tg-gen').addEventListener('click', generate);
  generate();
</script>

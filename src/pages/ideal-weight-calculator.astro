---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="ideal-weight-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Units">
      <button type="button" data-unit="metric" class="iw-tab btn btn-primary" aria-selected="true">Metric</button>
      <button type="button" data-unit="imperial" class="iw-tab btn btn-secondary" aria-selected="false">Imperial</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sex
        <select id="iw-sex" class="field">
          <option value="male">Male</option>
          <option value="female">Female</option>
        </select>
      </label>
      <label id="iw-metric" class="flex flex-col gap-1 text-sm text-ink-subtle">Height (cm)
        <input id="iw-cm" type="number" min="0" class="field" value="175" inputmode="decimal" />
      </label>
      <div id="iw-imperial" class="hidden grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (ft)
          <input id="iw-ft" type="number" min="0" class="field" value="5" inputmode="decimal" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (in)
          <input id="iw-in" type="number" min="0" class="field" value="9" inputmode="decimal" />
        </label>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="panel p-5 text-center"><div id="iw-devine" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Devine</div></div>
      <div class="panel p-5 text-center"><div id="iw-robinson" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Robinson</div></div>
      <div class="panel p-5 text-center"><div id="iw-miller" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Miller</div></div>
      <div class="panel p-5 text-center"><div id="iw-hamwi" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Hamwi</div></div>
    </div>
    <div class="panel panel-lift p-5 text-center">
      <div id="iw-range" class="font-display text-2xl font-semibold text-primary-hover">—</div>
      <div class="mt-1 text-[13px] text-ink-subtle">Healthy weight range (BMI 18.5–25)</div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free ideal weight calculator estimates a healthy target weight for
      your height and sex using four well-known formulas — Devine, Robinson,
      Miller and Hamwi — alongside the healthy weight range derived from a normal
      BMI. Switch between metric and imperial units. These are guides, not strict
      targets.
    </p>
  </div>
</ToolLayout>

<script>
  const sexEl = document.getElementById('iw-sex') as HTMLSelectElement;
  const cmEl = document.getElementById('iw-cm') as HTMLInputElement;
  const ftEl = document.getElementById('iw-ft') as HTMLInputElement;
  const inEl = document.getElementById('iw-in') as HTMLInputElement;
  let unit: 'metric' | 'imperial' = 'metric';

  function fmt(kgVal: number): string {
    return unit === 'imperial' ? (kgVal / 0.45359237).toFixed(1) + ' lb' : kgVal.toFixed(1) + ' kg';
  }

  function heightCm(): number {
    return unit === 'imperial'
      ? (Number(ftEl.value) * 12 + Number(inEl.value)) * 2.54
      : Number(cmEl.value);
  }

  function calc() {
    const male = sexEl.value === 'male';
    const cm = heightCm();
    if (!(cm > 0)) { ['iw-devine','iw-robinson','iw-miller','iw-hamwi','iw-range'].forEach((id)=>document.getElementById(id)!.textContent='—'); return; }
    const inchesOver5ft = Math.max(0, cm / 2.54 - 60);
    const devine = (male ? 50 : 45.5) + 2.3 * inchesOver5ft;
    const robinson = (male ? 52 : 49) + (male ? 1.9 : 1.7) * inchesOver5ft;
    const miller = (male ? 56.2 : 53.1) + (male ? 1.41 : 1.36) * inchesOver5ft;
    const hamwi = (male ? 48 : 45.5) + (male ? 2.7 : 2.2) * inchesOver5ft;
    document.getElementById('iw-devine')!.textContent = fmt(devine);
    document.getElementById('iw-robinson')!.textContent = fmt(robinson);
    document.getElementById('iw-miller')!.textContent = fmt(miller);
    document.getElementById('iw-hamwi')!.textContent = fmt(hamwi);
    const m = cm / 100;
    document.getElementById('iw-range')!.textContent = `${fmt(18.5 * m * m)}–${fmt(25 * m * m)}`;
  }

  document.querySelectorAll<HTMLButtonElement>('.iw-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      unit = tab.dataset.unit as 'metric' | 'imperial';
      document.querySelectorAll('.iw-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('iw-metric')!.classList.toggle('hidden', unit !== 'metric');
      document.getElementById('iw-metric')!.classList.toggle('flex', unit === 'metric');
      document.getElementById('iw-imperial')!.classList.toggle('hidden', unit !== 'imperial');
      document.getElementById('iw-imperial')!.classList.toggle('grid', unit === 'imperial');
      calc();
    });
  });
  [sexEl, cmEl, ftEl, inEl].forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="epub-to-azw3">
  <ArchiveConvert slug="epub-to-azw3" from="epub" to="azw3" noun="ebook" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free EPUB to AZW3 converter converts EPUB ebooks to Kindle AZW3 format for modern Kindle devices.
    </p>
    <p>
      Conversion is handled on our servers, because these
      ebook formats can't be read reliably in a browser. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

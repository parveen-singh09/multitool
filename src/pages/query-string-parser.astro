---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="query-string-parser">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Query string or full URL
      <textarea
        id="qsp-in"
        class="field min-h-32 resize-y font-mono text-[13px]"
        placeholder="?q=hello world&tags=a&tags=b&page=2  — or a full https://… URL"
        spellcheck="false"
      >https://example.com/search?q=hello%20world&tags=a&tags=b&page=2&empty=</textarea>
    </label>

    <p id="qsp-empty" class="hidden text-[13px] text-ink-muted" role="status">No parameters found.</p>

    <div id="qsp-params-wrap" class="panel p-4">
      <div class="mb-2 text-sm text-ink-subtle">Parameters (decoded)</div>
      <div id="qsp-params" class="flex flex-col gap-2"></div>
    </div>

    <div class="flex flex-col gap-1">
      <div class="flex items-center gap-2 text-sm text-ink-subtle">
        Reconstructed &amp; encoded string
      </div>
      <div class="copy-wrap">
        <div id="qsp-rebuilt" class="panel p-4 font-mono text-[13px] text-ink break-all">—</div>
        <button type="button" class="copy-icon" data-copy-target="#qsp-rebuilt" aria-label="Copy"></button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free query string parser takes a raw query string or a complete URL and
      lists every parameter as a decoded key-value pair, including repeated keys
      which are grouped as arrays. It also rebuilds the properly percent-encoded
      query string so you can copy a clean version. Handy for debugging links,
      tracking parameters and API calls.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('qsp-in') as HTMLTextAreaElement;
  const paramsEl = document.getElementById('qsp-params')!;
  const paramsWrap = document.getElementById('qsp-params-wrap')!;
  const emptyMsg = document.getElementById('qsp-empty')!;
  const rebuilt = document.getElementById('qsp-rebuilt')!;

  function extractQuery(raw: string): string {
    const t = raw.trim();
    if (!t) return '';

    const qIndex = t.indexOf('?');
    if (/^[a-z][a-z\d+.-]*:\/\//i.test(t)) {
      if (qIndex === -1) return '';
      return t.slice(qIndex + 1).split('#')[0];
    }

    return (qIndex === 0 ? t.slice(1) : t).split('#')[0];
  }

  function parse() {
    const query = extractQuery(input.value);
    const params = new URLSearchParams(query);

    const groups = new Map<string, string[]>();
    for (const [k, v] of params.entries()) {
      if (!groups.has(k)) groups.set(k, []);
      groups.get(k)!.push(v);
    }

    paramsEl.textContent = '';
    if (groups.size === 0) {
      paramsWrap.classList.add('hidden');
      emptyMsg.classList.remove('hidden');
      rebuilt.textContent = '—';
      return;
    }
    paramsWrap.classList.remove('hidden');
    emptyMsg.classList.add('hidden');

    for (const [key, values] of groups.entries()) {
      const row = document.createElement('div');
      row.className = 'grid grid-cols-[minmax(90px,auto)_1fr] gap-x-4 border-t border-white/5 pt-2 text-sm first:border-0 first:pt-0';
      const k = document.createElement('div');
      k.className = 'font-mono text-[13px] text-primary-hover break-all';
      k.textContent = values.length > 1 ? `${key} [${values.length}]` : key;
      const v = document.createElement('div');
      v.className = 'font-mono text-[13px] text-ink break-all';
      v.textContent = values.map((x) => (x === '' ? '(empty)' : x)).join('\n');
      v.style.whiteSpace = 'pre-wrap';
      row.append(k, v);
      paramsEl.append(row);
    }

    rebuilt.textContent = params.toString() || '—';
  }

  input.addEventListener('input', parse);
  parse();
</script>

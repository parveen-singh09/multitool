---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="bz2-to-zip">
  <ArchiveConvert slug="bz2-to-zip" from="bz2" to="zip" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free BZ2 to ZIP converter Convert Bzip2 (.bz2) files to ZIP archives that open everywhere.
    </p>
    <p>
      Conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

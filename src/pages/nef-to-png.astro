---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="nef-to-png">
  <ArchiveConvert slug="nef-to-png" from="nef" to="png" noun="RAW photo" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free NEF to PNG converter converts Nikon NEF RAW photos to lossless PNG images.
    </p>
    <p>
      Conversion is handled on our servers, because these
      formats can't be decoded in a browser. Your file is uploaded to our servers, converted, and returned as a download link.
    </p>
  </div>
</ToolLayout>

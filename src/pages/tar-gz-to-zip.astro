---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="tar-gz-to-zip">
  <ArchiveConvert slug="tar-gz-to-zip" from="gz" to="zip" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free TAR.GZ to ZIP converter Convert compressed TAR.GZ (tarball) archives to ZIP for easy extraction on Windows and Mac.
    </p>
    <p>
      Conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

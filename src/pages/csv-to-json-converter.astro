---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="csv-to-json-converter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="c2j-convert" class="btn btn-primary">Convert to JSON</button>
      <button id="c2j-download" class="btn btn-secondary">Download</button>
      <button id="c2j-clear" class="btn btn-tertiary">Clear</button>
      <label class="btn btn-tertiary cursor-pointer">
        Upload CSV
        <input id="c2j-file" type="file" accept=".csv,.tsv,.txt,text/csv" class="hidden" />
      </label>
    </div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <label class="flex items-center gap-2">
        Delimiter
        <select id="c2j-delim" class="field w-auto py-1">
          <option value="auto">Auto-detect</option>
          <option value=",">Comma</option>
          <option value=";">Semicolon</option>
          <option value="tab">Tab</option>
          <option value="|">Pipe</option>
          <option value=":">Colon</option>
          <option value=" ">Space</option>
        </select>
      </label>
      <label class="flex items-center gap-2">
        Output
        <select id="c2j-shape" class="field w-auto py-1">
          <option value="objects">Array of objects</option>
          <option value="ndjson">JSON Lines (NDJSON)</option>
          <option value="keyed">Keyed by first column</option>
          <option value="columns">Column arrays</option>
          <option value="matrix">Array of arrays</option>
        </select>
      </label>
      <label class="flex items-center gap-2">
        Indent
        <select id="c2j-indent" class="field w-auto py-1">
          <option value="2">2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <label class="flex items-center gap-2">
        <input id="c2j-header" type="checkbox" checked class="h-4 w-4" />
        First row is header
      </label>
      <label class="flex items-center gap-2">
        <input id="c2j-parse" type="checkbox" checked class="h-4 w-4" />
        Parse numbers & booleans
      </label>
      <label class="flex items-center gap-2">
        <input id="c2j-null" type="checkbox" class="h-4 w-4" />
        Empty cells as null
      </label>
      <label class="flex items-center gap-2">
        <input id="c2j-minify" type="checkbox" class="h-4 w-4" />
        Minify
      </label>
    </div>

    <div id="c2j-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid gap-4 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        CSV input
        <div id="c2j-drop" class="hl-edit field p-0" style="height:22rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="c2j-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea
            id="c2j-input"
            spellcheck="false"
            autocapitalize="off"
            autocomplete="off"
            autocorrect="off"
            placeholder={"name,age,active\nAda,36,true\nGrace,45,false"}
            aria-label="CSV input"
          ></textarea>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>JSON output</span>
          <span id="c2j-count" class="text-ink-tertiary"></span>
        </span>
        <div class="copy-wrap"><pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre"><code id="c2j-output" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#c2j-output" aria-label="Copy"></button></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSV to JSON converter turns CSV into JSON right in your browser —
      nothing is ever uploaded. Paste, drag-and-drop, or upload a file, then pick
      the exact shape you need: an array of objects, JSON Lines (NDJSON) for
      streaming and MongoDB imports, an object keyed by the first column, column
      arrays, or a raw array of arrays. The delimiter is auto-detected across
      comma, semicolon, tab, pipe, colon and space, and quoted fields with escaped
      quotes and embedded newlines are parsed correctly.
    </p>
    <p>
      Toggle number and boolean parsing on or off, choose whether empty cells
      become <code>null</code> or empty strings, dedupe repeated column headers
      automatically, and switch between pretty-printed (2 space, 4 space or tab)
      and minified output. Both panes are syntax-highlighted, conversion is live
      as you type, and you can copy or download the result with one click. Errors
      point at the problem instead of failing silently.
    </p>
  </div>
</ToolLayout>

<script>
  import { parseCsv, detectDelimiter, type Json } from '../lib/dataformats';
  import { hl, wireInput } from '../lib/highlight';

  const input = document.getElementById('c2j-input') as HTMLTextAreaElement;
  const inHl = document.getElementById('c2j-in-hl')!;
  const output = document.getElementById('c2j-output')!;
  const status = document.getElementById('c2j-status')!;
  const count = document.getElementById('c2j-count')!;
  const drop = document.getElementById('c2j-drop')!;
  const delimSel = document.getElementById('c2j-delim') as HTMLSelectElement;
  const shapeSel = document.getElementById('c2j-shape') as HTMLSelectElement;
  const indentSel = document.getElementById('c2j-indent') as HTMLSelectElement;
  const headerBox = document.getElementById('c2j-header') as HTMLInputElement;
  const parseBox = document.getElementById('c2j-parse') as HTMLInputElement;
  const nullBox = document.getElementById('c2j-null') as HTMLInputElement;
  const minifyBox = document.getElementById('c2j-minify') as HTMLInputElement;
  let rawOutput = '';

  const refresh = wireInput(input, inHl, () => 'plaintext', () => convert());

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  function resolveDelimiter(): string {
    const v = delimSel.value;
    if (v === 'tab') return '\t';
    if (v === 'auto') return detectDelimiter(input.value);
    return v;
  }

  function cell(v: string): Json {
    if (v === '') return nullBox.checked ? null : '';
    if (!parseBox.checked) return v;
    if (v === 'true') return true;
    if (v === 'false') return false;
    if (v === 'null') return null;
    if (/^[+-]?\d+$/.test(v)) {
      const n = Number(v);
      if (Number.isSafeInteger(n)) return n;
    }
    if (/^[+-]?(\d+\.\d*|\.\d+|\d+)([eE][+-]?\d+)?$/.test(v) && /[.eE]/.test(v)) {
      const n = Number(v);
      if (!Number.isNaN(n)) return n;
    }
    return v;
  }

  function uniqueHeaders(header: string[]): string[] {
    const seen: Record<string, number> = {};
    return header.map((h) => {
      const name = h === '' ? 'field' : h;
      if (seen[name]) return `${name}_${++seen[name]}`;
      seen[name] = 1;
      return name;
    });
  }

  function getIndent(): string | number {
    return indentSel.value === 'tab' ? '\t' : Number(indentSel.value);
  }

  function build(matrix: string[][]): { text: string; items: number } {
    const shape = shapeSel.value;
    const hasHeader = headerBox.checked;
    const indent = minifyBox.checked ? undefined : getIndent();

    // Array of arrays never uses a header row as keys.
    if (shape === 'matrix' || !hasHeader) {
      const rows = matrix.map((r) => r.map(cell));
      return { text: JSON.stringify(rows, null, indent), items: rows.length };
    }
    if (matrix.length === 0) return { text: JSON.stringify([], null, indent), items: 0 };

    const header = uniqueHeaders(matrix[0]);
    const body = matrix.slice(1);

    if (shape === 'columns') {
      const cols: Record<string, Json[]> = {};
      header.forEach((h, i) => { cols[h] = body.map((r) => cell(r[i] ?? '')); });
      return { text: JSON.stringify(cols, null, indent), items: body.length };
    }

    const objects = body.map((row) => {
      const obj: Record<string, Json> = {};
      header.forEach((h, i) => { obj[h] = cell(row[i] ?? ''); });
      return obj;
    });

    if (shape === 'keyed') {
      // First column value becomes the key; remaining fields are the value.
      const keyName = header[0];
      const map: Record<string, Json> = {};
      objects.forEach((o) => {
        const key = String(o[keyName] ?? '');
        const rest = { ...o };
        delete rest[keyName];
        map[key] = rest;
      });
      return { text: JSON.stringify(map, null, indent), items: objects.length };
    }

    if (shape === 'ndjson') {
      // One object per line; indent/minify don't apply to JSON Lines.
      return { text: objects.map((o) => JSON.stringify(o)).join('\n'), items: objects.length };
    }

    return { text: JSON.stringify(objects, null, indent), items: objects.length };
  }

  async function convert() {
    if (!input.value.trim()) {
      rawOutput = '';
      output.textContent = '';
      count.textContent = '';
      status.classList.add('hidden');
      return;
    }
    try {
      const delim = resolveDelimiter();
      const matrix = parseCsv(input.value, delim);
      const { text, items } = build(matrix);
      rawOutput = text;
      await hl(output, text, 'json');
      count.textContent = `${items} ${items === 1 ? 'record' : 'records'}`;
      const label = delim === '\t' ? 'tab' : delim === ';' ? 'semicolon' : delim === '|' ? 'pipe'
        : delim === ':' ? 'colon' : delim === ' ' ? 'space' : 'comma';
      showStatus(`Converted ${items} ${items === 1 ? 'record' : 'records'} using ${label} delimiter ✓`, true);
    } catch (e) {
      rawOutput = '';
      output.textContent = '';
      count.textContent = '';
      showStatus(`CSV error: ${(e as Error).message}`, false);
    }
  }

  document.getElementById('c2j-convert')!.addEventListener('click', convert);
  [delimSel, shapeSel, indentSel].forEach((el) => el.addEventListener('change', convert));
  [headerBox, parseBox, nullBox, minifyBox].forEach((el) => el.addEventListener('change', convert));

  document.getElementById('c2j-clear')!.addEventListener('click', () => {
    input.value = '';
    refresh();
    rawOutput = '';
    output.textContent = '';
    count.textContent = '';
    status.classList.add('hidden');
  });

  document.getElementById('c2j-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const ext = shapeSel.value === 'ndjson' ? 'jsonl' : 'json';
    const blob = new Blob([rawOutput], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `converted.${ext}`;
    a.click();
    URL.revokeObjectURL(url);
  });

  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => { input.value = String(reader.result ?? ''); refresh(); convert(); };
    reader.onerror = () => showStatus('Could not read file.', false);
    reader.readAsText(file);
  }

  const fileInput = document.getElementById('c2j-file') as HTMLInputElement;
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  // Drag-and-drop a CSV onto the input pane.
  ['dragover', 'dragenter'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.style.outline = '2px solid #5e6ad2'; }));
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, () => { drop.style.outline = ''; }));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) loadFile(file);
  });
</script>

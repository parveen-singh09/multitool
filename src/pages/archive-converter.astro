---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="archive-converter">
  <ArchiveConvert slug="archive-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online archive converter turns one archive format into another —
      upload a RAR, 7Z, TAR, GZ, ISO, CAB, DEB, BZ2 and more, then pick your target
      (ZIP, 7Z, TAR, TAR.GZ or TAR.BZ2) from the dropdown and convert.
    </p>
    <p>
      Conversion is handled on our servers. Your file is
      uploaded to our servers, converted on their
      servers, and returned as a download link — so this tool works with formats
      that no browser can open on its own, like proprietary or disk-image archives.
    </p>
  </div>
</ToolLayout>

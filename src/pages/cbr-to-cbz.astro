---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="cbr-to-cbz">
  <ArchiveConvert slug="cbr-to-cbz" from="cbr" to="cbz" noun="ebook" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CBR to CBZ converter converts RAR-based comic-book CBR archives to the more widely-supported ZIP-based CBZ.
    </p>
    <p>
      Conversion is handled on our servers, because these
      ebook formats can't be read reliably in a browser. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

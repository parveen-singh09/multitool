---
import ToolLayout from '../layouts/ToolLayout.astro';
import DocConvert from '../components/DocConvert.astro';
---

<ToolLayout slug="ppt-to-epub">
  <DocConvert slug="ppt-to-epub" outLabel="EPUB" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PowerPoint to EPUB converter converts a PowerPoint (.pptx) presentation into an EPUB ebook. It extracts the slide text — visual layout is not reproduced. Everything runs entirely in your browser, so your files are never uploaded to a server.
    </p>
    <p>
      Paste your content or attach a file, click Convert, then download or copy the result.
      Conversions happen offline through your browser, so the tool works without a network
      connection and nothing leaves your device.
    </p>
  </div>
</ToolLayout>

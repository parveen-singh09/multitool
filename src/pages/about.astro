---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { tools } from '../data/tools';
import { SITE } from '../data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `About ${SITE.name}`,
  url: `${SITE.url}/about`,
  description: `Learn how ${SITE.name} builds fast, free online tools.`,
};
---

<Layout
  title="About"
  description={`Learn how ${SITE.name} builds fast, free online tools — no sign-up required.`}
  jsonLd={jsonLd}
>
  <Header />

  <main class="container-page py-14">
    <div class="mx-auto max-w-3xl">
      <span class="eyebrow text-primary-hover">About</span>
      <h1 class="display-md mt-3 text-ink">Tools that work for you, not against you</h1>

      <div class="mt-8 flex flex-col gap-4 text-[15px] leading-relaxed text-ink-muted">
        <p>
          <strong class="text-ink">{SITE.name}</strong> is a free collection of
          {tools.length} online utilities, each designed to do one job and do it
          well. No accounts, no paywalls, no clutter — just the tool you came for.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">How it works</h2>
        <p>
          Each tool is a focused, single-purpose utility built on native web
          standards. Pick the tool you need, enter your input, and get the result
          right away — no setup and no sign-up.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">What we believe</h2>
        <ul class="flex list-disc flex-col gap-2 pl-5">
          <li><strong class="text-ink">No sign-up.</strong> Every tool is usable the moment the page loads.</li>
          <li><strong class="text-ink">Speed matters.</strong> A lightweight static site that loads instantly.</li>
          <li><strong class="text-ink">Free forever.</strong> No paywalls and no usage limits.</li>
          <li><strong class="text-ink">Focused tools.</strong> Each utility does one job and does it well.</li>
        </ul>

        <div class="mt-6">
          <a href="/tools" class="btn btn-primary">Explore all {tools.length} tools</a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

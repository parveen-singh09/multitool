---
import ToolLayout from '../layouts/ToolLayout.astro';

const squares = ['10x10','12x12','14x14','16x16','18x18','20x20','22x22','24x24','26x26','32x32','36x36','40x40','44x44','48x48','52x52','64x64','72x72','80x80','88x88','96x96','104x104','120x120','132x132','144x144'];
const rects = ['8x18','8x32','12x26','12x36','16x36','16x48'];
---

<ToolLayout slug="data-matrix-generator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_20rem]">

    <div class="flex flex-col gap-5">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Data to encode
        <textarea id="dm-text" class="field min-h-24 resize-y font-mono text-[13px]" placeholder="Enter text or numbers…" spellcheck="false">TOOLSILK-2026</textarea>
      </label>

      <div class="panel p-4">
        <div class="mb-3 font-display text-sm font-medium text-ink">Options</div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Symbology
            <select id="dm-mode" class="field">
              <option value="datamatrix" selected>Data Matrix (ECC 200)</option>
              <option value="gs1datamatrix">GS1 Data Matrix</option>
            </select></label>

          <label class="col-span-2 flex flex-col gap-1 text-sm text-ink-subtle sm:col-span-1">Size
            <select id="dm-version" class="field">
              <option value="auto" selected>Automatic</option>
              <optgroup label="Square">
                {squares.map((v) => <option value={v}>{v}</option>)}
              </optgroup>
              <optgroup label="Rectangular">
                {rects.map((v) => <option value={v}>{v}</option>)}
              </optgroup>
            </select></label>

          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Rotation
            <select id="dm-rotate" class="field">
              <option value="N" selected>0°</option>
              <option value="R">90°</option>
              <option value="I">180°</option>
              <option value="L">270°</option>
            </select></label>

          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Foreground
            <input id="dm-fg" type="color" value="#010102" class="field h-10 cursor-pointer p-1" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Background
            <input id="dm-bg" type="color" value="#ffffff" class="field h-10 cursor-pointer p-1" /></label>
          <label class="flex items-center gap-2 text-sm text-ink-subtle">
            <input id="dm-transparent" type="checkbox" class="size-4" /> Transparent</label>

          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Module size: <span id="dm-scale-val">6</span> px
            <input id="dm-scale" type="range" min="2" max="16" value="6" class="w-full" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Quiet zone: <span id="dm-quiet-val">2</span>
            <input id="dm-quiet" type="range" min="0" max="10" value="2" class="w-full" /></label>
          <label class="flex items-center gap-2 text-sm text-ink-subtle" title="Interpret ^NNN escapes and \n">
            <input id="dm-parse" type="checkbox" class="size-4" /> Parse escapes</label>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <div class="panel panel-lift dm-checker flex aspect-square w-full items-center justify-center p-6">
        <canvas id="dm-canvas" class="max-h-full max-w-full rounded-sm" aria-label="Data Matrix preview"></canvas>
      </div>
      <div class="flex flex-col gap-2">
        <button id="dm-png" type="button" class="btn btn-primary">Download PNG</button>
        <button id="dm-svg" type="button" class="btn btn-secondary">Download SVG</button>
      </div>
      <p id="dm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Data Matrix generator encodes any text or numbers into a compact
      Data Matrix 2D barcode — the square dot-matrix code widely used to mark
      small parts, electronics and documents because it packs a lot of data into
      a tiny footprint. Choose a fixed square or rectangular size, set colors and
      rotation, add a quiet zone, or switch to GS1 Data Matrix for supply-chain
      application identifiers. Preview updates live and downloads are always
      high-resolution PNG or infinitely scalable SVG.
    </p>
    <p>
      Everything is encoded with the ECC 200 standard.
    </p>
  </div>
</ToolLayout>

<style>

  .dm-checker {
    background-image:
      linear-gradient(45deg, var(--color-surface-3) 25%, transparent 25%),
      linear-gradient(-45deg, var(--color-surface-3) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, var(--color-surface-3) 75%),
      linear-gradient(-45deg, transparent 75%, var(--color-surface-3) 75%);
    background-size: 16px 16px;
    background-position: 0 0, 0 8px, 8px -8px, -8px 0;
  }
</style>

<script>
  import { toCanvas, toSVG, type RenderOpts } from '../lib/barcode';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const canvas = $<HTMLCanvasElement>('dm-canvas');
  const err = $('dm-error');
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  function opts(scale: number): RenderOpts {
    const o: RenderOpts = {
      bcid: $<HTMLSelectElement>('dm-mode').value,
      text: $<HTMLTextAreaElement>('dm-text').value,
      scale,
      rotate: $<HTMLSelectElement>('dm-rotate').value,
      barcolor: $<HTMLInputElement>('dm-fg').value.replace('#', ''),
      parse: $<HTMLInputElement>('dm-parse').checked,
    };
    const version = $<HTMLSelectElement>('dm-version').value;
    if (version !== 'auto') o.version = version;
    if (!$<HTMLInputElement>('dm-transparent').checked) {
      o.backgroundcolor = $<HTMLInputElement>('dm-bg').value.replace('#', '');
    }
    const quiet = Number($<HTMLInputElement>('dm-quiet').value);
    if (quiet > 0) { o.paddingwidth = quiet; o.paddingheight = quiet; }
    return o;
  }

  function download(href: string, name: string) {
    const a = document.createElement('a'); a.href = href; a.download = name; a.click();
  }

  async function draw() {
    $('dm-scale-val').textContent = $<HTMLInputElement>('dm-scale').value;
    $('dm-quiet-val').textContent = $<HTMLInputElement>('dm-quiet').value;
    if (!$<HTMLTextAreaElement>('dm-text').value.trim()) { setErr('Enter some text to encode.'); return; }
    try {
      await toCanvas(canvas, opts(Number($<HTMLInputElement>('dm-scale').value)));
      setErr('');
    } catch {
      setErr('Could not encode that data at the chosen size.');
    }
  }

  let t: number;
  const debounced = () => { clearTimeout(t); t = window.setTimeout(draw, 150); };
  document.querySelectorAll('#dm-text, #dm-mode, #dm-version, #dm-rotate, #dm-fg, #dm-bg, #dm-transparent, #dm-scale, #dm-quiet, #dm-parse')
    .forEach((el) => el.addEventListener('input', debounced));

  $('dm-png').addEventListener('click', async () => {

    try {
      const out = document.createElement('canvas');
      await toCanvas(out, opts(16));
      download(out.toDataURL('image/png'), 'datamatrix.png');
    } catch { setErr('Could not encode that data at the chosen size.'); }
  });
  $('dm-svg').addEventListener('click', async () => {
    try {
      const svg = await toSVG(opts(6));
      const url = URL.createObjectURL(new Blob([svg], { type: 'image/svg+xml' }));
      download(url, 'datamatrix.svg');
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch { setErr('Could not encode that data at the chosen size.'); }
  });

  draw();
</script>

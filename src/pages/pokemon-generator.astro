---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="pokemon-generator">
  <div class="flex flex-col gap-7">

    <div class="flex flex-wrap items-end justify-center gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="pk-count" type="number" min="1" max="50" value="1" class="field w-24" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Generation
        <select id="pk-gen" class="field w-44">
          <option value="">Any generation</option>
          <option value="1-151">Gen 1 — Kanto</option>
          <option value="152-251">Gen 2 — Johto</option>
          <option value="252-386">Gen 3 — Hoenn</option>
          <option value="387-493">Gen 4 — Sinnoh</option>
          <option value="494-649">Gen 5 — Unova</option>
          <option value="650-721">Gen 6 — Kalos</option>
          <option value="722-809">Gen 7 — Alola</option>
          <option value="810-905">Gen 8 — Galar</option>
          <option value="906-1025">Gen 9 — Paldea</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Type
        <select id="pk-type" class="field w-40">
          <option value="">Any type</option>
        </select>
      </label>
      <label class="flex items-center gap-2 self-center pt-5 text-sm text-ink-subtle">
        <input id="pk-shiny" type="checkbox" class="h-4 w-4 accent-primary" /> Shiny ✨
      </label>
      <button id="pk-go" class="btn btn-primary">Generate</button>
    </div>

    <p id="pk-status" class="h-5 text-center text-sm text-ink-tertiary" aria-live="polite"></p>

    <div id="pk-grid" class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free random Pokémon generator draws one or more Pokémon at random and
      shows each with high-resolution official artwork, full base stats (HP,
      Attack, Defense, Special Attack, Special Defense and Speed), types,
      abilities, height, weight and its Pokédex entry. Narrow the pool by
      generation (Kanto through Paldea) or by type, flip the shiny toggle for the
      alternate coloration, and roll a full team of up to twelve at once — handy
      for nuzlockes, randomizer runs, art prompts or just settling which starter
      to main. Data comes live from the open
      <a href="https://pokeapi.co" target="_blank" rel="noopener" class="text-primary-hover underline">PokéAPI</a>;
      picks are made in your browser and nothing about you is uploaded.
    </p>
  </div>
</ToolLayout>

<style is:global>

  .pk-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid var(--color-hairline, #26262e);
    background: var(--color-surface-2, #16161c);
    position: relative;
    overflow: hidden;
  }
  .pk-card::before {

    content: '';
    position: absolute;
    inset: -40% 0 auto 0;
    height: 60%;
    background: radial-gradient(ellipse at 50% 0, var(--pk-accent, #5e6ad2) 0%, transparent 70%);
    opacity: 0.28;
    pointer-events: none;
  }
  .pk-art {
    width: 100%;
    height: 180px;
    object-fit: contain;
    z-index: 1;
    filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.35));
  }
  .pk-art-skeleton {
    height: 180px;
    border-radius: 0.75rem;
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.09) 37%, rgba(255,255,255,0.04) 63%);
    background-size: 400% 100%;
    animation: pk-shimmer 1.3s ease-in-out infinite;
  }
  @keyframes pk-shimmer { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }
  .pk-badge {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 1px 1px rgba(0,0,0,0.25);
  }
  .pk-stat-row { display: grid; grid-template-columns: 3.2rem 1fr 2rem; align-items: center; gap: 0.5rem; }
  .pk-stat-label { font-size: 0.72rem; color: var(--color-ink-tertiary, #8b8b96); }
  .pk-stat-track { height: 7px; border-radius: 9999px; background: rgba(255,255,255,0.07); overflow: hidden; }
  .pk-stat-fill { display: block; height: 100%; border-radius: 9999px; transition: width 0.6s cubic-bezier(0.22,1,0.36,1); }
  .pk-stat-val { font-size: 0.72rem; text-align: right; font-variant-numeric: tabular-nums; color: var(--color-ink-subtle, #c4c4cc); }
</style>

<script>
  import { randInt, sample } from '../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const grid = $('pk-grid');
  const status = $('pk-status');
  const countEl = $('pk-count') as HTMLInputElement;
  const genEl = $('pk-gen') as HTMLSelectElement;
  const typeEl = $('pk-type') as HTMLSelectElement;
  const shinyEl = $('pk-shiny') as HTMLInputElement;

  const API = 'https://pokeapi.co/api/v2';
  const MAX_DEX = 1025; 

  const TYPE_COLORS: Record<string, string> = {
    normal: '#9fa19f', fire: '#ff9d55', water: '#5090d6', electric: '#f4d23c',
    grass: '#63bc5a', ice: '#73cec0', fighting: '#ce4069', poison: '#ab6ac8',
    ground: '#d97845', flying: '#8fa9de', psychic: '#fa7179', bug: '#91c12f',
    rock: '#c5b78c', ghost: '#5269ad', dragon: '#0b6dc3', dark: '#5a5465',
    steel: '#5a8ea1', fairy: '#ec8fe6',
  };
  const STAT_LABELS: Record<string, string> = {
    hp: 'HP', attack: 'ATK', defense: 'DEF',
    'special-attack': 'SpA', 'special-defense': 'SpD', speed: 'SPD',
  };

  const TYPE_EMOJI: Record<string, string> = {
    normal: '⚪', fire: '🔥', water: '💧', electric: '⚡', grass: '🍃', ice: '❄️',
    fighting: '🥊', poison: '☠️', ground: '🏜️', flying: '🕊️', psychic: '🔮',
    bug: '🐛', rock: '🪨', ghost: '👻', dragon: '🐉', dark: '🌙', steel: '⚙️', fairy: '🧚',
  };

  for (const t of Object.keys(TYPE_COLORS).sort()) {
    const opt = document.createElement('option');
    opt.value = t;
    opt.textContent = `${TYPE_EMOJI[t] ?? ''} ${t[0].toUpperCase() + t.slice(1)}`;
    typeEl.appendChild(opt);
  }

  const detailCache = new Map<number, any>();
  const speciesCache = new Map<number, any>();
  const typeIdsCache = new Map<string, number[]>();

  async function j(url: string) {
    const r = await fetch(url);
    if (!r.ok) throw new Error(`${r.status} ${url}`);
    return r.json();
  }

  async function candidateIds(): Promise<number[]> {
    const [lo, hi] = genEl.value ? genEl.value.split('-').map(Number) : [1, MAX_DEX];

    if (!typeEl.value) {
      const ids: number[] = [];
      for (let i = lo; i <= hi; i++) ids.push(i);
      return ids;
    }

    let typeIds = typeIdsCache.get(typeEl.value);
    if (!typeIds) {
      const data = await j(`${API}/type/${typeEl.value}`);
      typeIds = (data.pokemon as any[])
        .map((p) => Number(p.pokemon.url.split('/').filter(Boolean).pop()))
        .filter((id) => id <= MAX_DEX);
      typeIdsCache.set(typeEl.value, typeIds);
    }
    return typeIds.filter((id) => id >= lo && id <= hi);
  }

  function flavor(species: any): string {
    const entries = (species?.flavor_text_entries ?? []).filter(
      (e: any) => e.language?.name === 'en',
    );
    if (!entries.length) return '';
    const txt = entries[randInt(0, entries.length - 1)].flavor_text as string;
    return txt.replace(/[\n\f\r]+/g, ' ').replace(/\s+/g, ' ').trim();
  }

  function cardHTML(d: any, species: any, shiny: boolean): string {
    const name = (d.name as string).replace(/-/g, ' ');
    const dex = String(d.id).padStart(4, '0');
    const artwork = d.sprites?.other?.['official-artwork'] ?? {};
    const art =
      (shiny ? artwork.front_shiny : artwork.front_default) ??
      artwork.front_default ??
      d.sprites?.front_default ??
      '';
    const types: string[] = d.types.map((t: any) => t.type.name);
    const accent = TYPE_COLORS[types[0]] ?? '#5e6ad2';

    const typeBadges = types
      .map((t) => `<span class="pk-badge" style="background:${TYPE_COLORS[t] ?? '#777'}">${t}</span>`)
      .join(' ');

    const stats = (d.stats as any[])
      .map((s) => {
        const key = s.stat.name;
        const val = s.base_stat as number;
        const pctW = Math.min(100, Math.round((val / 200) * 100));
        const hue = val >= 100 ? 140 : val >= 60 ? 45 : 0;
        return `<div class="pk-stat-row">
          <span class="pk-stat-label">${STAT_LABELS[key] ?? key}</span>
          <span class="pk-stat-track"><span class="pk-stat-fill" style="width:${pctW}%;background:hsl(${hue} 70% 55%)"></span></span>
          <span class="pk-stat-val">${val}</span>
        </div>`;
      })
      .join('');
    const total = (d.stats as any[]).reduce((a, s) => a + s.base_stat, 0);

    const abilities = (d.abilities as any[])
      .map((a) => {
        const nm = (a.ability.name as string).replace(/-/g, ' ');
        return a.is_hidden ? `${nm} (hidden)` : nm;
      })
      .join(', ');

    const gen = (species?.generation?.name ?? '').replace('generation-', 'Gen ').toUpperCase();
    const desc = flavor(species);

    return `<div class="pk-card" style="--pk-accent:${accent}">
      <img class="pk-art" src="${art}" alt="Official artwork of ${name}" loading="lazy" />
      <div class="flex items-baseline justify-between">
        <h3 class="text-lg font-bold capitalize text-ink">${name}</h3>
        <span class="font-mono text-sm text-ink-tertiary">#${dex}</span>
      </div>
      <div class="flex flex-wrap gap-1.5">${typeBadges}</div>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-[13px] text-ink-subtle">
        <span>Height <b class="text-ink">${(d.height / 10).toFixed(1)} m</b></span>
        <span>Weight <b class="text-ink">${(d.weight / 10).toFixed(1)} kg</b></span>
        ${gen ? `<span>${gen}</span>` : ''}
      </div>
      <div class="flex flex-col gap-1">${stats}
        <div class="pk-stat-row"><span class="pk-stat-label font-semibold">TOT</span><span></span><span class="pk-stat-val font-semibold text-ink">${total}</span></div>
      </div>
      <p class="text-[13px] text-ink-subtle"><b class="text-ink-muted">Abilities:</b> <span class="capitalize">${abilities}</span></p>
      ${desc ? `<p class="text-[13px] italic leading-relaxed text-ink-tertiary">${desc}</p>` : ''}
    </div>`;
  }

  async function generate() {
    const n = Math.max(1, Math.min(50, Number(countEl.value) || 1));
    const btn = $('pk-go') as HTMLButtonElement;
    btn.disabled = true;
    status.textContent = 'Summoning…';
    grid.innerHTML = Array.from({ length: n }, () => `<div class="pk-card"><div class="pk-art-skeleton"></div></div>`).join('');

    try {
      const pool = await candidateIds();
      if (!pool.length) {
        status.textContent = 'No Pokémon match that generation + type combo. Try loosening a filter.';
        grid.innerHTML = '';
        return;
      }

      const ids = pool.length >= n
        ? sample(pool, n)
        : Array.from({ length: n }, () => pool[randInt(0, pool.length - 1)]);
      const shiny = shinyEl.checked;

      const cards = await Promise.all(
        ids.map(async (id) => {
          let d = detailCache.get(id);
          if (!d) { d = await j(`${API}/pokemon/${id}`); detailCache.set(id, d); }
          let sp = speciesCache.get(id);
          if (!speciesCache.has(id)) {
            sp = await j(`${API}/pokemon-species/${id}`).catch(() => null);
            speciesCache.set(id, sp);
          }
          return cardHTML(d, sp, shiny);
        }),
      );
      grid.innerHTML = cards.join('');
      status.textContent = `${n} random Pokémon${shiny ? ' (shiny)' : ''} from ${pool.length} candidates.`;
    } catch (err) {
      status.textContent = 'Could not reach the Pokédex. Check your connection and try again.';
      grid.innerHTML = '';
      console.error(err);
    } finally {
      btn.disabled = false;
    }
  }

  $('pk-go').addEventListener('click', generate);
  generate();
</script>

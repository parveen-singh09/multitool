---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { categories, toolsByCategory } from '../data/tools';
import { SITE } from '../data/site';
import ArchiveConvert from '../components/ArchiveConvert.astro';

const ANY_TARGETS = [
  'pdf', 'docx', 'doc', 'odt', 'rtf', 'txt', 'html',
  'jpg', 'png', 'webp', 'gif', 'bmp', 'tiff', 'svg', 'ico',
  'mp3', 'wav', 'flac', 'aac', 'ogg', 'm4a',
  'mp4', 'webm', 'mkv', 'mov', 'avi',
  'xlsx', 'csv', 'pptx',
  'epub', 'mobi', 'zip', '7z',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/tools?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const catStyle: Record<string, { bg: string; ring: string; fg: string; icon: string }> = {
  Text: { bg: 'bg-sky-500/12', ring: 'ring-sky-500/20', fg: 'text-sky-400', icon: 'M4 7V4h16v3 M9 20h6 M12 4v16' },
  Developer: { bg: 'bg-violet-500/12', ring: 'ring-violet-500/20', fg: 'text-violet-400', icon: 'm16 18 6-6-6-6 M8 6l-6 6 6 6' },
  Image: { bg: 'bg-emerald-500/12', ring: 'ring-emerald-500/20', fg: 'text-emerald-400', icon: 'M3 3h18v18H3z M8.5 8.5a1.5 1.5 0 1 0 0 3 M21 15l-5-5L5 21' },
  Converters: { bg: 'bg-amber-500/12', ring: 'ring-amber-500/20', fg: 'text-amber-400', icon: 'M21 12a9 9 0 1 1-3-6.7L21 8 M21 3v5h-5' },
  Calculators: { bg: 'bg-rose-500/12', ring: 'ring-rose-500/20', fg: 'text-rose-400', icon: 'M5 2h14v20H5z M8 6h8 M8 11h2 M12 11h2 M8 15h2 M12 15h2' },
  Generators: { bg: 'bg-fuchsia-500/12', ring: 'ring-fuchsia-500/20', fg: 'text-fuchsia-400', icon: 'M12 3l1.9 5.8L20 11l-6.1 2.2L12 19l-1.9-5.8L4 11z' },
  Security: { bg: 'bg-teal-500/12', ring: 'ring-teal-500/20', fg: 'text-teal-400', icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z' },
  PDF: { bg: 'bg-red-500/12', ring: 'ring-red-500/20', fg: 'text-red-400', icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6' },
  'Audio & Video': { bg: 'bg-indigo-500/12', ring: 'ring-indigo-500/20', fg: 'text-indigo-400', icon: 'm22 8-6 4 6 4V8z M2 6h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2z' },
  'Device & Sensors': { bg: 'bg-cyan-500/12', ring: 'ring-cyan-500/20', fg: 'text-cyan-400', icon: 'M12 13l4-4 M3.5 16a9 9 0 1 1 17 0z' },
};
---

<Layout bare jsonLd={jsonLd}>
  <Header landing />

  <main>
    <section class="relative flex min-h-svh items-center overflow-hidden">
      <div class="container-page w-full py-12">
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-12">
          
          <div class="text-center lg:text-left">
            <span class="status-badge mx-auto lg:mx-0">
              <span class="h-1.5 w-1.5 rounded-full" style="background:#27a644"></span>
              500+ free tools
            </span>

            <h1 class="display-lg mt-6 text-balance text-ink">
              Free online tools<br />
              <span class="text-ink-subtle">for images, text &amp; more.</span>
            </h1>

            <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-ink-muted lg:mx-0">
              Convert, compress, edit and create — images, audio, video, documents, archives and more.
            </p>

            <div class="mt-8 flex justify-center lg:justify-start">
              <a href="/tools" class="btn btn-secondary inline-flex items-center gap-2">
                Browse all tools
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </div>
          </div>

          
          <div class="flex flex-col gap-6">
            <div id="fmt-row" class="flex items-center justify-center gap-2 sm:gap-4">
              <div class="fmt-slot">
                <div class="fmt-card">
                  <button id="fmt-from-btn" type="button" class="fmt-inner" aria-haspopup="listbox" aria-expanded="false" aria-label="Source format">
                    <span id="fmt-from-icon" class="fmt-icon text-ink-subtle"></span>
                    <span id="fmt-from" class="fmt-label">SVG</span>
                    <svg class="fmt-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                  </button>
                </div>
                <div id="fmt-from-menu" class="fmt-panel hidden" role="dialog" aria-label="Choose source format">
                  <div class="fmt-search">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                    <input id="fmt-search" type="text" placeholder="Search format" autocomplete="off" spellcheck="false" />
                  </div>
                  <div class="fmt-body">
                    <div id="fmt-cats" class="fmt-cats" role="tablist"></div>
                    <div id="fmt-chips" class="fmt-chips"></div>
                  </div>
                </div>
              </div>
              <span class="fmt-line"></span>
              <span class="flex h-9 w-9 flex-none items-center justify-center rounded-full border border-hairline bg-surface-2 text-primary-hover">
                <svg class="fmt-spin-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
              </span>
              <span class="fmt-line fmt-line-rev"></span>
              <div class="fmt-slot">
                <div class="fmt-card">
                  <button id="fmt-to-btn" type="button" class="fmt-inner" aria-haspopup="listbox" aria-expanded="false" aria-label="Target format">
                    <span id="fmt-to-icon" class="fmt-icon text-primary-hover"></span>
                    <span id="fmt-to" class="fmt-label">PNG</span>
                    <svg class="fmt-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                  </button>
                </div>
                <div id="fmt-to-menu" class="fmt-menu hidden" role="listbox"></div>
              </div>
            </div>

            <div class="text-left">
              <ArchiveConvert slug="file-converter" targets={ANY_TARGETS} noun="file" smart={true} syncTarget={true} />
            </div>
          </div>
        </div>
      </div>
    </section>

    
    <section class="container-page py-16">
      <div class="mb-10 flex flex-col gap-2">
        <span class="eyebrow text-primary-hover">{categories.length} categories</span>
        <h2 class="display-md text-ink">Pick a category, start working</h2>
        <p class="mt-2 max-w-xl text-lg leading-relaxed text-ink-muted">
          500+ tools grouped so you land on the right one fast.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((category) => {
          const s = catStyle[category];
          const catTools = toolsByCategory(category);
          const sample = catTools.slice(0, 3).map((t) => t.name).join(' · ');
          return (
            <a
              href={`/${category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')}`}
              class="panel panel-lift group flex items-start gap-4 p-5 transition-colors duration-150 hover:bg-surface-2 hover:border-hairline-strong"
            >
              <span class={`flex h-10 w-10 flex-none items-center justify-center rounded-lg ring-1 ${s.bg} ${s.ring} ${s.fg}`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon} /></svg>
              </span>
              <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="font-display text-[17px] font-medium tracking-[-0.01em] text-ink">{category}</h3>
                  <span class="status-badge">{catTools.length}</span>
                </div>
                <p class="mt-1 truncate text-sm text-ink-subtle">{sample}</p>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    
    <section class="container-page py-16">
      <div class="rounded-xl border border-hairline bg-surface-1 p-6 md:p-10">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div>
            <span class="eyebrow text-primary-hover">Why it's different</span>
            <h2 class="mt-2 display-md text-ink">Nothing leaves your device</h2>
          </div>
          <div class="flex flex-col gap-5 md:col-span-2">
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-none text-primary-hover" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="10" width="16" height="10" rx="2" /><path d="M8 10V7a4 4 0 0 1 8 0v3" /></svg>
              <p class="text-ink-muted"><span class="text-ink">Private by default.</span> Files are processed right in your browser — they're never uploaded to a server.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-none text-primary-hover" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9z" /></svg>
              <p class="text-ink-muted"><span class="text-ink">Instant.</span> No round-trips, no queues. Results happen the moment you hit go.</p>
            </div>
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-none text-primary-hover" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
              <p class="text-ink-muted"><span class="text-ink">Free, no account.</span> Every tool is free to use as often as you like — no sign-up, no limits.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    
    <section class="container-page py-16">
      <div class="max-w-3xl">
        <h2 class="display-md text-ink">Built for quick jobs and real work alike</h2>
        <div class="mt-6 flex flex-col gap-4 text-lg leading-relaxed text-ink-muted">
          <p>
            {SITE.name} pulls together images, text, developer, and everyday utilities into one place — so you stop hunting across a dozen single-purpose sites.
          </p>
          <p>
            Convert a file, format some JSON, generate a QR code, or crunch a calculation — each tool runs on its own, right in the browser, with nothing to install.
          </p>
          <p>
            The collection keeps growing. New tools land regularly, so the next thing you need is likely already here.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer full />

  <style>
    
    .fmt-card {
      position: relative;
      width: 6.5rem;
      height: 6.5rem;
      border-radius: 18px;
    }
    /* ponytail: fixed 6.5rem cards + spinner + lines overflow ~320px phones */
    @media (max-width: 380px) {
      .fmt-card { width: 5rem; height: 5rem; }
    }
    .fmt-card {
      padding: 1.5px;
      overflow: hidden;
      isolation: isolate;
      background: var(--color-hairline, #23252a);
    }
    .fmt-card::before {
      content: "";
      position: absolute;
      inset: -60%;
      z-index: -2;
      background: conic-gradient(
        from 0deg,
        transparent 0deg,
        transparent 200deg,
        #5e6ad2 280deg,
        #828fff 320deg,
        transparent 360deg
      );
      animation: fmt-spin 3.5s linear infinite;
    }
    .fmt-card { cursor: pointer; }
    .fmt-inner {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      height: 100%;
      border-radius: 16.5px;
      background: var(--color-surface-3, #18191a);
    }
    
    button.fmt-inner {
      cursor: pointer;
      border: 0;
      font: inherit;
      color: inherit;
    }
    
    .fmt-slot { position: relative; }
    
    .fmt-menu {
      position: absolute;
      top: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      z-index: 30;
      width: 8.5rem;
      max-height: 15rem;
      overflow-y: auto;
      padding: 0.3rem;
      border-radius: 12px;
      border: 1px solid var(--color-hairline, #23252a);
      background: var(--color-surface-2, #141516);
      box-shadow: 0 16px 40px -12px rgba(0,0,0,0.6);
    }
    
    .fmt-panel {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      z-index: 30;
      width: min(27rem, calc(100vw - 2rem));
      border-radius: 14px;
      border: 1px solid var(--color-hairline, #23252a);
      background: var(--color-surface-2, #141516);
      box-shadow: 0 24px 60px -16px rgba(0,0,0,0.7);
      overflow: hidden;
    }
    .fmt-search {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 0.75rem;
      border-bottom: 1px solid var(--color-hairline, #23252a);
      color: var(--color-ink-tertiary, #8a8f98);
    }
    .fmt-search input {
      flex: 1;
      background: transparent;
      border: 0;
      outline: none;
      font: inherit;
      font-size: 14px;
      color: var(--color-ink, #f7f8f8);
    }
    .fmt-search input::placeholder { color: var(--color-ink-tertiary, #8a8f98); }
    .fmt-body { display: flex; height: 17rem; }
    .fmt-cats {
      flex: 0 0 8.5rem;
      overflow-y: auto;
      padding: 0.35rem;
      border-right: 1px solid var(--color-hairline, #23252a);
    }
    .fmt-chips {
      flex: 1;
      overflow-y: auto;
      padding: 0.5rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: min-content;
      gap: 0.4rem;
      align-content: start;
    }
    :global(.fmt-cat) {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 0.5rem 0.6rem;
      border-radius: 8px;
      border: 0;
      background: transparent;
      color: var(--color-ink-subtle, #b3b8c0);
      font: inherit;
      font-size: 13.5px;
      cursor: pointer;
      text-align: left;
      transition: background 0.12s ease, color 0.12s ease;
    }
    :global(.fmt-cat:hover) { background: var(--color-surface-3, #18191a); color: var(--color-ink, #f7f8f8); }
    :global(.fmt-cat[aria-selected="true"]) { background: var(--color-surface-3, #18191a); color: var(--color-ink, #f7f8f8); }
    :global(.fmt-cat svg) { opacity: 0.5; }
    :global(.fmt-chip) {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.55rem 0.4rem;
      border-radius: 8px;
      border: 1px solid var(--color-hairline, #23252a);
      background: var(--color-surface-1, #0c0d0e);
      color: var(--color-ink, #f7f8f8);
      font: inherit;
      font-size: 12.5px;
      font-weight: 600;
      letter-spacing: 0.03em;
      cursor: pointer;
      transition: background 0.12s ease, border-color 0.12s ease;
    }
    :global(.fmt-chip:hover:not(:disabled)) { background: var(--color-surface-3, #18191a); border-color: var(--color-hairline-strong, #33353b); }
    :global(.fmt-chip[aria-selected="true"]) { background: var(--color-primary, #5e6ad2); border-color: var(--color-primary, #5e6ad2); color: #fff; }
    :global(.fmt-chip:disabled) { opacity: 0.32; cursor: not-allowed; }
    :global(.fmt-chips-empty) { grid-column: 1 / -1; padding: 1rem 0.4rem; font-size: 13px; color: var(--color-ink-tertiary, #8a8f98); text-align: center; }
    
    :global(.fmt-opt) {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.5rem 0.65rem;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--color-ink, #f7f8f8);
      background: transparent;
      border: 0;
      cursor: pointer;
      text-align: left;
      transition: background 0.12s ease;
    }
    :global(.fmt-opt:hover) { background: var(--color-surface-3, #18191a); }
    :global(.fmt-opt[aria-selected="true"]) { background: var(--color-primary, #5e6ad2); color: #fff; }
    :global(.fmt-opt svg) { flex: none; opacity: 0.7; }
    .fmt-chevron {
      position: absolute;
      right: 0.6rem;
      bottom: 0.5rem;
      color: var(--color-ink-tertiary, #8a8f98);
    }
    .fmt-icon {
      display: flex;
      transition: opacity 0.3s ease, transform 0.3s ease;
    }
    .fmt-label {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.05em;
      color: var(--color-ink, #f7f8f8);
      transition: opacity 0.3s ease;
    }
    .fmt-swap { opacity: 0; transform: translateY(3px); }
    @keyframes fmt-spin { to { transform: rotate(1turn); } }

    
    .fmt-line {
      position: relative;
      flex: 0 0 auto;
      width: 1.25rem;
      height: 2px;
      border-radius: 2px;
      background: var(--color-hairline, #23252a);
      overflow: hidden;
    }
    @media (min-width: 640px) { .fmt-line { width: 3rem; } }
    .fmt-line::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 60%;
      border-radius: 2px;
      background: linear-gradient(90deg, transparent, #e5484d, #ff6b6b, transparent);
      animation: fmt-flow 1.8s linear infinite;
    }
    .fmt-line-rev::after { animation-direction: reverse; }
    @keyframes fmt-flow {
      from { transform: translateX(-100%); }
      to { transform: translateX(200%); }
    }

    
    .fmt-spin-icon { animation: fmt-spin 6s linear infinite; }

    
    #fmt-row { transition: gap 0.4s ease; }
    #fmt-row.fmt-picked { gap: 0.75rem; }

    @media (prefers-reduced-motion: reduce) {
      .fmt-card::before,
      .fmt-line::after,
      .fmt-spin-icon { animation: none; }
    }
  </style>

  <script>
    import { CONVERT_MATRIX } from '../data/convertMatrix';
    import { FORMAT_CATEGORIES, targetsFor as catTargetsFor } from '../data/formatCatalog';
    const FAMILY_ICON = {
      document: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/>',
      image: '<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="1.8"/><path d="M21 15l-5-5L5 21"/>',
      audio: '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
      video: '<rect x="2" y="5" width="14" height="14" rx="2"/><path d="m22 8-6 4 6 4V8z"/>',
      archive: '<rect x="3" y="4" width="18" height="4" rx="1"/><path d="M5 8v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V8"/><path d="M10 12h4"/>',
      ebook: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
      sheet: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/>',
      generic: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/>',
    };
    FAMILY_ICON.font = '<path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/>';
    FAMILY_ICON.vector = '<path d="M4.5 4.5h4v4h-4z"/><path d="M15.5 15.5h4v4h-4z"/><path d="M8.5 6.5h7a2 2 0 0 1 2 2v7"/>';
    const FAMILY_OF = {
      pdf: 'document', docx: 'document', doc: 'document', odt: 'document', rtf: 'document', txt: 'document', html: 'document', htm: 'document', md: 'document', pages: 'document', wpd: 'document', xml: 'document', log: 'document',
      png: 'image', jpg: 'image', jpeg: 'image', webp: 'image', tiff: 'image', tif: 'image', gif: 'image', bmp: 'image', ico: 'image', heic: 'image', heif: 'image', avif: 'image', jfif: 'image', psd: 'image',
      mp3: 'audio', wav: 'audio', flac: 'audio', ogg: 'audio', oga: 'audio', m4a: 'audio', aac: 'audio', opus: 'audio', aiff: 'audio', ac3: 'audio', wma: 'audio',
      mp4: 'video', mov: 'video', webm: 'video', mkv: 'video', avi: 'video', flv: 'video', ogv: 'video', wmv: 'video', mpeg: 'video', mpg: 'video', '3gp': 'video', '3g2': 'video', m2ts: 'video', mts: 'video', ts: 'video', vob: 'video', rmvb: 'video', rm: 'video', swf: 'video', m4v: 'video',
      zip: 'archive', '7z': 'archive', tar: 'archive', rar: 'archive', gz: 'archive', bz2: 'archive', xz: 'archive', tgz: 'archive', cab: 'archive', iso: 'archive',
      epub: 'ebook', mobi: 'ebook', azw3: 'ebook', azw: 'ebook', fb2: 'ebook', lit: 'ebook', pdb: 'ebook', cbz: 'ebook', cbr: 'ebook',
      xlsx: 'sheet', xls: 'sheet', csv: 'sheet', ods: 'sheet', numbers: 'sheet', tsv: 'sheet',
      pptx: 'document', ppt: 'document', odp: 'document', key: 'document',
      ttf: 'font', otf: 'font', woff: 'font', woff2: 'font', eot: 'font',
      svg: 'vector', ai: 'vector', eps: 'vector', cdr: 'vector', wmf: 'vector', emf: 'vector', ps: 'vector',
      dxf: 'vector', dwg: 'vector', dwf: 'vector',
    };
    const svg = (fmt) => {
      const fam = FAMILY_OF[fmt.toLowerCase()] || 'generic';
      return `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${FAMILY_ICON[fam]}</svg>`;
    };

    const up = (s) => s.toUpperCase();
    const matrixTargets = (fmt) => (CONVERT_MATRIX[fmt.toLowerCase()] || []).map(up);

    const CANDIDATE_PAIRS = [
      ['SVG', 'PNG'], ['HEIC', 'JPG'], ['WEBP', 'PNG'], ['PNG', 'JPG'],
      ['DOCX', 'PDF'], ['PNG', 'WEBP'], ['TIFF', 'JPG'], ['EPUB', 'PDF'],
      ['XLSX', 'CSV'], ['PPTX', 'PDF'], ['PDF', 'DOCX'], ['JPG', 'PNG'],
    ];
    const PAIRS = CANDIDATE_PAIRS.filter(([a, b]) => matrixTargets(a).includes(b));
    const row = document.getElementById('fmt-row');
    const fromEl = document.getElementById('fmt-from');
    const toEl = document.getElementById('fmt-to');
    const fromIcon = document.getElementById('fmt-from-icon');
    const toIcon = document.getElementById('fmt-to-icon');
    const fromBtn = document.getElementById('fmt-from-btn');
    const toBtn = document.getElementById('fmt-to-btn');
    const fromMenu = document.getElementById('fmt-from-menu');
    const toMenu = document.getElementById('fmt-to-menu');

    const setFrom = (fmt) => { if (fromEl) fromEl.textContent = fmt; if (fromIcon) fromIcon.innerHTML = svg(fmt); };
    const setTo = (fmt) => { if (toEl) toEl.textContent = fmt; if (toIcon) toIcon.innerHTML = svg(fmt); };
    function paint(idx) {
      const [a, b] = PAIRS[idx];
      setFrom(a); setTo(b);
    }
    paint(0);

    let timer = null;
    if (fromEl && toEl && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let i = 0;
      const els = [fromEl, toEl, fromIcon, toIcon].filter(Boolean);
      timer = setInterval(() => {
        i = (i + 1) % PAIRS.length;
        els.forEach((el) => el.classList.add('fmt-swap'));
        setTimeout(() => {
          paint(i);
          els.forEach((el) => el.classList.remove('fmt-swap'));
        }, 300);
      }, 2400);
    }

    function stopCycle() {
      if (timer) { clearInterval(timer); timer = null; }
      row?.classList.add('fmt-picked');
    }
    const closeMenus = () => {
      [fromMenu, toMenu].forEach((m) => m?.classList.add('hidden'));
      [fromBtn, toBtn].forEach((b) => b?.setAttribute('aria-expanded', 'false'));
    };

    function fillMenu(menu, opts, current, onPick) {
      if (!menu) return;
      menu.innerHTML = '';
      for (const f of opts) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'fmt-opt';
        b.setAttribute('role', 'option');
        if (f === current) b.setAttribute('aria-selected', 'true');
        b.innerHTML = svg(f).replace('width="26" height="26"', 'width="15" height="15"') + `<span>${f}</span>`;
        b.addEventListener('click', (e) => { e.stopPropagation(); closeMenus(); onPick(f); });
        menu.appendChild(b);
      }
    }

    function targetsFor(sourceFmt) {
      return catTargetsFor(sourceFmt).map(up);
    }
    function refreshTargets(sourceFmt) {
      const opts = targetsFor(sourceFmt);
      const cur = toEl?.textContent || '';
      setTo(opts.includes(cur) ? cur : (opts[0] || 'PDF'));
      fillMenu(toMenu, opts, toEl?.textContent, (f) => { stopCycle(); setTo(f); });
    }

    const catsEl = document.getElementById('fmt-cats');
    const chipsEl = document.getElementById('fmt-chips');
    const searchEl = document.getElementById('fmt-search');
    let activeCat = FORMAT_CATEGORIES[0]?.label || '';

    const CAT_ICON = {
      Document: FAMILY_ICON.document, Ebook: FAMILY_ICON.ebook, Font: FAMILY_ICON.font,
      Image: FAMILY_ICON.image, Presentation: FAMILY_ICON.document, Spreadsheet: FAMILY_ICON.sheet,
      Vector: FAMILY_ICON.vector, CAD: FAMILY_ICON.vector, Video: FAMILY_ICON.video,
      Audio: FAMILY_ICON.audio, Archive: FAMILY_ICON.archive,
    };

    function pickSource(fmt) {
      stopCycle();
      setFrom(up(fmt));
      refreshTargets(fmt);
      closeMenus();
    }

    function renderChips(query) {
      if (!chipsEl) return;
      chipsEl.innerHTML = '';
      const q = (query || '').trim().toLowerCase();
      let formats;
      if (q) {
        formats = FORMAT_CATEGORIES.flatMap((c) => c.formats).filter((f) => f.includes(q));
        formats = [...new Set(formats)];
      } else {
        formats = FORMAT_CATEGORIES.find((c) => c.label === activeCat)?.formats || [];
      }
      // Drop formats nothing can convert (no valid targets) instead of showing them grayed out.
      formats = formats.filter((f) => catTargetsFor(f).length);
      if (!formats.length) {
        const empty = document.createElement('div');
        empty.className = 'fmt-chips-empty';
        empty.textContent = 'No formats match.';
        chipsEl.appendChild(empty);
        return;
      }
      const cur = (fromEl?.textContent || '').toLowerCase();
      for (const f of formats) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'fmt-chip';
        b.textContent = up(f);
        if (f === cur) b.setAttribute('aria-selected', 'true');
        b.addEventListener('click', (e) => { e.stopPropagation(); pickSource(f); });
        chipsEl.appendChild(b);
      }
    }

    function renderCats() {
      if (!catsEl) return;
      catsEl.innerHTML = '';
      for (const c of FORMAT_CATEGORIES) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'fmt-cat';
        b.setAttribute('role', 'tab');
        if (c.label === activeCat) b.setAttribute('aria-selected', 'true');
        b.innerHTML = `<span>${c.label}</span><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`;
        const select = (e) => {
          e.stopPropagation();
          if (activeCat === c.label && !(searchEl && searchEl.value)) return;
          activeCat = c.label;
          if (searchEl) searchEl.value = '';
          for (const el of catsEl.children) el.removeAttribute('aria-selected');
          b.setAttribute('aria-selected', 'true');
          renderChips('');
        };
        b.addEventListener('mouseenter', select);
        b.addEventListener('click', select);
        catsEl.appendChild(b);
      }
    }

    searchEl?.addEventListener('input', () => renderChips(searchEl.value));
    fromMenu?.addEventListener('click', (e) => e.stopPropagation());

    fromBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = fromMenu.classList.contains('hidden');
      closeMenus();
      if (open) {
        if (searchEl) searchEl.value = '';
        renderCats();
        renderChips('');
        fromMenu.classList.remove('hidden');
        fromBtn.setAttribute('aria-expanded', 'true');
        searchEl?.focus();
      }
    });
    toBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = toMenu.classList.contains('hidden');
      closeMenus();
      if (open) {
        fillMenu(toMenu, targetsFor(fromEl?.textContent || 'SVG'), toEl?.textContent, (f) => { stopCycle(); setTo(f); });
        toMenu.classList.remove('hidden');
        toBtn.setAttribute('aria-expanded', 'true');
      }
    });
    document.addEventListener('click', closeMenus);

    document.addEventListener('fmt-lock', (e) => {
      const ext = ((e as CustomEvent).detail?.from || '').toUpperCase();
      if (!ext) return;
      stopCycle();
      setFrom(ext);
      refreshTargets(ext);
    });
  </script>
</Layout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="timezone-converter">
  <div class="flex flex-col gap-5">

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Date &amp; time
        <input id="tz-datetime" type="datetime-local" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Source time zone
        <input id="tz-from" class="field" list="tz-all" spellcheck="false"
          autocapitalize="off" autocomplete="off" placeholder="Type to search a zone…" />
      </label>
    </div>

    <datalist id="tz-all"></datalist>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <button id="tz-now" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Set to now</button>
      <label class="flex items-center gap-2">
        <input id="tz-live" type="checkbox" class="h-4 w-4" />
        Live (tick every second)
      </label>
      <span class="flex items-center gap-1">
        <span>Clock</span>
        <select id="tz-fmt" class="field w-auto py-1">
          <option value="24">24-hour</option>
          <option value="12" selected>12-hour</option>
        </select>
      </span>
      <label class="flex items-center gap-2">
        <input id="tz-secs" type="checkbox" class="h-4 w-4" />
        Show seconds
      </label>
      <label class="flex items-center gap-2">
        <input id="tz-biz" type="checkbox" checked class="h-4 w-4" />
        Mark working hours (9–17)
      </label>
    </div>

    <div id="tz-error" class="hidden rounded-md border px-3 py-2 text-sm" role="alert"
      style="border-color:#e5484d;color:#e5484d"></div>

    <div>
      <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
        <span class="text-[13px] text-ink-subtle">Converted times</span>
        <span class="flex flex-wrap gap-2">
          <input id="tz-add" class="field w-auto py-1 text-[13px]" list="tz-avail"
            spellcheck="false" autocapitalize="off" autocomplete="off" placeholder="+ Add a zone…" />
          <datalist id="tz-avail"></datalist>
          <button id="tz-copy" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy all</button>
          <button id="tz-share" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy link</button>
        </span>
      </div>
      <div id="tz-list" class="flex flex-col gap-2"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free time zone converter shows what a chosen date and time is across
      any number of cities and zones at once — ideal for scheduling calls and
      meetings across the world. It uses your browser's built-in IANA time zone
      database (every zone your system knows, searchable as you type), so daylight
      saving is handled automatically for each zone. Pick a source time, add the
      zones you care about, and read the results instantly.
    </p>
    <p>
      Every row shows the local date and time, the zone's GMT offset and
      abbreviation, and how far ahead or behind it is from your source zone. Rows
      sort automatically by offset, and a day/night marker (plus optional
      working-hours highlighting for 9am–5pm) makes it easy to spot who's awake and
      who's at their desk. Switch between 12- and 24-hour clocks, toggle seconds,
      and flip on <strong>Live</strong> to watch the clocks tick in real time.
    </p>
    <p>
      Copy every converted time as plain text for pasting into an email or chat, or
      copy a shareable link that reproduces the exact date, source zone, and list
      of zones — your selection is also remembered in this browser.
    </p>
  </div>
</ToolLayout>

<script>

  const FALLBACK = [
    'UTC', 'America/Los_Angeles', 'America/Denver', 'America/Chicago', 'America/New_York',
    'America/Sao_Paulo', 'Europe/London', 'Europe/Paris', 'Europe/Berlin', 'Europe/Moscow',
    'Africa/Cairo', 'Africa/Johannesburg', 'Asia/Dubai', 'Asia/Kolkata', 'Asia/Bangkok',
    'Asia/Shanghai', 'Asia/Singapore', 'Asia/Tokyo', 'Asia/Seoul', 'Australia/Sydney',
    'Pacific/Auckland', 'Pacific/Honolulu',
  ];

  const ZONES: string[] = (() => {
    try {
      const all = (Intl as any).supportedValuesOf?.('timeZone') as string[] | undefined;
      if (all && all.length) return all.includes('UTC') ? all : ['UTC', ...all];
    } catch {  }
    return FALLBACK;
  })();
  const ZONESET = new Set(ZONES);
  const local = Intl.DateTimeFormat().resolvedOptions().timeZone;
  if (!ZONESET.has(local)) { ZONES.unshift(local); ZONESET.add(local); }

  const dtEl = document.getElementById('tz-datetime') as HTMLInputElement;
  const fromEl = document.getElementById('tz-from') as HTMLInputElement;
  const addEl = document.getElementById('tz-add') as HTMLInputElement;
  const allList = document.getElementById('tz-all') as HTMLDataListElement;
  const availList = document.getElementById('tz-avail') as HTMLDataListElement;
  const list = document.getElementById('tz-list')!;
  const errEl = document.getElementById('tz-error')!;
  const fmtEl = document.getElementById('tz-fmt') as HTMLSelectElement;
  const secsEl = document.getElementById('tz-secs') as HTMLInputElement;
  const bizEl = document.getElementById('tz-biz') as HTMLInputElement;
  const liveEl = document.getElementById('tz-live') as HTMLInputElement;

  let source = local;
  const targets = new Set<string>();

  const params = new URLSearchParams(location.search);
  function seedTargets(zones: string[]) {
    targets.clear();
    for (const z of zones) if (ZONESET.has(z)) targets.add(z);
    if (!targets.size) {
      ['UTC', 'Europe/London', 'Asia/Tokyo'].filter((z) => z !== source).forEach((z) => targets.add(z));
      targets.add(source === 'UTC' ? 'America/New_York' : source);
    }
  }
  const saved = (() => { try { return JSON.parse(localStorage.getItem('tz-conv') || '{}'); } catch { return {}; } })();
  if (params.get('from') && ZONESET.has(params.get('from')!)) source = params.get('from')!;
  else if (saved.from && ZONESET.has(saved.from)) source = saved.from;
  fromEl.value = source;
  if (params.get('fmt') === '24' || params.get('fmt') === '12') fmtEl.value = params.get('fmt')!;
  else if (saved.fmt) fmtEl.value = saved.fmt;
  if (saved.secs) secsEl.checked = true;
  if (saved.biz === false) bizEl.checked = false;
  seedTargets(params.get('zones') ? params.get('zones')!.split(',') : (saved.zones || []));

  allList.innerHTML = ZONES.map((z) => `<option value="${z}"></option>`).join('');

  function refreshAvail() {
    availList.innerHTML = ZONES.filter((z) => !targets.has(z))
      .map((z) => `<option value="${z}"></option>`).join('');
  }

  function persist() {
    try {
      localStorage.setItem('tz-conv', JSON.stringify({
        from: source, fmt: fmtEl.value, secs: secsEl.checked, biz: bizEl.checked,
        zones: Array.from(targets),
      }));
    } catch {  }
  }

  function zonedToUtc(y: number, mo: number, d: number, h: number, mi: number, zone: string): Date {
    const guess = Date.UTC(y, mo - 1, d, h, mi);
    const offset = tzOffsetMs(new Date(guess), zone);
    return new Date(guess - offset);
  }
  function tzOffsetMs(date: Date, zone: string): number {
    const dtf = new Intl.DateTimeFormat('en-US', {
      timeZone: zone, hour12: false,
      year: 'numeric', month: '2-digit', day: '2-digit',
      hour: '2-digit', minute: '2-digit', second: '2-digit',
    });
    const map: Record<string, number> = {};
    for (const p of dtf.formatToParts(date)) if (p.type !== 'literal') map[p.type] = Number(p.value);
    const asUtc = Date.UTC(map.year, map.month - 1, map.day, map.hour % 24, map.minute, map.second);
    return asUtc - date.getTime();
  }
  function offsetLabel(ms: number): string {
    const sign = ms < 0 ? '-' : '+';
    const total = Math.abs(Math.round(ms / 60000));
    return `GMT${sign}${String(Math.floor(total / 60)).padStart(2, '0')}:${String(total % 60).padStart(2, '0')}`;
  }
  function diffLabel(ms: number): string {
    if (ms === 0) return 'same as source';
    const sign = ms < 0 ? '−' : '+';
    const total = Math.abs(Math.round(ms / 60000));
    const h = Math.floor(total / 60), m = total % 60;
    const hm = m ? `${h}:${String(m).padStart(2, '0')}` : `${h}h`;
    return `${sign}${hm} vs source`;
  }
  function fmt(date: Date, zone: string): string {
    return new Intl.DateTimeFormat('en-US', {
      timeZone: zone, weekday: 'short', year: 'numeric', month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit',
      ...(secsEl.checked ? { second: '2-digit' } : {}),
      hour12: fmtEl.value === '12',
      timeZoneName: 'short',
    }).format(date);
  }
  function hourIn(date: Date, zone: string): number {
    return Number(new Intl.DateTimeFormat('en-US', { timeZone: zone, hour: 'numeric', hour12: false }).format(date)) % 24;
  }

  function getInstant(): Date | null {
    const v = dtEl.value;
    if (!v) return null;
    const [datePart, timePart] = v.split('T');
    if (!datePart || !timePart) return null;
    const [y, mo, d] = datePart.split('-').map(Number);
    const [h, mi] = timePart.split(':').map(Number);
    if ([y, mo, d, h, mi].some((n) => Number.isNaN(n))) return null;
    return zonedToUtc(y, mo, d, h, mi, source);
  }

  function showError(msg: string) { errEl.textContent = msg; errEl.classList.remove('hidden'); }
  function clearError() { errEl.classList.add('hidden'); }

  function copyText(): string {
    const instant = getInstant();
    if (!instant) return '';
    const lines = [`Source: ${fmt(instant, source)} (${source.replace(/_/g, ' ')})`, ''];
    Array.from(targets)
      .sort((a, b) => tzOffsetMs(instant, a) - tzOffsetMs(instant, b))
      .forEach((z) => lines.push(`${z.replace(/_/g, ' ')}: ${fmt(instant, z)}`));
    return lines.join('\n');
  }

  function shareUrl(): string {
    const u = new URL(location.href);
    u.search = '';
    u.searchParams.set('t', dtEl.value);
    u.searchParams.set('from', source);
    u.searchParams.set('fmt', fmtEl.value);
    u.searchParams.set('zones', Array.from(targets).join(','));
    return u.toString();
  }

  function render() {
    if (!ZONESET.has(fromEl.value)) {
      showError(`Unknown source time zone "${fromEl.value}". Pick one from the list.`);
      return;
    }
    source = fromEl.value;
    const instant = getInstant();
    if (!instant) { showError('Enter a valid date and time.'); return; }
    clearError();

    list.innerHTML = '';
    const srcOffset = tzOffsetMs(instant, source);
    const sorted = Array.from(targets).sort((a, b) => tzOffsetMs(instant, a) - tzOffsetMs(instant, b));
    if (!sorted.length) {
      list.innerHTML = '<p class="text-[13px] text-ink-subtle">No zones added yet. Use the “Add a zone” box above.</p>';
    }
    for (const zone of sorted) {
      const off = tzOffsetMs(instant, zone);
      const hr = hourIn(instant, zone);
      const isDay = hr >= 6 && hr < 18;
      const isBiz = bizEl.checked && hr >= 9 && hr < 17;
      const row = document.createElement('div');
      row.className = 'panel panel-lift flex items-center justify-between gap-3 p-3';
      const meta = `${offsetLabel(off)} · ${zone === source ? 'source zone' : diffLabel(off - srcOffset)}`;
      row.innerHTML = `
        <div class="flex items-center gap-3">
          <span title="${isDay ? 'Daytime' : 'Night'}" aria-hidden="true" style="font-size:15px">${isDay ? '☀️' : '🌙'}</span>
          <div class="flex flex-col">
            <span class="text-[13px] text-ink-subtle">${zone.replace(/_/g, ' ')}${isBiz ? ' · <span style="color:#27a644">working hours</span>' : ''}</span>
            <span class="font-mono text-[15px] text-ink">${fmt(instant, zone)}</span>
            <span class="text-[11px] text-ink-tertiary">${meta}</span>
          </div>
        </div>
        <button type="button" class="btn btn-tertiary px-2 py-1 text-[13px]" aria-label="Remove ${zone}">✕</button>`;
      row.querySelector('button')!.addEventListener('click', () => {
        targets.delete(zone); refreshAvail(); persist(); render();
      });
      list.appendChild(row);
    }
    persist();
  }

  addEl.addEventListener('change', () => {
    const z = addEl.value.trim();
    if (!z) return;
    if (!ZONESET.has(z)) { showError(`Unknown time zone "${z}".`); addEl.value = ''; return; }
    targets.add(z); addEl.value = ''; refreshAvail(); render();
  });
  fromEl.addEventListener('change', render);
  dtEl.addEventListener('input', render);
  fmtEl.addEventListener('change', render);
  secsEl.addEventListener('change', render);
  bizEl.addEventListener('change', render);

  document.getElementById('tz-now')!.addEventListener('click', setNow);

  let ticker: number | undefined;
  liveEl.addEventListener('change', () => {
    if (liveEl.checked) { setNow(); ticker = window.setInterval(setNow, 1000); }
    else if (ticker) { clearInterval(ticker); ticker = undefined; }
  });

  document.getElementById('tz-copy')!.addEventListener('click', async (e) => {
    const text = copyText();
    if (!text) return;
    await navigator.clipboard.writeText(text);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy all'), 1400);
  });
  document.getElementById('tz-share')!.addEventListener('click', async (e) => {
    await navigator.clipboard.writeText(shareUrl());
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Link copied!'; setTimeout(() => (b.textContent = 'Copy link'), 1400);
  });

  function setNow() {
    const now = new Date();
    if (!secsEl.checked) now.setSeconds(0, 0);
    const p = (n: number) => String(n).padStart(2, '0');
    dtEl.value = `${now.getFullYear()}-${p(now.getMonth() + 1)}-${p(now.getDate())}T${p(now.getHours())}:${p(now.getMinutes())}${secsEl.checked ? ':' + p(now.getSeconds()) : ''}`;
    dtEl.step = secsEl.checked ? '1' : '60';
    render();
  }

  refreshAvail();
  if (params.get('t')) { dtEl.value = params.get('t')!; render(); }
  else setNow();
</script>

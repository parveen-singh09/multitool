---
import ToolLayout from '../layouts/ToolLayout.astro';

const types = [
  { id: 'url', label: 'URL' },
  { id: 'text', label: 'Text' },
  { id: 'wifi', label: 'WiFi' },
  { id: 'vcard', label: 'vCard' },
  { id: 'email', label: 'Email' },
  { id: 'sms', label: 'SMS' },
  { id: 'phone', label: 'Phone' },
  { id: 'geo', label: 'Location' },
  { id: 'event', label: 'Event' },
  { id: 'bitcoin', label: 'Bitcoin' },
];
---

<ToolLayout slug="qr-code-generator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_20rem]">

    <div class="flex flex-col gap-5">

      <div class="flex flex-wrap gap-1 rounded-md border border-hairline p-1" role="tablist" aria-label="Content type">
        {types.map((t, i) => (
          <button
            data-type={t.id}
            class="btn btn-tertiary px-3 py-1 text-sm"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          >{t.label}</button>
        ))}
      </div>

      <div id="fields" class="flex flex-col gap-3">
        <div data-fields="url">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Website URL
            <input data-f="url" class="field" placeholder="example.com" value="https://toolsilk.com" />
          </label>
        </div>

        <div data-fields="text" hidden>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Text
            <textarea data-f="text" class="field min-h-24 resize-y" placeholder="Any text…"></textarea>
          </label>
        </div>

        <div data-fields="wifi" hidden class="grid grid-cols-2 gap-3">
          <label class="col-span-2 flex flex-col gap-1 text-sm text-ink-subtle">Network name (SSID)
            <input data-f="ssid" class="field" placeholder="MyWiFi" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Password
            <input data-f="password" class="field" placeholder="••••••" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Encryption
            <select data-f="encryption" class="field">
              <option value="WPA" selected>WPA/WPA2</option>
              <option value="WEP">WEP</option>
              <option value="nopass">None</option>
            </select></label>
          <label class="col-span-2 flex items-center gap-2 text-sm text-ink-subtle">
            <input data-f="hidden" type="checkbox" class="size-4" /> Hidden network</label>
        </div>

        <div data-fields="vcard" hidden class="grid grid-cols-2 gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">First name
            <input data-f="firstName" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Last name
            <input data-f="lastName" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Phone
            <input data-f="phone" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Email
            <input data-f="email" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Organization
            <input data-f="org" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Job title
            <input data-f="title" class="field" /></label>
          <label class="col-span-2 flex flex-col gap-1 text-sm text-ink-subtle">Website
            <input data-f="url" class="field" /></label>
          <label class="col-span-2 flex flex-col gap-1 text-sm text-ink-subtle">Address
            <input data-f="address" class="field" /></label>
        </div>

        <div data-fields="email" hidden class="grid grid-cols-1 gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">To
            <input data-f="email" class="field" placeholder="name@example.com" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Subject
            <input data-f="subject" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Body
            <textarea data-f="body" class="field min-h-20 resize-y"></textarea></label>
        </div>

        <div data-fields="sms" hidden class="grid grid-cols-1 gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Phone number
            <input data-f="phone" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Message
            <textarea data-f="message" class="field min-h-20 resize-y"></textarea></label>
        </div>

        <div data-fields="phone" hidden>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Phone number
            <input data-f="phone" class="field" placeholder="+1 555 123 4567" /></label>
        </div>

        <div data-fields="geo" hidden class="grid grid-cols-2 gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Latitude
            <input data-f="lat" class="field" placeholder="37.7749" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Longitude
            <input data-f="lng" class="field" placeholder="-122.4194" /></label>
        </div>

        <div data-fields="event" hidden class="grid grid-cols-2 gap-3">
          <label class="col-span-2 flex flex-col gap-1 text-sm text-ink-subtle">Title
            <input data-f="title" class="field" /></label>
          <label class="col-span-2 flex flex-col gap-1 text-sm text-ink-subtle">Location
            <input data-f="location" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Starts
            <input data-f="start" type="datetime-local" class="field" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Ends
            <input data-f="end" type="datetime-local" class="field" /></label>
        </div>

        <div data-fields="bitcoin" hidden class="grid grid-cols-1 gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Address
            <input data-f="address" class="field" placeholder="bc1q…" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Amount (BTC)
            <input data-f="amount" class="field" placeholder="0.01" /></label>
        </div>
      </div>

      <div class="panel p-4">
        <div class="mb-3 font-display text-sm font-medium text-ink">Design</div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Body shape
            <select id="opt-dot" class="field">
              <option value="square">Square</option>
              <option value="rounded">Rounded</option>
              <option value="extra-rounded">Extra rounded</option>
              <option value="dots">Dots</option>
              <option value="diamond">Diamond</option>
            </select></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Eye frame
            <select id="opt-eye-frame" class="field">
              <option value="square">Square</option>
              <option value="rounded">Rounded</option>
              <option value="circle">Circle</option>
            </select></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Eye ball
            <select id="opt-eye-ball" class="field">
              <option value="square">Square</option>
              <option value="rounded">Rounded</option>
              <option value="circle">Circle</option>
            </select></label>

          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Fill
            <select id="opt-gradient" class="field">
              <option value="none">Solid</option>
              <option value="linear">Linear gradient</option>
              <option value="radial">Radial gradient</option>
            </select></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Foreground
            <input id="opt-fg" type="color" value="#010102" class="field h-10 cursor-pointer p-1" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle" id="grad-to-wrap" hidden>Gradient end
            <input id="opt-grad-to" type="color" value="#5e6ad2" class="field h-10 cursor-pointer p-1" /></label>

          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Background
            <input id="opt-bg" type="color" value="#ffffff" class="field h-10 cursor-pointer p-1" /></label>
          <label class="flex items-center gap-2 text-sm text-ink-subtle">
            <input id="opt-transparent" type="checkbox" class="size-4" /> Transparent</label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Eye color
            <input id="opt-eye-color" type="color" value="#010102" class="field h-10 cursor-pointer p-1" /></label>

          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Error correction
            <select id="opt-ec" class="field">
              <option value="L">Low</option>
              <option value="M" selected>Medium</option>
              <option value="Q">Quartile</option>
              <option value="H">High</option>
            </select></label>
          <label class="col-span-2 flex flex-col gap-1 text-sm text-ink-subtle">Logo (center)
            <input id="opt-logo" type="file" accept="image/*" class="field text-xs" /></label>
        </div>
        <div class="mt-3 flex items-center gap-3" id="logo-row" hidden>
          <label class="flex flex-1 flex-col gap-1 text-sm text-ink-subtle">Logo size
            <input id="opt-logo-size" type="range" min="10" max="35" value="22" class="w-full" /></label>
          <button id="opt-logo-clear" class="btn btn-tertiary px-2 py-1 text-xs">Remove logo</button>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <div class="panel panel-lift qr-checker flex aspect-square w-full items-center justify-center p-6">
        <canvas id="qr-canvas" class="aspect-square w-full max-w-xs rounded-md" aria-label="QR code preview"></canvas>
      </div>
      <div class="flex flex-col gap-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Download size
          <select id="opt-size" class="field">
            <option value="512">512 px</option>
            <option value="1024" selected>1024 px</option>
            <option value="2048">2048 px</option>
          </select></label>
        <button id="dl-png" class="btn btn-primary">Download PNG</button>
        <button id="dl-svg" class="btn btn-secondary">Download SVG</button>
      </div>
    </div>
  </div>
</ToolLayout>

<style>

  .qr-checker {
    background-image:
      linear-gradient(45deg, var(--color-surface-3) 25%, transparent 25%),
      linear-gradient(-45deg, var(--color-surface-3) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, var(--color-surface-3) 75%),
      linear-gradient(-45deg, transparent 75%, var(--color-surface-3) 75%);
    background-size: 16px 16px;
    background-position: 0 0, 0 8px, 8px -8px, -8px 0;
  }
</style>

<script>
  import {
    buildPayload,
    renderToCanvas,
    renderToSvg,
    DEFAULT_OPTIONS,
    type QROptions,
    type EC,
    type DotStyle,
    type EyeFrame,
    type EyeBall,
    type GradientType,
    type Fields,
  } from '../lib/qr';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const canvas = $<HTMLCanvasElement>('qr-canvas');

  let activeType = 'url';
  let logo: HTMLImageElement | null = null;

  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-type]'));
  const fieldBlocks = Array.from(document.querySelectorAll<HTMLDivElement>('[data-fields]'));

  function collectFields(): Fields {
    const block = fieldBlocks.find((b) => b.dataset.fields === activeType);
    const f: Fields = {};
    block?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('[data-f]').forEach((el) => {
      const key = (el as HTMLElement).dataset.f!;
      f[key] = el instanceof HTMLInputElement && el.type === 'checkbox' ? el.checked : el.value;
    });
    return f;
  }

  function currentOptions(): QROptions {
    const gradient = $<HTMLSelectElement>('opt-gradient').value as GradientType;
    const transparent = $<HTMLInputElement>('opt-transparent').checked;
    return {
      ...DEFAULT_OPTIONS,
      ec: $<HTMLSelectElement>('opt-ec').value as EC,
      dot: $<HTMLSelectElement>('opt-dot').value as DotStyle,
      eyeFrame: $<HTMLSelectElement>('opt-eye-frame').value as EyeFrame,
      eyeBall: $<HTMLSelectElement>('opt-eye-ball').value as EyeBall,
      paint: {
        fg: $<HTMLInputElement>('opt-fg').value,
        gradient,
        gradTo: $<HTMLInputElement>('opt-grad-to').value,
        gradRotation: 45,
      },
      eyeColor: $<HTMLInputElement>('opt-eye-color').value,
      bg: transparent ? null : $<HTMLInputElement>('opt-bg').value,
      logo,
      logoRatio: Number($<HTMLInputElement>('opt-logo-size').value) / 100,
    };
  }

  const payload = () => buildPayload(activeType, collectFields());

  function render() {

    $('grad-to-wrap').hidden = $<HTMLSelectElement>('opt-gradient').value === 'none';
    try {
      renderToCanvas(canvas, payload(), currentOptions(), 1024);
    } catch (e) {
      console.error(e);
    }
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      activeType = tab.dataset.type!;
      tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
      fieldBlocks.forEach((b) => (b.hidden = b.dataset.fields !== activeType));
      render();
    });
  });

  document.getElementById('fields')!.addEventListener('input', render);
  ['opt-dot', 'opt-eye-frame', 'opt-eye-ball', 'opt-gradient', 'opt-fg', 'opt-grad-to', 'opt-bg', 'opt-transparent', 'opt-eye-color', 'opt-ec', 'opt-logo-size'].forEach(
    (id) => $(id).addEventListener('input', render)
  );

  $<HTMLInputElement>('opt-logo').addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    const img = new Image();
    img.onload = () => {
      logo = img;
      $('logo-row').hidden = false;
      render();
    };
    img.src = URL.createObjectURL(file);
  });
  $('opt-logo-clear').addEventListener('click', () => {
    logo = null;
    $<HTMLInputElement>('opt-logo').value = '';
    $('logo-row').hidden = true;
    render();
  });

  $('dl-png').addEventListener('click', () => {
    const size = Number($<HTMLSelectElement>('opt-size').value);
    const out = document.createElement('canvas');
    renderToCanvas(out, payload(), currentOptions(), size);
    const link = document.createElement('a');
    link.download = 'toolsilk-qr.png';
    link.href = out.toDataURL('image/png');
    link.click();
  });
  $('dl-svg').addEventListener('click', () => {
    const opts = currentOptions();
    const emit = (o: QROptions) => {
      const svg = renderToSvg(payload(), o, Number($<HTMLSelectElement>('opt-size').value));
      const blob = new Blob([svg], { type: 'image/svg+xml' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.download = 'toolsilk-qr.svg';
      link.href = url;
      link.click();
      URL.revokeObjectURL(url);
    };

    if (opts.logo && !opts.logo.src.startsWith('data:')) {
      const c = document.createElement('canvas');
      c.width = opts.logo.naturalWidth;
      c.height = opts.logo.naturalHeight;
      c.getContext('2d')!.drawImage(opts.logo, 0, 0);
      const dataImg = new Image();
      dataImg.src = c.toDataURL('image/png');
      emit({ ...opts, logo: dataImg });
    } else {
      emit(opts);
    }
  });

  render();
</script>

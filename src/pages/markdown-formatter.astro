---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="markdown-formatter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="mf-format" class="btn btn-primary">Format</button>
      <button id="mf-clear" class="btn btn-tertiary">Clear</button>
    </div>

    <div id="mf-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid gap-4 md:grid-cols-2">
      <div class="copy-wrap">
        <div class="hl-edit field p-0" style="height:18rem;resize:vertical;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="mf-input-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea
            id="mf-input"
            placeholder="Type Markdown here, e.g.&#10;# Title&#10;&#10;Some **bold** text and a [link](https://example.com)."
            spellcheck="false"
            aria-label="Markdown input"
          ></textarea>
        </div>
        <button type="button" class="copy-icon" data-copy-target="#mf-input" aria-label="Copy"></button>
      </div>
      <div id="mf-preview" class="panel p-4 min-h-72 overflow-auto text-[15px] leading-relaxed text-ink" aria-label="Rendered preview"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Markdown formatter normalizes your Markdown — tidying heading
      spacing, unifying list markers and collapsing extra blank lines — and
      shows a live rendered HTML preview as you type. It handles headings, bold
      and italic, links, inline code, fenced code blocks, lists and
      blockquotes.
    </p>
  </div>
</ToolLayout>

<script>
  import { wireInput } from '../lib/highlight';

  const input = document.getElementById('mf-input') as HTMLTextAreaElement;
  const inputHl = document.getElementById('mf-input-hl')!;
  const preview = document.getElementById('mf-preview')!;
  const status = document.getElementById('mf-status')!;

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function inline(text: string): string {
    let s = escapeHtml(text);

    const codes: string[] = [];
    s = s.replace(/`([^`]+)`/g, (_m, c) => {
      codes.push(`<code>${c}</code>`);
      return `\u0000${codes.length - 1}\u0000`;
    });
    s = s.replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, (_m, t, url) => {
      return `<a href="${url}" rel="noopener noreferrer" target="_blank">${t}</a>`;
    });
    s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    s = s.replace(/__([^_]+)__/g, '<strong>$1</strong>');
    s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
    s = s.replace(/_([^_]+)_/g, '<em>$1</em>');
    s = s.replace(/\u0000(\d+)\u0000/g, (_m, i) => codes[Number(i)]);
    return s;
  }

  function render(md: string): string {
    const lines = md.replace(/\r\n/g, '\n').split('\n');
    const html: string[] = [];
    let i = 0;
    const n = lines.length;

    while (i < n) {
      const line = lines[i];

      const fence = line.match(/^```(.*)$/);
      if (fence) {
        const buf: string[] = [];
        i++;
        while (i < n && !/^```\s*$/.test(lines[i])) {
          buf.push(lines[i]);
          i++;
        }
        i++;
        html.push(`<pre><code>${escapeHtml(buf.join('\n'))}</code></pre>`);
        continue;
      }

      const h = line.match(/^(#{1,6})\s+(.*)$/);
      if (h) {
        const level = h[1].length;
        html.push(`<h${level}>${inline(h[2].trim())}</h${level}>`);
        i++;
        continue;
      }

      if (/^>\s?/.test(line)) {
        const buf: string[] = [];
        while (i < n && /^>\s?/.test(lines[i])) {
          buf.push(lines[i].replace(/^>\s?/, ''));
          i++;
        }
        html.push(`<blockquote>${inline(buf.join(' '))}</blockquote>`);
        continue;
      }

      if (/^\s*[-*+]\s+/.test(line)) {
        const items: string[] = [];
        while (i < n && /^\s*[-*+]\s+/.test(lines[i])) {
          items.push(`<li>${inline(lines[i].replace(/^\s*[-*+]\s+/, ''))}</li>`);
          i++;
        }
        html.push(`<ul>${items.join('')}</ul>`);
        continue;
      }

      if (/^\s*\d+[.)]\s+/.test(line)) {
        const items: string[] = [];
        while (i < n && /^\s*\d+[.)]\s+/.test(lines[i])) {
          items.push(`<li>${inline(lines[i].replace(/^\s*\d+[.)]\s+/, ''))}</li>`);
          i++;
        }
        html.push(`<ol>${items.join('')}</ol>`);
        continue;
      }

      if (/^\s*([-*_])(\s*\1){2,}\s*$/.test(line)) {
        html.push('<hr />');
        i++;
        continue;
      }

      if (line.trim() === '') {
        i++;
        continue;
      }

      const buf: string[] = [];
      while (
        i < n &&
        lines[i].trim() !== '' &&
        !/^(#{1,6})\s+/.test(lines[i]) &&
        !/^```/.test(lines[i]) &&
        !/^>\s?/.test(lines[i]) &&
        !/^\s*[-*+]\s+/.test(lines[i]) &&
        !/^\s*\d+[.)]\s+/.test(lines[i])
      ) {
        buf.push(lines[i].trim());
        i++;
      }
      html.push(`<p>${inline(buf.join(' '))}</p>`);
    }

    return html.join('\n');
  }

  function normalize(md: string): string {
    const lines = md.replace(/\r\n/g, '\n').split('\n');
    const out: string[] = [];
    let inFence = false;
    for (let idx = 0; idx < lines.length; idx++) {
      let line = lines[idx];
      if (/^```/.test(line.trim())) {
        inFence = !inFence;
        out.push(line.trimEnd());
        continue;
      }
      if (inFence) {
        out.push(line);
        continue;
      }
      line = line.replace(/[ \t]+$/, '');

      line = line.replace(/^(#{1,6})\s*(\S.*)$/, '$1 $2');

      line = line.replace(/^(\s*)[*+]\s+/, '$1- ');
      line = line.replace(/^(\s*)-\s+/, '$1- ');
      out.push(line);
    }

    return out.join('\n').replace(/\n{3,}/g, '\n\n').trim() + '\n';
  }

  function update() {
    preview.innerHTML = render(input.value);
  }

  document.getElementById('mf-format')!.addEventListener('click', () => {
    if (!input.value.trim()) return;
    input.value = normalize(input.value);
    refresh();
    update();
    showStatus('Formatted ✓', true);
  });
  document.getElementById('mf-clear')!.addEventListener('click', () => {
    input.value = '';
    refresh();
    preview.innerHTML = '';
    status.classList.add('hidden');
  });
  const refresh = wireInput(input, inputHl, () => 'markdown', () => update());
  update();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="epub-to-mobi">
  <ArchiveConvert slug="epub-to-mobi" from="epub" to="mobi" noun="ebook" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free EPUB to MOBI converter converts EPUB ebooks to Kindle-compatible MOBI format.
    </p>
    <p>
      Conversion is handled on our servers, because these
      ebook formats can't be read reliably in a browser. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const RAW_TARGETS = ['jpg', 'png', 'tiff', 'webp'];
---

<ToolLayout slug="raw-converter">
  <ArchiveConvert slug="raw-converter" targets={RAW_TARGETS} noun="RAW photo" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online RAW converter converts camera RAW photos — including Nikon
      NEF, Canon CR2/CR3/CRW, Sony ARW, Adobe DNG, Kodak DCR and other formats — to
      standard JPG, PNG, TIFF or WebP images. Upload a RAW file, pick a target
      format, and convert.
    </p>
    <p>
      Camera RAW formats are proprietary sensor dumps that browsers can't decode,
      so conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

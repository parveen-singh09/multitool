---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="wtv-to-mp4">
  <ArchiveConvert slug="wtv-to-mp4" from="wtv" to="mp4" noun="video" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free WTV to MP4 converter converts Windows Media Center WTV recordings to modern MP4.
    </p>
    <p>
      Conversion is handled on our servers, because these
      broadcast and proprietary video formats can't be decoded in a browser. Your
      file is uploaded to our servers, converted on their
      servers, and returned as a download link.
    </p>
  </div>
</ToolLayout>

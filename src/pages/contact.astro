---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

const email = `hello@${SITE.domain}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contact ${SITE.name}`,
  url: `${SITE.url}/contact`,
  email,
};
---

<Layout
  title="Contact Us"
  description={`Get in touch with the ${SITE.name} team — feedback, bug reports, and tool suggestions welcome.`}
  jsonLd={jsonLd}
>
  <Header />

  <main class="container-page py-14">
    <div class="mx-auto max-w-3xl">
      <span class="eyebrow text-primary-hover">Contact</span>
      <h1 class="display-md mt-3 text-ink">Get in touch</h1>

      <div class="mt-8 flex flex-col gap-4 text-[15px] leading-relaxed text-ink-muted">
        <p>
          Found a bug, have an idea for a new tool, or just want to say hello? We
          read every message and love hearing how you use {SITE.name}.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Email</h2>
        <p>
          The fastest way to reach us is by email:
        </p>
        <p>
          <a href={`mailto:${email}`} class="btn btn-primary">{email}</a>
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">What to include</h2>
        <ul class="flex list-disc flex-col gap-2 pl-5">
          <li><strong class="text-ink">Bug reports:</strong> the tool name, what you expected, and what happened.</li>
          <li><strong class="text-ink">Tool ideas:</strong> what the tool should do and who it helps.</li>
          <li><strong class="text-ink">Feedback:</strong> anything that would make {SITE.name} better.</li>
        </ul>

        <p class="mt-4">
          Prefer to browse first? Explore all
          <a href="/#tools" class="text-primary-hover underline">available tools</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="grams-to-cups-converter">
  <div class="flex flex-col gap-5">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Amount
        <input id="gc-amount" type="number" min="0" step="any" value="200" class="field w-32" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">From
        <select id="gc-from" class="field w-44">
          <option value="g">Grams (g)</option>
          <option value="kg">Kilograms (kg)</option>
          <option value="oz">Ounces (oz)</option>
          <option value="lb">Pounds (lb)</option>
          <option value="cup">Cups</option>
          <option value="tbsp">Tablespoons</option>
          <option value="tsp">Teaspoons</option>
          <option value="floz">Fluid ounces</option>
          <option value="ml">Millilitres (ml)</option>
          <option value="stick">Sticks of butter</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Ingredient
        <select id="gc-ingredient" class="field w-56"></select>
      </label>
      <label id="gc-custom-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Density (g per US cup)
        <input id="gc-custom" type="number" min="0" step="any" value="150" class="field w-40" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Cup standard
        <select id="gc-cup" class="field w-48">
          <option value="236.588">US customary (236.6 ml)</option>
          <option value="240">US legal (240 ml)</option>
          <option value="250">Metric (250 ml)</option>
          <option value="284.131">Imperial / UK (284.1 ml)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Rounding
        <select id="gc-precision" class="field w-32">
          <option value="auto">Auto</option>
          <option value="0">0 dp</option>
          <option value="1">1 dp</option>
          <option value="2">2 dp</option>
          <option value="3">3 dp</option>
        </select>
      </label>
    </div>

    <p id="gc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="gc-out" class="grid grid-cols-2 gap-3 sm:grid-cols-3"></div>

    <div class="flex flex-wrap items-center gap-2">
      <button id="gc-copy" type="button" class="btn btn-secondary px-3 py-1 text-[13px]">Copy all results</button>
      <span id="gc-copied" class="hidden text-[13px] text-ink-subtle" role="status">Copied</span>
      <span class="text-[13px] text-ink-tertiary">Tip: click any result tile to copy it.</span>
    </div>

    <div class="panel p-4">
      <div class="mb-3 flex items-center justify-between">
        <span class="eyebrow text-primary-hover">Quick reference</span>
        <span id="gc-ref-name" class="text-[13px] text-ink-subtle"></span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="text-left text-ink-tertiary">
              <th class="py-1 pr-4 font-medium">Cups</th>
              <th class="py-1 pr-4 font-medium">Grams</th>
              <th class="py-1 pr-4 font-medium">Ounces</th>
              <th class="py-1 font-medium">Millilitres</th>
            </tr>
          </thead>
          <tbody id="gc-ref"></tbody>
        </table>
      </div>
    </div>

    <p class="text-[13px] text-ink-tertiary">
      Ingredient densities are grams per US customary cup; other cup standards are
      scaled by volume. Weights are approximate — pack, sift and humidity all change
      ingredient density. For baking accuracy, weigh in grams where you can.
    </p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free grams to cups converter turns baking weights into volume and back,
      using per-ingredient densities — because a cup of flour and a cup of sugar
      weigh very different amounts. Pick your ingredient (flour, sugar, butter,
      cocoa, honey and more), enter grams, kilograms, ounces, pounds, cups,
      tablespoons, teaspoons, fluid ounces, millilitres or sticks of butter, and see
      every other unit at once.
    </p>
    <p>
      Unlike single-standard converters, you can switch the cup standard between US
      customary (236.6 ml), US legal (240 ml), metric (250 ml) and imperial UK
      (284.1 ml), so a recipe from any country lands right. Not sure of the density?
      Choose <strong>Custom ingredient</strong> and type your own grams-per-cup. A
      rounding control lets you match a recipe's precision, click-to-copy grabs any
      result, and the quick reference table shows common cup fractions for your
      chosen ingredient at a glance.
    </p>
  </div>
</ToolLayout>

<script>

  const GROUPS: { label: string; items: { name: string; gPerCup: number }[] }[] = [
    {
      label: 'Flour & grains',
      items: [
        { name: 'All-purpose flour', gPerCup: 125 },
        { name: 'Bread flour', gPerCup: 127 },
        { name: 'Cake flour', gPerCup: 114 },
        { name: 'Whole wheat flour', gPerCup: 120 },
        { name: 'Cornstarch', gPerCup: 120 },
        { name: 'Cornmeal', gPerCup: 157 },
        { name: 'Rolled oats', gPerCup: 90 },
        { name: 'Rice (uncooked)', gPerCup: 185 },
        { name: 'Breadcrumbs (dry)', gPerCup: 108 },
      ],
    },
    {
      label: 'Sugars & sweeteners',
      items: [
        { name: 'Granulated sugar', gPerCup: 200 },
        { name: 'Brown sugar (packed)', gPerCup: 220 },
        { name: 'Powdered sugar', gPerCup: 120 },
        { name: 'Caster sugar', gPerCup: 225 },
        { name: 'Honey', gPerCup: 340 },
        { name: 'Maple syrup', gPerCup: 322 },
        { name: 'Golden syrup', gPerCup: 340 },
      ],
    },
    {
      label: 'Dairy & fats',
      items: [
        { name: 'Butter', gPerCup: 227 },
        { name: 'Vegetable oil', gPerCup: 218 },
        { name: 'Milk', gPerCup: 244 },
        { name: 'Yogurt', gPerCup: 245 },
        { name: 'Sour cream', gPerCup: 230 },
        { name: 'Cream cheese', gPerCup: 232 },
        { name: 'Grated parmesan', gPerCup: 100 },
      ],
    },
    {
      label: 'Liquids',
      items: [
        { name: 'Water', gPerCup: 236.6 },
      ],
    },
    {
      label: 'Baking & mix-ins',
      items: [
        { name: 'Cocoa powder', gPerCup: 100 },
        { name: 'Chocolate chips', gPerCup: 170 },
        { name: 'Chopped nuts', gPerCup: 120 },
        { name: 'Desiccated coconut', gPerCup: 93 },
        { name: 'Raisins', gPerCup: 165 },
        { name: 'Salt (table)', gPerCup: 288 },
      ],
    },
  ];

  const INGREDIENTS = GROUPS.flatMap((g) => g.items);
  const CUSTOM = INGREDIENTS.length; 

  const TBSP_ML = 14.7867648;
  const TSP_ML = 4.92892159;
  const FLOZ_ML = 29.5735296;
  const STICK_ML = 8 * TBSP_ML; 
  const OZ_G = 28.3495231;
  const LB_G = 453.59237;
  const US_CUP_ML = 236.588; 

  const amountEl = document.getElementById('gc-amount') as HTMLInputElement;
  const fromEl = document.getElementById('gc-from') as HTMLSelectElement;
  const ingredientEl = document.getElementById('gc-ingredient') as HTMLSelectElement;
  const customWrap = document.getElementById('gc-custom-wrap') as HTMLLabelElement;
  const customEl = document.getElementById('gc-custom') as HTMLInputElement;
  const cupEl = document.getElementById('gc-cup') as HTMLSelectElement;
  const precisionEl = document.getElementById('gc-precision') as HTMLSelectElement;
  const out = document.getElementById('gc-out')!;
  const errEl = document.getElementById('gc-error')!;
  const copyBtn = document.getElementById('gc-copy') as HTMLButtonElement;
  const copiedEl = document.getElementById('gc-copied')!;
  const refBody = document.getElementById('gc-ref')!;
  const refName = document.getElementById('gc-ref-name')!;

  ingredientEl.innerHTML =
    GROUPS.map(
      (g) =>
        `<optgroup label="${g.label}">` +
        g.items
          .map((x) => `<option value="${INGREDIENTS.indexOf(x)}">${x.name}</option>`)
          .join('') +
        `</optgroup>`,
    ).join('') + `<optgroup label="Other"><option value="${CUSTOM}">Custom ingredient…</option></optgroup>`;
  ingredientEl.value = String(INGREDIENTS.findIndex((x) => x.name === 'All-purpose flour'));

  function activeDensity(): number {

    if (Number(ingredientEl.value) === CUSTOM) return parseFloat(customEl.value) || 0;
    return INGREDIENTS[Number(ingredientEl.value)].gPerCup;
  }

  function activeName(): string {
    return Number(ingredientEl.value) === CUSTOM ? 'Custom ingredient' : INGREDIENTS[Number(ingredientEl.value)].name;
  }

  function fmt(n: number): string {
    if (!isFinite(n)) return '—';
    const p = precisionEl.value;
    if (p !== 'auto') {
      const dp = Number(p);
      return Number(n.toFixed(dp)).toLocaleString(undefined, { maximumFractionDigits: dp });
    }
    if (n === 0) return '0';
    const abs = Math.abs(n);
    if (abs < 0.01) return n.toExponential(2);
    if (abs < 10) return n.toFixed(2).replace(/\.?0+$/, '');
    if (abs < 100) return n.toFixed(1).replace(/\.0$/, '');
    return Math.round(n).toLocaleString();
  }

  function asFraction(cups: number): string {
    const whole = Math.floor(cups);
    const frac = cups - whole;
    const table: [number, string][] = [
      [0, ''], [1 / 8, '⅛'], [1 / 4, '¼'], [1 / 3, '⅓'], [3 / 8, '⅜'],
      [1 / 2, '½'], [5 / 8, '⅝'], [2 / 3, '⅔'], [3 / 4, '¾'], [7 / 8, '⅞'], [1, ''],
    ];
    let best = table[0], bestD = Infinity;
    for (const t of table) { const d = Math.abs(frac - t[0]); if (d < bestD) { bestD = d; best = t; } }
    let w = whole;
    const sym = best[1];
    if (best[0] === 1) w += 1;
    if (w === 0 && !sym) return '0';
    if (!sym) return String(w);
    return w ? `${w} ${sym}` : sym;
  }

  // Convert everything through a canonical grams + g/ml density model.
  function toGrams(amount: number, unit: string, gPerMl: number, cupMl: number): number {
    switch (unit) {
      case 'g': return amount;
      case 'kg': return amount * 1000;
      case 'oz': return amount * OZ_G;
      case 'lb': return amount * LB_G;
      case 'cup': return amount * cupMl * gPerMl;
      case 'tbsp': return amount * TBSP_ML * gPerMl;
      case 'tsp': return amount * TSP_ML * gPerMl;
      case 'floz': return amount * FLOZ_ML * gPerMl;
      case 'ml': return amount * gPerMl;
      case 'stick': return amount * STICK_ML * gPerMl;
      default: return amount;
    }
  }

  let lastResults: [string, string][] = [];

  function compute() {
    const raw = amountEl.value.trim();
    const amount = parseFloat(raw);
    const density = activeDensity();

    // Validation.
    if (Number(ingredientEl.value) === CUSTOM && !(density > 0)) {
      showError('Enter a density greater than 0 g per cup for the custom ingredient.');
      return;
    }
    if (raw === '' || isNaN(amount)) {
      showError('Enter a numeric amount to convert.');
      return;
    }
    if (amount < 0) {
      showError('Amount must be zero or positive.');
      return;
    }
    errEl.classList.add('hidden');

    const cupMl = parseFloat(cupEl.value);
    const gPerMl = density / US_CUP_ML; // density measured against the US customary cup
    const grams = toGrams(amount, fromEl.value, gPerMl, cupMl);
    const ml = gPerMl > 0 ? grams / gPerMl : 0;
    const cups = ml / cupMl;

    lastResults = [
      ['Grams', `${fmt(grams)} g`],
      ['Cups', asFraction(cups)],
      ['Cups (decimal)', fmt(cups)],
      ['Tablespoons', fmt(ml / TBSP_ML)],
      ['Teaspoons', fmt(ml / TSP_ML)],
      ['Ounces', `${fmt(grams / OZ_G)} oz`],
      ['Pounds', `${fmt(grams / LB_G)} lb`],
      ['Fluid ounces', `${fmt(ml / FLOZ_ML)} fl oz`],
      ['Millilitres', `${fmt(ml)} ml`],
      ['Sticks of butter', fmt(ml / STICK_ML)],
    ];

    out.innerHTML = lastResults
      .map(
        ([label, val]) => `<button type="button" data-copy="${val.replace(/"/g, '&quot;')}"
        class="panel panel-lift flex flex-col gap-1 p-4 text-left transition-colors hover:bg-surface-2 hover:border-hairline-strong">
        <span class="text-xs text-ink-tertiary">${label}</span>
        <span class="font-display text-xl font-semibold text-ink">${val}</span>
      </button>`,
      )
      .join('');

    buildReference(gPerMl, cupMl);
  }

  function buildReference(gPerMl: number, cupMl: number) {
    refName.textContent = `${activeName()} · ${cupEl.selectedOptions[0].textContent}`;
    const cupFracs: [string, number][] = [
      ['1 cup', 1], ['¾ cup', 0.75], ['⅔ cup', 2 / 3],
      ['½ cup', 0.5], ['⅓ cup', 1 / 3], ['¼ cup', 0.25], ['⅛ cup', 0.125],
    ];
    refBody.innerHTML = cupFracs
      .map(([label, c]) => {
        const ml = c * cupMl;
        const grams = ml * gPerMl;
        return `<tr class="border-t border-hairline">
          <td class="py-1.5 pr-4 text-ink">${label}</td>
          <td class="py-1.5 pr-4 text-ink-muted">${fmt(grams)} g</td>
          <td class="py-1.5 pr-4 text-ink-muted">${fmt(grams / OZ_G)} oz</td>
          <td class="py-1.5 text-ink-muted">${fmt(ml)} ml</td>
        </tr>`;
      })
      .join('');
  }

  function showError(msg: string) {
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
    out.innerHTML = '';
    refBody.innerHTML = '';
    refName.textContent = '';
    lastResults = [];
  }

  function flashCopied() {
    copiedEl.classList.remove('hidden');
    setTimeout(() => copiedEl.classList.add('hidden'), 1200);
  }

  // Click a tile → copy its value.
  out.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-copy]') as HTMLElement | null;
    if (!btn) return;
    navigator.clipboard?.writeText(btn.dataset.copy || '').then(flashCopied).catch(() => {});
  });

  // Copy all results as a labelled block.
  copyBtn.addEventListener('click', () => {
    if (!lastResults.length) return;
    const text = `${amountEl.value} ${fromEl.value} of ${activeName()}\n` +
      lastResults.map(([l, v]) => `${l}: ${v}`).join('\n');
    navigator.clipboard?.writeText(text).then(flashCopied).catch(() => {});
  });

  ingredientEl.addEventListener('change', () => {
    customWrap.classList.toggle('hidden', Number(ingredientEl.value) !== CUSTOM);
    customWrap.classList.toggle('flex', Number(ingredientEl.value) === CUSTOM);
    compute();
  });

  [amountEl, fromEl, cupEl, precisionEl, customEl].forEach((el) => el.addEventListener('input', compute));
  compute();

  // ponytail: self-check — verify the round-trip and density model hold.
  function selfCheck() {
    const gPerMl = 125 / US_CUP_ML; // all-purpose flour
    // 1 US customary cup of flour ≈ 125 g
    const g = toGrams(1, 'cup', gPerMl, US_CUP_ML);
    console.assert(Math.abs(g - 125) < 0.001, 'cup→g flour', g);
    // 1 stick of butter (227 g/cup) ≈ 113.4 g
    const bMl = 227 / US_CUP_ML;
    const stick = toGrams(1, 'stick', bMl, US_CUP_ML);
    console.assert(Math.abs(stick - 113.5) < 1, 'stick→g butter', stick);
    // metric cup of water (250 ml) ≈ 250 g
    const wMl = 236.6 / US_CUP_ML;
    console.assert(Math.abs(toGrams(1, 'cup', wMl, 250) - 250) < 0.5, 'metric cup water', toGrams(1, 'cup', wMl, 250));
  }
  if (new URLSearchParams(location.search).has('selftest')) selfCheck();
</script>

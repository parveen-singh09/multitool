---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const DOC_TARGETS = ['pdf', 'docx', 'odt', 'rtf', 'txt', 'html', 'doc'];
---

<ToolLayout slug="document-converter">
  <ArchiveConvert slug="document-converter" targets={DOC_TARGETS} noun="document" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online document converter converts between word-processing and
      document formats — including legacy and proprietary ones like DOC, ODT, RTF,
      Apple Pages, WordPerfect (WPD), HWP, DjVu and AbiWord. Upload a file, pick a
      target format (PDF, DOCX, ODT, RTF, TXT, HTML or DOC), and convert.
    </p>
    <p>
      Older binary and proprietary document formats can't be read reliably in a
      browser, so conversion is handled on our servers.
      Your file is uploaded to our servers, converted on their
      servers, and returned as a download link.
    </p>
  </div>
</ToolLayout>

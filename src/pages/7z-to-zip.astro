---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="7z-to-zip">
  <ArchiveConvert slug="7z-to-zip" from="7z" to="zip" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free 7Z to ZIP converter Convert 7-Zip (.7z) archives to ZIP for broad compatibility — no 7-Zip install needed to open the result.
    </p>
    <p>
      Conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const EBOOK_TARGETS = ['epub', 'mobi', 'azw3', 'fb2', 'pdf', 'txt', 'cbz', 'lit', 'pdb'];
---

<ToolLayout slug="ebook-format-converter">
  <ArchiveConvert slug="ebook-format-converter" targets={EBOOK_TARGETS} noun="ebook" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online ebook converter converts between ebook formats — including
      Kindle and legacy ones like AZW, AZW3, MOBI, LIT, LRF, PDB and PRC, plus
      EPUB, FB2 and comic-book CBR/CBZ. Upload a file, pick a target format (EPUB,
      MOBI, AZW3, FB2, PDF, TXT, CBZ, LIT or PDB), and convert.
    </p>
    <p>
      Proprietary Kindle and legacy ebook formats can't be read reliably in a
      browser, so conversion is handled on our servers.
      Your file is uploaded to our servers, converted on their
      servers, and returned as a download link.
    </p>
  </div>
</ToolLayout>

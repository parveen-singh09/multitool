---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const SPREADSHEET_TARGETS = ['xlsx', 'xls', 'ods', 'csv', 'pdf'];
---

<ToolLayout slug="spreadsheet-converter">
  <ArchiveConvert slug="spreadsheet-converter" targets={SPREADSHEET_TARGETS} noun="spreadsheet" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online spreadsheet converter converts between spreadsheet formats —
      Excel XLS and XLSX, OpenDocument ODS, Apple Numbers, and CSV. Upload a file,
      pick a target format (XLSX, XLS, ODS, CSV or PDF), and convert.
    </p>
    <p>
      Binary and proprietary spreadsheet formats can't be read reliably in a
      browser, so conversion is handled on our servers.
      Your file is uploaded to our servers, converted on their
      servers, and returned as a download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="svg-to-eps">
  <ArchiveConvert slug="svg-to-eps" from="svg" to="eps" noun="vector file" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SVG to EPS converter converts scalable SVG vectors to Encapsulated PostScript EPS for print workflows.
    </p>
    <p>
      Conversion is handled on our servers, because these
      vector formats can't be read reliably in a browser. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

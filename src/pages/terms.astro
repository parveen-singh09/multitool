---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `Terms & Conditions — ${SITE.name}`,
  url: `${SITE.url}/terms`,
};
---

<Layout
  title="Terms & Conditions"
  description={`The terms and conditions for using ${SITE.name}'s free online tools.`}
  jsonLd={jsonLd}
>
  <Header />

  <main class="container-page py-14">
    <div class="mx-auto max-w-3xl">
      <span class="eyebrow text-primary-hover">Legal</span>
      <h1 class="display-md mt-3 text-ink">Terms &amp; Conditions</h1>

      <div class="mt-8 flex flex-col gap-4 text-[15px] leading-relaxed text-ink-muted">
        <p>
          By using {SITE.name}, you agree to these terms. If you do not agree,
          please do not use the site.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Use of the service</h2>
        <p>
          {SITE.name} provides free online tools for personal and commercial use.
          You may use them without creating an account. You agree not to misuse the
          site — for example by attempting to disrupt it, overload it, or use it for
          unlawful purposes.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">No warranty</h2>
        <p>
          The tools are provided “as is” and “as available”, without warranties of
          any kind, express or implied. While we work to keep every tool accurate
          and reliable, we do not guarantee that results will be error-free or fit
          for a particular purpose. Always verify important results independently.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Limitation of liability</h2>
        <p>
          To the fullest extent permitted by law, {SITE.name} and its authors are
          not liable for any loss or damage arising from your use of, or inability
          to use, the tools — including any loss of data or inaccurate output.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Intellectual property</h2>
        <p>
          The {SITE.name} name, design, and site content are the property of their
          respective owners. Content you enter into a tool remains yours; most tools
          run entirely in your browser and never send that content to us.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Changes to these terms</h2>
        <p>
          We may update these terms from time to time. Continued use of the site
          after changes take effect means you accept the revised terms.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Contact</h2>
        <p>
          Questions about these terms? See the <a href="/contact" class="text-primary-hover underline">contact page</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

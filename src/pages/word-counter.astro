---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="word-counter">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="panel p-4 text-center">
        <div id="stat-words" class="font-display text-2xl font-semibold text-ink">0</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Words</div>
      </div>
      <div class="panel p-4 text-center">
        <div id="stat-chars" class="font-display text-2xl font-semibold text-ink">0</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Characters</div>
      </div>
      <div class="panel p-4 text-center">
        <div id="stat-sentences" class="font-display text-2xl font-semibold text-ink">0</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Sentences</div>
      </div>
      <div class="panel p-4 text-center">
        <div id="stat-reading" class="font-display text-2xl font-semibold text-ink">0s</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Reading time</div>
      </div>
    </div>

    <div class="copy-wrap">
      <textarea
        id="wc-input"
        class="field min-h-64 resize-y font-sans"
        placeholder="Start typing or paste your text here…"
        aria-label="Text to count"
      ></textarea>
      <button type="button" class="copy-icon" data-copy-target="#wc-input" aria-label="Copy"></button>
    </div>

    <div class="flex flex-wrap gap-3 text-[13px] text-ink-subtle">
      <span>Characters (no spaces): <span id="stat-nospace" class="text-ink">0</span></span>
      <span>Paragraphs: <span id="stat-paragraphs" class="text-ink">0</span></span>
    </div>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('wc-input') as HTMLTextAreaElement;
  const els = {
    words: document.getElementById('stat-words')!,
    chars: document.getElementById('stat-chars')!,
    sentences: document.getElementById('stat-sentences')!,
    reading: document.getElementById('stat-reading')!,
    nospace: document.getElementById('stat-nospace')!,
    paragraphs: document.getElementById('stat-paragraphs')!,
  };

  function update() {
    const text = input.value;
    const words = (text.match(/\b\S+\b/g) || []).length;
    const chars = text.length;
    const nospace = text.replace(/\s/g, '').length;
    const sentences = (text.match(/[^.!?]+[.!?]+/g) || []).length;
    const paragraphs = text.split(/\n\s*\n/).filter((p) => p.trim().length).length;
    const seconds = Math.round((words / 200) * 60);
    const readingTime =
      seconds < 60 ? `${seconds}s` : `${Math.floor(seconds / 60)}m ${seconds % 60}s`;

    els.words.textContent = words.toLocaleString();
    els.chars.textContent = chars.toLocaleString();
    els.sentences.textContent = sentences.toLocaleString();
    els.reading.textContent = readingTime;
    els.nospace.textContent = nospace.toLocaleString();
    els.paragraphs.textContent = paragraphs.toLocaleString();
  }

  input.addEventListener('input', update);
  update();
</script>

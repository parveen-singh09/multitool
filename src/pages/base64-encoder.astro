---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="base64-encoder">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <div class="inline-flex rounded-md border border-hairline p-0.5" role="tablist" aria-label="Mode">
        <button id="mode-encode" class="btn btn-tertiary px-3 py-1 text-sm" role="tab" aria-selected="true">Encode</button>
        <button id="mode-decode" class="btn btn-tertiary px-3 py-1 text-sm" role="tab" aria-selected="false">Decode</button>
      </div>
      <button id="b64-run" class="btn btn-primary">Encode →</button>
      <button id="b64-swap" class="btn btn-tertiary" title="Move output to input">Swap</button>
      <button id="b64-clear" class="btn btn-tertiary">Clear</button>
    </div>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink-subtle">
      <label class="inline-flex items-center gap-2"><input id="opt-live" type="checkbox" checked /> Live</label>
      <label class="inline-flex items-center gap-2"><input id="opt-urlsafe" type="checkbox" /> URL-safe (<code>-_</code>, no padding)</label>
      <label id="wrap-label" class="inline-flex items-center gap-2"><input id="opt-wrap" type="checkbox" /> Wrap at 76 chars (MIME)</label>
      <label id="perline-label" class="hidden items-center gap-2"><input id="opt-perline" type="checkbox" /> Decode each line separately</label>
      <label id="charset-label" class="inline-flex items-center gap-2">
        Character set
        <select id="opt-charset" class="field h-8 py-0 text-sm">
          <optgroup label="Popular">
            <option value="auto" selected>Auto-detect</option>
            <option value="utf-8">UTF-8</option>
            <option value="us-ascii">ASCII</option>
            <option value="iso-8859-1">ISO-8859-1 (Latin-1)</option>
            <option value="iso-8859-2">ISO-8859-2</option>
            <option value="iso-8859-15">ISO-8859-15</option>
            <option value="windows-1252">Windows-1252</option>
          </optgroup>
          <optgroup label="Cyrillic">
            <option value="windows-1251">Windows-1251</option>
            <option value="koi8-r">KOI8-R</option>
            <option value="koi8-u">KOI8-U</option>
            <option value="ibm866">CP866</option>
          </optgroup>
          <optgroup label="Other European">
            <option value="iso-8859-5">ISO-8859-5</option>
            <option value="iso-8859-7">ISO-8859-7 (Greek)</option>
            <option value="iso-8859-9">ISO-8859-9 (Turkish)</option>
            <option value="windows-1250">Windows-1250</option>
            <option value="windows-1253">Windows-1253</option>
            <option value="windows-1254">Windows-1254</option>
          </optgroup>
          <optgroup label="Asian">
            <option value="shift_jis">Shift_JIS (CP932)</option>
            <option value="euc-jp">EUC-JP</option>
            <option value="iso-2022-jp">ISO-2022-JP</option>
            <option value="gbk">GBK (CP936)</option>
            <option value="gb18030">GB18030</option>
            <option value="big5">Big5 (CP950)</option>
            <option value="euc-kr">EUC-KR</option>
          </optgroup>
          <optgroup label="Unicode">
            <option value="utf-16le">UTF-16 LE</option>
            <option value="utf-16be">UTF-16 BE</option>
          </optgroup>
        </select>
      </label>
    </div>

    <div id="b64-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <label for="b64-input" class="text-sm text-ink-subtle">Input</label>
          <span id="in-count" class="text-xs text-ink-tertiary">0 chars</span>
        </div>
        <div class="copy-wrap">
          <textarea id="b64-input" class="field min-h-52 resize-y font-mono text-[13px]" placeholder="Text or Base64…" spellcheck="false"></textarea>
          <button type="button" class="copy-icon" data-copy-target="#b64-input" aria-label="Copy"></button>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button id="b64-load" class="btn btn-secondary text-sm">Load file…</button>
          <input id="b64-file" type="file" class="hidden" />
        </div>
      </div>
      <div class="flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <label for="b64-output" class="text-sm text-ink-subtle">Output</label>
          <span id="out-count" class="text-xs text-ink-tertiary">0 chars</span>
        </div>
        <div class="copy-wrap">
          <textarea id="b64-output" class="field min-h-52 resize-y font-mono text-[13px]" placeholder="Result…" spellcheck="false" readonly></textarea>
          <button type="button" class="copy-icon" data-copy-target="#b64-output" aria-label="Copy"></button>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button id="b64-download" class="btn btn-tertiary text-sm">Download</button>
        </div>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const input = $<HTMLTextAreaElement>('b64-input');
  const output = $<HTMLTextAreaElement>('b64-output');
  const status = $('b64-status');
  const runBtn = $('b64-run');
  const encTab = $('mode-encode');
  const decTab = $('mode-decode');
  const inCount = $('in-count');
  const outCount = $('out-count');
  const optLive = $<HTMLInputElement>('opt-live');
  const optUrlSafe = $<HTMLInputElement>('opt-urlsafe');
  const optWrap = $<HTMLInputElement>('opt-wrap');
  const optPerLine = $<HTMLInputElement>('opt-perline');
  const optCharset = $<HTMLSelectElement>('opt-charset');
  const wrapLabel = $('wrap-label');
  const perLineLabel = $('perline-label');

  const enc = new TextEncoder();
  let mode: 'encode' | 'decode' = 'encode';

  const MULTIBYTE = new Set([
    'shift_jis', 'euc-jp', 'iso-2022-jp', 'gbk', 'gb18030', 'big5', 'euc-kr', 'utf-16le', 'utf-16be',
  ]);

  const revMapCache = new Map<string, Map<string, number>>();
  function reverseMap(cs: string): Map<string, number> {
    let m = revMapCache.get(cs);
    if (m) return m;
    m = new Map();
    const d = new TextDecoder(cs);
    for (let b = 0; b < 256; b++) {
      const ch = d.decode(new Uint8Array([b]));
      if (ch && !m.has(ch)) m.set(ch, b);
    }
    revMapCache.set(cs, m);
    return m;
  }

  function textToBytes(str: string): Uint8Array {
    const cs = optCharset.value;
    if (cs === 'auto' || cs === 'utf-8' || cs === 'us-ascii' || MULTIBYTE.has(cs)) {
      return enc.encode(str);
    }
    const map = reverseMap(cs);
    const out = new Uint8Array(str.length);
    for (let i = 0; i < str.length; i++) {
      const b = map.get(str[i]);
      if (b === undefined) throw new Error(`"${str[i]}" can't be represented in ${cs}`);
      out[i] = b;
    }
    return out;
  }

  function bytesToText(bytes: Uint8Array): string {
    const cs = optCharset.value;
    if (cs === 'auto') {
      try {
        return new TextDecoder('utf-8', { fatal: true }).decode(bytes);
      } catch {
        return new TextDecoder('windows-1252').decode(bytes);
      }
    }

    return new TextDecoder(cs, { fatal: true }).decode(bytes);
  }

  const toUrlSafe = (s: string) => s.replace(/\+/g, '-').replace(/\//g, '_');
  const fromUrlSafe = (s: string) => s.replace(/-/g, '+').replace(/_/g, '/');
  const wrap76 = (s: string) => s.replace(/.{76}/g, '$&\n');

  function bytesToB64(bytes: Uint8Array): string {
    let bin = '';
    for (const b of bytes) bin += String.fromCharCode(b);
    let b64 = btoa(bin);
    if (optUrlSafe.checked) b64 = toUrlSafe(b64);
    if (optWrap.checked) b64 = wrap76(b64);
    return b64;
  }

  function b64ToText(b64: string): string {
    let s = b64.replace(/\s+/g, '');
    if (optUrlSafe.checked || /[-_]/.test(s)) s = fromUrlSafe(s);
    if (s.length % 4) s += '='.repeat(4 - (s.length % 4)); 
    const bin = atob(s);
    const bytes = Uint8Array.from(bin, (c) => c.charCodeAt(0));
    return bytesToText(bytes);
  }

  function showError(msg: string) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = '#d14d4d';
    status.style.color = '#e08585';
  }
  function showNote(msg: string) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = 'var(--color-hairline-strong)';
    status.style.color = 'var(--color-ink-subtle)';
  }
  const clearError = () => status.classList.add('hidden');

  function run() {
    clearError();
    const src = input.value;
    if (!src) {
      output.value = '';
      updateCounts();
      return;
    }
    try {
      if (mode === 'encode') {
        output.value = bytesToB64(textToBytes(src));
        const cs = optCharset.value;
        if (MULTIBYTE.has(cs)) showNote(`Encoding uses UTF-8 — ${cs} encode isn't supported by browsers.`);
      } else if (optPerLine.checked) {
        output.value = src
          .split(/\r?\n/)
          .map((line) => (line.trim() ? b64ToText(line) : ''))
          .join('\n');
      } else {
        output.value = b64ToText(src);
      }
    } catch (e) {
      output.value = '';
      showError(
        mode === 'encode'
          ? (e as Error).message || 'Could not encode this input.'
          : 'Invalid Base64 — check for stray characters or wrong URL-safe setting.'
      );
    }
    updateCounts();
  }

  function updateCounts() {
    const inBytes = enc.encode(input.value).length;
    const outBytes = enc.encode(output.value).length;
    inCount.textContent = `${input.value.length} chars · ${inBytes} bytes`;
    outCount.textContent = `${output.value.length} chars · ${outBytes} bytes`;
  }

  function setMode(next: 'encode' | 'decode') {
    mode = next;
    const isEnc = next === 'encode';
    encTab.setAttribute('aria-selected', String(isEnc));
    decTab.setAttribute('aria-selected', String(!isEnc));
    encTab.classList.toggle('btn-secondary', isEnc);
    decTab.classList.toggle('btn-secondary', !isEnc);
    runBtn.textContent = isEnc ? 'Encode →' : '← Decode';
    wrapLabel.classList.toggle('hidden', !isEnc);
    wrapLabel.classList.toggle('inline-flex', isEnc);
    perLineLabel.classList.toggle('hidden', isEnc);
    perLineLabel.classList.toggle('inline-flex', !isEnc);
    input.placeholder = isEnc ? 'Text to encode…' : 'Base64 to decode…';
    run();
  }

  encTab.addEventListener('click', () => setMode('encode'));
  decTab.addEventListener('click', () => setMode('decode'));
  runBtn.addEventListener('click', run);
  [optUrlSafe, optWrap, optPerLine, optCharset].forEach((el) => el.addEventListener('change', run));

  input.addEventListener('input', () => {
    updateCounts();
    if (optLive.checked) run();
  });

  $('b64-swap').addEventListener('click', () => {
    input.value = output.value;
    output.value = '';
    setMode(mode === 'encode' ? 'decode' : 'encode');
  });
  $('b64-clear').addEventListener('click', () => {
    input.value = output.value = '';
    clearError();
    updateCounts();
  });

  $('b64-download').addEventListener('click', () => {
    const blob = new Blob([output.value], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = mode === 'encode' ? 'encoded.txt' : 'decoded.txt';
    a.click();
    URL.revokeObjectURL(a.href);
  });

  // Load file: encode mode reads bytes → Base64; decode mode reads text.
  const fileInput = $<HTMLInputElement>('b64-file');
  $('b64-load').addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    clearError();
    if (mode === 'encode') {
      const buf = new Uint8Array(await file.arrayBuffer());
      input.value = `[${file.name}, ${buf.length} bytes]`;
      output.value = bytesToB64(buf);
      updateCounts();
    } else {
      input.value = await file.text();
      run();
    }
    fileInput.value = '';
  });

  setMode('encode');
</script>

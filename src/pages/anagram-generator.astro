---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="anagram-generator">
  <div class="flex flex-col gap-5">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Letters, word or phrase
      <input id="an-in" class="field" value="dormitory" spellcheck="false" maxlength="24" autocomplete="off" />
    </label>

    <div class="flex flex-wrap gap-2">
      <button id="an-mode-full" class="btn btn-primary" data-mode="full">Full anagrams</button>
      <button id="an-mode-within" class="btn btn-secondary" data-mode="within">Words within</button>
      <button id="an-scramble" class="btn btn-secondary ml-auto">Scramble</button>
    </div>

    <details id="an-opts" class="rounded-lg border border-hairline bg-surface-1 px-4 py-3">
      <summary class="cursor-pointer text-sm text-ink-subtle select-none">Advanced options</summary>
      <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Include word(s) — force into every result
          <input id="an-include" class="field" spellcheck="false" autocomplete="off" placeholder="e.g. my" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Max words per anagram
          <input id="an-maxwords" class="field" type="number" min="1" max="6" value="2" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Shortest word length
          <input id="an-minlen" class="field" type="number" min="1" max="24" value="2" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Longest word length
          <input id="an-maxlen" class="field" type="number" min="1" max="24" placeholder="auto" />
        </label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          <input id="an-cap" type="checkbox" class="accent-primary" /> Capitalize each word
        </label>
      </div>
    </details>

    <div class="flex items-baseline justify-between border-t border-hairline pt-4">
      <p id="an-summary" class="text-sm text-ink-subtle">Loading dictionary…</p>
    </div>
    <div class="copy-wrap">
      <div id="an-out" class="flex flex-col gap-4"></div>
      <button type="button" id="an-copy-icon" class="copy-icon" aria-label="Copy"></button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free anagram generator rearranges the letters of any word or phrase into new
      words and multi-word phrases. In <strong>Full anagrams</strong> mode it uses every
      letter — turning "dormitory" into "dirty room" — searching a 360,000-word dictionary
      right in your browser. Use the advanced options to force a word into every result,
      cap how many words each anagram may use, or set minimum and maximum word lengths.
    </p>
    <p>
      Switch to <strong>Words within</strong> to find every word you can spell from a subset
      of the letters, grouped by length — handy for Scrabble, Words with Friends, crosswords
      and word puzzles.
    </p>
  </div>
</ToolLayout>

<script>
  import { shuffle } from '../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const inEl = $('an-in') as HTMLInputElement;
  const includeEl = $('an-include') as HTMLInputElement;
  const maxWordsEl = $('an-maxwords') as HTMLInputElement;
  const minLenEl = $('an-minlen') as HTMLInputElement;
  const maxLenEl = $('an-maxlen') as HTMLInputElement;
  const capEl = $('an-cap') as HTMLInputElement;
  const optsEl = $('an-opts') as HTMLDetailsElement;
  const out = $('an-out')!;
  const summary = $('an-summary')!;

  const A = 'a'.charCodeAt(0);
  const RESULT_CAP = 400; 
  const STEP_CAP = 4_000_000; 

  function sig(s: string): Int32Array {
    const v = new Int32Array(26);
    for (let i = 0; i < s.length; i++) {
      const k = s.charCodeAt(i) - A;
      if (k >= 0 && k < 26) v[k]++;
    }
    return v;
  }
  const clean = (s: string) => s.toLowerCase().replace(/[^a-z]/g, '');

  let WORDS: string[] = [];
  let SIGS: Uint8Array; 
  let dictReady: Promise<void> | null = null;

  function loadDict(): Promise<void> {
    if (dictReady) return dictReady;
    dictReady = (async () => {
      const res = await fetch('/squaredle-dict.txt.gz');
      if (!res.ok) throw new Error('dict fetch failed');
      const buf = new Uint8Array(await res.arrayBuffer());

      const gzipped = buf[0] === 0x1f && buf[1] === 0x8b;
      let text: string;
      if (gzipped && 'DecompressionStream' in window) {
        const ds = new (window as any).DecompressionStream('gzip');
        text = await new Response(new Blob([buf]).stream().pipeThrough(ds)).text();
      } else {
        text = new TextDecoder().decode(buf);
      }
      const words: string[] = [];
      for (const line of text.split('\n')) {
        const w = line.trim();
        if (w.length >= 1 && /^[a-z]+$/.test(w)) words.push(w);
      }
      WORDS = words;
      SIGS = new Uint8Array(words.length * 26);
      for (let i = 0; i < words.length; i++) {
        const w = words[i];
        const base = i * 26;
        for (let j = 0; j < w.length; j++) SIGS[base + w.charCodeAt(j) - A]++;
      }
    })();
    return dictReady;
  }

  let mode: 'full' | 'within' = 'full';
  let lastList: string[] = [];

  const titleCase = (s: string) =>
    s.replace(/\b[a-z]/g, (m) => m.toUpperCase());

  function fullAnagrams(pool: Int32Array): { results: string[]; capped: boolean } {
    const total = pool.reduce((a, b) => a + b, 0);
    const maxWords = Math.max(1, Math.min(6, parseInt(maxWordsEl.value) || 2));
    const minLen = Math.max(1, parseInt(minLenEl.value) || 1);
    const maxLen = parseInt(maxLenEl.value) || total;

    const cand: { i: number; len: number; w: string }[] = [];
    for (let i = 0; i < WORDS.length; i++) {
      const w = WORDS[i];
      if (w.length < minLen || w.length > maxLen || w.length > total) continue;
      const base = i * 26;
      let ok = true;
      for (let k = 0; k < 26; k++) {
        if (SIGS[base + k] > pool[k]) { ok = false; break; }
      }
      if (ok) cand.push({ i, len: w.length, w });
    }
    cand.sort((a, b) => b.len - a.len || (a.w < b.w ? -1 : 1));

    const results: string[] = [];
    const remaining = Int32Array.from(pool);
    const chosen: string[] = [];
    let steps = 0;
    let capped = false;

    function recurse(start: number, left: number): void {
      if (results.length >= RESULT_CAP || capped) return;
      if (left === 0) {
        results.push(chosen.join(' '));
        return;
      }
      if (chosen.length >= maxWords) return; 
      for (let ci = start; ci < cand.length; ci++) {
        if (++steps > STEP_CAP) { capped = true; return; }
        const { i, len } = cand[ci];
        if (len > left) continue;
        const base = i * 26;
        let fits = true;
        for (let k = 0; k < 26; k++) {
          if (SIGS[base + k] > remaining[k]) { fits = false; break; }
        }
        if (!fits) continue;
        for (let k = 0; k < 26; k++) remaining[k] -= SIGS[base + k];
        chosen.push(cand[ci].w);
        recurse(ci, left - len); 
        chosen.pop();
        for (let k = 0; k < 26; k++) remaining[k] += SIGS[base + k];
        if (results.length >= RESULT_CAP || capped) return;
      }
    }
    recurse(0, total);
    return { results, capped };
  }

  function wordsWithin(pool: Int32Array, self: string): string[] {
    const total = pool.reduce((a, b) => a + b, 0);
    const minLen = Math.max(1, parseInt(minLenEl.value) || 1);
    const maxLen = parseInt(maxLenEl.value) || total;
    const hits: string[] = [];
    for (let i = 0; i < WORDS.length; i++) {
      const w = WORDS[i];
      if (w === self || w.length < minLen || w.length > maxLen || w.length > total) continue;
      const base = i * 26;
      let ok = true;
      for (let k = 0; k < 26; k++) {
        if (SIGS[base + k] > pool[k]) { ok = false; break; }
      }
      if (ok) hits.push(w);
    }
    return hits;
  }

  function chip(w: string) {
    return `<span class="rounded-md border border-hairline bg-surface-1 px-2.5 py-1 text-[15px] text-ink">${w}</span>`;
  }

  function solve() {
    const raw = clean(inEl.value);
    if (!raw) {
      summary.textContent = 'Type some letters to begin.';
      out.innerHTML = '';
      lastList = [];
      return;
    }

    if (mode === 'within') {
      const list = wordsWithin(sig(raw), raw);
      lastList = list;
      if (!list.length) {
        summary.textContent = `No words found within "${raw}".`;
        out.innerHTML = '';
        return;
      }
      const groups = new Map<number, string[]>();
      for (const w of list) (groups.get(w.length) ?? groups.set(w.length, []).get(w.length)!).push(w);
      const lengths = [...groups.keys()].sort((a, b) => b - a);
      summary.textContent = `${list.length} word${list.length === 1 ? '' : 's'} within "${raw}".`;
      out.innerHTML = lengths
        .map((len) => {
          const words = groups.get(len)!.sort();
          return `<div class="flex flex-col gap-2">
            <span class="text-[13px] font-medium uppercase tracking-wide text-ink-tertiary">${len} letters · ${words.length}</span>
            <div class="flex flex-wrap gap-2">${words.map(chip).join('')}</div>
          </div>`;
        })
        .join('');
      return;
    }

    const pool = sig(raw);
    const includeWords = clean(includeEl.value).length
      ? includeEl.value.trim().split(/\s+/).map(clean).filter(Boolean)
      : [];
    const prefix: string[] = [];
    for (const iw of includeWords) {
      const s = sig(iw);
      let fits = true;
      for (let k = 0; k < 26; k++) if (s[k] > pool[k]) { fits = false; break; }
      if (!fits) {
        summary.textContent = `Can't include "${iw}" — its letters aren't all in "${raw}".`;
        out.innerHTML = '';
        lastList = [];
        return;
      }
      for (let k = 0; k < 26; k++) pool[k] -= s[k];
      prefix.push(iw);
    }

    summary.textContent = 'Searching…';
    out.innerHTML = '';
    setTimeout(() => {
      if (clean(inEl.value) !== raw) return;
      const { results, capped } = fullAnagrams(pool);
      let phrases = results.map((r) => (prefix.length ? prefix.join(' ') + ' ' + r : r));
      phrases = phrases.filter((p) => clean(p) !== raw + prefix.join(''));
      phrases.sort((a, b) => a.split(' ').length - b.split(' ').length || (a < b ? -1 : 1));
      if (capEl.checked) phrases = phrases.map(titleCase);
      lastList = phrases;

      if (!phrases.length) {
        summary.textContent = `No full anagrams found for "${raw}".`;
        return;
      }
      summary.textContent = capped
        ? `Showing first ${phrases.length} anagrams (search limited).`
        : `${phrases.length} full anagram${phrases.length === 1 ? '' : 's'} of "${raw}".`;
      out.innerHTML = `<div class="flex flex-wrap gap-2">${phrases.map(chip).join('')}</div>`;
    }, 0);
  }

  function setMode(m: 'full' | 'within') {
    mode = m;
    ($('an-mode-full') as HTMLButtonElement).className =
      'btn ' + (m === 'full' ? 'btn-primary' : 'btn-secondary');
    ($('an-mode-within') as HTMLButtonElement).className =
      'btn ' + (m === 'within' ? 'btn-primary' : 'btn-secondary');
    optsEl.style.display = '';
    if (WORDS.length) solve();
  }
  $('an-mode-full').addEventListener('click', () => setMode('full'));
  $('an-mode-within').addEventListener('click', () => setMode('within'));

  let t: number | undefined;
  const debounced = () => {
    clearTimeout(t);
    t = window.setTimeout(() => WORDS.length && solve(), 200);
  };
  [inEl, includeEl, maxWordsEl, minLenEl, maxLenEl].forEach((el) =>
    el.addEventListener('input', debounced)
  );
  capEl.addEventListener('change', () => WORDS.length && solve());

  $('an-scramble').addEventListener('click', () => {
    const raw = clean(inEl.value);
    if (raw.length > 1) inEl.value = shuffle([...raw]).join('');
    if (WORDS.length) solve();
  });

  $('an-copy-icon').addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    navigator.clipboard.writeText(lastList.join('\n'));
    btn.classList.add('copied');
    btn.setAttribute('aria-label', 'Copied');
    setTimeout(() => { btn.classList.remove('copied'); btn.setAttribute('aria-label', 'Copy'); }, 1500);
  });

  loadDict()
    .then(() => {
      summary.textContent = 'Ready.';
      solve();
    })
    .catch(() => {
      summary.textContent = 'Failed to load the dictionary. Try reloading.';
    });
</script>

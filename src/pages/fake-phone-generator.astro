---
import ToolLayout from '../layouts/ToolLayout.astro';
import { COUNTRIES } from '../lib/fphone';
---

<ToolLayout slug="fake-phone-generator">
  <div class="flex flex-col gap-6">

    <section class="flex flex-col gap-3">
      <div class="flex flex-wrap items-end gap-3">
        <div class="flex flex-col gap-1 text-sm text-ink-subtle">
          <span>Country</span>
          <div id="fp-country-wrap" class="relative">
            <select id="fp-country" class="sr-only" tabindex="-1" aria-hidden="true"></select>
            <button id="fp-country-btn" type="button" class="field flex w-auto items-center gap-2 text-left" aria-haspopup="listbox" aria-expanded="false">
              <img id="fp-country-btn-flag" alt="" width="20" height="15" class="rounded-[2px]" />
              <span id="fp-country-btn-label" class="text-ink">United States (+1)</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-ink-subtle"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div id="fp-country-pop" class="absolute left-0 z-20 mt-1 hidden w-72 max-w-[90vw] overflow-hidden rounded-md border border-hairline bg-surface-1 shadow-xl">
              <input id="fp-country-search" type="text" placeholder="Search country…" class="field w-full rounded-none border-x-0 border-t-0" spellcheck="false" autocomplete="off" />
              <ul id="fp-country-list" role="listbox" class="max-h-64 overflow-y-auto py-1"></ul>
            </div>
          </div>
        </div>
        <button id="fp-new" class="btn btn-primary ml-auto">New number</button>
      </div>
      <div id="fp-card" class="panel panel-lift grid grid-cols-1 gap-x-6 gap-y-2 p-5 sm:grid-cols-2"></div>
      <p class="text-xs text-ink-tertiary">Click any format to copy it.</p>
    </section>

    <section class="flex flex-col gap-3 border-t border-hairline pt-5">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
          <input id="fp-count" type="number" min="1" max="1000" value="10" class="field w-28" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Style
          <select id="fp-style" class="field w-44">
            <option value="national" selected>National</option>
            <option value="international">International</option>
            <option value="e164">E.164</option>
            <option value="plain">Digits only</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Output
          <select id="fp-fmt" class="field w-32">
            <option value="list" selected>List</option>
            <option value="csv">CSV</option>
            <option value="json">JSON</option>
          </select>
        </label>
        <label class="flex items-center gap-2 self-end pb-2 text-sm text-ink-subtle">
          <input id="fp-unique" type="checkbox" checked class="size-4 accent-accent" /> Unique
        </label>
        <button id="fp-gen" class="btn btn-primary ml-auto">Generate</button>
        <button id="fp-dl" class="btn btn-secondary">Download</button>
      </div>
      <div class="copy-wrap">
        <textarea id="fp-out" class="field min-h-64 resize-y font-mono text-[13px]" readonly aria-label="Generated phone numbers"></textarea>
        <button type="button" class="copy-icon" data-copy-target="#fp-out" aria-label="Copy"></button>
      </div>
    </section>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free fake phone number generator creates random, correctly formatted phone
      numbers for {COUNTRIES.length} countries — United States, Canada, United Kingdom,
      Australia, Germany, France, Italy, Spain, Netherlands, Sweden, Japan, China, India,
      Brazil, Mexico and Russia. Pick a country for a single number shown in every
      format at once — national, international, E.164 and plain digits — with click-to-copy,
      or generate up to a thousand at once in the style you choose and export them as a
      plain list, CSV or JSON.
    </p>
    <p>
      Every number is fictional. US and Canadian numbers use the reserved 555-01xx range
      and UK numbers use Ofcom's 07700 900xxx drama range, so they can never dial a real
      person; elsewhere the subscriber digits are randomised. Tick <em>Unique</em> to
      guarantee no duplicates in a batch. Use it to test phone fields and validation, seed sample
      databases and build demos. Need a matching identity? Try the fake address and fake
      name generators, or check formatting with the phone number validator.
    </p>
  </div>
</ToolLayout>

<script>
  import { COUNTRIES, generate, styleOf, type Phone, type Style } from '../lib/fphone';

  const $ = (id: string) => document.getElementById(id)!;
  const countryEl = $('fp-country') as HTMLSelectElement;

  const flagUrl = (code: string) => `https://flagcdn.com/40x30/${code.toLowerCase()}.png`;
  const cbBtn = $('fp-country-btn') as HTMLButtonElement;
  const cbFlag = $('fp-country-btn-flag') as HTMLImageElement;
  const cbLabel = $('fp-country-btn-label')!;
  const cbPop = $('fp-country-pop')!;
  const cbSearch = $('fp-country-search') as HTMLInputElement;
  const cbList = $('fp-country-list')!;

  countryEl.append(...COUNTRIES.map((c) => {
    const el = document.createElement('option');
    el.value = c.code;
    el.textContent = `${c.name} (${c.dialCode})`;
    return el;
  }));

  const cbRows = COUNTRIES.map((c) => {
    const li = document.createElement('li');
    li.role = 'option';
    li.dataset.code = c.code;
    li.className = 'flex cursor-pointer items-center gap-2 px-3 py-1.5 text-[13px] text-ink hover:bg-surface-2 aria-selected:bg-surface-2';
    const img = document.createElement('img');
    img.width = 20; img.height = 15; img.alt = ''; img.className = 'rounded-[2px]';
    img.src = flagUrl(c.code);
    img.addEventListener('error', () => { img.style.visibility = 'hidden'; });
    const span = document.createElement('span');
    span.textContent = `${c.name} (${c.dialCode})`;
    li.append(img, span);
    li.addEventListener('click', () => selectCountry(c.code));
    return li;
  });
  cbList.append(...cbRows);

  function syncCountryBtn() {
    const c = COUNTRIES.find((x) => x.code === countryEl.value);
    if (!c) return;
    cbFlag.src = flagUrl(c.code);
    cbFlag.style.visibility = 'visible';
    cbLabel.textContent = `${c.name} (${c.dialCode})`;
  }
  cbFlag.addEventListener('error', () => { cbFlag.style.visibility = 'hidden'; });

  function filterCountries(q: string) {
    const needle = q.trim().toLowerCase();
    cbRows.forEach((li, i) => {
      const c = COUNTRIES[i];
      const hit = !needle || c.name.toLowerCase().includes(needle) || c.dialCode.includes(needle) || c.code.toLowerCase().includes(needle);
      li.classList.toggle('hidden', !hit);
    });
  }
  function openCbPop() {
    cbPop.classList.remove('hidden');
    cbBtn.setAttribute('aria-expanded', 'true');
    cbSearch.value = ''; filterCountries(''); cbSearch.focus();
  }
  function closeCbPop() {
    cbPop.classList.add('hidden');
    cbBtn.setAttribute('aria-expanded', 'false');
  }
  function selectCountry(code: string) {
    countryEl.value = code;
    syncCountryBtn();
    closeCbPop();
    renderCard(); generateBulk();
    cbBtn.focus();
  }
  cbBtn.addEventListener('click', () => (cbPop.classList.contains('hidden') ? openCbPop() : closeCbPop()));
  cbSearch.addEventListener('input', () => filterCountries(cbSearch.value));
  cbSearch.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      const first = cbRows.find((li) => !li.classList.contains('hidden'));
      if (first?.dataset.code) selectCountry(first.dataset.code);
    } else if (e.key === 'Escape') { closeCbPop(); cbBtn.focus(); }
  });
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('#fp-country-wrap')) closeCbPop();
  });

  countryEl.value = 'US';
  syncCountryBtn();

  const card = $('fp-card');
  const countEl = $('fp-count') as HTMLInputElement;
  const styleEl = $('fp-style') as HTMLSelectElement;
  const fmtEl = $('fp-fmt') as HTMLSelectElement;
  const uniqueEl = $('fp-unique') as HTMLInputElement;
  const out = $('fp-out') as HTMLTextAreaElement;

  const attr = (s: string) => s.replace(/"/g, '&quot;');

  const CARD_FIELDS: [Style, string][] = [
    ['national', 'National'], ['international', 'International'],
    ['e164', 'E.164'], ['plain', 'Digits only'],
  ];

  function renderCard() {
    const p = generate(countryEl.value);
    card.innerHTML = CARD_FIELDS.map(([s, label]) => {
      const v = styleOf(p, s);
      return `<button type="button" class="fp-field flex flex-col items-start gap-0.5 rounded-md p-1 text-left transition-colors hover:bg-surface-2" data-copy="${attr(v)}">
           <span class="text-xs uppercase tracking-wide text-ink-tertiary">${label}</span>
           <span class="font-mono text-sm text-ink">${attr(v)}</span>
         </button>`;
    }).join('');
  }

  card.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.fp-field');
    if (!btn) return;
    await navigator.clipboard.writeText(btn.dataset.copy || '');
    const label = btn.querySelector('span:first-child')!;
    const orig = label.textContent;
    label.textContent = 'Copied!';
    setTimeout(() => (label.textContent = orig), 1200);
  });

  function build(n: number, unique: boolean): Phone[] {
    const list: Phone[] = [];
    const seen = new Set<string>();
    for (let tries = 0; list.length < n && tries < n * 50; tries++) {
      const p = generate(countryEl.value);
      if (unique && !seen.has(p.plain)) { seen.add(p.plain); list.push(p); }
      else if (!unique) list.push(p);
    }
    return list;
  }

  function csvCell(v: string): string {
    return /[",\n]/.test(v) ? '"' + v.replace(/"/g, '""') + '"' : v;
  }

  function format(list: Phone[]): string {
    const style = styleEl.value as Style;
    const fmt = fmtEl.value;
    if (fmt === 'json') return JSON.stringify(list.map((p) => ({ country: p.country, number: styleOf(p, style) })), null, 2);
    if (fmt === 'csv') return ['country,number', ...list.map((p) => `${csvCell(p.country)},${csvCell(styleOf(p, style))}`)].join('\n');
    return list.map((p) => styleOf(p, style)).join('\n');
  }

  function generateBulk() {
    const n = Math.max(1, Math.min(1000, Number(countEl.value) || 1));
    out.value = format(build(n, uniqueEl.checked));
  }

  const ext = () => (fmtEl.value === 'json' ? 'json' : fmtEl.value === 'csv' ? 'csv' : 'txt');

  $('fp-new').addEventListener('click', renderCard);
  [countEl, styleEl, fmtEl].forEach((el) => el.addEventListener('input', generateBulk));
  uniqueEl.addEventListener('change', generateBulk);
  $('fp-gen').addEventListener('click', generateBulk);
  $('fp-dl').addEventListener('click', () => {
    const type = fmtEl.value === 'json' ? 'application/json' : fmtEl.value === 'csv' ? 'text/csv' : 'text/plain';
    const url = URL.createObjectURL(new Blob([out.value], { type }));
    const a = document.createElement('a');
    a.href = url; a.download = `fake-phone-numbers.${ext()}`; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });

  renderCard();
  generateBulk();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="htaccess-generator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">

    <div class="flex flex-col gap-3">

      <details class="ha-sec" open>
        <summary>Redirects &amp; HTTPS</summary>
        <div class="ha-body">
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="https" checked /> Force HTTPS (redirect http → https)</label>
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="www" /> Force www</label>
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="nonwww" /> Force non-www</label>
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="trailing" /> Remove trailing slash</label>
          <div class="ha-grp">
            <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="redir301" /> 301 redirect (old → new)</label>
            <div class="ha-fields">
              <input class="field ha-in" data-k="redir301" data-f="from" placeholder="/old-page.html" spellcheck="false" />
              <input class="field ha-in" data-k="redir301" data-f="to" placeholder="/new-page.html or https://…" spellcheck="false" />
            </div>
          </div>
        </div>
      </details>

      <details class="ha-sec">
        <summary>Custom error pages</summary>
        <div class="ha-body ha-fields">
          <label class="ha-lbl">400 Bad Request<input class="field ha-in" data-k="errors" data-f="400" placeholder="/errors/400.html" spellcheck="false" /></label>
          <label class="ha-lbl">401 Unauthorized<input class="field ha-in" data-k="errors" data-f="401" placeholder="/errors/401.html" spellcheck="false" /></label>
          <label class="ha-lbl">403 Forbidden<input class="field ha-in" data-k="errors" data-f="403" placeholder="/errors/403.html" spellcheck="false" /></label>
          <label class="ha-lbl">404 Not Found<input class="field ha-in" data-k="errors" data-f="404" placeholder="/404.html" spellcheck="false" /></label>
          <label class="ha-lbl">500 Server Error<input class="field ha-in" data-k="errors" data-f="500" placeholder="/errors/500.html" spellcheck="false" /></label>
        </div>
      </details>

      <details class="ha-sec">
        <summary>Caching &amp; compression</summary>
        <div class="ha-body">
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="compress" checked /> Gzip compression</label>
          <div class="ha-grp">
            <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="cache" /> Browser caching</label>
            <div class="ha-fields">
              <label class="ha-lbl">File extensions (comma-separated)<input class="field ha-in" data-k="cache" data-f="ext" value="jpg,jpeg,png,gif,webp,svg,css,js,woff2" spellcheck="false" /></label>
              <div class="flex gap-2">
                <label class="ha-lbl flex-1">Duration<input class="field ha-in" type="number" min="1" data-k="cache" data-f="num" value="1" /></label>
                <label class="ha-lbl flex-1">Unit
                  <select class="field ha-in" data-k="cache" data-f="unit">
                    <option>minutes</option><option>hours</option><option>days</option>
                    <option>weeks</option><option selected>months</option><option>years</option>
                  </select>
                </label>
              </div>
              <label class="ha-chk"><input class="ha-in" type="checkbox" data-k="cache" data-f="revalidate" /> Must revalidate</label>
            </div>
          </div>
        </div>
      </details>

      <details class="ha-sec">
        <summary>Access &amp; blocking</summary>
        <div class="ha-body">
          <div class="ha-grp">
            <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="ip" /> Block / allow IPs</label>
            <div class="ha-fields">
              <label class="ha-lbl">Block these IPs (comma-separated)<input class="field ha-in" data-k="ip" data-f="block" placeholder="1.2.3.4, 5.6.7.8" spellcheck="false" /></label>
              <label class="ha-lbl">Allow only these IPs (comma-separated)<input class="field ha-in" data-k="ip" data-f="allow" placeholder="10.0.0.1" spellcheck="false" /></label>
            </div>
          </div>
          <div class="ha-grp">
            <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="hotlink" /> Prevent hotlinking</label>
            <div class="ha-fields">
              <label class="ha-lbl">Your domain<input class="field ha-in" data-k="hotlink" data-f="domain" placeholder="example.com" spellcheck="false" /></label>
              <label class="ha-lbl">Protected extensions<input class="field ha-in" data-k="hotlink" data-f="ext" value="jpg,jpeg,png,gif,webp" spellcheck="false" /></label>
              <label class="ha-lbl">Replacement image (optional)<input class="field ha-in" data-k="hotlink" data-f="img" placeholder="/nohotlink.png" spellcheck="false" /></label>
            </div>
          </div>
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="badbots" /> Block bad bots (by user-agent)</label>
        </div>
      </details>

      <details class="ha-sec">
        <summary>Password protection</summary>
        <div class="ha-body">
          <div class="ha-grp">
            <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="protect" /> Password-protect directory / file</label>
            <div class="ha-fields">
              <label class="ha-lbl">.htpasswd path (absolute on server)<input class="field ha-in" data-k="protect" data-f="path" placeholder="/home/user/.htpasswd" spellcheck="false" /></label>
              <label class="ha-lbl">Restrict to file (optional, blank = whole dir)<input class="field ha-in" data-k="protect" data-f="file" placeholder="admin.php" spellcheck="false" /></label>
            </div>
          </div>
          <div class="ha-grp">
            <p class="text-xs text-ink-tertiary">.htpasswd line generator (bcrypt)</p>
            <div class="ha-fields">
              <div class="flex gap-2">
                <input id="hp-user" class="field ha-in flex-1" placeholder="username" spellcheck="false" autocomplete="off" />
                <input id="hp-pass" class="field ha-in flex-1" placeholder="password" spellcheck="false" autocomplete="off" />
                <button id="hp-gen" type="button" class="btn btn-secondary whitespace-nowrap">Generate</button>
              </div>
              <div class="copy-wrap"><input id="hp-out" class="field font-mono text-[13px]" readonly placeholder=".htpasswd line appears here" aria-label="htpasswd line" /><button type="button" class="copy-icon" data-copy-target="#hp-out" aria-label="Copy"></button></div>
            </div>
          </div>
        </div>
      </details>

      <details class="ha-sec">
        <summary>Directory &amp; security</summary>
        <div class="ha-body">
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="nolisting" /> Disable directory listing</label>
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="protecthtaccess" checked /> Block access to .htaccess itself</label>
          <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="headers" /> Security headers (XSS, clickjacking, MIME)</label>
          <div class="ha-grp">
            <label class="ha-chk"><input class="ha-r" type="checkbox" data-k="dirindex" /> Custom default directory page</label>
            <div class="ha-fields">
              <input class="field ha-in" data-k="dirindex" data-f="page" value="index.html index.php" spellcheck="false" />
            </div>
          </div>
        </div>
      </details>
    </div>

    <div class="flex flex-col gap-2 lg:sticky lg:top-6 self-start">
      <label class="text-sm text-ink-subtle">.htaccess</label>
      <div class="copy-wrap"><pre class="hl-block field min-h-72 max-h-[70vh]" style="resize:vertical;overflow:auto"><code id="ha-out" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#ha-out" aria-label="Copy"></button></div>
      <div class="flex gap-2">
        <button id="ha-dl" class="btn btn-secondary">Download</button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free .htaccess generator assembles the Apache directives most sites
      need — force HTTPS, force www or non-www, 301 redirects, custom error pages
      for 400/401/403/404/500, Gzip compression, browser caching, IP blocking,
      hotlink protection, bad-bot blocking, password protection with a bcrypt
      <code class="font-mono text-ink">.htpasswd</code> line generator, directory
      listing controls and security headers — into one ready-to-use
      <code class="font-mono text-ink">.htaccess</code> file. Tick the rules you
      need, fill in the details, then copy or download the result to your site
      root.
    </p>
  </div>
</ToolLayout>

<style>
  .ha-sec { border: 1px solid var(--hairline, #2a2a35); border-radius: 0.5rem; overflow: hidden; }
  .ha-sec > summary { cursor: pointer; padding: 0.6rem 0.85rem; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; list-style: none; }
  .ha-sec > summary::-webkit-details-marker { display: none; }
  .ha-sec > summary::before { content: '▸'; display: inline-block; margin-right: 0.5rem; transition: transform .15s; }
  .ha-sec[open] > summary::before { transform: rotate(90deg); }
  .ha-body { display: flex; flex-direction: column; gap: 0.55rem; padding: 0 0.85rem 0.85rem; }
  .ha-chk { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; }
  .ha-chk input[type=checkbox] { accent-color: #5e6ad2; }
  .ha-grp { display: flex; flex-direction: column; gap: 0.4rem; }
  .ha-fields { display: flex; flex-direction: column; gap: 0.4rem; padding-left: 1.5rem; }
  .ha-lbl { display: flex; flex-direction: column; gap: 0.2rem; font-size: 0.8rem; }
  .ha-in { font-size: 0.8rem; }
</style>

<script>
  import { hl } from '../lib/highlight';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('ha-out') as HTMLElement;
  let rawOutput = '';

  const field = (k: string, f: string): string => {
    const el = document.querySelector<HTMLInputElement>(`.ha-in[data-k="${k}"][data-f="${f}"]`);
    if (!el) return '';
    return el.type === 'checkbox' ? String(el.checked) : el.value.trim();
  };
  const list = (s: string) => s.split(',').map((x) => x.trim()).filter(Boolean);

  const UNIT_SECONDS: Record<string, number> = {
    minutes: 60, hours: 3600, days: 86400, weeks: 604800, months: 2592000, years: 31536000,
  };

  const BUILD: Record<string, () => string> = {
    https: () => `# Force HTTPS\n<IfModule mod_rewrite.c>\n  RewriteEngine On\n  RewriteCond %{HTTPS} off\n  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]\n</IfModule>`,
    www: () => `# Force www\n<IfModule mod_rewrite.c>\n  RewriteEngine On\n  RewriteCond %{HTTP_HOST} !^www\\. [NC]\n  RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]\n</IfModule>`,
    nonwww: () => `# Force non-www\n<IfModule mod_rewrite.c>\n  RewriteEngine On\n  RewriteCond %{HTTP_HOST} ^www\\.(.*)$ [NC]\n  RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]\n</IfModule>`,
    trailing: () => `# Remove trailing slash\n<IfModule mod_rewrite.c>\n  RewriteEngine On\n  RewriteCond %{REQUEST_FILENAME} !-d\n  RewriteRule ^(.+)/$ /$1 [L,R=301]\n</IfModule>`,
    redir301: () => {
      const from = field('redir301', 'from'), to = field('redir301', 'to');
      if (!from || !to) return '';
      return `# 301 redirect\nRedirect 301 ${from} ${to}`;
    },
    errors: () => {
      const lines = ['400', '401', '403', '404', '500']
        .map((c) => { const p = field('errors', c); return p ? `ErrorDocument ${c} ${p}` : ''; })
        .filter(Boolean);
      return lines.length ? `# Custom error pages\n${lines.join('\n')}` : '';
    },
    compress: () => `# Gzip compression\n<IfModule mod_deflate.c>\n  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/javascript application/json application/xml image/svg+xml\n</IfModule>`,
    cache: () => {
      const exts = list(field('cache', 'ext'));
      if (!exts.length) return '';
      const n = parseInt(field('cache', 'num')) || 1;
      const unit = field('cache', 'unit') || 'months';
      const secs = n * (UNIT_SECONDS[unit] ?? 2592000);
      const revalidate = field('cache', 'revalidate') === 'true' ? ', must-revalidate' : '';
      return `# Browser caching\n<IfModule mod_headers.c>\n  <FilesMatch "\\.(${exts.join('|')})$">\n    Header set Cache-Control "max-age=${secs}, public${revalidate}"\n  </FilesMatch>\n</IfModule>`;
    },
    ip: () => {
      const block = list(field('ip', 'block')), allow = list(field('ip', 'allow'));
      if (!block.length && !allow.length) return '';
      const parts = ['# IP access control', '<RequireAll>'];
      if (allow.length) { parts.push('  Require all denied'); allow.forEach((ip) => parts.push(`  Require ip ${ip}`)); }
      else { parts.push('  Require all granted'); block.forEach((ip) => parts.push(`  Require not ip ${ip}`)); }
      parts.push('</RequireAll>');
      return parts.join('\n');
    },
    hotlink: () => {
      const domain = field('hotlink', 'domain'), exts = list(field('hotlink', 'ext')), img = field('hotlink', 'img');
      if (!domain || !exts.length) return '';
      const esc = domain.replace(/\./g, '\\.');
      const rule = img
        ? `  RewriteRule \\.(${exts.join('|')})$ ${img} [NC,R,L]`
        : `  RewriteRule \\.(${exts.join('|')})$ - [NC,F,L]`;
      return `# Prevent hotlinking\n<IfModule mod_rewrite.c>\n  RewriteEngine On\n  RewriteCond %{HTTP_REFERER} !^$\n  RewriteCond %{HTTP_REFERER} !^https?://(www\\.)?${esc} [NC]\n${rule}\n</IfModule>`;
    },
    badbots: () => `# Block bad bots\n<IfModule mod_rewrite.c>\n  RewriteEngine On\n  RewriteCond %{HTTP_USER_AGENT} (ahrefs|semrush|mj12bot|dotbot|petalbot|blexbot|scrapy|python-requests|masscan|nikto|sqlmap) [NC]\n  RewriteRule ^ - [F,L]\n</IfModule>`,
    protect: () => {
      const path = field('protect', 'path');
      if (!path) return '';
      const file = field('protect', 'file');
      const auth = `AuthType Basic\nAuthName "Restricted Area"\nAuthUserFile ${path}\nRequire valid-user`;
      return file
        ? `# Password protection\n<Files "${file}">\n${auth.split('\n').map((l) => '  ' + l).join('\n')}\n</Files>`
        : `# Password protection\n${auth}`;
    },
    nolisting: () => `# Disable directory listing\nOptions -Indexes`,
    protecthtaccess: () => `# Block access to .htaccess\n<Files ".ht*">\n  Require all denied\n</Files>`,
    headers: () => `# Security headers\n<IfModule mod_headers.c>\n  Header set X-Content-Type-Options "nosniff"\n  Header set X-Frame-Options "SAMEORIGIN"\n  Header set Referrer-Policy "strict-origin-when-cross-origin"\n  Header set X-XSS-Protection "1; mode=block"\n</IfModule>`,
    dirindex: () => { const p = field('dirindex', 'page'); return p ? `# Default directory page\nDirectoryIndex ${p}` : ''; },
  };

  function build() {
    const blocks: string[] = [];
    document.querySelectorAll<HTMLInputElement>('.ha-r:checked').forEach((el) => {
      const k = el.dataset.k!;
      const b = BUILD[k]?.();
      if (b) blocks.push(b);
    });
    rawOutput = blocks.join('\n\n');
    hl(out, rawOutput || '# Tick some rules to generate your .htaccess', 'plaintext');
  }

  document.querySelectorAll('.ha-r, .ha-in').forEach((el) => {
    el.addEventListener('change', build);
    el.addEventListener('input', build);
  });

  // htpasswd bcrypt line generator
  $('hp-gen').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const user = ($('hp-user') as HTMLInputElement).value.trim();
    const pass = ($('hp-pass') as HTMLInputElement).value;
    if (!user || !pass) { ($('hp-out') as HTMLInputElement).value = 'Enter a username and password'; return; }
    btn.textContent = '…'; btn.disabled = true;
    const mod = await import('bcryptjs');
    const bcrypt = (mod.default ?? mod) as typeof import('bcryptjs');
    const hash = await bcrypt.hash(pass, 10);
    // Apache expects the $2y$ prefix for bcrypt in .htpasswd
    ($('hp-out') as HTMLInputElement).value = `${user}:${hash.replace(/^\$2[ab]\$/, '$2y$')}`;
    btn.textContent = 'Generate'; btn.disabled = false;
  });

  $('ha-dl').addEventListener('click', () => {
    const url = URL.createObjectURL(new Blob([rawOutput], { type: 'text/plain' }));
    const a = document.createElement('a'); a.href = url; a.download = '.htaccess'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });

  build();
</script>

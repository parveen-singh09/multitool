---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="ambigram-generator">
  <div class="flex flex-col gap-6">

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <label class="flex flex-col gap-1.5 text-sm text-ink-subtle">Word
        <input id="am-a" class="field" value="love" spellcheck="false" maxlength="20" autocomplete="off" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm text-ink-subtle">Reads as when flipped 180°
        <input id="am-b" class="field" placeholder="leave blank to mirror the word onto itself" spellcheck="false" maxlength="20" autocomplete="off" />
      </label>
    </div>

    <div class="flex flex-wrap items-end gap-x-5 gap-y-4">
      <label class="flex flex-col gap-1.5 text-sm text-ink-subtle">Font
        <select id="am-font" class="field w-48"></select>
      </label>

      <div class="flex flex-col gap-1.5 text-sm text-ink-subtle">Text
        <input id="am-color" type="color" value="#f7f8f8" class="am-color" aria-label="Text color" />
      </div>

      <div class="flex flex-col gap-1.5 text-sm text-ink-subtle">Background
        <div class="flex items-center gap-2">
          <input id="am-bg" type="color" value="#0f1011" class="am-color" aria-label="Background color" />
          <label class="flex items-center gap-1.5 text-[13px]"><input id="am-transparent" type="checkbox" class="am-check" /> None</label>
        </div>
      </div>

      <label class="flex flex-col gap-1.5 text-sm text-ink-subtle">Size · <span id="am-size-v" class="text-ink">96px</span>
        <input id="am-size" type="range" min="32" max="200" step="1" value="96" class="am-range" />
      </label>

      <label class="flex flex-col gap-1.5 text-sm text-ink-subtle">Letter spacing · <span id="am-track-v" class="text-ink">0px</span>
        <input id="am-track" type="range" min="-10" max="30" step="1" value="0" class="am-range" />
      </label>
    </div>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-3">
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="am-spin" type="checkbox" class="am-check" /> Auto-rotate to verify</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="am-ghost" type="checkbox" checked class="am-check" /> Show flipped overlay</label>
      <div class="ml-auto flex flex-wrap gap-2">
        <button id="am-dl-png" class="btn btn-primary">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0 0 4-4m-4 4-4-4M4 21h16"/></svg>
          Download PNG
        </button>
        <button id="am-dl-svg" class="btn btn-secondary">SVG</button>
        <button id="am-share" class="btn btn-secondary">Copy link</button>
      </div>
    </div>

    <div class="am-stage panel panel-lift">
      <canvas id="am-canvas" class="am-canvas" aria-label="Ambigram preview"></canvas>
    </div>
    <p class="-mt-2 text-center text-[13px] text-ink-tertiary">Turn your screen (or the page) 180° — the word reads the same, or as the second word.</p>

    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <span class="text-sm text-ink-subtle">Letter pairs — each column must read as its partner upside-down</span>
        <span class="flex items-center gap-3 text-[12px] text-ink-tertiary">
          <span class="flex items-center gap-1.5"><span class="am-dot" style="background:#27a644"></span> rotates cleanly</span>
          <span class="flex items-center gap-1.5"><span class="am-dot" style="background:#8a8f98"></span> needs custom lettering</span>
        </span>
      </div>
      <div id="am-pairs" class="am-pairs"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      An ambigram is a word designed to read the same — or as a second word — when rotated
      180°. This free ambigram generator pairs each letter of your word with the letter it
      lands on when the word is flipped, then shows which pairs already rotate cleanly
      (<strong class="text-ink-muted">o, s, x, z, n/u, d/p, b/q, m/w</strong>) and which need
      custom lettering. Enter one word to mirror it onto itself, or two words of any length to
      make one read as the other upside-down.
    </p>
    <p>
      Choose from a range of display and script fonts, set the text and background colours, size
      and letter spacing, then tick <strong class="text-ink-muted">Auto-rotate to verify</strong>
      to watch it flip. Download a high-resolution <strong class="text-ink-muted">PNG</strong>
      (transparent or on a solid background) or a resolution-independent
      <strong class="text-ink-muted">SVG</strong>, or copy a link that restores every setting.
    </p>
    <p class="text-[13px] text-ink-tertiary">
      Note: a true, seamless ambigram usually needs hand-lettering so each shape reads both ways.
      This tool gives you a faithful rotational preview, letter-pair guidance and a starting point
      rather than a finished custom typeface.
    </p>
  </div>
</ToolLayout>

<style>
  .am-color {
    width: 46px;
    height: 34px;
    padding: 3px;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    background-color: var(--color-surface-1);
    cursor: pointer;
  }
  .am-check { width: 16px; height: 16px; accent-color: var(--color-primary); cursor: pointer; }
  .am-range { width: 150px; accent-color: var(--color-primary); cursor: pointer; }

  .am-stage {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 16 / 7;
    min-height: 220px;
  }
  .am-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: transform 0.9s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .am-canvas.is-spun { transform: rotate(180deg); }

  .am-pairs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .am-pair {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 46px;
    padding: 8px 6px 6px;
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
  }
  .am-pair-top { font-size: 22px; font-weight: 600; color: var(--color-ink); line-height: 1.1; }
  .am-pair-bot { font-size: 22px; font-weight: 600; color: var(--color-ink-subtle); line-height: 1.1; transform: rotate(180deg); }
  .am-pair-mark { margin-top: 4px; width: 6px; height: 6px; border-radius: 9999px; }
  .am-pair.ok { border-color: color-mix(in srgb, #27a644 45%, var(--color-hairline)); }
  .am-dot { display: inline-block; width: 8px; height: 8px; border-radius: 9999px; }
</style>

<script>
  import { FONTS, ensureFont } from '../lib/collage/fonts';

  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

  const aEl = $('am-a') as HTMLInputElement;
  const bEl = $('am-b') as HTMLInputElement;
  const fontEl = $('am-font') as HTMLSelectElement;
  const colorEl = $('am-color') as HTMLInputElement;
  const bgEl = $('am-bg') as HTMLInputElement;
  const transEl = $('am-transparent') as HTMLInputElement;
  const sizeEl = $('am-size') as HTMLInputElement;
  const trackEl = $('am-track') as HTMLInputElement;
  const spinEl = $('am-spin') as HTMLInputElement;
  const ghostEl = $('am-ghost') as HTMLInputElement;
  const stage = document.querySelector('.am-stage') as HTMLElement;
  const canvas = $('am-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const pairsEl = $('am-pairs');

  const FONT_GROUPS: { label: string; fonts: string[] }[] = [
    { label: 'Script', fonts: ['Lobster', 'Great Vibes', 'Pacifico', 'Satisfy', 'Dancing Script'] },
    { label: 'Heavy', fonts: ['Anton', 'Abril Fatface', 'Righteous', 'Bebas Neue'] },
    { label: 'Serif', fonts: ['Playfair Display', 'Serif (system)'] },
    { label: 'Clean', fonts: ['Oswald', 'Montserrat', 'Poppins', 'Inter'] },
  ];
  const byLabel = new Map(FONTS.map((f) => [f.label, f]));
  for (const group of FONT_GROUPS) {
    const og = document.createElement('optgroup');
    og.label = group.label;
    for (const label of group.fonts) {
      const def = byLabel.get(label);
      if (!def) continue;
      const opt = document.createElement('option');
      opt.value = def.family;
      opt.textContent = label;
      og.appendChild(opt);
    }
    if (og.childElementCount) fontEl.appendChild(og);
  }

  const ROT: Record<string, string> = {
    o: 'o', s: 's', x: 'x', z: 'z', l: 'l', i: 'i',
    n: 'u', u: 'n', d: 'p', p: 'd', b: 'q', q: 'b',
    m: 'w', w: 'm', h: 'y', y: 'h', '0': '0', '1': '1', '8': '8', '6': '9', '9': '6',
  };
  const rotatesTo = (top: string, bot: string) => {
    const t = top.toLowerCase(), b = bot.toLowerCase();
    return t === b ? !!ROT[t] && ROT[t] === t : ROT[t] === b;
  };

  let cssW = 0, cssH = 0;

  function sizeCanvas() {
    const dpr = Math.min(window.devicePixelRatio || 1, 3);
    const rect = stage.getBoundingClientRect();
    cssW = rect.width;
    cssH = rect.height;
    canvas.width = Math.round(cssW * dpr);
    canvas.height = Math.round(cssH * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    render();
  }

  function fitFont(c: CanvasRenderingContext2D, word: string, family: string, track: number, want: number, w: number) {
    let fs = want;
    c.font = `600 ${fs}px ${family}`;
    const width = () => c.measureText(word).width + track * Math.max(0, word.length - 1);
    while (width() > w * 0.86 && fs > 10) { fs -= 1; c.font = `600 ${fs}px ${family}`; }
    return fs;
  }

  function drawTracked(c: CanvasRenderingContext2D, word: string, cx: number, cy: number, track: number) {
    const widths = [...word].map((ch) => c.measureText(ch).width);
    const total = widths.reduce((a, b) => a + b, 0) + track * Math.max(0, word.length - 1);
    let x = cx - total / 2;
    c.textAlign = 'left';
    c.textBaseline = 'middle';
    for (let i = 0; i < word.length; i++) {
      c.fillText(word[i], x, cy);
      x += widths[i] + track;
    }
  }

  function paint(c: CanvasRenderingContext2D, w: number, h: number, scale: number) {
    const a = (aEl.value.trim() || 'word');
    const b = bEl.value.trim();
    const family = fontEl.value;
    const color = colorEl.value;
    const track = Number(trackEl.value) * scale;
    const want = Number(sizeEl.value) * scale;

    if (!transEl.checked) { c.fillStyle = bgEl.value; c.fillRect(0, 0, w, h); }

    const fs = fitFont(c, a, family, track, want, w);
    c.font = `600 ${fs}px ${family}`;

    if (ghostEl.checked) {
      c.save();
      c.translate(w / 2, h / 2);
      c.rotate(Math.PI);
      c.globalAlpha = 0.28;
      c.fillStyle = color;
      c.font = `600 ${fs}px ${family}`;
      drawTracked(c, b || a, 0, 0, track);
      c.restore();
    }

    c.globalAlpha = 1;
    c.fillStyle = color;
    drawTracked(c, a, w / 2, h / 2, track);
  }

  function render() {
    ctx.clearRect(0, 0, cssW, cssH);
    paint(ctx, cssW, cssH, cssW / 900);
    canvas.classList.toggle('is-spun', spinEl.checked);
    renderPairs();
  }

  function renderPairs() {
    const a = (aEl.value.trim() || 'word');
    const bRaw = bEl.value.trim() || a;
    const n = Math.max(a.length, bRaw.length);
    pairsEl.replaceChildren();
    for (let i = 0; i < n; i++) {
      const top = a[i] ?? '·';
      const bot = bRaw[bRaw.length - 1 - i] ?? '·';
      const ok = top !== '·' && bot !== '·' && rotatesTo(top, bot);
      const cell = document.createElement('div');
      cell.className = 'am-pair' + (ok ? ' ok' : '');
      cell.innerHTML =
        `<span class="am-pair-top">${top}</span>` +
        `<span class="am-pair-bot">${bot}</span>` +
        `<span class="am-pair-mark" style="background:${ok ? '#27a644' : '#8a8f98'}"></span>`;
      pairsEl.appendChild(cell);
    }
  }

  function download(href: string, name: string) {
    const el = document.createElement('a');
    el.href = href; el.download = name; el.click();
  }

  function downloadPng() {
    const scaleUp = 3;
    const w = Math.round(cssW * scaleUp), h = Math.round(cssH * scaleUp);
    const off = document.createElement('canvas');
    off.width = w; off.height = h;
    paint(off.getContext('2d')!, w, h, w / 900);
    download(off.toDataURL('image/png'), 'ambigram.png');
  }

  function downloadSvg() {
    const a = (aEl.value.trim() || 'word');
    const b = bEl.value.trim();
    const family = fontEl.value.replace(/"/g, "'");
    const W = 900, H = Math.round(900 * (cssH / cssW));
    const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const fs = Number(sizeEl.value);
    const track = Number(trackEl.value);
    const bg = transEl.checked ? '' : `<rect width="${W}" height="${H}" fill="${bgEl.value}"/>`;
    const common = `text-anchor="middle" dominant-baseline="central" font-family="${family}" font-weight="600" font-size="${fs}" letter-spacing="${track}"`;
    const ghost = ghostEl.checked
      ? `<text x="0" y="0" ${common} fill="${colorEl.value}" opacity="0.28" transform="translate(${W / 2} ${H / 2}) rotate(180)">${esc(b || a)}</text>`
      : '';
    const svg =
      `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${W} ${H}" width="${W}" height="${H}">` +
      `${bg}${ghost}<text x="${W / 2}" y="${H / 2}" ${common} fill="${colorEl.value}">${esc(a)}</text></svg>`;
    const url = URL.createObjectURL(new Blob([svg], { type: 'image/svg+xml' }));
    download(url, 'ambigram.svg');
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function writeShare() {
    const state = {
      a: aEl.value, b: bEl.value, f: fontEl.value, c: colorEl.value,
      bg: bgEl.value, t: transEl.checked, s: sizeEl.value, k: trackEl.value, g: ghostEl.checked,
    };
    const hash = btoa(encodeURIComponent(JSON.stringify(state)));
    const url = `${location.origin}${location.pathname}#${hash}`;
    history.replaceState(null, '', url);
    navigator.clipboard?.writeText(url).then(() => {
      const btn = $('am-share');
      const prev = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = prev; }, 1400);
    });
  }

  async function readShare() {
    if (!location.hash.length) return;
    try {
      const s = JSON.parse(decodeURIComponent(atob(location.hash.slice(1))));
      if (typeof s.a === 'string') aEl.value = s.a;
      if (typeof s.b === 'string') bEl.value = s.b;
      if (typeof s.f === 'string' && [...fontEl.options].some((o) => o.value === s.f)) fontEl.value = s.f;
      if (typeof s.c === 'string') colorEl.value = s.c;
      if (typeof s.bg === 'string') bgEl.value = s.bg;
      transEl.checked = !!s.t;
      if (s.s) { sizeEl.value = String(s.s); $('am-size-v').textContent = `${s.s}px`; }
      if (s.k != null) { trackEl.value = String(s.k); $('am-track-v').textContent = `${s.k}px`; }
      ghostEl.checked = s.g !== false;
      await ensureFont(fontEl.value);
    } catch {}
  }

  async function pickFont() { await ensureFont(fontEl.value); render(); }

  [aEl, bEl, colorEl, bgEl].forEach((el) => el.addEventListener('input', render));
  [transEl, spinEl, ghostEl].forEach((el) => el.addEventListener('change', render));
  fontEl.addEventListener('change', pickFont);
  sizeEl.addEventListener('input', () => { $('am-size-v').textContent = `${sizeEl.value}px`; render(); });
  trackEl.addEventListener('input', () => { $('am-track-v').textContent = `${trackEl.value}px`; render(); });
  $('am-dl-png').addEventListener('click', downloadPng);
  $('am-dl-svg').addEventListener('click', downloadSvg);
  $('am-share').addEventListener('click', writeShare);
  window.addEventListener('resize', sizeCanvas);

  (async () => {
    await readShare();
    await ensureFont(fontEl.value);
    sizeCanvas();
  })();
</script>

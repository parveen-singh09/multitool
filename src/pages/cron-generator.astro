---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="cron-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Preset
      <select id="cr-preset" class="field">
        <option value="">Custom</option>
        <option value="* * * * *">Every minute</option>
        <option value="*/5 * * * *">Every 5 minutes</option>
        <option value="*/15 * * * *">Every 15 minutes</option>
        <option value="*/30 * * * *">Every 30 minutes</option>
        <option value="0 * * * *">Every hour</option>
        <option value="0 */2 * * *">Every 2 hours</option>
        <option value="0 0 * * *">Every day at midnight</option>
        <option value="0 9 * * *">Every day at 9am</option>
        <option value="0 9 * * 1-5">Weekdays at 9am</option>
        <option value="0 0 * * 0">Every Sunday at midnight</option>
        <option value="0 0 * * 6,0">Every weekend</option>
        <option value="0 0 1 * *">First of every month</option>
        <option value="0 0 1 1 *">Every January 1st</option>
        <option value="*/15 9-17 * * 1-5">Every 15 min, business hours, weekdays</option>
      </select>
    </label>
    <div class="grid grid-cols-5 gap-2">
      <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Minute
        <input id="cr-min" class="field font-mono" value="0" spellcheck="false" />
        <span class="text-[11px] text-ink-tertiary">0–59</span>
      </label>
      <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Hour
        <input id="cr-hour" class="field font-mono" value="9" spellcheck="false" />
        <span class="text-[11px] text-ink-tertiary">0–23</span>
      </label>
      <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Day (month)
        <input id="cr-dom" class="field font-mono" value="*" spellcheck="false" />
        <span class="text-[11px] text-ink-tertiary">1–31</span>
      </label>
      <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Month
        <input id="cr-mon" class="field font-mono" value="*" spellcheck="false" />
        <span class="text-[11px] text-ink-tertiary">1–12</span>
      </label>
      <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Day (week)
        <input id="cr-dow" class="field font-mono" value="1-5" spellcheck="false" />
        <span class="text-[11px] text-ink-tertiary">0–6 (Sun–Sat)</span>
      </label>
    </div>

    <div class="panel panel-lift flex flex-col gap-2 p-4">
      <div class="flex items-center gap-3">
        <div class="copy-wrap flex-1"><pre class="hl-block" style="overflow:auto"><code id="cr-expr" class="hljs text-lg" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#cr-expr" aria-label="Copy"></button></div>
      </div>
      <p id="cr-human" class="text-sm text-ink-subtle"></p>
      <p id="cr-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
    </div>

    <div id="cr-next-panel" class="panel p-4">
      <div class="mb-2 text-sm text-ink-subtle">Next 5 run times (local time)</div>
      <div id="cr-next" class="flex flex-col gap-2"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free cron expression generator helps you build and understand cron
      schedules — the five-field syntax used by crontab, CI pipelines and
      schedulers. Start from a preset or edit each field (minute, hour, day of
      month, month, day of week), and the tool explains the schedule in plain
      English and previews the next five run times in your local time so you can
      be sure it fires when you expect. Steps like <code>*/5</code>, ranges like
      <code>9-17</code> and lists like <code>1,15</code> all work, and each field
      is validated as you type.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl } from '../lib/highlight';
  import { describe, nextRuns, fmtDate } from '../lib/cron';

  const $ = (id: string) => document.getElementById(id)!;
  const fields = ['cr-min', 'cr-hour', 'cr-dom', 'cr-mon', 'cr-dow'];
  const exprEl = $('cr-expr') as HTMLElement;
  const humanEl = $('cr-human')!;
  const errEl = $('cr-error')!;
  const nextEl = $('cr-next')!;
  let rawOutput = '';

  function renderNext(vals: string[]) {
    const runs = nextRuns(vals, 5);
    nextEl.textContent = '';
    if (!runs.length) {
      const p = document.createElement('div');
      p.className = 'font-mono text-[13px] text-ink-muted';
      p.textContent = 'No upcoming run times found (impossible date combination, e.g. Feb 30).';
      nextEl.append(p);
      return;
    }
    runs.forEach((r, i) => {
      const row = document.createElement('div');
      row.className = 'flex items-baseline gap-3 border-t border-white/5 pt-2 first:border-0 first:pt-0';
      const n = document.createElement('span');
      n.className = 'font-mono text-[13px] text-ink-muted';
      n.textContent = String(i + 1) + '.';
      const t = document.createElement('span');
      t.className = 'font-mono text-[13px] text-ink';
      t.textContent = fmtDate(r);
      row.append(n, t);
      nextEl.append(row);
    });
  }

  function build() {
    const vals = fields.map((id) => ($(id) as HTMLInputElement).value.trim() || '*');
    rawOutput = vals.join(' ');
    hl(exprEl, rawOutput, 'plaintext');

    try {
      humanEl.textContent = describe(vals) + '.';
      errEl.classList.add('hidden');
      renderNext(vals);
    } catch (e) {
      humanEl.textContent = '';
      errEl.textContent = (e as Error).message;
      errEl.classList.remove('hidden');
      nextEl.textContent = '';
    }
  }

  $('cr-preset').addEventListener('change', () => {
    const v = ($('cr-preset') as HTMLSelectElement).value;
    if (!v) return;
    const parts = v.split(' ');
    fields.forEach((id, i) => { ($(id) as HTMLInputElement).value = parts[i]; });
    build();
  });
  fields.forEach((id) => $(id).addEventListener('input', build));
  build();
</script>

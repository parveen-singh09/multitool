---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="texas-paycheck-calculator">
  <div class="flex flex-col gap-5">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Pay type">
      <button type="button" data-pay="salary" class="tx-tab btn btn-primary" aria-selected="true">Salary</button>
      <button type="button" data-pay="hourly" class="tx-tab btn btn-secondary" aria-selected="false">Hourly</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">

      <label id="tx-salary-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">Gross pay
        <span class="flex gap-2">
          <input id="tx-gross" type="number" min="0" class="field" value="2500" inputmode="decimal" />
          <select id="tx-grossbasis" class="field w-32"><option value="period">per period</option><option value="year">per year</option></select>
        </span>
      </label>

      <div id="tx-hourly-wrap" class="hidden grid-cols-3 gap-2 sm:col-span-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Hourly rate<input id="tx-rate" type="number" min="0" step="0.01" class="field" value="25" inputmode="decimal" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Hours / period<input id="tx-hours" type="number" min="0" step="0.5" class="field" value="80" inputmode="decimal" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">OT hours (1.5×)<input id="tx-othours" type="number" min="0" step="0.5" class="field" value="0" inputmode="decimal" /></label>
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Pay frequency
        <select id="tx-freq" class="field">
          <option value="52">Weekly</option>
          <option value="26" selected>Bi-weekly</option>
          <option value="24">Semi-monthly</option>
          <option value="12">Monthly</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Filing status
        <select id="tx-status" class="field">
          <option value="single">Single</option>
          <option value="married">Married filing jointly</option>
          <option value="head">Head of household</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Pre-tax deductions (per period)
        <input id="tx-pretax" type="number" min="0" class="field" value="0" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Dependents (child tax credit)
        <input id="tx-children" type="number" min="0" step="1" class="field" value="0" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Other dependents
        <input id="tx-otherdep" type="number" min="0" step="1" class="field" value="0" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Extra federal withholding (per period)
        <input id="tx-extra" type="number" min="0" step="1" class="field" value="0" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Other taxable income / year (W-4 4a)
        <input id="tx-other" type="number" min="0" step="1" class="field" value="0" inputmode="decimal" />
      </label>
    </div>

    <p class="status-badge w-fit">Texas has no state income tax</p>

    <div class="panel panel-lift p-6">
      <div class="flex items-baseline justify-between">
        <span class="text-sm text-ink-subtle">Take-home pay (per period)</span>
        <span id="tx-net" class="font-display text-4xl font-semibold text-primary-hover">—</span>
      </div>
      <div id="tx-annual-net" class="mt-1 text-right text-sm text-ink-muted"></div>
      <div id="tx-breakdown" class="mt-5 flex flex-col gap-2 text-sm"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Texas paycheck calculator estimates your take-home pay after
      federal withholding, Social Security and Medicare. Texas is one of a handful
      of states with no state income tax, so your only mandatory deductions here
      are federal — that’s why Texas paychecks stretch further than in many other
      states. Enter your gross pay, how often you’re paid, your filing status and
      any pre-tax deductions (like 401(k) or health premiums) to see the split.
      It uses 2025 federal tax brackets, the standard deduction, Social Security
      at 6.2% up to the wage base and Medicare at 1.45% (plus the 0.9% additional
      Medicare tax over $200,000). This is an estimate, not tax advice — your
      actual W-4 elections and local specifics may differ. Everything runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const sel = (id: string) => document.getElementById(id) as unknown as HTMLSelectElement;

  const BRACKETS: Record<string, [number, number][]> = {
    single: [
      [11925, 0.1], [48475, 0.12], [103350, 0.22], [197300, 0.24],
      [250525, 0.32], [626350, 0.35], [Infinity, 0.37],
    ],
    married: [
      [23850, 0.1], [96950, 0.12], [206700, 0.22], [394600, 0.24],
      [501050, 0.32], [751600, 0.35], [Infinity, 0.37],
    ],
    head: [
      [17000, 0.1], [64850, 0.12], [103350, 0.22], [197300, 0.24],
      [250500, 0.32], [626350, 0.35], [Infinity, 0.37],
    ],
  };

  const STD: Record<string, number> = { single: 15000, married: 30000, head: 22500 };

  const SS_RATE = 0.062;
  const SS_WAGE_BASE = 176100; 
  const MEDI_RATE = 0.0145;
  const ADDL_MEDI_RATE = 0.009;
  const ADDL_MEDI_THRESHOLD: Record<string, number> = { single: 200000, married: 250000, head: 200000 };

  function federalTax(taxable: number, status: string): number {
    if (taxable <= 0) return 0;
    const brackets = BRACKETS[status];
    let tax = 0;
    let last = 0;
    for (const [cap, rate] of brackets) {
      if (taxable > cap) {
        tax += (cap - last) * rate;
        last = cap;
      } else {
        tax += (taxable - last) * rate;
        break;
      }
    }
    return tax;
  }

  const money = (n: number) =>
    '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  let payType: 'salary' | 'hourly' = 'salary';

  function calc() {
    const periods = Number(sel('tx-freq').value);
    const status = sel('tx-status').value;
    const pretax = Number($('tx-pretax').value) || 0;
    const extra = Number($('tx-extra').value) || 0;
    const otherIncome = Number($('tx-other').value) || 0;
    const childCredit = (Number($('tx-children').value) || 0) * 2000;
    const otherDepCredit = (Number($('tx-otherdep').value) || 0) * 500;

    let gross: number;
    if (payType === 'hourly') {
      const rate = Number($('tx-rate').value) || 0;
      const hours = Number($('tx-hours').value) || 0;
      const ot = Number($('tx-othours').value) || 0;
      gross = rate * hours + rate * 1.5 * ot;
    } else {
      const amt = Number($('tx-gross').value) || 0;
      gross = sel('tx-grossbasis').value === 'year' ? amt / periods : amt;
    }

    const netEl = document.getElementById('tx-net')!;
    const annualEl = document.getElementById('tx-annual-net')!;
    const breakdownEl = document.getElementById('tx-breakdown')!;

    if (!(gross > 0)) {
      netEl.textContent = '—';
      annualEl.textContent = '';
      breakdownEl.innerHTML = '';
      return;
    }

    const annualGross = gross * periods;
    const annualPretax = pretax * periods;

    const ficaWages = Math.max(0, annualGross - annualPretax);
    const ss = Math.min(ficaWages, SS_WAGE_BASE) * SS_RATE;
    let medicare = ficaWages * MEDI_RATE;
    if (ficaWages > ADDL_MEDI_THRESHOLD[status]) {
      medicare += (ficaWages - ADDL_MEDI_THRESHOLD[status]) * ADDL_MEDI_RATE;
    }

    const taxable = Math.max(0, annualGross - annualPretax + otherIncome - STD[status]);
    const fedAnnual = Math.max(0, federalTax(taxable, status) - childCredit - otherDepCredit) + extra * periods;

    const annualNet = annualGross - annualPretax - ss - medicare - fedAnnual;
    const perNet = annualNet / periods;

    netEl.textContent = money(perNet);
    annualEl.textContent = money(annualNet) + ' per year';

    const rows: [string, number][] = [
      ['Gross pay', gross],
      ['Pre-tax deductions', -pretax],
      ['Federal income tax', -fedAnnual / periods],
      ['Social Security', -ss / periods],
      ['Medicare', -medicare / periods],
      ['State income tax', 0],
    ];
    breakdownEl.innerHTML = rows
      .map(([label, val], i) => {
        const isState = label === 'State income tax';
        const disp = isState ? '$0.00 (none in TX)' : money(val);
        const color = val < 0 ? '#e5484d' : i === 0 ? 'var(--color-ink)' : 'var(--color-ink-muted)';
        return `<div class="flex items-center justify-between border-t border-hairline pt-2 first:border-0 first:pt-0">
          <span class="text-ink-subtle">${label}</span>
          <span class="font-mono" style="color:${color}">${disp}</span>
        </div>`;
      })
      .join('');
  }

  document.querySelectorAll<HTMLButtonElement>('.tx-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      payType = tab.dataset.pay as 'salary' | 'hourly';
      document.querySelectorAll('.tx-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('tx-salary-wrap')!.classList.toggle('hidden', payType !== 'salary');
      document.getElementById('tx-salary-wrap')!.classList.toggle('flex', payType === 'salary');
      document.getElementById('tx-hourly-wrap')!.classList.toggle('hidden', payType !== 'hourly');
      document.getElementById('tx-hourly-wrap')!.classList.toggle('grid', payType === 'hourly');
      calc();
    });
  });

  document
    .querySelectorAll('#tx-gross, #tx-grossbasis, #tx-rate, #tx-hours, #tx-othours, #tx-freq, #tx-status, #tx-pretax, #tx-children, #tx-otherdep, #tx-extra, #tx-other')
    .forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

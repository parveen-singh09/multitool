---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="binary-converter">
  <div class="flex flex-col gap-5">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Mode">
      <button data-mode="num" class="bc-tab btn btn-primary" aria-selected="true">Number ↔ Binary</button>
      <button data-mode="text" class="bc-tab btn btn-secondary" aria-selected="false">Text ↔ Binary</button>
    </div>

    <div id="bc-num" class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Decimal (base 10)
        <div class="copy-wrap">
          <input id="bc-dec" data-base="dec" type="text" class="field font-mono bc-in" placeholder="42" inputmode="numeric" spellcheck="false" autocomplete="off" />
          <button type="button" class="copy-icon" data-copy-target="#bc-dec" aria-label="Copy"></button>
        </div>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Binary (base 2)
        <div class="copy-wrap">
          <input id="bc-bin" data-base="bin" type="text" class="field font-mono bc-in" placeholder="101010" spellcheck="false" autocomplete="off" />
          <button type="button" class="copy-icon" data-copy-target="#bc-bin" aria-label="Copy"></button>
        </div>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Hexadecimal (base 16)
        <div class="copy-wrap">
          <input id="bc-hex" data-base="hex" type="text" class="field font-mono bc-in" placeholder="2a" spellcheck="false" autocomplete="off" />
          <button type="button" class="copy-icon" data-copy-target="#bc-hex" aria-label="Copy"></button>
        </div>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Octal (base 8)
        <div class="copy-wrap">
          <input id="bc-oct" data-base="oct" type="text" class="field font-mono bc-in" placeholder="52" spellcheck="false" autocomplete="off" />
          <button type="button" class="copy-icon" data-copy-target="#bc-oct" aria-label="Copy"></button>
        </div>
      </label>
      <label class="flex items-center gap-2 text-[13px] text-ink-subtle">
        <input id="bc-group" type="checkbox" class="accent-[var(--color-primary)]" />
        Group binary into 4-bit nibbles
      </label>
    </div>

    <div id="bc-textwrap" class="hidden flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Text
        <div class="copy-wrap">
          <textarea id="bc-txt" class="field" rows="3" placeholder="Hi" spellcheck="false"></textarea>
          <button type="button" class="copy-icon" data-copy-target="#bc-txt" aria-label="Copy"></button>
        </div>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Separator
        <select id="bc-sep" class="field w-auto py-1">
          <option value=" " selected>Space</option>
          <option value=",">Comma</option>
          <option value="">None</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Binary (8-bit UTF-8 bytes)
        <div class="copy-wrap">
          <textarea id="bc-txtbin" class="field font-mono" rows="3" placeholder="01001000 01101001"></textarea>
          <button type="button" class="copy-icon" data-copy-target="#bc-txtbin" aria-label="Copy"></button>
        </div>
      </label>
    </div>

    <p id="bc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free binary converter works two ways. In <strong>Number ↔ Binary</strong>
      mode, type into any of the decimal, binary, hexadecimal or octal fields and
      the other three update live — every field is editable, so you can convert in
      any direction, and an optional toggle groups binary into readable 4-bit
      nibbles. In <strong>Text ↔ Binary</strong> mode it turns text into 8-bit
      UTF-8 byte codes (and back), with a choice of space, comma or no separator.
      Negative whole numbers are supported and arbitrarily large values are handled
      exactly with BigInt. It's a handy companion for programming, digital
      electronics and computer-science study.
    </p>
  </div>
</ToolLayout>

<script>
  const decEl = document.getElementById('bc-dec') as HTMLInputElement;
  const binEl = document.getElementById('bc-bin') as HTMLInputElement;
  const hexEl = document.getElementById('bc-hex') as HTMLInputElement;
  const octEl = document.getElementById('bc-oct') as HTMLInputElement;
  const groupEl = document.getElementById('bc-group') as HTMLInputElement;
  const txtEl = document.getElementById('bc-txt') as HTMLTextAreaElement;
  const txtBinEl = document.getElementById('bc-txtbin') as HTMLTextAreaElement;
  const sepEl = document.getElementById('bc-sep') as HTMLSelectElement;
  const numWrap = document.getElementById('bc-num')!;
  const textWrap = document.getElementById('bc-textwrap')!;
  const err = document.getElementById('bc-error')!;

  function setErr(msg: string) { err.textContent = msg; err.classList.toggle('hidden', !msg); }

  const RADIX: Record<string, number> = { dec: 10, bin: 2, hex: 16, oct: 8 };
  const VALID: Record<string, RegExp> = {
    dec: /^-?\d+$/, bin: /^-?[01]+$/, hex: /^-?[0-9a-fA-F]+$/, oct: /^-?[0-7]+$/,
  };
  const LABEL: Record<string, string> = { dec: 'Decimal', bin: 'Binary', hex: 'Hex', oct: 'Octal' };
  const inputs: Record<string, HTMLInputElement> = { dec: decEl, bin: binEl, hex: hexEl, oct: octEl };

  function groupBits(bits: string): string {
    return bits.replace(/\B(?=(\d{4})+$)/g, ' ');
  }

  function render(base: string, neg: boolean, abs: bigint): string {
    let s = abs.toString(RADIX[base]);
    if (base === 'bin' && groupEl.checked) s = groupBits(s);
    return (neg ? '-' : '') + s;
  }

  function syncFrom(base: string) {
    setErr('');
    const raw = inputs[base].value.trim().replace(/\s+/g, '');
    if (!raw || raw === '-') {
      for (const b of Object.keys(inputs)) if (b !== base) inputs[b].value = '';
      return;
    }
    if (!VALID[base].test(raw)) {
      setErr(`${LABEL[base]} can only contain ${base === 'dec' ? 'digits' : base === 'bin' ? '0 and 1' : base === 'hex' ? '0-9 and a-f' : '0-7'}.`);
      return;
    }
    const neg = raw.startsWith('-');
    const digits = neg ? raw.slice(1) : raw;
    let abs: bigint;
    try {
      const prefix = base === 'bin' ? '0b' : base === 'hex' ? '0x' : base === 'oct' ? '0o' : '';
      abs = BigInt(prefix + digits);
    } catch { setErr('Could not parse that number.'); return; }
    for (const b of Object.keys(inputs)) if (b !== base) inputs[b].value = render(b, neg, abs);
  }

  for (const [base, el] of Object.entries(inputs)) {
    el.addEventListener('input', () => syncFrom(base));
  }
  groupEl.addEventListener('change', () => {
    const v = decEl.value.trim();
    if (v && VALID.dec.test(v.replace(/\s+/g, ''))) syncFrom('dec');
  });

  function encodeText() {
    const sep = sepEl.value;
    const bytes = new TextEncoder().encode(txtEl.value);
    txtBinEl.value = Array.from(bytes).map((b) => b.toString(2).padStart(8, '0')).join(sep);
  }
  txtEl.addEventListener('input', encodeText);
  sepEl.addEventListener('change', encodeText);

  txtBinEl.addEventListener('input', () => {
    setErr('');
    const groups = txtBinEl.value.trim().split(/[\s,]+/).filter(Boolean);
    if (!groups.length) { txtEl.value = ''; return; }
    if (!groups.every((g) => /^[01]{1,8}$/.test(g))) { setErr('Use 8-bit binary groups of 0s and 1s.'); return; }
    try {
      const bytes = Uint8Array.from(groups.map((g) => parseInt(g, 2)));
      txtEl.value = new TextDecoder().decode(bytes);
    } catch { setErr('Could not decode those bytes.'); }
  });

  document.querySelectorAll<HTMLButtonElement>('.bc-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const mode = tab.dataset.mode;
      document.querySelectorAll('.bc-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      numWrap.classList.toggle('hidden', mode !== 'num');
      numWrap.classList.toggle('flex', mode === 'num');
      textWrap.classList.toggle('hidden', mode !== 'text');
      textWrap.classList.toggle('flex', mode === 'text');
      setErr('');
    });
  });

  decEl.value = '42'; syncFrom('dec');
  txtEl.value = 'Hi'; encodeText();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="cron-parser">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Cron expression (5 fields: minute hour day-of-month month day-of-week)
      <input
        id="cronp-in"
        type="text"
        class="field font-mono text-[13px]"
        placeholder="*/15 9-17 * * 1-5"
        spellcheck="false"
        value="*/15 9-17 * * 1-5"
      />
    </label>

    <div class="flex flex-wrap gap-2 text-[13px]">
      <button class="btn btn-tertiary cronp-ex" data-ex="* * * * *">every minute</button>
      <button class="btn btn-tertiary cronp-ex" data-ex="0 * * * *">hourly</button>
      <button class="btn btn-tertiary cronp-ex" data-ex="0 0 * * *">daily</button>
      <button class="btn btn-tertiary cronp-ex" data-ex="0 9 * * 1-5">weekday 9am</button>
      <button class="btn btn-tertiary cronp-ex" data-ex="30 3 1 * *">monthly</button>
    </div>

    <p id="cronp-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="cronp-results" class="flex flex-col gap-4">
      <div class="panel panel-lift p-4">
        <div class="text-[13px] text-ink-subtle">Schedule</div>
        <div class="copy-wrap">
          <div id="cronp-desc" class="mt-1 font-display text-lg text-primary-hover">—</div>
          <button type="button" class="copy-icon" data-copy-target="#cronp-desc" aria-label="Copy"></button>
        </div>
      </div>

      <div class="panel p-4">
        <div class="mb-2 text-sm text-ink-subtle">Next 5 run times (local time)</div>
        <div id="cronp-next" class="flex flex-col gap-2"></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free cron parser reads a standard five-field cron expression — minute,
      hour, day of month, month and day of week — and explains its schedule in
      plain English. It also computes the next five run times in your local time by
      scanning forward minute by minute and matching each field, so wildcards,
      steps like <code>*/15</code>, ranges like <code>9-17</code> and lists like
      <code>1,15</code> all work. Field ranges are validated. Parsing runs entirely
      in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { parseField, describe, nextRuns, fmtDate } from '../lib/cron';

  const input = document.getElementById('cronp-in') as HTMLInputElement;
  const err = document.getElementById('cronp-error')!;
  const results = document.getElementById('cronp-results')!;
  const descEl = document.getElementById('cronp-desc')!;
  const nextEl = document.getElementById('cronp-next')!;

  function run() {
    const raw = input.value.trim().replace(/\s+/g, ' ');
    if (!raw) {
      err.classList.add('hidden');
      results.classList.add('hidden');
      return;
    }
    const fields = raw.split(' ');
    if (fields.length !== 5) {
      err.textContent = `Expected 5 fields, got ${fields.length}. Format: minute hour day-of-month month day-of-week.`;
      err.classList.remove('hidden');
      results.classList.add('hidden');
      return;
    }

    let desc: string;
    try {
      fields.forEach((f, i) => parseField(f, i));
      desc = describe(fields);
    } catch (e) {
      err.textContent = (e as Error).message;
      err.classList.remove('hidden');
      results.classList.add('hidden');
      return;
    }

    err.classList.add('hidden');
    results.classList.remove('hidden');
    descEl.textContent = desc;

    const runs = nextRuns(fields, 5);
    nextEl.textContent = '';
    if (!runs.length) {
      const p = document.createElement('div');
      p.className = 'font-mono text-[13px] text-ink-muted';
      p.textContent = 'No upcoming run times found (impossible date combination, e.g. Feb 30).';
      nextEl.append(p);
      return;
    }
    runs.forEach((r, i) => {
      const row = document.createElement('div');
      row.className = 'flex items-baseline gap-3 border-t border-white/5 pt-2 first:border-0 first:pt-0';
      const n = document.createElement('span');
      n.className = 'font-mono text-[13px] text-ink-muted';
      n.textContent = String(i + 1) + '.';
      const t = document.createElement('span');
      t.className = 'font-mono text-[13px] text-ink';
      t.textContent = fmtDate(r);
      row.append(n, t);
      nextEl.append(row);
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.cronp-ex').forEach((btn) => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.ex!;
      run();
    });
  });

  input.addEventListener('input', run);
  run();
</script>

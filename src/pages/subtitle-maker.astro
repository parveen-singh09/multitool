---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="subtitle-maker">
  <div class="flex flex-col gap-5">

    <div id="subm-video-wrap" class="flex flex-col gap-2">
      <div class="flex flex-wrap items-center gap-2">
        <label class="btn btn-secondary cursor-pointer">
          Load video to sync
          <input id="subm-video-file" type="file" accept="video/*,audio/*" class="sr-only" />
        </label>
        <label class="btn btn-secondary cursor-pointer">
          Import .srt / .vtt
          <input id="subm-import" type="file" accept=".srt,.vtt,text/plain" class="sr-only" />
        </label>
        <span class="grow"></span>
        <button id="subm-add" class="btn btn-secondary">Add caption</button>
      </div>
      <div id="subm-player" class="hidden panel relative overflow-hidden p-0">
        <video id="subm-video" controls class="w-full rounded-lg bg-black"></video>
        <div id="subm-overlay" class="pointer-events-none absolute inset-x-0 bottom-6 flex justify-center px-4 text-center"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div class="flex flex-col gap-4">
        <div class="flex flex-wrap items-center gap-2">
          <label class="flex items-center gap-2 text-[13px] text-ink-subtle">Shift all
            <input id="subm-shift" type="number" step="0.1" value="0" class="field w-20" /> s
          </label>
          <button id="subm-shift-go" class="btn btn-tertiary">Apply</button>
        </div>
        <p id="subm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
        <div id="subm-rows" class="flex flex-col gap-3"></div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-sm text-ink-subtle">Subtitle preview</span>
          <span class="grow"></span>
          <button id="subm-fmt-srt" class="subm-fmt btn btn-tertiary" data-active>SRT</button>
          <button id="subm-fmt-vtt" class="subm-fmt btn btn-tertiary">VTT</button>
        </div>
        <div class="copy-wrap">
          <pre id="subm-preview" class="field min-h-72 resize-y overflow-auto whitespace-pre-wrap font-mono text-[13px]"></pre>
          <button type="button" class="copy-icon" data-copy-target="#subm-preview" aria-label="Copy"></button>
        </div>
        <button id="subm-download" class="btn btn-primary w-fit">Download <span id="subm-dl-ext">.srt</span></button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free subtitle maker builds SRT and WebVTT subtitle files. Load a video
      (or audio) to sync against and set each caption's start and end to the exact
      playhead position with one click, watching the captions appear live on the
      video as it plays. Import an existing .srt or .vtt to edit, shift every
      timestamp at once to fix sync, and keep an eye on the reading-speed
      (characters-per-second) warning so lines stay comfortable to read. Export as
      SRT or VTT.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .subm-fmt[data-active] { background-color: var(--color-surface-2); color: var(--color-ink); border-color: var(--color-hairline); }
  #subm-overlay span { background: rgba(0,0,0,0.65); color:#fff; padding:2px 8px; border-radius:4px; font-size:clamp(13px,2.5vw,20px); line-height:1.3; }
</style>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const rowsEl = $('subm-rows');
  const previewEl = $('subm-preview');
  const err = $('subm-error');
  const video = $('subm-video') as HTMLVideoElement;
  const overlay = $('subm-overlay');

  const TIME_RE = /^(\d{2}):([0-5]\d):([0-5]\d)[,.](\d{3})$/;
  let fmt: 'srt' | 'vtt' = 'srt';

  interface Row { start: string; end: string; text: string; }
  let rows: Row[] = [
    { start: '00:00:00,000', end: '00:00:02,500', text: 'Welcome to the show.' },
    { start: '00:00:02,600', end: '00:00:05,000', text: "Let's get started." },
  ];

  const pad = (n: number, w = 2) => String(n).padStart(w, '0');
  function timeToMs(t: string): number {
    const m = TIME_RE.exec(t.trim());
    if (!m) return NaN;
    return +m[1] * 3600000 + +m[2] * 60000 + +m[3] * 1000 + +m[4];
  }
  function msToTime(ms: number, sep = ','): string {
    ms = Math.max(0, Math.round(ms));
    const h = Math.floor(ms / 3600000); ms -= h * 3600000;
    const mn = Math.floor(ms / 60000); ms -= mn * 60000;
    const s = Math.floor(ms / 1000); ms -= s * 1000;
    return `${pad(h)}:${pad(mn)}:${pad(s)}${sep}${pad(ms, 3)}`;
  }

  function buildSrt(): string {
    return rows.map((r, i) => `${i + 1}\n${r.start.replace('.', ',')} --> ${r.end.replace('.', ',')}\n${r.text}`).join('\n\n');
  }
  function buildVtt(): string {
    const body = rows.map((r, i) => `${i + 1}\n${msToTime(timeToMs(r.start), '.')} --> ${msToTime(timeToMs(r.end), '.')}\n${r.text}`).join('\n\n');
    return `WEBVTT\n\n${body}`;
  }

  function validate(): string | null {
    for (let i = 0; i < rows.length; i++) {
      const r = rows[i];
      const s = timeToMs(r.start), e = timeToMs(r.end);
      if (Number.isNaN(s)) return `Caption ${i + 1}: start time must be hh:mm:ss,ms.`;
      if (Number.isNaN(e)) return `Caption ${i + 1}: end time must be hh:mm:ss,ms.`;
      if (e <= s) return `Caption ${i + 1}: end time must be after start time.`;
    }
    return null;
  }

  function cps(r: Row): number {
    const s = timeToMs(r.start), e = timeToMs(r.end);
    const dur = (e - s) / 1000;
    const chars = r.text.replace(/\s+/g, ' ').trim().length;
    return dur > 0 ? chars / dur : Infinity;
  }

  function refresh() {
    previewEl.textContent = fmt === 'srt' ? buildSrt() : buildVtt();
    const problem = validate();
    err.textContent = problem || '';
    err.classList.toggle('hidden', !problem);
  }

  function makeInput(value: string, placeholder: string, cls: string, onInput: (v: string) => void): HTMLInputElement {
    const elx = document.createElement('input');
    elx.type = 'text'; elx.className = cls; elx.value = value; elx.placeholder = placeholder;
    elx.addEventListener('input', () => onInput(elx.value));
    return elx;
  }

  function renderRows() {
    rowsEl.replaceChildren();
    rows.forEach((row, i) => {
      const card = document.createElement('div');
      card.className = 'panel flex flex-col gap-2 p-3';

      const bar = document.createElement('div');
      bar.className = 'flex items-center justify-between gap-2';
      const label = document.createElement('span');
      label.className = 'text-[13px] text-ink-muted';
      label.textContent = `Caption ${i + 1}`;
      const speed = document.createElement('span');
      const c = cps(row);
      speed.className = 'text-xs';
      speed.style.color = c > 21 ? '#e5484d' : c > 17 ? '#d0954a' : 'var(--color-ink-tertiary)';
      speed.textContent = isFinite(c) ? `${c.toFixed(1)} cps` : '';
      const del = document.createElement('button');
      del.className = 'btn btn-tertiary'; del.textContent = 'Remove';
      del.addEventListener('click', () => { rows.splice(i, 1); renderRows(); refresh(); });
      const left = document.createElement('div'); left.className = 'flex items-center gap-2'; left.append(label, speed);
      bar.append(left, del);

      const times = document.createElement('div');
      times.className = 'grid grid-cols-2 gap-2';
      times.appendChild(makeInput(row.start, '00:00:00,000', 'field font-mono text-[13px]', (v) => { row.start = v; refresh(); renderSpeed(speed, row); }));
      times.appendChild(makeInput(row.end, '00:00:02,000', 'field font-mono text-[13px]', (v) => { row.end = v; refresh(); renderSpeed(speed, row); }));

      const syncBar = document.createElement('div');
      syncBar.className = 'flex flex-wrap gap-2';
      if (video.src) {
        const setS = document.createElement('button');
        setS.className = 'btn btn-tertiary'; setS.style.cssText = 'min-height:26px;padding:2px 8px;font-size:12px'; setS.textContent = 'Set start ⏱';
        setS.addEventListener('click', () => { row.start = msToTime(video.currentTime * 1000); renderRows(); refresh(); });
        const setE = document.createElement('button');
        setE.className = 'btn btn-tertiary'; setE.style.cssText = 'min-height:26px;padding:2px 8px;font-size:12px'; setE.textContent = 'Set end ⏱';
        setE.addEventListener('click', () => { row.end = msToTime(video.currentTime * 1000); renderRows(); refresh(); });
        const seek = document.createElement('button');
        seek.className = 'btn btn-tertiary'; seek.style.cssText = 'min-height:26px;padding:2px 8px;font-size:12px'; seek.textContent = '▶ from start';
        seek.addEventListener('click', () => { const s = timeToMs(row.start); if (!Number.isNaN(s)) { video.currentTime = s / 1000; video.play(); } });
        syncBar.append(setS, setE, seek);
      }

      const text = document.createElement('textarea');
      text.className = 'field'; text.rows = 2; text.value = row.text; text.placeholder = 'Caption text';
      text.addEventListener('input', () => { row.text = text.value; refresh(); renderSpeed(speed, row); });

      card.append(bar, times, syncBar, text);
      rowsEl.appendChild(card);
    });
  }
  function renderSpeed(span: HTMLElement, row: Row) {
    const c = cps(row);
    span.style.color = c > 21 ? '#e5484d' : c > 17 ? '#d0954a' : 'var(--color-ink-tertiary)';
    span.textContent = isFinite(c) ? `${c.toFixed(1)} cps` : '';
  }

  function parseSubs(text: string): Row[] {
    const clean = text.replace(/^﻿/, '').replace(/\r/g, '');
    const arrow = /(\d{2}:\d{2}:\d{2}[,.]\d{3})\s*-->\s*(\d{2}:\d{2}:\d{2}[,.]\d{3})/;
    const blocks = clean.split(/\n\s*\n/);
    const out: Row[] = [];
    for (const block of blocks) {
      const lines = block.split('\n').filter((l) => l.trim() !== '' && l.trim().toUpperCase() !== 'WEBVTT');
      const idx = lines.findIndex((l) => arrow.test(l));
      if (idx === -1) continue;
      const m = arrow.exec(lines[idx])!;
      const textLines = lines.slice(idx + 1).join('\n').trim();
      out.push({ start: m[1].replace('.', ','), end: m[2].replace('.', ','), text: textLines });
    }
    return out;
  }

  $('subm-import').addEventListener('change', async (e) => {
    const f = (e.target as HTMLInputElement).files?.[0]; if (!f) return;
    const parsed = parseSubs(await f.text());
    if (parsed.length) { rows = parsed; renderRows(); refresh(); }
    else { err.textContent = 'No captions found in that file.'; err.classList.remove('hidden'); }
  });

  $('subm-video-file').addEventListener('change', (e) => {
    const f = (e.target as HTMLInputElement).files?.[0]; if (!f) return;
    video.src = URL.createObjectURL(f);
    $('subm-player').classList.remove('hidden');
    renderRows();
  });
  video.addEventListener('timeupdate', () => {
    const t = video.currentTime * 1000;
    const active = rows.find((r) => { const s = timeToMs(r.start), e = timeToMs(r.end); return t >= s && t <= e; });
    overlay.replaceChildren();
    if (active && active.text.trim()) { const s = document.createElement('span'); s.textContent = active.text; overlay.appendChild(s); }
  });

  $('subm-shift-go').addEventListener('click', () => {
    const delta = Number(($('subm-shift') as HTMLInputElement).value) * 1000;
    if (!delta) return;
    rows = rows.map((r) => ({ ...r, start: msToTime(Math.max(0, timeToMs(r.start) + delta)), end: msToTime(Math.max(0, timeToMs(r.end) + delta)) }));
    renderRows(); refresh();
  });

  function setFmt(f: 'srt' | 'vtt') {
    fmt = f;
    $('subm-fmt-srt').toggleAttribute('data-active', f === 'srt');
    $('subm-fmt-vtt').toggleAttribute('data-active', f === 'vtt');
    $('subm-dl-ext').textContent = '.' + f;
    refresh();
  }
  $('subm-fmt-srt').addEventListener('click', () => setFmt('srt'));
  $('subm-fmt-vtt').addEventListener('click', () => setFmt('vtt'));

  $('subm-add').addEventListener('click', () => {
    const last = rows[rows.length - 1];
    const start = last ? last.end : '00:00:00,000';
    rows.push({ start, end: msToTime(timeToMs(start) + 2000), text: '' });
    renderRows(); refresh();
  });

  $('subm-download').addEventListener('click', () => {
    const problem = validate();
    if (problem) { err.textContent = problem; err.classList.remove('hidden'); return; }
    const content = fmt === 'srt' ? buildSrt() : buildVtt();
    const blob = new Blob([content + '\n'], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.download = `toolsilk-subtitles.${fmt}`; link.href = url; link.click();
    URL.revokeObjectURL(url);
  });

  renderRows();
  refresh();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="xml-to-json-converter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Attributes
        <select id="x2j-attr" class="field w-auto py-1">
          <option value="group" selected>Group under @attributes</option>
          <option value="prefix">Prefix keys with @</option>
          <option value="ignore">Ignore attributes</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Indent
        <select id="x2j-indent" class="field w-auto py-1">
          <option value="2" selected>2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <label class="flex items-center gap-2 pb-2 text-sm text-ink-subtle">
        <input id="x2j-minify" type="checkbox" class="h-4 w-4" />
        Minify
      </label>
      <label class="flex items-center gap-2 pb-2 text-sm text-ink-subtle">
        <input id="x2j-coerce" type="checkbox" class="h-4 w-4" />
        Infer numbers &amp; booleans
      </label>
      <label class="flex items-center gap-2 pb-2 text-sm text-ink-subtle">
        <input id="x2j-root" type="checkbox" class="h-4 w-4" />
        Drop root wrapper
      </label>
    </div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <label class="btn btn-tertiary cursor-pointer">
        Upload XML
        <input id="x2j-file" type="file" accept=".xml,.svg,.rss,.atom,.wsdl,.xsd,.txt,text/xml,application/xml" class="hidden" />
      </label>
      <button id="x2j-sample" type="button" class="btn btn-tertiary">Load sample</button>
    </div>

    <div id="x2j-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>XML input</span>
          <button id="x2j-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
        </span>
        <div id="x2j-drop" class="hl-edit field p-0" style="height:22rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="x2j-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea id="x2j-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="XML input"></textarea>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>JSON output</span>
          <span class="flex gap-2">
            <button id="x2j-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
          </span>
        </span>
        <div class="copy-wrap">
          <pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre"><code id="x2j-out" class="hljs" style="background:transparent;padding:0"></code></pre>
          <button type="button" class="copy-icon" data-copy-target="#x2j-out" aria-label="Copy"></button>
        </div>
      </div>
    </div>

    <p id="x2j-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free XML to JSON converter parses XML with the browser's built-in
      DOMParser and maps it to structured JSON, live as you type. Elements become
      objects, repeated child elements become arrays, and text content is stored
      under <code>#text</code> when an element also carries attributes or children.
      Both panes are syntax-highlighted.
    </p>
    <p>
      Control how attributes map: group them under an <code>@attributes</code> key
      (the default), flatten them as <code>@</code>-prefixed keys alongside child
      elements, or drop them entirely. Turn on <em>Infer numbers &amp; booleans</em>
      to coerce text like <code>42</code>, <code>true</code> and <code>null</code>
      into real JSON types instead of strings, or <em>Drop root wrapper</em> to
      unwrap the single top-level element. Output can be pretty-printed at 2 spaces,
      4 spaces or a tab, or minified to one line.
    </p>
    <p>
      Paste XML, upload a file, or drag-and-drop it onto the input pane — SVG, RSS,
      Atom, WSDL and XSD are all just XML. Copy or download the JSON with one click.
      Parse errors report the exact problem the browser found instead of failing
      silently, and the status line shows the line and byte count of the result.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl, wireInput } from '../lib/highlight';

  type Json = null | string | number | boolean | Json[] | { [k: string]: Json };

  const input = document.getElementById('x2j-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('x2j-in-hl')!;
  const output = document.getElementById('x2j-out')!;
  const err = document.getElementById('x2j-error')!;
  const statusEl = document.getElementById('x2j-status')!;
  const attrSel = document.getElementById('x2j-attr') as HTMLSelectElement;
  const indentSel = document.getElementById('x2j-indent') as HTMLSelectElement;
  const indentWrap = indentSel.closest('label') as HTMLElement;
  const minifyBox = document.getElementById('x2j-minify') as HTMLInputElement;
  const coerceBox = document.getElementById('x2j-coerce') as HTMLInputElement;
  const rootBox = document.getElementById('x2j-root') as HTMLInputElement;
  const drop = document.getElementById('x2j-drop')!;
  let rawOutput = '';

  function getIndent(): string | number {
    return indentSel.value === 'tab' ? '\t' : Number(indentSel.value);
  }

  function coerce(text: string): Json {
    if (!coerceBox.checked) return text;
    if (text === 'true') return true;
    if (text === 'false') return false;
    if (text === 'null') return null;

    if (/^-?(0|[1-9]\d*)(\.\d+)?([eE][+-]?\d+)?$/.test(text)) {
      const n = Number(text);
      if (Number.isFinite(n) && String(n) === text) return n;
    }
    return text;
  }

  function elementToJson(el: Element): Json {
    const obj: { [k: string]: Json } = {};
    const attrMode = attrSel.value;

    if (attrMode !== 'ignore' && el.attributes.length) {
      if (attrMode === 'group') {
        const attrs: { [k: string]: Json } = {};
        for (const a of Array.from(el.attributes)) attrs[a.name] = coerce(a.value);
        obj['@attributes'] = attrs;
      } else {
        for (const a of Array.from(el.attributes)) obj['@' + a.name] = coerce(a.value);
      }
    }

    const children = Array.from(el.childNodes).filter((n) => n.nodeType === Node.ELEMENT_NODE) as Element[];
    let text = '';
    el.childNodes.forEach((n) => {
      if (n.nodeType === Node.TEXT_NODE || n.nodeType === Node.CDATA_SECTION_NODE) text += n.nodeValue ?? '';
    });
    text = text.trim();

    if (!children.length) {
      if (!Object.keys(obj).length) return coerce(text);
      if (text !== '') obj['#text'] = coerce(text);
      return obj;
    }

    for (const child of children) {
      const key = child.nodeName;
      const value = elementToJson(child);
      if (key in obj) {
        const existing = obj[key];
        if (Array.isArray(existing)) existing.push(value);
        else obj[key] = [existing, value];
      } else obj[key] = value;
    }
    if (text !== '') obj['#text'] = coerce(text);
    return obj;
  }

  function xmlToJson(text: string): Json {
    const doc = new DOMParser().parseFromString(text, 'application/xml');
    const pe = doc.querySelector('parsererror');
    if (pe) throw new Error(pe.textContent?.replace(/\s+/g, ' ').trim() || 'invalid XML');
    const root = doc.documentElement;
    if (!root) throw new Error('no root element');
    const value = elementToJson(root);
    return rootBox.checked ? value : { [root.nodeName]: value };
  }

  function showStatus(msg: string) {
    statusEl.textContent = msg;
    statusEl.classList.remove('hidden');
    statusEl.style.borderColor = '#27a644';
    statusEl.style.color = '#27a644';
  }

  function syncUI() {
    indentWrap.style.display = minifyBox.checked ? 'none' : '';
  }

  const rerender = wireInput(input, inHl, () => 'xml', () => { void convert(); });

  async function convert() {
    syncUI();
    err.classList.add('hidden');
    const raw = input.value.trim();
    if (!raw) {
      rawOutput = ''; output.textContent = ''; statusEl.classList.add('hidden');
      return;
    }
    try {
      const data = xmlToJson(raw);
      rawOutput = JSON.stringify(data, null, minifyBox.checked ? undefined : getIndent());
      await hl(output, rawOutput, 'json');
      const bytes = new Blob([rawOutput]).size;
      const lines = rawOutput ? rawOutput.split('\n').length : 0;
      showStatus(`XML → JSON · ${lines} ${lines === 1 ? 'line' : 'lines'} · ${bytes} bytes ✓`);
    } catch (e) {
      rawOutput = ''; output.textContent = ''; statusEl.classList.add('hidden');
      err.textContent = `XML parse error: ${(e as Error).message}`;
      err.classList.remove('hidden');
    }
  }

  for (const el of [attrSel, indentSel, minifyBox, coerceBox, rootBox]) {
    el.addEventListener('change', () => { void convert(); });
  }

  document.getElementById('x2j-clear')!.addEventListener('click', () => {
    input.value = ''; rawOutput = ''; output.textContent = '';
    err.classList.add('hidden'); statusEl.classList.add('hidden');
    rerender();
  });

  document.getElementById('x2j-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const blob = new Blob([rawOutput], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'converted.json';
    a.click();
    URL.revokeObjectURL(url);
  });

  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => { input.value = String(reader.result ?? ''); rerender(); void convert(); };
    reader.onerror = () => { err.textContent = 'Could not read file.'; err.classList.remove('hidden'); };
    reader.readAsText(file);
  }

  const fileInput = document.getElementById('x2j-file') as HTMLInputElement;
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  ['dragover', 'dragenter'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.style.outline = '2px solid #5e6ad2'; }));
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, () => { drop.style.outline = ''; }));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) loadFile(file);
  });

  const SAMPLE = '<book id="1" lang="en">\n  <title>YAML</title>\n  <price>29.99</price>\n  <inStock>true</inStock>\n  <tags>\n    <tag>fast</tag>\n    <tag>human-readable</tag>\n  </tags>\n</book>';
  document.getElementById('x2j-sample')!.addEventListener('click', () => {
    input.value = SAMPLE; rerender(); void convert();
  });

  input.value = SAMPLE;
  rerender();
  void convert();
</script>

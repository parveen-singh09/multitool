---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';
import { tools } from '../data/tools';
import { toolHaystack } from '../lib/toolSearch';

// Same search index shape as the header dropdown: name + full haystack.
const toolIndex = tools.map((t) => ({ n: t.name, h: toolHaystack(t) }));
---

<Layout
  title="Feedback"
  description={`Suggest a new tool, request changes to an existing one, or report a bug on ${SITE.name}.`}
  noindex
>
  <Header />

  <main class="container-page py-14">
    <div class="mx-auto max-w-2xl">
      <span class="eyebrow text-primary-hover">Feedback</span>
      <h1 class="display-md mt-3 text-ink">Send us your feedback</h1>
      <p class="mt-4 text-[15px] leading-relaxed text-ink-muted">
        Want a new tool, a change to an existing one, or found something broken?
        Fill this in and we'll pick it up over email.
      </p>

      <form id="feedback-form" class="mt-8 flex flex-col gap-5">
        <label class="flex flex-col gap-2">
          <span class="text-sm font-medium text-ink">Type of request</span>
          <select
            name="type"
            class="h-10 rounded-md border border-hairline bg-surface-2 px-3 text-sm text-ink focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          >
            <option value="Add a new tool">Add a new tool</option>
            <option value="Change an existing tool">Change an existing tool</option>
            <option value="Bug report">Bug report</option>
            <option value="General feedback">General feedback</option>
          </select>
        </label>

        <label class="flex flex-col gap-2">
          <span class="text-sm font-medium text-ink">Tool name <span class="text-ink-subtle">(optional)</span></span>
          <div class="relative">
            <input
              id="tool-input"
              type="text"
              name="tool"
              autocomplete="off"
              role="combobox"
              aria-expanded="false"
              aria-controls="tool-results"
              aria-autocomplete="list"
              placeholder="Start typing to search tools…"
              class="h-10 w-full rounded-md border border-hairline bg-surface-2 px-3 text-sm text-ink placeholder:text-ink-subtle focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            />
            <ul id="tool-results" class="tool-results hidden" role="listbox"></ul>
          </div>
        </label>

        <label class="flex flex-col gap-2">
          <span class="text-sm font-medium text-ink">Message</span>
          <textarea
            name="message"
            rows="6"
            required
            placeholder="Tell us what you'd like — what it should do, who it helps, or what went wrong."
            class="rounded-md border border-hairline bg-surface-2 px-3 py-2 text-sm text-ink placeholder:text-ink-subtle focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          ></textarea>
        </label>

        <label class="flex flex-col gap-2">
          <span class="text-sm font-medium text-ink">Your email <span class="text-ink-subtle">(optional, if you want a reply)</span></span>
          <input
            type="email"
            name="from"
            placeholder="you@example.com"
            class="h-10 rounded-md border border-hairline bg-surface-2 px-3 text-sm text-ink placeholder:text-ink-subtle focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </label>

        <div class="flex items-center gap-3">
          <button type="submit" class="btn btn-primary">Send feedback</button>
          <span id="feedback-status" class="text-sm text-ink-subtle" role="status" aria-live="polite"></span>
        </div>
      </form>
    </div>
  </main>

  <Footer />
</Layout>

<script type="application/json" data-tool-index set:html={JSON.stringify(toolIndex)} />

<style>
  .tool-results {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    z-index: 60;
    max-height: 20rem;
    overflow-y: auto;
    margin: 0;
    padding: 0.25rem;
    list-style: none;
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.45);
  }
  .tool-results:empty { display: none; }
  .tool-results :global(li) {
    padding: 0.5rem 0.625rem;
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    font-size: 0.875rem;
    line-height: 1.3;
    cursor: pointer;
  }
  .tool-results :global(li[aria-selected='true']),
  .tool-results :global(li:hover) {
    background-color: var(--color-surface-2);
  }
</style>

<script>
  import { matchesQuery, compareByQuery } from '../lib/toolSearch';

  const input = document.getElementById('tool-input') as HTMLInputElement | null;
  const list = document.getElementById('tool-results') as HTMLUListElement | null;
  if (input && list) {
    let index: { n: string; h: string }[] = [];
    try {
      const raw = document.querySelector('[data-tool-index]')?.textContent;
      if (raw) index = JSON.parse(raw);
    } catch (_) {}

    let items: { n: string; h: string }[] = [];
    let active = -1;

    const close = () => {
      list.replaceChildren();
      list.classList.add('hidden');
      input.setAttribute('aria-expanded', 'false');
      active = -1;
    };

    const pick = (name: string) => {
      input.value = name;
      close();
    };

    const setActive = (i: number) => {
      const lis = list.querySelectorAll('li');
      lis.forEach((li) => li.setAttribute('aria-selected', 'false'));
      active = i;
      if (i >= 0 && lis[i]) {
        lis[i].setAttribute('aria-selected', 'true');
        lis[i].scrollIntoView({ block: 'nearest' });
      }
    };

    const render = (raw: string) => {
      const q = raw.trim();
      if (!q) return close();
      items = index
        .filter((t) => matchesQuery(t.h, raw))
        .sort((a, b) => compareByQuery(a.n, b.n, raw))
        .slice(0, 5); // max 5 at once
      if (!items.length) return close();
      list.replaceChildren(
        ...items.map((t) => {
          const li = document.createElement('li');
          li.setAttribute('role', 'option');
          li.setAttribute('aria-selected', 'false');
          li.textContent = t.n;
          li.addEventListener('mousedown', (e) => {
            e.preventDefault();
            pick(t.n);
          });
          return li;
        }),
      );
      list.classList.remove('hidden');
      input.setAttribute('aria-expanded', 'true');
      active = -1;
    };

    input.addEventListener('input', () => render(input.value));
    input.addEventListener('focus', () => {
      if (input.value.trim()) render(input.value);
    });
    input.addEventListener('keydown', (e) => {
      if (list.classList.contains('hidden')) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(Math.min(active + 1, items.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(Math.max(active - 1, 0));
      } else if (e.key === 'Enter' && active >= 0) {
        e.preventDefault();
        pick(items[active].n);
      } else if (e.key === 'Escape') {
        close();
      }
    });
    input.addEventListener('blur', () => setTimeout(close, 120));
  }
</script>

<script is:inline>
  const form = document.getElementById('feedback-form');
  const status = document.getElementById('feedback-status');
  const btn = form?.querySelector('button[type="submit"]');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const payload = {
      type: (data.get('type') || 'Feedback').toString(),
      tool: (data.get('tool') || '').toString().trim(),
      message: (data.get('message') || '').toString().trim(),
      from: (data.get('from') || '').toString().trim(),
    };

    if (status) { status.textContent = 'Sending…'; status.style.color = ''; }
    if (btn) btn.disabled = true;

    try {
      const res = await fetch('/api/feedback', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error();
      form.reset();
      if (status) {
        status.textContent = 'Thanks — your feedback was sent.';
        status.style.color = 'var(--color-primary-hover)';
      }
    } catch (_) {
      if (status) {
        status.textContent = 'Could not send. Please email us instead.';
        status.style.color = '#f87171';
      }
    } finally {
      if (btn) btn.disabled = false;
    }
  });
</script>

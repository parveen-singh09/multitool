---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="swf-to-mp4">
  <ArchiveConvert slug="swf-to-mp4" from="swf" to="mp4" noun="video" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SWF to MP4 converter converts legacy Flash SWF animations to modern MP4 video.
    </p>
    <p>
      Conversion is handled on our servers, because these
      broadcast and proprietary video formats can't be decoded in a browser. Your
      file is uploaded to our servers, converted on their
      servers, and returned as a download link.
    </p>
  </div>
</ToolLayout>

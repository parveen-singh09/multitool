---
import ToolLayout from '../layouts/ToolLayout.astro';
import FontConvert from '../components/FontConvert.astro';
---

<ToolLayout slug="otf-to-woff">
  <FontConvert slug="otf-to-woff" from="otf" to="woff" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free OTF to WOFF converter converts OpenType OTF fonts to web-ready WOFF for @font-face embedding.
    </p>
    <p>
      Everything runs entirely in your browser — your fonts are never uploaded to a
      server. Convert one font or a whole batch and download the results
      individually or as a ZIP.
    </p>
  </div>
</ToolLayout>

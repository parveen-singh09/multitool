---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="lottery-number-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Game
      <select id="lt-game" class="field">
        <option value="5,1,69,1,1,26">Powerball (5 of 1–69 + 1 of 1–26)</option>
        <option value="5,1,70,1,1,25">Mega Millions (5 of 1–70 + 1 of 1–25)</option>
        <option value="5,1,50,2,1,12">EuroMillions (5 of 1–50 + 2 of 1–12)</option>
        <option value="5,1,50,2,1,10">EuroJackpot (5 of 1–50 + 2 of 1–10)</option>
        <option value="6,1,59,1,1,59">UK Lotto (6 of 1–59 + bonus)</option>
        <option value="6,1,49,0,0,0">Lotto 6/49 (6 of 1–49)</option>
        <option value="6,1,45,0,0,0">Lotto 6/45 (6 of 1–45)</option>
        <option value="5,1,50,0,0,0">Keno-style (5 of 1–50)</option>
        <option value="custom">Custom…</option>
      </select>
    </label>

    <div id="lt-custom" class="hidden flex-col gap-3">
      <div class="grid grid-cols-3 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Main count
          <input id="lt-mc" type="number" min="1" max="30" value="6" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Main from
          <input id="lt-mf" type="number" min="0" max="998" value="1" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Main to
          <input id="lt-mt" type="number" min="1" max="999" value="49" class="field" />
        </label>
      </div>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="lt-bonus-on" type="checkbox" class="h-4 w-4" /> Bonus numbers
      </label>
      <div id="lt-bonus-row" class="hidden grid-cols-3 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bonus count
          <input id="lt-bc" type="number" min="1" max="10" value="1" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bonus from
          <input id="lt-bf" type="number" min="0" max="998" value="1" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bonus to
          <input id="lt-bt" type="number" min="1" max="999" value="26" class="field" />
        </label>
      </div>
    </div>

    <div class="flex flex-wrap items-end gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Lines
        <input id="lt-lines" type="number" min="1" max="50" value="1" class="field w-20" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Reveal speed
        <select id="lt-speed" class="field w-32">
          <option value="0">Instant</option>
          <option value="120" selected>Normal</option>
          <option value="300">Slow / suspense</option>
        </select>
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="lt-sort" type="checkbox" class="h-4 w-4" checked /> Sort
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="lt-uniq" type="checkbox" class="h-4 w-4" checked /> No repeats
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="lt-sound" type="checkbox" class="h-4 w-4" /> Sound
      </label>
      <button id="lt-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="lt-copy" class="btn btn-secondary">Copy all</button>
    </div>

    <div id="lt-out" class="flex flex-col gap-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free lottery number generator produces random picks for popular games —
      Powerball, Mega Millions, EuroMillions, EuroJackpot, UK Lotto and Lotto
      6/49 / 6/45 — or a fully custom game you define with your own number range,
      how many to draw and optional bonus balls on their own range. Generate up to
      50 lines at once, sort each line, allow or forbid repeats, and reveal the
      balls one at a time for a bit of draw-day suspense with an optional click.
    </p>
    <p>
      Every number uses your browser's secure random source
      (<code>crypto.getRandomValues</code>) with rejection sampling, so draws are
      genuinely uniform and unbiased — no modulo skew. Copy any line, or copy all
      lines at once. For entertainment only; it cannot improve your odds of winning.
    </p>
  </div>
</ToolLayout>

<style>
  @keyframes lt-pop { from { transform: scale(0.4); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .lt-pop { animation: lt-pop 0.25s ease-out; }
  @media (prefers-reduced-motion: reduce) { .lt-pop { animation: none; } }
</style>

<script>
  import { sample, pickN, randInt } from '../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const gameEl = $('lt-game') as HTMLSelectElement;
  const out = $('lt-out')!;
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const chk = (id: string) => ($(id) as HTMLInputElement).checked;
  const num = (id: string) => Number(($(id) as HTMLInputElement).value);

  let ac: AudioContext | null = null;
  function tick() {
    if (!chk('lt-sound')) return;
    ac ??= new (window.AudioContext || (window as any).webkitAudioContext)();
    const o = ac.createOscillator(), g = ac.createGain();
    o.frequency.value = 660; o.connect(g); g.connect(ac.destination);
    g.gain.setValueAtTime(0.15, ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + 0.08);
    o.start(); o.stop(ac.currentTime + 0.08);
  }

  gameEl.addEventListener('change', () => {
    const custom = gameEl.value === 'custom';
    $('lt-custom').classList.toggle('hidden', !custom);
    $('lt-custom').classList.toggle('flex', custom);
    generate();
  });
  $('lt-bonus-on').addEventListener('change', () => {
    const on = chk('lt-bonus-on');
    $('lt-bonus-row').classList.toggle('hidden', !on);
    $('lt-bonus-row').classList.toggle('grid', on);
    generate();
  });

  function config() {
    if (gameEl.value === 'custom') {
      const bonus = chk('lt-bonus-on');
      return {
        mc: num('lt-mc'), mf: num('lt-mf'), mt: num('lt-mt'),
        bc: bonus ? num('lt-bc') : 0, bf: num('lt-bf'), bt: num('lt-bt'),
      };
    }
    const [mc, mf, mt, bc, bf, bt] = gameEl.value.split(',').map(Number);
    return { mc, mf, mt, bc, bf, bt };
  }

  function draw(count: number, from: number, to: number): number[] {
    const lo = Math.min(from, to), hi = Math.max(from, to);
    const size = hi - lo + 1;
    const uniq = chk('lt-uniq');
    let nums: number[];
    if (uniq && count <= size) {
      const pool = Array.from({ length: size }, (_, i) => lo + i);
      nums = sample(pool, count);
    } else {

      nums = pickN(Array.from({ length: size }, (_, i) => lo + i), count);
    }
    return chk('lt-sort') ? nums.slice().sort((a, b) => a - b) : nums;
  }

  function ballHtml(n: number, bonus: boolean, hidden: boolean): string {
    const base = 'lt-ball flex h-11 w-11 items-center justify-center rounded-full font-mono text-[15px] font-semibold';
    const skin = bonus ? 'bg-primary text-white' : 'border border-hairline bg-surface-2 text-ink';
    return `<span class="${base} ${skin}${hidden ? '' : ' lt-pop'}" data-n="${n}">${hidden ? '' : n}</span>`;
  }

  function lineHtml(idx: number, main: number[], bonus: number[]): string {
    const speed = num('lt-speed');
    const hidden = speed > 0 && !reduceMotion;
    let balls = main.map((n) => ballHtml(n, false, hidden)).join('');
    if (bonus.length) {
      balls += '<span class="mx-1 self-center text-ink-tertiary">+</span>' +
        bonus.map((n) => ballHtml(n, true, hidden)).join('');
    }
    const text = main.join(' ') + (bonus.length ? '  +  ' + bonus.join(' ') : '');
    return `<div class="flex flex-wrap items-center gap-2" data-line="${text}">
      ${balls}
      <button class="btn btn-secondary ml-auto lt-copy-one" title="Copy this line" data-text="${text}">Copy</button>
    </div>`;
  }

  let revealTimer = 0;
  function revealAll() {
    clearInterval(revealTimer);
    const balls = Array.from(out.querySelectorAll<HTMLElement>('.lt-ball'))
      .filter((b) => !b.textContent);
    if (!balls.length) return;
    const speed = num('lt-speed');
    let i = 0;
    revealTimer = window.setInterval(() => {
      const b = balls[i++];
      b.textContent = b.dataset.n || '';
      b.classList.add('lt-pop');
      tick();
      if (i >= balls.length) clearInterval(revealTimer);
    }, speed);
  }

  function generate() {
    const { mc, mf, mt, bc, bf, bt } = config();
    const lines = Math.max(1, Math.min(50, num('lt-lines') || 1));
    const rows: string[] = [];
    for (let i = 0; i < lines; i++) {
      const main = draw(mc, mf, mt);
      const bonus = bc > 0 ? draw(bc, bf, bt) : [];
      rows.push(lineHtml(i, main, bonus));
    }
    out.innerHTML = rows.join('');
    revealAll();
  }

  out.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.lt-copy-one') as HTMLElement | null;
    if (btn) navigator.clipboard?.writeText(btn.dataset.text || '');
  });
  $('lt-copy').addEventListener('click', () => {
    const text = Array.from(out.querySelectorAll<HTMLElement>('[data-line]'))
      .map((el) => el.dataset.line).join('\n');
    if (text) navigator.clipboard?.writeText(text);
  });

  ['lt-lines', 'lt-mc', 'lt-mf', 'lt-mt', 'lt-bc', 'lt-bf', 'lt-bt', 'lt-speed', 'lt-sort', 'lt-uniq']
    .forEach((id) => $(id).addEventListener('input', generate));
  $('lt-gen').addEventListener('click', generate);
  generate();
</script>

?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="heic-to-jpg">
  <div class="flex flex-col gap-4">
    <label id="hc-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose HEIC/HEIF photos or drop them here</span>
      <input id="hc-file" type="file" accept=".heic,.heif,image/heic,image/heif" multiple class="sr-only" />
    </label>

    <div id="hc-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Format
          <select id="hc-fmt" class="field w-32">
            <option value="image/jpeg">JPG</option>
            <option value="image/png">PNG</option>
            <option value="image/webp">WebP</option>
          </select>
        </label>
        <label id="hc-qwrap" class="flex flex-1 flex-col gap-1 text-sm text-ink-subtle" style="min-width:12rem">Quality: <span id="hc-qval" class="text-ink">90%</span>
          <input id="hc-q" type="range" min="10" max="100" value="90" class="w-full accent-primary" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Max size (px)
          <input id="hc-max" type="number" min="16" step="1" placeholder="Original" class="field w-32" />
        </label>
      </div>
      <p class="text-[13px] text-ink-tertiary">Change any option to re-convert instantly — the decoded photos stay cached, so there's no waiting for a fresh HEIC decode.</p>
      <div class="flex flex-wrap items-center gap-3">
        <p id="hc-status" class="flex-1 text-[13px] text-ink-subtle"></p>
        <button id="hc-more" class="btn btn-secondary hidden py-1 text-[13px]" type="button">Add more</button>
        <button id="hc-all" class="btn btn-secondary hidden py-1 text-[13px]" type="button">Download all (ZIP)</button>
        <button id="hc-clear" class="btn btn-tertiary hidden py-1 text-[13px]" type="button">Clear</button>
      </div>
      <div id="hc-grid" class="grid grid-cols-2 gap-3 sm:grid-cols-3"></div>
    </div>
    <p id="hc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free HEIC to JPG converter turns Apple HEIC and HEIF photos — the
      format iPhones use — into universally supported JPG, PNG, or WebP images.
      Add one or several photos, pick a format, tune the quality, optionally cap
      the longest side to shrink large shots, then download each result or grab
      them all in a single ZIP.
    </p>
    <p>
      Re-encoding strips embedded
      EXIF metadata (location, device, timestamps) from the output, and each
      card shows the output dimensions plus original versus converted size so
      you can see how much space you saved.
    </p>
    <p>
      Unlike most online converters, each photo is decoded once and kept in
      memory — so changing the format, quality, or maximum size re-converts
      instantly instead of re-processing every file from scratch. Add more
      photos to the batch at any time, remove individual ones you don't want,
      then download results one by one or all together as a ZIP.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const fileInput = document.getElementById('hc-file') as HTMLInputElement;
  const drop = document.getElementById('hc-drop')!;
  const panel = document.getElementById('hc-panel')!;
  const grid = document.getElementById('hc-grid')!;
  const status = document.getElementById('hc-status')!;
  const err = document.getElementById('hc-error')!;
  const qEl = document.getElementById('hc-q') as HTMLInputElement;
  const qval = document.getElementById('hc-qval')!;
  const qwrap = document.getElementById('hc-qwrap')!;
  const fmtEl = document.getElementById('hc-fmt') as HTMLSelectElement;
  const maxEl = document.getElementById('hc-max') as HTMLInputElement;
  const allBtn = document.getElementById('hc-all') as HTMLButtonElement;
  const clearBtn = document.getElementById('hc-clear') as HTMLButtonElement;
  const moreBtn = document.getElementById('hc-more') as HTMLButtonElement;

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const fmtSize = (n: number) => n < 1024 ? n + ' B' : n < 1048576 ? (n / 1024).toFixed(1) + ' KB' : (n / 1048576).toFixed(2) + ' MB';

  qEl.addEventListener('input', () => (qval.textContent = qEl.value + '%'));

  const syncQuality = () => qwrap.style.display = fmtEl.value === 'image/png' ? 'none' : 'flex';
  fmtEl.addEventListener('change', syncQuality);
  syncQuality();

  type Item = { file: File; decoded?: Blob; name?: string; blob?: Blob; w?: number; h?: number; url?: string; error?: boolean };
  const items: Item[] = [];

  function crc32(buf: Uint8Array) {
    let crc = 0xffffffff;
    for (let i = 0; i < buf.length; i++) {
      let c = (crc ^ buf[i]) & 0xff;
      for (let k = 0; k < 8; k++) c = c & 1 ? 0xedb88320 ^ (c >>> 1) : c >>> 1;
      crc = (crc >>> 8) ^ c;
    }
    return (crc ^ 0xffffffff) >>> 0;
  }
  const u16 = (n: number) => new Uint8Array([n & 255, (n >> 8) & 255]);
  const u32 = (n: number) => new Uint8Array([n & 255, (n >> 8) & 255, (n >> 16) & 255, (n >> 24) & 255]);
  function makeZip(entries: { name: string; data: Uint8Array }[]) {
    const enc = new TextEncoder();
    const parts: BlobPart[] = [];
    const central: Uint8Array[] = [];
    let offset = 0;
    for (const e of entries) {
      const name = enc.encode(e.name);
      const crc = crc32(e.data), size = e.data.length;
      const lfh = [u32(0x04034b50), u16(20), u16(0), u16(0), u16(0), u16(0), u32(crc), u32(size), u32(size), u16(name.length), u16(0), name, e.data];
      const lfhLen = lfh.reduce((s, a) => s + a.length, 0);
      parts.push(...(lfh as BlobPart[]));
      central.push(...[u32(0x02014b50), u16(20), u16(20), u16(0), u16(0), u16(0), u16(0), u32(crc), u32(size), u32(size), u16(name.length), u16(0), u16(0), u16(0), u16(0), u32(0), u32(offset), name] as any);
      offset += lfhLen;
    }
    const cdStart = offset;
    const cdSize = central.reduce((s, a) => s + a.length, 0);
    parts.push(...(central as unknown as BlobPart[]));
    parts.push(u32(0x06054b50), u16(0), u16(0), u16(entries.length), u16(entries.length), u32(cdSize), u32(cdStart), u16(0));
    return new Blob(parts, { type: 'application/zip' });
  }

  if (crc32(new TextEncoder().encode('123456789')) !== 0xcbf43926) console.error('crc32 self-check failed');

  async function reencode(srcBlob: Blob, fmt: string, quality: number, maxDim: number) {
    const img = await createImageBitmap(srcBlob);
    let { width, height } = img;
    if (maxDim > 0 && Math.max(width, height) > maxDim) {
      const s = maxDim / Math.max(width, height);
      width = Math.round(width * s); height = Math.round(height * s);
    }
    const canvas = document.createElement('canvas');
    canvas.width = width; canvas.height = height;
    canvas.getContext('2d')!.drawImage(img, 0, 0, width, height);
    img.close();
    const out: Blob = await new Promise((res, rej) =>
      canvas.toBlob((b) => (b ? res(b) : rej(new Error('encode failed'))), fmt, quality));
    return { blob: out, width, height };
  }

  const currentExt = () => (fmtEl.value === 'image/png' ? 'png' : fmtEl.value === 'image/webp' ? 'webp' : 'jpg');

  function render() {
    grid.innerHTML = '';
    for (let i = 0; i < items.length; i++) {
      const it = items[i];
      const div = document.createElement('div');
      if (it.error) {
        div.className = 'panel flex items-center justify-between gap-2 p-3 text-[13px]';
        div.style.color = '#e5484d';
        div.innerHTML = `<span class="truncate" title="${it.file.name}">${it.file.name}: not a valid HEIC/HEIF image</span>`;
        const x = document.createElement('button');
        x.type = 'button'; x.textContent = '✕'; x.title = 'Remove';
        x.className = 'shrink-0 text-ink-tertiary hover:text-ink';
        x.addEventListener('click', () => removeAt(i));
        div.appendChild(x);
        grid.appendChild(div);
        continue;
      }
      div.className = 'panel panel-lift flex flex-col gap-2 p-2';
      const dims = it.w ? `${it.w}×${it.h}` : '';
      const meta = it.blob ? `${it.name} · ${dims} · ${fmtSize(it.blob.size)}` : `${it.file.name} · decoding…`;
      div.innerHTML =
        (it.url ? `<img src="${it.url}" class="w-full rounded-sm" alt="${it.name}" loading="lazy" />` : '') +
        `<span class="truncate text-[12px] text-ink-subtle" title="${meta}">${meta}</span>` +
        `<div class="flex gap-2">` +
          (it.blob ? `<a href="${it.url}" download="${it.name}" class="btn btn-secondary flex-1 py-1 text-[13px] truncate">Download</a>` : '') +
          `<button type="button" data-rm class="btn btn-tertiary py-1 text-[13px]" title="Remove">✕</button>` +
        `</div>`;
      div.querySelector('[data-rm]')!.addEventListener('click', () => removeAt(i));
      grid.appendChild(div);
    }
    const has = items.some((it) => it.blob);
    allBtn.classList.toggle('hidden', !has);
    clearBtn.classList.toggle('hidden', items.length === 0);
    moreBtn.classList.toggle('hidden', items.length === 0);
  }

  function removeAt(i: number) {
    const it = items[i];
    if (it?.url) URL.revokeObjectURL(it.url);
    items.splice(i, 1);
    if (items.length === 0) { clearAll(); return; }
    updateStatus(); render();
  }

  function updateStatus() {
    let savedIn = 0, savedOut = 0, ok = 0;
    for (const it of items) if (it.blob) { savedIn += it.file.size; savedOut += it.blob.size; ok++; }
    const delta = savedIn - savedOut;
    const savedMsg = ok && delta > 0 ? ` — saved ${fmtSize(delta)} (${Math.round((delta / savedIn) * 100)}%)` : '';
    status.textContent = ok ? `Done — ${ok}/${items.length} converted${savedMsg}.` : '';
  }

  // Re-encode every already-decoded item with the current format/quality/size. Instant — no HEIC decode.
  async function encodeAll() {
    const fmt = fmtEl.value, ext = currentExt();
    const quality = Number(qEl.value) / 100;
    const maxDim = Math.max(0, Number(maxEl.value) || 0);
    for (const it of items) {
      if (!it.decoded) continue;
      try {
        const { blob, width, height } = await reencode(it.decoded, fmt, quality, maxDim);
        if (it.url) URL.revokeObjectURL(it.url);
        it.blob = blob; it.w = width; it.h = height; it.url = URL.createObjectURL(blob);
        it.name = it.file.name.replace(/\.hei[cf]$/i, '') + '.' + ext;
      } catch { it.error = true; }
    }
    updateStatus(); render();
  }

  // Decode any not-yet-decoded items (the slow HEIC step), then encode with current settings.
  async function decodePending() {
    const pending = items.filter((it) => !it.decoded && !it.error);
    if (!pending.length) { await encodeAll(); return; }
    const { default: heic2any } = await import('heic2any');
    let n = 0;
    for (const it of pending) {
      status.textContent = `Decoding ${it.file.name} (${++n}/${pending.length})…`;
      render();
      try {
        const decoded = await heic2any({ blob: it.file, toType: 'image/png' });
        it.decoded = (Array.isArray(decoded) ? decoded[0] : decoded) as Blob;
      } catch { it.error = true; }
    }
    await encodeAll();
  }

  function add(files: File[]) {
    setErr('');
    panel.classList.remove('hidden'); panel.classList.add('flex');
    for (const f of files) items.push({ file: f });
    render();
    decodePending();
  }

  function clearAll() {
    for (const it of items) if (it.url) URL.revokeObjectURL(it.url);
    items.length = 0;
    status.textContent = '';
    fileInput.value = '';
    render();
    panel.classList.add('hidden'); panel.classList.remove('flex');
  }

  // Debounce re-encode so dragging the quality slider doesn't fire on every pixel.
  let reencodeTimer: number | undefined;
  const scheduleReencode = () => {
    clearTimeout(reencodeTimer);
    reencodeTimer = window.setTimeout(() => { if (items.some((it) => it.decoded)) encodeAll(); }, 250);
  };
  qEl.addEventListener('input', scheduleReencode);
  maxEl.addEventListener('input', scheduleReencode);
  fmtEl.addEventListener('change', () => { if (items.some((it) => it.decoded)) encodeAll(); });

  allBtn.addEventListener('click', async () => {
    const ready = items.filter((it) => it.blob);
    if (!ready.length) return;
    allBtn.disabled = true;
    const prev = allBtn.textContent;
    allBtn.textContent = 'Zipping…';
    try {
      const entries = await Promise.all(ready.map(async (r) => ({ name: r.name!, data: new Uint8Array(await r.blob!.arrayBuffer()) })));
      const zip = makeZip(entries);
      const url = URL.createObjectURL(zip);
      const a = document.createElement('a');
      a.href = url; a.download = 'heic-converted.zip';
      a.click();
      setTimeout(() => URL.revokeObjectURL(url), 4000);
    } catch { setErr('Could not build the ZIP archive.'); }
    allBtn.disabled = false; allBtn.textContent = prev;
  });

  clearBtn.addEventListener('click', clearAll);
  moreBtn.addEventListener('click', () => fileInput.click());

  function pick(files: FileList | File[]) {
    const arr = Array.from(files).filter((f) => /\.hei[cf]$/i.test(f.name) || /heic|heif/.test(f.type));
    if (!arr.length) { setErr('Please choose HEIC or HEIF files.'); return; }
    add(arr);
  }

  fileInput.addEventListener('change', () => { if (fileInput.files) pick(fileInput.files); fileInput.value = ''; });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files; if (f) pick(f); });
</script>

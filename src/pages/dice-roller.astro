---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="dice-roller">
  <div class="flex flex-col gap-6">

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Dice type
        <select id="dr-type" class="field w-32">
          <option value="4">D4</option>
          <option value="6" selected>D6</option>
          <option value="8">D8</option>
          <option value="10">D10</option>
          <option value="12">D12</option>
          <option value="20">D20</option>
          <option value="100">D100</option>
          <option value="custom">Custom…</option>
        </select>
      </label>
      <label id="dr-sides-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Sides
        <input id="dr-sides" type="number" min="2" max="100000" value="6" class="field w-24" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="dr-count" type="number" min="1" max="100" value="2" class="field w-24" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Modifier
        <input id="dr-mod" type="number" value="0" class="field w-24" />
      </label>
      <button id="dr-roll" class="btn btn-primary ml-auto">Roll</button>
      <button id="dr-clear" class="btn btn-secondary">Clear</button>
      <button id="dr-sound" type="button" class="btn btn-secondary" aria-pressed="true" aria-label="Toggle roll sound" title="Toggle roll sound">🔊</button>
    </div>

    <div id="dr-dice" class="flex flex-wrap gap-3"></div>

    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="panel panel-lift flex flex-col items-center gap-1 p-4">
        <span id="dr-total" class="font-mono text-3xl text-ink">0</span>
        <span class="text-[13px] text-ink-subtle">Total</span>
      </div>
      <div class="panel flex flex-col items-center gap-1 p-4">
        <span id="dr-avg" class="font-mono text-3xl text-ink">0</span>
        <span class="text-[13px] text-ink-subtle">Average</span>
      </div>
      <div class="panel flex flex-col items-center gap-1 p-4">
        <span id="dr-min" class="font-mono text-3xl text-ink">0</span>
        <span class="text-[13px] text-ink-subtle">Lowest</span>
      </div>
      <div class="panel flex flex-col items-center gap-1 p-4">
        <span id="dr-max" class="font-mono text-3xl text-ink">0</span>
        <span class="text-[13px] text-ink-subtle">Highest</span>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <span class="text-sm text-ink-subtle">Roll history</span>
      <div id="dr-history" class="flex min-h-[2.5rem] flex-col gap-1 font-mono text-[13px] text-ink-tertiary"></div>
    </div>
  </div>

  <style is:global>
    /* These classes are applied to elements injected via innerHTML in client JS,
       which don't receive Astro's scope attribute — so the styles must be global.
       All selectors are `dr-`-prefixed to avoid leaking into other components. */
    /* --- 3D rolling cube (D6) --- */
    .dr-scene {
      position: relative;
      width: 4rem;
      height: 4rem;
      perspective: 600px;
    }
    /* soft ground shadow so the die reads as sitting on a surface */
    .dr-scene::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -0.5rem;
      width: 3.6rem;
      height: 0.75rem;
      transform: translateX(-50%);
      background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.6), transparent 72%);
      filter: blur(2px);
      z-index: -1;
      pointer-events: none;
    }
    .dr-cube {
      position: relative;
      width: 4rem;
      height: 4rem;
      transform-style: preserve-3d;
      transform: rotateX(-24deg) rotateY(24deg);
      transition: transform 1.1s cubic-bezier(0.2, 0.9, 0.25, 1);
    }
    .dr-cube.dr-instant { transition: none; }
    .dr-face {
      position: absolute;
      width: 4rem;
      height: 4rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      place-items: center;
      gap: 0.125rem;
      padding: 0.5rem;
      border-radius: 0.6rem;
      background: linear-gradient(150deg, #e5484d 0%, #c0343a 55%, #8f2025 100%);
      border: 1px solid #7a1519;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.18),
        inset 0 -7px 14px rgba(0, 0, 0, 0.4);
    }
    /* pips read as engraved dots */
    .dr-pip {
      box-shadow:
        inset 0 -1px 1px rgba(0, 0, 0, 0.45),
        0 1px 1px rgba(0, 0, 0, 0.55);
    }
    /* lavender energy while the cube is spinning (accent, used sparingly) */
    .dr-cube.dr-active .dr-face {
      border-color: rgba(94, 106, 210, 0.55);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.07),
        inset 0 -7px 14px rgba(0, 0, 0, 0.5),
        0 0 12px rgba(94, 106, 210, 0.5);
    }
    /* half of 4rem = 2rem push outward */
    .dr-f-front  { transform: translateZ(2rem); }
    .dr-f-back   { transform: rotateY(180deg) translateZ(2rem); }
    .dr-f-right  { transform: rotateY(90deg)  translateZ(2rem); }
    .dr-f-left   { transform: rotateY(-90deg) translateZ(2rem); }
    .dr-f-top    { transform: rotateX(90deg)  translateZ(2rem); }
    .dr-f-bottom { transform: rotateX(-90deg) translateZ(2rem); }

    /* --- flat tumble for polyhedral / custom number dice --- */
    @keyframes dr-tumble {
      0%   { transform: translateY(0)    rotate(0deg)   scale(1);    }
      20%  { transform: translateY(-4px) rotate(-14deg) scale(1.08); }
      40%  { transform: translateY(2px)  rotate(11deg)  scale(0.95); }
      60%  { transform: translateY(-3px) rotate(-7deg)  scale(1.05); }
      80%  { transform: translateY(1px)  rotate(5deg)   scale(0.98); }
      100% { transform: translateY(0)    rotate(0deg)   scale(1);    }
    }
    .dr-rolling { animation: dr-tumble 0.32s ease-in-out infinite; }

    @media (prefers-reduced-motion: reduce) {
      .dr-rolling { animation: none; }
      .dr-cube { transition: none; }
    }
  </style>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free dice roller rolls standard six-sided dice with real pip faces, plus
      any polyhedral die from D4 to D100 and fully custom-sided dice — enough for
      any board game or tabletop RPG when the physical dice have gone missing. Roll
      up to 100 at once with an optional modifier, and read the total, average,
      lowest and highest across every die as you go. A running roll history keeps
      your last results in view.
    </p>
    <p>
      Each die uses your browser's secure random source with rejection sampling, so
      results are genuinely uniform and unbiased — no modulo skew toward low
      numbers.
    </p>
  </div>
</ToolLayout>

<script>
  import { randInt } from '../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const typeSel = $('dr-type') as HTMLSelectElement;
  const sidesWrap = $('dr-sides-wrap')!;
  const sidesInput = $('dr-sides') as HTMLInputElement;
  const diceEl = $('dr-dice')!;
  const historyEl = $('dr-history')!;
  const history: string[] = [];

  const PIPS: Record<number, number[]> = {
    1: [5], 2: [1, 9], 3: [1, 5, 9], 4: [1, 3, 7, 9], 5: [1, 3, 5, 7, 9], 6: [1, 3, 4, 6, 7, 9],
  };

  const OUTER_NUM = 'flex h-16 min-w-16 items-center justify-center rounded-lg border border-hairline bg-surface-2 px-2 font-mono text-2xl text-ink';

  // Cube rotation (deg) that brings each value's face toward the viewer.
  // Faces: front=1, back=6, right=3, left=4, top=2, bottom=5 (opposites sum to 7).
  const FACE_SHOW: Record<number, [number, number]> = {
    1: [0, 0], 2: [-90, 0], 3: [0, -90], 4: [0, 90], 5: [90, 0], 6: [0, 180],
  };

  function pips(v: number): string {
    const on = new Set(PIPS[v] || []);
    return Array.from({ length: 9 }, (_, i) =>
      `<span class="h-2 w-2 rounded-full ${on.has(i + 1) ? 'bg-ink dr-pip' : ''}"></span>`
    ).join('');
  }

  function cubeHtml(): string {
    const face = (cls: string, n: number) =>
      `<div class="dr-face ${cls} border border-hairline bg-surface-2">${pips(n)}</div>`;
    return `<div class="dr-scene"><div class="dr-cube">` +
      face('dr-f-front', 1) + face('dr-f-back', 6) +
      face('dr-f-right', 3) + face('dr-f-left', 4) +
      face('dr-f-top', 2) + face('dr-f-bottom', 5) +
      `</div></div>`;
  }

  function sides(): number {
    const raw = typeSel.value === 'custom' ? Number(sidesInput.value) : Number(typeSel.value);
    return Math.max(2, Math.min(100000, Math.floor(raw) || 6));
  }

  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  let animTimer = 0;

  // --- Synthesized dice-clatter sound (no audio assets) ---
  let audioCtx: AudioContext | null = null;
  let soundOn = true;

  function playRoll(count: number): void {
    if (!soundOn) return;
    try {
      audioCtx ||= new (window.AudioContext || (window as any).webkitAudioContext)();
      const ctx = audioCtx;
      if (ctx.state === 'suspended') ctx.resume();

      // A handful of short filtered-noise "clicks" per die, scattered in time,
      // to mimic a die tumbling and knocking against a surface.
      const hits = Math.min(14, 4 + count * 2);
      for (let i = 0; i < hits; i++) {
        const t = ctx.currentTime + Math.random() * 0.6;
        const dur = 0.04 + Math.random() * 0.05;

        const buf = ctx.createBuffer(1, Math.ceil(ctx.sampleRate * dur), ctx.sampleRate);
        const data = buf.getChannelData(0);
        for (let j = 0; j < data.length; j++) {
          data[j] = (Math.random() * 2 - 1) * (1 - j / data.length); // decaying noise
        }
        const src = ctx.createBufferSource();
        src.buffer = buf;

        const bp = ctx.createBiquadFilter();
        bp.type = 'bandpass';
        bp.frequency.value = 1400 + Math.random() * 2600;
        bp.Q.value = 0.8;

        const gain = ctx.createGain();
        gain.gain.value = 0.16 + Math.random() * 0.12;

        src.connect(bp).connect(gain).connect(ctx.destination);
        src.start(t);
        src.stop(t + dur);
      }
    } catch { /* Web Audio unavailable — silently skip */ }
  }

  // --- D6: real 3D cubes, spun to their landed face via CSS transition ---
  function renderCubes(vals: number[], animate: boolean): void {
    diceEl.innerHTML = vals.map(cubeHtml).join('');
    const cubes = Array.from(diceEl.querySelectorAll('.dr-cube')) as HTMLElement[];
    cubes.forEach((cube, i) => {
      const [rx, ry] = FACE_SHOW[vals[i]];
      (cube.parentElement as HTMLElement).title = String(vals[i]);

      if (!animate || reduceMotion) {
        cube.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg)`;
        return;
      }
      // Snap to a start pose, then transition to the target + several whole spins.
      cube.classList.add('dr-instant');
      cube.style.transform = 'rotateX(-24deg) rotateY(24deg)';
      void cube.offsetWidth; // force reflow so the next change animates
      cube.classList.remove('dr-instant');
      cube.classList.add('dr-active');
      const spinX = 360 * (2 + (i % 2));
      const spinY = 360 * (3 + (i % 3));
      cube.style.transform = `rotateX(${rx + spinX}deg) rotateY(${ry + spinY}deg)`;
      const clearGlow = () => cube.classList.remove('dr-active');
      cube.addEventListener('transitionend', clearGlow, { once: true });
    });
  }

  // --- Polyhedral / custom: flat number tiles ---
  function renderNumbers(vals: number[], rolling: boolean): void {
    const cls = rolling && !reduceMotion ? `${OUTER_NUM} dr-rolling` : OUTER_NUM;
    diceEl.innerHTML = vals
      .map((r) => `<div class="${cls}" title="${r}">${r}</div>`)
      .join('');
  }

  function updateNumberFaces(vals: number[]): void {
    const nodes = diceEl.children;
    for (let i = 0; i < vals.length && i < nodes.length; i++) {
      const el = nodes[i] as HTMLElement;
      el.textContent = String(vals[i]);
      el.title = String(vals[i]);
    }
  }

  function updateStats(rolls: number[], s: number, mod: number): void {
    const sum = rolls.reduce((a, b) => a + b, 0);
    const total = sum + mod;
    $('dr-total').textContent = String(total);
    $('dr-avg').textContent = (sum / rolls.length).toFixed(2);
    $('dr-min').textContent = String(Math.min(...rolls));
    $('dr-max').textContent = String(Math.max(...rolls));

    const modStr = mod ? ` ${mod > 0 ? '+' : '−'} ${Math.abs(mod)}` : '';
    history.unshift(`${rolls.length}d${s}${modStr} → [${rolls.join(', ')}]${mod ? ` = ${total}` : ''}`);
    history.splice(20);
    historyEl.innerHTML = history.map((h) => `<div>${h}</div>`).join('');
  }

  function roll(animate = false) {
    const s = sides();
    const count = Math.max(1, Math.min(100, Math.floor(Number(($('dr-count') as HTMLInputElement).value)) || 1));
    const mod = Math.floor(Number(($('dr-mod') as HTMLInputElement).value)) || 0;

    const rolls: number[] = [];
    for (let i = 0; i < count; i++) rolls.push(randInt(1, s));

    clearInterval(animTimer);
    if (animate && !reduceMotion) playRoll(count);

    // D6 uses real 3D cubes that spin to their landed face.
    if (s === 6) {
      renderCubes(rolls, animate);
      updateStats(rolls, s, mod);
      return;
    }

    // Polyhedral / custom: instant, or shake-and-cycle then settle.
    if (!animate || reduceMotion) {
      renderNumbers(rolls, false);
      updateStats(rolls, s, mod);
      return;
    }

    renderNumbers(rolls, true);
    const start = performance.now();
    animTimer = window.setInterval(() => {
      if (performance.now() - start >= 650) {
        clearInterval(animTimer);
        renderNumbers(rolls, false);
        updateStats(rolls, s, mod);
        return;
      }
      updateNumberFaces(rolls.map(() => randInt(1, s)));
    }, 80);
  }

  typeSel.addEventListener('change', () => {
    const custom = typeSel.value === 'custom';
    sidesWrap.classList.toggle('hidden', !custom);
    sidesWrap.classList.toggle('flex', custom);
    roll();
  });
  ['dr-sides', 'dr-count', 'dr-mod'].forEach((id) => $(id).addEventListener('input', () => roll()));
  $('dr-roll').addEventListener('click', () => roll(true));

  const soundBtn = $('dr-sound');
  soundBtn.addEventListener('click', () => {
    soundOn = !soundOn;
    soundBtn.textContent = soundOn ? '🔊' : '🔇';
    soundBtn.setAttribute('aria-pressed', String(soundOn));
  });
  $('dr-clear').addEventListener('click', () => {
    clearInterval(animTimer);
    history.length = 0;
    historyEl.innerHTML = '';
    diceEl.innerHTML = '';
    ['dr-total', 'dr-min', 'dr-max'].forEach((id) => ($(id).textContent = '0'));
    $('dr-avg').textContent = '0';
  });
  roll();
</script>

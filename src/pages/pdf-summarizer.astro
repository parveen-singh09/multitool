?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="pdf-summarizer">
  <div class="flex flex-col gap-4">
    <label id="ps-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose a PDF or drop it here</span>
      <input id="ps-file" type="file" accept="application/pdf" class="sr-only" />
    </label>

    <div id="ps-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Length
          <select id="ps-length" class="field w-40">
            <option value="short">Short (2-3 sentences)</option>
            <option value="medium" selected>Paragraph</option>
            <option value="detailed">Bullet points</option>
          </select>
        </label>
        <button id="ps-run" class="btn btn-primary">Summarize</button>
        <span id="ps-status" class="text-[13px] text-ink-subtle" aria-live="polite"></span>
      </div>
      <p class="text-[13px] text-ink-tertiary">
        Unlike our other tools, this one sends the PDF’s extracted <em>text</em> to
        an AI model to be summarized.
        Don’t summarize confidential documents you wouldn’t share.
      </p>
      <div id="ps-out-wrap" class="copy-wrap" style="display:none">
        <div id="ps-out" class="panel min-h-24 whitespace-pre-wrap p-4 pr-12 text-[15px] leading-relaxed text-ink"></div>
        <button type="button" class="copy-icon" data-copy-target="#ps-out" aria-label="Copy"></button>
      </div>
    </div>
    <p id="ps-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PDF summarizer reads the text out of a PDF and condenses it into a
      short recap — pick a two-to-three sentence summary, a single paragraph, or a
      set of bullet points covering the key sections. The PDF is opened and its
      text extracted entirely in your browser using the same engine as our PDF to
      Text tool.
    </p>
    <p>
      Summarizing needs an AI model, so this is the one tool on the site that
      isn’t fully offline: the extracted <strong>text</strong> is sent directly
      from your browser to the AI service to be summarized and the result sent
      back. Only the text it contains is sent,
      and only when you click Summarize. Because the text leaves your device,
      avoid summarizing confidential or sensitive documents here. Scanned
      image-only PDFs have no text to read; run them through our PDF to Text
      (OCR) tool first.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import * as pdfjsLib from 'pdfjs-dist';
  import workerUrl from 'pdfjs-dist/build/pdf.worker.min.mjs?url';
  import { aiChat } from '../lib/ai';
  pdfjsLib.GlobalWorkerOptions.workerSrc = workerUrl;

  const MAX_CHARS = 100_000;

  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('ps-file') as HTMLInputElement;
  const drop = $('ps-drop');
  const panel = $('ps-panel');
  const out = $('ps-out');
  const outWrap = $('ps-out-wrap');
  const status = $('ps-status');
  const err = $('ps-error');
  const runBtn = $('ps-run') as HTMLButtonElement;

  let bytes: ArrayBuffer | null = null;
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  function load(file: File) {
    setErr('');
    file.arrayBuffer().then((b) => {
      bytes = b;
      panel.classList.remove('hidden'); panel.classList.add('flex');
      status.textContent = `${file.name} ready.`;
      outWrap.style.display = 'none'; out.textContent = '';
    });
  }

  async function extractText(): Promise<string> {
    const pdf = await pdfjsLib.getDocument({ data: bytes!.slice(0) }).promise;
    let text = '';
    for (let n = 1; n <= pdf.numPages; n++) {
      status.textContent = `Reading page ${n} / ${pdf.numPages}…`;
      const page = await pdf.getPage(n);
      const content = await page.getTextContent();
      text += (content.items as any[]).map((it) => it.str).join(' ') + '\n\n';
      if (text.length > MAX_CHARS) break;
    }
    return text.trim();
  }

  async function run() {
    if (!bytes) return;
    setErr(''); runBtn.disabled = true;
    try {
      let text = await extractText();
      if (text.replace(/\s/g, '').length < 20) {
        setErr('No readable text found. If this is a scanned PDF, run it through PDF to Text (OCR) first.');
        status.textContent = '';
        return;
      }
      let truncated = false;
      if (text.length > MAX_CHARS) { text = text.slice(0, MAX_CHARS); truncated = true; }

      status.textContent = 'Summarizing…';
      const lenVal = ($('ps-length') as HTMLSelectElement).value;
      const targets: Record<string, string> = {
        short: 'in 2-3 sentences',
        medium: 'in one concise paragraph',
        detailed: 'as 5-8 bullet points covering the key sections',
      };
      const target = targets[lenVal] ?? targets.medium;
      const prompt =
        `Summarize the following document ${target}. ` +
        `Be faithful to the source; do not add information that isn't in the text. ` +
        `Reply with only the summary, no preamble.\n\n<document>\n${text}\n</document>`;
      let summary: string;
      try {
        summary = await aiChat([{ role: 'user', content: prompt }], { temperature: 0.3 });
      } catch (e) {
        setErr(`Could not summarize: ${(e as Error).message}`);
        status.textContent = '';
        return;
      }
      out.textContent = summary;
      outWrap.style.display = 'block';
      status.textContent = truncated
        ? 'Done — summarized the first part of a long document.'
        : 'Done.';
    } catch (e) {
      setErr('Could not read this PDF: ' + (e as Error).message);
      status.textContent = '';
    } finally { runBtn.disabled = false; }
  }

  fileInput.addEventListener('change', () => fileInput.files?.[0] && load(fileInput.files[0]));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) load(f); });
  runBtn.addEventListener('click', run);
</script>

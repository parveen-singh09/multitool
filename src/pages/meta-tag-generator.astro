---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="meta-tag-generator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">

    <div class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Page title
        <input id="mt-title" class="field" value="My Awesome Page" />
        <span id="mt-title-c" class="self-end text-xs"></span>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Description
        <textarea id="mt-desc" class="field min-h-20 resize-y">A short, compelling description of the page for search results.</textarea>
        <span id="mt-desc-c" class="self-end text-xs"></span>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Keywords (comma-separated)
        <input id="mt-keywords" class="field" value="tools, online, free" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Author
          <input id="mt-author" class="field" placeholder="Your name" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Language
          <input id="mt-lang" class="field" value="en" placeholder="en" />
        </label>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Canonical URL
        <input id="mt-url" class="field" placeholder="https://example.com/page" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Robots
          <select id="mt-robots" class="field"><option value="index, follow">index, follow</option><option value="noindex, follow">noindex, follow</option><option value="index, nofollow">index, nofollow</option><option value="noindex, nofollow">noindex, nofollow</option></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Theme color
          <input id="mt-theme" type="color" value="#5e6ad2" class="field h-10 cursor-pointer p-1" />
        </label>
      </div>

      <details class="rounded-lg border border-hairline bg-surface-2 p-3" open>
        <summary class="cursor-pointer text-sm text-ink">Social sharing (Open Graph + Twitter)</summary>
        <div class="mt-3 flex flex-col gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Image URL
            <input id="mt-image" class="field" placeholder="https://example.com/preview.png" />
          </label>
          <div class="grid grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">OG type
              <select id="mt-ogtype" class="field"><option>website</option><option>article</option><option>product</option><option>profile</option><option>video.other</option></select>
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Twitter card
              <select id="mt-twcard" class="field"><option value="summary_large_image">summary_large_image</option><option value="summary">summary</option></select>
            </label>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Site name
              <input id="mt-sitename" class="field" placeholder="My Site" />
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Twitter @handle
              <input id="mt-twsite" class="field" placeholder="@handle" />
            </label>
          </div>
        </div>
      </details>
    </div>

    <div class="flex flex-col gap-4">
      <div class="flex flex-col gap-2">
        <span class="text-sm text-ink-subtle">Google result preview</span>
        <div class="rounded-lg border border-hairline bg-surface-2 p-4">
          <div id="pv-url" class="truncate text-[13px] text-ink-subtle"></div>
          <div id="pv-title" class="text-[18px] leading-tight text-[#8ab4f8]"></div>
          <div id="pv-desc" class="mt-0.5 text-[13px] leading-snug text-ink-subtle"></div>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <span class="text-sm text-ink-subtle">Social card preview</span>
        <div class="overflow-hidden rounded-lg border border-hairline bg-surface-2">
          <div id="pv-img" class="aspect-[1.91/1] w-full bg-surface-3 bg-cover bg-center"></div>
          <div class="flex flex-col gap-0.5 border-t border-hairline p-3">
            <div id="pv-og-domain" class="text-xs uppercase text-ink-subtle"></div>
            <div id="pv-og-title" class="truncate text-sm text-ink"></div>
            <div id="pv-og-desc" class="truncate text-xs text-ink-subtle"></div>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm text-ink-subtle">Generated meta tags</label>
        <div class="copy-wrap">
          <pre class="hl-block field min-h-48" style="resize:vertical;overflow:auto"><code id="mt-out" class="hljs" style="background:transparent;padding:0"></code></pre>
          <button type="button" class="copy-icon" data-copy-target="#mt-out" aria-label="Copy"></button>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free meta tag generator builds every tag a page needs to rank and
      share well — title, description, keywords, author, canonical URL, language,
      robots and theme color, plus a full set of Open Graph and Twitter Card tags
      for rich link previews on Facebook, LinkedIn, X and Slack. Paste the result
      straight into your HTML <code class="font-mono text-ink">&lt;head&gt;</code>.
    </p>
    <p>
      As you type, the live Google result preview and social card preview show
      exactly how your page will look in search and when shared. The character
      counters flag when your title or description runs past the length Google
      typically displays (about 60 and 160 characters), so you can trim before
      it gets truncated. Everything is generated in your browser — nothing is
      sent anywhere.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl } from '../lib/highlight';

  const $ = (id: string) => document.getElementById(id)!;
  const val = (id: string) => ($(id) as HTMLInputElement).value.trim();
  const out = $('mt-out') as HTMLElement;
  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  let rawOutput = '';

  function counter(id: string, span: string, ideal: number, max: number) {
    const el = $(span);
    const n = val(id).length;
    el.textContent = `${n} chars${n > max ? ' — too long' : n < ideal ? ' — could be longer' : ' — good'}`;
    el.style.color = n > max ? '#e5a04c' : n >= ideal ? '#4caf7d' : 'var(--ink-subtle, #8a8f98)';
  }

  function build() {
    const title = val('mt-title'), desc = val('mt-desc'), kw = val('mt-keywords');
    const author = val('mt-author'), lang = val('mt-lang'), url = val('mt-url');
    const robots = ($('mt-robots') as HTMLSelectElement).value;
    const theme = val('mt-theme');
    const image = val('mt-image'), ogType = val('mt-ogtype'), twCard = val('mt-twcard');
    const siteName = val('mt-sitename'), twSite = val('mt-twsite');

    const L: string[] = [];
    L.push('<meta charset="UTF-8">');
    L.push('<meta name="viewport" content="width=device-width, initial-scale=1.0">');
    if (title) L.push(`<title>${esc(title)}</title>`);
    if (desc) L.push(`<meta name="description" content="${esc(desc)}">`);
    if (kw) L.push(`<meta name="keywords" content="${esc(kw)}">`);
    if (author) L.push(`<meta name="author" content="${esc(author)}">`);
    if (robots) L.push(`<meta name="robots" content="${robots}">`);
    if (url) L.push(`<link rel="canonical" href="${esc(url)}">`);
    if (theme) L.push(`<meta name="theme-color" content="${esc(theme)}">`);

    // Open Graph
    const og: string[] = [];
    if (title) og.push(`<meta property="og:title" content="${esc(title)}">`);
    if (desc) og.push(`<meta property="og:description" content="${esc(desc)}">`);
    og.push(`<meta property="og:type" content="${esc(ogType || 'website')}">`);
    if (url) og.push(`<meta property="og:url" content="${esc(url)}">`);
    if (image) og.push(`<meta property="og:image" content="${esc(image)}">`);
    if (siteName) og.push(`<meta property="og:site_name" content="${esc(siteName)}">`);
    if (lang) og.push(`<meta property="og:locale" content="${esc(lang)}">`);

    // Twitter
    const tw: string[] = [];
    tw.push(`<meta name="twitter:card" content="${esc(twCard || 'summary_large_image')}">`);
    if (twSite) tw.push(`<meta name="twitter:site" content="${esc(twSite)}">`);
    if (title) tw.push(`<meta name="twitter:title" content="${esc(title)}">`);
    if (desc) tw.push(`<meta name="twitter:description" content="${esc(desc)}">`);
    if (image) tw.push(`<meta name="twitter:image" content="${esc(image)}">`);

    rawOutput = [...L, '', '', ...og, '', '', ...tw].join('\n');
    hl(out, rawOutput, 'html');

    // Previews
    let host = 'example.com', path = '';
    try { const u = new URL(url); host = u.hostname; path = u.pathname === '/' ? '' : u.pathname; } catch {}
    $('pv-url').textContent = `${host}${path ? ' › ' + path.split('/').filter(Boolean).join(' › ') : ''}`;
    $('pv-title').textContent = title || 'Page title';
    $('pv-desc').textContent = desc || 'Your page description will appear here.';
    $('pv-og-domain').textContent = host;
    $('pv-og-title').textContent = title || 'Page title';
    $('pv-og-desc').textContent = desc || 'Page description';
    ($('pv-img') as HTMLElement).style.backgroundImage = image ? `url("${image.replace(/"/g, '')}")` : '';

    counter('mt-title', 'mt-title-c', 30, 60);
    counter('mt-desc', 'mt-desc-c', 70, 160);
  }

  ['mt-title','mt-desc','mt-keywords','mt-author','mt-lang','mt-url','mt-robots','mt-theme','mt-image','mt-ogtype','mt-twcard','mt-sitename','mt-twsite']
    .forEach((id) => $(id).addEventListener('input', build));

  build();
</script>

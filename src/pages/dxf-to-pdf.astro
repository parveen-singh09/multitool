---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="dxf-to-pdf">
  <ArchiveConvert slug="dxf-to-pdf" from="dxf" to="pdf" noun="CAD file" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free DXF to PDF converter exports DXF drawings to PDF for sharing and printing without CAD software.
    </p>
    <p>
      DWG, DXF and DWF are proprietary CAD formats no browser can read on its own,
      so conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

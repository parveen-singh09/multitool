---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="mobi-to-azw3">
  <ArchiveConvert slug="mobi-to-azw3" from="mobi" to="azw3" noun="ebook" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free MOBI to AZW3 converter converts older Kindle MOBI ebooks to the newer AZW3 format.
    </p>
    <p>
      Conversion is handled on our servers, because these
      ebook formats can't be read reliably in a browser. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

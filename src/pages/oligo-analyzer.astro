---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="oligo-analyzer">
  <div class="flex flex-col gap-6">
    <!-- Sequence input -->
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
      <label class="flex flex-1 flex-col gap-1 text-sm text-ink-subtle">Oligo sequence (5′ → 3′)
        <textarea id="ol-in" class="field min-h-20 resize-y font-mono text-sm tracking-wider" placeholder="e.g. GTAAAACGACGGCCAGT" spellcheck="false"></textarea>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Type
        <select id="ol-type" class="field w-28">
          <option value="dna">DNA</option>
          <option value="rna">RNA</option>
        </select>
      </label>
    </div>

    <!-- Reaction conditions -->
    <div class="panel p-4">
      <div class="eyebrow mb-3">Reaction conditions</div>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        <label class="flex flex-col gap-1 text-xs text-ink-subtle">Oligo conc. (nM)
          <input id="ol-conc" type="number" min="1" step="1" value="250" class="field text-sm" />
        </label>
        <label class="flex flex-col gap-1 text-xs text-ink-subtle">Na⁺ / K⁺ (mM)
          <input id="ol-na" type="number" min="0" step="1" value="50" class="field text-sm" />
        </label>
        <label class="flex flex-col gap-1 text-xs text-ink-subtle">Mg²⁺ (mM)
          <input id="ol-mg" type="number" min="0" step="0.1" value="0" class="field text-sm" />
        </label>
        <label class="flex flex-col gap-1 text-xs text-ink-subtle">dNTPs (mM)
          <input id="ol-dntp" type="number" min="0" step="0.1" value="0" class="field text-sm" />
        </label>
      </div>
    </div>

    <div id="ol-status" class="hidden rounded-md border px-3 py-2 text-sm"></div>

    <!-- Metric tiles -->
    <div id="ol-grid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"></div>

    <div id="ol-extra" class="hidden flex-col gap-4">
      <!-- Thermodynamics detail -->
      <div class="panel p-4">
        <div class="eyebrow mb-3">Melting temperature &amp; thermodynamics</div>
        <div id="ol-tm" class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-3"></div>
        <p class="mt-3 text-xs text-ink-tertiary">Nearest-neighbor T<sub>m</sub> uses SantaLucia (1998) unified parameters with Owczarzy monovalent/divalent salt corrections — the same model as commercial oligo tools. Wallace and GC-rule are shown for reference.</p>
      </div>

      <!-- Base composition -->
      <div class="panel p-4">
        <div class="eyebrow mb-3">Base composition</div>
        <div id="ol-comp" class="flex flex-col gap-2"></div>
      </div>

      <!-- Complement strands -->
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="panel p-4">
          <div class="eyebrow">Reverse complement (5′ → 3′)</div>
          <div class="copy-wrap">
            <p id="ol-revcomp" class="mt-2 break-all font-mono text-sm tracking-wider text-ink"></p>
            <button type="button" class="copy-icon" data-copy-target="#ol-revcomp" aria-label="Copy"></button>
          </div>
        </div>
        <div class="panel p-4">
          <div class="eyebrow">Complement (3′ → 5′)</div>
          <div class="copy-wrap">
            <p id="ol-comp-seq" class="mt-2 break-all font-mono text-sm tracking-wider text-ink"></p>
            <button type="button" class="copy-icon" data-copy-target="#ol-comp-seq" aria-label="Copy"></button>
          </div>
        </div>
      </div>

      <!-- Secondary structure -->
      <div class="panel p-4">
        <div class="eyebrow mb-3">Secondary structure</div>
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-ink">Hairpin</span>
              <span id="ol-hp-dg" class="rounded-full bg-surface-3 px-2 py-0.5 text-xs text-ink-subtle"></span>
            </div>
            <pre id="ol-hp" class="overflow-x-auto rounded-lg border border-hairline bg-surface-2 p-3 font-mono text-xs leading-relaxed text-ink"></pre>
          </div>
          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-ink">Self-dimer</span>
              <span id="ol-sd-dg" class="rounded-full bg-surface-3 px-2 py-0.5 text-xs text-ink-subtle"></span>
            </div>
            <pre id="ol-sd" class="overflow-x-auto rounded-lg border border-hairline bg-surface-2 p-3 font-mono text-xs leading-relaxed text-ink"></pre>
          </div>
        </div>
        <p class="mt-3 text-xs text-ink-tertiary">More-negative ΔG means a more stable, more troublesome structure. Rule of thumb: primer self-structures below about −9 kcal/mol (hairpin) or −6 kcal/mol (dimer) near the annealing temperature can hurt a PCR.</p>
      </div>

      <!-- Hetero-dimer (second sequence) — beats the single-sequence free tools -->
      <div class="panel p-4">
        <div class="eyebrow mb-3">Hetero-dimer with a second oligo</div>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Second sequence (5′ → 3′) — e.g. your reverse primer
          <textarea id="ol-in2" class="field min-h-16 resize-y font-mono text-sm tracking-wider" placeholder="paste a second oligo to check cross-dimers" spellcheck="false"></textarea>
        </label>
        <div id="ol-hd-wrap" class="mt-3 hidden flex-col gap-2">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-ink">Best cross-dimer</span>
            <span id="ol-hd-dg" class="rounded-full bg-surface-3 px-2 py-0.5 text-xs text-ink-subtle"></span>
          </div>
          <pre id="ol-hd" class="overflow-x-auto rounded-lg border border-hairline bg-surface-2 p-3 font-mono text-xs leading-relaxed text-ink"></pre>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free oligo analyzer computes the properties that matter for PCR primer
      and probe design: length, GC content, melting temperature (T<sub>m</sub>),
      molecular weight, extinction coefficient, µg/OD and nmol/OD, base
      composition, and both complement strands. Paste a sequence 5′→3′ and it
      recalculates instantly — nothing leaves your browser.
    </p>
    <p>
      The T<sub>m</sub> uses full <strong>nearest-neighbor thermodynamics</strong>
      (SantaLucia 1998 unified parameters) with <strong>Owczarzy salt
      corrections</strong> for monovalent (Na⁺/K⁺) and divalent (Mg²⁺) cations,
      accounting for dNTP chelation of magnesium — the same model as IDT
      OligoAnalyzer and Eurofins. Set your actual oligo concentration and buffer
      to get a T<sub>m</sub> that matches your bench conditions, plus ΔH, ΔS and
      ΔG at 37 °C.
    </p>
    <p>
      It also flags <strong>secondary structures</strong> that free tools often
      hide behind a login: the most stable hairpin, self-dimer, and — paste a
      second oligo — the cross/hetero-dimer between a primer pair, each drawn as
      a base-paired alignment with an estimated ΔG.
    </p>
  </div>
</ToolLayout>

<script>
  import {
    clean, validate, counts, gcFraction, complement, reverseComplement,
    molecularWeight, extinctionCoefficient, meltingTemp, selfDimer, heteroDimer,
    hairpin, DEFAULT_CONDITIONS,
    type SeqType, type Conditions, type Alignment,
  } from '../lib/oligo';

  const $ = (id: string) => document.getElementById(id)!;
  const input = $('ol-in') as HTMLTextAreaElement;
  const input2 = $('ol-in2') as HTMLTextAreaElement;
  const typeEl = $('ol-type') as HTMLSelectElement;
  const concEl = $('ol-conc') as HTMLInputElement;
  const naEl = $('ol-na') as HTMLInputElement;
  const mgEl = $('ol-mg') as HTMLInputElement;
  const dntpEl = $('ol-dntp') as HTMLInputElement;
  const status = $('ol-status');
  const grid = $('ol-grid');
  const extra = $('ol-extra');

  function showStatus(msg: string) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = '#d14d4d';
    status.style.color = '#e08585';
  }

  function tile(label: string, value: string, sub = ''): string {
    return `<div class="panel panel-lift flex flex-col gap-1 p-4">
      <span class="text-xs text-ink-tertiary">${label}</span>
      <span class="font-display text-2xl font-semibold text-ink">${value}</span>
      ${sub ? `<span class="text-xs text-ink-tertiary">${sub}</span>` : ''}
    </div>`;
  }

  function bar(base: string, count: number, total: number, color: string): string {
    const pct = total ? (count / total) * 100 : 0;
    return `<div class="flex items-center gap-3">
      <span class="w-6 font-mono text-ink">${base}</span>
      <div class="h-2 flex-1 overflow-hidden rounded-full bg-surface-3">
        <div class="h-full rounded-full" style="width:${pct}%;background:${color}"></div>
      </div>
      <span class="w-24 text-right text-[13px] text-ink-subtle">${count} · ${pct.toFixed(0)}%</span>
    </div>`;
  }

  function tmRow(label: string, value: string, hint = ''): string {
    return `<div class="flex flex-col gap-0.5 rounded-lg bg-surface-2 p-3">
      <span class="text-xs text-ink-tertiary">${label}</span>
      <span class="font-mono text-lg text-ink">${value}</span>
      ${hint ? `<span class="text-[11px] text-ink-tertiary">${hint}</span>` : ''}
    </div>`;
  }

  function renderAlignment(a: Alignment): string {
    const esc = (s: string) => s.replace(/</g, '&lt;');
    return `5'-${esc(a.top)}-3'\n   ${esc(a.pair)}\n3'-${esc(a.bot)}-5'`;
  }

  function conditions(): Conditions {
    return {
      oligoNM: Math.max(0.01, Number(concEl.value) || DEFAULT_CONDITIONS.oligoNM),
      naMM: Math.max(0, Number(naEl.value) || 0),
      mgMM: Math.max(0, Number(mgEl.value) || 0),
      dntpMM: Math.max(0, Number(dntpEl.value) || 0),
    };
  }

  function analyze() {
    const type = typeEl.value as SeqType;
    const seq = clean(input.value);
    grid.innerHTML = '';
    extra.classList.add('hidden');
    extra.classList.remove('flex');

    if (!seq) { status.classList.add('hidden'); return; }

    const v = validate(seq, type);
    if (!v.ok) {
      const allowed = (type === 'rna' ? 'ACGU' : 'ACGT').split('').join(', ');
      showStatus(`Invalid character(s) for ${type.toUpperCase()}: ${v.bad.join(', ')}. Allowed bases: ${allowed}.`);
      return;
    }
    status.classList.add('hidden');

    const n = seq.length;
    const c = counts(seq);
    const cond = conditions();
    const gcPct = gcFraction(seq) * 100;
    const tm = meltingTemp(seq, type, cond);
    const mw = molecularWeight(seq, type);
    const ext = extinctionCoefficient(seq, type);
    const ugPerOD = ext ? (mw / ext) * 1e6 : 0;
    const nmolPerOD = ext ? (1 / ext) * 1e9 : 0;

    grid.innerHTML =
      tile('Length', `${n} nt`) +
      tile('GC content', `${gcPct.toFixed(1)}%`) +
      tile('Tm (nearest-neighbor)', isNaN(tm.nn) ? '—' : `${tm.nn.toFixed(1)} °C`, 'at your conditions') +
      tile('Molecular weight', mw.toFixed(1), 'g/mol (ss)') +
      tile('Ext. coefficient', `${(ext / 1000).toFixed(1)}k`, 'L/(mol·cm), 260 nm') +
      tile('µg / OD₂₆₀', ugPerOD.toFixed(1)) +
      tile('nmol / OD₂₆₀', nmolPerOD.toFixed(1)) +
      tile('ΔG 37°C', `${tm.dg37.toFixed(1)}`, 'kcal/mol');

    $('ol-tm').innerHTML =
      tmRow('Nearest-neighbor', isNaN(tm.nn) ? '—' : `${tm.nn.toFixed(1)} °C`, 'SantaLucia + Owczarzy salt') +
      tmRow('Wallace rule', `${tm.wallace.toFixed(0)} °C`, '2(A+T)+4(G+C)') +
      tmRow('GC rule', `${tm.gcRule.toFixed(1)} °C`, 'Marmur-Doty salt-adj.') +
      tmRow('ΔH', `${tm.dh.toFixed(1)}`, 'kcal/mol') +
      tmRow('ΔS', `${tm.ds.toFixed(1)}`, 'cal/(mol·K)') +
      tmRow('ΔG (37°C)', `${tm.dg37.toFixed(1)}`, 'kcal/mol');

    const colors: Record<string, string> = { A: '#5e6ad2', C: '#27a644', G: '#e0a055', T: '#d15b8f', U: '#d15b8f' };
    const bases = type === 'rna' ? ['A', 'C', 'G', 'U'] : ['A', 'C', 'G', 'T'];
    $('ol-comp').innerHTML = bases.map((b) => bar(b, c[b], n, colors[b])).join('');

    $('ol-revcomp').textContent = reverseComplement(seq, type);
    $('ol-comp-seq').textContent = complement(seq, type);

    const hp = hairpin(seq, type);
    if (hp) {
      $('ol-hp').textContent = hp.render.join('\n');
      $('ol-hp-dg').textContent = `ΔG ≈ ${hp.dg.toFixed(1)} kcal/mol · stem ${hp.stem} · loop ${hp.loop}`;
    } else {
      $('ol-hp').textContent = 'No significant hairpin found.';
      $('ol-hp-dg').textContent = '';
    }

    const sd = selfDimer(seq, type);
    if (sd) {
      $('ol-sd').textContent = renderAlignment(sd);
      $('ol-sd-dg').textContent = `ΔG ≈ ${sd.dg.toFixed(1)} kcal/mol · ${sd.matches} bp · run ${sd.runLen}`;
    } else {
      $('ol-sd').textContent = 'No significant self-dimer found.';
      $('ol-sd-dg').textContent = '';
    }

    const seq2 = clean(input2.value);
    const hdWrap = $('ol-hd-wrap');
    if (seq2 && validate(seq2, type).ok) {
      const hd = heteroDimer(seq, seq2, type);
      hdWrap.classList.remove('hidden');
      hdWrap.classList.add('flex');
      if (hd) {
        $('ol-hd').textContent = renderAlignment(hd);
        $('ol-hd-dg').textContent = `ΔG ≈ ${hd.dg.toFixed(1)} kcal/mol · ${hd.matches} bp · run ${hd.runLen}`;
      } else {
        $('ol-hd').textContent = 'No significant cross-dimer found.';
        $('ol-hd-dg').textContent = '';
      }
    } else {
      hdWrap.classList.add('hidden');
      hdWrap.classList.remove('flex');
    }

    extra.classList.remove('hidden');
    extra.classList.add('flex');
  }

  for (const el of [input, input2]) el.addEventListener('input', analyze);
  for (const el of [concEl, naEl, mgEl, dntpEl]) el.addEventListener('input', analyze);
  typeEl.addEventListener('change', analyze);

  input.value = 'GTAAAACGACGGCCAGT';
  analyze();
</script>

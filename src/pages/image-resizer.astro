?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="image-resizer">
  <div class="flex flex-col gap-4">
    <label id="ir-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an image or drop it here</span>
      <input id="ir-file" type="file" accept="image/*" class="sr-only" />
    </label>

    <div id="ir-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Width (px)<input id="ir-w" type="number" min="1" class="field w-28" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (px)<input id="ir-h" type="number" min="1" class="field w-28" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Scale (%)<input id="ir-pct" type="number" min="1" step="1" class="field w-24" /></label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="ir-lock" type="checkbox" checked class="accent-primary" /> Lock ratio</label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Format
          <select id="ir-fmt" class="field w-32"><option value="image/png">PNG</option><option value="image/jpeg">JPEG</option><option value="image/webp">WebP</option></select>
        </label>
        <button id="ir-download" class="btn btn-primary ml-auto">Download</button>
      </div>
      <div class="flex flex-col gap-3">
        <label class="flex items-center gap-3 text-sm text-ink-subtle">
          <span class="w-14 shrink-0">Width</span>
          <input id="ir-ws" type="range" min="1" class="ir-range flex-1" />
        </label>
        <label class="flex items-center gap-3 text-sm text-ink-subtle">
          <span class="w-14 shrink-0">Height</span>
          <input id="ir-hs" type="range" min="1" class="ir-range flex-1" />
        </label>
        <label class="flex items-center gap-3 text-sm text-ink-subtle">
          <span class="w-14 shrink-0">Scale</span>
          <input id="ir-ps" type="range" min="1" max="200" value="100" class="ir-range flex-1" />
        </label>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-[13px] text-ink-subtle">
        <span>Original: <span id="ir-orig" class="text-ink">—</span></span>
      </div>
      <div class="panel flex justify-center overflow-hidden p-4"><canvas id="ir-canvas" class="max-h-96 w-auto max-w-full rounded-md"></canvas></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free image resizer changes the dimensions of JPG, PNG and WebP images
      right in your browser. Lock the aspect ratio to avoid distortion, pick your
      output format, and download the resized file in a click.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .ir-range { -webkit-appearance:none; appearance:none; height:4px; border-radius:9999px; background:#23252a; cursor:pointer; }
  .ir-range::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:16px; height:16px; border-radius:9999px; background:#5e6ad2; border:none; cursor:pointer; }
  .ir-range::-moz-range-thumb { width:16px; height:16px; border-radius:9999px; background:#5e6ad2; border:none; cursor:pointer; }
  .ir-range:focus-visible { outline:2px solid rgba(94,105,209,0.5); outline-offset:2px; }
</style>

<script>
  const fileInput = document.getElementById('ir-file') as HTMLInputElement;
  const drop = document.getElementById('ir-drop')!;
  const panel = document.getElementById('ir-panel')!;
  const wEl = document.getElementById('ir-w') as HTMLInputElement;
  const hEl = document.getElementById('ir-h') as HTMLInputElement;
  const wSlider = document.getElementById('ir-ws') as HTMLInputElement;
  const hSlider = document.getElementById('ir-hs') as HTMLInputElement;
  const pctEl = document.getElementById('ir-pct') as HTMLInputElement;
  const pctSlider = document.getElementById('ir-ps') as HTMLInputElement;
  const lock = document.getElementById('ir-lock') as HTMLInputElement;
  const fmt = document.getElementById('ir-fmt') as HTMLSelectElement;
  const canvas = document.getElementById('ir-canvas') as HTMLCanvasElement;
  const orig = document.getElementById('ir-orig')!;

  let img = new Image();
  let natW = 0, natH = 0, ratio = 1;

  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => {
      img = new Image();
      img.onload = () => {
        natW = img.naturalWidth; natH = img.naturalHeight; ratio = natW / natH;
        const wMax = Math.max(natW * 2, natW), hMax = Math.max(natH * 2, natH);
        wSlider.max = String(wMax); hSlider.max = String(hMax);
        wEl.value = String(natW); hEl.value = String(natH);
        wSlider.value = String(natW); hSlider.value = String(natH);
        pctEl.value = '100'; pctSlider.value = '100';
        orig.textContent = `${natW} × ${natH}px`;
        panel.classList.remove('hidden');
        panel.classList.add('flex');
        redraw();
      };
      img.src = reader.result as string;
    };
    reader.readAsDataURL(file);
  }

  function redraw() {
    const w = Math.max(1, Number(wEl.value) || 1);
    const h = Math.max(1, Number(hEl.value) || 1);
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d')!;
    ctx.clearRect(0, 0, w, h);
    ctx.drawImage(img, 0, 0, w, h);
  }

  function syncPct() {
    if (!natW) return;
    const p = Math.round((Number(wEl.value) / natW) * 100);
    pctEl.value = String(p);
    pctSlider.value = String(Math.min(Number(pctSlider.max), Math.max(Number(pctSlider.min), p)));
  }

  function setWidth(w: number) {
    w = Math.max(1, Math.round(w));
    wEl.value = String(w); wSlider.value = String(w);
    if (lock.checked) {
      const h = Math.max(1, Math.round(w / ratio));
      hEl.value = String(h); hSlider.value = String(h);
    }
    syncPct();
    redraw();
  }

  function setHeight(h: number) {
    h = Math.max(1, Math.round(h));
    hEl.value = String(h); hSlider.value = String(h);
    if (lock.checked) {
      const w = Math.max(1, Math.round(h * ratio));
      wEl.value = String(w); wSlider.value = String(w);
    }
    syncPct();
    redraw();
  }

  function setPercent(p: number) {
    if (!natW) return;
    p = Math.max(1, p);
    pctEl.value = String(p);
    pctSlider.value = String(Math.min(Number(pctSlider.max), Math.max(Number(pctSlider.min), p)));
    const w = Math.max(1, Math.round((natW * p) / 100));
    const h = Math.max(1, Math.round((natH * p) / 100));
    wEl.value = String(w); wSlider.value = String(w);
    hEl.value = String(h); hSlider.value = String(h);
    redraw();
  }

  wEl.addEventListener('input', () => setWidth(Number(wEl.value)));
  hEl.addEventListener('input', () => setHeight(Number(hEl.value)));
  wSlider.addEventListener('input', () => setWidth(Number(wSlider.value)));
  hSlider.addEventListener('input', () => setHeight(Number(hSlider.value)));
  pctEl.addEventListener('input', () => setPercent(Number(pctEl.value)));
  pctSlider.addEventListener('input', () => setPercent(Number(pctSlider.value)));
  fmt.addEventListener('change', redraw);

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) loadFile(f); });

  document.getElementById('ir-download')!.addEventListener('click', () => {
    const ext = fmt.value.split('/')[1].replace('jpeg', 'jpg');
    const link = document.createElement('a');
    link.download = `resized-${canvas.width}x${canvas.height}.${ext}`;
    link.href = canvas.toDataURL(fmt.value, 0.92);
    link.click();
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { tools } from '../data/tools';
---

<Layout title="Page not found" noindex>
  <Header />

  <main class="container-page py-14">
    <div class="mx-auto max-w-3xl">
      <span class="eyebrow text-primary-hover">404</span>
      <h1 class="display-md mt-3 text-ink">This page wandered off</h1>

      <div class="mt-8 flex flex-col gap-4 text-[15px] leading-relaxed text-ink-muted">
        <p>
          The page you're looking for doesn't exist, or it may have moved.
          Check the address, or head back and pick up a tool from the shelf.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/" class="btn btn-primary">Back home</a>
          <a href="/tools" class="btn btn-secondary">Browse all {tools.length} tools</a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import FontConvert from '../components/FontConvert.astro';
---

<ToolLayout slug="font-converter">
  <FontConvert slug="font-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online font converter converts between font formats — TTF, OTF,
      WOFF, WOFF2 and EOT. Drop a font (or a whole batch), pick your target format,
      and convert. Ideal for turning desktop fonts into web-ready WOFF/WOFF2 or
      unpacking web fonts back to TTF.
    </p>
    <p>
      Everything runs entirely in your browser — your fonts are never uploaded to a
      server, so conversions are private and work offline once the page has loaded.
      OTF can be used as a source; because OTF is a CFF-outline format it isn't
      offered as an output — convert to TTF, WOFF or WOFF2 instead.
    </p>
  </div>
</ToolLayout>

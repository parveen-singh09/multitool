---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="odp-to-pptx">
  <ArchiveConvert slug="odp-to-pptx" from="odp" to="pptx" noun="presentation" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free ODP to PPTX converter converts OpenDocument ODP presentations to PowerPoint PPTX.
    </p>
    <p>
      Conversion is handled on our servers, because these
      presentation formats can't be read reliably in a browser. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="anagram-checker">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      First word or phrase
      <input id="ana-a" class="field font-mono text-[13px]" placeholder="e.g. Listen" spellcheck="false" value="Listen" />
    </label>
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Second word or phrase
      <input id="ana-b" class="field font-mono text-[13px]" placeholder="e.g. Silent" spellcheck="false" value="Silent" />
    </label>

    <div class="grid grid-cols-1 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="ana-verdict" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Verdict</div></div>
      <div class="panel p-4"><div id="ana-sig-a" class="font-mono text-lg text-ink break-all">—</div><div class="mt-1 text-[13px] text-ink-subtle">Signature A</div></div>
      <div class="panel p-4"><div id="ana-sig-b" class="font-mono text-lg text-ink break-all">—</div><div class="mt-1 text-[13px] text-ink-subtle">Signature B</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free anagram checker tells you whether two words or phrases are
      anagrams — that is, whether they use exactly the same letters rearranged.
      It ignores case, spaces and punctuation, so “Listen” and “Silent” count.
      The tool builds a sorted letter signature for each input and compares them,
      showing both signatures alongside the verdict. Everything runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  const inputA = document.getElementById('ana-a') as HTMLInputElement;
  const inputB = document.getElementById('ana-b') as HTMLInputElement;
  const verdictEl = document.getElementById('ana-verdict')!;
  const sigAEl = document.getElementById('ana-sig-a')!;
  const sigBEl = document.getElementById('ana-sig-b')!;

  function signature(text: string): string {
    return [...text.toLowerCase().replace(/[^a-z0-9]/gi, '')].sort().join('');
  }

  function check() {
    const rawA = inputA.value;
    const rawB = inputB.value;
    const sigA = signature(rawA);
    const sigB = signature(rawB);

    sigAEl.textContent = sigA === '' ? '—' : sigA;
    sigBEl.textContent = sigB === '' ? '—' : sigB;

    if (sigA === '' || sigB === '') {
      verdictEl.textContent = '—';
      verdictEl.className = 'font-display text-xl font-semibold text-primary-hover';
      return;
    }

    const isAnagram = sigA === sigB;
    verdictEl.textContent = isAnagram ? 'Anagrams' : 'Not anagrams';
    verdictEl.className = isAnagram
      ? 'font-display text-xl font-semibold text-primary-hover'
      : 'font-display text-xl font-semibold text-ink';
  }

  inputA.addEventListener('input', check);
  inputB.addEventListener('input', check);
  check();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="ai-to-png">
  <ArchiveConvert slug="ai-to-png" from="ai" to="png" noun="vector file" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free AI to PNG converter converts Adobe Illustrator AI artwork to raster PNG images.
    </p>
    <p>
      Conversion is handled on our servers, because these
      vector formats can't be read reliably in a browser. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

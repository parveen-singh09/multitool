?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="audio-speed-changer">
  <div class="flex flex-col gap-4">
    <label id="as-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an audio file or drop it here</span>
      <input id="as-file" type="file" accept="audio/*" class="sr-only" />
    </label>

    <div id="as-panel" class="hidden flex-col gap-4">
      <audio id="as-original" controls class="w-full"></audio>

      <div class="flex flex-col gap-1">
        <div class="flex items-center justify-between text-sm text-ink-subtle">
          <span>Speed</span>
          <span><span id="as-speed-val" class="text-ink">1.00×</span> · <span id="as-speed-pct" class="text-ink-tertiary">100%</span></span>
        </div>
        <input id="as-speed" type="range" min="0.25" max="4" step="0.05" value="1" class="w-full accent-primary" />
        <div class="mt-1 flex flex-wrap gap-2">
          <button class="as-preset btn btn-secondary" data-s="0.5">0.5×</button>
          <button class="as-preset btn btn-secondary" data-s="0.75">0.75×</button>
          <button class="as-preset btn btn-secondary" data-s="1">1×</button>
          <button class="as-preset btn btn-secondary" data-s="1.25">1.25×</button>
          <button class="as-preset btn btn-secondary" data-s="1.5">1.5×</button>
          <button class="as-preset btn btn-secondary" data-s="2">2×</button>
          <label class="ml-auto flex items-center gap-1 text-[13px] text-ink-subtle">Exact
            <input id="as-speed-num" type="number" min="0.25" max="4" step="0.01" value="1" class="field w-20" />
          </label>
        </div>
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Pitch: <span id="as-pitch-val" class="text-ink">0 semitones</span>
        <input id="as-pitch" type="range" min="-12" max="12" step="1" value="0" class="w-full accent-primary" />
      </label>

      <div class="flex flex-col gap-2">
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          <input id="as-link" type="checkbox" class="accent-primary" />
          Link speed &amp; pitch — tape/record effect (faster is higher-pitched)
        </label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          <input id="as-reverse" type="checkbox" class="accent-primary" /> Reverse audio
        </label>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="as-go" class="btn btn-primary">Apply</button>
        <button id="as-reset" class="btn btn-secondary">Reset</button>
        <span id="as-note" class="text-[13px] text-ink-tertiary"></span>
      </div>

      <div id="as-progwrap" class="hidden flex-col gap-1">
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-surface-3"><div id="as-bar" class="h-full w-0 rounded-full transition-all" style="background:var(--color-primary)"></div></div>
        <span id="as-status" class="text-[13px] text-ink-subtle"></span>
      </div>

      <div id="as-result" class="hidden flex-col gap-3">
        <div class="flex flex-wrap items-center gap-3">
          <span id="as-info" class="text-[13px]" style="color:var(--color-success)"></span>
          <button id="as-download" class="btn btn-primary">Download MP3</button>
        </div>
        <audio id="as-preview" controls class="w-full"></audio>
      </div>
    </div>
    <p id="as-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free audio speed and pitch changer lets you slow down or speed up
      audio from a quarter speed to 4× — with one-click presets, an exact numeric
      entry, and speed shown as both a multiplier and a percentage. By default the
      pitch is preserved as you change speed, so slowed-down music still sounds in
      tune; shift the pitch separately in semitones, link the two for an old
      record/tape effect, or reverse the whole track. Great for music practice,
      transcription, backing tracks and voice effects.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import { getFFmpeg, fetchFile } from '../lib/ffmpeg';

  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('as-file') as HTMLInputElement;
  const drop = $('as-drop');
  const panel = $('as-panel');
  const original = $('as-original') as HTMLAudioElement;
  const speed = $('as-speed') as HTMLInputElement;
  const speedNum = $('as-speed-num') as HTMLInputElement;
  const pitch = $('as-pitch') as HTMLInputElement;
  const speedVal = $('as-speed-val');
  const speedPct = $('as-speed-pct');
  const pitchVal = $('as-pitch-val');
  const link = $('as-link') as HTMLInputElement;
  const reverse = $('as-reverse') as HTMLInputElement;
  const goBtn = $('as-go') as HTMLButtonElement;
  const note = $('as-note');
  const progWrap = $('as-progwrap');
  const bar = $('as-bar');
  const statusEl = $('as-status');
  const result = $('as-result');
  const info = $('as-info');
  const preview = $('as-preview') as HTMLAudioElement;
  const err = $('as-error');

  let file: File | null = null;
  let outUrl = '';
  let origUrl = '';
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  function refreshLabels() {
    const s = Number(speed.value);
    speedVal.textContent = s.toFixed(2) + '×';
    speedPct.textContent = Math.round(s * 100) + '%';
    speedNum.value = s.toFixed(2);
    const p = Number(pitch.value);
    pitchVal.textContent = (p > 0 ? '+' : '') + p + ' semitone' + (Math.abs(p) === 1 ? '' : 's');
    pitch.disabled = link.checked;
    note.textContent = link.checked
      ? 'Linked: pitch follows speed (tape effect).'
      : 'Independent: speed keeps the original pitch.';
  }
  speed.addEventListener('input', refreshLabels);
  speedNum.addEventListener('input', () => {
    const v = Math.max(0.25, Math.min(4, Number(speedNum.value) || 1));
    speed.value = String(v); refreshLabels();
  });
  pitch.addEventListener('input', refreshLabels);
  link.addEventListener('change', refreshLabels);
  document.querySelectorAll<HTMLButtonElement>('.as-preset').forEach((b) =>
    b.addEventListener('click', () => { speed.value = b.dataset.s!; refreshLabels(); }));
  $('as-reset').addEventListener('click', () => {
    speed.value = '1'; pitch.value = '0'; link.checked = false; reverse.checked = false; refreshLabels();
  });

  function pick(f: File) {
    file = f;
    if (origUrl) URL.revokeObjectURL(origUrl);
    origUrl = URL.createObjectURL(f);
    original.src = origUrl;
    panel.classList.remove('hidden'); panel.classList.add('flex');
    result.classList.add('hidden'); setErr(''); refreshLabels();
  }

  function atempoChain(factor: number): string {
    const parts: number[] = [];
    let f = factor;
    while (f > 2) { parts.push(2); f /= 2; }
    while (f < 0.5) { parts.push(0.5); f /= 0.5; }
    parts.push(f);
    return parts.map((p) => `atempo=${p.toFixed(4)}`).join(',');
  }

  function buildFilter(): string {
    const s = Number(speed.value);
    const chain: string[] = [];
    if (reverse.checked) chain.push('areverse');
    if (link.checked) {
      chain.push(`asetrate=44100*${s.toFixed(4)}`, 'aresample=44100');
    } else {
      const semi = Number(pitch.value);
      if (semi !== 0) {
        const pf = Math.pow(2, semi / 12);
        chain.push(`asetrate=44100*${pf.toFixed(4)}`, 'aresample=44100', atempoChain(1 / pf));
      }
      if (s !== 1) chain.push(atempoChain(s));
    }
    return chain.length ? chain.join(',') : 'anull';
  }

  async function apply() {
    if (!file) return;
    setErr(''); goBtn.disabled = true;
    progWrap.classList.remove('hidden'); progWrap.classList.add('flex'); result.classList.add('hidden'); bar.style.width = '0%';
    try {
      const ff = await getFFmpeg({
        onProgress: (r) => { bar.style.width = Math.min(100, Math.round(r * 100)) + '%'; },
        onDownload: (n) => { if (n) statusEl.textContent = n; },
      });
      statusEl.textContent = 'Processing…';
      const inName = 'in.' + (file.name.split('.').pop() || 'mp3');
      await ff.writeFile(inName, await fetchFile(file));
      await ff.exec(['-i', inName, '-af', buildFilter(), '-c:a', 'libmp3lame', '-q:a', '2', 'out.mp3']);
      const data = await ff.readFile('out.mp3');
      const blob = new Blob([data as BlobPart], { type: 'audio/mpeg' });
      if (outUrl) URL.revokeObjectURL(outUrl);
      outUrl = URL.createObjectURL(blob);
      try { await ff.deleteFile(inName); await ff.deleteFile('out.mp3'); } catch {}
      preview.src = outUrl;
      info.textContent = `Done — ${(blob.size / 1024).toFixed(0)} KB MP3`;
      progWrap.classList.add('hidden');
      result.classList.remove('hidden'); result.classList.add('flex');
    } catch (e) { progWrap.classList.add('hidden'); setErr('Processing failed: ' + (e as Error).message); }
    finally { goBtn.disabled = false; }
  }

  $('as-download').addEventListener('click', () => {
    if (!outUrl || !file) return;
    const a = document.createElement('a'); a.href = outUrl; a.download = file.name.replace(/\.[^.]+$/, '') + '-modified.mp3'; a.click();
  });

  fileInput.addEventListener('change', () => fileInput.files?.[0] && pick(fileInput.files[0]));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) pick(f); });
  goBtn.addEventListener('click', apply);
</script>

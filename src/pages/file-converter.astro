---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const ANY_TARGETS = [
  'pdf', 'docx', 'doc', 'odt', 'rtf', 'txt', 'html',
  'jpg', 'png', 'webp', 'gif', 'bmp', 'tiff', 'svg', 'ico',
  'mp3', 'wav', 'flac', 'aac', 'ogg', 'm4a',
  'mp4', 'webm', 'mkv', 'mov', 'avi',
  'xlsx', 'csv', 'pptx',
  'epub', 'mobi', 'zip', '7z',
];
---

<ToolLayout slug="file-converter">
  <ArchiveConvert slug="file-converter" targets={ANY_TARGETS} noun="file" smart={true} />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online file converter converts almost any file to another format —
      documents, images, audio, video, spreadsheets, presentations, ebooks and
      archives. Upload a file, choose the format you want, and convert.
    </p>
    <p>
      Not every format converts to every other — you can't turn an audio file into
      a spreadsheet, for example. If you pick a combination that isn't supported,
      you'll see a message and can choose a different target. Your file is securely
      uploaded to our servers, converted, and returned as a download link. For
      common images, audio and video, our dedicated converters run entirely in your
      browser instead.
    </p>
  </div>
</ToolLayout>

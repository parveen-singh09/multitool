?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="tiff-converter">
  <div class="flex flex-col gap-4">
    <label id="tf-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose TIFF (or other) images or drop them here</span>
      <input id="tf-file" type="file" accept=".tif,.tiff,image/tiff,image/*" multiple class="sr-only" />
    </label>

    <div id="tf-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Convert to
          <select id="tf-fmt" class="field w-36">
            <option value="image/png">PNG</option>
            <option value="image/jpeg">JPG</option>
            <option value="image/webp">WebP</option>
            <option value="image/tiff">TIFF</option>
            <option value="application/pdf">PDF</option>
          </select>
        </label>
        <label id="tf-q-wrap" class="flex min-w-40 flex-1 flex-col gap-1 text-sm text-ink-subtle">Quality: <span id="tf-qval" class="text-ink">90%</span>
          <input id="tf-q" type="range" min="10" max="100" value="90" class="w-full accent-primary" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Longest side
          <input id="tf-resize" type="number" min="1" placeholder="original" class="field w-28" title="Resize so the longest side fits this many pixels. Leave blank to keep original size." />
        </label>
        <label id="tf-bg-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">Background
          <input id="tf-bg" type="color" value="#ffffff" class="field h-9 w-14 p-1" title="Fill colour behind transparent areas (formats without alpha)." />
        </label>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Page
          <select id="tf-page" class="field w-auto"></select>
        </label>
        <div class="ml-auto flex flex-wrap gap-2">
          <button id="tf-download" class="btn btn-primary">Download page</button>
          <button id="tf-download-all" class="btn btn-secondary">Download all (ZIP)</button>
          <button id="tf-download-pdf" class="btn btn-secondary">Combine to PDF</button>
        </div>
      </div>

      <p id="tf-status" class="text-[13px] text-ink-subtle"></p>
      <div class="panel flex justify-center overflow-hidden p-4"><img id="tf-preview" class="max-h-96 w-auto max-w-full rounded-md" alt="Converted preview" /></div>
    </div>
    <p id="tf-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free TIFF converter turns TIFF/TIF images into PNG, JPG, WebP or PDF —
      and can also convert ordinary images back into TIFF. TIFF is common in
      scanning, publishing and photography but isn't supported by web browsers
      directly, so this tool decodes it in-page and lets you download a
      web-friendly version. Drop a whole batch at once, and multi-page TIFFs are
      expanded into every page automatically.
    </p>
    <p>
      Convert a single page, download every page and file together as a ZIP, or
      combine them into one multi-page PDF — ideal for turning scanned TIFF
      documents into a shareable file. Optional controls let you resize by longest
      side, pick a JPG/WebP quality, and choose a background colour that fills
      transparent areas when writing formats without an alpha channel.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import UTIF from 'utif';
  import { PDFDocument } from 'pdf-lib';

  const fileInput = document.getElementById('tf-file') as HTMLInputElement;
  const drop = document.getElementById('tf-drop')!;
  const panel = document.getElementById('tf-panel')!;
  const preview = document.getElementById('tf-preview') as HTMLImageElement;
  const status = document.getElementById('tf-status')!;
  const err = document.getElementById('tf-error')!;
  const fmtEl = document.getElementById('tf-fmt') as HTMLSelectElement;
  const qEl = document.getElementById('tf-q') as HTMLInputElement;
  const qval = document.getElementById('tf-qval')!;
  const qWrap = document.getElementById('tf-q-wrap')!;
  const resizeEl = document.getElementById('tf-resize') as HTMLInputElement;
  const bgEl = document.getElementById('tf-bg') as HTMLInputElement;
  const bgWrap = document.getElementById('tf-bg-wrap')!;
  const pageSel = document.getElementById('tf-page') as HTMLSelectElement;

  type Page = { canvas: HTMLCanvasElement; base: string; page: number; pages: number };
  let pagesList: Page[] = [];

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const isLossy = () => fmtEl.value === 'image/jpeg' || fmtEl.value === 'image/webp' || fmtEl.value === 'application/pdf';

  const needsMatte = () => fmtEl.value === 'image/jpeg' || fmtEl.value === 'application/pdf';

  function syncUI() {
    qWrap.style.display = isLossy() ? '' : 'none';
    bgWrap.style.display = needsMatte() ? '' : 'none';
  }

  qEl.addEventListener('input', () => { qval.textContent = qEl.value + '%'; convert(); });
  bgEl.addEventListener('input', () => convert());
  resizeEl.addEventListener('input', () => convert());
  fmtEl.addEventListener('change', () => { syncUI(); convert(); });
  pageSel.addEventListener('change', () => convert());

  function baseName(name: string) { return name.replace(/\.[^.]+$/, '') || 'image'; }

  async function decodeFile(file: File): Promise<Page[]> {
    const base = baseName(file.name);
    if (/\.tif{1,2}$/i.test(file.name) || file.type === 'image/tiff') {
      const buf = await file.arrayBuffer();
      const ifds = UTIF.decode(buf);
      if (!ifds.length) throw new Error('no images found in TIFF');
      UTIF.decodeImages(buf, ifds);
      return ifds.map((ifd: any, i: number) => {
        const rgba = UTIF.toRGBA8(ifd);
        const canvas = document.createElement('canvas');
        canvas.width = ifd.width; canvas.height = ifd.height;
        const ctx = canvas.getContext('2d')!;
        const imgData = ctx.createImageData(canvas.width, canvas.height);
        imgData.data.set(rgba);
        ctx.putImageData(imgData, 0, 0);
        return { canvas, base, page: i + 1, pages: ifds.length };
      });
    }

    const url = URL.createObjectURL(file);
    try {
      const canvas = await new Promise<HTMLCanvasElement>((res, rej) => {
        const img = new Image();
        img.onload = () => {
          const c = document.createElement('canvas');
          c.width = img.naturalWidth; c.height = img.naturalHeight;
          c.getContext('2d')!.drawImage(img, 0, 0);
          res(c);
        };
        img.onerror = () => rej(new Error('the browser could not decode this image'));
        img.src = url;
      });
      return [{ canvas, base, page: 1, pages: 1 }];
    } finally { URL.revokeObjectURL(url); }
  }

  async function loadFiles(files: File[]) {
    setErr('');
    if (!files.length) return;
    status.textContent = 'Decoding…';
    const collected: Page[] = [];
    const failed: string[] = [];
    for (const f of files) {
      try { collected.push(...await decodeFile(f)); }
      catch (e) { failed.push(`${f.name} (${(e as Error).message})`); }
    }
    if (!collected.length) {
      setErr('Could not read any image: ' + failed.join('; '));
      status.textContent = '';
      return;
    }
    pagesList = collected;
    if (failed.length) setErr('Skipped ' + failed.join('; '));
    panel.classList.remove('hidden'); panel.classList.add('flex');
    pageSel.innerHTML = '';
    pagesList.forEach((p, i) => {
      const o = document.createElement('option');
      o.value = String(i);
      o.textContent = p.pages > 1 ? `${p.base} — page ${p.page}/${p.pages}` : p.base;
      pageSel.appendChild(o);
    });
    pageSel.value = '0';
    syncUI();
    convert();
  }

  function renderTarget(page: Page, matte: string | null): HTMLCanvasElement {
    const max = Math.max(1, Math.floor(Number(resizeEl.value) || 0));
    let w = page.canvas.width, h = page.canvas.height;
    if (max > 0 && Math.max(w, h) > max) {
      const s = max / Math.max(w, h);
      w = Math.max(1, Math.round(w * s));
      h = Math.max(1, Math.round(h * s));
    }
    const c = document.createElement('canvas');
    c.width = w; c.height = h;
    const ctx = c.getContext('2d')!;
    if (matte) { ctx.fillStyle = matte; ctx.fillRect(0, 0, w, h); }
    ctx.imageSmoothingQuality = 'high';
    ctx.drawImage(page.canvas, 0, 0, w, h);
    return c;
  }

  function canvasToBlob(c: HTMLCanvasElement, type: string, q: number): Promise<Blob> {
    return new Promise((res, rej) =>
      c.toBlob((b) => b ? res(b) : rej(new Error('the browser could not encode this format')), type, q));
  }

  async function encodePage(page: Page): Promise<{ blob: Blob; ext: string }> {
    const fmt = fmtEl.value;
    const q = Number(qEl.value) / 100;
    if (fmt === 'image/tiff') {
      const c = renderTarget(page, null);
      const data = c.getContext('2d')!.getImageData(0, 0, c.width, c.height);
      const tiff = UTIF.encodeImage(data.data, c.width, c.height);
      return { blob: new Blob([tiff], { type: 'image/tiff' }), ext: 'tif' };
    }
    const c = renderTarget(page, needsMatte() ? bgEl.value : null);
    const blob = await canvasToBlob(c, fmt, q);
    return { blob, ext: fmt.split('/')[1].replace('jpeg', 'jpg') };
  }

  let outUrl = '';
  async function convert() {
    if (!pagesList.length) return;
    setErr('');
    const page = pagesList[Number(pageSel.value) || 0];
    try {
      if (fmtEl.value === 'application/pdf') {
        preview.src = renderTarget(page, bgEl.value).toDataURL('image/png');
        status.textContent = `${pagesList.length} page(s) ready · "Combine to PDF" builds one document`;
        return;
      }
      const { blob } = await encodePage(page);
      if (outUrl) URL.revokeObjectURL(outUrl);
      outUrl = URL.createObjectURL(blob);
      preview.src = fmtEl.value === 'image/tiff'
        ? renderTarget(page, null).toDataURL('image/png')
        : outUrl;
      const c = renderTarget(page, null);
      status.textContent = `${page.base}${page.pages > 1 ? ` p${page.page}` : ''} · ${c.width}×${c.height} · ${(blob.size / 1024).toFixed(1)} KB · ${pagesList.length} page(s) total`;
    } catch (e) { setErr('Conversion failed: ' + (e as Error).message); }
  }

  function triggerDownload(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  document.getElementById('tf-download')!.addEventListener('click', async () => {
    if (!pagesList.length) return;
    const page = pagesList[Number(pageSel.value) || 0];
    if (fmtEl.value === 'application/pdf') { setErr('Use "Combine to PDF" for PDF output.'); return; }
    try {
      const { blob, ext } = await encodePage(page);
      triggerDownload(blob, `${page.base}${page.pages > 1 ? `-p${page.page}` : ''}.${ext}`);
    } catch (e) { setErr('Download failed: ' + (e as Error).message); }
  });

  document.getElementById('tf-download-all')!.addEventListener('click', async (ev) => {
    if (!pagesList.length) return;
    if (fmtEl.value === 'application/pdf') { setErr('ZIP applies to image formats. Use "Combine to PDF" for PDF.'); return; }
    const btn = ev.currentTarget as HTMLButtonElement;
    btn.disabled = true; const label = btn.textContent; btn.textContent = 'Zipping…';
    try {
      const files: { name: string; data: Uint8Array }[] = [];
      const seen: Record<string, number> = {};
      for (const page of pagesList) {
        const { blob, ext } = await encodePage(page);
        let name = `${page.base}${page.pages > 1 ? `-p${page.page}` : ''}.${ext}`;
        if (seen[name] != null) name = `${page.base}-${++seen[name]}.${ext}`; else seen[name] = 0;
        files.push({ name, data: new Uint8Array(await blob.arrayBuffer()) });
      }
      triggerDownload(new Blob([buildZip(files) as BlobPart], { type: 'application/zip' }), 'tiff-converted.zip');
    } catch (e) { setErr('ZIP failed: ' + (e as Error).message); }
    finally { btn.disabled = false; btn.textContent = label; }
  });

  document.getElementById('tf-download-pdf')!.addEventListener('click', async (ev) => {
    if (!pagesList.length) return;
    const btn = ev.currentTarget as HTMLButtonElement;
    btn.disabled = true; const label = btn.textContent; btn.textContent = 'Building PDF…';
    try {
      const q = Number(qEl.value) / 100;
      const pdf = await PDFDocument.create();
      for (const page of pagesList) {
        const c = renderTarget(page, bgEl.value);
        const bytes = new Uint8Array(await (await canvasToBlob(c, 'image/jpeg', q)).arrayBuffer());
        const img = await pdf.embedJpg(bytes);
        const p = pdf.addPage([img.width, img.height]);
        p.drawImage(img, { x: 0, y: 0, width: img.width, height: img.height });
      }
      const out = await pdf.save();
      triggerDownload(new Blob([out as BlobPart], { type: 'application/pdf' }), 'tiff-converted.pdf');
    } catch (e) { setErr('PDF failed: ' + (e as Error).message); }
    finally { btn.disabled = false; btn.textContent = label; }
  });

  function crc32(buf: Uint8Array): number {
    let c = ~0;
    for (let i = 0; i < buf.length; i++) {
      c ^= buf[i];
      for (let k = 0; k < 8; k++) c = (c >>> 1) ^ (0xEDB88320 & -(c & 1));
    }
    return ~c >>> 0;
  }
  function buildZip(files: { name: string; data: Uint8Array }[]): Uint8Array {
    const enc = new TextEncoder();
    const locals: Uint8Array[] = [];
    const central: Uint8Array[] = [];
    let offset = 0;
    for (const f of files) {
      const nameBytes = enc.encode(f.name);
      const crc = crc32(f.data);
      const size = f.data.length;
      const local = new Uint8Array(30 + nameBytes.length + size);
      const lv = new DataView(local.buffer);
      lv.setUint32(0, 0x04034b50, true); lv.setUint16(4, 20, true); lv.setUint16(6, 0x0800, true);
      lv.setUint16(8, 0, true); lv.setUint16(10, 0, true); lv.setUint16(12, 0, true);
      lv.setUint32(14, crc, true); lv.setUint32(18, size, true); lv.setUint32(22, size, true);
      lv.setUint16(26, nameBytes.length, true); lv.setUint16(28, 0, true);
      local.set(nameBytes, 30); local.set(f.data, 30 + nameBytes.length);
      locals.push(local);
      const cd = new Uint8Array(46 + nameBytes.length);
      const cv = new DataView(cd.buffer);
      cv.setUint32(0, 0x02014b50, true); cv.setUint16(4, 20, true); cv.setUint16(6, 20, true);
      cv.setUint16(8, 0x0800, true); cv.setUint16(10, 0, true); cv.setUint16(12, 0, true); cv.setUint16(14, 0, true);
      cv.setUint32(16, crc, true); cv.setUint32(20, size, true); cv.setUint32(24, size, true);
      cv.setUint16(28, nameBytes.length, true); cv.setUint32(42, offset, true);
      cd.set(nameBytes, 46);
      central.push(cd);
      offset += local.length;
    }
    const centralSize = central.reduce((n, c) => n + c.length, 0);
    const end = new Uint8Array(22);
    const ev = new DataView(end.buffer);
    ev.setUint32(0, 0x06054b50, true); ev.setUint16(8, files.length, true); ev.setUint16(10, files.length, true);
    ev.setUint32(12, centralSize, true); ev.setUint32(16, offset, true);
    const total = offset + centralSize + 22;
    const out = new Uint8Array(total);
    let pos = 0;
    for (const l of locals) { out.set(l, pos); pos += l.length; }
    for (const c of central) { out.set(c, pos); pos += c.length; }
    out.set(end, pos);
    return out;
  }

  fileInput.addEventListener('change', () => loadFiles(Array.from(fileInput.files ?? [])));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); loadFiles(Array.from((ev as DragEvent).dataTransfer?.files ?? [])); });

  syncUI();
</script>

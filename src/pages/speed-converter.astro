---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="speed-converter">
  <div id="sc-root" class="flex flex-col gap-5">

    <div class="flex flex-wrap gap-2">
      <span class="self-center text-[13px] text-ink-subtle">Quick:</span>
      <button type="button" class="btn btn-tertiary sc-preset" data-from="Kilometre / hour" data-to="Mile / hour">km/h → mph</button>
      <button type="button" class="btn btn-tertiary sc-preset" data-from="Mile / hour" data-to="Kilometre / hour">mph → km/h</button>
      <button type="button" class="btn btn-tertiary sc-preset" data-from="Metre / second" data-to="Kilometre / hour">m/s → km/h</button>
      <button type="button" class="btn btn-tertiary sc-preset" data-from="Knot" data-to="Mile / hour">knots → mph</button>
      <button type="button" class="btn btn-tertiary sc-preset" data-from="Mile / hour" data-to="Foot / second">mph → ft/s</button>
    </div>

    <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="sc-from-val">From</label>
        <input id="sc-from-val" type="number" class="field" value="100" inputmode="decimal" step="any" />
        <select id="sc-from-unit" class="field mt-1"></select>
      </div>
      <button
        id="sc-swap"
        type="button"
        class="btn btn-secondary mb-1 h-10 w-10 shrink-0 justify-self-center p-0"
        aria-label="Swap units"
        title="Swap units"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4"/></svg>
      </button>
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="sc-to-val">To</label>
        <div class="copy-wrap">
          <input id="sc-to-val" type="text" class="field pr-12" readonly />
          <button type="button" class="copy-icon" data-copy-target="#sc-to-val" aria-label="Copy"></button>
        </div>
        <select id="sc-to-unit" class="field mt-1"></select>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <label class="flex items-center gap-2 text-[13px] text-ink-subtle" for="sc-precision">
        Decimals
        <select id="sc-precision" class="field h-8 w-auto py-0 text-[13px]">
          <option value="auto" selected>Auto</option>
          <option value="0">0</option>
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="6">6</option>
          <option value="8">8</option>
        </select>
      </label>
      <p id="sc-formula" class="text-[13px] text-ink-tertiary"></p>
    </div>

    <p id="sc-error" class="hidden text-[13px] text-primary-hover"></p>

    <div>
      <p class="mb-2 text-[13px] text-ink-subtle">Converted to every unit</p>
      <div id="sc-table" class="overflow-hidden rounded-md border border-hairline"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free speed converter converts speed between kilometres per hour (km/h), miles per hour (mph), metres per second (m/s), feet per second (ft/s), knots, Mach and more. Handy for travel, sport, aviation, marine navigation and physics.
    </p>
    <p>
      Pick any pair of units, or tap a quick preset like km/h → mph. Choose how many decimals you want (or leave it on Auto for sensible significant figures), copy the result with one click, and use the live table to see your value expressed in every supported unit at once. Common factors: multiply m/s by 3.6 for km/h, multiply mph by 1.60934 for km/h, and multiply knots by 1.15078 for mph.
    </p>
  </div>
</ToolLayout>

<script>

  const UNITS: Record<string, number> = {
    'Metre / second': 1,
    'Kilometre / hour': 0.2777777778,
    'Mile / hour': 0.44704,
    'Foot / second': 0.3048,
    'Foot / minute': 0.00508,
    'Metre / minute': 0.0166666667,
    'Kilometre / minute': 16.6666666667,
    'Kilometre / second': 1000,
    'Centimetre / second': 0.01,
    'Millimetre / second': 0.001,
    'Yard / second': 0.9144,
    'Mile / minute': 26.8224,
    'Mile / second': 1609.344,
    Knot: 0.5144444444,
    'Mach (sea level)': 340.29,
    'Speed of light': 299792458,
  };
  const UNIT_NAMES = Object.keys(UNITS);

  const fromVal = document.getElementById('sc-from-val') as HTMLInputElement;
  const toVal = document.getElementById('sc-to-val') as HTMLInputElement;
  const fromUnit = document.getElementById('sc-from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('sc-to-unit') as HTMLSelectElement;
  const swap = document.getElementById('sc-swap') as HTMLButtonElement;
  const precision = document.getElementById('sc-precision') as HTMLSelectElement;
  const formula = document.getElementById('sc-formula') as HTMLElement;
  const errorEl = document.getElementById('sc-error') as HTMLElement;
  const table = document.getElementById('sc-table') as HTMLElement;

  function convert(value: number, from: string, to: string): number {
    return (value * UNITS[from]) / UNITS[to];
  }

  function fmt(n: number): string {
    if (!isFinite(n)) return '∞';
    const p = precision.value;
    if (p !== 'auto') return n.toFixed(Number(p));
    if (n === 0) return '0';
    const abs = Math.abs(n);
    if (abs >= 1e15 || abs < 1e-6) return n.toExponential(6);
    return String(Math.round(n * 1e9) / 1e9);
  }

  function fillUnits() {
    const opts = UNIT_NAMES.map((u) => `<option>${u}</option>`).join('');
    fromUnit.innerHTML = opts;
    toUnit.innerHTML = opts;
    fromUnit.value = 'Kilometre / hour';
    toUnit.value = 'Mile / hour';
  }

  function update() {
    const raw = fromVal.value.trim();
    if (raw === '' || isNaN(Number(raw))) {
      toVal.value = '';
      formula.textContent = '';
      if (raw !== '') {
        errorEl.textContent = 'Enter a valid number.';
        errorEl.classList.remove('hidden');
      } else {
        errorEl.classList.add('hidden');
      }
      table.innerHTML = '';
      return;
    }
    errorEl.classList.add('hidden');
    const v = Number(raw);
    const result = convert(v, fromUnit.value, toUnit.value);
    toVal.value = fmt(result);
    formula.textContent = `${fmt(v)} ${fromUnit.value} = ${fmt(result)} ${toUnit.value}`;
    renderTable(v);
  }

  function renderTable(v: number) {
    const rows = UNIT_NAMES
      .filter((u) => u !== fromUnit.value)
      .map((u) => {
        const r = convert(v, fromUnit.value, u);
        const hot = u === toUnit.value;
        return `<tr class="border-t border-hairline${hot ? ' bg-surface-2' : ''}">
          <td class="px-3 py-2 text-ink-subtle">${u}</td>
          <td class="px-3 py-2 text-right font-mono text-ink">${fmt(r)}</td>
        </tr>`;
      })
      .join('');
    table.innerHTML = `<table class="w-full text-[13px]">${rows}</table>`;
  }

  fromVal.addEventListener('input', update);
  fromUnit.addEventListener('change', update);
  toUnit.addEventListener('change', update);
  precision.addEventListener('change', update);

  swap.addEventListener('click', () => {
    const a = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = a;
    if (toVal.value !== '' && toVal.value !== '∞') fromVal.value = toVal.value;
    update();
  });

  for (const btn of document.querySelectorAll<HTMLButtonElement>('.sc-preset')) {
    btn.addEventListener('click', () => {
      fromUnit.value = btn.dataset.from!;
      toUnit.value = btn.dataset.to!;
      update();
    });
  }

  fillUnits();
  update();

  console.assert(Math.abs(convert(100, 'Kilometre / hour', 'Mile / hour') - 62.1371) < 0.01, 'km/h→mph');
  console.assert(Math.abs(convert(1, 'Metre / second', 'Kilometre / hour') - 3.6) < 1e-6, 'm/s→km/h');
  console.assert(Math.abs(convert(1, 'Knot', 'Mile / hour') - 1.15078) < 1e-4, 'knot→mph');
</script>

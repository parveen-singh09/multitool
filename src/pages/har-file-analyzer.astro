---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="har-file-analyzer">
  <div class="flex flex-col gap-5">
    <div id="ha-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-ink-subtle"><path d="M12 16V4m0 0L8 8m4-4 4 4M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="text-sm text-ink">Drop a <span class="font-mono">.har</span> file here or click to choose</span>
      <span class="text-xs text-ink-tertiary">Captured from your browser's Network tab · parsed locally</span>
      <input id="ha-file" type="file" accept=".har,application/json" class="hidden" />
    </div>

    <div id="ha-report" class="hidden flex-col gap-5">
      <div id="ha-summary" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6"></div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="panel p-4">
          <div class="eyebrow mb-3">By type</div>
          <div id="ha-types" class="flex flex-col gap-2"></div>
        </div>
        <div class="panel p-4">
          <div class="eyebrow mb-3">By domain</div>
          <div id="ha-domains" class="flex flex-col gap-2"></div>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <div class="flex flex-wrap items-center gap-2">
          <input id="ha-search" type="text" placeholder="Filter by URL, domain or status…" class="field min-w-52 flex-1 text-[13px]" />
          <select id="ha-sort" class="field w-40 text-[13px]">
            <option value="start">Sort by start time</option>
            <option value="time">Sort by duration</option>
            <option value="size">Sort by size</option>
            <option value="wait">Sort by TTFB</option>
          </select>
        </div>
        <div id="ha-chips" class="flex flex-wrap gap-1.5"></div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2">
          <div class="eyebrow">Request waterfall</div>
          <span id="ha-count" class="ml-auto text-xs text-ink-tertiary"></span>
        </div>
        <div class="panel overflow-x-auto">
          <table class="w-full text-left text-[13px]">
            <thead class="text-ink-tertiary">
              <tr class="border-b border-hairline">
                <th class="p-2 font-medium">Status</th>
                <th class="p-2 font-medium">Method</th>
                <th class="p-2 font-medium">URL</th>
                <th class="p-2 text-right font-medium">Size</th>
                <th class="p-2 text-right font-medium">Time</th>
                <th class="p-2 font-medium" style="min-width:200px">Waterfall</th>
              </tr>
            </thead>
            <tbody id="ha-rows" class="font-mono"></tbody>
          </table>
        </div>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px] text-ink-tertiary" id="ha-legend"></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free HAR file analyzer breaks down a HTTP Archive (.har) capture from
      your browser's Network tab. It summarizes the total requests, transfer size,
      wall-clock load time and cache hits, groups traffic by content type and by
      domain, and draws a timing <strong>waterfall</strong> showing how each request's
      time splits across DNS, connect, TLS, request, wait (TTFB) and download phases —
      so you can spot slow servers, render-blocking resources and third-party bloat.
      Filter by type, search by URL or status, and click any row to expand its full
      timing breakdown. To create a HAR: open DevTools → Network, reload the page,
      then right-click and "Save all as HAR".
    </p>
  </div>
</ToolLayout>

<script>
  const drop = document.getElementById('ha-drop')!;
  const fileInput = document.getElementById('ha-file') as HTMLInputElement;
  const report = document.getElementById('ha-report')!;
  const sortSel = document.getElementById('ha-sort') as HTMLSelectElement;
  const searchInput = document.getElementById('ha-search') as HTMLInputElement;
  const chipsEl = document.getElementById('ha-chips')!;

  interface Timings { blocked: number; dns: number; connect: number; ssl: number; send: number; wait: number; receive: number; }
  interface Entry {
    status: number; method: string; url: string; host: string; type: string;
    size: number; time: number; start: number; startText: string;
    fromCache: boolean; timings: Timings; mime: string;
  }
  let entries: Entry[] = [];
  let activeType: string | null = null;

  const PHASES: { key: keyof Timings; label: string; color: string }[] = [
    { key: 'blocked', label: 'Blocked', color: '#3e3e44' },
    { key: 'dns', label: 'DNS', color: '#7a7fad' },
    { key: 'connect', label: 'Connect', color: '#8a8f98' },
    { key: 'ssl', label: 'TLS', color: '#a0789a' },
    { key: 'send', label: 'Send', color: '#6f86c9' },
    { key: 'wait', label: 'Wait (TTFB)', color: '#5e6ad2' },
    { key: 'receive', label: 'Download', color: '#27a644' },
  ];

  function fmtBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
    return `${(n / 1024 / 1024).toFixed(2)} MB`;
  }
  function fmtMs(n: number): string {
    if (n < 1000) return `${Math.round(n)} ms`;
    return `${(n / 1000).toFixed(2)} s`;
  }

  function categorize(mime: string, url: string): string {
    const m = (mime || '').toLowerCase();
    if (m.includes('html')) return 'Document';
    if (m.includes('css')) return 'CSS';
    if (m.includes('javascript') || m.includes('ecmascript') || /\.js(\?|$)/.test(url)) return 'JS';
    if (m.startsWith('image/') || /\.(png|jpe?g|gif|webp|svg|avif)(\?|$)/i.test(url)) return 'Image';
    if (m.startsWith('font/') || m.includes('font') || /\.(woff2?|ttf|otf|eot)(\?|$)/i.test(url)) return 'Font';
    if (m.includes('json') || m.includes('xml') || url.includes('/api/')) return 'XHR/Fetch';
    if (m.startsWith('video/') || m.startsWith('audio/')) return 'Media';
    return 'Other';
  }

  function statusColor(s: number): string {
    if (s >= 500) return '#e08585';
    if (s >= 400) return '#e0a085';
    if (s >= 300) return '#e0c185';
    if (s >= 200) return '#27a644';
    return '#8a8f98';
  }

  function parse(har: any): Entry[] {
    const log = har.log || har;
    const es = (log.entries || []) as any[];
    let origin = Infinity;
    for (const e of es) {
      const t = Date.parse(e.startedDateTime);
      if (!isNaN(t)) origin = Math.min(origin, t);
    }
    if (!isFinite(origin)) origin = 0;

    return es.map((e) => {
      let host = '';
      try { host = new URL(e.request.url).hostname; } catch { host = '(invalid)'; }
      const size = Math.max(0, e.response?._transferSize ?? e.response?.content?.size ?? e.response?.bodySize ?? 0);
      const t = e.timings || {};
      const clamp = (v: any) => Math.max(0, v ?? 0);
      const timings: Timings = {
        blocked: clamp(t.blocked), dns: clamp(t.dns), connect: clamp(t.connect),
        ssl: clamp(t.ssl), send: clamp(t.send), wait: clamp(t.wait), receive: clamp(t.receive),
      };
      const startMs = isNaN(Date.parse(e.startedDateTime)) ? 0 : Date.parse(e.startedDateTime) - origin;
      const cache = e.response?._transferSize === 0 && (e.response?.status ?? 0) > 0;
      return {
        status: e.response?.status ?? 0,
        method: e.request?.method ?? 'GET',
        url: e.request?.url ?? '',
        host,
        mime: e.response?.content?.mimeType || '',
        type: categorize(e.response?.content?.mimeType || '', e.request?.url || ''),
        size,
        time: Math.max(0, e.time ?? 0),
        start: startMs,
        startText: e.startedDateTime || '',
        fromCache: cache || (e.response?._fromCache != null),
        timings,
      };
    });
  }

  function statTile(label: string, value: string): string {
    return `<div class="panel panel-lift flex flex-col gap-1 p-4">
      <span class="text-xs text-ink-tertiary">${label}</span>
      <span class="font-display text-2xl font-semibold text-ink">${value}</span>
    </div>`;
  }

  function bar(label: string, count: number, size: number, max: number): string {
    const pct = max > 0 ? Math.round((count / max) * 100) : 0;
    return `<div class="flex flex-col gap-1">
      <div class="flex items-baseline justify-between text-[13px]">
        <span class="text-ink">${esc(label)}</span>
        <span class="text-ink-tertiary">${count} · ${fmtBytes(size)}</span>
      </div>
      <div class="h-1.5 w-full overflow-hidden rounded-full bg-surface-3">
        <div class="h-full rounded-full" style="width:${pct}%;background:#5e6ad2"></div>
      </div>
    </div>`;
  }

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  const groupBy = (key: (e: Entry) => string) => {
    const map = new Map<string, { count: number; size: number }>();
    for (const e of entries) {
      const k = key(e);
      const g = map.get(k) || { count: 0, size: 0 };
      g.count++; g.size += e.size; map.set(k, g);
    }
    return [...map.entries()].sort((a, b) => b[1].count - a[1].count);
  };

  function render() {
    if (!entries.length) return;
    const total = entries.length;
    const totalSize = entries.reduce((a, e) => a + e.size, 0);
    const spans = entries.filter((e) => e.startText);
    let wall = entries.reduce((a, e) => a + e.time, 0);
    if (spans.length) {
      const end = Math.max(...spans.map((e) => e.start + e.time));
      wall = end;
    }
    const failures = entries.filter((e) => e.status >= 400 || e.status === 0).length;
    const cached = entries.filter((e) => e.fromCache).length;
    const domains = groupBy((e) => e.host);

    document.getElementById('ha-summary')!.innerHTML =
      statTile('Requests', String(total)) +
      statTile('Transferred', fmtBytes(totalSize)) +
      statTile('Load time', fmtMs(wall)) +
      statTile('Errors (≥400)', String(failures)) +
      statTile('Cached', String(cached)) +
      statTile('Domains', String(domains.length));

    const types = groupBy((e) => e.type);
    const maxType = Math.max(...types.map((t) => t[1].count), 1);
    document.getElementById('ha-types')!.innerHTML = types.map(([k, g]) => bar(k, g.count, g.size, maxType)).join('');

    const topDomains = domains.slice(0, 8);
    const maxDom = Math.max(...topDomains.map((d) => d[1].count), 1);
    document.getElementById('ha-domains')!.innerHTML = topDomains.map(([k, g]) => bar(k, g.count, g.size, maxDom)).join('');

    renderChips(types.map((t) => t[0]));
    renderLegend();
    renderRows();
    report.classList.remove('hidden');
  }

  function renderChips(types: string[]) {
    const chip = (label: string, active: boolean) =>
      `<button data-type="${esc(label)}" class="rounded-full border px-2.5 py-1 text-xs transition-colors ${
        active ? 'border-primary bg-primary/15 text-ink' : 'border-hairline text-ink-subtle hover:bg-surface-2'
      }">${esc(label)}</button>`;
    chipsEl.innerHTML = chip('All', activeType === null) + types.map((t) => chip(t, activeType === t)).join('');
    chipsEl.querySelectorAll('button').forEach((b) => {
      b.addEventListener('click', () => {
        const t = (b as HTMLElement).dataset.type!;
        activeType = t === 'All' ? null : t;
        renderChips(types);
        renderRows();
      });
    });
  }

  function renderLegend() {
    document.getElementById('ha-legend')!.innerHTML = PHASES.map(
      (p) => `<span class="inline-flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-sm" style="background:${p.color}"></span>${p.label}</span>`
    ).join('');
  }

  function filtered(): Entry[] {
    const q = searchInput.value.trim().toLowerCase();
    return entries.filter((e) => {
      if (activeType && e.type !== activeType) return false;
      if (q && !(`${e.status} ${e.method} ${e.url}`.toLowerCase().includes(q))) return false;
      return true;
    });
  }

  function waterfall(e: Entry, minStart: number, scale: number): string {
    const offset = (e.start - minStart) * scale;
    let segs = '';
    for (const p of PHASES) {
      const w = e.timings[p.key] * scale;
      if (w <= 0) continue;
      segs += `<span title="${p.label}: ${fmtMs(e.timings[p.key])}" style="display:inline-block;height:9px;width:${Math.max(w, 0.5)}px;background:${p.color}"></span>`;
    }
    if (!segs) segs = `<span style="display:inline-block;height:9px;width:${Math.max(e.time * scale, 1)}px;background:#5e6ad2"></span>`;
    return `<span style="display:inline-flex;align-items:center;padding-left:${Math.max(offset, 0)}px">${segs}</span>`;
  }

  function detailRow(e: Entry): string {
    const rows = PHASES.filter((p) => e.timings[p.key] > 0)
      .map((p) => `<div class="flex items-center gap-2"><span class="inline-block h-2 w-2 rounded-sm" style="background:${p.color}"></span><span class="w-24 text-ink-subtle">${p.label}</span><span class="text-ink-muted">${fmtMs(e.timings[p.key])}</span></div>`)
      .join('');
    const meta = [
      ['URL', esc(e.url)],
      ['Type', `${e.type}${e.mime ? ` · ${esc(e.mime)}` : ''}`],
      ['Started at', e.startText ? esc(e.startText) : '—'],
      ['Transfer size', fmtBytes(e.size)],
      ['From cache', e.fromCache ? 'yes' : 'no'],
    ].map(([k, v]) => `<div class="flex gap-2"><span class="w-24 shrink-0 text-ink-tertiary">${k}</span><span class="break-all text-ink-muted">${v}</span></div>`).join('');
    return `<tr class="ha-detail border-b border-hairline/50 bg-surface-1"><td colspan="6" class="p-3">
      <div class="grid grid-cols-1 gap-4 text-[12px] md:grid-cols-2">
        <div class="flex flex-col gap-1">${meta}</div>
        <div class="flex flex-col gap-1">${rows || '<span class="text-ink-tertiary">No phase timing recorded.</span>'}</div>
      </div>
    </td></tr>`;
  }

  function renderRows() {
    const list = filtered();
    const key =
      sortSel.value === 'size' ? (e: Entry) => -e.size
      : sortSel.value === 'time' ? (e: Entry) => -e.time
      : sortSel.value === 'wait' ? (e: Entry) => -e.timings.wait
      : (e: Entry) => e.start;
    const rows = [...list].sort((a, b) => key(a) - key(b)).slice(0, 200);

    document.getElementById('ha-count')!.textContent =
      `${list.length} request${list.length === 1 ? '' : 's'}${list.length > 200 ? ' (showing 200)' : ''}`;

    const minStart = Math.min(...rows.map((e) => e.start), 0);
    const maxEnd = Math.max(...rows.map((e) => e.start - minStart + e.time), 1);
    const scale = 180 / maxEnd;

    document.getElementById('ha-rows')!.innerHTML = rows
      .map((e, i) => {
        let path = e.url;
        try { const u = new URL(e.url); path = u.hostname + u.pathname; } catch {}
        return `<tr class="ha-row cursor-pointer border-b border-hairline/50 hover:bg-surface-2" data-i="${i}">
          <td class="p-2"><span style="color:${statusColor(e.status)}">${e.status || '—'}</span></td>
          <td class="p-2 text-ink-subtle">${e.method}</td>
          <td class="p-2 max-w-70 truncate text-ink-muted" title="${esc(e.url)}">${esc(path)}</td>
          <td class="p-2 text-right text-ink-subtle">${e.fromCache ? '<span class="text-ink-tertiary">cache</span>' : fmtBytes(e.size)}</td>
          <td class="p-2 text-right text-ink-subtle">${fmtMs(e.time)}</td>
          <td class="p-2">${waterfall(e, minStart, scale)}</td>
        </tr>`;
      })
      .join('');

    const tbody = document.getElementById('ha-rows')!;
    tbody.querySelectorAll('.ha-row').forEach((tr) => {
      tr.addEventListener('click', () => {
        const next = tr.nextElementSibling;
        if (next && next.classList.contains('ha-detail')) { next.remove(); return; }
        tbody.querySelectorAll('.ha-detail').forEach((d) => d.remove());
        const idx = parseInt((tr as HTMLElement).dataset.i!, 10);
        tr.insertAdjacentHTML('afterend', detailRow(rows[idx]));
      });
    });
  }

  function load(text: string) {
    try {
      const har = JSON.parse(text);
      entries = parse(har);
      if (!entries.length) { alert('No requests found in this HAR file.'); return; }
      activeType = null;
      searchInput.value = '';
      render();
    } catch {
      alert('Could not parse this file as a HAR (JSON) archive.');
    }
  }

  function handleFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => load(String(reader.result));
    reader.readAsText(file);
  }

  drop.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) handleFile(fileInput.files[0]); });
  drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('bg-surface-2'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('bg-surface-2'));
  drop.addEventListener('drop', (e) => {
    e.preventDefault(); drop.classList.remove('bg-surface-2');
    const f = e.dataTransfer?.files?.[0]; if (f) handleFile(f);
  });
  sortSel.addEventListener('change', renderRows);
  searchInput.addEventListener('input', renderRows);
</script>

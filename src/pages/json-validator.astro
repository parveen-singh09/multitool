---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="json-validator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="jv-sample" class="btn btn-secondary">Load sample</button>
      <button id="jv-clear" class="btn btn-tertiary">Clear</button>
      <label class="btn btn-secondary cursor-pointer">
        Upload file
        <input id="jv-file" type="file" accept=".json,application/json,text/plain" class="hidden" />
      </label>

      <label class="ml-auto flex items-center gap-2 text-sm text-ink-subtle">
        Preview indent
        <select id="jv-indent" class="field w-auto py-1">
          <option value="2">2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
    </div>

    <div id="jv-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      JSON to validate
      <div class="hl-edit field p-0 jv-editor" style="height:24rem;resize:vertical;overflow:hidden">
        <div id="jv-gutter" class="jv-gutter" aria-hidden="true">1</div>
        <pre class="hl-block" aria-hidden="true"><code id="jv-in-hl" class="hljs" style="background:transparent"></code></pre>
        <textarea id="jv-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder='Paste JSON here, e.g. {"hello":"world"}'></textarea>
      </div>
    </label>

    <div id="jv-caret-wrap" class="hidden">
      <div class="eyebrow">Error location</div>
      <pre id="jv-caret" class="panel p-4 mt-2 overflow-x-auto font-mono text-[13px] leading-relaxed"></pre>
    </div>

    <div id="jv-stats" class="hidden flex-wrap gap-2 text-[12px]"></div>

    <div id="jv-preview-wrap" class="hidden">
      <div class="eyebrow">Formatted preview</div>
      <div class="copy-wrap mt-2"><pre id="jv-preview" class="hl-block field" style="overflow:auto"><code id="jv-preview-code" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#jv-preview-code" aria-label="Copy"></button></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free JSON validator checks your JSON the instant you type — no button
      to press. Valid JSON is confirmed and pretty-printed with your choice of
      indentation, alongside a stats bar showing byte size, key count and nesting
      depth. When there is a syntax error it reports the exact line and column and
      shows a few surrounding lines with a caret pointing directly at the
      offending character, so you find the problem in seconds. The editor has a
      line-number gutter for easy cross-referencing. Need to repair broken JSON
      (trailing commas, comments, single quotes)? Use the JSON Formatter's
      Auto-fix.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl, wireInput } from '../lib/highlight';

  const input = document.getElementById('jv-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('jv-in-hl')!;
  const gutter = document.getElementById('jv-gutter')!;
  const status = document.getElementById('jv-status')!;
  const caretWrap = document.getElementById('jv-caret-wrap')!;
  const caret = document.getElementById('jv-caret')!;
  const statsEl = document.getElementById('jv-stats')!;
  const previewWrap = document.getElementById('jv-preview-wrap')!;
  const preview = document.getElementById('jv-preview-code')!;
  const indentSel = document.getElementById('jv-indent') as HTMLSelectElement;
  let rawOutput = '';

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  function getIndent(): string | number {
    return indentSel.value === 'tab' ? '\t' : Number(indentSel.value);
  }

  function syncGutter() {
    const n = input.value.split('\n').length;
    const nums = Array.from({ length: n }, (_, i) => i + 1).join('\n');
    if (gutter.textContent !== nums) gutter.textContent = nums;
    gutter.scrollTop = input.scrollTop;
  }
  input.addEventListener('scroll', syncGutter);

  function positionFromError(msg: string, text: string): number | null {
    const posMatch = msg.match(/position (\d+)/i);
    if (posMatch) return Math.min(Number(posMatch[1]), text.length);
    const lineCol = msg.match(/line (\d+) column (\d+)/i);
    if (lineCol) {
      const line = Number(lineCol[1]);
      const col = Number(lineCol[2]);
      const lines = text.split('\n');
      let idx = 0;
      for (let i = 0; i < line - 1 && i < lines.length; i++) idx += lines[i].length + 1;
      return idx + (col - 1);
    }
    return null;
  }

  function lineColFromPos(text: string, pos: number): { line: number; col: number } {
    let line = 1, col = 1;
    for (let i = 0; i < pos && i < text.length; i++) {
      if (text[i] === '\n') { line++; col = 1; } else { col++; }
    }
    return { line, col };
  }

  function renderCaret(text: string, line: number, col: number) {
    caret.replaceChildren();
    const lines = text.split('\n');
    const from = Math.max(1, line - 2);
    const to = Math.min(lines.length, line + 2);
    const gw = String(to).length;
    for (let ln = from; ln <= to; ln++) {
      const raw = lines[ln - 1] ?? '';
      const shown = raw.length > 240 ? raw.slice(0, 240) + '…' : raw;
      const row = document.createElement('div');
      row.textContent = `${String(ln).padStart(gw)} | ${shown}`;
      if (ln === line) row.className = 'jv-errline';
      caret.appendChild(row);
      if (ln === line) {
        const pointer = document.createElement('div');
        pointer.className = 'jv-errline';
        pointer.textContent = `${' '.repeat(gw)} | ${' '.repeat(Math.max(0, col - 1))}^`;
        caret.appendChild(pointer);
      }
    }
    caretWrap.classList.remove('hidden');
  }

  function pill(text: string): HTMLElement {
    const el = document.createElement('span');
    el.className = 'status-badge';
    el.textContent = text;
    return el;
  }
  function depthOf(v: any): number {
    if (Array.isArray(v)) return 1 + (v.length ? Math.max(...v.map(depthOf)) : 0);
    if (v && typeof v === 'object') {
      const ks = Object.keys(v);
      return 1 + (ks.length ? Math.max(...ks.map((k) => depthOf(v[k]))) : 0);
    }
    return 0;
  }
  function renderStats(parsed: any, text: string) {
    statsEl.replaceChildren();
    const bytes = new Blob([text]).size;
    const size = bytes < 1024 ? `${bytes} B` : `${(bytes / 1024).toFixed(1)} KB`;
    statsEl.appendChild(pill(`Size ${size}`));
    if (parsed && typeof parsed === 'object') {
      const count = Array.isArray(parsed) ? parsed.length : Object.keys(parsed).length;
      statsEl.appendChild(pill(`${Array.isArray(parsed) ? 'Items' : 'Keys'} ${count}`));
      statsEl.appendChild(pill(`Depth ${depthOf(parsed)}`));
    }
    statsEl.classList.remove('hidden');
    statsEl.classList.add('flex');
  }

  function validate() {
    caretWrap.classList.add('hidden');
    previewWrap.classList.add('hidden');
    statsEl.classList.add('hidden');
    const text = input.value;
    if (!text.trim()) {
      status.classList.add('hidden');
      return;
    }
    try {
      const parsed = JSON.parse(text);
      showStatus('Valid JSON ✓', true);
      rawOutput = JSON.stringify(parsed, null, getIndent());
      hl(preview, rawOutput, 'json');
      renderStats(parsed, text);
      previewWrap.classList.remove('hidden');
    } catch (e) {
      const msg = (e as Error).message;
      const pos = positionFromError(msg, text);
      if (pos !== null) {
        const { line, col } = lineColFromPos(text, pos);
        showStatus(`Invalid JSON at line ${line}, column ${col}: ${msg}`, false);
        renderCaret(text, line, col);
      } else {
        showStatus(`Invalid JSON: ${msg}`, false);
      }
    }
  }

  const refresh = wireInput(input, inHl, () => 'json', () => { syncGutter(); validate(); });

  document.getElementById('jv-clear')!.addEventListener('click', () => {
    input.value = '';
    refresh();
    syncGutter();
    status.classList.add('hidden');
    caretWrap.classList.add('hidden');
    statsEl.classList.add('hidden');
    previewWrap.classList.add('hidden');
  });

  document.getElementById('jv-sample')!.addEventListener('click', () => {
    input.value = JSON.stringify({
      name: 'Ada Lovelace',
      active: true,
      roles: ['engineer', 'author'],
      address: { city: 'London', zip: 'SW1' },
      projects: 3,
      notes: null,
    }, null, 2);
    refresh();
    syncGutter();
    validate();
  });

  indentSel.addEventListener('change', validate);

  const fileInput = document.getElementById('jv-file') as HTMLInputElement;
  async function loadFile(file: File) {
    input.value = await file.text();
    refresh();
    syncGutter();
    validate();
  }
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
  input.addEventListener('dragover', (e) => e.preventDefault());
  input.addEventListener('drop', (e) => {
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) { e.preventDefault(); loadFile(file); }
  });

  syncGutter();
  validate();
</script>

<style>

  .jv-editor > pre.hl-block,
  .jv-editor > textarea {
    padding-left: 3.25rem;
    white-space: pre;
    overflow-wrap: normal;
    word-break: normal;
  }
  .jv-gutter {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 2.75rem;
    padding: 0.75rem 0.5rem 0.75rem 0;
    text-align: right;
    white-space: pre;
    overflow: hidden;
    color: var(--color-ink-subtle);
    border-right: 1px solid var(--color-hairline);
    background: var(--color-surface-2);
    pointer-events: none;
    user-select: none;
  }
  .jv-errline {
    color: #e08585;
    background: color-mix(in srgb, #d14d4d 12%, transparent);
  }

</style>

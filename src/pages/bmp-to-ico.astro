---
import ToolLayout from '../layouts/ToolLayout.astro';
import RasterBatch from '../components/RasterBatch.astro';
---

<ToolLayout slug="bmp-to-ico">
  <RasterBatch to="ico" accept="image/bmp,.bmp" fromLabel="BMP" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free BMP to ICO converter packs each BMP into a Windows icon (.ico) with 16, 32, 48, 64, 128 and 256-pixel sizes for favicons and app icons. Everything runs
      entirely in your browser — your images are never uploaded to a server.
    </p>
    <p>
      Drop a single image or a whole batch at once, optionally resize by the longest side,
      and preview each result before you download. Conversions happen offline through the
      browser's canvas, so the tool works without a network connection and nothing leaves your device.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="upc-generator">
  <div class="grid gap-6 lg:grid-cols-[1fr_320px]">

    <div class="flex flex-col gap-4">
      <div id="up-stage" class="flex min-h-55 items-center justify-center overflow-auto rounded-md border border-hairline bg-white p-6">
        <canvas id="up-canvas" class="max-w-full"></canvas>
      </div>

      <p class="text-[13px] text-ink-tertiary">
        Full code (check digit added automatically):
        <span id="up-full" class="font-mono text-ink"></span>
      </p>
      <p id="up-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

      <div class="flex flex-wrap gap-2">
        <button id="up-png" type="button" class="btn btn-primary">Download PNG</button>
        <button id="up-svg" type="button" class="btn btn-secondary">Download SVG</button>
        <button id="up-jpg" type="button" class="btn btn-secondary">Download JPG</button>
        <button id="up-copy" type="button" class="btn btn-tertiary">Copy PNG</button>
      </div>
    </div>

    <div class="flex flex-col gap-4">

      <div class="flex rounded-md border border-hairline p-0.5 text-sm">
        <button id="up-mode-single" type="button" class="mode-tab flex-1 rounded-[5px] px-3 py-1.5">Single</button>
        <button id="up-mode-batch" type="button" class="mode-tab flex-1 rounded-[5px] px-3 py-1.5">Batch</button>
      </div>

      <div id="up-single-pane" class="flex flex-col gap-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          First 11 digits
          <input id="up-digits" class="field font-mono" maxlength="12" inputmode="numeric" placeholder="03600029145" spellcheck="false" autocomplete="off" />
        </label>
        <button id="up-rand" type="button" class="btn btn-secondary self-start">Randomize</button>
      </div>

      <div id="up-batch-pane" class="hidden flex-col gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Codes (one 11- or 12-digit code per line)
          <textarea id="up-batch-text" class="field min-h-28 resize-y font-mono text-[13px]" spellcheck="false" autocomplete="off" placeholder="03600029145&#10;01234567890"></textarea>
        </label>
        <details class="rounded-md border border-hairline px-3 py-2 text-sm text-ink-subtle">
          <summary class="cursor-pointer select-none">Fill from a sequence</summary>
          <div class="mt-3 grid grid-cols-3 gap-2">
            <label class="flex flex-col gap-1 text-[13px]">Start
              <input id="up-seq-start" class="field font-mono" inputmode="numeric" value="03600029145" /></label>
            <label class="flex flex-col gap-1 text-[13px]">Count
              <input id="up-seq-count" class="field font-mono" inputmode="numeric" value="10" /></label>
            <label class="flex flex-col gap-1 text-[13px]">Step
              <input id="up-seq-step" class="field font-mono" inputmode="numeric" value="1" /></label>
          </div>
          <button id="up-seq-fill" type="button" class="btn btn-secondary mt-3">Generate sequence</button>
          <p class="mt-2 text-[12px] text-ink-tertiary">No cap on how many you generate — the whole sheet renders locally.</p>
        </details>
      </div>

      <div class="h-px bg-hairline"></div>

      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Scale <span id="up-scale-v" class="text-ink-tertiary">3</span>
          <input id="up-scale" type="range" min="1" max="8" value="3" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Bar height <span id="up-height-v" class="text-ink-tertiary">20</span>
          <input id="up-height" type="range" min="8" max="50" value="20" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Quiet zone <span id="up-quiet-v" class="text-ink-tertiary">10</span>
          <input id="up-quiet" type="range" min="0" max="30" value="10" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Font size <span id="up-font-v" class="text-ink-tertiary">10</span>
          <input id="up-font" type="range" min="6" max="20" value="10" />
        </label>
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Rotation
        <select id="up-rotate" class="field">
          <option value="N">None</option>
          <option value="R">90° right</option>
          <option value="L">90° left</option>
          <option value="I">180°</option>
        </select>
      </label>

      <div class="grid grid-cols-3 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Bars
          <input id="up-bar" type="color" value="#000000" class="h-9 w-full cursor-pointer rounded-md border border-hairline bg-transparent" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Background
          <input id="up-bg" type="color" value="#ffffff" class="h-9 w-full cursor-pointer rounded-md border border-hairline bg-transparent" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Text
          <input id="up-textcolor" type="color" value="#000000" class="h-9 w-full cursor-pointer rounded-md border border-hairline bg-transparent" />
        </label>
      </div>

      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="up-label" type="checkbox" class="accent-primary" checked /> Show human-readable text
      </label>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free UPC code generator creates valid UPC-A barcodes — the 12-digit
      retail barcodes scanned at checkout across North America. Enter the first
      11 digits (or hit Randomize) and the tool computes the correct mod-10
      check digit and renders a scannable barcode. Tune the scale, bar height,
      quiet zone, rotation, colors and human-readable font, then download as
      PNG, SVG or JPG — SVG export is free here, no subscription. Need a batch?
      Switch to Batch mode, paste or generate a sequence with no artificial
      limit, and download every code as a single print-ready sheet.
    </p>
  </div>
</ToolLayout>

<style>
  .mode-tab { color: var(--color-ink-subtle); transition: background-color .12s, color .12s; }
  .mode-tab[data-active='true'] { background-color: var(--color-surface-1); color: var(--color-ink); }
</style>

<script>
  import { toCanvas, toSVG, type RenderOpts } from '../lib/barcode';
  import { gtinCheckDigit, randInt } from '../lib/random';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const digitsEl = $<HTMLInputElement>('up-digits');
  const batchTextEl = $<HTMLTextAreaElement>('up-batch-text');
  const fullEl = $('up-full');
  const canvas = $<HTMLCanvasElement>('up-canvas');
  const err = $('up-error');

  const scaleEl = $<HTMLInputElement>('up-scale');
  const heightEl = $<HTMLInputElement>('up-height');
  const quietEl = $<HTMLInputElement>('up-quiet');
  const fontEl = $<HTMLInputElement>('up-font');
  const rotateEl = $<HTMLSelectElement>('up-rotate');
  const barEl = $<HTMLInputElement>('up-bar');
  const bgEl = $<HTMLInputElement>('up-bg');
  const textColorEl = $<HTMLInputElement>('up-textcolor');
  const labelEl = $<HTMLInputElement>('up-label');

  const singlePane = $('up-single-pane');
  const batchPane = $('up-batch-pane');
  const tabSingle = $<HTMLButtonElement>('up-mode-single');
  const tabBatch = $<HTMLButtonElement>('up-mode-batch');

  let mode: 'single' | 'batch' = 'single';
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const noHash = (c: string) => c.replace('#', '');

  function toUpc(raw: string): string | null {
    const p = raw.replace(/\D/g, '').slice(0, 11);
    if (p.length !== 11) return null;
    return p + gtinCheckDigit(p);
  }

  function opts(code: string): RenderOpts {
    return {
      bcid: 'upca',
      text: code,
      scale: Number(scaleEl.value),
      height: Number(heightEl.value),
      includetext: labelEl.checked,
      textsize: Number(fontEl.value),
      rotate: rotateEl.value,
      barcolor: noHash(barEl.value),
      backgroundcolor: noHash(bgEl.value),
      textcolor: noHash(textColorEl.value),
      paddingwidth: Number(quietEl.value),
      paddingheight: 4,
    };
  }

  async function drawSingle() {
    const code = toUpc(digitsEl.value);
    if (!code) { setErr('Enter exactly 11 digits.'); fullEl.textContent = ''; return; }
    fullEl.textContent = code;
    try {
      await toCanvas(canvas, opts(code));
      setErr('');
    } catch { setErr('Could not render barcode.'); }
  }

  async function drawBatch() {
    const codes = batchTextEl.value.split('\n').map(toUpc).filter(Boolean) as string[];
    if (!codes.length) { setErr('Enter at least one 11- or 12-digit code.'); fullEl.textContent = ''; return; }
    fullEl.textContent = `${codes.length} code${codes.length > 1 ? 's' : ''}`;
    try {
      const tiles: HTMLCanvasElement[] = [];
      for (const code of codes) {
        const c = document.createElement('canvas');
        await toCanvas(c, opts(code));
        tiles.push(c);
      }
      const gap = 16;
      const width = Math.max(...tiles.map((t) => t.width));
      const height = tiles.reduce((s, t) => s + t.height, 0) + gap * (tiles.length - 1);
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext('2d')!;
      ctx.fillStyle = bgEl.value;
      ctx.fillRect(0, 0, width, height);
      let y = 0;
      for (const t of tiles) {
        ctx.drawImage(t, (width - t.width) / 2, y);
        y += t.height + gap;
      }
      setErr('');
    } catch { setErr('Could not render one of the codes.'); }
  }

  const draw = () => (mode === 'single' ? drawSingle() : drawBatch());

  function setMode(m: 'single' | 'batch') {
    mode = m;
    singlePane.classList.toggle('hidden', m !== 'single');
    batchPane.classList.toggle('hidden', m !== 'batch');
    batchPane.classList.toggle('flex', m === 'batch');
    tabSingle.dataset.active = String(m === 'single');
    tabBatch.dataset.active = String(m === 'batch');
    draw();
  }

  function randomize() {
    let s = '';
    for (let i = 0; i < 11; i++) s += randInt(0, 9);
    digitsEl.value = s;
    draw();
  }

  function fillSequence() {
    const start = ($<HTMLInputElement>('up-seq-start').value.replace(/\D/g, '') || '0').slice(0, 11);
    const count = Math.max(1, Number($<HTMLInputElement>('up-seq-count').value) || 1);
    const step = Number($<HTMLInputElement>('up-seq-step').value) || 1;
    const width = start.length;
    let n = Number(start);
    const lines: string[] = [];
    for (let i = 0; i < count; i++) {
      lines.push(String(Math.max(0, n)).padStart(width, '0').slice(0, 11));
      n += step;
    }
    batchTextEl.value = lines.join('\n');
    draw();
  }

  function download(href: string, name: string) {
    const a = document.createElement('a'); a.href = href; a.download = name; a.click();
  }
  const outName = () => (mode === 'single' ? (toUpc(digitsEl.value) ?? 'upc') : 'upc-batch');

  digitsEl.addEventListener('input', drawSingle);
  batchTextEl.addEventListener('input', () => { if (mode === 'batch') draw(); });
  [scaleEl, heightEl, quietEl, fontEl].forEach((el) => el.addEventListener('input', () => {
    $('up-scale-v').textContent = scaleEl.value;
    $('up-height-v').textContent = heightEl.value;
    $('up-quiet-v').textContent = quietEl.value;
    $('up-font-v').textContent = fontEl.value;
    draw();
  }));
  [rotateEl, barEl, bgEl, textColorEl, labelEl].forEach((el) => el.addEventListener('input', draw));

  $('up-rand').addEventListener('click', randomize);
  $('up-seq-fill').addEventListener('click', fillSequence);
  tabSingle.addEventListener('click', () => setMode('single'));
  tabBatch.addEventListener('click', () => setMode('batch'));

  $('up-png').addEventListener('click', () => download(canvas.toDataURL('image/png'), `${outName()}.png`));
  $('up-jpg').addEventListener('click', () => download(canvas.toDataURL('image/jpeg', 0.92), `${outName()}.jpg`));
  $('up-svg').addEventListener('click', async () => {
    const code = mode === 'single' ? toUpc(digitsEl.value)
      : (batchTextEl.value.split('\n').map(toUpc).filter(Boolean)[0] as string | undefined);
    if (!code) { setErr('Enter a valid code first.'); return; }
    try {
      const url = URL.createObjectURL(new Blob([await toSVG(opts(code))], { type: 'image/svg+xml' }));
      download(url, `${code}.svg`);
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch { setErr('Could not export SVG.'); }
  });
  $('up-copy').addEventListener('click', () => {
    canvas.toBlob(async (blob) => {
      if (!blob || !navigator.clipboard?.write) return;
      try { await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]); } catch {}
    });
  });

  digitsEl.value = '03600029145';
  setMode('single');
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const PRESENTATION_TARGETS = ['pptx', 'ppt', 'odp', 'pdf'];
---

<ToolLayout slug="presentation-converter">
  <ArchiveConvert slug="presentation-converter" targets={PRESENTATION_TARGETS} noun="presentation" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online presentation converter converts between slideshow formats —
      including PowerPoint PPT and PPTX, Apple Keynote (KEY), OpenDocument ODP, and
      templates like POT, POTX and PPS. Upload a file, pick a target format (PPTX,
      PPT, ODP or PDF), and convert.
    </p>
    <p>
      Presentation formats are proprietary and can't be read reliably in a browser,
      so conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

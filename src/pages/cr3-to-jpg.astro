---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="cr3-to-jpg">
  <ArchiveConvert slug="cr3-to-jpg" from="cr3" to="jpg" noun="RAW photo" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CR3 to JPG converter converts Canon CR3 RAW photos to standard JPG images.
    </p>
    <p>
      Conversion is handled on our servers, because these
      formats can't be decoded in a browser. Your file is uploaded to our servers, converted, and returned as a download link.
    </p>
  </div>
</ToolLayout>

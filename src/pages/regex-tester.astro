---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="regex-tester">
  <div class="flex flex-col gap-4">

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      <label for="re-flavor">Flavor</label>
      <select id="re-flavor" class="field w-full sm:w-64">
        <option value="js">JavaScript</option>
        <option value="pcre">PCRE2 (PHP)</option>
        <option value="python">Python</option>
        <option value="go">Golang (RE2)</option>
        <option value="java">Java</option>
        <option value="dotnet">.NET (C#)</option>
        <option value="rust">Rust</option>
      </select>
      <p id="re-flavornote" class="text-[12px] text-ink-tertiary"></p>
    </div>

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span class="flex items-center justify-between">
        Pattern
        <button id="re-copy" type="button" class="btn btn-secondary !min-h-0 !px-2 !py-1 text-[12px]">Copy</button>
      </span>
      <span class="flex items-center gap-2">
        <span class="text-ink-tertiary">/</span>
        <input id="re-pattern" type="text" class="field font-mono" value="(?<user>\w+)@(?<domain>[\w.]+)" spellcheck="false" autocomplete="off" />
        <span class="text-ink-tertiary">/</span>
        <input id="re-flags" type="text" class="field w-24 font-mono" value="gm" spellcheck="false" autocomplete="off" aria-label="Flags" />
      </span>
    </div>

    <div id="re-flagchips" class="flex flex-wrap gap-2"></div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Test string
      <div class="copy-wrap">
        <textarea id="re-input" class="field min-h-40 resize-y font-mono text-[13px]" spellcheck="false">Contact us at hello@toolsilk.com or support@example.org today.
Ping ada@dev.io and grace@compute.net for access.</textarea>
        <button type="button" class="copy-icon" data-copy-target="#re-input" aria-label="Copy"></button>
      </div>
    </label>

    <p id="re-status" class="text-[13px] text-ink-subtle" aria-live="polite"></p>

    <div>
      <span class="text-[13px] text-ink-subtle">Highlighted matches</span>
      <div id="re-output" class="panel panel-lift mt-2 min-h-24 whitespace-pre-wrap break-words p-4 font-mono text-[13px] leading-relaxed"></div>
    </div>

    <div class="mt-2 flex gap-1 border-b border-hairline">
      <button data-tab="matches" class="re-tab -mb-px border-b-2 px-3 py-2 text-[13px]">Match details</button>
      <button data-tab="substitution" class="re-tab -mb-px border-b-2 px-3 py-2 text-[13px]">Substitution</button>
      <button data-tab="explain" class="re-tab -mb-px border-b-2 px-3 py-2 text-[13px]">Explanation</button>
    </div>

    <div id="tab-matches" class="re-panel">
      <div id="re-matches"></div>
    </div>

    <div id="tab-substitution" class="re-panel hidden">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Replacement <span class="text-ink-tertiary">($1, $&lt;name&gt;, $&amp;, $`, $')</span>
        <input id="re-replace" type="text" class="field font-mono" value="$<user> [at] $<domain>" spellcheck="false" autocomplete="off" />
      </label>
      <div class="mt-3">
        <span class="text-[13px] text-ink-subtle">Result</span>
        <div id="re-subresult" class="panel panel-lift mt-2 min-h-16 whitespace-pre-wrap break-words p-4 font-mono text-[13px] leading-relaxed"></div>
      </div>
    </div>

    <div id="tab-explain" class="re-panel hidden">
      <div id="re-explain" class="panel mt-1 p-2"></div>
    </div>

    <details class="panel mt-2 p-4 text-[13px] text-ink-subtle">
      <summary class="cursor-pointer text-ink select-none">Quick reference</summary>
      <div id="re-cheat" class="mt-3 grid grid-cols-1 gap-x-6 gap-y-1 sm:grid-cols-2 md:grid-cols-3"></div>
    </details>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free regex tester lets you build, debug, and understand regular
      expressions with instant feedback across multiple flavors — JavaScript,
      PCRE2 (PHP), Python, Golang, Java, .NET, and Rust. Pick a flavor to adapt
      the available flags and named-group syntax; non-JS flavors are approximated
      with warnings when a target engine
      lacks a feature (for example, RE2 has no lookaround or backreferences).
      Type a pattern and toggle flags, paste your test string, and every match
      is highlighted live. The
      match details panel breaks down each match with its position, numbered
      groups, and named capture groups. The substitution tab shows a live
      replace result with full support for <code>$1</code>, <code>$&lt;name&gt;</code>,
      <code>$&amp;</code>, <code>$`</code>, and <code>$'</code> tokens. The
      explanation tab decodes your pattern token by token, and a built-in quick
      reference covers the common syntax.
    </p>
  </div>
</ToolLayout>

<style>
  .re-tab { color: var(--color-ink-subtle); border-color: transparent; cursor: pointer; }
  .re-tab:hover { color: var(--color-ink); }
  .re-tab[aria-selected='true'] { color: var(--color-ink); border-color: var(--color-primary); }
  .flag-chip { cursor: pointer; user-select: none; }
  .flag-chip input { display: none; }
  .flag-chip span {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 4px 10px; border-radius: 9999px;
    border: 1px solid var(--color-hairline);
    background: var(--color-surface-1); color: var(--color-ink-subtle);
    font-size: 12px; transition: all 0.12s ease;
  }
  .flag-chip input:checked + span {
    border-color: var(--color-primary);
    color: var(--color-ink);
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
  }
  .flag-chip code { font-family: var(--font-mono); font-weight: 600; color: var(--color-ink); }
</style>

<script>
  const patternEl = document.getElementById('re-pattern') as HTMLInputElement;
  const flagsEl = document.getElementById('re-flags') as HTMLInputElement;
  const inputEl = document.getElementById('re-input') as HTMLTextAreaElement;
  const replaceEl = document.getElementById('re-replace') as HTMLInputElement;
  const output = document.getElementById('re-output')!;
  const status = document.getElementById('re-status')!;
  const matchesBox = document.getElementById('re-matches')!;
  const subResult = document.getElementById('re-subresult')!;
  const explainBox = document.getElementById('re-explain')!;
  const flagChips = document.getElementById('re-flagchips')!;
  const cheatBox = document.getElementById('re-cheat')!;
  const flavorEl = document.getElementById('re-flavor') as HTMLSelectElement;
  const flavorNote = document.getElementById('re-flavornote')!;

  const esc = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  const FLAG_LABELS: Record<string, string> = {
    g: 'global — find all matches',
    i: 'ignore case',
    m: 'multiline — ^ and $ match line breaks',
    s: 'dotAll — . matches newlines',
    x: 'extended — ignore whitespace & allow # comments',
    u: 'unicode',
    y: 'sticky — match at lastIndex only',
    d: 'indices — capture group positions',
    a: 'ASCII-only \\w \\d \\s',
  };

  interface Flavor {
    label: string;
    flags: string;              
    note: string;               
    noLookaround?: boolean;     
    noBackref?: boolean;        
    pyNames?: boolean;          
  }
  const FLAVORS: Record<string, Flavor> = {
    js:     { label: 'JavaScript', flags: 'gimsuyd', note: 'Native — runs on your browser’s JS engine.' },
    pcre:   { label: 'PCRE2 (PHP)', flags: 'imsxu', note: 'Approximated with the JS engine. PCRE extras (recursion, atomic/possessive) aren’t emulated.' },
    python: { label: 'Python (re)', flags: 'imsxa', note: 'Approximated with the JS engine. Python (?P<name>) named groups are supported.', pyNames: true },
    go:     { label: 'Golang (RE2)', flags: 'ims', note: 'RE2 has no lookaround or backreferences — patterns using them are flagged.', noLookaround: true, noBackref: true },
    java:   { label: 'Java', flags: 'imsxu', note: 'Approximated with the JS engine. Most Java syntax overlaps.' },
    dotnet: { label: '.NET (C#)', flags: 'imsx', note: 'Approximated with the JS engine. .NET balancing groups aren’t emulated.' },
    rust:   { label: 'Rust (regex)', flags: 'imsxu', note: 'RE2-based — no lookaround or backreferences; patterns using them are flagged.', noLookaround: true, noBackref: true },
  };

  function curFlavor(): Flavor {
    return FLAVORS[flavorEl.value] ?? FLAVORS.js;
  }

  let flagBoxes: HTMLInputElement[] = [];
  function renderFlagChips() {
    const f = curFlavor();
    flagChips.innerHTML = f.flags
      .split('')
      .map(
        (flag) =>
          `<label class="flag-chip" title="${FLAG_LABELS[flag] ?? flag}"><input type="checkbox" data-flag="${flag}" /><span><code>${flag}</code></span></label>`,
      )
      .join('');
    flagBoxes = Array.from(flagChips.querySelectorAll('input[data-flag]')) as HTMLInputElement[];
    flagBoxes.forEach((b) => b.addEventListener('change', syncTextFromChips));
  }

  function syncChipsFromText() {
    const set = new Set(flagsEl.value.split(''));
    flagBoxes.forEach((b) => (b.checked = set.has(b.dataset.flag!)));
  }
  function syncTextFromChips() {
    flagsEl.value = flagBoxes.filter((b) => b.checked).map((b) => b.dataset.flag).join('');
    run();
  }

  function onFlavorChange() {
    const f = curFlavor();
    flavorNote.textContent = f.note;

    flagsEl.value = flagsEl.value.split('').filter((fl) => f.flags.includes(fl)).join('');
    renderFlagChips();
    syncChipsFromText();
    run();
  }
  flavorEl.addEventListener('change', onFlavorChange);

  const tabs = Array.from(document.querySelectorAll('.re-tab')) as HTMLButtonElement[];
  function selectTab(name: string) {
    tabs.forEach((t) => {
      const on = t.dataset.tab === name;
      t.setAttribute('aria-selected', String(on));
      document.getElementById('tab-' + t.dataset.tab)!.classList.toggle('hidden', !on);
    });
  }
  tabs.forEach((t) => t.addEventListener('click', () => selectTab(t.dataset.tab!)));
  selectTab('matches');

  const MATCH_COLORS = ['#5e6ad2', '#7a7fad', '#828fff'];

  function toJsPattern(src: string, f: Flavor): string {
    if (f.pyNames) {

      src = src.replace(/\(\?P<([^>]+)>/g, '(?<$1>').replace(/\(\?P=([A-Za-z_]\w*)\)/g, '\\k<$1>');
    }

    if (flagsEl.value.includes('x')) src = stripExtended(src);
    return src;
  }

  function stripExtended(src: string): string {
    let out = '', inClass = false;
    for (let i = 0; i < src.length; i++) {
      const c = src[i];
      if (c === '\\') { out += c + (src[i + 1] ?? ''); i++; continue; }
      if (c === '[') inClass = true;
      else if (c === ']') inClass = false;
      if (!inClass) {
        if (/\s/.test(c)) continue;
        if (c === '#') { while (i < src.length && src[i] !== '\n') i++; continue; }
      }
      out += c;
    }
    return out;
  }

  function flavorWarning(src: string, f: Flavor): string {
    if (f.noLookaround && /\(\?<?[=!]/.test(src)) return `${f.label} has no lookahead/lookbehind support.`;
    if (f.noBackref && /\\[1-9]|\\k<[^>]+>/.test(src)) return `${f.label} has no backreference support.`;
    return '';
  }

  function buildRegex(): RegExp | null {
    const f = curFlavor();
    let flags = flagsEl.value;
    // x (extended) has no JS equivalent — strip it for execution but keep it in the field.
    let exec = flags.replace(/[^gimsuyd]/g, '');
    if (!exec.includes('g')) exec += 'g';
    const warn = flavorWarning(patternEl.value, f);
    try {
      const re = new RegExp(toJsPattern(patternEl.value, f), exec);
      status.textContent = warn;
      status.style.color = warn ? '#d29922' : '';
      return re;
    } catch (e) {
      status.textContent = 'Invalid regex: ' + (e as Error).message;
      status.style.color = '#e5484d';
      return null;
    }
  }

  interface MatchRec { m: RegExpExecArray; index: number; }

  function collectMatches(re: RegExp, text: string): MatchRec[] {
    const out: MatchRec[] = [];
    let m: RegExpExecArray | null;
    re.lastIndex = 0;
    while ((m = re.exec(text)) !== null) {
      out.push({ m, index: m.index });
      if (m[0] === '') re.lastIndex++; // avoid infinite loop on empty matches
      if (out.length > 10000) break; // ponytail: hard cap, no runaway on pathological patterns
    }
    return out;
  }

  function run() {
    const text = inputEl.value;
    matchesBox.innerHTML = '';
    subResult.textContent = '';

    if (!patternEl.value) {
      output.textContent = text;
      status.textContent = '';
      renderExplain('');
      return;
    }
    const re = buildRegex();
    if (!re) {
      output.textContent = text;
      renderExplain(patternEl.value);
      return;
    }

    const matches = collectMatches(re, text);

    // Highlight
    let last = 0, html = '';
    matches.forEach(({ m, index }, i) => {
      const color = MATCH_COLORS[i % MATCH_COLORS.length];
      html += esc(text.slice(last, index));
      html += `<mark style="background:color-mix(in srgb,${color} 40%,transparent);color:var(--color-ink);border-radius:3px;padding:0 1px" title="Match ${i + 1} @ ${index}">${esc(m[0]) || '&nbsp;'}</mark>`;
      last = index + m[0].length;
    });
    html += esc(text.slice(last));
    output.innerHTML = html || '<span class="text-ink-tertiary">No text.</span>';

    const n = matches.length;
    status.textContent = `${n} match${n === 1 ? '' : 'es'}`;

    // Match details
    if (n === 0) {
      matchesBox.innerHTML = '<p class="text-[13px] text-ink-tertiary py-2">No matches.</p>';
    } else {
      matchesBox.innerHTML = matches
        .map(({ m, index }, i) => renderMatch(m, index, i))
        .join('');
    }

    // Substitution
    renderSubstitution(re, text);

    // Explanation
    renderExplain(patternEl.value);
  }

  function renderMatch(m: RegExpExecArray, index: number, i: number): string {
    const color = MATCH_COLORS[i % MATCH_COLORS.length];
    const end = index + m[0].length;
    let rows = `<div class="flex items-baseline gap-2">
      <span class="inline-block h-2 w-2 rounded-full" style="background:${color}"></span>
      <span class="text-ink">Match ${i + 1}</span>
      <span class="text-ink-tertiary text-[12px]">[${index}–${end}]</span>
      <span class="text-ink font-mono">${esc(m[0]) || '<span class=\'text-ink-tertiary\'>(empty)</span>'}</span>
    </div>`;

    // Numbered groups
    for (let g = 1; g < m.length; g++) {
      const val = m[g];
      rows += `<div class="ml-4 flex items-baseline gap-2 text-[12px]">
        <span class="text-ink-tertiary">Group ${g}</span>
        <span class="${val === undefined ? 'text-ink-tertiary italic' : 'text-ink'} font-mono">${val === undefined ? 'undefined' : esc(val) || '(empty)'}</span>
      </div>`;
    }
    // Named groups
    if (m.groups) {
      for (const [name, val] of Object.entries(m.groups)) {
        rows += `<div class="ml-4 flex items-baseline gap-2 text-[12px]">
          <span class="text-primary-hover font-mono">&lt;${esc(name)}&gt;</span>
          <span class="${val === undefined ? 'text-ink-tertiary italic' : 'text-ink'} font-mono">${val === undefined ? 'undefined' : esc(val as string) || '(empty)'}</span>
        </div>`;
      }
    }
    return `<div class="border-b border-hairline py-2 last:border-0">${rows}</div>`;
  }

  function renderSubstitution(re: RegExp, text: string) {
    try {
      subResult.textContent = text.replace(re, replaceEl.value);
    } catch (e) {
      subResult.textContent = '';
      subResult.innerHTML = `<span style="color:#e5484d">${esc((e as Error).message)}</span>`;
    }
  }

  // ---- Explanation: tokenize the pattern ----
  const CLASS_DESC: Record<string, string> = {
    '\\d': 'digit (0–9)', '\\D': 'non-digit',
    '\\w': 'word char (a–z, 0–9, _)', '\\W': 'non-word char',
    '\\s': 'whitespace', '\\S': 'non-whitespace',
    '\\b': 'word boundary', '\\B': 'non-word boundary',
    '\\n': 'newline', '\\r': 'carriage return', '\\t': 'tab',
    '.': 'any char (except newline)', '^': 'start of string/line',
    '$': 'end of string/line',
  };

  function explainTokens(src: string): { tok: string; desc: string }[] {
    const out: { tok: string; desc: string }[] = [];
    let i = 0;
    const push = (tok: string, desc: string) => out.push({ tok, desc });
    while (i < src.length) {
      const c = src[i];
      // Escapes
      if (c === '\\') {
        const two = src.slice(i, i + 2);
        if (CLASS_DESC[two]) { push(two, CLASS_DESC[two]); i += 2; continue; }
        push(two, `literal "${src[i + 1] ?? ''}"`);
        i += 2; continue;
      }
      // Groups
      if (c === '(') {
        if (src.startsWith('(?<', i) && src[i + 3] !== '=' && src[i + 3] !== '!') {
          const gt = src.indexOf('>', i);
          const name = src.slice(i + 3, gt);
          push(`(?<${name}>`, `named capture group "${name}"`);
          i = gt + 1; continue;
        }
        if (src.startsWith('(?:', i)) { push('(?:', 'non-capturing group'); i += 3; continue; }
        if (src.startsWith('(?=', i)) { push('(?=', 'positive lookahead'); i += 3; continue; }
        if (src.startsWith('(?!', i)) { push('(?!', 'negative lookahead'); i += 3; continue; }
        if (src.startsWith('(?<=', i)) { push('(?<=', 'positive lookbehind'); i += 4; continue; }
        if (src.startsWith('(?<!', i)) { push('(?<!', 'negative lookbehind'); i += 4; continue; }
        push('(', 'start capture group'); i++; continue;
      }
      if (c === ')') { push(')', 'end group'); i++; continue; }
      // Character class
      if (c === '[') {
        let j = i + 1;
        const neg = src[j] === '^';
        while (j < src.length && src[j] !== ']') { if (src[j] === '\\') j++; j++; }
        const body = src.slice(i, j + 1);
        push(body, neg ? 'any char NOT in set' : 'any char in set');
        i = j + 1; continue;
      }
      // Quantifiers
      if (c === '*') { push('*', '0 or more'); i++; continue; }
      if (c === '+') { push('+', '1 or more'); i++; continue; }
      if (c === '?') {
        if (out.length && /[*+?}]$/.test(out[out.length - 1].tok)) { push('?', 'lazy (as few as possible)'); i++; continue; }
        push('?', '0 or 1 (optional)'); i++; continue;
      }
      if (c === '{') {
        const close = src.indexOf('}', i);
        if (close > -1) {
          const q = src.slice(i, close + 1);
          const inner = src.slice(i + 1, close);
          const [a, b] = inner.split(',');
          let desc = `exactly ${a} times`;
          if (inner.includes(',')) desc = b === undefined || b === '' ? `${a} or more times` : `${a} to ${b} times`;
          push(q, desc); i = close + 1; continue;
        }
      }
      if (c === '|') { push('|', 'OR / alternation'); i++; continue; }
      if (CLASS_DESC[c]) { push(c, CLASS_DESC[c]); i++; continue; }
      // Literal run
      let j = i;
      while (j < src.length && !'\\()[]{}*+?|^$.'.includes(src[j])) j++;
      const lit = src.slice(i, j);
      push(lit, `literal "${lit}"`);
      i = j;
    }
    return out;
  }

  function renderExplain(src: string) {
    if (!src) { explainBox.innerHTML = '<p class="text-[13px] text-ink-tertiary p-2">Enter a pattern to see its breakdown.</p>'; return; }
    const toks = explainTokens(src);
    explainBox.innerHTML = toks
      .map(
        (t) =>
          `<div class="flex items-baseline gap-3 border-b border-hairline px-2 py-1.5 last:border-0 text-[13px]">
            <code class="text-ink shrink-0" style="min-width:5rem">${esc(t.tok)}</code>
            <span class="text-ink-subtle">${esc(t.desc)}</span>
          </div>`,
      )
      .join('');
  }

  // ---- Cheatsheet ----
  const CHEAT: [string, string][] = [
    ['.', 'any char'], ['\\d', 'digit'], ['\\w', 'word char'], ['\\s', 'whitespace'],
    ['\\b', 'word boundary'], ['^', 'start'], ['$', 'end'], ['[abc]', 'set'],
    ['[^abc]', 'not in set'], ['[a-z]', 'range'], ['a*', '0+'], ['a+', '1+'],
    ['a?', 'optional'], ['a{2,4}', '2 to 4'], ['a|b', 'a or b'], ['(…)', 'capture'],
    ['(?:…)', 'non-capture'], ['(?<n>…)', 'named'], ['(?=…)', 'lookahead'], ['(?<=…)', 'lookbehind'],
  ];
  cheatBox.innerHTML = CHEAT.map(
    ([sym, desc]) => `<div class="flex gap-2"><code class="text-ink" style="min-width:4rem">${esc(sym)}</code><span>${esc(desc)}</span></div>`,
  ).join('');

  // ---- Copy ----
  document.getElementById('re-copy')!.addEventListener('click', () => {
    navigator.clipboard?.writeText(patternEl.value);
  });

  // ---- Wire up ----
  flagsEl.addEventListener('input', () => { syncChipsFromText(); run(); });
  [patternEl, inputEl, replaceEl].forEach((el) => el.addEventListener('input', run));
  renderFlagChips();
  flavorNote.textContent = curFlavor().note;
  syncChipsFromText();
  run();
</script>

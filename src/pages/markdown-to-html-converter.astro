---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="markdown-to-html-converter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <label class="flex items-center gap-2" title="GitHub Flavored Markdown: tables, task lists, strikethrough, autolinks">
        <input id="m2h-gfm" type="checkbox" checked class="h-4 w-4" />
        GFM (tables, task lists)
      </label>
      <label class="flex items-center gap-2" title="Turn single newlines into <br> line breaks">
        <input id="m2h-breaks" type="checkbox" class="h-4 w-4" />
        Line breaks
      </label>
      <label class="flex items-center gap-2" title="Add heading IDs so links can jump to sections">
        <input id="m2h-ids" type="checkbox" checked class="h-4 w-4" />
        Heading IDs
      </label>
      <label class="flex items-center gap-2" title="Wrap the output in a full, styled HTML document ready to save and open">
        <input id="m2h-doc" type="checkbox" class="h-4 w-4" />
        Full HTML document
      </label>
      <label class="btn btn-tertiary cursor-pointer">
        Upload .md
        <input id="m2h-file" type="file" accept=".md,.markdown,.mdown,.mkd,.txt,text/markdown,text/plain" class="hidden" />
      </label>
    </div>

    <div id="m2h-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>Markdown input</span>
          <button id="m2h-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
        </span>
        <div class="copy-wrap"><div id="m2h-drop" class="hl-edit field p-0" style="height:24rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="m2h-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea id="m2h-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="Markdown input"></textarea>
        </div><button type="button" class="copy-icon" data-copy-target="#m2h-in" aria-label="Copy"></button></div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>HTML source</span>
          <span class="flex gap-2">
            <button id="m2h-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
          </span>
        </span>
        <div class="copy-wrap"><pre class="hl-block field" style="height:24rem;margin:0;overflow:auto;white-space:pre-wrap;word-break:break-word"><code id="m2h-out" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#m2h-out" aria-label="Copy"></button></div>
      </div>
    </div>

    <p id="m2h-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      Live preview
      <div id="m2h-preview" class="panel panel-lift p-4 text-ink" style="overflow:auto"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Markdown to HTML converter turns Markdown into clean HTML source and
      shows a live rendered preview, side by side, entirely in your browser — nothing
      you paste is ever uploaded. It supports full
      <strong>GitHub Flavored Markdown</strong>: headings, bold and italic,
      strikethrough, links and images, autolinks, inline and fenced code blocks with
      syntax highlighting, ordered, unordered and nested lists, task lists
      (<code>- [ ]</code> / <code>- [x]</code>), tables, blockquotes and horizontal
      rules. Both panes are syntax-highlighted and the output updates as you type.
    </p>
    <p>
      Toggle GFM extensions on or off, convert single newlines into <code>&lt;br&gt;</code>
      line breaks, and add automatic heading IDs so anchor links jump to the right
      section. Choose a plain HTML fragment for pasting into an existing page, or a
      complete, styled <code>&lt;!DOCTYPE html&gt;</code> document you can save and open
      straight in a browser. Upload or drag-and-drop a <code>.md</code> file, then copy
      the HTML or download it as a <code>.html</code> file. The rendered preview is
      sanitized so pasted markup can't run scripts, and errors are shown clearly instead
      of failing silently.
    </p>
  </div>
</ToolLayout>

<script>
  import { Marked } from 'marked';
  import DOMPurify from 'dompurify';
  import { hl, wireInput, loadHljs } from '../lib/highlight';

  const input = document.getElementById('m2h-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('m2h-in-hl')!;
  const output = document.getElementById('m2h-out')!;
  const preview = document.getElementById('m2h-preview')!;
  const err = document.getElementById('m2h-error')!;
  const statusEl = document.getElementById('m2h-status')!;
  const gfmBox = document.getElementById('m2h-gfm') as HTMLInputElement;
  const breaksBox = document.getElementById('m2h-breaks') as HTMLInputElement;
  const idsBox = document.getElementById('m2h-ids') as HTMLInputElement;
  const docBox = document.getElementById('m2h-doc') as HTMLInputElement;
  const drop = document.getElementById('m2h-drop')!;

  let rawOutput = ''; 

  function slugify(text: string): string {
    return text.toLowerCase().trim()
      .replace(/[^\w\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-') || 'section';
  }

  function wrapDoc(body: string, title: string): string {
    return `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>${title.replace(/[<>&]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[c]!))}</title>
<style>
  body { max-width: 48rem; margin: 2rem auto; padding: 0 1rem; font: 16px/1.6 -apple-system, system-ui, Segoe UI, Roboto, sans-serif; color: #1a1a1a; }
  pre { background: #f5f5f5; padding: 1rem; border-radius: 6px; overflow: auto; }
  code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9em; }
  pre code { padding: 0; }
  table { border-collapse: collapse; } th, td { border: 1px solid #ddd; padding: 6px 12px; }
  blockquote { border-left: 4px solid #ddd; margin: 0; padding-left: 1rem; color: #555; }
  img { max-width: 100%; }
</style>
</head>
<body>
${body}
</body>
</html>`;
  }

  function buildMarked() {
    const inst = new Marked({ gfm: gfmBox.checked, breaks: breaksBox.checked });
    if (idsBox.checked) {
      inst.use({
        renderer: {
          heading(token: any) {
            const text = this.parser.parseInline(token.tokens);
            const raw = token.tokens.map((t: any) => t.text ?? '').join('');
            return `<h${token.depth} id="${slugify(raw)}">${text}</h${token.depth}>\n`;
          },
        },
      });
    }
    return inst;
  }

  function showStatus(msg: string) {
    statusEl.textContent = msg;
    statusEl.classList.remove('hidden');
    statusEl.style.borderColor = '#27a644';
    statusEl.style.color = '#27a644';
  }

  async function convert() {
    err.classList.add('hidden');
    const md = input.value;
    if (!md.trim()) {
      rawOutput = '';
      output.textContent = '';
      preview.innerHTML = '';
      statusEl.classList.add('hidden');
      return;
    }
    try {
      const inst = buildMarked();
      const body = (inst.parse(md) as string).trim();
      const safe = DOMPurify.sanitize(body);
      preview.innerHTML = safe;
      const hljs = await loadHljs();
      preview.querySelectorAll('pre code').forEach((el) => hljs.highlightElement(el as HTMLElement));

      const firstHeading = md.match(/^#{1,6}\s+(.+)$/m)?.[1]?.trim() || 'Converted Markdown';
      rawOutput = docBox.checked ? wrapDoc(body, firstHeading) : body;
      await hl(output, rawOutput, 'xml');

      const words = (md.match(/\S+/g) || []).length;
      const bytes = new Blob([rawOutput]).size;
      showStatus(`${words} ${words === 1 ? 'word' : 'words'} in · ${bytes} bytes of HTML out ✓`);
    } catch (e) {
      rawOutput = '';
      output.textContent = '';
      preview.innerHTML = '';
      statusEl.classList.add('hidden');
      err.textContent = `Conversion failed: ${(e as Error).message}`;
      err.classList.remove('hidden');
    }
  }

  const rerender = wireInput(input, inHl, () => 'markdown', () => { void convert(); });

  gfmBox.addEventListener('change', () => { void convert(); });
  breaksBox.addEventListener('change', () => { void convert(); });
  idsBox.addEventListener('change', () => { void convert(); });
  docBox.addEventListener('change', () => { void convert(); });

  document.getElementById('m2h-clear')!.addEventListener('click', () => {
    input.value = '';
    rawOutput = '';
    output.textContent = '';
    preview.innerHTML = '';
    err.classList.add('hidden');
    statusEl.classList.add('hidden');
    rerender();
  });

  document.getElementById('m2h-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const blob = new Blob([rawOutput], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'converted.html';
    a.click();
    URL.revokeObjectURL(url);
  });

  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => { input.value = String(reader.result ?? ''); rerender(); void convert(); };
    reader.onerror = () => { err.textContent = 'Could not read file.'; err.classList.remove('hidden'); };
    reader.readAsText(file);
  }

  const fileInput = document.getElementById('m2h-file') as HTMLInputElement;
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  ['dragover', 'dragenter'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.style.outline = '2px solid #5e6ad2'; }));
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, () => { drop.style.outline = ''; }));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) loadFile(file);
  });

  input.value = [
    '# Markdown to HTML',
    '',
    'Convert **Markdown** into clean HTML with a *live* preview.',
    '',
    '- Tables, task lists and ~~strikethrough~~',
    '- [x] GitHub Flavored Markdown',
    '- [ ] Syntax-highlighted code',
    '',
    '```js',
    'const greet = (name) => `Hello, ${name}!`;',
    '```',
    '',
    '| Feature | Supported |',
    '| ------- | --------- |',
    '| Tables  | yes       |',
    '| Preview | yes       |',
    '',
    '> Blockquotes are supported too.',
  ].join('\n');
  rerender();
  void convert();
</script>

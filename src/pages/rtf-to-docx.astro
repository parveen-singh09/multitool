---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="rtf-to-docx">
  <ArchiveConvert slug="rtf-to-docx" from="rtf" to="docx" noun="document" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free RTF to DOCX converter converts Rich Text Format RTF documents to Microsoft Word DOCX.
    </p>
    <p>
      Conversion is handled on our servers, because these
      document formats can't be read reliably in a browser. Your file is uploaded
      to our servers, converted, and returned
      as a download link.
    </p>
  </div>
</ToolLayout>

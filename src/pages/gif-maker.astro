  function hitTest(canvasX: number, canvasY: number) {
    for (let i = stickerLayers.length - 1; i >= 0; i--) {
      const l = stickerLayers[i];
      if (!l.allFrames && (currentFrameIndex < l.frameStart || currentFrameIndex > l.frameEnd)) continue;

      const px = l.cx * canvasWidth;
      const py = l.cy * canvasHeight;
      const w = 60 * (l.scale / 100);
      const h = w * l.aspect;

      const dx = canvasX - px;
      const dy = canvasY - py;
      const rad = (-l.rotation * Math.PI) / 180;
      const lx = dx * Math.cos(rad) - dy * Math.sin(rad);
      const ly = dx * Math.sin(rad) + dy * Math.cos(rad);

      if (Math.abs(lx) <= w / 2 && Math.abs(ly) <= h / 2) {
        return { layer: l, type: 'sticker', handle: 'body' };
      }
    }

    for (let i = textLayers.length - 1; i >= 0; i--) {
      const l = textLayers[i];
      if (!l.allFrames && (currentFrameIndex < l.frameStart || currentFrameIndex > l.frameEnd)) continue;

      const px = l.cx * canvasWidth;
      const py = l.cy * canvasHeight;

      const fontPx = l.size;
      const fontStr = `${l.italic ? 'italic ' : ''}${l.bold ? 'bold ' : ''}${fontPx}px ${l.fontFamily}`;
      editorCtx.font = fontStr;
      const lines = (l.upper ? l.text.toUpperCase() : l.text).split('\n');
      let maxW = 0;
      lines.forEach((line) => {
        maxW = Math.max(maxW, editorCtx.measureText(line).width);
      });
      const w = maxW + 20;
      const h = lines.length * fontPx * 1.2 + 10;

      const dx = canvasX - px;
      const dy = canvasY - py;
      const rad = (-l.rotation * Math.PI) / 180;
      const lx = dx * Math.cos(rad) - dy * Math.sin(rad);
      const ly = dx * Math.sin(rad) + dy * Math.cos(rad);

      if (Math.abs(lx) <= w / 2 && Math.abs(ly) <= h / 2) {
        return { layer: l, type: 'text', handle: 'body' };
      }
    }

    return null;
  }

  function getHandleHit(sel: any, canvasX: number, canvasY: number) {
    const px = sel.cx * canvasWidth;
    const py = sel.cy * canvasHeight;

    let w = 0, h = 0;
    if (sel.type === 'text') {
      const fontPx = sel.size;
      editorCtx.font = `${sel.italic ? 'italic ' : ''}${sel.bold ? 'bold ' : ''}${fontPx}px ${sel.fontFamily}`;
      const lines = (sel.upper ? sel.text.toUpperCase() : sel.text).split('\n');
      let maxW = 0;
      lines.forEach((line: string) => {
        maxW = Math.max(maxW, editorCtx.measureText(line).width);
      });
      w = maxW + 20;
      h = lines.length * fontPx * 1.2 + 10;
    } else if (sel.type === 'sticker') {
      w = 60 * (sel.scale / 100) + 10;
      h = w * sel.aspect;
    }

    const dx = canvasX - px;
    const dy = canvasY - py;
    const rad = (-sel.rotation * Math.PI) / 180;
    const lx = dx * Math.cos(rad) - dy * Math.sin(rad);
    const ly = dx * Math.sin(rad) + dy * Math.cos(rad);

    const stalk = 15;
    const rx = 0;
    const ry = -h / 2 - stalk;
    if (Math.hypot(lx - rx, ly - ry) < 10) {
      return 'rotate';
    }

    const cornerRadius = 10;
    for (const sx of [-1, 1]) {
      for (const sy of [-1, 1]) {
        const cx = sx * w / 2;
        const cy = sy * h / 2;
        if (Math.hypot(lx - cx, ly - cy) < cornerRadius) {
          return 'resize';
        }
      }
    }

    if (Math.abs(lx) <= w / 2 && Math.abs(ly) <= h / 2) {
      return 'body';
    }

    return null;
  }

  let isPointerDown = false;
  let pointerMode: 'none' | 'drag' | 'resize' | 'rotate' = 'none';
  let dragStartOffsetX = 0;
  let dragStartOffsetY = 0;
  let initialScale = 100;
  let initialSize = 32;
  let initialRotation = 0;
  let initialDist = 0;
  let initialAngle = 0;

  editorCanvas.addEventListener('pointerdown', (ev) => {
    const rect = editorCanvas.getBoundingClientRect();
    const canvasX = ((ev.clientX - rect.left) / rect.width) * canvasWidth;
    const canvasY = ((ev.clientY - rect.top) / rect.height) * canvasHeight;

    isPointerDown = true;

    if (canvasMode === 'draw') {
      const strokeAll = ($('gf-draw-all-frames') as HTMLInputElement).checked;
      const startF = strokeAll ? 0 : Number(($('gf-draw-start-frame') as HTMLInputElement).value);
      const endF = strokeAll ? originalFrames.length - 1 : Number(($('gf-draw-end-frame') as HTMLInputElement).value);

      const stroke = {
        points: [{ x: canvasX / canvasWidth, y: canvasY / canvasHeight }],
        color: ($('gf-draw-color') as HTMLInputElement).value,
        size: Number(($('gf-draw-size') as HTMLInputElement).value),
        allFrames: strokeAll,
        frameStart: startF,
        frameEnd: endF
      };
      strokes.push(stroke);
      drawEditorFrame();
      return;
    }

    const sel = getSelectedLayer();
    if (sel) {
      const handle = getHandleHit(sel, canvasX, canvasY);
      if (handle === 'rotate') {
        pointerMode = 'rotate';
        initialRotation = sel.rotation;
        initialAngle = Math.atan2(canvasY - sel.cy * canvasHeight, canvasX - sel.cx * canvasWidth);
        editorCanvas.setPointerCapture(ev.pointerId);
        return;
      }
      if (handle === 'resize') {
        pointerMode = 'resize';
        initialDist = Math.hypot(canvasX - sel.cx * canvasWidth, canvasY - sel.cy * canvasHeight);
        if (sel.type === 'text') {
          initialSize = sel.size;
        } else {
          initialScale = sel.scale;
        }
        editorCanvas.setPointerCapture(ev.pointerId);
        return;
      }
      if (handle === 'body') {
        pointerMode = 'drag';
        dragStartOffsetX = canvasX - sel.cx * canvasWidth;
        dragStartOffsetY = canvasY - sel.cy * canvasHeight;
        editorCanvas.setPointerCapture(ev.pointerId);
        return;
      }
    }

    const hit = hitTest(canvasX, canvasY);
    if (hit) {
      selectedLayerId = hit.layer.id;
      pointerMode = 'drag';
      dragStartOffsetX = canvasX - hit.layer.cx * canvasWidth;
      dragStartOffsetY = canvasY - hit.layer.cy * canvasHeight;
      editorCanvas.setPointerCapture(ev.pointerId);

      if (hit.type === 'text') {
        setEditorTab('text');
        syncTextInspector();
      } else {
        setEditorTab('sticker');
        syncStickerInspector();
      }
      drawEditorFrame();
      renderTextList();
    } else {
      selectedLayerId = null;
      syncTextInspector();
      syncStickerInspector();
      drawEditorFrame();
      renderTextList();
    }
  });

  editorCanvas.addEventListener('pointermove', (ev) => {
    if (!isPointerDown) return;
    const rect = editorCanvas.getBoundingClientRect();
    const canvasX = ((ev.clientX - rect.left) / rect.width) * canvasWidth;
    const canvasY = ((ev.clientY - rect.top) / rect.height) * canvasHeight;

    if (canvasMode === 'draw') {
      const currentStroke = strokes[strokes.length - 1];
      if (currentStroke) {
        currentStroke.points.push({ x: canvasX / canvasWidth, y: canvasY / canvasHeight });
        drawEditorFrame();
      }
      return;
    }

    const sel = getSelectedLayer();
    if (!sel) return;

    if (pointerMode === 'drag') {
      sel.cx = Math.max(0, Math.min(1, (canvasX - dragStartOffsetX) / canvasWidth));
      sel.cy = Math.max(0, Math.min(1, (canvasY - dragStartOffsetY) / canvasHeight));
      drawEditorFrame();
    } else if (pointerMode === 'resize') {
      const dist = Math.hypot(canvasX - sel.cx * canvasWidth, canvasY - sel.cy * canvasHeight);
      const ratio = dist / (initialDist || 1);
      if (sel.type === 'text') {
        sel.size = Math.max(8, Math.min(150, Math.round(initialSize * ratio)));
        ($('gf-t-size') as HTMLInputElement).value = String(sel.size);
        $('gf-t-size-val').textContent = `${sel.size}px`;
      } else {
        sel.scale = Math.max(10, Math.min(300, Math.round(initialScale * ratio)));
        ($('gf-s-scale') as HTMLInputElement).value = String(sel.scale);
        $('gf-s-scale-val').textContent = `${sel.scale}%`;
      }
      drawEditorFrame();
    } else if (pointerMode === 'rotate') {
      const angle = Math.atan2(canvasY - sel.cy * canvasHeight, canvasX - sel.cx * canvasWidth);
      const diffRad = angle - initialAngle;
      let deg = Math.round(initialRotation + (diffRad * 180) / Math.PI);

      deg = ((deg + 180) % 360) - 180;
      if (deg < -180) deg += 360;

      sel.rotation = deg;
      if (sel.type === 'sticker') {
        ($('gf-s-rot') as HTMLInputElement).value = String(sel.rotation);
        $('gf-s-rot-val').textContent = `${sel.rotation}°`;
      }
      drawEditorFrame();
    }
  });

  editorCanvas.addEventListener('pointerup', (ev) => {
    isPointerDown = false;
    pointerMode = 'none';
    try { editorCanvas.releasePointerCapture(ev.pointerId); } catch {}
    drawEditorFrame();
  });

  editorCanvas.addEventListener('pointercancel', (ev) => {
    isPointerDown = false;
    pointerMode = 'none';
    try { editorCanvas.releasePointerCapture(ev.pointerId); } catch {}
  });


  document.addEventListener('keydown', (ev) => {
    const sel = getSelectedLayer();
    if (!sel) return;

    const active = document.activeElement;
    if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA')) {
      return;
    }

    if (ev.key === 'Delete' || ev.key === 'Backspace') {
      ev.preventDefault();
      if (sel.type === 'text') {
        deleteTextLayer(sel.id);
      } else {
        deleteStickerLayer(sel.id);
      }
    } else if (ev.key === 'ArrowLeft') {
      ev.preventDefault();
      sel.cx = Math.max(0, sel.cx - 1 / canvasWidth);
      drawEditorFrame();
    } else if (ev.key === 'ArrowRight') {
      ev.preventDefault();
      sel.cx = Math.min(1, sel.cx + 1 / canvasWidth);
      drawEditorFrame();
    } else if (ev.key === 'ArrowUp') {
      ev.preventDefault();
      sel.cy = Math.max(0, sel.cy - 1 / canvasHeight);
      drawEditorFrame();
    } else if (ev.key === 'ArrowDown') {
      ev.preventDefault();
      sel.cy = Math.min(1, sel.cy + 1 / canvasHeight);
      drawEditorFrame();
    }
  });


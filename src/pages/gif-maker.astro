---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="gif-maker">
  <div class="flex flex-col gap-6">
    <div class="flex flex-wrap gap-2">
      <button id="gf-tab-img" class="btn btn-primary">From images</button>
      <button id="gf-tab-vid" class="btn btn-secondary">From video</button>
      <button id="gf-tab-hot" class="btn btn-secondary">🔥 Hot GIFs</button>
    </div>

    <div id="gf-pane-hot" class="hidden flex-col gap-4">
      <div id="gf-hot-cats" class="flex flex-wrap gap-2"></div>
      <div id="gf-hot-grid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"></div>
      <button id="gf-hot-more" class="btn btn-secondary self-center mt-2 hidden">Load More</button>
      <p id="gf-hot-note" class="text-[13px] text-ink-tertiary">Pick a GIF, then hit "Make GIF" to re-encode it with your settings.</p>
    </div>

    <div id="gf-pane-img" class="flex flex-col gap-3">
      <span class="text-sm text-ink-subtle">Images (select several — order = frame order)</span>
      <label class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
        <input id="gf-imgs" type="file" accept="image/*" multiple class="sr-only" />
      </label>
      <div id="gf-thumbs" class="flex flex-wrap gap-2"></div>
    </div>

    <div id="gf-pane-vid" class="hidden flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Video clip (a few seconds works best)
        <input id="gf-vid" type="file" accept="video/*" class="field file:mr-3 file:rounded-md file:border-0 file:bg-surface-2 file:px-3 file:py-1 file:text-ink" />
      </label>
      <div class="flex flex-wrap items-end gap-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Start (s)
          <input id="gf-start" type="number" min="0" step="0.1" value="0" class="field w-24" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Duration (s)
          <input id="gf-dur" type="number" min="0.2" max="15" step="0.1" value="3" class="field w-24" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Frames / sec
          <input id="gf-fps" type="number" min="2" max="24" value="10" class="field w-24" />
        </label>
        <button id="gf-btn-load-vid" type="button" class="btn btn-secondary py-2 font-medium">Load Video Frames</button>
      </div>
    </div>

    <div id="gf-editor" class="hidden flex-col gap-6 border-t border-hairline pt-6">
      <h3 class="text-lg font-semibold text-ink">GIF Editor Workspace</h3>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1.5fr_1fr]">

        <div class="flex flex-col gap-4">
          <div class="flex justify-center overflow-auto rounded-lg border border-hairline bg-surface-2 p-4 relative">
            <canvas id="gf-canvas" class="max-w-full touch-none" style="cursor: default;"></canvas>
          </div>

          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between gap-4">
              <div class="flex items-center gap-2">
                <button id="gf-btn-play" type="button" class="btn btn-secondary px-3 py-1 text-sm">Play</button>
                <button id="gf-btn-prev" type="button" class="btn btn-secondary px-2 py-1 text-sm" title="Previous Frame">◀</button>
                <button id="gf-btn-next" type="button" class="btn btn-secondary px-2 py-1 text-sm" title="Next Frame">▶</button>
              </div>
              <span id="gf-frame-info" class="text-sm font-mono text-ink-subtle">Frame 1 of 1</span>
            </div>
            <input id="gf-timeline" type="range" min="0" max="0" value="0" class="w-full accent-primary" />
          </div>
        </div>

        <div class="panel panel-lift flex flex-col gap-4 p-4 bg-surface-1 rounded-xl border border-hairline">

          <div class="flex border-b border-hairline pb-2">
            <button id="gf-tab-text" type="button" class="flex-1 py-1.5 text-center text-sm font-medium border-b-2 border-primary text-ink">💬 Text</button>
            <button id="gf-tab-draw" type="button" class="flex-1 py-1.5 text-center text-sm font-medium border-b-2 border-transparent text-ink-subtle hover:text-ink">🖌️ Draw</button>
            <button id="gf-tab-sticker" type="button" class="flex-1 py-1.5 text-center text-sm font-medium border-b-2 border-transparent text-ink-subtle hover:text-ink">✨ Stickers</button>
          </div>

          <div id="gf-panel-text" class="flex flex-col gap-4">
            <button id="gf-add-text" type="button" class="btn btn-secondary w-full text-sm font-semibold">+ Add Text Box</button>
            <div id="gf-text-list" class="flex flex-col gap-2 max-h-40 overflow-y-auto pr-1"></div>

            <div id="gf-text-inspector" class="hidden flex-col gap-3 border-t border-hairline pt-3">
              <span class="eyebrow text-primary text-xs font-semibold">Selected Text Settings</span>
              <textarea id="gf-t-text" rows="2" class="field resize-y w-full text-sm" placeholder="Enter text..."></textarea>

              <div class="grid grid-cols-2 gap-2">
                <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Font
                  <select id="gf-t-font" class="field text-sm py-1">
                    <option value="Impact, 'Arial Narrow', sans-serif">Impact</option>
                    <option value="Arial, Helvetica, sans-serif">Arial</option>
                    <option value="'Comic Sans MS', cursive">Comic Sans</option>
                    <option value="'Times New Roman', serif">Times New Roman</option>
                    <option value="Courier New, monospace">Courier New</option>
                    <option value="Inter, sans-serif">Inter</option>
                  </select>
                </label>
                <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Alignment
                  <select id="gf-t-align" class="field text-sm py-1">
                    <option value="center">Center</option>
                    <option value="left">Left</option>
                    <option value="right">Right</option>
                  </select>
                </label>
              </div>

              <div class="grid grid-cols-2 gap-2">
                <label class="flex items-center justify-between gap-1 text-[13px] text-ink-subtle">Fill
                  <input id="gf-t-fill" type="color" value="#ffffff" class="h-6 w-10 cursor-pointer rounded border border-hairline bg-transparent" />
                </label>
                <label class="flex items-center justify-between gap-1 text-[13px] text-ink-subtle">Outline
                  <input id="gf-t-stroke" type="color" value="#000000" class="h-6 w-10 cursor-pointer rounded border border-hairline bg-transparent" />
                </label>
              </div>

              <div class="flex flex-col gap-1">
                <label class="flex justify-between text-[13px] text-ink-subtle font-medium">Font size: <span id="gf-t-size-val" class="text-ink">40px</span></label>
                <input id="gf-t-size" type="range" min="10" max="100" value="40" class="w-full accent-primary" />
              </div>

              <div class="flex flex-col gap-1">
                <label class="flex justify-between text-[13px] text-ink-subtle font-medium">Outline width: <span id="gf-t-sw-val" class="text-ink">4px</span></label>
                <input id="gf-t-sw" type="range" min="0" max="15" value="4" class="w-full accent-primary" />
              </div>

              <div class="flex items-center gap-4 py-1">
                <label class="flex items-center gap-1.5 text-[13px] text-ink-subtle"><input id="gf-t-bold" type="checkbox" /> Bold</label>
                <label class="flex items-center gap-1.5 text-[13px] text-ink-subtle"><input id="gf-t-italic" type="checkbox" /> Italic</label>
                <label class="flex items-center gap-1.5 text-[13px] text-ink-subtle"><input id="gf-t-upper" type="checkbox" /> Caps</label>
              </div>

              <div class="flex flex-col gap-2 border-t border-hairline pt-2 mt-1">
                <label class="flex items-center gap-2 text-[13px] text-ink-subtle">
                  <input id="gf-t-all-frames" type="checkbox" checked /> Show on all frames
                </label>
                <div id="gf-t-timing-range" class="hidden flex-col gap-2">
                  <div class="grid grid-cols-2 gap-2">
                    <div class="flex flex-col gap-1 text-xs text-ink-subtle">
                      <span>Start frame</span>
                      <div class="flex gap-1">
                        <input id="gf-t-start-frame" type="number" min="0" value="0" class="field text-sm py-1 min-w-0 flex-1" />
                        <button id="gf-t-btn-start-curr" type="button" class="btn btn-secondary px-1 text-[11px]" title="Use current frame">Current</button>
                      </div>
                    </div>
                    <div class="flex flex-col gap-1 text-xs text-ink-subtle">
                      <span>End frame</span>
                      <div class="flex gap-1">
                        <input id="gf-t-end-frame" type="number" min="0" value="0" class="field text-sm py-1 min-w-0 flex-1" />
                        <button id="gf-t-btn-end-curr" type="button" class="btn btn-secondary px-1 text-[11px]" title="Use current frame">Current</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <button id="gf-t-delete" type="button" class="btn btn-secondary text-sm border-red-500/30 text-red-400 hover:bg-red-950/20 py-1 mt-2">Delete Text Layer</button>
            </div>
          </div>

          <div id="gf-panel-draw" class="hidden flex-col gap-4">
            <label class="flex items-center gap-2 text-sm text-ink-subtle">
              <input id="gf-draw-enable" type="checkbox" class="accent-primary" /> Enable Drawing Mode
            </label>
            <div class="flex flex-col gap-3">
              <div class="flex items-center justify-between gap-2">
                <span class="text-sm text-ink-subtle">Brush Color</span>
                <input id="gf-draw-color" type="color" value="#ff0000" class="h-8 w-14 cursor-pointer rounded border border-hairline bg-transparent" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="flex justify-between text-sm text-ink-subtle font-medium">Brush Size: <span id="gf-draw-size-val" class="text-ink">5px</span></label>
                <input id="gf-draw-size" type="range" min="1" max="40" value="5" class="w-full accent-primary" />
              </div>

              <div class="flex flex-col gap-2 border-t border-hairline pt-2 mt-1">
                <label class="flex items-center gap-2 text-[13px] text-ink-subtle">
                  <input id="gf-draw-all-frames" type="checkbox" checked /> Draw on all frames
                </label>
                <div id="gf-draw-timing-range" class="hidden flex-col gap-2">
                  <div class="grid grid-cols-2 gap-2">
                    <div class="flex flex-col gap-1 text-xs text-ink-subtle">
                      <span>Start frame</span>
                      <div class="flex gap-1">
                        <input id="gf-draw-start-frame" type="number" min="0" value="0" class="field text-sm py-1 min-w-0 flex-1" />
                        <button id="gf-draw-btn-start-curr" type="button" class="btn btn-secondary px-1 text-[11px]" title="Use current frame">Current</button>
                      </div>
                    </div>
                    <div class="flex flex-col gap-1 text-xs text-ink-subtle">
                      <span>End frame</span>
                      <div class="flex gap-1">
                        <input id="gf-draw-end-frame" type="number" min="0" value="0" class="field text-sm py-1 min-w-0 flex-1" />
                        <button id="gf-draw-btn-end-curr" type="button" class="btn btn-secondary px-1 text-[11px]" title="Use current frame">Current</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="flex gap-2 mt-2">
                <button id="gf-draw-undo" type="button" class="btn btn-secondary flex-1 py-1.5 text-sm font-semibold">Undo Stroke</button>
                <button id="gf-draw-clear" type="button" class="btn btn-secondary flex-1 py-1.5 text-sm text-red-400 border-red-500/20 hover:bg-red-950/20 font-semibold">Clear All</button>
              </div>
            </div>
          </div>

          <div id="gf-panel-sticker" class="hidden flex-col gap-4">
            <span class="text-sm font-medium text-ink-subtle">Emoji Stickers</span>
            <div id="gf-emoji-grid" class="grid grid-cols-6 gap-1 max-h-32 overflow-y-auto p-1 bg-surface-2 rounded-lg border border-hairline">

            </div>

            <span class="text-sm font-medium text-ink-subtle mt-2">Custom Image Overlay</span>
            <label class="btn btn-secondary w-full text-center cursor-pointer text-sm py-2 font-semibold">
              📁 Upload Sticker Image
              <input id="gf-sticker-upload" type="file" accept="image/*" class="sr-only" />
            </label>

            <div id="gf-sticker-inspector" class="hidden flex-col gap-3 border-t border-hairline pt-3 mt-1">
              <span class="eyebrow text-primary text-xs font-semibold">Selected Sticker Settings</span>

              <div class="flex flex-col gap-1">
                <label class="flex justify-between text-[13px] text-ink-subtle font-semibold">Scale: <span id="gf-s-scale-val" class="text-ink">100%</span></label>
                <input id="gf-s-scale" type="range" min="10" max="250" value="100" class="w-full accent-primary" />
              </div>

              <div class="flex flex-col gap-1">
                <label class="flex justify-between text-[13px] text-ink-subtle font-semibold">Rotation: <span id="gf-s-rot-val" class="text-ink">0°</span></label>
                <input id="gf-s-rot" type="range" min="-180" max="180" value="0" class="w-full accent-primary" />
              </div>

              <div class="flex flex-col gap-1">
                <label class="flex justify-between text-[13px] text-ink-subtle font-semibold">Opacity: <span id="gf-s-op-val" class="text-ink">100%</span></label>
                <input id="gf-s-op" type="range" min="10" max="100" value="100" class="w-full accent-primary" />
              </div>

              <div class="flex flex-col gap-2 border-t border-hairline pt-2 mt-1">
                <label class="flex items-center gap-2 text-[13px] text-ink-subtle">
                  <input id="gf-s-all-frames" type="checkbox" checked /> Show on all frames
                </label>
                <div id="gf-s-timing-range" class="hidden flex-col gap-2">
                  <div class="grid grid-cols-2 gap-2">
                    <div class="flex flex-col gap-1 text-xs text-ink-subtle">
                      <span>Start frame</span>
                      <div class="flex gap-1">
                        <input id="gf-s-start-frame" type="number" min="0" value="0" class="field text-sm py-1 min-w-0 flex-1" />
                        <button id="gf-s-btn-start-curr" type="button" class="btn btn-secondary px-1 text-[11px]" title="Use current frame">Current</button>
                      </div>
                    </div>
                    <div class="flex flex-col gap-1 text-xs text-ink-subtle">
                      <span>End frame</span>
                      <div class="flex gap-1">
                        <input id="gf-s-end-frame" type="number" min="0" value="0" class="field text-sm py-1 min-w-0 flex-1" />
                        <button id="gf-s-btn-end-curr" type="button" class="btn btn-secondary px-1 text-[11px]" title="Use current frame">Current</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <button id="gf-s-delete" type="button" class="btn btn-secondary text-sm border-red-500/30 text-red-400 hover:bg-red-950/20 py-1 mt-2">Delete Sticker Layer</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap items-end gap-4 border-t border-hairline pt-5">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Max width (px)
        <input id="gf-width" type="number" min="48" max="800" value="480" class="field w-28" />
      </label>
      <label id="gf-delay-row" class="flex flex-col gap-1 text-sm text-ink-subtle">Frame delay (ms)
        <input id="gf-delay" type="number" min="20" max="2000" value="120" class="field w-28" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Colors
        <select id="gf-colors" class="field w-28">
          <option value="256">256 (best)</option>
          <option value="128">128</option>
          <option value="64">64 (smaller)</option>
          <option value="32">32</option>
        </select>
      </label>
      <label class="flex items-center gap-2 self-end pb-2.5 text-sm text-ink-subtle"><input id="gf-loop" type="checkbox" class="accent-primary" checked /> Loop forever</label>
      <button id="gf-make" class="btn btn-primary ml-auto font-semibold">Make GIF</button>
    </div>

    <p id="gf-status" class="text-sm text-ink-subtle" role="status" aria-live="polite"></p>

    <div id="gf-result" class="hidden flex-col items-center gap-4 rounded-xl border border-hairline bg-surface-1 p-5">
      <img id="gf-out" alt="Generated GIF preview" class="max-h-80 rounded-lg" />
      <div class="flex items-center gap-3">
        <span id="gf-size" class="text-[13px] text-ink-tertiary font-mono"></span>
        <a id="gf-dl" class="btn btn-primary font-semibold" download="animation.gif">Download GIF</a>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online GIF maker turns a set of images, a short video clip, or a trending
      template into an animated GIF. Browse the Hot GIFs tab for trending GIFs and memes,
      or switch to built-in Templates for original animations generated on the
      fly in your browser — copyright-safe and offline.
    </p>
    <p>
      Once loaded, use our powerful <strong>GIF Editor Workspace</strong> to overlay 
      custom text boxes (with customizable font styles, stroke sizes, alignments, and timing), 
      draw directly on the frames (with brush settings and timing range controls), 
      and add emojis or custom image overlays. The preview player allows you to play 
      the animation, step frame-by-frame, and view active edits instantly.
    </p>
    <p>
      Finally, choose the maximum width, color quantization, and looping parameters, 
      and download the final generated GIF. Everything is processed and encoded 
      entirely in your browser — your images, videos, and captions never touch a server.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }

  #gf-emoji-grid::-webkit-scrollbar {
    width: 6px;
  }
  #gf-emoji-grid::-webkit-scrollbar-track {
    background: transparent;
  }
  #gf-emoji-grid::-webkit-scrollbar-thumb {
    background: var(--color-hairline-strong);
    border-radius: 3px;
  }
</style>

<script>
  import { encodeGif, type GifFrameInput } from '../lib/gifenc';
  import { GIF_TEMPLATES, type GifTemplate } from '../lib/giftemplates';
  import { decodeGif } from '../lib/gifdec';

  const $ = (id: string) => document.getElementById(id)!;
  const statusEl = $('gf-status')!;
  let source: 'img' | 'vid' | 'hot' = 'img';
  let imageFiles: File[] = [];
  let selectedTemplate: GifTemplate | null = null;

  function setTab(tab: 'img' | 'vid' | 'hot') {
    source = tab;
    $('gf-pane-img').className = tab === 'img' ? 'flex flex-col gap-3' : 'hidden flex-col gap-3';
    $('gf-pane-vid').className = tab === 'vid' ? 'flex flex-col gap-3' : 'hidden flex-col gap-3';
    $('gf-pane-hot').className = tab === 'hot' ? 'flex flex-col gap-4' : 'hidden flex-col gap-4';
    for (const t of ['img', 'vid', 'hot'] as const) {
      ($(`gf-tab-${t}`) as HTMLButtonElement).className = tab === t ? 'btn btn-primary' : 'btn btn-secondary';
    }
    ($('gf-delay-row') as HTMLElement).style.display = tab === 'img' ? '' : 'none';

    $('gf-editor').className = 'hidden flex-col gap-6 border-t border-hairline pt-6';
    originalFrames = [];
    textLayers = [];
    stickerLayers = [];
    strokes = [];
    selectedLayerId = null;
    if (isPlaying) {
      isPlaying = false;
      if (playTimer) clearTimeout(playTimer);
      $('gf-btn-play').textContent = 'Play';
    }

    if (tab === 'hot') {
      renderHotGrid();
    } else if (tab === 'img') {
      if (imageFiles.length) loadSourceFrames();
    }
  }
  $('gf-tab-img').addEventListener('click', () => setTab('img'));
  $('gf-tab-vid').addEventListener('click', () => setTab('vid'));
  $('gf-tab-hot').addEventListener('click', () => setTab('hot'));

  interface TextLayer {
    id: string;
    type: 'text';
    text: string;
    cx: number; cy: number;
    size: number;
    fontFamily: string;
    fill: string;
    stroke: string;
    strokeW: number;
    bold: boolean;
    italic: boolean;
    upper: boolean;
    align: 'center' | 'left' | 'right';
    allFrames: boolean;
    frameStart: number;
    frameEnd: number;
    rotation: number;
  }

  interface StickerLayer {
    id: string;
    type: 'sticker';
    kind: 'emoji' | 'image';
    emoji?: string;
    img?: HTMLImageElement;
    cx: number; cy: number;
    scale: number;
    rotation: number;
    opacity: number;
    allFrames: boolean;
    frameStart: number;
    frameEnd: number;
    aspect: number;
  }

  interface DrawStroke {
    points: { x: number; y: number }[];
    color: string;
    size: number;
    allFrames: boolean;
    frameStart: number;
    frameEnd: number;
  }

  let originalFrames: { canvas: HTMLCanvasElement; delayMs: number }[] = [];
  let textLayers: TextLayer[] = [];
  let stickerLayers: StickerLayer[] = [];
  let strokes: DrawStroke[] = [];
  let selectedLayerId: string | null = null;

  let currentFrameIndex = 0;
  let isPlaying = false;
  let playTimer: any = undefined;
  let canvasMode: 'select' | 'draw' = 'select';

  let canvasWidth = 480;
  let canvasHeight = 270;

  const editorCanvas = $('gf-canvas') as HTMLCanvasElement;
  const editorCtx = editorCanvas.getContext('2d')!;
  const timeline = $('gf-timeline') as HTMLInputElement;


  const HOT_CATS: { id: string; name: string }[] = [
    { id: 'trending', name: '🔥 Trending' },
    { id: 'memes', name: '😂 Memes' },
    { id: 'reactions', name: '🙌 Reactions' },
    { id: 'animals', name: '🐱 Animals' },
    { id: 'gaming', name: '🎮 Gaming' },
    { id: 'anime', name: '✨ Anime' },
    { id: 'movies', name: '🎬 Movies' },
    { id: 'music', name: '🎵 Music' },
    { id: 'sports', name: '⚽ Sports' },
    { id: 'dance', name: '💃 Dance' },
    { id: 'holidays', name: '🎃 Holidays' },
    { id: 'templates', name: '🎨 Templates' },
  ];

  const KLIPY_KEY = (import.meta.env.PUBLIC_KLIPY_API_KEY as string | undefined) ?? '';
  const hasKlipy = KLIPY_KEY.length > 0;

  interface HotGif { id: string; title: string; previewUrl: string; gifUrl: string; source: 'klipy' | 'imgflip' }
  let selectedHot: HotGif | null = null;
  let hotCategory = 'trending';
  let hotAnimTimer: any = 0;
  let hotPage = 1;
  const imgflipCache: HotGif[] = [];
  const previewCache = new Map<string, HTMLCanvasElement[]>();

  async function fetchKlipy(category: string, page = 1): Promise<HotGif[]> {
    const q = category === 'trending' ? '' : `&q=${encodeURIComponent(category)}`;
    const url = q
      ? `https://api.klipy.com/api/v1/${KLIPY_KEY}/gifs/search?page=${page}&limit=24${q}`
      : `https://api.klipy.com/api/v1/${KLIPY_KEY}/gifs/trending?page=${page}&limit=24`;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`Klipy request failed (${res.status}).`);
    const json = await res.json();
    const gifs: HotGif[] = (json.data?.data || []).map((g: any) => ({
      id: g.id || g.slug || String(Math.random()),
      title: g.title || g.slug || 'GIF',
      previewUrl: g.file?.sm?.gif?.url || g.file?.xs?.gif?.url || g.file?.md?.gif?.url || '',
      gifUrl: g.file?.md?.gif?.url || g.file?.hd?.gif?.url || g.file?.sm?.gif?.url || '',
      source: 'klipy' as const,
    })).filter((g: HotGif) => g.previewUrl && g.gifUrl);
    return gifs;
  }

  async function fetchImgflip(): Promise<HotGif[]> {
    if (imgflipCache.length) return imgflipCache;
    const res = await fetch('https://api.imgflip.com/get_memes');
    if (!res.ok) throw new Error(`imgflip request failed (${res.status}).`);
    const json = await res.json();
    if (!json.success) throw new Error('imgflip returned an error.');
    const gifs: HotGif[] = (json.data?.memes || [])
      .filter((m: any) => m.url)
      .slice(0, 100)
      .map((m: any) => ({
        id: m.id,
        title: m.name || 'Meme',
        previewUrl: m.url,
        gifUrl: m.url,
        source: 'imgflip' as const,
      }));
    imgflipCache.push(...gifs);
    return gifs;
  }

  async function loadTrendingGifs(page = 1): Promise<HotGif[]> {
    if (hasKlipy) {
      try { return await fetchKlipy('trending', page); } catch {}
    }
    const allMemes = await fetchImgflip();
    const start = (page - 1) * 24;
    return allMemes.slice(start, start + 24);
  }

  async function searchGifs(query: string, page = 1): Promise<HotGif[]> {
    if (hasKlipy) {
      try { return await fetchKlipy(query, page); } catch {}
    }
    const allMemes = await fetchImgflip();
    const filtered = allMemes.filter(m => m.title.toLowerCase().includes(query.toLowerCase()));
    const start = (page - 1) * 24;
    return filtered.slice(start, start + 24);
  }

  function templateFrames(t: GifTemplate) {
    let frames = previewCache.get(t.id);
    if (!frames) {
      frames = t.make().map((f) => f.canvas);
      previewCache.set(t.id, frames);
    }
    return frames;
  }

  function renderHotCats() {
    const wrap = $('gf-hot-cats');
    wrap.replaceChildren();
    for (const cat of HOT_CATS) {
      const b = document.createElement('button');
      b.textContent = cat.name;
      b.className =
        cat.id === hotCategory
          ? 'rounded-full bg-surface-2 px-3.5 py-1.5 text-sm font-medium text-ink'
          : 'rounded-full px-3.5 py-1.5 text-sm font-medium text-ink-subtle hover:text-ink';
      b.addEventListener('click', () => { hotCategory = cat.id; renderHotGrid(); });
      wrap.appendChild(b);
    }
  }

  function hotCard(selected: boolean): HTMLButtonElement {
    const card = document.createElement('button');
    card.className =
      'group flex flex-col overflow-hidden rounded-lg border text-left transition ' +
      (selected ? 'border-primary bg-surface-2' : 'border-hairline bg-surface-1 hover:bg-surface-2');
    return card;
  }

  function hotLabel(text: string, selected: boolean): HTMLSpanElement {
    const label = document.createElement('span');
    label.textContent = text;
    label.className = 'truncate px-3 py-2 text-[13px] ' + (selected ? 'text-ink' : 'text-ink-subtle');
    return label;
  }

  function renderTemplateGrid() {
    const grid = $('gf-hot-grid');
    const anims: { ctx: CanvasRenderingContext2D; frames: HTMLCanvasElement[]; i: number }[] = [];
    for (const t of GIF_TEMPLATES) {
      const selected = selectedTemplate?.id === t.id;
      const card = hotCard(selected);
      const cv = document.createElement('canvas');
      cv.width = 240; cv.height = 135;
      cv.className = 'aspect-video w-full';

      const label = hotLabel(t.name, selected);
      card.appendChild(cv);
      card.appendChild(label);

      card.addEventListener('click', () => {
        selectedTemplate = t; selectedHot = null;
        renderHotGrid();
        loadSourceFrames();
      });
      grid.appendChild(card);
      try {
        const frames = templateFrames(t);
        const ctx = cv.getContext('2d')!;
        ctx.drawImage(frames[0], 0, 0, 240, 135);
        anims.push({ ctx, frames, i: 1 });
      } catch {}
    }
    hotAnimTimer = window.setInterval(() => {
      for (const a of anims) {
        a.ctx.drawImage(a.frames[a.i % a.frames.length], 0, 0, 240, 135);
        a.i++;
      }
    }, 100);
  }

  async function renderGifGrid(gifs: HotGif[], append = false) {
    const grid = $('gf-hot-grid');
    if (!append) grid.replaceChildren();
    for (const g of gifs) {
      const selected = selectedHot?.id === g.id;
      const card = hotCard(selected);
      if (g.gifUrl.endsWith('.mp4')) {
        const vid = document.createElement('video');
        vid.src = g.previewUrl;
        vid.muted = true; vid.loop = true; vid.autoplay = true; vid.playsInline = true;
        vid.className = 'aspect-video w-full object-cover';
        card.appendChild(vid);
      } else {
        const im = document.createElement('img');
        im.src = g.previewUrl;
        im.alt = g.title;
        im.loading = 'lazy';
        im.className = 'aspect-video w-full object-cover';
        card.appendChild(im);
      }
      card.appendChild(hotLabel(g.title, selected));
      card.addEventListener('click', () => {
        selectedHot = g; selectedTemplate = null;
        renderHotGrid();
        loadSourceFrames();
      });
      grid.appendChild(card);
    }
  }

  async function renderHotGrid(append = false) {
    const moreBtn = $('gf-hot-more') as HTMLButtonElement;

    if (!append) {
      hotPage = 1;
      $('gf-hot-grid').replaceChildren();
      renderHotCats();
      clearInterval(hotAnimTimer);
      moreBtn.className = 'hidden';
    }

    if (hotCategory === 'templates') {
      $('gf-hot-note').textContent = 'Templates are generated in your browser — original and copyright-safe.';
      moreBtn.className = 'hidden';
      if (!append) renderTemplateGrid();
      return;
    }

    if (hotCategory === 'trending') {
      $('gf-hot-note').textContent = 'Pick a GIF, then hit "Make GIF" to re-encode it with your settings.';
    } else {
      $('gf-hot-note').textContent = 'Pick a GIF/meme template, then hit "Make GIF" to re-encode it with your settings.';
    }

    moreBtn.className = 'hidden';

    let loadingPara = document.getElementById('gf-hot-loading');
    if (!loadingPara) {
      loadingPara = document.createElement('p');
      loadingPara.id = 'gf-hot-loading';
      loadingPara.className = 'col-span-full text-sm text-ink-subtle text-center py-2';
    }
    loadingPara.textContent = 'Loading…';
    $('gf-hot-grid').appendChild(loadingPara);

    try {
      const pageGifs = hotCategory === 'trending' ? await loadTrendingGifs(hotPage) : await searchGifs(hotCategory, hotPage);

      loadingPara.remove();

      if (pageGifs.length === 0) {
        if (!append) {
          const errPara = document.createElement('p');
          errPara.className = 'col-span-full text-sm text-ink-subtle';
          errPara.textContent = 'No results found.';
          $('gf-hot-grid').appendChild(errPara);
        }
      } else {
        renderGifGrid(pageGifs, append);
        if (pageGifs.length < 24) {
          moreBtn.className = 'hidden';
        } else {
          moreBtn.className = 'btn btn-secondary self-center mt-2';
        }
      }
    } catch (err) {
      if (loadingPara) loadingPara.remove();
      if (!append) {
        $('gf-hot-grid').replaceChildren();
        const errPara = document.createElement('p');
        errPara.className = 'col-span-full text-sm text-ink-subtle';
        errPara.textContent = `${(err as Error).message}. Try the Templates tab instead.`;
        $('gf-hot-grid').appendChild(errPara);
      }
    }
  }


  function loadImage(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const url = URL.createObjectURL(file);
      const im = new Image();
      im.onload = () => { URL.revokeObjectURL(url); resolve(im); };
      im.onerror = () => { URL.revokeObjectURL(url); reject(new Error('image load failed')); };
      im.src = url;
    });
  }

  function loadVideo(fileOrUrl: File | string): Promise<HTMLVideoElement> {
    return new Promise((resolve, reject) => {
      const url = typeof fileOrUrl === 'string' ? fileOrUrl : URL.createObjectURL(fileOrUrl);
      const v = document.createElement('video');
      v.muted = true; v.preload = 'auto'; v.src = url;
      v.onloadedmetadata = () => resolve(v);
      v.onerror = () => { URL.revokeObjectURL(url); reject(new Error('video load failed')); };
    });
  }

  function seek(v: HTMLVideoElement, t: number): Promise<void> {
    return new Promise((resolve) => {
      const done = () => { v.removeEventListener('seeked', done); resolve(); };
      v.addEventListener('seeked', done);
      v.currentTime = Math.min(t, v.duration - 0.01);
    });
  }

  async function loadSourceFrames() {
    statusEl.textContent = 'Loading source frames...';
    try {
      let srcFrames: { canvas: HTMLCanvasElement; delayMs: number }[] = [];
      let w = 480;
      let h = 270;

      if (source === 'img') {
        if (!imageFiles.length) throw new Error('Add at least one image.');

        const maxW = Math.max(48, Math.min(800, num('gf-width')));
        const delay = Math.max(20, Math.min(2000, num('gf-delay')));

        let targetW = maxW;
        let targetH = 270;
        let aspectFound = false;

        const getDims = (naturalW: number, naturalH: number) => {
          const scale = Math.min(1, maxW / naturalW);
          return {
            w: Math.round(naturalW * scale),
            h: Math.round(naturalH * scale)
          };
        };

        for (let i = 0; i < imageFiles.length; i++) {
          const file = imageFiles[i];
          statusEl.textContent = `Loading file ${i + 1} of ${imageFiles.length}...`;

          if (file.type === 'image/gif' || file.name.endsWith('.gif')) {
            statusEl.textContent = `Decoding GIF: ${file.name}...`;
            try {
              const decoded = await decodeGif(file);
              if (decoded && decoded.length) {
                if (!aspectFound) {
                  const dims = getDims(decoded[0].canvas.width, decoded[0].canvas.height);
                  targetW = dims.w;
                  targetH = dims.h;
                  aspectFound = true;
                }

                for (const frame of decoded) {
                  const c = document.createElement('canvas');
                  c.width = targetW;
                  c.height = targetH;
                  const x = c.getContext('2d')!;
                  x.fillStyle = '#000';
                  x.fillRect(0, 0, targetW, targetH);
                  x.drawImage(frame.canvas, 0, 0, targetW, targetH);
                  srcFrames.push({ canvas: c, delayMs: frame.delayMs || delay });
                }
              }
            } catch (err) {
              console.error('Failed to decode GIF file:', err);
              const im = await loadImage(file);
              if (!aspectFound) {
                const dims = getDims(im.naturalWidth, im.naturalHeight);
                targetW = dims.w;
                targetH = dims.h;
                aspectFound = true;
              }
              const c = document.createElement('canvas');
              c.width = targetW;
              c.height = targetH;
              const x = c.getContext('2d')!;
              x.fillStyle = '#000';
              x.fillRect(0, 0, targetW, targetH);
              x.drawImage(im, 0, 0, targetW, targetH);
              srcFrames.push({ canvas: c, delayMs: delay });
            }
          } else {
            const im = await loadImage(file);
            if (!aspectFound) {
              const dims = getDims(im.naturalWidth, im.naturalHeight);
              targetW = dims.w;
              targetH = dims.h;
              aspectFound = true;
            }
            const c = document.createElement('canvas');
            c.width = targetW;
            c.height = targetH;
            const x = c.getContext('2d')!;
            x.fillStyle = '#000';
            x.fillRect(0, 0, targetW, targetH);
            const s = Math.min(targetW / im.naturalWidth, targetH / im.naturalHeight);
            const dw = im.naturalWidth * s, dh = im.naturalHeight * s;
            x.drawImage(im, (targetW - dw) / 2, (targetH - dh) / 2, dw, dh);
            srcFrames.push({ canvas: c, delayMs: delay });
          }
        }
        w = targetW;
        h = targetH;
      } else if (source === 'vid') {
        const file = ($('gf-vid') as HTMLInputElement).files?.[0];
        if (!file) throw new Error('Choose a video first.');
        const v = await loadVideo(file);
        const maxW = Math.max(48, Math.min(800, num('gf-width')));
        const fps = Math.max(2, Math.min(24, num('gf-fps')));
        const start = Math.max(0, num('gf-start'));
        const dur = Math.max(0.2, Math.min(15, num('gf-dur')));
        const scale = Math.min(1, maxW / v.videoWidth);
        w = Math.round(v.videoWidth * scale);
        h = Math.round(v.videoHeight * scale);

        const count = Math.max(1, Math.min(150, Math.round(dur * fps)));
        const delay = Math.round(1000 / fps);

        for (let i = 0; i < count; i++) {
          const t = start + i / fps;
          if (t >= v.duration) break;
          await seek(v, t);
          statusEl.textContent = `Extracting video frame ${i + 1} of ${count}...`;
          const c = document.createElement('canvas');
          c.width = w; c.height = h;
          const x = c.getContext('2d')!;
          x.fillStyle = '#000';
          x.fillRect(0, 0, w, h);
          const s = Math.min(w / v.videoWidth, h / v.videoHeight);
          const dw = v.videoWidth * s, dh = v.videoHeight * s;
          x.drawImage(v, (w - dw) / 2, (h - dh) / 2, dw, dh);
          srcFrames.push({ canvas: c, delayMs: delay });
        }
        URL.revokeObjectURL(v.src);
        if (!srcFrames.length) throw new Error('No frames captured from video.');
      } else {
        let src: { canvas: HTMLCanvasElement; delayMs: number }[];
        if (selectedHot) {
          const isVideo = selectedHot.gifUrl.endsWith('.mp4');
          if (isVideo) {
            statusEl.textContent = 'Loading video…';
            const v = await loadVideo(selectedHot.gifUrl);
            const maxW = Math.max(48, Math.min(800, num('gf-width')));
            const fps = Math.max(2, Math.min(24, num('gf-fps')));
            const scale = Math.min(1, maxW / v.videoWidth);
            w = Math.round(v.videoWidth * scale);
            h = Math.round(v.videoHeight * scale);
            const dur = Math.min(v.duration, 5);
            const count = Math.max(1, Math.min(60, Math.round(dur * fps)));
            const delay = Math.round(1000 / fps);

            src = [];
            for (let i = 0; i < count; i++) {
              await seek(v, i / fps);
              statusEl.textContent = `Capturing frame ${i + 1} of ${count}…`;
              const c = document.createElement('canvas');
              c.width = w; c.height = h;
              const x = c.getContext('2d')!;
              x.fillStyle = '#000'; x.fillRect(0, 0, w, h);
              const s = Math.min(w / v.videoWidth, h / v.videoHeight);
              const dw = v.videoWidth * s, dh = v.videoHeight * s;
              x.drawImage(v, (w - dw) / 2, (h - dh) / 2, dw, dh);
              src.push({ canvas: c, delayMs: delay });
            }
            URL.revokeObjectURL(v.src);
            if (!src.length) throw new Error('No frames captured from video.');
          } else {
            statusEl.textContent = 'Downloading GIF…';
            const res = await fetch(selectedHot.gifUrl);
            if (!res.ok) throw new Error('GIF download failed.');
            statusEl.textContent = 'Decoding frames…';
            src = await decodeGif(await res.blob());
            if (src.length > 150) src = src.slice(0, 150);
          }
        } else if (selectedTemplate) {
          src = selectedTemplate.make();
        } else {
          throw new Error('Pick a template or Hot GIF first.');
        }

        const maxW = Math.max(48, Math.min(800, num('gf-width')));
        const scale = Math.min(1, maxW / src[0].canvas.width);
        w = Math.round(src[0].canvas.width * scale);
        h = Math.round(src[0].canvas.height * scale);

        for (const f of src) {
          const c = document.createElement('canvas');
          c.width = w; c.height = h;
          const x = c.getContext('2d')!;
          x.drawImage(f.canvas, 0, 0, w, h);
          srcFrames.push({ canvas: c, delayMs: f.delayMs });
        }
      }

      originalFrames = srcFrames;
      canvasWidth = w;
      canvasHeight = h;

      textLayers = [];
      stickerLayers = [];
      strokes = [];
      selectedLayerId = null;

      const maxFrameIdx = originalFrames.length - 1;
      ($('gf-t-start-frame') as HTMLInputElement).max = String(maxFrameIdx);
      ($('gf-t-end-frame') as HTMLInputElement).max = String(maxFrameIdx);
      ($('gf-draw-start-frame') as HTMLInputElement).max = String(maxFrameIdx);
      ($('gf-draw-end-frame') as HTMLInputElement).max = String(maxFrameIdx);
      ($('gf-s-start-frame') as HTMLInputElement).max = String(maxFrameIdx);
      ($('gf-s-end-frame') as HTMLInputElement).max = String(maxFrameIdx);

      editorCanvas.width = w;
      editorCanvas.height = h;

      timeline.max = String(maxFrameIdx);
      timeline.value = '0';
      currentFrameIndex = 0;

      $('gf-editor').className = 'flex flex-col gap-6 border-t border-hairline pt-6';
      statusEl.textContent = `Successfully loaded ${originalFrames.length} frames in the editor.`;

      syncTextInspector();
      syncStickerInspector();
      renderTextList();

      drawEditorFrame();
    } catch (err) {
      statusEl.textContent = (err as Error).message || 'Failed to load source frames.';
      $('gf-editor').className = 'hidden flex-col gap-6 border-t border-hairline pt-6';
    }
  }

  $('gf-btn-load-vid').addEventListener('click', loadSourceFrames);


  function getSelectedLayer(): any {
    if (selectedLayerId === null) return null;
    const t = textLayers.find(l => l.id === selectedLayerId);
    if (t) return t;
    const s = stickerLayers.find(l => l.id === selectedLayerId);
    if (s) return s;
    return null;
  }

  function play() {
    if (isPlaying && originalFrames.length) {
      currentFrameIndex = (currentFrameIndex + 1) % originalFrames.length;
      drawEditorFrame();
      const delay = originalFrames[currentFrameIndex].delayMs || 100;
      playTimer = window.setTimeout(play, delay);
    }
  }

  function drawSelectionBox() {
    const sel = getSelectedLayer();
    if (!sel) return;

    editorCtx.save();
    const px = sel.cx * canvasWidth;
    const py = sel.cy * canvasHeight;
    editorCtx.translate(px, py);
    editorCtx.rotate((sel.rotation * Math.PI) / 180);

    let w = 0, h = 0;
    if (sel.type === 'text') {
      const fontPx = sel.size;
      const fontStr = `${sel.italic ? 'italic ' : ''}${sel.bold ? 'bold ' : ''}${fontPx}px ${sel.fontFamily}`;
      editorCtx.font = fontStr;
      const lines = (sel.upper ? sel.text.toUpperCase() : sel.text).split('\n');
      let maxW = 0;
      lines.forEach((line: string) => {
        maxW = Math.max(maxW, editorCtx.measureText(line).width);
      });
      w = maxW + 20;
      h = lines.length * fontPx * 1.2 + 10;
    } else if (sel.type === 'sticker') {
      w = 60 * (sel.scale / 100) + 10;
      h = w * sel.aspect;
    }

    editorCtx.strokeStyle = 'var(--color-primary, #5e6ad2)';
    editorCtx.lineWidth = 2;
    editorCtx.setLineDash([4, 4]);
    editorCtx.strokeRect(-w / 2, -h / 2, w, h);

    editorCtx.fillStyle = 'var(--color-primary, #5e6ad2)';
    const handleSize = 6;
    for (const sx of [-1, 1]) {
      for (const sy of [-1, 1]) {
        editorCtx.fillRect(sx * w / 2 - handleSize / 2, sy * h / 2 - handleSize / 2, handleSize, handleSize);
      }
    }

    const stalk = 15;
    editorCtx.beginPath();
    editorCtx.moveTo(0, -h / 2);
    editorCtx.lineTo(0, -h / 2 - stalk);
    editorCtx.stroke();

    editorCtx.beginPath();
    editorCtx.arc(0, -h / 2 - stalk, 4, 0, Math.PI * 2);
    editorCtx.fill();

    editorCtx.restore();
  }

  function drawEditorFrame() {
    if (!originalFrames || !originalFrames.length) return;
    const frame = originalFrames[currentFrameIndex];

    editorCtx.clearRect(0, 0, canvasWidth, canvasHeight);

    editorCtx.drawImage(frame.canvas, 0, 0, canvasWidth, canvasHeight);

    for (const stroke of strokes) {
      if (stroke.allFrames || (currentFrameIndex >= stroke.frameStart && currentFrameIndex <= stroke.frameEnd)) {
        if (stroke.points.length < 2) continue;
        editorCtx.beginPath();
        editorCtx.strokeStyle = stroke.color;
        editorCtx.lineWidth = stroke.size;
        editorCtx.lineCap = 'round';
        editorCtx.lineJoin = 'round';

        const p0 = stroke.points[0];
        editorCtx.moveTo(p0.x * canvasWidth, p0.y * canvasHeight);
        for (let i = 1; i < stroke.points.length; i++) {
          const p = stroke.points[i];
          editorCtx.lineTo(p.x * canvasWidth, p.y * canvasHeight);
        }
        editorCtx.stroke();
      }
    }

    for (const layer of textLayers) {
      if (layer.allFrames || (currentFrameIndex >= layer.frameStart && currentFrameIndex <= layer.frameEnd)) {
        editorCtx.save();

        const px = layer.cx * canvasWidth;
        const py = layer.cy * canvasHeight;
        editorCtx.translate(px, py);
        editorCtx.rotate((layer.rotation * Math.PI) / 180);

        const fontPx = layer.size;
        const fontStr = `${layer.italic ? 'italic ' : ''}${layer.bold ? 'bold ' : ''}${fontPx}px ${layer.fontFamily}`;
        editorCtx.font = fontStr;
        editorCtx.textAlign = layer.align;
        editorCtx.textBaseline = 'middle';
        editorCtx.lineJoin = 'round';
        editorCtx.miterLimit = 2;

        const rawText = layer.upper ? layer.text.toUpperCase() : layer.text;
        const lines = rawText.split('\n');
        const lh = fontPx * 1.2;

        editorCtx.fillStyle = layer.fill;
        editorCtx.strokeStyle = layer.stroke;
        editorCtx.lineWidth = layer.strokeW;

        lines.forEach((line, idx) => {
          const yOffset = (idx - (lines.length - 1) / 2) * lh;
          if (layer.strokeW > 0) {
            editorCtx.strokeText(line, 0, yOffset);
          }
          editorCtx.fillText(line, 0, yOffset);
        });

        editorCtx.restore();
      }
    }

    for (const layer of stickerLayers) {
      if (layer.allFrames || (currentFrameIndex >= layer.frameStart && currentFrameIndex <= layer.frameEnd)) {
        editorCtx.save();

        const px = layer.cx * canvasWidth;
        const py = layer.cy * canvasHeight;
        editorCtx.translate(px, py);
        editorCtx.rotate((layer.rotation * Math.PI) / 180);

        editorCtx.globalAlpha = layer.opacity;

        const w = 60 * (layer.scale / 100);
        const h = w * layer.aspect;

        if (layer.kind === 'emoji' && layer.emoji) {
          editorCtx.font = `${w}px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif`;
          editorCtx.textAlign = 'center';
          editorCtx.textBaseline = 'middle';
          editorCtx.fillStyle = '#ffffff';
          editorCtx.fillText(layer.emoji, 0, 0);
        } else if (layer.img) {
          editorCtx.drawImage(layer.img, -w / 2, -h / 2, w, h);
        }

        editorCtx.restore();
      }
    }

    if (!isPlaying) {
      drawSelectionBox();
    }

    timeline.value = String(currentFrameIndex);
    $('gf-frame-info').textContent = `Frame ${currentFrameIndex + 1} of ${originalFrames.length}`;
  }


  function setEditorTab(tab: 'text' | 'draw' | 'sticker') {
    $('gf-panel-text').className = tab === 'text' ? 'flex flex-col gap-4' : 'hidden flex-col gap-4';
    $('gf-panel-draw').className = tab === 'draw' ? 'flex flex-col gap-4' : 'hidden flex-col gap-4';
    $('gf-panel-sticker').className = tab === 'sticker' ? 'flex flex-col gap-4' : 'hidden flex-col gap-4';

    for (const t of ['text', 'draw', 'sticker'] as const) {

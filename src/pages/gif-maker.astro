  });
  $('gf-draw-all-frames').addEventListener('change', () => {
    const isAll = ($('gf-draw-all-frames') as HTMLInputElement).checked;
    if (isAll) {
      $('gf-draw-timing-range').className = 'hidden';
    } else {
      $('gf-draw-timing-range').className = 'flex flex-col gap-2';
      ($('gf-draw-start-frame') as HTMLInputElement).value = String(currentFrameIndex);
      ($('gf-draw-end-frame') as HTMLInputElement).value = String(currentFrameIndex);
    }
  });
  $('gf-draw-btn-start-curr').addEventListener('click', () => {
    ($('gf-draw-start-frame') as HTMLInputElement).value = String(currentFrameIndex);
  });
  $('gf-draw-btn-end-curr').addEventListener('click', () => {
    ($('gf-draw-end-frame') as HTMLInputElement).value = String(currentFrameIndex);
  });
  $('gf-draw-undo').addEventListener('click', () => {
    strokes.pop();
    drawEditorFrame();
  });
  $('gf-draw-clear').addEventListener('click', () => {
    strokes = [];
    drawEditorFrame();
  });

  $('gf-s-scale').addEventListener('input', () => {
    const sel = getSelectedLayer();
    const val = Number(($('gf-s-scale') as HTMLInputElement).value);
    if (sel && sel.type === 'sticker') {
      sel.scale = val;
      drawEditorFrame();
    }
    $('gf-s-scale-val').textContent = `${val}%`;
  });

  $('gf-s-rot').addEventListener('input', () => {
    const sel = getSelectedLayer();
    const val = Number(($('gf-s-rot') as HTMLInputElement).value);
    if (sel && sel.type === 'sticker') {
      sel.rotation = val;
      drawEditorFrame();
    }
    $('gf-s-rot-val').textContent = `${val}°`;
  });

  $('gf-s-op').addEventListener('input', () => {
    const sel = getSelectedLayer();
    const val = Number(($('gf-s-op') as HTMLInputElement).value);
    if (sel && sel.type === 'sticker') {
      sel.opacity = val / 100;
      drawEditorFrame();
    }
    $('gf-s-op-val').textContent = `${val}%`;
  });

  $('gf-s-delete').addEventListener('click', () => {
    const sel = getSelectedLayer();
    if (sel && sel.type === 'sticker') {
      deleteStickerLayer(sel.id);
    }
  });

  $('gf-s-all-frames').addEventListener('change', () => {
    const sel = getSelectedLayer();
    if (sel && sel.type === 'sticker') {
      sel.allFrames = ($('gf-s-all-frames') as HTMLInputElement).checked;
      if (sel.allFrames) {
        sel.frameStart = 0;
        sel.frameEnd = originalFrames.length - 1;
      }
      syncStickerInspector();
      drawEditorFrame();
    }
  });
  $('gf-s-start-frame').addEventListener('change', () => {
    const sel = getSelectedLayer();
    if (sel && sel.type === 'sticker') {
      sel.frameStart = Math.max(0, Math.min(originalFrames.length - 1, Number(($('gf-s-start-frame') as HTMLInputElement).value)));
      drawEditorFrame();
    }
  });
  $('gf-s-end-frame').addEventListener('change', () => {
    const sel = getSelectedLayer();
    if (sel && sel.type === 'sticker') {
      sel.frameEnd = Math.max(0, Math.min(originalFrames.length - 1, Number(($('gf-s-end-frame') as HTMLInputElement).value)));
      drawEditorFrame();
    }
  });
  $('gf-s-btn-start-curr').addEventListener('click', () => {
    const sel = getSelectedLayer();
    if (sel && sel.type === 'sticker') {
      sel.frameStart = currentFrameIndex;
      ($('gf-s-start-frame') as HTMLInputElement).value = String(currentFrameIndex);
      drawEditorFrame();
    }
  });
  $('gf-s-btn-end-curr').addEventListener('click', () => {
    const sel = getSelectedLayer();
    if (sel && sel.type === 'sticker') {
      sel.frameEnd = currentFrameIndex;
      ($('gf-s-end-frame') as HTMLInputElement).value = String(currentFrameIndex);
      drawEditorFrame();
    }
  });


  timeline.addEventListener('input', () => {
    if (isPlaying) {
      isPlaying = false;
      if (playTimer) clearTimeout(playTimer);
      $('gf-btn-play').textContent = 'Play';
    }
    currentFrameIndex = Number(timeline.value);
    drawEditorFrame();
  });

  $('gf-btn-play').addEventListener('click', () => {
    if (isPlaying) {
      isPlaying = false;
      if (playTimer) clearTimeout(playTimer);
      $('gf-btn-play').textContent = 'Play';
      drawEditorFrame();
    } else {
      if (!originalFrames || !originalFrames.length) return;
      isPlaying = true;
      $('gf-btn-play').textContent = 'Pause';
      selectedLayerId = null;
      syncTextInspector();
      syncStickerInspector();
      play();
    }
  });

  $('gf-btn-prev').addEventListener('click', () => {
    if (isPlaying) {
      isPlaying = false;
      if (playTimer) clearTimeout(playTimer);
      $('gf-btn-play').textContent = 'Play';
    }
    if (originalFrames.length) {
      currentFrameIndex = (currentFrameIndex - 1 + originalFrames.length) % originalFrames.length;
      drawEditorFrame();
    }
  });

  $('gf-btn-next').addEventListener('click', () => {
    if (isPlaying) {
      isPlaying = false;
      if (playTimer) clearTimeout(playTimer);
      $('gf-btn-play').textContent = 'Play';
    }
    if (originalFrames.length) {
      currentFrameIndex = (currentFrameIndex + 1) % originalFrames.length;
      drawEditorFrame();
    }
  });


  const num = (id: string) => Number(($(id) as HTMLInputElement).value);

  $('gf-make').addEventListener('click', async () => {
    const btn = $('gf-make') as HTMLButtonElement;
    btn.disabled = true;
    $('gf-result').className = 'hidden flex-col items-center gap-4 rounded-xl border border-hairline bg-surface-1 p-5';
    try {
      if (!originalFrames || !originalFrames.length) {
        await loadSourceFrames();
      }

      if (!originalFrames || !originalFrames.length) {
        throw new Error('Please select a source first.');
      }

      statusEl.textContent = 'Preparing composite frames…';
      await new Promise((r) => setTimeout(r));

      const compCanvas = document.createElement('canvas');
      compCanvas.width = canvasWidth;
      compCanvas.height = canvasHeight;
      const compCtx = compCanvas.getContext('2d', { willReadFrequently: true })!;

      const frames: GifFrameInput[] = [];
      const count = originalFrames.length;

      for (let i = 0; i < count; i++) {
        statusEl.textContent = `Compositing frame ${i + 1} of ${count}…`;
        await new Promise((r) => setTimeout(r));

        const baseFrame = originalFrames[i];
        compCtx.clearRect(0, 0, canvasWidth, canvasHeight);

        compCtx.drawImage(baseFrame.canvas, 0, 0, canvasWidth, canvasHeight);

        for (const stroke of strokes) {
          if (stroke.allFrames || (i >= stroke.frameStart && i <= stroke.frameEnd)) {
            if (stroke.points.length < 2) continue;
            compCtx.beginPath();
            compCtx.strokeStyle = stroke.color;
            compCtx.lineWidth = stroke.size;
            compCtx.lineCap = 'round';
            compCtx.lineJoin = 'round';

            const p0 = stroke.points[0];
            compCtx.moveTo(p0.x * canvasWidth, p0.y * canvasHeight);
            for (let j = 1; j < stroke.points.length; j++) {
              const p = stroke.points[j];
              compCtx.lineTo(p.x * canvasWidth, p.y * canvasHeight);
            }
            compCtx.stroke();
          }
        }

        for (const layer of textLayers) {
          if (layer.allFrames || (i >= layer.frameStart && i <= layer.frameEnd)) {
            compCtx.save();
            const px = layer.cx * canvasWidth;
            const py = layer.cy * canvasHeight;
            compCtx.translate(px, py);
            compCtx.rotate((layer.rotation * Math.PI) / 180);

            const fontPx = layer.size;
            const fontStr = `${layer.italic ? 'italic ' : ''}${layer.bold ? 'bold ' : ''}${fontPx}px ${layer.fontFamily}`;
            compCtx.font = fontStr;
            compCtx.textAlign = layer.align;
            compCtx.textBaseline = 'middle';
            compCtx.lineJoin = 'round';
            compCtx.miterLimit = 2;

            const rawText = layer.upper ? layer.text.toUpperCase() : layer.text;
            const lines = rawText.split('\n');
            const lh = fontPx * 1.2;

            compCtx.fillStyle = layer.fill;
            compCtx.strokeStyle = layer.stroke;
            compCtx.lineWidth = layer.strokeW;

            lines.forEach((line, idx) => {
              const yOffset = (idx - (lines.length - 1) / 2) * lh;
              if (layer.strokeW > 0) {
                compCtx.strokeText(line, 0, yOffset);
              }
              compCtx.fillText(line, 0, yOffset);
            });

            compCtx.restore();
          }
        }

        for (const layer of stickerLayers) {
          if (layer.allFrames || (i >= layer.frameStart && i <= layer.frameEnd)) {
            compCtx.save();
            const px = layer.cx * canvasWidth;
            const py = layer.cy * canvasHeight;
            compCtx.translate(px, py);
            compCtx.rotate((layer.rotation * Math.PI) / 180);

            compCtx.globalAlpha = layer.opacity;

            const w = 60 * (layer.scale / 100);
            const h = w * layer.aspect;

            if (layer.kind === 'emoji' && layer.emoji) {
              compCtx.font = `${w}px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif`;
              compCtx.textAlign = 'center';
              compCtx.textBaseline = 'middle';
              compCtx.fillStyle = '#ffffff';
              compCtx.fillText(layer.emoji, 0, 0);
            } else if (layer.img) {
              compCtx.drawImage(layer.img, -w / 2, -h / 2, w, h);
            }

            compCtx.restore();
          }
        }

        const imgData = compCtx.getImageData(0, 0, canvasWidth, canvasHeight);
        frames.push({ rgba: imgData.data, delayMs: baseFrame.delayMs });
      }

      statusEl.textContent = `Encoding ${frames.length} frames…`;
      await new Promise((r) => setTimeout(r));
      const bytes = encodeGif(frames, {
        width: canvasWidth,
        height: canvasHeight,
        loop: ($('gf-loop') as HTMLInputElement).checked ? 0 : 1,
        maxColors: Number(($('gf-colors') as HTMLSelectElement).value),
      });
      const blob = new Blob([bytes as unknown as BlobPart], { type: 'image/gif' });
      const url = URL.createObjectURL(blob);
      ($('gf-out') as HTMLImageElement).src = url;
      ($('gf-dl') as HTMLAnchorElement).href = url;
      const kb = (blob.size / 1024).toFixed(0);
      $('gf-size').textContent = `${canvasWidth}×${canvasHeight} · ${frames.length} frames · ${kb} KB`;
      $('gf-result').className = 'flex flex-col items-center gap-4 rounded-xl border border-hairline bg-surface-1 p-5';
      statusEl.textContent = 'Done.';
    } catch (err) {
      statusEl.textContent = (err as Error).message || 'Something went wrong.';
    } finally {
      btn.disabled = false;
    }
  });

  function renderThumbnails() {
    const thumbs = $('gf-thumbs')!;
    thumbs.replaceChildren();

    imageFiles.forEach((f, idx) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'relative group h-16 w-16';

      const url = URL.createObjectURL(f);
      const im = document.createElement('img');
      im.src = url;
      im.className = 'h-16 w-16 rounded-md border border-hairline object-cover';
      im.onload = () => URL.revokeObjectURL(url);

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.innerHTML = '&times;';
      removeBtn.className = 'absolute top-0 right-0 h-5 w-5 bg-red-600 hover:bg-red-700 text-white rounded-full flex items-center justify-center text-xs font-bold shadow-md cursor-pointer transition-opacity opacity-0 group-hover:opacity-100';
      removeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        imageFiles.splice(idx, 1);
        renderThumbnails();
        if (imageFiles.length) {
          loadSourceFrames();
        } else {
          $('gf-editor').className = 'hidden flex-col gap-6 border-t border-hairline pt-6';
          originalFrames = [];
          drawEditorFrame();
          statusEl.textContent = '';
        }
      });

      wrapper.appendChild(im);
      wrapper.appendChild(removeBtn);
      thumbs.appendChild(wrapper);
    });
  }

  $('gf-imgs').addEventListener('change', () => {
    const newFiles = Array.from(($('gf-imgs') as HTMLInputElement).files || []);
    imageFiles.push(...newFiles);
    renderThumbnails();
    if (imageFiles.length) {
      loadSourceFrames();
    }
  });

  $('gf-vid').addEventListener('change', () => {
    const file = ($('gf-vid') as HTMLInputElement).files?.[0];
    if (file) {
      loadSourceFrames();
    }
  });

  $('gf-hot-more').addEventListener('click', () => {
    hotPage++;
    renderHotGrid(true);
  });

  setTab('img');
</script>

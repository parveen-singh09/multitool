---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="pokemon-team-builder">
  <div class="flex flex-col gap-6">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-1 flex-col gap-1 text-sm text-ink-subtle">Add Pokémon
        <input id="tb-search" class="field" placeholder="Search the Kanto Pokédex, e.g. Charizard" spellcheck="false" autocomplete="off" />
      </label>
      <button id="tb-random" class="btn btn-secondary">🎲 Random team</button>
      <button id="tb-clear" class="btn btn-tertiary">Clear</button>
    </div>
    <div id="tb-suggest" class="hidden flex-wrap gap-1.5"></div>

    <div id="tb-team" class="grid grid-cols-2 gap-3 sm:grid-cols-3"></div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="panel p-4">
        <div class="eyebrow mb-3">Team defensive coverage</div>
        <div id="tb-defense" class="flex flex-col gap-1.5 text-[13px]"></div>
      </div>
      <div class="panel p-4">
        <div class="eyebrow mb-3">Summary</div>
        <div id="tb-summary" class="flex flex-col gap-2 text-[13px] text-ink-subtle"></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Pokémon team builder lets you assemble a squad of up to six from
      the original 151 Kanto Pokémon and instantly analyzes its type balance.
      Search and add Pokémon (or roll a random team), and the tool tallies how many
      of your members are weak, resistant or immune to each of the 15 attacking
      types — highlighting shared weaknesses to patch and types you cover well.
      Type badges use the official colors.
    </p>
  </div>
</ToolLayout>

<script>
  import { POKEMON_GEN1, POKEMON_TYPE_COLORS } from '../lib/gendata';
  import { sample } from '../lib/random';

  const CHART: Record<string, Record<string, number>> = {
    Normal: { Rock: 0.5, Ghost: 0, Steel: 0.5 },
    Fire: { Fire: 0.5, Water: 0.5, Grass: 2, Ice: 2, Bug: 2, Rock: 0.5, Dragon: 0.5, Steel: 2 },
    Water: { Fire: 2, Water: 0.5, Grass: 0.5, Ground: 2, Rock: 2, Dragon: 0.5 },
    Electric: { Water: 2, Electric: 0.5, Grass: 0.5, Ground: 0, Flying: 2, Dragon: 0.5 },
    Grass: { Fire: 0.5, Water: 2, Grass: 0.5, Poison: 0.5, Ground: 2, Flying: 0.5, Bug: 0.5, Rock: 2, Dragon: 0.5, Steel: 0.5 },
    Ice: { Fire: 0.5, Water: 0.5, Grass: 2, Ice: 0.5, Ground: 2, Flying: 2, Dragon: 2, Steel: 0.5 },
    Fighting: { Normal: 2, Ice: 2, Poison: 0.5, Flying: 0.5, Psychic: 0.5, Bug: 0.5, Rock: 2, Ghost: 0, Steel: 2, Fairy: 0.5 },
    Poison: { Grass: 2, Poison: 0.5, Ground: 0.5, Rock: 0.5, Ghost: 0.5, Steel: 0, Fairy: 2 },
    Ground: { Fire: 2, Electric: 2, Grass: 0.5, Poison: 2, Flying: 0, Bug: 0.5, Rock: 2, Steel: 2 },
    Flying: { Electric: 0.5, Grass: 2, Fighting: 2, Bug: 2, Rock: 0.5, Steel: 0.5 },
    Psychic: { Fighting: 2, Poison: 2, Psychic: 0.5, Steel: 0.5 },
    Bug: { Fire: 0.5, Grass: 2, Fighting: 0.5, Poison: 0.5, Flying: 0.5, Psychic: 2, Ghost: 0.5, Steel: 0.5, Fairy: 0.5 },
    Rock: { Fire: 2, Ice: 2, Fighting: 0.5, Ground: 0.5, Flying: 2, Bug: 2, Steel: 0.5 },
    Ghost: { Normal: 0, Psychic: 2, Ghost: 2, Steel: 0.5 },
    Dragon: { Dragon: 2, Steel: 0.5, Fairy: 0 },
  };

  const ATTACK_TYPES = Object.keys(CHART);

  function effectiveness(atk: string, defTypes: string[]): number {
    let mult = 1;
    for (const d of defTypes) {
      const m = CHART[atk]?.[d];
      if (m !== undefined) mult *= m;
    }
    return mult;
  }

  const $ = (id: string) => document.getElementById(id)!;
  const search = $('tb-search') as HTMLInputElement;
  const suggest = $('tb-suggest');
  const teamEl = $('tb-team');

  let team: typeof POKEMON_GEN1 = [];

  function badge(t: string): string {
    const c = POKEMON_TYPE_COLORS[t] || '#666';
    return `<span class="rounded-full px-2 py-0.5 text-[11px] font-medium text-white" style="background:${c}">${t}</span>`;
  }

  function renderTeam() {
    const slots = [];
    for (let i = 0; i < 6; i++) {
      const p = team[i];
      if (p) {
        slots.push(`<div class="panel panel-lift flex flex-col items-center gap-2 p-4 text-center">
          <span class="text-[11px] text-ink-tertiary">#${String(p.id).padStart(3, '0')}</span>
          <span class="font-display text-[15px] font-medium text-ink">${p.name}</span>
          <div class="flex flex-wrap justify-center gap-1">${p.types.map(badge).join('')}</div>
          <button class="btn btn-tertiary mt-1 h-8 min-h-0 px-2 text-xs" data-remove="${p.id}">Remove</button>
        </div>`);
      } else {
        slots.push(`<div class="flex min-h-32 items-center justify-center rounded-lg border border-dashed border-hairline text-[13px] text-ink-tertiary">Empty slot</div>`);
      }
    }
    teamEl.innerHTML = slots.join('');
    teamEl.querySelectorAll<HTMLButtonElement>('[data-remove]').forEach((btn) => {
      btn.addEventListener('click', () => { team = team.filter((p) => p.id !== Number(btn.dataset.remove)); update(); });
    });
  }

  function renderAnalysis() {
    const defense = $('tb-defense');
    const summary = $('tb-summary');
    if (!team.length) {
      defense.innerHTML = '<span class="text-ink-tertiary">Add Pokémon to see coverage.</span>';
      summary.innerHTML = '<span class="text-ink-tertiary">—</span>';
      return;
    }

    const rows = ATTACK_TYPES.map((atk) => {
      let weak = 0, resist = 0, immune = 0;
      for (const p of team) {
        const e = effectiveness(atk, p.types);
        if (e === 0) immune++;
        else if (e > 1) weak++;
        else if (e < 1) resist++;
      }
      return { atk, weak, resist, immune };
    });

    defense.innerHTML = rows
      .map((r) => {
        const net = r.weak - r.resist - r.immune;
        const color = net > 0 ? '#e08585' : net < 0 ? '#27a644' : '#8a8f98';
        const parts = [];
        if (r.weak) parts.push(`<span style="color:#e08585">${r.weak} weak</span>`);
        if (r.resist) parts.push(`<span style="color:#27a644">${r.resist} resist</span>`);
        if (r.immune) parts.push(`<span style="color:#828fff">${r.immune} immune</span>`);
        return `<div class="flex items-center gap-2">
          <span class="w-20">${badge(r.atk)}</span>
          <span class="flex-1 text-ink-subtle">${parts.join(' · ') || 'neutral'}</span>
          <span class="h-2 w-2 rounded-full" style="background:${color}"></span>
        </div>`;
      })
      .join('');

    const shared = rows.filter((r) => r.weak >= Math.ceil(team.length / 2) && r.weak > r.resist).sort((a, b) => b.weak - a.weak);
    const covered = rows.filter((r) => r.resist + r.immune >= Math.ceil(team.length / 2));
    const lines = [];
    lines.push(`<div>Team size: <span class="text-ink">${team.length}/6</span></div>`);
    if (shared.length) {
      lines.push(`<div>⚠️ Common weakness: ${shared.slice(0, 3).map((r) => badge(r.atk)).join(' ')} — consider a counter.</div>`);
    } else {
      lines.push('<div>✅ No single type threatens most of the team.</div>');
    }
    if (covered.length) {
      lines.push(`<div>🛡️ Well-resisted: ${covered.slice(0, 4).map((r) => badge(r.atk)).join(' ')}</div>`);
    }
    summary.innerHTML = lines.join('');
  }

  function update() {
    renderTeam();
    renderAnalysis();
  }

  function renderSuggest() {
    const q = search.value.trim().toLowerCase();
    if (!q) { suggest.classList.add('hidden'); return; }
    const matches = POKEMON_GEN1
      .filter((p) => p.name.toLowerCase().includes(q) && !team.some((t) => t.id === p.id))
      .slice(0, 12);
    if (!matches.length) { suggest.classList.add('hidden'); return; }
    suggest.classList.remove('hidden');
    suggest.classList.add('flex');
    suggest.innerHTML = matches
      .map((p) => `<button class="btn btn-secondary h-8 min-h-0 px-2.5 text-[13px]" data-add="${p.id}">${p.name}</button>`)
      .join('');
    suggest.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (team.length >= 6) return;
        const p = POKEMON_GEN1.find((x) => x.id === Number(btn.dataset.add));
        if (p) team.push(p);
        search.value = '';
        suggest.classList.add('hidden');
        update();
      });
    });
  }

  search.addEventListener('input', renderSuggest);
  search.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const first = suggest.querySelector<HTMLButtonElement>('[data-add]');
      first?.click();
    }
  });
  $('tb-random').addEventListener('click', () => { team = sample(POKEMON_GEN1, 6); update(); });
  $('tb-clear').addEventListener('click', () => { team = []; update(); });

  team = sample(POKEMON_GEN1, 6);
  update();
</script>

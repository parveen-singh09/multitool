---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="dwf-to-dwg">
  <ArchiveConvert slug="dwf-to-dwg" from="dwf" to="dwg" noun="CAD file" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free DWF to DWG converter converts Autodesk DWF design web files to editable DWG drawings.
    </p>
    <p>
      DWG, DXF and DWF are proprietary CAD formats no browser can read on its own,
      so conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

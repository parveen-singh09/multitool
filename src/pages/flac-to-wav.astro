---
import ToolLayout from '../layouts/ToolLayout.astro';
import AudioConvert from '../components/AudioConvert.astro';
---

<ToolLayout slug="flac-to-wav">
  <AudioConvert slug="flac-to-wav" from="flac" to="wav" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free FLAC to WAV converter decodes lossless FLAC into uncompressed WAV (PCM), handy for audio editing software.
    </p>
    <p>
      Everything runs entirely in your browser using ffmpeg compiled to
      WebAssembly — your audio is never uploaded to a server. Convert one file or
      a whole batch and download the results individually or as a ZIP.
    </p>
  </div>
</ToolLayout>

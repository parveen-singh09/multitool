---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="number-to-words">
  <div class="flex flex-col gap-5">

    <div class="flex flex-wrap gap-4 text-sm text-ink-subtle">
      <label class="flex flex-col gap-1">
        Direction
        <select id="nw-dir" class="field w-auto py-1">
          <option value="n2w" selected>Number → words</option>
          <option value="w2n">Words → number</option>
        </select>
      </label>
      <label class="flex flex-col gap-1" id="nw-format-wrap">
        Format
        <select id="nw-format" class="field w-auto py-1">
          <option value="cardinal" selected>Cardinal (one, two…)</option>
          <option value="ordinal">Ordinal (first, second…)</option>
          <option value="currency">Currency</option>
        </select>
      </label>
      <label class="flex flex-col gap-1" id="nw-system-wrap">
        Number system
        <select id="nw-system" class="field w-auto py-1">
          <option value="short" selected>International (thousand, million)</option>
          <option value="indian">Indian (lakh, crore)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1" id="nw-currency-wrap" hidden>
        Currency
        <select id="nw-currency-sel" class="field w-auto py-1">
          <option value="USD" selected>US dollars &amp; cents</option>
          <option value="GBP">Pounds &amp; pence</option>
          <option value="EUR">Euros &amp; cents</option>
          <option value="INR">Rupees &amp; paise</option>
        </select>
      </label>
      <label class="flex flex-col gap-1" id="nw-case-wrap">
        Letter case
        <select id="nw-case" class="field w-auto py-1">
          <option value="lower" selected>lowercase</option>
          <option value="sentence">Sentence case</option>
          <option value="title">Title Case</option>
          <option value="upper">UPPERCASE</option>
        </select>
      </label>
    </div>

    <div class="flex flex-wrap gap-4 text-sm text-ink-subtle">
      <label class="flex items-center gap-2"><input id="nw-and" type="checkbox" class="accent-primary" checked /> Use “and” (British)</label>
      <label class="flex items-center gap-2" id="nw-cheque-wrap" hidden><input id="nw-cheque" type="checkbox" class="accent-primary" checked /> Cheque style cents (“and 56/100”)</label>
      <label class="flex items-center gap-2" id="nw-hyphen-wrap"><input id="nw-hyphen" type="checkbox" class="accent-primary" checked /> Hyphenate (twenty-one)</label>
      <label class="flex items-center gap-2"><input id="nw-batch" type="checkbox" class="accent-primary" /> Batch mode (one per line)</label>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span id="nw-in-label">Number</span>
      <input id="nw-num" type="text" class="field font-mono" placeholder="1234.56" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" />
      <textarea id="nw-num-multi" class="field font-mono" rows="5" placeholder="1234.56&#10;42&#10;1000000" spellcheck="false" autocomplete="off" hidden></textarea>
    </label>

    <div class="flex flex-wrap items-center gap-2 text-[13px] text-ink-tertiary">
      <span>Try:</span>
      <div id="nw-examples" class="flex flex-wrap gap-2"></div>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span id="nw-out-label">In words</span>
      <div class="flex gap-2">
        <div class="copy-wrap flex-1">
          <textarea id="nw-out" class="field" rows="3" readonly></textarea>
          <button type="button" class="copy-icon" data-copy-target="#nw-out" aria-label="Copy"></button>
        </div>
        <div class="flex flex-col gap-2">
          <button id="nw-download" type="button" class="btn btn-tertiary self-start">Download</button>
        </div>
      </div>
    </label>

    <p id="nw-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free number to words converter spells out any number in plain
      English — perfect for writing cheques, contracts and invoices. Choose
      cardinal words (one, two, three), ordinals (first, second, third) or a
      currency reading, and pick between the international scale (thousand,
      million, billion) and the Indian scale (lakh, crore). It handles decimals,
      negatives and integers of unlimited size, with optional British “and”,
      hyphenation and four letter-case styles.
    </p>
    <p>
      Currency mode supports US dollars, pounds, euros and rupees, and can
      render cheque-style cents as “and 56/100”. A batch mode converts a whole
      column of numbers at once — one per line — so you can spell out an entire
      spreadsheet in a single paste. Switch the direction to turn words back into
      a number too. Copy the result or download it as a text file. Everything
      runs instantly.
    </p>
  </div>
</ToolLayout>

<script>
  const dirEl = document.getElementById('nw-dir') as HTMLSelectElement;
  const formatEl = document.getElementById('nw-format') as HTMLSelectElement;
  const systemEl = document.getElementById('nw-system') as HTMLSelectElement;
  const currencySel = document.getElementById('nw-currency-sel') as HTMLSelectElement;
  const caseEl = document.getElementById('nw-case') as HTMLSelectElement;
  const useAnd = document.getElementById('nw-and') as HTMLInputElement;
  const cheque = document.getElementById('nw-cheque') as HTMLInputElement;
  const hyphen = document.getElementById('nw-hyphen') as HTMLInputElement;
  const batch = document.getElementById('nw-batch') as HTMLInputElement;

  const numEl = document.getElementById('nw-num') as HTMLInputElement;
  const multiEl = document.getElementById('nw-num-multi') as HTMLTextAreaElement;
  const out = document.getElementById('nw-out') as HTMLTextAreaElement;
  const errEl = document.getElementById('nw-error')!;
  const examples = document.getElementById('nw-examples')!;

  const formatWrap = document.getElementById('nw-format-wrap')!;
  const systemWrap = document.getElementById('nw-system-wrap')!;
  const currencyWrap = document.getElementById('nw-currency-wrap')!;
  const caseWrap = document.getElementById('nw-case-wrap')!;
  const chequeWrap = document.getElementById('nw-cheque-wrap')!;
  const hyphenWrap = document.getElementById('nw-hyphen-wrap')!;
  const inLabel = document.getElementById('nw-in-label')!;
  const outLabel = document.getElementById('nw-out-label')!;

  const ONES = ['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine', 'ten',
    'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen'];
  const TENS = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];

  const SHORT = ['', 'thousand', 'million', 'billion', 'trillion', 'quadrillion', 'quintillion',
    'sextillion', 'septillion', 'octillion', 'nonillion', 'decillion', 'undecillion', 'duodecillion',
    'tredecillion', 'quattuordecillion', 'quindecillion'];

  const INDIAN = ['', 'thousand', 'lakh', 'crore', 'arab', 'kharab', 'neel', 'padma', 'shankh'];

  const CURRENCIES: Record<string, { major: [string, string]; minor: [string, string] }> = {
    USD: { major: ['dollar', 'dollars'], minor: ['cent', 'cents'] },
    GBP: { major: ['pound', 'pounds'], minor: ['penny', 'pence'] },
    EUR: { major: ['euro', 'euros'], minor: ['cent', 'cents'] },
    INR: { major: ['rupee', 'rupees'], minor: ['paisa', 'paise'] },
  };

  const CURRENCY_SYMBOL: Record<string, string> = { USD: '$', GBP: '£', EUR: '€', INR: '₹' };

  const sep = () => (hyphen.checked ? '-' : ' ');

  function chunk(n: number): string {
    let s = '';
    if (n >= 100) {
      s += ONES[Math.floor(n / 100)] + ' hundred';
      n %= 100;
      if (n) s += useAnd.checked ? ' and ' : ' ';
    }
    if (n >= 20) {
      s += TENS[Math.floor(n / 10)];
      if (n % 10) s += sep() + ONES[n % 10];
    } else if (n > 0) {
      s += ONES[n];
    }
    return s.trim();
  }

  function intToWords(digits: string): string {
    let s = digits.replace(/^0+(?=\d)/, '');
    if (s === '0' || s === '') return 'zero';

    if (systemEl.value === 'indian') {

      const groups: number[] = [];
      groups.push(Number(s.slice(-3)));
      s = s.slice(0, -3);
      while (s.length) { groups.push(Number(s.slice(-2))); s = s.slice(0, -2); }
      const parts: string[] = [];
      for (let i = groups.length - 1; i >= 0; i--) {
        const g = groups[i];
        if (g === 0) continue;
        const scale = INDIAN[i] ?? '';
        parts.push(chunk(g) + (scale ? ' ' + scale : ''));
      }
      return parts.join(' ').trim();
    }

    const groups: number[] = [];
    while (s.length) { groups.unshift(Number(s.slice(-3))); s = s.slice(0, -3); }
    const parts: string[] = [];
    groups.forEach((g, i) => {
      if (g === 0) return;
      const scale = SHORT[groups.length - 1 - i] ?? '';
      parts.push(chunk(g) + (scale ? ' ' + scale : ''));
    });
    return parts.join(' ').trim();
  }

  const ORD_ONES: Record<string, string> = {
    zero: 'zeroth', one: 'first', two: 'second', three: 'third', five: 'fifth',
    eight: 'eighth', nine: 'ninth', twelve: 'twelfth',
  };
  function ordinalize(words: string): string {
    const tokens = words.split(' ');
    let last = tokens[tokens.length - 1];

    const dash = last.lastIndexOf('-');
    let prefix = '';
    if (dash >= 0) { prefix = last.slice(0, dash + 1); last = last.slice(dash + 1); }
    let ord: string;
    if (ORD_ONES[last]) ord = ORD_ONES[last];
    else if (last.endsWith('y')) ord = last.slice(0, -1) + 'ieth';
    else ord = last + 'th';
    tokens[tokens.length - 1] = prefix + ord;
    return tokens.join(' ');
  }

  function readDecimals(decPart: string): string {

    return 'point ' + decPart.split('').map((d) => ONES[Number(d)]).join(' ');
  }

  function numberToWords(raw0: string): string {
    const raw = raw0.trim().replace(/[, _]/g, '').replace(/^[$£€₹]/, '');
    if (!raw) return '';
    if (!/^-?\d*\.?\d+$/.test(raw)) throw new Error(`“${raw0.trim()}” is not a valid number.`);

    const neg = raw.startsWith('-');
    const [intPart, decPart] = raw.replace(/^-/, '').split('.');
    const format = formatEl.value;
    let result: string;

    if (format === 'currency') {
      const cur = CURRENCIES[currencySel.value];
      const majorDigits = intPart || '0';
      const majorNum = majorDigits.replace(/^0+(?=\d)/, '');
      const isOne = majorNum === '1';
      const majorWords = intToWords(majorDigits);
      const centsStr = decPart ? (decPart + '00').slice(0, 2) : '00';
      const centsVal = Number(centsStr);
      const majorPart = `${majorWords} ${isOne ? cur.major[0] : cur.major[1]}`;
      if (centsVal > 0 && cheque.checked) {
        result = `${majorPart} and ${centsStr}/100`;
      } else if (centsVal > 0) {
        const centWords = intToWords(String(centsVal));
        result = `${majorPart} and ${centWords} ${centsVal === 1 ? cur.minor[0] : cur.minor[1]}`;
      } else {
        result = majorPart;
      }
    } else if (format === 'ordinal') {
      result = ordinalize(intToWords(intPart || '0'));
      if (decPart && /[1-9]/.test(decPart)) result += ' ' + readDecimals(decPart);
    } else {
      result = intToWords(intPart || '0');
      if (decPart && /[1-9]/.test(decPart)) result += ' ' + readDecimals(decPart);
    }

    if (neg) result = 'negative ' + result;
    return applyCase(result);
  }

  function applyCase(s: string): string {
    switch (caseEl.value) {
      case 'upper': return s.toUpperCase();
      case 'title': return s.replace(/\b[a-z]/g, (c) => c.toUpperCase());
      case 'sentence': return s.charAt(0).toUpperCase() + s.slice(1);
      default: return s;
    }
  }

  // ---- words -> number (short scale, cardinal) ----
  const WORD_ONES: Record<string, number> = {};
  ONES.forEach((w, i) => { WORD_ONES[w] = i; });
  const WORD_TENS: Record<string, number> = {};
  TENS.forEach((w, i) => { if (w) WORD_TENS[w] = i * 10; });
  const WORD_SCALE: Record<string, number> = { hundred: 100 };
  SHORT.forEach((w, i) => { if (w) WORD_SCALE[w] = Math.pow(1000, i); });

  function wordsToNumber(raw0: string): string {
    const clean = raw0.trim().toLowerCase().replace(/\band\b/g, ' ').replace(/[-,]/g, ' ');
    if (!clean.trim()) return '';
    let neg = false;
    const tokens = clean.split(/\s+/).filter(Boolean).filter((t) => {
      if (t === 'negative' || t === 'minus') { neg = true; return false; }
      return true;
    });

    // split off decimal part after "point"
    const pIdx = tokens.indexOf('point');
    const intTokens = pIdx >= 0 ? tokens.slice(0, pIdx) : tokens;
    const decTokens = pIdx >= 0 ? tokens.slice(pIdx + 1) : [];

    let total = 0n;
    let current = 0n;
    let sawWord = false;
    for (const t of intTokens) {
      if (t in WORD_ONES) { current += BigInt(WORD_ONES[t]); sawWord = true; }
      else if (t in WORD_TENS) { current += BigInt(WORD_TENS[t]); sawWord = true; }
      else if (t === 'hundred') { current = (current === 0n ? 1n : current) * 100n; sawWord = true; }
      else if (t in WORD_SCALE) {
        const scale = BigInt(WORD_SCALE[t]);
        total += (current === 0n ? 1n : current) * scale;
        current = 0n; sawWord = true;
      } else {
        throw new Error(`Unrecognized word: “${t}”.`);
      }
    }
    total += current;
    if (!sawWord && intTokens.length) throw new Error('Could not parse those words.');

    let dec = '';
    for (const t of decTokens) {
      if (t in WORD_ONES && WORD_ONES[t] < 10) dec += String(WORD_ONES[t]);
      else throw new Error(`Unrecognized decimal word: “${t}”.`);
    }
    return (neg ? '-' : '') + total.toString() + (dec ? '.' + dec : '');
  }

  function convertOne(raw: string): string {
    return dirEl.value === 'w2n' ? wordsToNumber(raw) : numberToWords(raw);
  }

  function convert() {
    errEl.classList.add('hidden');
    try {
      if (batch.checked) {
        const lines = multiEl.value.split('\n');
        out.value = lines.map((l) => (l.trim() ? convertOne(l) : '')).join('\n');
      } else {
        out.value = convertOne(numEl.value);
      }
    } catch (e) {
      out.value = '';
      errEl.textContent = (e as Error).message;
      errEl.classList.remove('hidden');
    }
  }

  // ---- UI wiring / visibility ----
  function syncVisibility() {
    const w2n = dirEl.value === 'w2n';
    const currency = formatEl.value === 'currency';

    // in words->number direction most number-formatting controls are irrelevant
    formatWrap.hidden = w2n;
    systemWrap.hidden = w2n;
    caseWrap.hidden = w2n;
    hyphenWrap.hidden = w2n;
    currencyWrap.hidden = w2n || !currency;
    chequeWrap.hidden = w2n || !currency;

    inLabel.textContent = w2n ? 'Words' : 'Number';
    outLabel.textContent = w2n ? 'As a number' : 'In words';

    // single vs batch input element
    numEl.hidden = batch.checked;
    multiEl.hidden = !batch.checked;
    if (w2n) {
      numEl.placeholder = 'one thousand two hundred thirty-four';
      multiEl.placeholder = 'one thousand\nforty-two\nnegative seven';
    } else {
      numEl.placeholder = '1234.56';
      multiEl.placeholder = '1234.56\n42\n1000000';
    }
  }

  function loadExamples() {
    examples.innerHTML = '';
    const items = dirEl.value === 'w2n'
      ? ['one thousand two hundred thirty-four', 'forty-two', 'negative nineteen']
      : ['1234.56', '1000000', '-7', '0.05', '999999999'];
    for (const ex of items) {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'btn btn-tertiary px-2 py-1 text-[13px] font-mono';
      b.textContent = ex;
      b.addEventListener('click', () => {
        if (batch.checked) multiEl.value = ex; else numEl.value = ex;
        convert();
      });
      examples.appendChild(b);
    }
  }

  [dirEl, formatEl, systemEl, currencySel, caseEl].forEach((el) =>
    el.addEventListener('change', () => { syncVisibility(); if (el === dirEl) loadExamples(); convert(); }));
  [useAnd, cheque, hyphen].forEach((el) => el.addEventListener('change', convert));
  batch.addEventListener('change', () => { syncVisibility(); convert(); });
  numEl.addEventListener('input', convert);
  multiEl.addEventListener('input', convert);

  document.getElementById('nw-download')!.addEventListener('click', () => {
    if (!out.value) return;
    const blob = new Blob([out.value], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'number-to-words.txt';
    a.click();
    URL.revokeObjectURL(a.href);
  });

  syncVisibility();
  loadExamples();
  numEl.value = '1234.56';
  convert();
</script>

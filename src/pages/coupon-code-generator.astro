---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="coupon-code-generator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Prefix
        <input id="cp-prefix" class="field font-mono" placeholder="SAVE" value="SAVE" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Suffix
        <input id="cp-suffix" class="field font-mono" placeholder="" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Code length
        <input id="cp-len" type="number" min="1" max="32" value="8" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="cp-count" type="number" min="1" max="100000" value="20" class="field" />
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Character set
        <select id="cp-set" class="field">
          <option value="unambig" selected>No ambiguous (A-Z 2-9)</option>
          <option value="alnum">Letters + numbers</option>
          <option value="upper">Uppercase + numbers</option>
          <option value="lower">Lowercase + numbers</option>
          <option value="alpha">Letters only</option>
          <option value="num">Numbers only</option>
          <option value="custom">Custom…</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Custom characters
        <input id="cp-custom" class="field font-mono" placeholder="ABCDEFGHJKMNPQRSTUVWXYZ23456789" spellcheck="false" disabled />
      </label>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Pattern <span class="text-ink-faint">(optional — <code>#</code> = one random char, everything else is literal. Overrides length.)</span>
      <input id="cp-pattern" class="field font-mono" placeholder="####-####-####" spellcheck="false" />
    </label>

    <div class="flex flex-wrap items-center gap-4">
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="cp-dash" type="checkbox" class="accent-primary" /> Group with dashes
      </label>
      <div class="ml-auto flex items-center gap-2 font-mono text-sm text-ink">
        <span class="text-ink-faint">Preview:</span> <span id="cp-preview">—</span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-4">
      <button id="cp-gen" class="btn btn-primary">Generate</button>
      <button id="cp-txt" class="btn btn-secondary">Export .txt</button>
      <button id="cp-csv" class="btn btn-secondary">Export .csv</button>
      <span id="cp-err" class="text-sm text-red-400" role="alert"></span>
    </div>
    <div class="copy-wrap">
      <textarea id="cp-out" class="field min-h-64 resize-y font-mono text-[13px]" readonly aria-label="Generated coupon codes"></textarea>
      <button type="button" class="copy-icon" data-copy-target="#cp-out" aria-label="Copy"></button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free coupon code generator creates batches of unique, hard-to-guess
      promo codes for sales, email campaigns, gift cards and loyalty programs.
      Add a prefix like SAVE and an optional suffix, pick the length and
      character set, or drop in a pattern like <code>####-####-####</code> where
      each <code>#</code> becomes a random character and everything else stays
      literal. The no-ambiguous set drops easily-confused characters like O and 0
      so codes are easy to read and type, and you can paste your own custom
      character set instead. Generate up to 100,000 at once, watch a live
      preview, then copy them or export as a .txt list or .csv sheet. Codes use
      your browser's secure random source, are de-duplicated within each batch,
      and the tool warns you when your settings can't produce that many unique
      codes.
    </p>
  </div>
</ToolLayout>

<script>
  import { randInt, randString, UNAMBIGUOUS, ALPHA_UPPER, ALPHA_LOWER, DIGITS } from '../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const prefix = $('cp-prefix') as HTMLInputElement;
  const suffix = $('cp-suffix') as HTMLInputElement;
  const lenEl = $('cp-len') as HTMLInputElement;
  const countEl = $('cp-count') as HTMLInputElement;
  const setEl = $('cp-set') as HTMLSelectElement;
  const customEl = $('cp-custom') as HTMLInputElement;
  const patternEl = $('cp-pattern') as HTMLInputElement;
  const dashEl = $('cp-dash') as HTMLInputElement;
  const previewEl = $('cp-preview') as HTMLSpanElement;
  const errEl = $('cp-err') as HTMLSpanElement;
  const out = $('cp-out') as HTMLTextAreaElement;

  function alphabet(): string {
    switch (setEl.value) {
      case 'alnum': return ALPHA_UPPER + ALPHA_LOWER + DIGITS;
      case 'upper': return ALPHA_UPPER + DIGITS;
      case 'lower': return ALPHA_LOWER + DIGITS;
      case 'alpha': return ALPHA_UPPER + ALPHA_LOWER;
      case 'num': return DIGITS;
      case 'custom': return [...new Set(customEl.value.replace(/\s/g, ''))].join('');
      default: return UNAMBIGUOUS;
    }
  }

  function group(s: string): string {
    return s.match(/.{1,4}/g)?.join('-') ?? s;
  }

  function body(ab: string): string {
    const pat = patternEl.value;
    if (pat.includes('#')) {
      return pat.replace(/#/g, () => ab[randInt(0, ab.length - 1)]);
    }
    const len = Math.max(1, Math.min(32, Number(lenEl.value) || 1));
    let s = randString(len, ab);
    if (dashEl.checked) s = group(s);
    return s;
  }

  function slots(): number {
    const pat = patternEl.value;
    if (pat.includes('#')) return (pat.match(/#/g) || []).length;
    return Math.max(1, Math.min(32, Number(lenEl.value) || 1));
  }

  function wrap(s: string): string {
    return prefix.value + s + suffix.value;
  }

  function generate() {
    errEl.textContent = '';
    const n = Math.max(1, Math.min(100000, Number(countEl.value) || 1));
    const ab = alphabet();
    if (ab.length < 1) {
      errEl.textContent = 'Add at least one character to the character set.';
      out.value = '';
      return;
    }

    const space = Math.pow(ab.length, Math.min(slots(), 40));
    if (space < n) {
      errEl.textContent = `Can't make ${n} unique codes — only ${Math.floor(space)} are possible with this length and character set.`;
      out.value = '';
      return;
    }
    const seen = new Set<string>();
    let guard = 0;
    while (seen.size < n && guard < n * 40 + 100) {
      guard++;
      seen.add(wrap(body(ab)));
    }
    out.value = [...seen].join('\n');
  }

  function updatePreview() {
    const ab = alphabet();
    previewEl.textContent = ab.length ? wrap(body(ab)) : '—';
  }

  function syncCustom() {
    customEl.disabled = setEl.value !== 'custom';
    dashEl.disabled = patternEl.value.includes('#');
  }

  const inputs = ['cp-prefix', 'cp-suffix', 'cp-len', 'cp-count', 'cp-set', 'cp-custom', 'cp-pattern', 'cp-dash'];
  inputs.forEach((id) => $(id).addEventListener('input', () => { syncCustom(); updatePreview(); generate(); }));

  function download(name: string, text: string) {
    const url = URL.createObjectURL(new Blob([text], { type: 'text/plain' }));
    const a = document.createElement('a');
    a.href = url;
    a.download = name;
    a.click();
    URL.revokeObjectURL(url);
  }

  $('cp-gen').addEventListener('click', () => { updatePreview(); generate(); });
  $('cp-txt').addEventListener('click', () => out.value && download('coupon-codes.txt', out.value));
  $('cp-csv').addEventListener('click', () => out.value && download('coupon-codes.csv', 'code\n' + out.value));

  syncCustom();
  updatePreview();
  generate();
</script>

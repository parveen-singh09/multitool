---
import ToolLayout from '../layouts/ToolLayout.astro';
import RasterBatch from '../components/RasterBatch.astro';
---

<ToolLayout slug="image-converter">
  <RasterBatch to="batch" accept="image/*" fromLabel="image" quality={true} matte={true} />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online image converter converts between all the common image
      formats — JPG, PNG, WebP, AVIF, BMP, TIFF, GIF and ICO. Drop one image or a
      whole batch, choose your output format, optionally resize or flatten
      transparency onto a background colour, and download.
    </p>
    <p>
      Everything runs entirely in your browser through the HTML canvas — your
      images are never uploaded to a server, so conversions are private and work
      offline once the page has loaded. Convert many files at once and download
      them individually or all together as a ZIP.
    </p>
  </div>
</ToolLayout>

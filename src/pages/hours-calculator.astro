---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="hours-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Hourly rate (optional)
        <input id="hc-rate" type="number" min="0" step="0.01" class="field" placeholder="e.g. 20" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Overtime after (hours/week)
        <input id="hc-ot" type="number" min="0" step="1" class="field" value="40" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">OT multiplier
        <input id="hc-otmult" type="number" min="1" step="0.5" class="field" value="1.5" inputmode="decimal" />
      </label>
    </div>

    <div class="flex flex-col gap-2">
      <div class="hidden grid-cols-[1fr_1fr_1fr_0.8fr_auto] gap-2 px-1 text-xs font-medium text-ink-subtle sm:grid">
        <span>Day / start</span><span>End</span><span></span><span>Break (min)</span><span class="text-right">Hours</span>
      </div>
      <div id="hc-rows" class="flex flex-col gap-2"></div>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="panel panel-lift p-5 text-center"><div id="hc-total" class="font-display text-2xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Weekly total (h:m)</div></div>
      <div class="panel p-5 text-center"><div id="hc-decimal" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Decimal hours</div></div>
      <div class="panel p-5 text-center"><div id="hc-pay" class="font-mono text-xl" style="color:var(--color-success)">—</div><div class="mt-1 text-[13px] text-ink-subtle">Gross pay</div></div>
    </div>

    <div id="hc-otbox" class="hidden panel p-4 text-center text-[13px] text-ink-muted"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free hours calculator adds up a full weekly time card. Enter start and
      end times (and any break) for each day, and it totals your hours in both
      hours-and-minutes and decimal form. Add an hourly rate to see gross pay, with
      any weekly overtime split out at your chosen multiplier. Overnight shifts
      (end earlier than start) are handled automatically, and the "Now" buttons
      fill the current time.
    </p>
  </div>
</ToolLayout>

<script>
  const DAYS = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
  const rowsEl = document.getElementById('hc-rows')!;
  const toMin = (v: string) => { const [h, m] = v.split(':').map(Number); return h * 60 + m; };

  rowsEl.innerHTML = DAYS.map((day, i) => {
    const weekday = i < 5;
    return `<div class="hc-row grid grid-cols-1 gap-2 sm:grid-cols-[1fr_1fr_auto_0.8fr_auto] sm:items-center">
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <span class="w-20 shrink-0">${day}</span>
        <input class="hc-start field font-mono" type="time" value="${weekday ? '09:00' : ''}" aria-label="${day} start" />
      </label>
      <input class="hc-end field font-mono" type="time" value="${weekday ? '17:30' : ''}" aria-label="${day} end" />
      <button type="button" class="hc-now btn btn-secondary !min-h-0 !px-2 !py-1 text-xs" aria-label="Fill now">Now</button>
      <input class="hc-break field" type="number" min="0" value="${weekday ? '30' : '0'}" inputmode="numeric" aria-label="${day} break minutes" />
      <span class="hc-dayhrs text-right font-mono text-sm text-ink-muted sm:w-16">0:00</span>
    </div>`;
  }).join('');

  const rateEl = document.getElementById('hc-rate') as HTMLInputElement;
  const otEl = document.getElementById('hc-ot') as HTMLInputElement;
  const otMultEl = document.getElementById('hc-otmult') as HTMLInputElement;

  function dayMinutes(row: Element): number {
    const s = (row.querySelector('.hc-start') as HTMLInputElement).value;
    const e = (row.querySelector('.hc-end') as HTMLInputElement).value;
    const brk = Number((row.querySelector('.hc-break') as HTMLInputElement).value) || 0;
    if (!s || !e) return 0;
    let mins = toMin(e) - toMin(s);
    if (mins < 0) mins += 24 * 60;
    mins -= brk;
    return Math.max(0, mins);
  }

  const hm = (mins: number) => `${Math.floor(mins / 60)}:${String(mins % 60).padStart(2, '0')}`;

  function calc() {
    let totalMin = 0;
    rowsEl.querySelectorAll('.hc-row').forEach((row) => {
      const m = dayMinutes(row);
      totalMin += m;
      (row.querySelector('.hc-dayhrs') as HTMLElement).textContent = hm(m);
    });

    const decimal = totalMin / 60;
    document.getElementById('hc-total')!.textContent = hm(totalMin);
    document.getElementById('hc-decimal')!.textContent = decimal.toFixed(2) + ' h';

    const rate = Number(rateEl.value) || 0;
    const payEl = document.getElementById('hc-pay')!;
    const otBox = document.getElementById('hc-otbox')!;
    if (rate > 0) {
      const otThreshold = Number(otEl.value) || 0;
      const otMult = Number(otMultEl.value) || 1.5;
      const regHours = otThreshold > 0 ? Math.min(decimal, otThreshold) : decimal;
      const otHours = otThreshold > 0 ? Math.max(0, decimal - otThreshold) : 0;
      const pay = regHours * rate + otHours * rate * otMult;
      payEl.textContent = '$' + pay.toFixed(2);
      if (otHours > 0) {
        otBox.classList.remove('hidden');
        otBox.textContent = `${regHours.toFixed(2)} h regular + ${otHours.toFixed(2)} h overtime @ ${otMult}× = $${pay.toFixed(2)}`;
      } else {
        otBox.classList.add('hidden');
      }
    } else {
      payEl.textContent = '—';
      otBox.classList.add('hidden');
    }
  }

  rowsEl.querySelectorAll('.hc-now').forEach((btn) => {
    btn.addEventListener('click', () => {
      const row = btn.closest('.hc-row')!;
      const startInp = row.querySelector('.hc-start') as HTMLInputElement;
      const endInp = row.querySelector('.hc-end') as HTMLInputElement;
      const now = new Date();
      const val = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
      if (!startInp.value) startInp.value = val;
      else endInp.value = val;
      calc();
    });
  });

  rowsEl.querySelectorAll('input').forEach((el) => el.addEventListener('input', calc));
  [rateEl, otEl, otMultEl].forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="word-cloud-maker">
  <div class="flex flex-col gap-4">

    <div class="flex flex-col gap-3">
      <div class="panel flex items-center justify-center p-4" style="min-height:320px">
        <canvas
          id="wcm-canvas"
          class="max-w-full h-auto rounded-md"
          aria-label="Word cloud preview"></canvas>
      </div>
      <p id="wcm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
      <div class="flex flex-wrap gap-2">
        <button id="wcm-render" class="btn btn-secondary">Regenerate</button>
        <button id="wcm-png" class="btn btn-primary">PNG</button>
        <button id="wcm-jpg" class="btn btn-secondary">JPG</button>
        <button id="wcm-svg" class="btn btn-secondary">SVG</button>
        <button id="wcm-csv" class="btn btn-secondary">CSV</button>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

      <div class="panel flex flex-col gap-3 p-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Text
          <div class="copy-wrap">
            <textarea id="wcm-text" class="field min-h-28 resize-y font-mono text-[13px]" spellcheck="false" placeholder="Paste your text hereвҖҰ">Words words words. Great ideas need great words, and the best words repeat until they become memorable. Repeat the words, shape the ideas, and let the cloud show which words matter most.</textarea>
            <button type="button" class="copy-icon" data-copy-target="#wcm-text" aria-label="Copy"></button>
          </div>
        </label>
        <div class="flex flex-wrap items-center gap-3">
          <button id="wcm-loadtxt" class="btn btn-secondary text-[13px]">Load .txt file</button>
          <input id="wcm-txtfile" type="file" accept=".txt,text/plain" class="hidden" />
          <button id="wcm-recount" class="btn btn-tertiary text-[13px]">Recount from text</button>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <label class="flex items-center gap-2 text-[13px] text-ink-subtle">
            <input id="wcm-stop" type="checkbox" checked class="h-4 w-4" />
            Skip stopwords
          </label>
          <label class="flex items-center gap-2 text-[13px] text-ink-subtle">
            Min length
            <input id="wcm-minlen" type="number" min="1" max="12" value="2" class="field w-16 py-1" />
          </label>
        </div>
      </div>

      <div class="panel flex flex-col gap-2 p-4">
        <div class="flex items-center justify-between">
          <span class="text-sm text-ink">Word list</span>
          <span id="wcm-count" class="text-[12px] text-ink-tertiary">0 words</span>
        </div>
        <div class="max-h-52 overflow-y-auto rounded-md border border-hairline">
          <table class="w-full text-[13px]">
            <thead class="sticky top-0 bg-surface-2 text-ink-subtle">
              <tr>
                <th class="px-2 py-1 text-left font-medium">Word</th>
                <th class="px-2 py-1 text-right font-medium">Weight</th>
                <th class="px-2 py-1 text-center font-medium">On</th>
                <th class="px-1 py-1"></th>
              </tr>
            </thead>
            <tbody id="wcm-rows"></tbody>
          </table>
        </div>
        <div class="flex gap-2">
          <input id="wcm-addword" type="text" placeholder="Add wordвҖҰ" class="field flex-1 py-1 text-[13px]" />
          <input id="wcm-addweight" type="number" min="1" value="10" class="field w-20 py-1 text-[13px]" />
          <button id="wcm-add" class="btn btn-secondary text-[13px]">Add</button>
        </div>
      </div>

      <div class="panel grid grid-cols-2 gap-3 p-4">
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          Font
          <select id="wcm-font" class="field py-1"></select>
        </label>
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          Shape
          <select id="wcm-shape" class="field py-1">
            <option value="circle">Circle</option>
            <option value="cardioid">Heart</option>
            <option value="diamond">Diamond</option>
            <option value="square">Square</option>
            <option value="triangle">Triangle</option>
            <option value="pentagon">Pentagon</option>
            <option value="star">Star</option>
            <option value="symbol">Symbol / emojiвҖҰ</option>
            <option value="draw">Draw shapeвҖҰ</option>
            <option value="image">Custom imageвҖҰ</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          Color theme
          <select id="wcm-scheme" class="field py-1">
            <option value="lavender">Lavender</option>
            <option value="ocean">Ocean</option>
            <option value="sunset">Sunset</option>
            <option value="forest">Forest</option>
            <option value="mono">Monochrome</option>
            <option value="random-dark">Random (dark)</option>
            <option value="random-light">Random (light)</option>
            <option value="single">Single color</option>
          </select>
        </label>
        <label id="wcm-single-wrap" class="hidden flex-col gap-1 text-[13px] text-ink-subtle">
          Word color
          <input id="wcm-single" type="color" value="#5e6ad2" class="field h-8 cursor-pointer p-1" />
        </label>
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          Background
          <input id="wcm-bg" type="color" value="#ffffff" class="field h-8 cursor-pointer p-1" />
        </label>
        <label class="flex items-end gap-2 pb-1 text-[13px] text-ink-subtle">
          <input id="wcm-transparent" type="checkbox" class="h-4 w-4" />
          Transparent bg
        </label>
        <label id="wcm-image-wrap" class="col-span-2 hidden flex-col gap-1 text-[13px] text-ink-subtle">
          Mask image (dark areas get filled)
          <input id="wcm-imagefile" type="file" accept="image/*" class="field py-1 text-[12px]" />
        </label>

        <div id="wcm-symbol-wrap" class="col-span-2 hidden flex-col gap-2 text-[13px] text-ink-subtle">
          <div class="flex items-center gap-2">
            <span>Type any emoji or character</span>
            <input id="wcm-symbol-input" type="text" value="вқӨ" maxlength="8"
              class="field w-16 py-1 text-center text-[16px]" aria-label="Symbol" />
          </div>
          <div id="wcm-symbol-grid"
            class="grid max-h-40 grid-cols-8 gap-1 overflow-y-auto rounded-md border border-hairline p-1"></div>
        </div>

        <div id="wcm-draw-wrap" class="col-span-2 hidden flex-col gap-2 text-[13px] text-ink-subtle">
          <span>Draw a shape вҖ” words fill what you paint</span>
          <canvas id="wcm-draw-canvas" width="320" height="200"
            class="w-full cursor-crosshair rounded-md border border-hairline bg-surface-2 touch-none"
            aria-label="Draw shape"></canvas>
          <div class="flex flex-wrap items-center gap-3">
            <label class="flex items-center gap-2">
              Brush
              <input id="wcm-brush" type="range" min="8" max="64" step="2" value="28" class="w-28" />
            </label>
            <button id="wcm-draw-clear" class="btn btn-tertiary text-[12px]">Clear</button>
          </div>
        </div>
      </div>

      <div class="panel grid grid-cols-1 gap-3 p-4">
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          Orientation
          <select id="wcm-orient" class="field py-1">
            <option value="h">Horizontal only</option>
            <option value="mixed" selected>Mostly horizontal</option>
            <option value="any">Any angle</option>
            <option value="v">Horizontal &amp; vertical</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          <span>Word scale: <span id="wcm-scaleout">1.0</span>&times;</span>
          <input id="wcm-scale" type="range" min="0.4" max="2.5" step="0.1" value="1" class="w-full" />
        </label>
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          <span>Spacing: <span id="wcm-gridout">8</span></span>
          <input id="wcm-grid" type="range" min="2" max="24" step="1" value="8" class="w-full" />
        </label>
        <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">
          <span>Rotated words: <span id="wcm-rotout">10</span>%</span>
          <input id="wcm-rot" type="range" min="0" max="100" step="5" value="10" class="w-full" />
        </label>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free word cloud maker turns any text into a cloud where the most
      frequent words appear largest. Paste text or load a <code>.txt</code> file,
      then fine-tune every word in the editable list: change its weight, toggle
      it off, or add your own. Pick from built-in shapes вҖ” circle, heart, star,
      diamond, and more вҖ” type any emoji or character to use as a silhouette,
      draw your own shape freehand, or upload an image as a mask, so the words
      fill any shape you like.
    </p>
    <p>
      Choose from 20 fonts, five color themes plus random and single-color
      modes, a custom background (or transparent), and control word rotation,
      scale, and spacing. Export the result as a PNG or JPG image, a scalable
      SVG vector, or the raw word-and-weight table as CSV. Everything runs
      locally in your browser вҖ” no text or images are ever uploaded to a server.
    </p>
  </div>
</ToolLayout>

<script>
  import WordCloud from 'wordcloud';
  import { FONTS, ensureFont } from '../lib/collage/fonts';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const textEl = $<HTMLTextAreaElement>('wcm-text');
  const canvas = $<HTMLCanvasElement>('wcm-canvas');
  const err = $<HTMLElement>('wcm-error');
  const rowsEl = $<HTMLTableSectionElement>('wcm-rows');
  const countEl = $<HTMLElement>('wcm-count');

  const fontEl = $<HTMLSelectElement>('wcm-font');
  const shapeEl = $<HTMLSelectElement>('wcm-shape');
  const schemeEl = $<HTMLSelectElement>('wcm-scheme');
  const singleWrap = $<HTMLElement>('wcm-single-wrap');
  const singleEl = $<HTMLInputElement>('wcm-single');
  const bgEl = $<HTMLInputElement>('wcm-bg');
  const transEl = $<HTMLInputElement>('wcm-transparent');
  const imageWrap = $<HTMLElement>('wcm-image-wrap');
  const imageFileEl = $<HTMLInputElement>('wcm-imagefile');

  const symbolWrap = $<HTMLElement>('wcm-symbol-wrap');
  const symbolInput = $<HTMLInputElement>('wcm-symbol-input');
  const symbolGrid = $<HTMLElement>('wcm-symbol-grid');
  const drawWrap = $<HTMLElement>('wcm-draw-wrap');
  const drawCanvas = $<HTMLCanvasElement>('wcm-draw-canvas');
  const brushEl = $<HTMLInputElement>('wcm-brush');

  const stopEl = $<HTMLInputElement>('wcm-stop');
  const minlenEl = $<HTMLInputElement>('wcm-minlen');

  const orientEl = $<HTMLSelectElement>('wcm-orient');
  const scaleEl = $<HTMLInputElement>('wcm-scale');
  const scaleOut = $<HTMLElement>('wcm-scaleout');
  const gridEl = $<HTMLInputElement>('wcm-grid');
  const gridOut = $<HTMLElement>('wcm-gridout');
  const rotEl = $<HTMLInputElement>('wcm-rot');
  const rotOut = $<HTMLElement>('wcm-rotout');

  const W = 1600;
  const H = 1000;

  const STOPWORDS = new Set(
    (
      'a an and are as at be but by for from has have he her him his i in is it its ' +
      'me my no not of on or our so that the their them they this to us was we were ' +
      'what when where which who will with you your yours its'
    ).split(' ')
  );

  const SCHEMES: Record<string, string[]> = {
    lavender: ['#5e6ad2', '#7b83e0', '#9aa0ec', '#4c56b8', '#8f7be0'],
    ocean: ['#1e88e5', '#00acc1', '#26a69a', '#5c6bc0', '#0277bd'],
    sunset: ['#ef6c00', '#e53935', '#d81b60', '#f9a825', '#c2185b'],
    forest: ['#2e7d32', '#558b2f', '#00695c', '#33691e', '#1b5e20'],
    mono: ['#2a2a30', '#45454f', '#5f5f6b', '#7a7a86', '#33333a'],
  };

  const SYMBOLS = (
    'вқӨ вӯҗ вҳ… вңҝ вқ„ вҳҒ вҳҖ вҳӮ вҡЎ вң” вңҡ в—Ҹ в–І в–  вҷҰ вҷ  вҷЈ вҷҘ ' +
    'рҹҗұ рҹҗ¶ рҹҰӢ рҹҗқ рҹҗҹ рҹҰ„ рҹҗҳ рҹҰ– рҹҢө рҹҢІ рҹҢі рҹҚҖ рҹҢә рҹҢ» рҹҢё рҹҚҒ ' +
    'рҹҚҺ рҹҚҢ рҹҚ• рҹҚә вҳ• рҹҺӮ рҹҚ© рҹҺҲ рҹҺғ рҹҺ„ вӣ„ рҹҺҒ рҹ‘‘ рҹ’Һ рҹ’Ў рҹ”‘ ' +
    'рҹҡ— вңҲ рҹҡҖ вҡ“ вӣө рҹҸ  рҹ—Ҫ рҹ—ә вҡҪ рҹҸҖ рҹҺө рҹҺё рҹ“· рҹ’» рҹ“ұ вҢҡ ' +
    'рҹ‘Қ рҹ‘Җ рҹ§  рҹҰҙ рҹ–җ рҹ’Җ рҹ‘» рҹӨ– рҹҳҖ рҹҷӮ рҹҗҫ рҹҢҚ рҹҢҷ рҹ”Ҙ рҹ’§ вҡҷ'
  )
    .split(' ')
    .filter(Boolean);

  interface Entry {
    word: string;
    weight: number;
    on: boolean;
  }

  let entries: Entry[] = [];

  let maskImg: HTMLImageElement | null = null;

  function setError(msg: string) {
    err.textContent = msg;
    err.classList.remove('hidden');
  }
  function clearError() {
    err.classList.add('hidden');
  }

  function countWords(): Entry[] {
    const skip = stopEl.checked;
    const minLen = Math.max(1, parseInt(minlenEl.value) || 2);
    const freq = new Map<string, number>();
    const tokens = textEl.value.toLowerCase().match(/[\p{L}\p{N}']+/gu) || [];
    for (const t of tokens) {
      if (t.length < minLen) continue;
      if (skip && STOPWORDS.has(t)) continue;
      freq.set(t, (freq.get(t) || 0) + 1);
    }

    return [...freq.entries()]
      .sort((a, b) => b[1] - a[1])
      .map(([word, weight]) => ({ word, weight, on: true }));
  }

  function renderTable() {
    rowsEl.innerHTML = '';
    entries.forEach((e, i) => {
      const tr = document.createElement('tr');
      tr.className = 'border-t border-hairline';
      tr.innerHTML =
        `<td class="px-2 py-1 text-ink">${escapeHtml(e.word)}</td>` +
        `<td class="px-2 py-1 text-right"><input type="number" min="1" value="${e.weight}" data-i="${i}" data-k="w" class="field w-16 py-0.5 text-right text-[12px]" /></td>` +
        `<td class="px-2 py-1 text-center"><input type="checkbox" ${e.on ? 'checked' : ''} data-i="${i}" data-k="on" class="h-4 w-4" /></td>` +
        `<td class="px-1 py-1 text-center"><button data-i="${i}" data-k="del" class="text-ink-tertiary hover:text-ink" title="Remove" aria-label="Remove word">&times;</button></td>`;
      rowsEl.appendChild(tr);
    });
    const active = entries.filter((e) => e.on).length;
    countEl.textContent = `${active} of ${entries.length} words`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string)
    );
  }

  function rotationOpts() {
    switch (orientEl.value) {
      case 'h':
        return { minRotation: 0, maxRotation: 0, rotationSteps: 1 };
      case 'v':
        return { minRotation: -Math.PI / 2, maxRotation: -Math.PI / 2, rotationSteps: 1 };
      case 'any':
        return { minRotation: -Math.PI / 2, maxRotation: Math.PI / 2, rotationSteps: 0 };
      case 'mixed':
      default:
        return { minRotation: -Math.PI / 2, maxRotation: Math.PI / 2, rotationSteps: 2 };
    }
  }

  function colorValue(): string | ((word: string, weight: number) => string) {
    const s = schemeEl.value;
    if (s === 'random-dark' || s === 'random-light') return s;
    if (s === 'single') return singleEl.value;
    const palette = SCHEMES[s] || SCHEMES.lavender;
    let n = 0;
    return () => palette[n++ % palette.length];
  }

  function activeList(): [string, number][] {
    return entries.filter((e) => e.on && e.weight > 0).map((e) => [e.word, e.weight]);
  }

  function weightFactor(): (w: number) => number {
    const active = entries.filter((e) => e.on);
    const maxW = Math.max(1, ...active.map((e) => e.weight));
    const scale = parseFloat(scaleEl.value) || 1;
    const base = Math.min(H / 5, (H * 1.6) / Math.sqrt(active.length + 3));
    return (w: number) => Math.max(6, Math.pow(w / maxW, 0.7) * base * scale);
  }

  function bgColor(): string {
    return transEl.checked ? 'rgba(255,255,255,0)' : bgEl.value;
  }

  const MASK_SHAPES = new Set(['symbol', 'draw', 'image']);
  const isMaskShape = () => MASK_SHAPES.has(shapeEl.value);

  function hasOpaque(c: HTMLCanvasElement): boolean {
    const d = c.getContext('2d')!.getImageData(0, 0, W, H).data;
    for (let i = 3; i < d.length; i += 4) if (d[i] >= 128) return true;
    return false;
  }

  function opaqueFraction(c: HTMLCanvasElement): number {
    const d = c.getContext('2d')!.getImageData(0, 0, W, H).data;
    let n = 0;
    for (let i = 3; i < d.length; i += 4) if (d[i] >= 128) n++;
    return n / (W * H);
  }

  function silhouette(): HTMLCanvasElement | null {
    const c = document.createElement('canvas');
    c.width = W;
    c.height = H;
    const ctx = c.getContext('2d')!;

    if (shapeEl.value === 'symbol') {
      const ch = symbolInput.value.trim() || 'вқӨ';
      const family =
        '"Apple Color Emoji","Segoe UI Emoji","Noto Color Emoji","Segoe UI Symbol",sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      let size = H * 0.92;
      ctx.font = `${size}px ${family}`;
      const w = ctx.measureText(ch).width || size;
      if (w > W * 0.92) {
        size *= (W * 0.92) / w;
        ctx.font = `${size}px ${family}`;
      }
      ctx.fillText(ch, W / 2, H / 2);
      return hasOpaque(c) ? c : null;
    }

    if (shapeEl.value === 'draw') {
      ctx.drawImage(drawCanvas, 0, 0, W, H);
      return hasOpaque(c) ? c : null;
    }

    if (shapeEl.value === 'image') {
      if (!maskImg) return null;
      const r = Math.min(W / maskImg.width, H / maskImg.height);
      const dw = maskImg.width * r;
      const dh = maskImg.height * r;
      ctx.drawImage(maskImg, (W - dw) / 2, (H - dh) / 2, dw, dh);
      const id = ctx.getImageData(0, 0, W, H);
      const d = id.data;
      for (let i = 0; i < d.length; i += 4) {
        const dark = d[i] + d[i + 1] + d[i + 2] <= 128 * 3 && d[i + 3] >= 128;
        d[i + 3] = dark ? 255 : 0;
      }
      ctx.putImageData(id, 0, 0);
      return c;
    }
    return null;
  }

  function paintMask(cvs: HTMLCanvasElement, sil: HTMLCanvasElement, bg: string) {
    const ctx = cvs.getContext('2d')!;
    const bctx = document.createElement('canvas').getContext('2d')!;
    bctx.fillStyle = bg;
    bctx.fillRect(0, 0, 1, 1);
    const bgP = bctx.getImageData(0, 0, 1, 1).data;

    const id = sil.getContext('2d')!.getImageData(0, 0, W, H);
    const d = id.data;
    for (let i = 0; i < d.length; i += 4) {
      const drawable = d[i + 3] >= 128;
      if (drawable) {
        d[i] = bgP[0];
        d[i + 1] = bgP[1];
        d[i + 2] = bgP[2];
        d[i + 3] = bgP[3];
      } else {
        d[i] = d[i + 1] = d[i + 2] = d[i + 3] = 0;
      }
    }
    ctx.putImageData(id, 0, 0);
  }

  function selectedFamily(): string {
    return fontEl.selectedOptions[0]?.dataset.family || 'Inter, system-ui, sans-serif';
  }

  function scaledList(): [string, number][] {
    const base = activeList();
    if (!base.length) return base;
    const scale = parseFloat(scaleEl.value) || 1;
    const target = isMaskShape()
      ? Math.round((500 * maskFill) / (scale * scale))
      : Math.round(base.length / (scale * scale));
    const cap = isMaskShape()
      ? Math.max(60, Math.round(400 * scale))
      : 300;
    const total = Math.min(cap, Math.max(base.length, target));
    if (total <= base.length) return base;
    const copies = Math.ceil(total / base.length);
    return Array.from({ length: copies }, () => base).flat().slice(0, total);
  }

  function baseOptions(): any {
    const family = selectedFamily();
    return {
      list: scaledList(),
      fontFamily: `${family}, Inter, system-ui, sans-serif`,
      fontWeight: '700',
      color: colorValue(),
      backgroundColor: bgColor(),
      weightFactor: weightFactor(),
      gridSize: parseInt(gridEl.value) || 8,
      rotateRatio: (parseInt(rotEl.value) || 0) / 100,
      shuffle: true,
      drawOutOfBound: false,
      shrinkToFit: true,
      abortThreshold: 2000,
      ...rotationOpts(),
    };
  }

  let renderTimer = 0;
  let maskFill = 1;
  function render() {
    clearTimeout(renderTimer);
    renderTimer = window.setTimeout(renderNow, 120);
  }

  async function renderNow() {
    clearError();
    WordCloud.stop();
    canvas.width = W;
    canvas.height = H;

    if (!activeList().length) {
      const ctx = canvas.getContext('2d')!;
      ctx.fillStyle = transEl.checked ? '#0f1011' : bgEl.value;
      ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = '#888';
      ctx.font = '32px Inter, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('Add some text or words to build a cloud.', W / 2, H / 2);
      return;
    }

    await ensureFont(selectedFamily());

    let sil: HTMLCanvasElement | null = null;
    if (isMaskShape()) {
      sil = silhouette();
      if (!sil) {
        maskFill = 1;
        setError(
          shapeEl.value === 'image'
            ? 'Upload a mask image, or pick a built-in shape.'
            : shapeEl.value === 'draw'
              ? 'Draw a shape above, or pick a built-in shape.'
              : 'Type a symbol, or pick a built-in shape.'
        );
        return;
      }
      maskFill = opaqueFraction(sil);
    } else {
      maskFill = 1;
    }

    const opts = baseOptions();

    if (sil) {
      paintMask(canvas, sil, transEl.checked ? '#ffffff' : bgEl.value);
      opts.clearCanvas = false;
      opts.backgroundColor = transEl.checked ? '#ffffff' : bgEl.value;
    } else {
      opts.shape = shapeEl.value;
    }

    WordCloud(canvas, opts);
  }

  function exportSVG() {
    if (!activeList().length) {
      setError('Add some text first.');
      return;
    }
    if (isMaskShape()) {
      const png = canvas.toDataURL('image/png');
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}"><image href="${png}" width="${W}" height="${H}"/></svg>`;
      downloadBlob(new Blob([svg], { type: 'image/svg+xml' }), 'word-cloud.svg');
      return;
    }

    const holder = document.createElement('div');
    holder.style.cssText = `position:absolute;left:-99999px;top:0;width:${W}px;height:${H}px;`;
    document.body.appendChild(holder);

    const opts = baseOptions();
    opts.shape = shapeEl.value;

    holder.addEventListener(
      'wordcloudstop',
      () => {
        const bg = transEl.checked ? 'none' : bgEl.value;
        let body = '';
        if (bg !== 'none') body += `<rect width="${W}" height="${H}" fill="${bg}"/>`;
        holder.querySelectorAll('span').forEach((span) => {
          const s = span.style;
          const left = parseFloat(s.left) || 0;
          const top = parseFloat(s.top) || 0;
          const fh = parseFloat(s.height) || 0;
          const sizeM = s.font.match(/(\d+(?:\.\d+)?)px/);
          const size = sizeM ? parseFloat(sizeM[1]) : fh;
          const family = sizeM ? s.font.slice(s.font.indexOf(sizeM[0]) + sizeM[0].length).trim() : 'sans-serif';
          const x = left;
          const y = top + fh * 0.78;
          const rot = (s.transform.match(/rotate\(([-\d.]+)deg\)/) || [])[1] || '0';
          const t = `translate(${x} ${y}) rotate(${rot})`;
          body +=
            `<text transform="${t}" font-family=${JSON.stringify(family || 'sans-serif')}` +
            ` font-size="${size}" font-weight="700" fill="${s.color || '#000'}"` +
            ` xml:space="preserve">${escapeHtml(span.textContent || '')}</text>`;
        });
        const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}">${body}</svg>`;
        downloadBlob(new Blob([svg], { type: 'image/svg+xml' }), 'word-cloud.svg');
        holder.remove();
      },
      { once: true }
    );

    WordCloud(holder, opts);
  }

  function downloadBlob(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.download = name;
    a.href = url;
    a.click();
    URL.revokeObjectURL(url);
  }

  function exportRaster(type: 'image/png' | 'image/jpeg', name: string) {
    if (!activeList().length) {
      setError('Add some text first.');
      return;
    }
    if (type === 'image/jpeg' && transEl.checked) {
      const flat = document.createElement('canvas');
      flat.width = W;
      flat.height = H;
      const fctx = flat.getContext('2d')!;
      fctx.fillStyle = '#ffffff';
      fctx.fillRect(0, 0, W, H);
      fctx.drawImage(canvas, 0, 0);
      flat.toBlob((b) => b && downloadBlob(b, name), type, 0.92);
      return;
    }
    canvas.toBlob((b) => b && downloadBlob(b, name), type, 0.92);
  }

  function exportCSV() {
    const rows = entries.filter((e) => e.on && e.weight > 0);
    if (!rows.length) {
      setError('Add some text first.');
      return;
    }
    const csv =
      'word,weight\n' +
      rows.map((e) => `"${e.word.replace(/"/g, '""')}",${e.weight}`).join('\n');
    downloadBlob(new Blob([csv], { type: 'text/csv' }), 'word-cloud.csv');
  }

  for (const f of FONTS) {
    const o = document.createElement('option');
    o.value = f.family.split(',')[0].replace(/['"]/g, '').trim();
    o.textContent = f.label;

    o.dataset.family = f.family;
    fontEl.appendChild(o);
  }

  const antonOpt = [...fontEl.options].find((o) => o.textContent === 'Anton');
  if (antonOpt) fontEl.value = antonOpt.value;

  rowsEl.addEventListener('input', (e) => {
    const t = e.target as HTMLInputElement;
    const i = parseInt(t.dataset.i || '-1');
    if (i < 0 || !entries[i]) return;
    if (t.dataset.k === 'w') entries[i].weight = Math.max(0, parseInt(t.value) || 0);
    if (t.dataset.k === 'on') entries[i].on = t.checked;
    render();
    countEl.textContent = `${entries.filter((x) => x.on).length} of ${entries.length} words`;
  });
  rowsEl.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.dataset.k !== 'del') return;
    const i = parseInt(t.dataset.i || '-1');
    if (i >= 0) {
      entries.splice(i, 1);
      renderTable();
      render();
    }
  });

  function recount() {
    entries = countWords();
    renderTable();
    render();
  }

  $('wcm-recount').addEventListener('click', recount);
  $('wcm-render').addEventListener('click', render);

  $('wcm-add').addEventListener('click', () => {
    const w = ($('wcm-addword') as HTMLInputElement).value.trim().toLowerCase();
    const wt = parseInt(($('wcm-addweight') as HTMLInputElement).value) || 10;
    if (!w) return;
    const existing = entries.find((e) => e.word === w);
    if (existing) existing.weight = wt;
    else entries.unshift({ word: w, weight: wt, on: true });
    ($('wcm-addword') as HTMLInputElement).value = '';
    renderTable();
    render();
  });

  $('wcm-loadtxt').addEventListener('click', () => $('wcm-txtfile').click());
  ($('wcm-txtfile') as HTMLInputElement).addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    textEl.value = await file.text();
    recount();
  });

  function togglePanel(el: HTMLElement, on: boolean) {
    el.classList.toggle('hidden', !on);
    el.classList.toggle('flex', on);
  }
  shapeEl.addEventListener('change', () => {
    togglePanel(imageWrap, shapeEl.value === 'image');
    togglePanel(symbolWrap, shapeEl.value === 'symbol');
    togglePanel(drawWrap, shapeEl.value === 'draw');
    render();
  });

  for (const s of SYMBOLS) {
    const b = document.createElement('button');
    b.type = 'button';
    b.textContent = s;
    b.className =
      'aspect-square rounded text-[18px] leading-none hover:bg-surface-3 focus:bg-surface-3';
    b.addEventListener('click', () => {
      symbolInput.value = s;
      render();
    });
    symbolGrid.appendChild(b);
  }
  symbolInput.addEventListener('input', render);

  const dctx = drawCanvas.getContext('2d')!;
  dctx.fillStyle = '#fff';
  dctx.strokeStyle = '#fff';
  dctx.lineCap = 'round';
  dctx.lineJoin = 'round';
  let drawing = false;
  let last: { x: number; y: number } | null = null;
  const drawPos = (e: PointerEvent) => {
    const r = drawCanvas.getBoundingClientRect();
    return {
      x: ((e.clientX - r.left) / r.width) * drawCanvas.width,
      y: ((e.clientY - r.top) / r.height) * drawCanvas.height,
    };
  };
  drawCanvas.addEventListener('pointerdown', (e) => {
    drawing = true;
    last = drawPos(e);
    dctx.lineWidth = parseInt(brushEl.value) || 28;
    dctx.beginPath();
    dctx.arc(last.x, last.y, dctx.lineWidth / 2, 0, Math.PI * 2);
    dctx.fill();
    drawCanvas.setPointerCapture(e.pointerId);
  });
  drawCanvas.addEventListener('pointermove', (e) => {
    if (!drawing || !last) return;
    const p = drawPos(e);
    dctx.lineWidth = parseInt(brushEl.value) || 28;
    dctx.beginPath();
    dctx.moveTo(last.x, last.y);
    dctx.lineTo(p.x, p.y);
    dctx.stroke();
    last = p;
  });
  const endDraw = () => {
    if (!drawing) return;
    drawing = false;
    last = null;
    render();
  };
  drawCanvas.addEventListener('pointerup', endDraw);
  drawCanvas.addEventListener('pointercancel', endDraw);
  $('wcm-draw-clear').addEventListener('click', () => {
    dctx.clearRect(0, 0, drawCanvas.width, drawCanvas.height);
    render();
  });
  imageFileEl.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    const img = new Image();
    img.onload = () => {
      maskImg = img;
      render();
    };
    img.onerror = () => setError('Could not load that image.');
    img.src = URL.createObjectURL(file);
  });

  schemeEl.addEventListener('change', () => {
    const single = schemeEl.value === 'single';
    singleWrap.classList.toggle('hidden', !single);
    singleWrap.classList.toggle('flex', single);
    render();
  });

  const bind = (el: HTMLInputElement, out: HTMLElement, fmt: (v: string) => string) => {
    el.addEventListener('input', () => {
      out.textContent = fmt(el.value);
      render();
    });
  };
  bind(scaleEl, scaleOut, (v) => parseFloat(v).toFixed(1));
  bind(gridEl, gridOut, (v) => v);
  bind(rotEl, rotOut, (v) => v);

  [fontEl, singleEl, bgEl, transEl, orientEl].forEach((el) =>
    el.addEventListener('input', render)
  );
  [stopEl, minlenEl].forEach((el) => el.addEventListener('change', recount));

  $('wcm-png').addEventListener('click', () => exportRaster('image/png', 'word-cloud.png'));
  $('wcm-jpg').addEventListener('click', () => exportRaster('image/jpeg', 'word-cloud.jpg'));
  $('wcm-svg').addEventListener('click', exportSVG);
  $('wcm-csv').addEventListener('click', exportCSV);

  recount();
</script>

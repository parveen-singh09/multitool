?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="mp3-to-wav">

  <div id="mc-root" class="flex flex-col gap-4">
    <label id="mc-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose MP3 files or drop them here</span>
      <input id="mc-file" type="file" accept="audio/mpeg,.mp3,audio/*" multiple class="sr-only" />
    </label>

    <div id="mc-panel" class="hidden flex-col gap-4">

      <div class="flex flex-wrap items-center gap-2">
        <span class="text-[13px] text-ink-tertiary">Presets:</span>
        <button type="button" class="preset btn btn-tertiary" data-codec="pcm_s16le" data-rate="44100" data-ch="2">CD · 16-bit 44.1 kHz</button>
        <button type="button" class="preset btn btn-tertiary" data-codec="pcm_s24le" data-rate="48000" data-ch="2">Studio · 24-bit 48 kHz</button>
        <button type="button" class="preset btn btn-tertiary" data-codec="pcm_s32le" data-rate="96000" data-ch="2">Master · 32-bit 96 kHz</button>
        <button type="button" class="preset btn btn-tertiary" data-codec="pcm_s16le" data-rate="16000" data-ch="1">Voice · 16-bit 16 kHz mono</button>
      </div>

      <div id="mc-files" class="flex flex-col gap-2"></div>

      <div class="panel flex flex-col gap-4 p-4">
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bit depth
            <select id="mc-codec" class="field">
              <option value="pcm_s16le" selected>16-bit PCM</option>
              <option value="pcm_s24le">24-bit PCM</option>
              <option value="pcm_s32le">32-bit PCM</option>
              <option value="pcm_f32le">32-bit float</option>
              <option value="pcm_u8">8-bit PCM</option>
            </select>
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sample rate
            <select id="mc-samplerate" class="field">
              <option value="0" selected>Keep original</option>
              <option value="96000">96 kHz</option>
              <option value="48000">48 kHz</option>
              <option value="44100">44.1 kHz</option>
              <option value="32000">32 kHz</option>
              <option value="22050">22.05 kHz</option>
              <option value="16000">16 kHz (voice)</option>
              <option value="8000">8 kHz (phone)</option>
            </select>
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Channels
            <select id="mc-channels" class="field">
              <option value="0" selected>Keep original</option>
              <option value="2">Stereo</option>
              <option value="1">Mono</option>
            </select>
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Volume (%)
            <input id="mc-volume" type="number" min="0" max="1000" step="5" placeholder="100" class="field" />
          </label>
        </div>

        <div class="flex flex-wrap items-center gap-5">
          <label class="flex items-center gap-2 text-sm text-ink-subtle" title="EBU R128 loudness normalization">
            <input id="mc-normalize" type="checkbox" class="accent-primary" /> Normalize loudness
          </label>
          <label class="flex items-center gap-2 text-sm text-ink-subtle" title="Play the audio backwards">
            <input id="mc-reverse" type="checkbox" class="accent-primary" /> Reverse audio
          </label>
        </div>

        <details class="group">
          <summary class="cursor-pointer select-none text-[13px] text-ink-subtle hover:text-ink">Trim &amp; fade options</summary>
          <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Trim start (s)
              <input id="mc-trimstart" type="number" min="0" step="0.5" placeholder="0" class="field" />
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Trim end (s)
              <input id="mc-trimend" type="number" min="0" step="0.5" placeholder="end" class="field" />
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Fade in (s)
              <input id="mc-fadein" type="number" min="0" step="0.5" placeholder="0" class="field" />
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Fade out (s)
              <input id="mc-fadeout" type="number" min="0" step="0.5" placeholder="0" class="field" />
            </label>
          </div>
          <p class="mt-2 text-xs text-ink-tertiary">Trim and fade apply to every file in the queue. Leave blank to keep the full length.</p>
        </details>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="mc-go" class="btn btn-primary">Convert to WAV</button>
        <button id="mc-clear" class="btn btn-secondary">Clear</button>
        <span id="mc-summary" class="text-[13px] text-ink-subtle"></span>
      </div>

      <div id="mc-batch-dl" class="hidden">
        <button id="mc-zip" class="btn btn-primary">Download all as ZIP</button>
      </div>
    </div>
    <p id="mc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free MP3 to WAV converter decodes compressed MP3 audio into an uncompressed WAV (PCM) file, ready for audio
      editing, mastering and sampling software. There is no file-size limit.
    </p>
    <p>
      Unlike most online converters, you get full control over the output: pick 8, 16, 24 or 32-bit depth (including
      32-bit float for studio work), set the sample rate up to 96 kHz, downmix to mono or keep stereo, and adjust the
      volume in percent. One-click presets cover CD, studio, mastering and voice targets. You can also normalize
      loudness (EBU R128), reverse the audio, trim a section and add fade-in/out — then batch-convert a whole folder and
      download everything as a ZIP.
    </p>
    <p>
      WAV is a lossless, uncompressed format, so the resulting file is considerably larger than the source MP3 but
      preserves the decoded audio exactly, which is what editors like Audacity, Adobe Audition and DAWs expect.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import { getFFmpeg, fetchFile } from '../lib/ffmpeg';
  import { makeZip } from '../lib/zip';

  const MIME = 'audio/wav';
  const EXT = 'wav';

  const $ = (id: string) => document.getElementById(id);
  const fileInput = $('mc-file') as HTMLInputElement;
  const drop = $('mc-drop')!;
  const panel = $('mc-panel')!;
  const filesEl = $('mc-files')!;
  const goBtn = $('mc-go') as HTMLButtonElement;
  const clearBtn = $('mc-clear') as HTMLButtonElement;
  const summary = $('mc-summary')!;
  const batchDl = $('mc-batch-dl')!;
  const zipBtn = $('mc-zip') as HTMLButtonElement;
  const err = $('mc-error')!;

  interface Opts {
    codec: string; sampleRate: number; channels: number; volume: number;
    normalize: boolean; reverse: boolean;
    trimStart: number; trimEnd: number; fadeIn: number; fadeOut: number;
  }

  interface Job {
    file: File; duration: number; row: HTMLElement; statusEl: HTMLElement;
    bar: HTMLElement; actionsEl: HTMLElement;
    outUrl?: string; outData?: Uint8Array; outName?: string; done: boolean;
  }
  let jobs: Job[] = [];
  let current: Job | null = null;

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const fmtSize = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;
  const num = (id: string) => { const v = Number(($(id) as HTMLInputElement)?.value); return Number.isFinite(v) && v > 0 ? v : 0; };
  const outNameFor = (f: File) => f.name.replace(/\.[^.]+$/, '') + '.' + EXT;

  // Build ffmpeg args for MP3 → WAV. Fast input seek (-ss before -i), -to bounds
  // the end, and one -af chain carries volume, reverse, fades and loudnorm.
  function buildWavArgs(o: Opts, input: string, output: string, duration: number): string[] {
    const pre: string[] = [];
    const start = o.trimStart > 0 ? o.trimStart : 0;
    if (start > 0) pre.push('-ss', String(start));
    pre.push('-i', input);
    if (o.trimEnd > start) pre.push('-to', String(o.trimEnd - start));

    const outDur = o.trimEnd > start ? o.trimEnd - start : (duration || 0) - start;
    const af: string[] = [];
    if (o.volume > 0 && o.volume !== 100) af.push(`volume=${(o.volume / 100).toFixed(4)}`);
    if (o.reverse) af.push('areverse');
    if (o.fadeIn > 0) af.push(`afade=t=in:st=0:d=${o.fadeIn}`);
    if (o.fadeOut > 0 && outDur > 0) af.push(`afade=t=out:st=${Math.max(0, outDur - o.fadeOut).toFixed(3)}:d=${o.fadeOut}`);
    if (o.normalize) af.push('loudnorm=I=-16:TP=-1.5:LRA=11');

    const out: string[] = ['-vn'];
    if (o.sampleRate > 0) out.push('-ar', String(o.sampleRate));
    if (o.channels > 0) out.push('-ac', String(o.channels));
    if (af.length) out.push('-af', af.join(','));
    out.push('-c:a', o.codec || 'pcm_s16le');
    return [...pre, ...out, output];
  }

  function readOptions(): Opts {
    return {
      codec: ($('mc-codec') as HTMLSelectElement).value,
      sampleRate: Number(($('mc-samplerate') as HTMLSelectElement).value),
      channels: Number(($('mc-channels') as HTMLSelectElement).value),
      volume: num('mc-volume') || 100,
      normalize: ($('mc-normalize') as HTMLInputElement).checked,
      reverse: ($('mc-reverse') as HTMLInputElement).checked,
      trimStart: num('mc-trimstart'), trimEnd: num('mc-trimend'),
      fadeIn: num('mc-fadein'), fadeOut: num('mc-fadeout'),
    };
  }

  // Read audio duration so fade-out and default trim end can be computed.
  function probeDuration(file: File): Promise<number> {
    return new Promise((resolve) => {
      const el = document.createElement('audio');
      el.preload = 'metadata';
      const url = URL.createObjectURL(file);
      el.onloadedmetadata = () => { URL.revokeObjectURL(url); resolve(isFinite(el.duration) ? el.duration : 0); };
      el.onerror = () => { URL.revokeObjectURL(url); resolve(0); };
      el.src = url;
    });
  }

  function addFiles(list: FileList | File[]) {
    setErr('');
    const arr = Array.from(list);
    if (!arr.length) return;
    for (const file of arr) {
      const row = document.createElement('div');
      row.className = 'panel flex flex-col gap-2 p-3';
      const top = document.createElement('div');
      top.className = 'flex flex-wrap items-center gap-2';
      const name = document.createElement('span');
      name.className = 'text-[13px] text-ink truncate';
      name.textContent = `${file.name} · ${fmtSize(file.size)}`;
      const statusEl = document.createElement('span');
      statusEl.className = 'text-xs text-ink-tertiary ml-auto';
      const actionsEl = document.createElement('span');
      actionsEl.className = 'flex items-center gap-2';
      top.append(name, statusEl, actionsEl);
      const barWrap = document.createElement('div');
      barWrap.className = 'h-1 w-full overflow-hidden rounded-full bg-surface-3';
      const bar = document.createElement('div');
      bar.className = 'h-full w-0 rounded-full transition-all';
      bar.style.background = 'var(--color-primary)';
      barWrap.appendChild(bar);
      row.append(top, barWrap);
      filesEl.appendChild(row);
      const job: Job = { file, duration: 0, row, statusEl, bar, actionsEl, done: false };
      jobs.push(job);
      probeDuration(file).then((d) => (job.duration = d));
    }
    panel.classList.remove('hidden'); panel.classList.add('flex');
    refreshSummary();
  }

  function refreshSummary() {
    const doneCount = jobs.filter((j) => j.done).length;
    summary.textContent = jobs.length ? `${jobs.length} file${jobs.length === 1 ? '' : 's'}${doneCount ? ` · ${doneCount} done` : ''}` : '';
    batchDl.classList.toggle('hidden', !(doneCount > 1));
  }

  function download(data: Uint8Array, name: string) {
    const blob = new Blob([data as BlobPart], { type: MIME });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 2000);
  }

  async function convertAll() {
    const pending = jobs.filter((j) => !j.done);
    if (!pending.length) return;
    setErr(''); goBtn.disabled = true; clearBtn.disabled = true;
    const opts = readOptions();
    try {
      const ff = await getFFmpeg({
        onDownload: (n) => { if (n) summary.textContent = n; },
        onProgress: (r) => { if (current) current.bar.style.width = Math.min(100, Math.round(r * 100)) + '%'; },
      });
      for (const job of pending) {
        current = job;
        job.bar.style.width = '0%';
        job.statusEl.textContent = 'Converting…';
        job.statusEl.style.color = '';
        const inName = 'in_' + Math.random().toString(36).slice(2) + '.mp3';
        const outName = 'out.' + EXT;
        await ff.writeFile(inName, await fetchFile(job.file));
        await ff.exec(buildWavArgs(opts, inName, outName, job.duration));
        const data = (await ff.readFile(outName)) as Uint8Array;
        try { await ff.deleteFile(inName); await ff.deleteFile(outName); } catch {}
        job.outData = data;
        job.outName = outNameFor(job.file);
        job.done = true;
        job.bar.style.width = '100%';
        job.statusEl.textContent = fmtSize(data.length);
        job.statusEl.style.color = 'var(--color-success)';
        renderActions(job);
        refreshSummary();
      }
    } catch (e) {
      setErr('Conversion failed: ' + (e as Error).message + '. Make sure the file is a valid MP3.');
    } finally {
      goBtn.disabled = false; clearBtn.disabled = false;
    }
  }

  function renderActions(job: Job) {
    job.actionsEl.replaceChildren();
    const dl = document.createElement('button');
    dl.className = 'btn btn-secondary';
    dl.style.minHeight = '28px'; dl.style.padding = '2px 10px'; dl.style.fontSize = '12px';
    dl.textContent = 'Download';
    dl.addEventListener('click', () => job.outData && download(job.outData, job.outName!));
    job.actionsEl.appendChild(dl);

    const pv = document.createElement('button');
    pv.className = 'btn btn-tertiary';
    pv.style.minHeight = '28px'; pv.style.padding = '2px 10px'; pv.style.fontSize = '12px';
    pv.textContent = 'Preview';
    let shown = false;
    let holder: HTMLElement | null = null;
    pv.addEventListener('click', () => {
      if (shown) { holder?.remove(); holder = null; shown = false; pv.textContent = 'Preview'; return; }
      const blob = new Blob([job.outData as BlobPart], { type: MIME });
      job.outUrl && URL.revokeObjectURL(job.outUrl);
      job.outUrl = URL.createObjectURL(blob);
      holder = document.createElement('div');
      holder.className = 'mt-1';
      holder.innerHTML = `<audio src="${job.outUrl}" controls class="w-full"></audio>`;
      job.row.appendChild(holder);
      shown = true; pv.textContent = 'Hide';
    });
    job.actionsEl.appendChild(pv);
  }

  zipBtn.addEventListener('click', () => {
    const done = jobs.filter((j) => j.done && j.outData);
    if (!done.length) return;
    const zip = makeZip(done.map((j) => ({ name: j.outName!, data: j.outData! })));
    const url = URL.createObjectURL(zip);
    const a = document.createElement('a'); a.href = url; a.download = 'mp3-to-wav-output.zip'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 2000);
  });

  clearBtn.addEventListener('click', () => {
    jobs.forEach((j) => { j.outUrl && URL.revokeObjectURL(j.outUrl); j.row.remove(); });
    jobs = []; refreshSummary();
    panel.classList.add('hidden'); panel.classList.remove('flex');
    fileInput.value = '';
  });

  document.querySelectorAll<HTMLButtonElement>('.preset').forEach((btn) => {
    btn.addEventListener('click', () => {
      (($('mc-codec') as HTMLSelectElement)).value = btn.dataset.codec!;
      (($('mc-samplerate') as HTMLSelectElement)).value = btn.dataset.rate!;
      (($('mc-channels') as HTMLSelectElement)).value = btn.dataset.ch!;
    });
  });

  fileInput.addEventListener('change', () => fileInput.files && addFiles(fileInput.files));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files; if (f?.length) addFiles(f); });
  goBtn.addEventListener('click', convertAll);

  if (location.search.includes('selftest')) {
    const j = (a: string[]) => a.join(' ');
    console.assert(
      j(buildWavArgs({ codec: 'pcm_s16le', sampleRate: 0, channels: 0, volume: 100, normalize: false, reverse: false, trimStart: 0, trimEnd: 0, fadeIn: 0, fadeOut: 0 }, 'i.mp3', 'o.wav', 10))
        === '-i i.mp3 -vn -c:a pcm_s16le', 'defaults');
    console.assert(
      j(buildWavArgs({ codec: 'pcm_s24le', sampleRate: 48000, channels: 1, volume: 150, normalize: true, reverse: true, trimStart: 2, trimEnd: 8, fadeIn: 1, fadeOut: 1 }, 'i.mp3', 'o.wav', 10))
        === '-ss 2 -i i.mp3 -to 6 -vn -ar 48000 -ac 1 -af volume=1.5000,areverse,afade=t=in:st=0:d=1,afade=t=out:st=5.000:d=1,loudnorm=I=-16:TP=-1.5:LRA=11 -c:a pcm_s24le', 'full chain');
    console.log('mp3-to-wav selftest ok');
  }
</script>

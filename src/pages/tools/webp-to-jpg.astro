---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ImageConverter from '../../components/ImageConverter.astro';
---

<ToolLayout slug="webp-to-jpg">
  <ImageConverter to="image/jpeg" accept="image/webp" ext="jpg" quality={true} flatten={true} />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free WebP to JPG converter turns WebP images into widely compatible
      JPEG files — handy when an app or service won't accept WebP. Transparent
      areas are flattened onto a white background, as JPEG has no transparency.
      Choose the quality and download. The conversion happens entirely in your
      browser, so your image never leaves your device.
    </p>
  </div>
</ToolLayout>

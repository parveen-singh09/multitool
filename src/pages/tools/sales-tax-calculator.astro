---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="sales-tax-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Mode">
      <button data-mode="add" class="st-tab btn btn-primary" aria-selected="true">Add tax</button>
      <button data-mode="remove" class="st-tab btn btn-secondary" aria-selected="false">Remove tax</button>
      <button data-mode="rate" class="st-tab btn btn-secondary" aria-selected="false">Find rate</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle"><span id="st-label">Amount (before tax)</span>
        <input id="st-amount" type="number" min="0" class="field" value="100" inputmode="decimal" />
      </label>
      <label id="st-rate-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">Tax rate (%)
        <input id="st-rate" type="number" min="0" step="0.01" class="field" value="8.5" inputmode="decimal" />
      </label>
      <label id="st-total-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Total paid (with tax)
        <input id="st-total" type="number" min="0" class="field" value="108.50" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">US state base rate (optional)
        <select id="st-state" class="field"><option value="">— pick a state —</option></select>
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="panel p-5 text-center"><div id="st-net" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Net (pre-tax)</div></div>
      <div class="panel p-5 text-center"><div id="st-tax" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Tax</div></div>
      <div class="panel panel-lift p-5 text-center"><div id="st-gross" class="font-display text-2xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Gross (with tax)</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free sales tax calculator adds sales tax, VAT or GST to a price, or
      works in reverse to find the pre-tax amount and the tax portion of a
      tax-inclusive total. Switch between "add tax" and "remove tax" modes to
      suit either job. All calculations run in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const amount = document.getElementById('st-amount') as HTMLInputElement;
  const rate = document.getElementById('st-rate') as HTMLInputElement;
  const totalEl = document.getElementById('st-total') as HTMLInputElement;
  const stateEl = document.getElementById('st-state') as HTMLSelectElement;
  const label = document.getElementById('st-label')!;
  let mode: 'add' | 'remove' | 'rate' = 'add';
  const money = (n: number) => n.toLocaleString(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });

  // US state base (statewide) sales-tax rates, %. Local county/city rates add on top.
  const STATE_RATES: [string, number][] = [
    ['Alabama', 4], ['Alaska', 0], ['Arizona', 5.6], ['Arkansas', 6.5], ['California', 7.25],
    ['Colorado', 2.9], ['Connecticut', 6.35], ['Delaware', 0], ['Florida', 6], ['Georgia', 4],
    ['Hawaii', 4], ['Idaho', 6], ['Illinois', 6.25], ['Indiana', 7], ['Iowa', 6], ['Kansas', 6.5],
    ['Kentucky', 6], ['Louisiana', 4.45], ['Maine', 5.5], ['Maryland', 6], ['Massachusetts', 6.25],
    ['Michigan', 6], ['Minnesota', 6.875], ['Mississippi', 7], ['Missouri', 4.225], ['Montana', 0],
    ['Nebraska', 5.5], ['Nevada', 6.85], ['New Hampshire', 0], ['New Jersey', 6.625], ['New Mexico', 4.875],
    ['New York', 4], ['North Carolina', 4.75], ['North Dakota', 5], ['Ohio', 5.75], ['Oklahoma', 4.5],
    ['Oregon', 0], ['Pennsylvania', 6], ['Rhode Island', 7], ['South Carolina', 6], ['South Dakota', 4.2],
    ['Tennessee', 7], ['Texas', 6.25], ['Utah', 6.1], ['Vermont', 6], ['Virginia', 5.3],
    ['Washington', 6.5], ['West Virginia', 6], ['Wisconsin', 5], ['Wyoming', 4], ['Washington DC', 6],
  ];
  stateEl.innerHTML = '<option value="">— pick a state —</option>' +
    STATE_RATES.map(([name, r]) => `<option value="${r}">${name} — ${r}%</option>`).join('');
  stateEl.addEventListener('change', () => {
    if (stateEl.value !== '') { rate.value = stateEl.value; calc(); }
  });

  function calc() {
    const a = Number(amount.value) || 0;
    let net: number, tax: number, gross: number, r: number;
    if (mode === 'rate') {
      // Derive the rate from before-tax amount + total paid.
      const total = Number(totalEl.value) || 0;
      net = a; gross = total; tax = gross - net;
      r = net > 0 ? tax / net : 0;
      rate.value = (r * 100).toFixed(3).replace(/\.?0+$/, '');
    } else {
      r = (Number(rate.value) || 0) / 100;
      if (mode === 'add') { net = a; tax = a * r; gross = a + tax; }
      else { gross = a; net = a / (1 + r); tax = gross - net; }
    }
    document.getElementById('st-net')!.textContent = money(net);
    document.getElementById('st-tax')!.textContent = money(tax);
    document.getElementById('st-gross')!.textContent = money(gross);
  }

  document.querySelectorAll<HTMLButtonElement>('.st-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      mode = tab.dataset.mode as 'add' | 'remove' | 'rate';
      document.querySelectorAll('.st-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      label.textContent = mode === 'add' ? 'Amount (before tax)' : mode === 'remove' ? 'Amount (with tax)' : 'Amount (before tax)';
      // In find-rate mode swap the rate input for the total-paid input.
      document.getElementById('st-rate-wrap')!.classList.toggle('hidden', mode === 'rate');
      document.getElementById('st-rate-wrap')!.classList.toggle('flex', mode !== 'rate');
      document.getElementById('st-total-wrap')!.classList.toggle('hidden', mode !== 'rate');
      document.getElementById('st-total-wrap')!.classList.toggle('flex', mode === 'rate');
      calc();
    });
  });
  [amount, rate, totalEl].forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

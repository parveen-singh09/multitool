---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="slug-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Title or text
      <input id="sg-in" type="text" class="field" value="10 Best Tools for Web Developers in 2025!" autocomplete="off" />
    </label>

    <div class="flex flex-wrap items-end gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Separator
        <select id="sg-sep" class="field w-32">
          <option value="-">Hyphen ( - )</option>
          <option value="_">Underscore ( _ )</option>
        </select>
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input type="checkbox" id="sg-lower" checked class="accent-primary" /> Lowercase
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input type="checkbox" id="sg-strip" checked class="accent-primary" /> Strip stop words
      </label>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Slug
      <div class="copy-wrap">
        <input id="sg-out" type="text" class="field font-mono" readonly />
        <button type="button" class="copy-icon" data-copy-target="#sg-out" aria-label="Copy"></button>
      </div>
    </label>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free slug generator turns any title into a clean, SEO-friendly URL
      slug. It lowercases text, replaces spaces with hyphens, removes accents
      and special characters, and can optionally drop common stop words for
      shorter links. Ideal for blog permalinks and page URLs. Runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('sg-in') as HTMLInputElement;
  const sep = document.getElementById('sg-sep') as HTMLSelectElement;
  const lower = document.getElementById('sg-lower') as HTMLInputElement;
  const strip = document.getElementById('sg-strip') as HTMLInputElement;
  const out = document.getElementById('sg-out') as HTMLInputElement;

  const STOP = new Set(['a','an','and','the','or','but','of','to','in','on','for','with','at','by','from','is','are','in','2025']);

  function slugify() {
    let text = input.value.normalize('NFKD').replace(/[̀-ͯ]/g, '');
    if (lower.checked) text = text.toLowerCase();
    let words = text
      .replace(/[^a-zA-Z0-9\s-_]/g, '')
      .split(/[\s-_]+/)
      .filter(Boolean);
    if (strip.checked) {
      const kept = words.filter((w) => !STOP.has(w.toLowerCase()));
      if (kept.length) words = kept;
    }
    out.value = words.join(sep.value);
  }

  [input, sep, lower, strip].forEach((el) => el.addEventListener('input', slugify));
  slugify();
</script>

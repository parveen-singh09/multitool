---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="vcard-downloader">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Full name
        <input id="vcd-name" type="text" class="field" placeholder="Jane Doe" value="Jane Doe" />
      </label>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Organization
          <input id="vcd-org" type="text" class="field" placeholder="Acme Inc." />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Job title
          <input id="vcd-title" type="text" class="field" placeholder="Product Manager" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Phone
          <input id="vcd-phone" type="tel" class="field" placeholder="+1 555 123 4567" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Email
          <input id="vcd-email" type="email" class="field" placeholder="jane@example.com" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Website
          <input id="vcd-website" type="url" class="field" placeholder="https://example.com" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Address
          <input id="vcd-address" type="text" class="field" placeholder="123 Main St, City, Country" />
        </label>
      </div>

      <p id="vcd-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

      <div class="flex flex-wrap gap-2">
        <button id="vcd-dl" class="btn btn-primary">Download .vcf</button>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <span class="text-sm text-ink-subtle">Preview</span>
      <div class="panel p-4">
        <pre id="vcd-preview" class="font-mono text-[13px] whitespace-pre-wrap text-ink-subtle"></pre>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free vCard downloader builds a valid vCard 3.0 <code>.vcf</code> file from
      a contact’s name, organization, title, phone, email, website and address.
      Preview the generated card, then download a file you can import into your phone,
      Google Contacts, Apple Contacts, Outlook or any other address book. Every field
      is escaped correctly and the whole card is generated in your browser, so the
      contact details you enter never leave your device.
    </p>
  </div>
</ToolLayout>

<script>
  const nameEl = document.getElementById('vcd-name') as HTMLInputElement;
  const orgEl = document.getElementById('vcd-org') as HTMLInputElement;
  const titleEl = document.getElementById('vcd-title') as HTMLInputElement;
  const phoneEl = document.getElementById('vcd-phone') as HTMLInputElement;
  const emailEl = document.getElementById('vcd-email') as HTMLInputElement;
  const websiteEl = document.getElementById('vcd-website') as HTMLInputElement;
  const addressEl = document.getElementById('vcd-address') as HTMLInputElement;
  const preview = document.getElementById('vcd-preview') as HTMLPreElement;
  const err = document.getElementById('vcd-error') as HTMLParagraphElement;

  function escapeText(value: string): string {
    return value
      .replace(/\\/g, '\\\\')
      .replace(/;/g, '\\;')
      .replace(/,/g, '\\,')
      .replace(/\r\n|\n|\r/g, '\\n');
  }

  function structuredName(full: string): string {
    const parts = full.trim().split(/\s+/);
    const last = parts.length > 1 ? parts[parts.length - 1] : '';
    const first = parts.length > 1 ? parts.slice(0, -1).join(' ') : parts[0] ?? '';
    return `${escapeText(last)};${escapeText(first)};;;`;
  }

  function showError(msg: string): void {
    err.textContent = msg;
    err.classList.remove('hidden');
  }

  function clearError(): void {
    err.classList.add('hidden');
  }

  function build(): string | null {
    const name = nameEl.value.trim();
    if (!name) {
      showError('Please enter a name.');
      return null;
    }

    const lines: string[] = [
      'BEGIN:VCARD',
      'VERSION:3.0',
      `N:${structuredName(name)}`,
      `FN:${escapeText(name)}`,
    ];

    if (orgEl.value.trim()) lines.push(`ORG:${escapeText(orgEl.value.trim())}`);
    if (titleEl.value.trim()) lines.push(`TITLE:${escapeText(titleEl.value.trim())}`);
    if (phoneEl.value.trim()) lines.push(`TEL;TYPE=CELL:${escapeText(phoneEl.value.trim())}`);
    if (emailEl.value.trim()) lines.push(`EMAIL;TYPE=INTERNET:${escapeText(emailEl.value.trim())}`);
    if (websiteEl.value.trim()) lines.push(`URL:${escapeText(websiteEl.value.trim())}`);
    if (addressEl.value.trim()) lines.push(`ADR;TYPE=HOME:;;${escapeText(addressEl.value.trim())};;;;`);

    lines.push(`REV:${new Date().toISOString()}`);
    lines.push('END:VCARD');
    clearError();
    return lines.join('\r\n');
  }

  function render(): void {
    const vcard = build();
    preview.textContent = vcard ?? '';
  }

  function download(): void {
    const vcard = build();
    if (!vcard) return;
    const blob = new Blob([vcard], { type: 'text/vcard;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.download = 'contact.vcf';
    a.href = url;
    a.click();
    URL.revokeObjectURL(url);
  }

  [nameEl, orgEl, titleEl, phoneEl, emailEl, websiteEl, addressEl].forEach((el) =>
    el.addEventListener('input', render)
  );
  document.getElementById('vcd-dl')!.addEventListener('click', download);

  render();
</script>

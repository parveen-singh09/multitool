---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ratio-calculator">
  <div class="flex flex-col gap-6">
    <!-- Simplify a ratio -->
    <div class="panel panel-lift flex flex-col gap-3 p-5">
      <p class="text-sm text-ink">Simplify a ratio</p>
      <div class="flex flex-wrap items-center gap-2 text-sm text-ink-subtle">
        <input id="rs-a" type="number" class="field w-24 font-mono" value="16" inputmode="numeric" aria-label="Ratio A" /> :
        <input id="rs-b" type="number" class="field w-24 font-mono" value="9" inputmode="numeric" aria-label="Ratio B" /> =
        <span id="rs-out" class="font-mono text-lg text-primary-hover">—</span>
      </div>
    </div>

    <!-- Solve for X -->
    <div class="panel panel-lift flex flex-col gap-3 p-5">
      <p class="text-sm text-ink">Solve equivalent ratios (A : B = C : X)</p>
      <div class="flex flex-wrap items-center gap-2 text-sm text-ink-subtle">
        <input id="rp-a" type="number" class="field w-20 font-mono" value="3" inputmode="numeric" aria-label="A" /> :
        <input id="rp-b" type="number" class="field w-20 font-mono" value="4" inputmode="numeric" aria-label="B" /> =
        <input id="rp-c" type="number" class="field w-20 font-mono" value="9" inputmode="numeric" aria-label="C" /> :
        <span id="rp-x" class="font-mono text-lg text-primary-hover">—</span>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free ratio calculator does two jobs: it simplifies a ratio to its
      lowest whole-number terms, and it solves equivalent ratios for a missing
      value (given A : B = C : X, it finds X). It is useful for scaling recipes,
      mixing ratios and aspect ratios. All calculations run in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const gcd = (a: number, b: number): number => (b === 0 ? Math.abs(a) : gcd(b, a % b));

  function simplify() {
    const a = Math.trunc(Number($('rs-a').value));
    const b = Math.trunc(Number($('rs-b').value));
    const out = document.getElementById('rs-out')!;
    if (a === 0 && b === 0) { out.textContent = '—'; return; }
    const g = gcd(a, b) || 1;
    out.textContent = `${a / g} : ${b / g}`;
  }

  function solve() {
    const a = Number($('rp-a').value);
    const b = Number($('rp-b').value);
    const c = Number($('rp-c').value);
    const x = document.getElementById('rp-x')!;
    if (a === 0) { x.textContent = '—'; return; }
    const val = (b * c) / a;
    x.textContent = String(Math.round(val * 1e6) / 1e6);
  }

  document.querySelectorAll('#rs-a, #rs-b').forEach((el) => el.addEventListener('input', simplify));
  document.querySelectorAll('#rp-a, #rp-b, #rp-c').forEach((el) => el.addEventListener('input', solve));
  simplify();
  solve();
</script>

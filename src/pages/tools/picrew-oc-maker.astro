---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="picrew-oc-maker">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-[260px_1fr]">
    <div class="flex flex-col items-center gap-4">
      <div id="oc-art" class="aspect-square w-full max-w-[260px] overflow-hidden rounded-[16px] border border-hairline bg-surface-2"></div>
      <div class="flex w-full gap-2">
        <button id="oc-random" class="btn btn-secondary flex-1">🎲 Randomize</button>
        <button id="oc-dl" class="btn btn-primary flex-1">Download</button>
      </div>
    </div>

    <div id="oc-controls" class="flex flex-col gap-4"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Picrew-style OC maker builds a cute cartoon avatar for your
      original character from layered, code-drawn parts — face shape, skin tone,
      hairstyle and color, eyes, blush, and a background. Mix options with the
      swatches or hit Randomize to roll a whole new character, then download a
      crisp PNG for profiles, ref sheets and role-play. Everything is drawn as SVG
      in your browser — no accounts, no uploads, and all art is original so it's
      free to use.
    </p>
  </div>
</ToolLayout>

<script>
  import { randInt } from '../../lib/random';

  const art = document.getElementById('oc-art')!;
  const controls = document.getElementById('oc-controls')!;

  const SKIN = ['#ffe0bd', '#f1c27d', '#e0ac69', '#c68642', '#8d5524', '#5c3a21'];
  const HAIR = ['#2c222b', '#4b3621', '#8b5a2b', '#c19a6b', '#e6be8a', '#b7472a', '#d94f70', '#7b5ea7', '#3a7ca5', '#e8e8e8'];
  const EYES = ['#5b3a29', '#3a7ca5', '#2e7d32', '#6a4c93', '#b7472a', '#2c2c2c'];
  const BG = ['#f7d6e0', '#d6ecf7', '#e0f7d6', '#f7f0d6', '#ede0f7', '#f0f0f2', '#ffd9c0'];

  // Hair style renderers (top layer behind + front). Each takes hair color.
  const HAIRSTYLES: ((c: string) => string)[] = [
    // short
    (c) => `<path d="M50 78 Q50 30 100 30 Q150 30 150 78 Q150 55 100 52 Q50 55 50 78 Z" fill="${c}"/>`,
    // long
    (c) => `<path d="M45 150 Q40 40 100 32 Q160 40 155 150 Q150 90 130 80 Q150 55 100 50 Q50 55 70 80 Q50 90 45 150 Z" fill="${c}"/>`,
    // twin buns
    (c) => `<circle cx="55" cy="52" r="18" fill="${c}"/><circle cx="145" cy="52" r="18" fill="${c}"/><path d="M52 74 Q52 34 100 34 Q148 34 148 74 Q148 54 100 52 Q52 54 52 74 Z" fill="${c}"/>`,
    // curly / afro
    (c) => `<g fill="${c}"><circle cx="70" cy="45" r="22"/><circle cx="100" cy="36" r="24"/><circle cx="130" cy="45" r="22"/><circle cx="55" cy="65" r="18"/><circle cx="145" cy="65" r="18"/></g>`,
    // ponytail
    (c) => `<path d="M148 60 Q175 90 160 150 Q150 120 140 95 Z" fill="${c}"/><path d="M52 76 Q52 34 100 34 Q148 34 148 76 Q148 56 100 54 Q52 56 52 76 Z" fill="${c}"/>`,
    // bob with bangs
    (c) => `<path d="M48 120 Q42 40 100 34 Q158 40 152 120 Q152 70 130 66 L128 82 L118 66 L108 82 L100 66 L92 82 L82 66 L72 82 L70 66 Q48 70 48 120 Z" fill="${c}"/>`,
  ];

  const FACES: ((skin: string) => string)[] = [
    (s) => `<ellipse cx="100" cy="95" rx="46" ry="52" fill="${s}"/>`,      // oval
    (s) => `<circle cx="100" cy="98" r="48" fill="${s}"/>`,                 // round
    (s) => `<path d="M56 80 Q56 50 100 50 Q144 50 144 80 L140 110 Q120 148 100 148 Q80 148 60 110 Z" fill="${s}"/>`, // heart-ish
  ];

  const EYESHAPES: ((c: string) => string)[] = [
    (c) => `<g><ellipse cx="82" cy="98" rx="8" ry="10" fill="#fff"/><circle cx="82" cy="99" r="5" fill="${c}"/><ellipse cx="118" cy="98" rx="8" ry="10" fill="#fff"/><circle cx="118" cy="99" r="5" fill="${c}"/></g>`,
    (c) => `<g stroke="${c}" stroke-width="3" fill="none" stroke-linecap="round"><path d="M74 98 Q82 92 90 98"/><path d="M110 98 Q118 92 126 98"/></g>`, // happy closed
    (c) => `<g><rect x="75" y="92" width="14" height="14" rx="4" fill="#fff"/><rect x="79" y="94" width="8" height="12" rx="3" fill="${c}"/><rect x="111" y="92" width="14" height="14" rx="4" fill="#fff"/><rect x="115" y="94" width="8" height="12" rx="3" fill="${c}"/></g>`, // big square
  ];

  const MOUTHS: string[] = [
    `<path d="M92 122 Q100 130 108 122" stroke="#a05252" stroke-width="3" fill="none" stroke-linecap="round"/>`,
    `<path d="M94 122 Q100 126 106 122" stroke="#a05252" stroke-width="2.5" fill="none" stroke-linecap="round"/>`,
    `<ellipse cx="100" cy="124" rx="6" ry="7" fill="#a05252"/>`,
  ];

  const state = {
    bg: 0, skin: 1, face: 0, hair: 0, hairColor: 0, eye: 0, eyeColor: 0, mouth: 0, blush: 1,
  };

  function svg(): string {
    const skin = SKIN[state.skin];
    const hairC = HAIR[state.hairColor];
    const blush = state.blush ? `<g fill="#ff9a9a" opacity="0.5"><ellipse cx="72" cy="112" rx="8" ry="5"/><ellipse cx="128" cy="112" rx="8" ry="5"/></g>` : '';
    return `<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
      <rect width="200" height="200" fill="${BG[state.bg]}"/>
      <path d="M70 140 Q70 160 60 195 L140 195 Q130 160 130 140 Z" fill="${skin}"/>
      ${FACES[state.face](skin)}
      ${HAIRSTYLES[state.hair](hairC)}
      ${EYESHAPES[state.eye](EYES[state.eyeColor])}
      <path d="M97 104 Q100 110 103 104" stroke="${skin}" stroke-width="2" fill="none" opacity="0.6"/>
      ${MOUTHS[state.mouth]}
      ${blush}
    </svg>`;
  }

  function render() {
    art.innerHTML = svg();
  }

  function swatches(label: string, key: keyof typeof state, options: string[], colors?: string[]) {
    const items = options
      .map((_, i) => {
        const active = state[key] === i;
        const bg = colors ? colors[i] : (i % 2 ? '#141516' : '#18191a');
        const style = colors ? `background:${bg}` : '';
        return `<button data-key="${key}" data-i="${i}" class="h-9 min-w-9 rounded-[6px] border px-2 text-[12px] ${active ? 'border-primary text-ink' : 'border-hairline text-ink-subtle'}" style="${style}">${colors ? '' : i + 1}</button>`;
      })
      .join('');
    return `<div class="flex flex-col gap-1.5">
      <span class="text-[12px] uppercase tracking-wide text-ink-tertiary">${label}</span>
      <div class="flex flex-wrap gap-1.5">${items}</div>
    </div>`;
  }

  function renderControls() {
    controls.innerHTML =
      swatches('Background', 'bg', BG, BG) +
      swatches('Skin', 'skin', SKIN, SKIN) +
      swatches('Face', 'face', FACES.map(String)) +
      swatches('Hair style', 'hair', HAIRSTYLES.map(String)) +
      swatches('Hair color', 'hairColor', HAIR, HAIR) +
      swatches('Eyes', 'eye', EYESHAPES.map(String)) +
      swatches('Eye color', 'eyeColor', EYES, EYES) +
      swatches('Mouth', 'mouth', MOUTHS) +
      swatches('Blush', 'blush', ['off', 'on']);

    controls.querySelectorAll<HTMLButtonElement>('[data-key]').forEach((btn) => {
      btn.addEventListener('click', () => {
        (state as any)[btn.dataset.key!] = Number(btn.dataset.i);
        render(); renderControls();
      });
    });
  }

  function randomize() {
    state.bg = randInt(0, BG.length - 1);
    state.skin = randInt(0, SKIN.length - 1);
    state.face = randInt(0, FACES.length - 1);
    state.hair = randInt(0, HAIRSTYLES.length - 1);
    state.hairColor = randInt(0, HAIR.length - 1);
    state.eye = randInt(0, EYESHAPES.length - 1);
    state.eyeColor = randInt(0, EYES.length - 1);
    state.mouth = randInt(0, MOUTHS.length - 1);
    state.blush = randInt(0, 1);
    render(); renderControls();
  }

  function download() {
    const source = svg().replace('width="100%" height="100%"', 'width="512" height="512"');
    const blob = new Blob([source], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    const image = new Image();
    image.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = 512; canvas.height = 512;
      canvas.getContext('2d')!.drawImage(image, 0, 0, 512, 512);
      const a = document.createElement('a');
      a.href = canvas.toDataURL('image/png');
      a.download = 'my-oc.png';
      a.click();
      URL.revokeObjectURL(url);
    };
    image.src = url;
  }

  document.getElementById('oc-random')!.addEventListener('click', randomize);
  document.getElementById('oc-dl')!.addEventListener('click', download);

  render();
  renderControls();
</script>

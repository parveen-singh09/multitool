---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="creatinine-clearance-calculator">
  <div class="flex flex-col gap-5">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Units">
      <button data-unit="metric" class="crcl-tab btn btn-primary" aria-selected="true">Metric (mg/dL, kg)</button>
      <button data-unit="si" class="crcl-tab btn btn-secondary" aria-selected="false">SI (µmol/L)</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sex
        <select id="crcl-sex" class="field">
          <option value="male">Male</option>
          <option value="female">Female</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Age (years)
        <input id="crcl-age" type="number" min="1" max="120" class="field" value="55" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight (kg)
        <input id="crcl-weight" type="number" min="1" class="field" value="80" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle"><span id="crcl-scr-label">Serum creatinine (mg/dL)</span>
        <input id="crcl-scr" type="number" min="0.1" step="0.01" class="field" value="1.1" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (cm)
        <input id="crcl-height" type="number" min="1" class="field" value="175" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Body weight used
        <select id="crcl-bw" class="field">
          <option value="actual">Actual body weight</option>
          <option value="ideal">Ideal body weight (Devine)</option>
          <option value="adjusted">Adjusted body weight</option>
        </select>
      </label>
    </div>

    <div class="panel panel-lift p-6 text-center">
      <div class="text-sm text-ink-subtle">Creatinine clearance (Cockcroft-Gault)</div>
      <div class="copy-wrap"><div id="crcl-value" class="mt-1 font-display text-4xl font-semibold text-primary-hover">—</div><button type="button" class="copy-icon" data-copy-target="#crcl-value" aria-label="Copy"></button></div>
      <div id="crcl-stage" class="mt-2 text-sm text-ink-muted"></div>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="panel p-4 text-center"><div class="copy-wrap"><div id="crcl-bsa" class="font-mono text-lg text-ink">—</div><button type="button" class="copy-icon" data-copy-target="#crcl-bsa" aria-label="Copy"></button></div><div class="mt-1 text-[13px] text-ink-subtle">BSA-normalized (mL/min/1.73m²)</div></div>
      <div class="panel p-4 text-center"><div class="copy-wrap"><div id="crcl-wtused" class="font-mono text-lg text-ink">—</div><button type="button" class="copy-icon" data-copy-target="#crcl-wtused" aria-label="Copy"></button></div><div class="mt-1 text-[13px] text-ink-subtle">Weight used in formula</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free creatinine clearance calculator estimates kidney function using
      the Cockcroft-Gault equation from age, weight, sex and serum creatinine. The
      result, in mL/min, approximates how much blood your kidneys filter per
      minute and is widely used to guide medication dosing. For women the estimate
      is multiplied by 0.85. It also shows the rough CKD stage the value falls in.
      This is an educational estimate — actual clinical decisions require a
      healthcare professional and may use other equations like CKD-EPI.
    </p>
  </div>
</ToolLayout>

<script>
  let unit: 'metric' | 'si' = 'metric';
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const sexEl = document.getElementById('crcl-sex') as unknown as HTMLSelectElement;

  function stage(crcl: number): [string, string] {
    if (crcl >= 90) return ['Normal kidney function (Stage 1)', '#27a644'];
    if (crcl >= 60) return ['Mildly reduced (Stage 2)', '#27a644'];
    if (crcl >= 45) return ['Mild–moderate (Stage 3a)', '#d2a05e'];
    if (crcl >= 30) return ['Moderate–severe (Stage 3b)', '#d2a05e'];
    if (crcl >= 15) return ['Severely reduced (Stage 4)', '#e5484d'];
    return ['Kidney failure (Stage 5)', '#e5484d'];
  }

  function calc() {
    const male = sexEl.value === 'male';
    const age = Number($('crcl-age').value);
    const actualWeight = Number($('crcl-weight').value);
    const heightCm = Number($('crcl-height').value);
    const bwMode = (document.getElementById('crcl-bw') as HTMLSelectElement).value;
    let scr = Number($('crcl-scr').value); 

    const valueEl = document.getElementById('crcl-value')!;
    const stageEl = document.getElementById('crcl-stage')!;
    const bsaEl = document.getElementById('crcl-bsa')!;
    const wtUsedEl = document.getElementById('crcl-wtused')!;

    if (unit === 'si') scr = scr / 88.42;

    const clear = () => { valueEl.textContent = '—'; stageEl.textContent = ''; bsaEl.textContent = '—'; wtUsedEl.textContent = '—'; };
    if (!(age > 0) || !(actualWeight > 0) || !(scr > 0)) { clear(); return; }

    const inchesOver5ft = Math.max(0, heightCm / 2.54 - 60);
    const ibw = (male ? 50 : 45.5) + 2.3 * inchesOver5ft;
    let weight = actualWeight;
    if (heightCm > 0) {
      if (bwMode === 'ideal') weight = ibw;
      else if (bwMode === 'adjusted') weight = ibw + 0.4 * (actualWeight - ibw);
    }

    let crcl = ((140 - age) * weight) / (72 * scr);
    if (!male) crcl *= 0.85;

    if (!isFinite(crcl) || crcl <= 0) { clear(); return; }

    valueEl.textContent = crcl.toFixed(1) + ' mL/min';
    const [label, color] = stage(crcl);
    stageEl.textContent = label;
    stageEl.style.color = color;
    wtUsedEl.textContent = weight.toFixed(1) + ' kg';

    if (heightCm > 0) {
      const bsa = 0.007184 * Math.pow(heightCm, 0.725) * Math.pow(actualWeight, 0.425);
      bsaEl.textContent = (crcl * 1.73 / bsa).toFixed(1);
    } else {
      bsaEl.textContent = '—';
    }
  }

  document.querySelectorAll<HTMLButtonElement>('.crcl-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      unit = tab.dataset.unit as 'metric' | 'si';
      document.querySelectorAll('.crcl-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('crcl-scr-label')!.textContent =
        unit === 'metric' ? 'Serum creatinine (mg/dL)' : 'Serum creatinine (µmol/L)';
      const scrEl = $('crcl-scr');

      const cur = Number(scrEl.value);
      if (cur > 0) scrEl.value = unit === 'si' ? (cur * 88.42).toFixed(0) : (cur / 88.42).toFixed(2);
      calc();
    });
  });

  document
    .querySelectorAll('#crcl-sex, #crcl-age, #crcl-weight, #crcl-scr, #crcl-height, #crcl-bw')
    .forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="toml-to-json-converter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <label id="t2j-indent-wrap" class="flex items-center gap-2">
        Indent
        <select id="t2j-indent" class="field w-auto py-1">
          <option value="2" selected>2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <label class="flex items-center gap-2">
        <input id="t2j-minify" type="checkbox" class="h-4 w-4" />
        Minify JSON
      </label>
      <label class="flex items-center gap-2">
        <input id="t2j-sortkeys" type="checkbox" class="h-4 w-4" />
        Sort keys
      </label>
      <label class="btn btn-tertiary cursor-pointer ml-auto">
        Upload .toml
        <input id="t2j-file" type="file" accept=".toml,.txt,text/plain" class="hidden" />
      </label>
      <button id="t2j-sample" type="button" class="btn btn-tertiary">Sample</button>
    </div>

    <div id="t2j-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>TOML input</span>
          <button id="t2j-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
        </span>
        <div id="t2j-drop" class="hl-edit field p-0" style="height:22rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="t2j-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea id="t2j-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="TOML input"></textarea>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>JSON output</span>
          <span class="flex gap-2">
            <button id="t2j-copy" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy</button>
            <button id="t2j-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
          </span>
        </span>
        <pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre"><code id="t2j-out" class="hljs" style="background:transparent;padding:0"></code></pre>
      </div>
    </div>

    <p id="t2j-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free TOML to JSON converter parses TOML configuration into formatted
      JSON, live as you type, with both panes syntax-highlighted. It supports
      <code>[table]</code> and dotted <code>[a.b]</code> nested tables, arrays of
      tables (<code>[[array]]</code>), inline tables, and key-value pairs with
      strings, integers, floats, booleans and arrays; dates and date-times are
      kept as strings. Underscores in numbers are handled. Syntax errors are
      flagged with a line number so you can jump straight to the problem.
    </p>
    <p>
      Paste TOML, upload a <code>.toml</code> file, or drag-and-drop it onto the
      input pane. Output can be pretty-printed at 2 spaces, 4 spaces or a tab, or
      minified to a single line, and keys can be sorted alphabetically for stable
      diffs. Copy the result to your clipboard or download it as a
      <code>.json</code> file. It covers the common subset of TOML rather than
      every corner of the specification, and runs entirely in your browser —
      nothing is uploaded to a server.
    </p>
  </div>
</ToolLayout>

<script>
  import { parseToml, type Json } from '../../lib/dataformats';
  import { hl, wireInput } from '../../lib/highlight';

  const input = document.getElementById('t2j-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('t2j-in-hl')!;
  const output = document.getElementById('t2j-out')!;
  const err = document.getElementById('t2j-error')!;
  const statusEl = document.getElementById('t2j-status')!;
  const indentSel = document.getElementById('t2j-indent') as HTMLSelectElement;
  const indentWrap = document.getElementById('t2j-indent-wrap')!;
  const minifyBox = document.getElementById('t2j-minify') as HTMLInputElement;
  const sortBox = document.getElementById('t2j-sortkeys') as HTMLInputElement;
  const drop = document.getElementById('t2j-drop')!;
  let rawOutput = '';

  const SAMPLE = 'title = "ToolCities"\n\n[owner]\nname = "Ada"\nports = [80, 443]\nactive = true\n\n[[servers]]\nhost = "alpha"\nrps = 1_200\n\n[[servers]]\nhost = "beta"\nrps = 3_400';

  function getIndent(): string | number {
    return indentSel.value === 'tab' ? '\t' : Number(indentSel.value);
  }

  // Recursively sort object keys for stable, diff-friendly output.
  function sortKeys(v: Json): Json {
    if (Array.isArray(v)) return v.map(sortKeys);
    if (v !== null && typeof v === 'object') {
      const out: { [k: string]: Json } = {};
      for (const k of Object.keys(v).sort()) out[k] = sortKeys((v as { [k: string]: Json })[k]);
      return out;
    }
    return v;
  }

  function showStatus(msg: string) {
    statusEl.textContent = msg;
    statusEl.classList.remove('hidden');
    statusEl.style.borderColor = '#27a644';
    statusEl.style.color = '#27a644';
  }

  function syncUI() {
    indentWrap.style.display = minifyBox.checked ? 'none' : '';
  }

  const rerender = wireInput(input, inHl, () => 'ini', () => { void convert(); });

  async function convert() {
    syncUI();
    err.classList.add('hidden');
    const raw = input.value.trim();
    if (!raw) {
      rawOutput = ''; output.textContent = ''; statusEl.classList.add('hidden');
      return;
    }
    try {
      let data = parseToml(input.value);
      if (sortBox.checked) data = sortKeys(data);
      rawOutput = JSON.stringify(data, null, minifyBox.checked ? undefined : getIndent());
      await hl(output, rawOutput, 'json');
      const bytes = new Blob([rawOutput]).size;
      const lines = rawOutput.split('\n').length;
      showStatus(`Converted to JSON · ${lines} ${lines === 1 ? 'line' : 'lines'} · ${bytes} bytes ✓`);
    } catch (e) {
      rawOutput = ''; output.textContent = ''; statusEl.classList.add('hidden');
      err.textContent = (e as Error).message;
      err.classList.remove('hidden');
    }
  }

  indentSel.addEventListener('change', () => { if (rawOutput || minifyBox.checked) void convert(); });
  minifyBox.addEventListener('change', () => { void convert(); });
  sortBox.addEventListener('change', () => { void convert(); });

  document.getElementById('t2j-sample')!.addEventListener('click', () => {
    input.value = SAMPLE; rerender(); void convert();
  });

  document.getElementById('t2j-clear')!.addEventListener('click', () => {
    input.value = ''; rawOutput = ''; output.textContent = '';
    err.classList.add('hidden'); statusEl.classList.add('hidden');
    rerender();
  });

  document.getElementById('t2j-copy')!.addEventListener('click', async (e) => {
    if (!rawOutput) return;
    await navigator.clipboard.writeText(rawOutput);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });

  document.getElementById('t2j-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const blob = new Blob([rawOutput], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'converted.json';
    a.click();
    URL.revokeObjectURL(url);
  });

  // Upload / drag-and-drop a .toml file onto the input pane.
  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => { input.value = String(reader.result ?? ''); rerender(); void convert(); };
    reader.onerror = () => { err.textContent = 'Could not read file.'; err.classList.remove('hidden'); };
    reader.readAsText(file);
  }

  const fileInput = document.getElementById('t2j-file') as HTMLInputElement;
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  ['dragover', 'dragenter'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.style.outline = '2px solid #5e6ad2'; }));
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, () => { drop.style.outline = ''; }));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) loadFile(file);
  });

  input.value = SAMPLE;
  rerender();
  void convert();
</script>

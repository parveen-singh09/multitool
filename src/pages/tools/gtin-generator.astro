---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="gtin-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        GTIN format
        <select id="gt-fmt" class="field w-40">
          <option value="8">GTIN-8</option>
          <option value="12">GTIN-12 (UPC-A)</option>
          <option value="13" selected>GTIN-13 (EAN-13)</option>
          <option value="14">GTIN-14</option>
        </select>
      </label>
      <button id="gt-rand" type="button" class="btn btn-primary">Generate</button>
    </div>
    <p class="text-[13px] text-ink-tertiary">GTIN: <span id="gt-full" class="font-mono text-ink"></span></p>

    <div class="flex justify-center rounded-[8px] border border-hairline bg-white p-6">
      <canvas id="gt-canvas" class="max-w-full"></canvas>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="gt-png" type="button" class="btn btn-primary">Download PNG</button>
      <button id="gt-svg" type="button" class="btn btn-secondary">Download SVG</button>
    </div>
    <p id="gt-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free GTIN generator creates valid Global Trade Item Numbers in all
      four lengths — GTIN-8, GTIN-12, GTIN-13 and GTIN-14 — each with a correct
      mod-10 check digit. GTIN-12 renders as a UPC-A barcode and GTIN-13 as an
      EAN-13; the shorter and longer forms are shown as numbers with their check
      digit. Handy for testing product and inventory systems. Runs in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { toCanvas, toSVG } from '../../lib/barcode';
  import { gtinCheckDigit, randInt } from '../../lib/random';

  const fmtEl = document.getElementById('gt-fmt') as HTMLSelectElement;
  const fullEl = document.getElementById('gt-full')!;
  const canvas = document.getElementById('gt-canvas') as HTMLCanvasElement;
  const err = document.getElementById('gt-error')!;
  const pngBtn = document.getElementById('gt-png') as HTMLButtonElement;
  const svgBtn = document.getElementById('gt-svg') as HTMLButtonElement;
  let current = '';

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  // Which formats have a renderable linear barcode symbology in bwip-js.
  function bcidFor(len: number): string | null {
    if (len === 12) return 'upca';
    if (len === 13) return 'ean13';
    if (len === 8) return 'ean8';
    return null; // GTIN-14 has no single standalone retail symbology here
  }

  async function generate() {
    const len = Number(fmtEl.value);
    let p = '';
    for (let i = 0; i < len - 1; i++) p += randInt(0, 9);
    current = p + gtinCheckDigit(p);
    fullEl.textContent = current;

    const bcid = bcidFor(len);
    canvas.classList.toggle('hidden', !bcid);
    pngBtn.disabled = !bcid; svgBtn.disabled = !bcid;
    if (bcid) {
      try {
        await toCanvas(canvas, { bcid, text: current, includetext: true, scale: 3, height: 20 });
        setErr('');
      } catch { setErr('Could not render barcode.'); }
    } else {
      setErr('GTIN-14 has no standalone retail barcode — use the number, or GTIN-13 for a barcode.');
    }
  }

  function download(href: string, name: string) {
    const a = document.createElement('a'); a.href = href; a.download = name; a.click();
  }

  fmtEl.addEventListener('change', generate);
  document.getElementById('gt-rand')!.addEventListener('click', generate);
  pngBtn.addEventListener('click', () => download(canvas.toDataURL('image/png'), 'gtin.png'));
  svgBtn.addEventListener('click', async () => {
    const bcid = bcidFor(Number(fmtEl.value)); if (!bcid || !current) return;
    const svg = await toSVG({ bcid, text: current, includetext: true, scale: 3, height: 20 });
    const url = URL.createObjectURL(new Blob([svg], { type: 'image/svg+xml' }));
    download(url, 'gtin.svg');
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });

  generate();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="image-metadata-analyzer">
  <div class="flex flex-col gap-4">
    <div id="ima-drop" class="panel panel-lift flex min-h-32 cursor-pointer flex-col items-center justify-center gap-2 p-6 text-center text-ink-subtle transition-colors hover:bg-surface-2">
      <div class="text-sm">Drop an image here or click to choose a file</div>
      <div class="text-[13px] text-ink-muted">JPG, PNG, GIF, WebP, SVG — read locally, never uploaded</div>
      <input id="ima-file" type="file" accept="image/*" class="hidden" />
    </div>

    <p id="ima-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="ima-result" class="hidden flex-col gap-4">
      <div class="panel overflow-hidden p-4">
        <img id="ima-preview" alt="Selected image preview" class="mx-auto max-h-64 rounded" />
      </div>

      <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
        <div class="panel panel-lift p-4"><div id="ima-dims" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Dimensions</div></div>
        <div class="panel p-4"><div id="ima-type" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Type</div></div>
        <div class="panel p-4"><div id="ima-size" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">File size</div></div>
        <div class="panel p-4"><div id="ima-ratio" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Aspect ratio</div></div>
        <div class="panel p-4"><div id="ima-mp" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Megapixels</div></div>
        <div class="panel p-4"><div id="ima-name" class="truncate font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">File name</div></div>
      </div>

      <div>
        <h2 class="mb-2 font-display text-sm font-semibold text-ink">EXIF (JPEG)</h2>
        <div id="ima-exif" class="text-[13px] text-ink-subtle">—</div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free image metadata analyzer reads an image entirely in your browser
      to show its pixel dimensions, format, file size, aspect ratio and megapixel
      count. For JPEG files it also attempts to read basic EXIF fields such as
      camera make, model and orientation from the APP1 segment. Your image is
      read locally with the FileReader API and is never uploaded to any server.
    </p>
  </div>
</ToolLayout>

<script>
  const drop = document.getElementById('ima-drop') as HTMLElement;
  const file = document.getElementById('ima-file') as HTMLInputElement;
  const err = document.getElementById('ima-error')!;
  const result = document.getElementById('ima-result') as HTMLElement;
  const preview = document.getElementById('ima-preview') as HTMLImageElement;
  const exifEl = document.getElementById('ima-exif')!;
  const set = (id: string, val: string) => { document.getElementById(id)!.textContent = val; };

  function gcd(a: number, b: number): number { return b === 0 ? a : gcd(b, a % b); }
  function fmtSize(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
  }

  const ORIENTATIONS: Record<number, string> = {
    1: 'Normal', 2: 'Flip horizontal', 3: 'Rotate 180°', 4: 'Flip vertical',
    5: 'Transpose', 6: 'Rotate 90° CW', 7: 'Transverse', 8: 'Rotate 90° CCW',
  };

  interface Exif { make?: string; model?: string; orientation?: number; software?: string; }

  function parseJpegExif(buffer: ArrayBuffer): Exif | null {
    const view = new DataView(buffer);
    if (view.getUint16(0) !== 0xffd8) return null; // not a JPEG
    let offset = 2;
    const len = view.byteLength;
    while (offset < len) {
      if (view.getUint16(offset) !== 0xffe0 && (view.getUint16(offset) & 0xff00) !== 0xff00) break;
      const marker = view.getUint16(offset);
      const size = view.getUint16(offset + 2);
      if (marker === 0xffe1) {
        // APP1 — check for "Exif\0\0"
        if (view.getUint32(offset + 4) === 0x45786966) {
          return parseExifBlock(view, offset + 10);
        }
      }
      if (marker === 0xffda) break; // start of scan
      offset += 2 + size;
    }
    return null;
  }

  function parseExifBlock(view: DataView, tiffStart: number): Exif | null {
    const byteOrder = view.getUint16(tiffStart);
    const little = byteOrder === 0x4949;
    const get16 = (o: number) => view.getUint16(o, little);
    const get32 = (o: number) => view.getUint32(o, little);
    if (get16(tiffStart + 2) !== 0x002a) return null;
    const ifd0 = tiffStart + get32(tiffStart + 4);
    const out: Exif = {};
    const count = get16(ifd0);
    for (let i = 0; i < count; i++) {
      const entry = ifd0 + 2 + i * 12;
      const tag = get16(entry);
      const type = get16(entry + 2);
      const num = get32(entry + 4);
      if (tag === 0x0112) { out.orientation = get16(entry + 8); continue; }
      if (type === 2 && (tag === 0x010f || tag === 0x0110 || tag === 0x0131)) {
        const valOffset = num > 4 ? tiffStart + get32(entry + 8) : entry + 8;
        let str = '';
        for (let j = 0; j < num - 1; j++) {
          const c = view.getUint8(valOffset + j);
          if (c === 0) break;
          str += String.fromCharCode(c);
        }
        str = str.trim();
        if (tag === 0x010f) out.make = str;
        else if (tag === 0x0110) out.model = str;
        else if (tag === 0x0131) out.software = str;
      }
    }
    return out;
  }

  function handle(f: File) {
    err.classList.add('hidden');
    if (!f.type.startsWith('image/')) {
      err.textContent = 'Please choose an image file.';
      err.classList.remove('hidden');
      return;
    }

    const url = URL.createObjectURL(f);
    preview.src = url;
    result.classList.remove('hidden');
    result.classList.add('flex');

    set('ima-type', f.type || 'unknown');
    set('ima-size', fmtSize(f.size));
    set('ima-name', f.name);
    exifEl.textContent = 'Reading…';

    const img = new Image();
    img.onload = () => {
      const w = img.naturalWidth, h = img.naturalHeight;
      set('ima-dims', `${w} × ${h}`);
      if (w && h) {
        const g = gcd(w, h);
        set('ima-ratio', `${w / g}:${h / g}`);
        set('ima-mp', `${((w * h) / 1e6).toFixed(2)} MP`);
      } else {
        set('ima-ratio', '—');
        set('ima-mp', '—');
      }
    };
    img.onerror = () => {
      set('ima-dims', 'unknown');
      set('ima-ratio', '—');
      set('ima-mp', '—');
    };
    img.src = url;

    if (f.type === 'image/jpeg') {
      const reader = new FileReader();
      reader.onload = () => {
        const exif = parseJpegExif(reader.result as ArrayBuffer);
        if (!exif || (!exif.make && !exif.model && !exif.orientation && !exif.software)) {
          exifEl.textContent = 'No EXIF found.';
          return;
        }
        const parts: string[] = [];
        if (exif.make) parts.push(`Make: ${exif.make}`);
        if (exif.model) parts.push(`Model: ${exif.model}`);
        if (exif.software) parts.push(`Software: ${exif.software}`);
        if (exif.orientation) parts.push(`Orientation: ${ORIENTATIONS[exif.orientation] || exif.orientation}`);
        exifEl.innerHTML = '';
        const wrap = document.createElement('div');
        wrap.className = 'flex flex-wrap gap-2';
        for (const p of parts) {
          const chip = document.createElement('span');
          chip.className = 'panel px-3 py-1 font-mono text-[13px] text-ink';
          chip.textContent = p;
          wrap.appendChild(chip);
        }
        exifEl.appendChild(wrap);
      };
      reader.onerror = () => { exifEl.textContent = 'Could not read EXIF.'; };
      reader.readAsArrayBuffer(f);
    } else {
      exifEl.textContent = 'EXIF is only read from JPEG files.';
    }
  }

  drop.addEventListener('click', () => file.click());
  file.addEventListener('change', () => { if (file.files && file.files[0]) handle(file.files[0]); });
  drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('bg-surface-2'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('bg-surface-2'));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    drop.classList.remove('bg-surface-2');
    if (e.dataTransfer && e.dataTransfer.files[0]) handle(e.dataTransfer.files[0]);
  });
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="trivia-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Category
        <select id="tv-cat" class="field w-48">
          <option value="any">Any</option>
          <option value="Science">Science</option>
          <option value="History">History</option>
          <option value="Geography">Geography</option>
          <option value="Pop culture">Pop culture</option>
          <option value="Sports">Sports</option>
        </select>
      </label>
      <button id="tv-gen" class="btn btn-primary ml-auto">New question</button>
    </div>
    <div class="panel panel-lift flex flex-col gap-3 p-5">
      <span id="tv-cat-label" class="text-xs uppercase tracking-wide text-primary-hover"></span>
      <p id="tv-q" class="text-lg leading-relaxed text-ink"></p>
      <button id="tv-reveal" class="btn btn-secondary w-fit">Reveal answer</button>
      <p id="tv-a" class="hidden text-[15px] font-medium text-success"></p>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free trivia question generator draws random questions across categories
      — science, history, geography, pop culture and sports — with the answer
      hidden until you click reveal. It's a quick source of questions for quiz
      night, the classroom, icebreakers and road trips. Everything runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { pick } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;

  const Q: { c: string; q: string; a: string }[] = [
    { c: 'Science', q: 'What is the chemical symbol for gold?', a: 'Au' },
    { c: 'Science', q: 'How many bones are in the adult human body?', a: '206' },
    { c: 'Science', q: 'What planet is known as the Red Planet?', a: 'Mars' },
    { c: 'Science', q: 'What gas do plants absorb from the atmosphere?', a: 'Carbon dioxide' },
    { c: 'History', q: 'In what year did World War II end?', a: '1945' },
    { c: 'History', q: 'Who was the first President of the United States?', a: 'George Washington' },
    { c: 'History', q: 'The Great Wall is located in which country?', a: 'China' },
    { c: 'Geography', q: 'What is the largest ocean on Earth?', a: 'The Pacific Ocean' },
    { c: 'Geography', q: 'What is the capital of Australia?', a: 'Canberra' },
    { c: 'Geography', q: 'Which country has the most natural lakes?', a: 'Canada' },
    { c: 'Geography', q: 'What is the longest river in the world?', a: 'The Nile (by most measures)' },
    { c: 'Pop culture', q: 'Which band released the album "Abbey Road"?', a: 'The Beatles' },
    { c: 'Pop culture', q: 'What is the name of the toy cowboy in Toy Story?', a: 'Woody' },
    { c: 'Pop culture', q: 'Who painted the Mona Lisa?', a: 'Leonardo da Vinci' },
    { c: 'Sports', q: 'How many players are on a soccer team on the field?', a: '11' },
    { c: 'Sports', q: 'In which sport would you perform a slam dunk?', a: 'Basketball' },
    { c: 'Sports', q: 'How often are the Summer Olympics held?', a: 'Every four years' },
  ];

  function generate() {
    const cat = ($('tv-cat') as HTMLSelectElement).value;
    const pool = cat === 'any' ? Q : Q.filter((x) => x.c === cat);
    const item = pick(pool);
    $('tv-cat-label').textContent = item.c;
    $('tv-q').textContent = item.q;
    const a = $('tv-a')!;
    a.textContent = 'Answer: ' + item.a;
    a.classList.add('hidden');
  }

  $('tv-cat').addEventListener('change', generate);
  $('tv-gen').addEventListener('click', generate);
  $('tv-reveal').addEventListener('click', () => $('tv-a').classList.toggle('hidden'));
  generate();
</script>

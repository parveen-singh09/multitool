---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="simple-interest-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Principal
        <input id="si-p" type="number" min="0" class="field" value="10000" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Annual rate (%)
        <input id="si-rate" type="number" min="0" step="0.01" class="field" value="5" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Time
        <span class="flex gap-2">
          <input id="si-time" type="number" min="0" step="0.1" class="field" value="3" inputmode="decimal" />
          <select id="si-timeunit" class="field w-28"><option value="years">years</option><option value="months">months</option><option value="days">days</option></select>
        </span>
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="panel panel-lift p-5 text-center"><div id="si-interest" class="font-display text-2xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Interest</div></div>
      <div class="panel p-5 text-center"><div id="si-total" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Total amount</div></div>
    </div>

    <p id="si-formula" class="text-center font-mono text-[13px] text-ink-subtle"></p>

    <!-- Per-period breakdown -->
    <details class="panel p-0">
      <summary class="cursor-pointer list-none px-5 py-4 text-sm font-medium text-ink hover:text-primary-hover">
        <span class="inline-flex items-center gap-2">▸ Interest per period</span>
      </summary>
      <div class="overflow-x-auto border-t border-hairline">
        <table class="w-full text-right text-[13px]">
          <thead class="text-ink-subtle"><tr class="border-b border-hairline"><th class="px-4 py-2 text-left font-medium">Period</th><th class="px-4 py-2 font-medium">Interest</th><th class="px-4 py-2 font-medium">Balance</th></tr></thead>
          <tbody id="si-sched" class="font-mono text-ink-muted"></tbody>
        </table>
      </div>
    </details>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free simple interest calculator uses the classic formula
      <code class="font-mono text-ink">I = P × R × T</code> to find the interest on a principal amount
      at a fixed annual rate over a period of time, plus the total repayable. It
      is ideal for short-term loans and quick estimates. All maths runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  const p = document.getElementById('si-p') as HTMLInputElement;
  const rate = document.getElementById('si-rate') as HTMLInputElement;
  const time = document.getElementById('si-time') as HTMLInputElement;
  const timeUnit = document.getElementById('si-timeunit') as unknown as HTMLSelectElement;
  const money = (n: number) => n.toLocaleString(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });

  function calc() {
    const P = Number(p.value) || 0;
    const R = Number(rate.value) / 100;
    const tRaw = Number(time.value) || 0;
    // Convert the entered term to years for the I = P·R·T math.
    const years = timeUnit.value === 'months' ? tRaw / 12 : timeUnit.value === 'days' ? tRaw / 365 : tRaw;
    const interest = P * R * years;
    document.getElementById('si-interest')!.textContent = money(interest);
    document.getElementById('si-total')!.textContent = money(P + interest);
    document.getElementById('si-formula')!.textContent =
      `I = ${money(P)} × ${(R).toString()} × ${years.toFixed(4).replace(/\.?0+$/, '')} yr = ${money(interest)}`;

    // Per-period breakdown: split the term into whole periods of the chosen unit.
    const sched = document.getElementById('si-sched')!;
    const perYearInterest = P * R; // interest accrued per year (simple)
    const periods = timeUnit.value === 'months' ? tRaw : timeUnit.value === 'days' ? tRaw : tRaw;
    const perPeriod = timeUnit.value === 'months' ? perYearInterest / 12 : timeUnit.value === 'days' ? perYearInterest / 365 : perYearInterest;
    const label = timeUnit.value === 'months' ? 'Month' : timeUnit.value === 'days' ? 'Day' : 'Year';
    const whole = Math.floor(periods);
    const rows: string[] = [];
    let cum = 0;
    for (let i = 1; i <= Math.min(whole, 120); i++) { // cap rows so a 3650-day term doesn't render 3650 rows
      cum += perPeriod;
      rows.push(`<tr class="border-b border-hairline/50"><td class="px-4 py-1.5 text-left text-ink-subtle">${label} ${i}</td><td class="px-4 py-1.5">${money(perPeriod)}</td><td class="px-4 py-1.5">${money(P + cum)}</td></tr>`);
    }
    if (whole > 120) rows.push(`<tr><td class="px-4 py-1.5 text-left text-ink-tertiary" colspan="3">… ${whole - 120} more ${label.toLowerCase()}s</td></tr>`);
    sched.innerHTML = rows.join('');
  }
  [p, rate, time].forEach((el) => el.addEventListener('input', calc));
  timeUnit.addEventListener('change', calc);
  calc();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="reading-time-estimator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Your text
      <div class="copy-wrap">
        <textarea id="rte-text" class="field min-h-40 w-full resize-y text-sm" placeholder="Paste or type your text here…" spellcheck="false">Paste your article, blog post or speech here to estimate how long it takes to read silently and to read aloud. The estimator counts words and sentences as you type.</textarea>
        <button type="button" class="copy-icon" data-copy-target="#rte-text" aria-label="Copy"></button>
      </div>
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Reading speed (words per minute)
        <input id="rte-read-wpm" type="number" min="1" step="1" class="field" value="238" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Speaking speed (words per minute)
        <input id="rte-speak-wpm" type="number" min="1" step="1" class="field" value="130" inputmode="numeric" />
      </label>
    </div>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel panel-lift p-4"><div id="rte-read" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Reading time</div></div>
      <div class="panel panel-lift p-4"><div id="rte-speak" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Speaking time</div></div>
      <div class="panel p-4"><div id="rte-words" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Words</div></div>
      <div class="panel p-4"><div id="rte-sentences" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Sentences</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free reading time estimator counts the words and sentences in your
      text and converts them into an estimated reading time and speaking time.
      The default reading speed of 238 words per minute reflects the average
      adult silent reading pace, while 130 words per minute is a comfortable
      speaking rate for presentations. Adjust both to match your audience.
      Everything is calculated in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const text = document.getElementById('rte-text') as HTMLTextAreaElement;
  const readWpm = document.getElementById('rte-read-wpm') as HTMLInputElement;
  const speakWpm = document.getElementById('rte-speak-wpm') as HTMLInputElement;

  function fmtTime(minutes: number): string {
    if (!isFinite(minutes) || minutes <= 0) return '0s';
    const totalSec = Math.round(minutes * 60);
    const m = Math.floor(totalSec / 60);
    const s = totalSec % 60;
    if (m === 0) return `${s}s`;
    if (s === 0) return `${m} min`;
    return `${m} min ${s}s`;
  }

  function calc() {
    const value = text.value.trim();
    const words = value === '' ? 0 : value.split(/\s+/).length;
    const sentences = value === '' ? 0 : (value.match(/[^.!?]+[.!?]+(\s|$)|[^.!?]+$/g) || []).length;

    const rWpm = Math.max(1, Number(readWpm.value) || 1);
    const sWpm = Math.max(1, Number(speakWpm.value) || 1);

    document.getElementById('rte-read')!.textContent = fmtTime(words / rWpm);
    document.getElementById('rte-speak')!.textContent = fmtTime(words / sWpm);
    document.getElementById('rte-words')!.textContent = words.toLocaleString();
    document.getElementById('rte-sentences')!.textContent = sentences.toLocaleString();
  }

  [text, readWpm, speakWpm].forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

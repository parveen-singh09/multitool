---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="url-encoder">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="url-encode" class="btn btn-primary">Encode →</button>
      <button id="url-decode" class="btn btn-secondary">← Decode</button>
      <label class="ml-auto flex items-center gap-2 text-sm text-ink-subtle">
        <input type="checkbox" id="url-component" checked class="accent-[#5e6ad2]" />
        Encode component (encodeURIComponent)
      </label>
    </div>

    <div id="url-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="flex flex-col gap-2">
        <label for="url-input" class="text-sm text-ink-subtle">Input</label>
        <textarea id="url-input" class="field min-h-52 resize-y font-mono text-[13px]" placeholder="https://example.com/search?q=hello world" spellcheck="false"></textarea>
      </div>
      <div class="flex flex-col gap-2">
        <label for="url-output" class="text-sm text-ink-subtle">Output</label>
        <textarea id="url-output" class="field min-h-52 resize-y font-mono text-[13px]" placeholder="Result…" spellcheck="false" readonly></textarea>
      </div>
    </div>
    <button id="url-copy" class="btn btn-secondary self-start">Copy output</button>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('url-input') as HTMLTextAreaElement;
  const output = document.getElementById('url-output') as HTMLTextAreaElement;
  const component = document.getElementById('url-component') as HTMLInputElement;
  const status = document.getElementById('url-status')!;

  function showError(msg: string) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = '#d14d4d';
    status.style.color = '#e08585';
  }

  document.getElementById('url-encode')!.addEventListener('click', () => {
    status.classList.add('hidden');
    output.value = component.checked
      ? encodeURIComponent(input.value)
      : encodeURI(input.value);
  });
  document.getElementById('url-decode')!.addEventListener('click', () => {
    status.classList.add('hidden');
    try {
      output.value = component.checked
        ? decodeURIComponent(input.value)
        : decodeURI(input.value);
    } catch {
      showError('Invalid encoding — cannot decode this input.');
    }
  });
  document.getElementById('url-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('url-copy')!;
    await navigator.clipboard.writeText(output.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy output'), 1500);
  });
</script>

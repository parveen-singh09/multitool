---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="credit-card-validator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Card number
      <input id="ccv-in" class="field font-mono text-[13px]" placeholder="4111 1111 1111 1111" spellcheck="false" inputmode="numeric" autocomplete="off" value="4111 1111 1111 1111" />
    </label>

    <p id="ccv-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-2 gap-3 text-center">
      <div class="panel panel-lift p-4"><div id="ccv-status" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Luhn check</div></div>
      <div class="panel p-4"><div id="ccv-brand" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Brand</div></div>
    </div>

    <p class="text-[13px] text-ink-muted">For testing only. This checks the number format and does not verify that a real, active account exists.</p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free credit card validator checks a card number against the Luhn
      algorithm and detects the card brand — Visa, Mastercard, American Express,
      Discover, JCB or Diners Club — from its prefix and length. Spaces and
      dashes are stripped automatically. It is intended for testing only and
      confirms format, not that a real account exists. Everything runs locally
      in your browser and nothing is stored or sent.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('ccv-in') as HTMLInputElement;
  const err = document.getElementById('ccv-error')!;
  const statusEl = document.getElementById('ccv-status')!;
  const brandEl = document.getElementById('ccv-brand')!;

  function luhn(digits: string): boolean {
    let sum = 0;
    let alt = false;
    for (let i = digits.length - 1; i >= 0; i--) {
      let d = digits.charCodeAt(i) - 48;
      if (alt) {
        d *= 2;
        if (d > 9) d -= 9;
      }
      sum += d;
      alt = !alt;
    }
    return sum % 10 === 0;
  }

  interface Brand {
    name: string;
    test: (n: string) => boolean;
    lengths: number[];
  }

  const BRANDS: Brand[] = [
    { name: 'American Express', test: (n) => /^3[47]/.test(n), lengths: [15] },
    { name: 'Diners Club', test: (n) => /^(36|38|30[0-5]|39)/.test(n), lengths: [14, 15, 16, 17, 18, 19] },
    { name: 'JCB', test: (n) => /^35(2[89]|[3-8][0-9])/.test(n), lengths: [16, 17, 18, 19] },
    { name: 'Discover', test: (n) => /^(6011|65|64[4-9]|622)/.test(n), lengths: [16, 17, 18, 19] },
    { name: 'Mastercard', test: (n) => /^(5[1-5]|2(2[2-9]|[3-6][0-9]|7[01]|720))/.test(n), lengths: [16] },
    { name: 'Visa', test: (n) => /^4/.test(n), lengths: [13, 16, 19] },
  ];

  function detectBrand(n: string): Brand | null {
    for (const b of BRANDS) {
      if (b.test(n)) return b;
    }
    return null;
  }

  function setStatus(text: string, ok: boolean) {
    statusEl.textContent = text;
    statusEl.style.color = ok ? '#27a644' : '#e5484d';
  }

  function validate() {
    err.classList.add('hidden');
    const raw = input.value.replace(/[\s-]/g, '');
    if (raw === '') {
      setStatus('—', true);
      statusEl.style.color = '';
      brandEl.textContent = '—';
      return;
    }
    if (!/^\d+$/.test(raw)) {
      err.textContent = 'Card number must contain only digits, spaces or dashes.';
      err.classList.remove('hidden');
      setStatus('—', false);
      statusEl.style.color = '';
      brandEl.textContent = '—';
      return;
    }

    const brand = detectBrand(raw);
    brandEl.textContent = brand ? brand.name : 'Unknown';

    const lengthOk = brand ? brand.lengths.includes(raw.length) : raw.length >= 12 && raw.length <= 19;
    const luhnOk = luhn(raw);

    if (luhnOk && lengthOk) {
      setStatus('Pass ✓', true);
    } else if (luhnOk && !lengthOk) {
      setStatus('Bad length', false);
    } else {
      setStatus('Fail ✕', false);
    }
  }

  input.addEventListener('input', validate);
  validate();
</script>

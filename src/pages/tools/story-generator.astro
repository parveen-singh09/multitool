---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="story-generator">
  <div class="flex flex-col gap-4">
    <button id="st-gen" class="btn btn-primary w-fit">Generate story idea</button>
    <div id="st-card" class="panel panel-lift flex flex-col gap-3 p-5"></div>
    <button id="st-copy" class="btn btn-secondary w-fit">Copy prompt</button>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free story idea generator sparks your next piece of fiction with a
      hand-written premise drawn from a deck of nearly 200 ideas across 15 genres,
      plus a ready-made opening line. Every idea is dealt without repeating until
      you've seen them all. It's built for writers facing a blank page, students
      doing creative exercises, and game masters improvising a scene. Generate as
      many as you like. Everything runs in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { pick, shuffle } from '../../lib/random';
  import { STORY_IDEAS } from '../../data/story-ideas';

  const $ = (id: string) => document.getElementById(id)!;
  const card = $('st-card')!;
  let current: Record<string, string> = {};

  const OPENERS = ['The morning it happened, the sky was the wrong color.', 'Nobody expected the door to be unlocked.', 'It began, as these things often do, with a knock.', 'She had exactly one hour, and she knew it.', 'The map was wrong, but the destination was real.', 'By the time the lights came back, everything had changed.', 'He counted the days on the wall until the wall ran out.', 'The letter arrived forty years too late.', 'Everyone in town agreed on one thing: it never happened.', 'The last train left without her, and she was glad.', 'There are three rules here, and I had already broken two.', 'The clock struck a number that does not exist.', 'She woke to find the sea had moved inland overnight.', 'The recording started playing before anyone pressed play.', 'On the day the birds stopped singing, I stopped listening.'];

  let deck: typeof STORY_IDEAS = [];
  function deal() {
    if (deck.length === 0) deck = shuffle(STORY_IDEAS);
    return deck.pop()!;
  }

  let lastOpener = '';
  function nextOpener() {
    let v = pick(OPENERS);
    while (v === lastOpener) v = pick(OPENERS);
    return (lastOpener = v);
  }

  function generate() {
    const idea = deal();
    current = {
      Premise: idea.premise,
      Genre: idea.genre,
      'Opening line': nextOpener(),
    };
    card.innerHTML = `
      <p class="text-lg leading-relaxed text-ink">${idea.premise}</p>
      <div class="grid grid-cols-1 gap-2 border-t border-hairline pt-3 sm:grid-cols-2">
        ${['Genre', 'Opening line'].map((k) =>
          `<div class="flex flex-col"><span class="text-xs uppercase tracking-wide text-ink-tertiary">${k}</span><span class="text-sm text-ink-subtle">${current[k]}</span></div>`).join('')}
      </div>`;
  }

  $('st-gen').addEventListener('click', generate);
  $('st-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const text = `Premise: ${current.Premise}\nGenre: ${current.Genre}\nOpening line: ${current['Opening line']}`;
    await navigator.clipboard.writeText(text);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy prompt'), 1500);
  });
  generate();
</script>

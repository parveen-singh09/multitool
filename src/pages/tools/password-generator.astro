---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="password-generator">
  <div class="flex flex-col gap-5">
    <div class="panel panel-lift flex items-center gap-3 p-4">
      <output
        id="pg-output"
        class="flex-1 select-all break-all font-mono text-lg text-ink"
      >click generate</output>
      <button id="pg-copy" class="btn btn-secondary" aria-label="Copy password">Copy</button>
      <button id="pg-refresh" class="btn btn-primary" aria-label="Generate new password">Generate</button>
    </div>

    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <label for="pg-length" class="text-sm text-ink-muted">Length</label>
        <span id="pg-length-val" class="font-mono text-sm text-ink">16</span>
      </div>
      <input id="pg-length" type="range" min="4" max="64" value="16" class="w-full accent-primary" />
    </div>

    <div class="grid grid-cols-2 gap-3">
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="pg-upper" checked class="accent-primary" />
        Uppercase (A–Z)
      </label>
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="pg-lower" checked class="accent-primary" />
        Lowercase (a–z)
      </label>
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="pg-numbers" checked class="accent-primary" />
        Numbers (0–9)
      </label>
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="pg-symbols" class="accent-primary" />
        Symbols (!@#$…)
      </label>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-sm text-ink-subtle">Strength</span>
      <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-surface-2">
        <div id="pg-strength" class="h-full w-0 rounded-full transition-all duration-300"></div>
      </div>
      <span id="pg-strength-label" class="w-16 text-right text-sm text-ink-subtle">—</span>
    </div>
  </div>
</ToolLayout>

<script>
  const out = document.getElementById('pg-output')!;
  const lengthEl = document.getElementById('pg-length') as HTMLInputElement;
  const lengthVal = document.getElementById('pg-length-val')!;
  const strengthBar = document.getElementById('pg-strength')!;
  const strengthLabel = document.getElementById('pg-strength-label')!;
  const opts = {
    upper: document.getElementById('pg-upper') as HTMLInputElement,
    lower: document.getElementById('pg-lower') as HTMLInputElement,
    numbers: document.getElementById('pg-numbers') as HTMLInputElement,
    symbols: document.getElementById('pg-symbols') as HTMLInputElement,
  };

  const SETS = {
    upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
    lower: 'abcdefghijklmnopqrstuvwxyz',
    numbers: '0123456789',
    symbols: '!@#$%^&*()-_=+[]{};:,.<>?',
  };

  function generate() {
    let pool = '';
    (Object.keys(SETS) as (keyof typeof SETS)[]).forEach((k) => {
      if (opts[k].checked) pool += SETS[k];
    });
    const len = Number(lengthEl.value);
    if (!pool) {
      out.textContent = 'select at least one option';
      updateStrength(0);
      return;
    }

    const bytes = new Uint32Array(len);
    crypto.getRandomValues(bytes);
    let pw = '';
    for (let i = 0; i < len; i++) pw += pool[bytes[i] % pool.length];
    out.textContent = pw;
    updateStrength(len * Math.log2(pool.length));
  }

  function updateStrength(bits: number) {
    const pct = Math.min(100, (bits / 128) * 100);
    strengthBar.style.width = `${pct}%`;
    let label = 'Weak', color = '#d14d4d';
    if (bits >= 90) { label = 'Strong'; color = '#27a644'; }
    else if (bits >= 60) { label = 'Good'; color = '#5e6ad2'; }
    else if (bits >= 40) { label = 'Fair'; color = '#c9a227'; }
    strengthBar.style.background = color;
    strengthLabel.textContent = label;
  }

  lengthEl.addEventListener('input', () => {
    lengthVal.textContent = lengthEl.value;
    generate();
  });
  Object.values(opts).forEach((el) => el.addEventListener('change', generate));
  document.getElementById('pg-refresh')!.addEventListener('click', generate);
  document.getElementById('pg-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('pg-copy')!;
    await navigator.clipboard.writeText(out.textContent || '');
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });

  generate();
</script>

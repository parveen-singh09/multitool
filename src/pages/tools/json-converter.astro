---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="json-converter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        From
        <select id="jc-from" class="field w-auto py-1">
          <option value="json" selected>JSON</option>
          <option value="yaml">YAML</option>
          <option value="xml">XML</option>
          <option value="toml">TOML</option>
          <option value="csv">CSV</option>
          <option value="tsv">TSV</option>
        </select>
      </label>
      <span class="pb-2 text-ink-subtle" aria-hidden="true">→</span>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        To
        <select id="jc-to" class="field w-auto py-1">
          <option value="xml" selected>XML</option>
          <option value="yaml">YAML</option>
          <option value="toml">TOML</option>
          <option value="csv">CSV</option>
          <option value="tsv">TSV</option>
          <option value="json">JSON</option>
        </select>
      </label>
      <label id="jc-indent-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">
        Indent
        <select id="jc-indent" class="field w-auto py-1">
          <option value="2" selected>2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <button id="jc-swap" type="button" class="btn btn-tertiary" title="Swap From/To">⇄ Swap</button>
    </div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <label class="btn btn-tertiary cursor-pointer">
        Upload file
        <input id="jc-file" type="file"
          accept=".json,.yaml,.yml,.xml,.toml,.csv,.tsv,.txt,text/plain" class="hidden" />
      </label>
      <label id="jc-minify-wrap" class="flex items-center gap-2 hidden">
        <input id="jc-minify" type="checkbox" class="h-4 w-4" />
        Minify JSON
      </label>
      <label id="jc-header-wrap" class="flex items-center gap-2 hidden">
        <input id="jc-header" type="checkbox" checked class="h-4 w-4" />
        First row is header
      </label>
    </div>

    <div id="jc-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span id="jc-in-label">JSON input</span>
          <button id="jc-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
        </span>
        <div id="jc-drop" class="hl-edit field p-0" style="height:22rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="jc-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea id="jc-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="Data input"></textarea>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span id="jc-out-label">XML output</span>
          <span class="flex gap-2">
            <button id="jc-copy" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy</button>
            <button id="jc-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
          </span>
        </span>
        <pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre"><code id="jc-out" class="hljs" style="background:transparent;padding:0"></code></pre>
      </div>
    </div>

    <p id="jc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free data converter transforms between JSON, YAML, XML, TOML, CSV and
      TSV in any direction. Pick a source and target format, paste, upload or
      drag-and-drop your data, then copy or download the result. Both panes are
      syntax-highlighted and conversion is live as you type. CSV and TSV work best
      on an array of flat objects (a header row is built from the keys, and you can
      toggle whether the first row is treated as a header); XML, YAML and TOML
      handle nested structures. Everything is parsed and converted entirely in your
      browser — nothing is uploaded to a server.
    </p>
    <p>
      JSON output can be pretty-printed at 2 spaces, 4 spaces or a tab, or minified
      to a single line. TOML output requires a top-level object and renders nested
      objects as <code>[tables]</code> and arrays of objects as
      <code>[[array-of-tables]]</code>. Errors point at the problem — a bad line
      number, an invalid root element, or a shape that a target format can't
      represent — instead of failing silently.
    </p>
  </div>
</ToolLayout>

<script>
  import { parseYaml, jsonToYaml, jsonToXml, jsonToCsv, csvToJson, parseToml, type Json } from '../../lib/dataformats';
  import { hl, wireInput } from '../../lib/highlight';

  const input = document.getElementById('jc-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('jc-in-hl')!;
  const output = document.getElementById('jc-out')!;
  const err = document.getElementById('jc-error')!;
  const statusEl = document.getElementById('jc-status')!;
  const fromSel = document.getElementById('jc-from') as HTMLSelectElement;
  const toSel = document.getElementById('jc-to') as HTMLSelectElement;
  const indentSel = document.getElementById('jc-indent') as HTMLSelectElement;
  const indentWrap = document.getElementById('jc-indent-wrap')!;
  const minifyWrap = document.getElementById('jc-minify-wrap')!;
  const minifyBox = document.getElementById('jc-minify') as HTMLInputElement;
  const headerWrap = document.getElementById('jc-header-wrap')!;
  const headerBox = document.getElementById('jc-header') as HTMLInputElement;
  const inLabel = document.getElementById('jc-in-label')!;
  const outLabel = document.getElementById('jc-out-label')!;
  const drop = document.getElementById('jc-drop')!;
  let rawOutput = '';

  const EXT: Record<string, string> = { json: 'json', yaml: 'yaml', xml: 'xml', toml: 'toml', csv: 'csv', tsv: 'tsv' };
  // Format value → highlight.js language id. csv/tsv have no grammar (plaintext); toml → hljs 'ini'.
  const HL_LANG: Record<string, string> = { json: 'json', yaml: 'yaml', xml: 'xml', toml: 'ini', csv: 'plaintext', tsv: 'plaintext' };

  function getIndent(): string | number {
    const v = indentSel.value;
    return v === 'tab' ? '\t' : Number(v);
  }

  // XML → JSON via the browser DOMParser (DOM-only, so it lives here not in the lib).
  function xmlToJson(text: string): Json {
    const doc = new DOMParser().parseFromString(text, 'application/xml');
    const pe = doc.querySelector('parsererror');
    if (pe) throw new Error(pe.textContent?.replace(/\s+/g, ' ').trim() || 'invalid XML');
    const root = doc.documentElement;
    if (!root) throw new Error('no root element');
    return { [root.nodeName]: elementToJson(root) };
  }
  function elementToJson(el: Element): Json {
    const obj: { [k: string]: Json } = {};
    if (el.attributes.length) {
      const attrs: { [k: string]: string } = {};
      for (const a of Array.from(el.attributes)) attrs[a.name] = a.value;
      obj['@attributes'] = attrs;
    }
    const children = Array.from(el.childNodes).filter((n) => n.nodeType === Node.ELEMENT_NODE) as Element[];
    let text = '';
    el.childNodes.forEach((n) => {
      if (n.nodeType === Node.TEXT_NODE || n.nodeType === Node.CDATA_SECTION_NODE) text += n.nodeValue ?? '';
    });
    text = text.trim();
    if (!children.length) {
      if (!Object.keys(obj).length) return text;
      if (text !== '') obj['#text'] = text;
      return obj;
    }
    for (const child of children) {
      const key = child.nodeName;
      const value = elementToJson(child);
      if (key in obj) {
        const existing = obj[key];
        if (Array.isArray(existing)) existing.push(value);
        else obj[key] = [existing, value];
      } else obj[key] = value;
    }
    if (text !== '') obj['#text'] = text;
    return obj;
  }

  // JSON → TOML. No lib serializer exists, so it's inlined here.
  // ponytail: covers the common shape (top-level object, nested [tables],
  // [[arrays-of-tables]], inline arrays/tables). Datetimes stay strings; add a
  // real datetime type if a caller needs unquoted TOML dates.
  function tomlKey(k: string): string {
    return /^[A-Za-z0-9_-]+$/.test(k) ? k : JSON.stringify(k);
  }
  function tomlValue(v: Json): string {
    if (v === null) return '""'; // TOML has no null; emptiest safe representation
    if (typeof v === 'string') return JSON.stringify(v);
    if (typeof v === 'number') return Number.isFinite(v) ? String(v) : JSON.stringify(String(v));
    if (typeof v === 'boolean') return String(v);
    if (Array.isArray(v)) return '[' + v.map(tomlValue).join(', ') + ']';
    // Inline table for a nested object appearing in an array/inline context.
    return '{ ' + Object.entries(v).map(([k, val]) => `${tomlKey(k)} = ${tomlValue(val)}`).join(', ') + ' }';
  }
  function isPlainObj(v: Json): v is { [k: string]: Json } {
    return v !== null && typeof v === 'object' && !Array.isArray(v);
  }
  function tomlWalk(obj: { [k: string]: Json }, path: string[], lines: string[], header: boolean) {
    const scalars: [string, Json][] = [];
    const tables: [string, { [k: string]: Json }][] = [];
    const arrayTables: [string, { [k: string]: Json }[]][] = [];
    for (const [k, v] of Object.entries(obj)) {
      if (isPlainObj(v)) tables.push([k, v]);
      else if (Array.isArray(v) && v.length && v.every(isPlainObj)) arrayTables.push([k, v as { [k: string]: Json }[]]);
      else scalars.push([k, v]);
    }
    if (header && path.length) lines.push(`[${path.map(tomlKey).join('.')}]`);
    for (const [k, v] of scalars) lines.push(`${tomlKey(k)} = ${tomlValue(v)}`);
    for (const [k, v] of tables) { lines.push(''); tomlWalk(v, [...path, k], lines, true); }
    for (const [k, arr] of arrayTables) {
      for (const item of arr) {
        lines.push('');
        lines.push(`[[${[...path, k].map(tomlKey).join('.')}]]`);
        tomlWalk(item, [...path, k], lines, false);
      }
    }
  }
  function jsonToToml(data: Json): string {
    if (!isPlainObj(data)) throw new Error('TOML output requires a top-level object (not an array or scalar).');
    const lines: string[] = [];
    tomlWalk(data, [], lines, true);
    return lines.join('\n').replace(/\n{3,}/g, '\n\n').trim();
  }

  function parseSource(fmt: string, raw: string): Json {
    switch (fmt) {
      case 'json': return JSON.parse(raw);
      case 'yaml': return parseYaml(raw);
      case 'xml': return xmlToJson(raw);
      case 'toml': return parseToml(raw);
      case 'csv': return csvToJson(raw, ',', headerBox.checked);
      case 'tsv': return csvToJson(raw, '\t', headerBox.checked);
      default: throw new Error('unknown source format');
    }
  }

  function serialize(fmt: string, data: Json): string {
    switch (fmt) {
      case 'json': return JSON.stringify(data, null, minifyBox.checked ? undefined : getIndent());
      case 'yaml': return jsonToYaml(data).trimEnd();
      case 'xml': return jsonToXml(data);
      case 'toml': return jsonToToml(data);
      case 'csv': return jsonToCsv(data, ',');
      case 'tsv': return jsonToCsv(data, '\t');
      default: throw new Error('unknown target format');
    }
  }

  function showStatus(msg: string) {
    statusEl.textContent = msg;
    statusEl.classList.remove('hidden');
    statusEl.style.borderColor = '#27a644';
    statusEl.style.color = '#27a644';
  }

  function syncUI() {
    const from = fromSel.value, to = toSel.value;
    inLabel.textContent = `${from.toUpperCase()} input`;
    outLabel.textContent = `${to.toUpperCase()} output`;
    // Indent only affects JSON/YAML output; hidden when minifying JSON.
    const indented = (to === 'json' && !minifyBox.checked) || to === 'yaml';
    indentWrap.style.display = indented ? '' : 'none';
    minifyWrap.classList.toggle('hidden', to !== 'json');
    headerWrap.classList.toggle('hidden', from !== 'csv' && from !== 'tsv');
  }

  const rerender = wireInput(input, inHl, () => HL_LANG[fromSel.value] ?? 'plaintext', () => { void convert(); });

  async function convert() {
    syncUI();
    err.classList.add('hidden');
    const raw = input.value.trim();
    if (!raw) {
      rawOutput = ''; output.textContent = ''; statusEl.classList.add('hidden');
      return;
    }
    try {
      const data = parseSource(fromSel.value, raw);
      rawOutput = serialize(toSel.value, data);
      await hl(output, rawOutput, HL_LANG[toSel.value] ?? 'plaintext');
      const bytes = new Blob([rawOutput]).size;
      const lines = rawOutput ? rawOutput.split('\n').length : 0;
      showStatus(`${fromSel.value.toUpperCase()} → ${toSel.value.toUpperCase()} · ${lines} ${lines === 1 ? 'line' : 'lines'} · ${bytes} bytes ✓`);
    } catch (e) {
      rawOutput = ''; output.textContent = ''; statusEl.classList.add('hidden');
      err.textContent = `${fromSel.value.toUpperCase()} → ${toSel.value.toUpperCase()} failed: ${(e as Error).message}`;
      err.classList.remove('hidden');
    }
  }

  fromSel.addEventListener('change', () => { void convert(); });
  toSel.addEventListener('change', () => { void convert(); });
  indentSel.addEventListener('change', () => { if (rawOutput) void convert(); });
  minifyBox.addEventListener('change', () => { void convert(); });
  headerBox.addEventListener('change', () => { void convert(); });

  document.getElementById('jc-swap')!.addEventListener('click', () => {
    const f = fromSel.value, t = toSel.value;
    // Swap directions; move the converted output back into the input.
    fromSel.value = t; toSel.value = f;
    if (rawOutput) input.value = rawOutput;
    rerender();
    void convert();
  });

  document.getElementById('jc-clear')!.addEventListener('click', () => {
    input.value = ''; rawOutput = ''; output.textContent = '';
    err.classList.add('hidden'); statusEl.classList.add('hidden');
    rerender();
  });

  document.getElementById('jc-copy')!.addEventListener('click', async (e) => {
    if (!rawOutput) return;
    await navigator.clipboard.writeText(rawOutput);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });

  document.getElementById('jc-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const blob = new Blob([rawOutput], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `converted.${EXT[toSel.value]}`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // Upload a file / drag-and-drop onto the input pane; guess source format by extension.
  const EXT_TO_FMT: Record<string, string> = {
    json: 'json', yaml: 'yaml', yml: 'yaml', xml: 'xml', toml: 'toml', csv: 'csv', tsv: 'tsv',
  };
  function loadFile(file: File) {
    const ext = file.name.split('.').pop()?.toLowerCase() ?? '';
    if (EXT_TO_FMT[ext]) fromSel.value = EXT_TO_FMT[ext];
    const reader = new FileReader();
    reader.onload = () => { input.value = String(reader.result ?? ''); rerender(); void convert(); };
    reader.onerror = () => {
      err.textContent = 'Could not read file.'; err.classList.remove('hidden');
    };
    reader.readAsText(file);
  }

  const fileInput = document.getElementById('jc-file') as HTMLInputElement;
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  ['dragover', 'dragenter'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.style.outline = '2px solid #5e6ad2'; }));
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, () => { drop.style.outline = ''; }));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) loadFile(file);
  });

  input.value = '[\n  { "name": "Ada", "age": 36 },\n  { "name": "Alan", "age": 41 }\n]';
  rerender();
  void convert();
</script>

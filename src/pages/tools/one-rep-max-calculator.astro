---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="one-rep-max-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight lifted
        <input id="orm-weight" type="number" min="0" step="0.5" class="field" value="100" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Reps performed
        <input id="orm-reps" type="number" min="1" max="12" step="1" class="field" value="5" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Unit
        <select id="orm-unit" class="field">
          <option value="kg">kg</option>
          <option value="lb">lb</option>
        </select>
      </label>
    </div>

    <div class="panel panel-lift p-6 text-center">
      <div id="orm-value" class="font-display text-4xl font-semibold text-primary-hover">—</div>
      <div id="orm-sub" class="mt-2 text-sm text-ink-muted"></div>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="panel p-5 text-center">
        <div id="orm-epley" class="font-mono text-xl text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Epley 1RM</div>
      </div>
      <div class="panel p-5 text-center">
        <div id="orm-brzycki" class="font-mono text-xl text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Brzycki 1RM</div>
      </div>
    </div>

    <div class="panel p-5">
      <div class="mb-3 text-sm text-ink-muted">Training percentages of 1RM</div>
      <div id="orm-table" class="flex flex-col gap-2"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free one-rep max calculator estimates the most weight you could lift
      for a single rep from a set you have already completed. It uses the Epley
      formula and cross-checks it with the Brzycki formula, then builds a
      percentage table so you can plan your working sets. Estimates are most
      accurate for sets of 1 to 12 reps and are guides, not a substitute for a
      proper max attempt with a spotter. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const sel = (id: string) => document.getElementById(id) as unknown as HTMLSelectElement;

  const percentages: { pct: number; reps: string }[] = [
    { pct: 95, reps: '2 reps' },
    { pct: 90, reps: '3-4 reps' },
    { pct: 85, reps: '5-6 reps' },
    { pct: 80, reps: '7-8 reps' },
    { pct: 75, reps: '9-10 reps' },
    { pct: 70, reps: '11-12 reps' },
    { pct: 65, reps: '13-15 reps' },
    { pct: 60, reps: '16-20 reps' },
  ];

  function calc() {
    const weight = Number($('orm-weight').value);
    const reps = Number($('orm-reps').value);
    const unit = sel('orm-unit').value;

    const clear = () => {
      document.getElementById('orm-value')!.textContent = '—';
      document.getElementById('orm-sub')!.textContent = '';
      document.getElementById('orm-epley')!.textContent = '—';
      document.getElementById('orm-brzycki')!.textContent = '—';
      document.getElementById('orm-table')!.innerHTML = '';
    };
    if (!(weight > 0) || !(reps >= 1)) { clear(); return; }

    const epley = weight * (1 + reps / 30);
    const brzycki = reps < 37 ? weight * (36 / (37 - reps)) : NaN;
    const oneRm = isFinite(brzycki) ? (epley + brzycki) / 2 : epley;

    const fmt = (n: number) => `${Math.round(n * 10) / 10} ${unit}`;

    document.getElementById('orm-value')!.textContent = fmt(oneRm);
    document.getElementById('orm-sub')!.textContent = 'Estimated one-rep max (average of Epley & Brzycki)';
    document.getElementById('orm-epley')!.textContent = fmt(epley);
    document.getElementById('orm-brzycki')!.textContent = isFinite(brzycki) ? fmt(brzycki) : '—';

    const rows = percentages
      .map((p) => {
        const w = Math.round((oneRm * p.pct) / 100 * 10) / 10;
        return `<div class="flex items-center justify-between border-t border-hairline pt-2 first:border-0 first:pt-0"><span class="text-ink-subtle">${p.pct}% · ${p.reps}</span><span class="font-mono text-ink-muted">${w} ${unit}</span></div>`;
      })
      .join('');
    document.getElementById('orm-table')!.innerHTML = rows;
  }

  document
    .querySelectorAll('#orm-weight, #orm-reps, #orm-unit')
    .forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

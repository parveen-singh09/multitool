---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="svg-wave-generator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height: <span id="sw-hv" class="text-ink">150</span>
        <input id="sw-height" type="range" min="40" max="320" value="150" class="w-full accent-primary" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Waviness: <span id="sw-wv" class="text-ink">4</span>
        <input id="sw-waves" type="range" min="1" max="10" value="4" class="w-full accent-primary" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Color
        <input id="sw-color" type="color" value="#5e6ad2" class="field h-10 cursor-pointer p-1" />
      </label>
      <div class="flex items-end gap-2">
        <button id="sw-rand" class="btn btn-secondary">Randomize</button>
        <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="sw-flip" type="checkbox" class="accent-primary" /> Flip</label>
      </div>
    </div>

    <div class="copy-wrap">
      <div id="sw-preview" class="overflow-hidden rounded-lg border border-hairline bg-surface-2"></div>
      <button type="button" id="sw-copy-icon" class="copy-icon" aria-label="Copy SVG code"></button>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="sw-dl" class="btn btn-primary">Download SVG</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SVG wave generator creates smooth wave dividers to place between
      sections of a page — a popular way to soften the hard edge where a colored
      hero meets the content below. Adjust the height and waviness, pick a color,
      flip it, or hit randomize for a fresh curve. Download the SVG or copy the
      code. Generated entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { randInt, randFloat } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const preview = $('sw-preview')!;
  const W = 1440;
  let seed: number[] = [];

  function reseed() {
    const n = Number(($('sw-waves') as HTMLInputElement).value);
    seed = Array.from({ length: n * 2 + 2 }, () => randFloat());
  }

  function path(h: number, waves: number, flip: boolean): string {
    const segW = W / waves;
    let d = `M0 ${h * 0.5}`;
    for (let i = 0; i < waves; i++) {
      const x1 = segW * i + segW / 3;
      const x2 = segW * i + (segW * 2) / 3;
      const x = segW * (i + 1);
      const up = (seed[i] ?? 0.5) * h * 0.5;
      const down = (seed[i + waves] ?? 0.5) * h * 0.5;
      d += ` C ${x1} ${up}, ${x2} ${h - down}, ${x} ${h * 0.5}`;
    }
    d += ` L ${W} ${flip ? 0 : h} L 0 ${flip ? 0 : h} Z`;
    return d;
  }

  function svg(): string {
    const h = Number(($('sw-height') as HTMLInputElement).value);
    const waves = Number(($('sw-waves') as HTMLInputElement).value);
    const color = ($('sw-color') as HTMLInputElement).value;
    const flip = ($('sw-flip') as HTMLInputElement).checked;
    $('sw-hv').textContent = String(h); $('sw-wv').textContent = String(waves);
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${W} ${h}" width="100%" height="${h}" preserveAspectRatio="none"><path fill="${color}" d="${path(h, waves, flip)}"/></svg>`;
  }

  function render() { preview.innerHTML = svg(); }

  ['sw-height', 'sw-waves', 'sw-color', 'sw-flip'].forEach((id) => $(id).addEventListener('input', () => {
    if (id === 'sw-waves') reseed();
    render();
  }));
  $('sw-rand').addEventListener('click', () => { reseed(); render(); });
  $('sw-dl').addEventListener('click', () => {
    const url = URL.createObjectURL(new Blob([svg()], { type: 'image/svg+xml' }));
    const a = document.createElement('a'); a.href = url; a.download = 'wave.svg'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });
  // Local handler: the copied value is the generated SVG source string, which
  // isn't reflected in any element's text (the preview holds rendered DOM).
  $('sw-copy-icon').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    try {
      await navigator.clipboard.writeText(svg());
      btn.classList.add('copied');
      btn.setAttribute('aria-label', 'Copied');
      setTimeout(() => { btn.classList.remove('copied'); btn.setAttribute('aria-label', 'Copy SVG code'); }, 1500);
    } catch {}
  });

  reseed(); render();
</script>

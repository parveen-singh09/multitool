---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="hex-converter">
  <div class="flex flex-col gap-5">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Mode">
      <button data-mode="num" class="hx-tab btn btn-primary" aria-selected="true">Number bases</button>
      <button data-mode="text" class="hx-tab btn btn-secondary" aria-selected="false">Text ↔ Hex</button>
    </div>

    <div id="hx-num" class="flex flex-col gap-3">
      <p class="text-[13px] text-ink-tertiary">Type into any field — the others update live. Accepts a leading <code class="font-mono">-</code> for negatives and an optional <code class="font-mono">0x</code>/<code class="font-mono">0b</code>/<code class="font-mono">0o</code> prefix.</p>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Decimal (base 10)
        <div class="flex gap-2">
          <input id="hx-dec" type="text" class="field font-mono" placeholder="255" inputmode="numeric" spellcheck="false" autocomplete="off" data-base="10" />
          <button class="btn btn-secondary hx-copy self-stretch" data-t="hx-dec" type="button">Copy</button>
        </div>
      </label>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Hexadecimal (base 16)
        <div class="flex gap-2">
          <input id="hx-hex" type="text" class="field font-mono" placeholder="ff" spellcheck="false" autocomplete="off" data-base="16" />
          <button class="btn btn-secondary hx-copy self-stretch" data-t="hx-hex" type="button">Copy</button>
        </div>
      </label>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Binary (base 2)
        <div class="flex gap-2">
          <input id="hx-bin" type="text" class="field font-mono" placeholder="11111111" spellcheck="false" autocomplete="off" data-base="2" />
          <button class="btn btn-secondary hx-copy self-stretch" data-t="hx-bin" type="button">Copy</button>
        </div>
      </label>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Octal (base 8)
        <div class="flex gap-2">
          <input id="hx-oct" type="text" class="field font-mono" placeholder="377" spellcheck="false" autocomplete="off" data-base="8" />
          <button class="btn btn-secondary hx-copy self-stretch" data-t="hx-oct" type="button">Copy</button>
        </div>
      </label>

      <div class="flex flex-wrap items-center gap-4 pt-1 text-[13px] text-ink-subtle">
        <label class="flex items-center gap-2"><input id="hx-upper" type="checkbox" /> Uppercase hex</label>
        <label class="flex items-center gap-2"><input id="hx-prefix" type="checkbox" /> Add <code class="font-mono">0x</code> prefix</label>
      </div>

      <div id="hx-signed" class="hidden panel p-3 text-[13px] text-ink-subtle"></div>
    </div>

    <div id="hx-textwrap" class="hidden flex-col gap-3">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Encoding
          <select id="hx-enc" class="field w-auto py-1">
            <option value="utf-8" selected>UTF-8</option>
            <option value="utf-16le">UTF-16 LE</option>
            <option value="utf-16be">UTF-16 BE</option>
            <option value="latin1">Latin-1 (ISO-8859-1)</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Byte separator
          <select id="hx-sep" class="field w-auto py-1">
            <option value=" " selected>Space</option>
            <option value="">None</option>
            <option value=", ">Comma</option>
            <option value=":">Colon</option>
            <option value="0x">0x prefix</option>
            <option value="\x">\x prefix</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Case
          <select id="hx-tcase" class="field w-auto py-1">
            <option value="lower" selected>lowercase</option>
            <option value="upper">UPPERCASE</option>
          </select>
        </label>
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          Text
          <span class="flex gap-2">
            <button id="hx-file" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Open file…</button>
            <button class="btn btn-secondary hx-copy px-2 py-1 text-[13px]" data-t="hx-txt" type="button">Copy</button>
          </span>
        </span>
        <textarea id="hx-txt" class="field" rows="3" placeholder="Hi 👋" spellcheck="false"></textarea>
        <input id="hx-fileinput" type="file" class="hidden" />
      </label>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          Hex bytes
          <span class="flex gap-2">
            <button class="btn btn-secondary hx-copy px-2 py-1 text-[13px]" data-t="hx-txthex" type="button">Copy</button>
            <button id="hx-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
          </span>
        </span>
        <textarea id="hx-txthex" class="field font-mono" rows="3" placeholder="48 69"></textarea>
      </label>
      <p class="text-[13px] text-ink-tertiary">Pasted hex accepts any spacing, commas, colons, and <code class="font-mono">0x</code>/<code class="font-mono">\x</code> prefixes — even one continuous string.</p>
    </div>

    <p id="hx-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free hexadecimal converter does two jobs. In <strong>Number bases</strong>
      mode, every field — decimal, hexadecimal, binary and octal — is live and
      editable: type a value in any base and the other three update instantly, with
      big-integer precision (no 53-bit rounding), optional uppercase and a
      <code class="font-mono">0x</code> prefix, and a signed two's-complement reading
      at 8, 16, 32 and 64 bits. In <strong>Text ↔ Hex</strong> mode it converts text
      to its hex byte codes and back across UTF-8, UTF-16 (little- and big-endian) and
      Latin-1, with a choice of byte separators (space, none, comma, colon, or
      <code class="font-mono">0x</code>/<code class="font-mono">\x</code> prefixes) and
      upper- or lowercase output. You can load a file to dump its bytes as hex, copy
      any field, or download the hex. Pasted hex is forgiving — mixed spacing, commas,
      colons, prefixes, or one unbroken string all parse.
    </p>
    <p>
      Hexadecimal is the compact base-16 notation used for colors, memory addresses,
      byte data and machine code, where each digit maps to exactly four bits. Every
      conversion runs entirely in your browser — nothing is uploaded to a server.
    </p>
  </div>
</ToolLayout>

<script>
  const decEl = document.getElementById('hx-dec') as HTMLInputElement;
  const hexEl = document.getElementById('hx-hex') as HTMLInputElement;
  const binEl = document.getElementById('hx-bin') as HTMLInputElement;
  const octEl = document.getElementById('hx-oct') as HTMLInputElement;
  const upperEl = document.getElementById('hx-upper') as HTMLInputElement;
  const prefixEl = document.getElementById('hx-prefix') as HTMLInputElement;
  const signedEl = document.getElementById('hx-signed')!;
  const baseFields = [decEl, hexEl, binEl, octEl];

  const txtEl = document.getElementById('hx-txt') as HTMLTextAreaElement;
  const txtHexEl = document.getElementById('hx-txthex') as HTMLTextAreaElement;
  const encEl = document.getElementById('hx-enc') as HTMLSelectElement;
  const sepEl = document.getElementById('hx-sep') as HTMLSelectElement;
  const tcaseEl = document.getElementById('hx-tcase') as HTMLSelectElement;

  const numWrap = document.getElementById('hx-num')!;
  const textWrap = document.getElementById('hx-textwrap')!;
  const err = document.getElementById('hx-error')!;

  function setErr(msg: string) { err.textContent = msg; err.classList.toggle('hidden', !msg); }

  const VALID: Record<number, RegExp> = {
    10: /^-?\d+$/,
    16: /^-?[0-9a-fA-F]+$/,
    2: /^-?[01]+$/,
    8: /^-?[0-7]+$/,
  };
  const PREFIX: Record<number, RegExp> = {
    10: /^$/, 16: /^0x/i, 2: /^0b/i, 8: /^0o/i,
  };

  function fmtHex(abs: bigint): string {
    let s = abs.toString(16);
    if (upperEl.checked) s = s.toUpperCase();
    if (prefixEl.checked) s = '0x' + s;
    return s;
  }

  function renderBases(n: bigint, skip?: HTMLInputElement) {
    const neg = n < 0n;
    const abs = neg ? -n : n;
    const sign = neg ? '-' : '';
    if (skip !== decEl) decEl.value = n.toString(10);
    if (skip !== hexEl) hexEl.value = sign + fmtHex(abs);
    if (skip !== binEl) binEl.value = sign + abs.toString(2);
    if (skip !== octEl) octEl.value = sign + abs.toString(8);
    renderSigned(n);
  }

  function clearBases(skip?: HTMLInputElement) {
    for (const f of baseFields) if (f !== skip) f.value = '';
    signedEl.classList.add('hidden');
  }

  function renderSigned(n: bigint) {
    if (n < 0n) { signedEl.classList.add('hidden'); return; }
    const rows: string[] = [];
    for (const bits of [8, 16, 32, 64]) {
      const max = 1n << BigInt(bits);
      if (n >= max) continue;
      const signed = n >= max / 2n ? n - max : n;
      rows.push(`${bits}-bit: <span class="font-mono text-ink">${signed}</span>`);
    }
    if (!rows.length) { signedEl.classList.add('hidden'); return; }
    signedEl.innerHTML = 'Signed (two\'s complement) — ' + rows.join(' · ');
    signedEl.classList.remove('hidden');
  }

  function onBaseInput(el: HTMLInputElement) {
    setErr('');
    const base = Number(el.dataset.base);
    let v = el.value.trim();
    if (!v) { clearBases(el); return; }
    const neg = v.startsWith('-');
    if (neg) v = v.slice(1);
    v = v.replace(PREFIX[base], '');
    if (!v || !VALID[base].test((neg ? '-' : '') + v)) {
      const names: Record<number, string> = { 10: '0–9', 16: '0–9 and A–F', 2: '0 and 1', 8: '0–7' };
      setErr(`This base only allows ${names[base]}.`);
      return;
    }
    try {
      let abs: bigint;
      if (base === 10) abs = BigInt(v);
      else if (base === 16) abs = BigInt('0x' + v);
      else if (base === 8) abs = BigInt('0o' + v);
      else abs = BigInt('0b' + v);
      renderBases(neg ? -abs : abs, el);
    } catch { setErr('Could not parse that value.'); }
  }

  for (const f of baseFields) f.addEventListener('input', () => onBaseInput(f));
  // Re-render hex when the display options change (re-derive from decimal).
  [upperEl, prefixEl].forEach((c) => c.addEventListener('change', () => {
    const v = decEl.value.trim();
    if (v && /^-?\d+$/.test(v)) renderBases(BigInt(v));
  }));

  // ── Text ↔ Hex (multi-encoding) ──────────────────────────────────
  // Encode a string to bytes for the chosen encoding.
  function encodeText(s: string, enc: string): Uint8Array {
    if (enc === 'utf-8') return new TextEncoder().encode(s);
    if (enc === 'latin1') {
      const out = new Uint8Array(s.length);
      for (let i = 0; i < s.length; i++) {
        const c = s.charCodeAt(i);
        if (c > 0xff) throw new Error(`"${s[i]}" is outside Latin-1 (0–255).`);
        out[i] = c;
      }
      return out;
    }
    // UTF-16 LE/BE from the string's UTF-16 code units.
    const le = enc === 'utf-16le';
    const out = new Uint8Array(s.length * 2);
    for (let i = 0; i < s.length; i++) {
      const c = s.charCodeAt(i);
      out[i * 2] = le ? c & 0xff : c >> 8;
      out[i * 2 + 1] = le ? c >> 8 : c & 0xff;
    }
    return out;
  }

  function bytesToHex(bytes: Uint8Array): string {
    const upper = tcaseEl.value === 'upper';
    const parts = Array.from(bytes, (b) => {
      let h = b.toString(16).padStart(2, '0');
      return upper ? h.toUpperCase() : h;
    });
    const sep = sepEl.value;
    if (sep === '0x') return parts.map((p) => '0x' + p).join(' ');
    if (sep === '\\x') return parts.map((p) => '\\x' + p).join('');
    return parts.join(sep);
  }

  // Parse forgiving hex input → bytes. Handles prefixes, any delimiter, or one
  // continuous string.
  function parseHexBytes(raw: string): Uint8Array {
    let s = raw.trim();
    if (!s) return new Uint8Array(0);
    s = s.replace(/0x/gi, '').replace(/\\x/gi, '');
    // Split on any non-hex run; if that leaves one long token, chunk into pairs.
    let tokens = s.split(/[^0-9a-fA-F]+/).filter(Boolean);
    if (tokens.length === 1 && tokens[0].length > 2) {
      const t = tokens[0];
      if (t.length % 2 !== 0) throw new Error('Continuous hex needs an even number of digits.');
      tokens = t.match(/.{2}/g)!;
    }
    for (const t of tokens) {
      if (!/^[0-9a-fA-F]{1,2}$/.test(t)) throw new Error(`"${t}" is not a hex byte.`);
    }
    return Uint8Array.from(tokens.map((t) => parseInt(t, 16)));
  }

  function textToHex() {
    setErr('');
    try {
      txtHexEl.value = bytesToHex(encodeText(txtEl.value, encEl.value));
    } catch (e) { setErr((e as Error).message); }
  }

  function hexToText() {
    setErr('');
    try {
      const bytes = parseHexBytes(txtHexEl.value);
      // TextDecoder handles utf-8, utf-16le/be and latin1 (fatal=false is lenient).
      const dec = encEl.value === 'utf-16be' ? 'utf-16be' : encEl.value;
      txtEl.value = new TextDecoder(dec).decode(bytes);
    } catch (e) { setErr((e as Error).message); }
  }

  txtEl.addEventListener('input', textToHex);
  txtHexEl.addEventListener('input', hexToText);
  // Option changes re-encode from the text side (text is the source of truth).
  [encEl, sepEl, tcaseEl].forEach((s) => s.addEventListener('change', textToHex));

  // File → hex dump of its raw bytes.
  const fileInput = document.getElementById('hx-fileinput') as HTMLInputElement;
  document.getElementById('hx-file')!.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    setErr('');
    try {
      const bytes = new Uint8Array(await file.arrayBuffer());
      txtHexEl.value = bytesToHex(bytes);
      txtEl.value = new TextDecoder(encEl.value === 'utf-16be' ? 'utf-16be' : encEl.value).decode(bytes);
    } catch (e) { setErr(`Could not read file: ${(e as Error).message}`); }
    fileInput.value = '';
  });

  document.getElementById('hx-download')!.addEventListener('click', () => {
    if (!txtHexEl.value) return;
    const blob = new Blob([txtHexEl.value], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'bytes.hex.txt';
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Tabs & copy ──────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.hx-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const mode = tab.dataset.mode;
      document.querySelectorAll('.hx-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      numWrap.classList.toggle('hidden', mode !== 'num');
      numWrap.classList.toggle('flex', mode === 'num');
      textWrap.classList.toggle('hidden', mode !== 'text');
      textWrap.classList.toggle('flex', mode === 'text');
      setErr('');
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.hx-copy').forEach((b) => {
    b.addEventListener('click', async () => {
      const t = document.getElementById(b.dataset.t!) as HTMLInputElement | HTMLTextAreaElement;
      if (!t.value) return;
      await navigator.clipboard.writeText(t.value);
      const orig = b.textContent;
      b.textContent = 'Copied!'; setTimeout(() => (b.textContent = orig), 1400);
    });
  });

  // Seed with example values.
  renderBases(255n);
  txtEl.value = 'Hi 👋'; textToHex();
</script>

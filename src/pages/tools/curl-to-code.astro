---
import ToolLayout from '../../layouts/ToolLayout.astro';

// value → curlconverter export name. Grouped for the <optgroup> UI below.
const LANG_GROUPS: { label: string; opts: [string, string, string][] }[] = [
  { label: 'JavaScript', opts: [
    ['javascript', 'fetch', 'toJavaScript'],
    ['javascript-jquery', 'jQuery', 'toJavaScriptJquery'],
    ['javascript-xhr', 'XHR', 'toJavaScriptXHR'],
  ]},
  { label: 'Node.js', opts: [
    ['node', 'fetch', 'toNode'],
    ['node-axios', 'axios', 'toNodeAxios'],
    ['node-got', 'got', 'toNodeGot'],
    ['node-ky', 'ky', 'toNodeKy'],
    ['node-request', 'request', 'toNodeRequest'],
    ['node-superagent', 'superagent', 'toNodeSuperAgent'],
    ['node-http', 'http', 'toNodeHttp'],
  ]},
  { label: 'Python', opts: [
    ['python', 'requests', 'toPython'],
    ['python-http', 'http.client', 'toPythonHttp'],
  ]},
  { label: 'PHP', opts: [
    ['php', 'curl', 'toPhp'],
    ['php-guzzle', 'Guzzle', 'toPhpGuzzle'],
    ['php-requests', 'Requests', 'toPhpRequests'],
  ]},
  { label: 'Java', opts: [
    ['java', 'HttpClient', 'toJava'],
    ['java-okhttp', 'OkHttp', 'toJavaOkHttp'],
    ['java-jsoup', 'jsoup', 'toJavaJsoup'],
    ['java-httpurlconnection', 'HttpURLConnection', 'toJavaHttpUrlConnection'],
  ]},
  { label: 'Ruby', opts: [
    ['ruby', 'net/http', 'toRuby'],
    ['ruby-httparty', 'HTTParty', 'toRubyHttparty'],
  ]},
  { label: 'R', opts: [
    ['r', 'httr', 'toR'],
    ['r-httr2', 'httr2', 'toRHttr2'],
  ]},
  { label: 'PowerShell', opts: [
    ['powershell', 'Invoke-RestMethod', 'toPowershellRestMethod'],
    ['powershell-webrequest', 'Invoke-WebRequest', 'toPowershellWebRequest'],
  ]},
  { label: 'More languages', opts: [
    ['go', 'Go', 'toGo'],
    ['rust', 'Rust', 'toRust'],
    ['csharp', 'C#', 'toCSharp'],
    ['c', 'C (libcurl)', 'toC'],
    ['swift', 'Swift', 'toSwift'],
    ['objc', 'Objective-C', 'toObjectiveC'],
    ['kotlin', 'Kotlin', 'toKotlin'],
    ['dart', 'Dart', 'toDart'],
    ['elixir', 'Elixir', 'toElixir'],
    ['clojure', 'Clojure', 'toClojure'],
    ['perl', 'Perl', 'toPerl'],
    ['lua', 'Lua', 'toLua'],
    ['ocaml', 'OCaml', 'toOCaml'],
    ['julia', 'Julia', 'toJulia'],
    ['matlab', 'MATLAB', 'toMATLAB'],
    ['cfml', 'ColdFusion', 'toCFML'],
  ]},
  { label: 'Tools & formats', opts: [
    ['httpie', 'HTTPie', 'toHttpie'],
    ['wget', 'Wget', 'toWget'],
    ['ansible', 'Ansible', 'toAnsible'],
    ['http', 'HTTP', 'toHTTP'],
    ['json', 'JSON', 'toJsonString'],
    ['har', 'HAR', 'toHarString'],
  ]},
];
---

<ToolLayout slug="curl-to-code">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      cURL command
      <textarea id="ct-in" class="field font-mono text-[13px]" rows="6" spellcheck="false" placeholder={"curl -X POST https://api.example.com/users -H 'Content-Type: application/json' -d '{\"name\":\"Ada\"}'"}></textarea>
    </label>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Target language
      <select id="ct-lang" class="field text-[13px]">
        {LANG_GROUPS.map((g) => (
          <optgroup label={g.label}>
            {g.opts.map(([value, name, fn]) => (
              <option value={value} data-fn={fn}>{g.label === 'More languages' || g.label === 'Tools & formats' ? name : `${g.label} — ${name}`}</option>
            ))}
          </optgroup>
        ))}
      </select>
    </label>

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span class="flex items-center justify-between">Generated code <button id="ct-copy" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy</button></span>
      <pre class="ct-code hl-block field font-mono text-[13px]" style="margin:0;overflow:auto;max-height:22rem;white-space:pre"><code id="ct-out" class="hljs" style="background:transparent;padding:0"></code></pre>
    </div>
    <p id="ct-warn" class="hidden text-[13px]" style="color:#f5a623" role="status"></p>
    <p id="ct-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free cURL to code converter turns a <code>curl</code> command into
      ready-to-run code for 30+ targets — JavaScript <code>fetch</code>, Node.js
      (axios, got, ky, request, superagent), Python <code>requests</code>, PHP,
      Java, Go, Rust, C#, Ruby, Swift, PowerShell, HTTPie and more. It handles
      methods, headers, query strings, JSON and form bodies, multipart uploads,
      cookies, basic auth and <code>--data-urlencode</code>. Paste a curl command,
      pick a language, and copy the equivalent snippet. Everything runs in your
      browser — nothing is sent to a server.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('ct-in') as HTMLTextAreaElement;
  const output = document.getElementById('ct-out') as HTMLElement;
  const langSel = document.getElementById('ct-lang') as HTMLSelectElement;
  const warnEl = document.getElementById('ct-warn')!;
  const err = document.getElementById('ct-error')!;
  const STORE = 'curl-to-code:lang';

  // Load the real curlconverter engine once. It requests the tree-sitter WASM
  // files from the server root (copied into public/), so this only works client-side.
  // Language value → highlight.js id. base = value before '-' (e.g. node-axios → node);
  // only the mismatches are listed, the rest map to their own name.
  const HL: Record<string, string> = {
    node: 'javascript', objc: 'objectivec', cfml: 'xml',
    httpie: 'bash', wget: 'bash', ansible: 'yaml', har: 'json',
  };
  function hlId(value: string): string {
    const base = value.split('-')[0];
    return HL[base] ?? base;
  }

  let cc: Record<string, (s: string) => [string, [string, string][]]> | null = null;
  let hljs: any = null;
  let loading: Promise<void> | null = null;
  function ensureEngine(): Promise<void> {
    if (cc && hljs) return Promise.resolve();
    if (!loading) loading = Promise.all([
      import('curlconverter'),
      import('highlight.js'),
    ]).then(([c, h]) => { cc = c as any; hljs = (h as any).default ?? h; });
    return loading;
  }

  function render(code: string) {
    const id = hlId(langSel.value);
    const lang = hljs.getLanguage(id) ? id : 'plaintext';
    output.innerHTML = hljs.highlight(code, { language: lang, ignoreIllegal: true }).value;
  }

  async function run() {
    err.classList.add('hidden');
    warnEl.classList.add('hidden');
    if (!input.value.trim()) { output.textContent = ''; return; }

    const fn = langSel.selectedOptions[0]?.dataset.fn;
    if (!fn) return;

    if (!output.textContent) output.textContent = 'Loading converter…';
    try {
      await ensureEngine();
      // Warn variants return [code, warnings]; fall back to the plain fn if absent.
      const warnFn = (cc as any)[fn + 'Warn'] ?? (cc as any)[fn];
      const res = warnFn(input.value);
      const [code, warnings] = Array.isArray(res) ? res : [res, []];
      render(code);
      if (warnings?.length) {
        warnEl.textContent = warnings
          .map((w: any) => (Array.isArray(w) ? w[w.length - 1] : String(w)))
          .join(' · ');
        warnEl.classList.remove('hidden');
      }
    } catch (e: any) {
      output.textContent = '';
      err.textContent = e?.message?.replace(/^curlconverter:\s*/i, '') || 'Could not parse that curl command.';
      err.classList.remove('hidden');
    }
  }

  // Restore last-used language.
  const saved = localStorage.getItem(STORE);
  if (saved && [...langSel.options].some((o) => o.value === saved)) langSel.value = saved;

  langSel.addEventListener('change', () => { localStorage.setItem(STORE, langSel.value); run(); });
  input.addEventListener('input', run);
  document.getElementById('ct-copy')!.addEventListener('click', async (e) => {
    await navigator.clipboard.writeText(output.textContent ?? '');
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });

  input.value = "curl -X POST https://api.example.com/users -H 'Content-Type: application/json' -d '{\"name\":\"Ada\",\"age\":36}'";
  run();
</script>

<style is:global>
  /* .hl-block token palette lives in global.css (shared across tools).
     .ct-code keeps its own sizing/scroll rules via the utility classes above. */
</style>

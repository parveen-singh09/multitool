---
import ToolLayout from '../../layouts/ToolLayout.astro';

const LANG_GROUPS: { label: string; opts: [string, string, string][] }[] = [
  { label: 'JavaScript', opts: [
    ['javascript', 'fetch', 'toJavaScript'],
    ['javascript-jquery', 'jQuery', 'toJavaScriptJquery'],
    ['javascript-xhr', 'XHR', 'toJavaScriptXHR'],
  ]},
  { label: 'Node.js', opts: [
    ['node', 'fetch', 'toNode'],
    ['node-axios', 'axios', 'toNodeAxios'],
    ['node-got', 'got', 'toNodeGot'],
    ['node-ky', 'ky', 'toNodeKy'],
    ['node-request', 'request', 'toNodeRequest'],
    ['node-superagent', 'superagent', 'toNodeSuperAgent'],
    ['node-http', 'http', 'toNodeHttp'],
  ]},
  { label: 'Python', opts: [
    ['python', 'requests', 'toPython'],
    ['python-http', 'http.client', 'toPythonHttp'],
  ]},
  { label: 'PHP', opts: [
    ['php', 'curl', 'toPhp'],
    ['php-guzzle', 'Guzzle', 'toPhpGuzzle'],
    ['php-requests', 'Requests', 'toPhpRequests'],
  ]},
  { label: 'Java', opts: [
    ['java', 'HttpClient', 'toJava'],
    ['java-okhttp', 'OkHttp', 'toJavaOkHttp'],
    ['java-jsoup', 'jsoup', 'toJavaJsoup'],
    ['java-httpurlconnection', 'HttpURLConnection', 'toJavaHttpUrlConnection'],
  ]},
  { label: 'Ruby', opts: [
    ['ruby', 'net/http', 'toRuby'],
    ['ruby-httparty', 'HTTParty', 'toRubyHttparty'],
  ]},
  { label: 'R', opts: [
    ['r', 'httr', 'toR'],
    ['r-httr2', 'httr2', 'toRHttr2'],
  ]},
  { label: 'PowerShell', opts: [
    ['powershell', 'Invoke-RestMethod', 'toPowershellRestMethod'],
    ['powershell-webrequest', 'Invoke-WebRequest', 'toPowershellWebRequest'],
  ]},
  { label: 'More languages', opts: [
    ['go', 'Go', 'toGo'],
    ['rust', 'Rust', 'toRust'],
    ['csharp', 'C#', 'toCSharp'],
    ['c', 'C (libcurl)', 'toC'],
    ['swift', 'Swift', 'toSwift'],
    ['objc', 'Objective-C', 'toObjectiveC'],
    ['kotlin', 'Kotlin', 'toKotlin'],
    ['dart', 'Dart', 'toDart'],
    ['elixir', 'Elixir', 'toElixir'],
    ['clojure', 'Clojure', 'toClojure'],
    ['perl', 'Perl', 'toPerl'],
    ['lua', 'Lua', 'toLua'],
    ['ocaml', 'OCaml', 'toOCaml'],
    ['julia', 'Julia', 'toJulia'],
    ['matlab', 'MATLAB', 'toMATLAB'],
    ['cfml', 'ColdFusion', 'toCFML'],
  ]},
  { label: 'Tools & formats', opts: [
    ['httpie', 'HTTPie', 'toHttpie'],
    ['wget', 'Wget', 'toWget'],
    ['ansible', 'Ansible', 'toAnsible'],
    ['http', 'HTTP', 'toHTTP'],
    ['json', 'JSON', 'toJsonString'],
    ['har', 'HAR', 'toHarString'],
  ]},
];

const PRESETS: { label: string; cmd: string }[] = [
  { label: 'GET', cmd: 'curl https://api.example.com/users' },
  { label: 'POST JSON', cmd: `curl -X POST https://api.example.com/users -H 'Content-Type: application/json' -d '{"name":"Ada","age":36}'` },
  { label: 'Bearer token', cmd: `curl https://api.example.com/me -H 'Authorization: Bearer YOUR_TOKEN'` },
  { label: 'Basic auth', cmd: 'curl -u user:pass https://api.example.com/protected' },
  { label: 'Form body', cmd: `curl -X POST https://api.example.com/login -d 'username=ada&password=secret'` },
  { label: 'File upload', cmd: `curl -X POST https://api.example.com/upload -F 'file=@photo.jpg' -F 'caption=Sunset'` },
  { label: 'Cookies', cmd: `curl https://api.example.com/dashboard -b 'session=abc123'` },
];
---

<ToolLayout slug="curl-to-code">
  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-2">
      <span class="eyebrow text-ink-subtle">Quick examples</span>
      <div class="flex flex-wrap gap-2">
        {PRESETS.map((p) => (
          <button type="button" class="btn btn-tertiary px-2 py-1 text-[13px]" data-preset={p.cmd}>{p.label}</button>
        ))}
      </div>
    </div>

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span class="flex items-center justify-between">
        <span>cURL command</span>
        <button id="ct-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
      </span>
      <div class="hl-edit field p-0" style="height:11rem;overflow:hidden">
        <pre class="hl-block" aria-hidden="true"><code id="ct-in-hl" class="hljs" style="background:transparent"></code></pre>
        <textarea id="ct-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder={"curl -X POST https://api.example.com/users -H 'Content-Type: application/json' -d '{\"name\":\"Ada\"}'"}></textarea>
      </div>
      <span class="text-[13px] text-ink-tertiary">Tip: in your browser DevTools, right-click a request → Copy → Copy as cURL, then paste it here.</span>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Target language
      <select id="ct-lang" class="field text-[13px]">
        {LANG_GROUPS.map((g) => (
          <optgroup label={g.label}>
            {g.opts.map(([value, name, fn]) => (
              <option value={value} data-fn={fn}>{g.label === 'More languages' || g.label === 'Tools & formats' ? name : `${g.label} — ${name}`}</option>
            ))}
          </optgroup>
        ))}
      </select>
    </label>

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span class="flex items-center justify-between">
        <span>Generated code</span>
        <span class="flex gap-2">
          <button id="ct-copy" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy</button>
          <button id="ct-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
        </span>
      </span>
      <pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre"><code id="ct-out" class="hljs" style="background:transparent;padding:0"></code></pre>
    </div>
    <p id="ct-warn" class="hidden text-[13px]" style="color:#f5a623" role="status"></p>
    <p id="ct-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free cURL to code converter turns a <code>curl</code> command into
      ready-to-run code for 30+ targets — JavaScript <code>fetch</code>, Node.js
      (axios, got, ky, request, superagent), Python <code>requests</code>, PHP
      (cURL, Guzzle, Requests), Java (HttpClient, OkHttp, jsoup), Go, Rust, C#,
      Ruby, Swift, Kotlin, Dart, Elixir, R, PowerShell, HTTPie, Wget, Ansible and
      more. It handles methods, headers, query strings, JSON and form bodies,
      multipart uploads, cookies, basic auth and <code>--data-urlencode</code>.
    </p>
    <p>
      Paste a curl command — or start from one of the quick examples (GET, POST
      JSON, bearer token, basic auth, form body, file upload, cookies) — pick a
      language, and the equivalent snippet appears instantly with syntax
      highlighting on both your command and the output. Copy it to the clipboard
      or download it as a source file with the right extension. The fastest way
      to grab a real request: open your browser DevTools, find the request on the
      Network tab, right-click and choose <code>Copy as cURL</code>, then paste it
      here.
    </p>
    <p>
      Everything runs in your browser — nothing is sent to a server. Note that
      copied curl commands may contain cookies, tokens or other secrets, so review
      before sharing the generated code.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl, wireInput } from '../../lib/highlight';

  const input = document.getElementById('ct-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('ct-in-hl')!;
  const output = document.getElementById('ct-out') as HTMLElement;
  const langSel = document.getElementById('ct-lang') as HTMLSelectElement;
  const warnEl = document.getElementById('ct-warn')!;
  const err = document.getElementById('ct-error')!;
  const STORE = 'curl-to-code:lang';

  const HL: Record<string, string> = {
    node: 'javascript', objc: 'objectivec', cfml: 'xml',
    httpie: 'bash', wget: 'bash', ansible: 'yaml', har: 'json',
  };
  function hlId(value: string): string {
    const base = value.split('-')[0];
    return HL[base] ?? base;
  }

  const EXT: Record<string, string> = {
    javascript: 'js', node: 'js', python: 'py', php: 'php', java: 'java',
    ruby: 'rb', go: 'go', rust: 'rs', csharp: 'cs', c: 'c', swift: 'swift',
    objc: 'm', kotlin: 'kt', dart: 'dart', elixir: 'ex', clojure: 'clj',
    perl: 'pl', lua: 'lua', ocaml: 'ml', julia: 'jl', matlab: 'm', cfml: 'cfm',
    r: 'r', powershell: 'ps1', httpie: 'sh', wget: 'sh', ansible: 'yml',
    http: 'http', json: 'json', har: 'har',
  };

  let cc: Record<string, (s: string) => unknown> | null = null;
  let loading: Promise<void> | null = null;
  function ensureEngine(): Promise<void> {
    if (cc) return Promise.resolve();
    if (!loading) loading = import('curlconverter').then((c) => { cc = c as any; });
    return loading;
  }

  let rawOutput = '';

  async function run() {
    err.classList.add('hidden');
    warnEl.classList.add('hidden');
    if (!input.value.trim()) { rawOutput = ''; output.textContent = ''; return; }

    const fn = langSel.selectedOptions[0]?.dataset.fn;
    if (!fn) return;

    if (!output.textContent) output.textContent = 'Loading converter…';
    try {
      await ensureEngine();

      const warnFn = (cc as any)[fn + 'Warn'] ?? (cc as any)[fn];
      const res = warnFn(input.value);
      const [code, warnings] = Array.isArray(res) ? res : [res, []];
      rawOutput = code;
      await hl(output, code, hlId(langSel.value));
      if (warnings?.length) {
        warnEl.textContent = warnings
          .map((w: any) => (Array.isArray(w) ? w[w.length - 1] : String(w)))
          .join(' · ');
        warnEl.classList.remove('hidden');
      }
    } catch (e: any) {
      rawOutput = '';
      output.textContent = '';
      err.textContent = e?.message?.replace(/^curlconverter:\s*/i, '') || 'Could not parse that curl command.';
      err.classList.remove('hidden');
    }
  }

  const rerender = wireInput(input, inHl, () => 'bash', run);

  const saved = localStorage.getItem(STORE);
  if (saved && [...langSel.options].some((o) => o.value === saved)) langSel.value = saved;

  langSel.addEventListener('change', () => { localStorage.setItem(STORE, langSel.value); run(); });

  document.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((btn) => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.preset ?? '';
      rerender();
      run();
    });
  });

  document.getElementById('ct-clear')!.addEventListener('click', () => {
    input.value = '';
    rawOutput = '';
    output.textContent = '';
    err.classList.add('hidden');
    warnEl.classList.add('hidden');
    rerender();
    input.focus();
  });

  document.getElementById('ct-copy')!.addEventListener('click', async (e) => {
    if (!rawOutput) return;
    await navigator.clipboard.writeText(rawOutput);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });

  document.getElementById('ct-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const ext = EXT[langSel.value.split('-')[0]] ?? 'txt';
    const blob = new Blob([rawOutput], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `request.${ext}`;
    a.click();
    URL.revokeObjectURL(url);
  });

  input.value = "curl -X POST https://api.example.com/users -H 'Content-Type: application/json' -d '{\"name\":\"Ada\",\"age\":36}'";
  rerender();
  run();
</script>

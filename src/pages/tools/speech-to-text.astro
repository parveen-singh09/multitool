            <option value="sl-SI">Slovenščina (Slovenian)</option>
            <option value="su-ID">Basa Sunda (Sundanese)</option>
            <option value="sw-KE">Kiswahili (Kenya)</option>
            <option value="sw-TZ">Kiswahili (Tanzania)</option>
            <option value="sv-SE">Svenska (Swedish)</option>
            <option value="ta-IN">தமிழ் (India)</option>
            <option value="ta-LK">தமிழ் (Sri Lanka)</option>
            <option value="ta-SG">தமிழ் (Singapore)</option>
            <option value="ta-MY">தமிழ் (Malaysia)</option>
            <option value="te-IN">తెలుగు (Telugu)</option>
            <option value="th-TH">ภาษาไทย (Thai)</option>
            <option value="tr-TR">Türkçe (Turkish)</option>
            <option value="uk-UA">Українська (Ukrainian)</option>
            <option value="ur-PK">اردو (Pakistan)</option>
            <option value="ur-IN">اردو (India)</option>
            <option value="uz-UZ">Oʻzbek (Uzbek)</option>
            <option value="vi-VN">Tiếng Việt (Vietnamese)</option>
            <option value="zu-ZA">IsiZulu (Zulu)</option>
          </optgroup>
        </select>
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="st-punct" type="checkbox" class="accent-primary" checked /> Auto-capitalize sentences
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="st-cmd" type="checkbox" class="accent-primary" checked /> Voice commands
      </label>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="st-start" type="button" class="btn btn-primary">
        <span id="st-dot" class="hidden h-2 w-2 rounded-full" style="background:#e5484d"></span>
        <span id="st-start-label">Start listening</span>
      </button>
      <button id="st-clear" type="button" class="btn btn-secondary">Clear</button>
      <button id="st-copy" type="button" class="btn btn-secondary">Copy</button>
      <button id="st-download-txt" type="button" class="btn btn-tertiary">Download .txt</button>
      <button id="st-download-doc" type="button" class="btn btn-tertiary">Download .doc</button>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span class="flex items-center gap-2">Transcript <span id="st-count" class="text-xs text-ink-tertiary"></span> <span id="st-saved" class="text-xs text-ink-tertiary"></span></span>
      <textarea id="st-out" class="field" rows="10" placeholder="Your speech will appear here as you talk…" spellcheck="true"></textarea>
    </label>
    <p id="st-interim" class="min-h-5 text-[13px] italic text-ink-tertiary"></p>

    <details class="panel p-4 text-[13px] text-ink-subtle">
      <summary class="cursor-pointer select-none text-ink-muted">Voice commands — say these while dictating</summary>
      <div class="mt-3 grid grid-cols-2 gap-x-6 gap-y-1 sm:grid-cols-3">
        <span><strong class="text-ink">“period”</strong> → .</span>
        <span><strong class="text-ink">“comma”</strong> → ,</span>
        <span><strong class="text-ink">“question mark”</strong> → ?</span>
        <span><strong class="text-ink">“exclamation mark”</strong> → !</span>
        <span><strong class="text-ink">“colon”</strong> → :</span>
        <span><strong class="text-ink">“semicolon”</strong> → ;</span>
        <span><strong class="text-ink">“new line”</strong> → line break</span>
        <span><strong class="text-ink">“new paragraph”</strong> → blank line</span>
        <span><strong class="text-ink">“open / close paren”</strong> → ( )</span>
        <span><strong class="text-ink">“open / close quote”</strong> → "</span>
        <span><strong class="text-ink">“hyphen” / “dash”</strong> → -</span>
        <span><strong class="text-ink">“smiley”</strong> → :)</span>
      </div>
    </details>

    <p id="st-unsupported" class="hidden text-[13px]" style="color:#e5484d" role="alert">
      Speech recognition isn't available in this browser. It works in Chrome and Edge on desktop and Android. On other browsers you can still type or paste into the transcript box.
    </p>
    <p id="st-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free speech to text tool transcribes your voice into editable text
      using your browser's built-in speech recognition. Click start, allow
      microphone access, and speak — words appear live and keep going across
      pauses. Speak <strong>voice commands</strong> like “period”, “comma”,
      “question mark”, “new line” and “new paragraph” to punctuate and format
      hands-free, and let auto-capitalization clean up each sentence. Pick from
      120+ languages and regional accents, watch the live word and character
      count, then copy the text or download it as a <strong>.txt</strong> or
      <strong>.doc</strong> file. Your transcript is autosaved in this browser
      so it survives an accidental refresh. Recognition is handled by your
      browser (Chrome and Edge support it best); no audio is uploaded or stored
      by this site.
    </p>
  </div>
</ToolLayout>

<script>
  const SR = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
  const startBtn = document.getElementById('st-start') as HTMLButtonElement;
  const startLabel = document.getElementById('st-start-label')!;
  const dot = document.getElementById('st-dot')!;
  const out = document.getElementById('st-out') as HTMLTextAreaElement;
  const interim = document.getElementById('st-interim')!;
  const langSel = document.getElementById('st-lang') as HTMLSelectElement;
  const punct = document.getElementById('st-punct') as HTMLInputElement;
  const cmdToggle = document.getElementById('st-cmd') as HTMLInputElement;
  const count = document.getElementById('st-count')!;
  const saved = document.getElementById('st-saved')!;
  const unsupported = document.getElementById('st-unsupported')!;
  const err = document.getElementById('st-error')!;

  const SAVE_KEY = 'speech-to-text:transcript';

  try {
    const prev = localStorage.getItem(SAVE_KEY);
    if (prev) out.value = prev;
  } catch {}

  let saveTimer: number | undefined;
  function autosave() {
    try {
      localStorage.setItem(SAVE_KEY, out.value);
      saved.textContent = '· saved';
      clearTimeout(saveTimer);
      saveTimer = window.setTimeout(() => (saved.textContent = ''), 1200);
    } catch {}
  }

  function updateCount() {
    const t = out.value.trim();
    const words = t ? t.split(/\s+/).length : 0;
    const chars = out.value.length;
    count.textContent = `${words} word${words === 1 ? '' : 's'} · ${chars} char${chars === 1 ? '' : 's'}`;
  }
  out.addEventListener('input', () => { updateCount(); autosave(); });

  // Spoken punctuation / formatting commands. Applied to each final chunk when enabled.
  const COMMANDS: Array<[RegExp, string]> = [
    [/\bnew paragraph\b/gi, '\n\n'],
    [/\bnew line\b/gi, '\n'],
    [/\b(full stop|period)\b/gi, '. '],
    [/\bcomma\b/gi, ', '],
    [/\bquestion mark\b/gi, '? '],
    [/\bexclamation (mark|point)\b/gi, '! '],
    [/\bsemicolon\b/gi, '; '],
    [/\bcolon\b/gi, ': '],
    [/\bopen paren(thesis)?\b/gi, ' ('],
    [/\bclose paren(thesis)?\b/gi, ') '],
    [/\bopen quote\b/gi, ' "'],
    [/\bclose quote\b/gi, '" '],
    [/\b(hyphen|dash)\b/gi, '-'],
    [/\bellipsis\b/gi, '… '],
    [/\bsmiley( face)?\b/gi, ' :) '],
    [/\bsad face\b/gi, ' :( '],
  ];
  function applyCommands(s: string) {
    for (const [re, rep] of COMMANDS) s = s.replace(re, rep);
    // Tidy spaces: collapse around line breaks, drop space before sentence
    // punctuation (but not smiley colons like :) ), and squeeze doubles.
    return s
      .replace(/[ \t]*\n[ \t]*/g, '\n')
      .replace(/[ \t]+([.,;:!?])(?![)(])/g, '$1')
      .replace(/[ \t]{2,}/g, ' ');
  }

  document.getElementById('st-clear')!.addEventListener('click', () => { out.value = ''; interim.textContent = ''; updateCount(); autosave(); });
  document.getElementById('st-copy')!.addEventListener('click', async (e) => {
    await navigator.clipboard.writeText(out.value);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });
  function download(filename: string, mime: string, data: string) {
    const blob = new Blob([data], { type: mime });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = filename; a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 1000);
  }
  document.getElementById('st-download-txt')!.addEventListener('click', () => {
    download('transcript.txt', 'text/plain', out.value);
  });
  document.getElementById('st-download-doc')!.addEventListener('click', () => {
    // Minimal Word-openable HTML document. ponytail: HTML .doc is the stdlib-free way Word imports cleanly.
    const esc = out.value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const html = `<html xmlns:w="urn:schemas-microsoft-com:office:word"><head><meta charset="utf-8"></head><body><p>${esc.replace(/\n\n+/g, '</p><p>').replace(/\n/g, '<br>')}</p></body></html>`;
    download('transcript.doc', 'application/msword', html);
  });

  if (!SR) {
    unsupported.classList.remove('hidden');
    startBtn.disabled = true;
    startBtn.classList.add('opacity-50');
  } else {
    const recog = new SR();
    recog.continuous = true;
    recog.interimResults = true;
    let listening = false;
    let manualStop = false;

    const capitalize = (s: string) => s.replace(/(^\s*\w|[.!?]\s+\w)/g, (c) => c.toUpperCase());

    langSel.addEventListener('change', () => { recog.lang = langSel.value; });
    recog.lang = langSel.value;

    recog.onresult = (ev: any) => {
      let finalTxt = '';
      let interimTxt = '';
      for (let i = ev.resultIndex; i < ev.results.length; i++) {
        const t = ev.results[i][0].transcript;
        if (ev.results[i].isFinal) finalTxt += t;
        else interimTxt += t;
      }
      if (finalTxt) {
        let addition = (cmdToggle.checked ? applyCommands(finalTxt) : finalTxt).trim();
        // Leading break (new line/paragraph) shouldn't get a space before it; nor should leading punctuation.
        const startsBreak = /^\n/.test(addition);
        const needsSpace = out.value && !/\s$/.test(out.value) && !startsBreak && !/^[.,;:!?)]/.test(addition);
        out.value += (needsSpace ? ' ' : '') + addition;
        if (punct.checked) out.value = capitalize(out.value);
        updateCount();
        autosave();
      }
      interim.textContent = cmdToggle.checked ? applyCommands(interimTxt) : interimTxt;
    };

    recog.onerror = (ev: any) => {
      if (ev.error === 'no-speech' || ev.error === 'aborted') return;
      manualStop = true; // don't auto-restart on a real error
      if (ev.error === 'not-allowed' || ev.error === 'service-not-allowed') {
        err.textContent = 'Microphone access was blocked. Allow the mic in your browser and try again.';
      } else if (ev.error === 'network') {
        err.innerHTML = 'Your browser can’t reach a speech-recognition service. Brave, Firefox and some privacy browsers disable the built-in service that Chrome and Edge use. Open this page in <strong>Chrome or Edge</strong> to dictate, or type/paste into the box below.';
      } else {
        err.textContent = `Recognition error: ${ev.error}`;
      }
      err.classList.remove('hidden');
      setListening(false);
    };

    recog.onend = () => {
      // Chrome stops after silence; restart unless the user pressed stop.
      if (listening && !manualStop) { try { recog.start(); } catch {} }
      else setListening(false);
    };

    function setListening(on: boolean) {
      listening = on;
      startLabel.textContent = on ? 'Stop listening' : 'Start listening';
      startBtn.classList.toggle('btn-primary', !on);
      startBtn.classList.toggle('btn-secondary', on);
      dot.classList.toggle('hidden', !on);
      if (on) dot.classList.add('animate-pulse');
    }

    startBtn.addEventListener('click', () => {
      err.classList.add('hidden');
      if (listening) {
        manualStop = true;
        recog.stop();
        setListening(false);
      } else {
        manualStop = false;
        try { recog.start(); setListening(true); } catch 
      }
    });
  }

  updateCount();
</script>

            <option value="lt-LT">Lietuvių (Lithuanian)</option>
            <option value="ms-MY">Bahasa Melayu (Malay)</option>
            <option value="ml-IN">മലയാളം (Malayalam)</option>
            <option value="mr-IN">मराठी (Marathi)</option>

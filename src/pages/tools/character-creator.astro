---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="character-creator">
  <div class="flex flex-col gap-5">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Genre
        <select id="cc-genre" class="field w-44">
          <option value="fantasy">Fantasy</option>
          <option value="scifi">Sci-fi</option>
          <option value="modern">Modern</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Stat method
        <select id="cc-method" class="field w-44">
          <option value="4d6">4d6 drop lowest</option>
          <option value="3d6">3d6 straight</option>
          <option value="array">Standard array</option>
        </select>
      </label>
      <button id="cc-roll" class="btn btn-primary ml-auto">🎲 Roll character</button>
    </div>

    <div id="cc-sheet" class="panel panel-lift flex flex-col gap-5 p-6"></div>

    <div class="flex gap-2">
      <button id="cc-copy" class="btn btn-secondary">Copy sheet</button>
      <button id="cc-reroll-stats" class="btn btn-secondary">Reroll stats only</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free character creator rolls a complete tabletop-style character in one
      click: a name, race/species, class or role, six ability scores with
      modifiers, a personality trait, an ideal, a flaw and a one-line backstory
      hook to get your story moving. Choose a fantasy, sci-fi or modern genre and
      your preferred stat method (4d6 drop lowest, straight 3d6, or the standard
      array), then reroll the whole sheet or just the stats. Great for D&D, writing
      prompts and RPG NPCs. Everything is generated in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { pick, randInt, shuffle } from '../../lib/random';

  const DATA: Record<string, { names: string[]; races: string[]; classes: string[] }> = {
    fantasy: {
      names: ['Aeryn', 'Bram', 'Cassia', 'Doran', 'Elowen', 'Fenn', 'Gwyn', 'Hale', 'Isolde', 'Joss', 'Kael', 'Lyra', 'Maeve', 'Nyx', 'Orin', 'Perrin', 'Rook', 'Sable', 'Thane', 'Vesper'],
      races: ['Human', 'Elf', 'Dwarf', 'Halfling', 'Half-orc', 'Tiefling', 'Dragonborn', 'Gnome', 'Half-elf'],
      classes: ['Fighter', 'Wizard', 'Rogue', 'Cleric', 'Ranger', 'Bard', 'Barbarian', 'Druid', 'Paladin', 'Warlock', 'Sorcerer', 'Monk'],
    },
    scifi: {
      names: ['Vex', 'Nova', 'Zane', 'Kira', 'Orion', 'Lux', 'Rell', 'Sylas', 'Juno', 'Dax', 'Echo', 'Cyra', 'Ansel', 'Mira', 'Talon'],
      races: ['Human', 'Android', 'Cyborg', 'Xenari', 'Clone', 'Uplift', 'Void-born', 'Synth'],
      classes: ['Pilot', 'Engineer', 'Marine', 'Medic', 'Netrunner', 'Smuggler', 'Diplomat', 'Bounty Hunter', 'Scientist', 'Mystic'],
    },
    modern: {
      names: ['Alex', 'Bailey', 'Cameron', 'Dana', 'Elliot', 'Frankie', 'Harper', 'Jordan', 'Kai', 'Morgan', 'Parker', 'Quinn', 'Riley', 'Sage', 'Taylor'],
      races: ['Human'],
      classes: ['Detective', 'Hacker', 'Doctor', 'Journalist', 'Soldier', 'Con Artist', 'Scientist', 'Athlete', 'Occultist', 'Mechanic'],
    },
  };

  const TRAITS = ['Fiercely loyal to a fault', 'Never backs down from a dare', 'Collects small trinkets obsessively', 'Speaks in questions', 'Distrusts anyone too polite', 'Laughs at the worst moments', 'Always keeps a promise', 'Endlessly curious', 'Quietly competitive', 'Terrible at lying'];
  const IDEALS = ['Freedom above all else', 'Knowledge is worth any price', 'Protect those who cannot protect themselves', 'The ends justify the means', 'Honor before victory', 'Change is the only constant', 'Family is everything', 'Redemption is always possible'];
  const FLAWS = ['Cannot resist a wager', 'Holds grudges for years', 'Secretly a coward under pressure', 'Trusts too easily', 'Haunted by a past mistake', 'Greedy for recognition', 'Speaks before thinking', 'Afraid of being forgotten'];
  const HOOKS = ['is searching for a sibling who vanished a year ago.', 'owes a dangerous debt to the wrong people.', 'carries a map no one else can read.', 'woke up with no memory of the last three days.', 'is the last of a fallen order.', 'received a letter from someone long presumed dead.', 'is hunting the person who ruined their family.', 'guards a secret that could start a war.'];

  const ABILITIES = ['STR', 'DEX', 'CON', 'INT', 'WIS', 'CHA'];
  const STANDARD_ARRAY = [15, 14, 13, 12, 10, 8];

  const $ = (id: string) => document.getElementById(id)!;
  const sheet = $('cc-sheet');

  interface Char { name: string; race: string; cls: string; trait: string; ideal: string; flaw: string; hook: string; stats: number[]; }
  let current: Char;

  function roll4d6(): number {
    const dice = [randInt(1, 6), randInt(1, 6), randInt(1, 6), randInt(1, 6)].sort((a, b) => a - b);
    return dice[1] + dice[2] + dice[3];
  }
  function roll3d6(): number { return randInt(1, 6) + randInt(1, 6) + randInt(1, 6); }

  function rollStats(): number[] {
    const method = ($('cc-method') as HTMLSelectElement).value;
    if (method === 'array') return shuffle(STANDARD_ARRAY);
    const fn = method === '3d6' ? roll3d6 : roll4d6;
    return ABILITIES.map(() => fn());
  }

  function mod(score: number): string {
    const m = Math.floor((score - 10) / 2);
    return m >= 0 ? `+${m}` : String(m);
  }

  function generate(keepStats = false): Char {
    const genre = ($('cc-genre') as HTMLSelectElement).value;
    const d = DATA[genre];
    return {
      name: pick(d.names),
      race: pick(d.races),
      cls: pick(d.classes),
      trait: pick(TRAITS),
      ideal: pick(IDEALS),
      flaw: pick(FLAWS),
      hook: pick(HOOKS),
      stats: keepStats && current ? current.stats : rollStats(),
    };
  }

  function render(c: Char) {
    const statCards = ABILITIES.map((a, i) => `
      <div class="flex flex-col items-center gap-0.5 rounded-[8px] border border-hairline bg-surface-2 p-2">
        <span class="text-[11px] text-ink-tertiary">${a}</span>
        <span class="font-display text-2xl font-semibold text-ink">${c.stats[i]}</span>
        <span class="text-[12px] text-primary-hover">${mod(c.stats[i])}</span>
      </div>`).join('');

    sheet.innerHTML = `
      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
        <span class="font-display text-3xl font-semibold text-ink">${c.name}</span>
        <span class="text-ink-subtle">${c.race} · ${c.cls}</span>
      </div>
      <div class="grid grid-cols-3 gap-2 sm:grid-cols-6">${statCards}</div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        ${line('Personality', c.trait)}
        ${line('Ideal', c.ideal)}
        ${line('Flaw', c.flaw)}
        ${line('Hook', `${c.name} ${c.hook}`)}
      </div>`;
  }

  function line(label: string, text: string): string {
    return `<div class="flex flex-col gap-0.5">
      <span class="text-[12px] uppercase tracking-wide text-ink-tertiary">${label}</span>
      <span class="text-[15px] text-ink-muted">${text}</span>
    </div>`;
  }

  function asText(c: Char): string {
    return `${c.name} — ${c.race} ${c.cls}\n` +
      ABILITIES.map((a, i) => `${a} ${c.stats[i]} (${mod(c.stats[i])})`).join('  ') + '\n' +
      `Personality: ${c.trait}\nIdeal: ${c.ideal}\nFlaw: ${c.flaw}\nHook: ${c.name} ${c.hook}`;
  }

  $('cc-roll').addEventListener('click', () => { current = generate(false); render(current); });
  $('cc-reroll-stats').addEventListener('click', () => { if (current) { current.stats = rollStats(); render(current); } });
  ($('cc-genre') as HTMLSelectElement).addEventListener('change', () => { current = generate(false); render(current); });
  ($('cc-method') as HTMLSelectElement).addEventListener('change', () => { if (current) { current.stats = rollStats(); render(current); } });
  $('cc-copy').addEventListener('click', async (e) => {
    await navigator.clipboard.writeText(asText(current));
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy sheet'), 1400);
  });

  current = generate(false);
  render(current);
</script>

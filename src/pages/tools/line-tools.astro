---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="line-tools">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2">
      <button data-op="sort-asc" class="btn btn-secondary">Sort A→Z</button>
      <button data-op="sort-desc" class="btn btn-secondary">Sort Z→A</button>
      <button data-op="dedupe" class="btn btn-secondary">Remove duplicates</button>
      <button data-op="reverse" class="btn btn-secondary">Reverse</button>
      <button data-op="shuffle" class="btn btn-secondary">Shuffle</button>
      <button data-op="trim" class="btn btn-secondary">Trim spaces</button>
      <button data-op="blank" class="btn btn-secondary">Remove blank lines</button>
    </div>

    <label class="flex items-center gap-2 text-sm text-ink-subtle">
      <input type="checkbox" id="lt-ci" class="accent-[#5e6ad2]" /> Case-insensitive sort & dedupe
    </label>

    <textarea id="lt-io" class="field min-h-64 resize-y font-mono text-[13px]" placeholder="Paste your lines here…" spellcheck="false"></textarea>

    <div class="flex flex-wrap items-center gap-4 text-[13px] text-ink-subtle">
      <span>Lines: <span id="lt-count" class="text-ink">0</span></span>
      <button id="lt-copy" class="btn btn-secondary ml-auto">Copy</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      These free line tools let you clean up lists fast: sort lines
      alphabetically, remove duplicate or blank lines, reverse or shuffle the
      order, and trim stray whitespace. Perfect for tidying keyword lists, CSV
      columns, or logs. Everything runs locally in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const io = document.getElementById('lt-io') as HTMLTextAreaElement;
  const ci = document.getElementById('lt-ci') as HTMLInputElement;
  const countEl = document.getElementById('lt-count')!;

  const lines = () => io.value.split('\n');
  const setLines = (arr: string[]) => { io.value = arr.join('\n'); updateCount(); };
  const updateCount = () => {
    countEl.textContent = io.value === '' ? '0' : String(io.value.split('\n').length);
  };
  const cmp = (a: string, b: string) =>
    (ci.checked ? a.toLowerCase() : a).localeCompare(ci.checked ? b.toLowerCase() : b);

  const ops: Record<string, () => void> = {
    'sort-asc': () => setLines([...lines()].sort(cmp)),
    'sort-desc': () => setLines([...lines()].sort((a, b) => cmp(b, a))),
    dedupe: () => {
      const seen = new Set<string>();
      setLines(lines().filter((l) => {
        const k = ci.checked ? l.toLowerCase() : l;
        if (seen.has(k)) return false;
        seen.add(k); return true;
      }));
    },
    reverse: () => setLines([...lines()].reverse()),
    shuffle: () => {
      const a = [...lines()];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      setLines(a);
    },
    trim: () => setLines(lines().map((l) => l.trim())),
    blank: () => setLines(lines().filter((l) => l.trim() !== '')),
  };

  document.querySelectorAll<HTMLButtonElement>('[data-op]').forEach((btn) => {
    btn.addEventListener('click', () => ops[btn.dataset.op!]?.());
  });
  io.addEventListener('input', updateCount);
  document.getElementById('lt-copy')!.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(io.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
  updateCount();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="sprite-sheet-maker">
  <div class="flex flex-col gap-4">
    <label id="ssm-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Drop frames here or choose images</span>
      <span class="text-[13px] text-ink-tertiary">PNG, JPG, GIF, WebP — packed in your browser, never uploaded</span>
      <input id="ssm-files" type="file" accept="image/png,image/jpeg,image/gif,image/webp" multiple class="sr-only" />
    </label>

    <details class="panel p-4">
      <summary class="cursor-pointer text-sm text-ink">Split an existing sheet into frames</summary>
      <div class="mt-3 flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sheet<input id="ssm-split-file" type="file" accept="image/png,image/jpeg,image/gif,image/webp" class="field w-56" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Columns<input id="ssm-split-cols" type="number" min="1" max="100" step="1" value="4" class="field w-24" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Rows<input id="ssm-split-rows" type="number" min="1" max="100" step="1" value="4" class="field w-24" /></label>
        <button id="ssm-split-go" class="btn btn-primary">Split into frames</button>
      </div>
      <p class="mt-2 text-[13px] text-ink-tertiary">Slices the sheet into columns × rows equal cells and adds each as a frame.</p>
    </details>

    <div id="ssm-frames-wrap" class="hidden flex-col gap-2">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-sm text-ink-subtle">Frames <span id="ssm-count" class="text-ink-tertiary"></span> — drag to reorder, click to select</span>
        <div class="ml-auto flex flex-wrap gap-1">
          <button id="ssm-flip-h" class="btn btn-secondary" title="Flip selected frame horizontally" disabled>Flip H</button>
          <button id="ssm-flip-v" class="btn btn-secondary" title="Flip selected frame vertically" disabled>Flip V</button>
          <button id="ssm-rotate" class="btn btn-secondary" title="Rotate selected frame 90°" disabled>Rotate</button>
          <button id="ssm-duplicate" class="btn btn-secondary" title="Duplicate selected frame" disabled>Duplicate</button>
        </div>
      </div>
      <div id="ssm-frames" class="flex flex-wrap gap-2"></div>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Layout
        <select id="ssm-mode" class="field">
          <option value="grid">Uniform grid</option>
          <option value="packed">Tight packing</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle" id="ssm-cols-wrap">
        Columns
        <input id="ssm-cols" type="number" min="1" max="50" step="1" value="4" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Padding (px)
        <input id="ssm-pad" type="number" min="0" max="100" step="1" value="4" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Background
        <input id="ssm-bg" type="color" value="#ffffff" class="field h-10 cursor-pointer p-1" />
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle sm:mt-6">
        <input id="ssm-transparent" type="checkbox" checked class="h-4 w-4 accent-[#5e6ad2]" />
        Transparent background
      </label>
    </div>

    <p id="ssm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="flex flex-col gap-4 lg:flex-row">
      <div class="panel flex-1 overflow-auto p-4">
        <canvas id="ssm-canvas" class="max-w-full h-auto rounded-md" aria-label="Sprite sheet preview"></canvas>
      </div>
      <div class="panel flex flex-col items-center gap-3 p-4 lg:w-64">
        <span class="self-start text-sm text-ink-subtle">Animation preview</span>
        <div class="flex min-h-24 items-center justify-center">
          <canvas id="ssm-anim" class="rounded-md" aria-label="Animation preview"></canvas>
        </div>
        <div class="flex w-full items-center gap-3">
          <button id="ssm-play" class="btn btn-primary">Play</button>
          <label class="flex min-w-0 flex-1 items-center gap-2 text-sm text-ink-subtle">
            <span id="ssm-fps-label" class="w-14 shrink-0">12 fps</span>
            <input id="ssm-fps" type="range" min="1" max="60" value="12" class="ssm-range w-full min-w-0 flex-1" />
          </label>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="ssm-dl-png" class="btn btn-primary">Download PNG</button>
      <button id="ssm-dl-json" class="btn btn-secondary">JSON atlas</button>
      <button id="ssm-dl-css" class="btn btn-secondary">CSS sprites</button>
      <button id="ssm-dl-zip" class="btn btn-secondary">ZIP bundle</button>
    </div>

    <div class="flex flex-col gap-1">
      <span class="text-sm text-ink-subtle">JSON atlas</span>
      <pre id="ssm-coords" class="field min-h-32 resize-y overflow-auto whitespace-pre-wrap font-mono text-[13px]">Add frames to see the atlas.</pre>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free sprite sheet maker packs multiple images into a single texture
      atlas for games and CSS. Drop your frames in, drag to reorder them, and
      choose a uniform grid or tight bin-packing that fits sprites of different
      sizes with minimal wasted space. Preview the animation at any frame rate,
      then export the combined PNG along with a JSON atlas (Phaser / PixiJS
      style), CSS sprite rules, or a ZIP bundle with all three.
    </p>
    <p>
      You can also split an existing sprite sheet back into individual frames by
      giving the number of columns and rows. Everything runs locally with the
      HTML canvas — your images never leave your device.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .ssm-range { -webkit-appearance:none; appearance:none; height:4px; border-radius:9999px; background:#23252a; cursor:pointer; }
  .ssm-range::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:16px; height:16px; border-radius:9999px; background:#5e6ad2; border:none; cursor:pointer; }
  .ssm-range::-moz-range-thumb { width:16px; height:16px; border-radius:9999px; background:#5e6ad2; border:none; cursor:pointer; }
  .ssm-range:focus-visible { outline:2px solid rgba(94,105,209,0.5); outline-offset:2px; }
  /* Thumbs are created in JS, so they miss Astro's scoping attribute — style them globally. */
  :global(.ssm-thumb) { position:relative; width:56px; height:56px; flex:0 0 auto; border:1px solid #23252a; border-radius:6px; background:#0f1011; display:flex; align-items:center; justify-content:center; cursor:grab; overflow:hidden; }
  :global(.ssm-thumb img) { max-width:100%; max-height:100%; object-fit:contain; image-rendering:pixelated; }
  :global(.ssm-thumb.dragging) { opacity:0.4; }
  :global(.ssm-thumb.selected) { border-color:#5e6ad2; box-shadow:0 0 0 1px #5e6ad2; }
  :global(.ssm-thumb-x) { position:absolute; top:1px; right:1px; width:16px; height:16px; line-height:14px; text-align:center; border-radius:9999px; background:rgba(0,0,0,0.6); color:#fff; font-size:12px; cursor:pointer; }
</style>

<script>
  import { makeZip } from '../../lib/zip';

  interface Frame { name: string; img: HTMLImageElement; w: number; h: number; }
  interface Placement { name: string; x: number; y: number; w: number; h: number; }

  const dropEl = document.getElementById('ssm-drop')!;
  const filesEl = document.getElementById('ssm-files') as HTMLInputElement;
  const splitFileEl = document.getElementById('ssm-split-file') as HTMLInputElement;
  const splitColsEl = document.getElementById('ssm-split-cols') as HTMLInputElement;
  const splitRowsEl = document.getElementById('ssm-split-rows') as HTMLInputElement;
  const splitGoEl = document.getElementById('ssm-split-go')!;
  const framesWrap = document.getElementById('ssm-frames-wrap')!;
  const framesEl = document.getElementById('ssm-frames')!;
  const countEl = document.getElementById('ssm-count')!;
  const modeEl = document.getElementById('ssm-mode') as HTMLSelectElement;
  const colsWrap = document.getElementById('ssm-cols-wrap')!;
  const colsEl = document.getElementById('ssm-cols') as HTMLInputElement;
  const padEl = document.getElementById('ssm-pad') as HTMLInputElement;
  const bgEl = document.getElementById('ssm-bg') as HTMLInputElement;
  const transparentEl = document.getElementById('ssm-transparent') as HTMLInputElement;
  const canvas = document.getElementById('ssm-canvas') as HTMLCanvasElement;
  const animCanvas = document.getElementById('ssm-anim') as HTMLCanvasElement;
  const playBtn = document.getElementById('ssm-play')!;
  const fpsEl = document.getElementById('ssm-fps') as HTMLInputElement;
  const fpsLabel = document.getElementById('ssm-fps-label')!;
  const coordsEl = document.getElementById('ssm-coords')!;
  const err = document.getElementById('ssm-error')!;
  const ctx = canvas.getContext('2d')!;
  const animCtx = animCanvas.getContext('2d')!;

  const PNG_NAME = 'toolcities-sprite-sheet.png';

  let frames: Frame[] = [];
  let placements: Placement[] = [];

  function showError(msg: string) { err.textContent = msg; err.classList.remove('hidden'); }

  function loadFile(file: File): Promise<Frame> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => resolve({ name: file.name.replace(/\.[^.]+$/, ''), img, w: img.naturalWidth, h: img.naturalHeight });
        img.onerror = () => reject(new Error('Could not decode ' + file.name));
        img.src = reader.result as string;
      };
      reader.onerror = () => reject(new Error('Could not read ' + file.name));
      reader.readAsDataURL(file);
    });
  }

  async function addFiles(list: FileList | File[]) {
    err.classList.add('hidden');
    try {
      const loaded = await Promise.all(Array.from(list).map(loadFile));
      frames.push(...loaded);
      renderFrames();
      render();
    } catch (e) {
      showError((e as Error).message);
    }
  }

  // Slice an existing sheet into cols×rows equal cells, each becomes a frame.
  function splitSheet(file: File, cols: number, rows: number) {
    err.classList.add('hidden');
    const reader = new FileReader();
    reader.onload = () => {
      const src = new Image();
      src.onload = () => {
        const cw = Math.floor(src.naturalWidth / cols);
        const ch = Math.floor(src.naturalHeight / rows);
        if (cw < 1 || ch < 1) { showError('Columns/rows are larger than the sheet.'); return; }
        const base = file.name.replace(/\.[^.]+$/, '');
        let added = 0;
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            const cell = document.createElement('canvas');
            cell.width = cw; cell.height = ch;
            cell.getContext('2d')!.drawImage(src, c * cw, r * ch, cw, ch, 0, 0, cw, ch);
            const img = new Image();
            img.src = cell.toDataURL('image/png');
            frames.push({ name: `${base}_${added}`, img, w: cw, h: ch });
            added++;
          }
        }
        // Images decode async from data URLs; wait a tick then render.
        Promise.all(frames.slice(-added).map((f) => f.img.decode().catch(() => {}))).then(() => {
          renderFrames();
          render();
        });
      };
      src.onerror = () => showError('Could not decode ' + file.name);
      src.src = reader.result as string;
    };
    reader.onerror = () => showError('Could not read ' + file.name);
    reader.readAsDataURL(file);
  }

  // ---- Frame strip with drag-to-reorder + selection ----
  let dragIndex = -1;
  let selected = -1;
  const flipHBtn = document.getElementById('ssm-flip-h') as HTMLButtonElement;
  const flipVBtn = document.getElementById('ssm-flip-v') as HTMLButtonElement;
  const rotateBtn = document.getElementById('ssm-rotate') as HTMLButtonElement;
  const dupBtn = document.getElementById('ssm-duplicate') as HTMLButtonElement;

  function updateToolbar() {
    const on = selected >= 0 && selected < frames.length;
    [flipHBtn, flipVBtn, rotateBtn, dupBtn].forEach((b) => (b.disabled = !on));
  }

  function renderFrames() {
    framesEl.innerHTML = '';
    if (!frames.length) { framesWrap.classList.add('hidden'); framesWrap.classList.remove('flex'); selected = -1; updateToolbar(); return; }
    framesWrap.classList.remove('hidden'); framesWrap.classList.add('flex');
    countEl.textContent = `(${frames.length})`;
    if (selected >= frames.length) selected = -1;
    frames.forEach((f, i) => {
      const thumb = document.createElement('div');
      thumb.className = 'ssm-thumb' + (i === selected ? ' selected' : '');
      thumb.draggable = true;
      thumb.title = f.name;
      thumb.addEventListener('click', () => { selected = selected === i ? -1 : i; renderFrames(); });
      const im = document.createElement('img');
      im.src = f.img.src;
      thumb.appendChild(im);
      const x = document.createElement('span');
      x.className = 'ssm-thumb-x';
      x.textContent = '×';
      x.addEventListener('click', (ev) => {
        ev.stopPropagation();
        frames.splice(i, 1);
        if (selected === i) selected = -1; else if (selected > i) selected--;
        renderFrames(); render();
      });
      thumb.appendChild(x);
      thumb.addEventListener('dragstart', () => { dragIndex = i; thumb.classList.add('dragging'); });
      thumb.addEventListener('dragend', () => { dragIndex = -1; thumb.classList.remove('dragging'); });
      thumb.addEventListener('dragover', (ev) => ev.preventDefault());
      thumb.addEventListener('drop', (ev) => {
        ev.preventDefault();
        if (dragIndex < 0 || dragIndex === i) return;
        const [moved] = frames.splice(dragIndex, 1);
        frames.splice(i, 0, moved);
        selected = -1;
        renderFrames();
        render();
      });
      framesEl.appendChild(thumb);
    });
    updateToolbar();
  }

  // ---- Per-frame transforms (bake into a new image via canvas) ----
  function bakeTransform(f: Frame, kind: 'flipH' | 'flipV' | 'rotate'): Frame {
    const cv = document.createElement('canvas');
    const c = cv.getContext('2d')!;
    if (kind === 'rotate') {
      cv.width = f.h; cv.height = f.w;
      c.translate(f.h / 2, f.w / 2); c.rotate(Math.PI / 2); c.drawImage(f.img, -f.w / 2, -f.h / 2);
    } else {
      cv.width = f.w; cv.height = f.h;
      if (kind === 'flipH') { c.translate(f.w, 0); c.scale(-1, 1); }
      else { c.translate(0, f.h); c.scale(1, -1); }
      c.drawImage(f.img, 0, 0);
    }
    const img = new Image();
    img.src = cv.toDataURL('image/png');
    return { name: f.name, img, w: cv.width, h: cv.height };
  }

  async function applyTransform(kind: 'flipH' | 'flipV' | 'rotate') {
    if (selected < 0) return;
    const nf = bakeTransform(frames[selected], kind);
    await nf.img.decode().catch(() => {});
    frames[selected] = nf;
    renderFrames(); render();
  }

  flipHBtn.addEventListener('click', () => applyTransform('flipH'));
  flipVBtn.addEventListener('click', () => applyTransform('flipV'));
  rotateBtn.addEventListener('click', () => applyTransform('rotate'));
  dupBtn.addEventListener('click', () => {
    if (selected < 0) return;
    const f = frames[selected];
    frames.splice(selected + 1, 0, { name: f.name + '_copy', img: f.img, w: f.w, h: f.h });
    selected += 1;
    renderFrames(); render();
  });

  // ---- Layout: uniform grid ----
  function layoutGrid(pad: number, cols: number): { w: number; h: number; place: Placement[] } {
    const cellW = Math.max(...frames.map((f) => f.w));
    const cellH = Math.max(...frames.map((f) => f.h));
    const rows = Math.ceil(frames.length / cols);
    const place = frames.map((f, i) => {
      const c = i % cols, r = Math.floor(i / cols);
      return { name: f.name, x: pad + c * (cellW + pad), y: pad + r * (cellH + pad), w: f.w, h: f.h };
    });
    return { w: cols * cellW + (cols + 1) * pad, h: rows * cellH + (rows + 1) * pad, place };
  }

  // ---- Layout: growing binary-tree bin packer (Jake Gordon algorithm) ----
  // ponytail: binary-tree packer, tight enough; swap for MaxRects only if measured waste matters.
  interface Node { x: number; y: number; w: number; h: number; used?: boolean; right?: Node; down?: Node; }
  function layoutPacked(pad: number): { w: number; h: number; place: Placement[] } {
    // Each box reserves pad on its right & bottom; a leading pad offset covers left & top.
    const boxes = frames.map((f, i) => ({ i, w: f.w + pad, h: f.h + pad }));
    const order = boxes.slice().sort((a, b) => Math.max(b.w, b.h) - Math.max(a.w, a.h));
    let root: Node = { x: 0, y: 0, w: order[0].w, h: order[0].h };

    function findNode(node: Node | undefined, w: number, h: number): Node | null {
      if (!node) return null;
      if (node.used) return findNode(node.right, w, h) || findNode(node.down, w, h);
      if (w <= node.w && h <= node.h) return node;
      return null;
    }
    function splitNode(node: Node, w: number, h: number): Node {
      node.used = true;
      node.down = { x: node.x, y: node.y + h, w: node.w, h: node.h - h };
      node.right = { x: node.x + w, y: node.y, w: node.w - w, h };
      return node;
    }
    function growRight(w: number, h: number): Node | null {
      root = { used: true, x: 0, y: 0, w: root.w + w, h: root.h, down: root, right: { x: root.w, y: 0, w, h: root.h } };
      const n = findNode(root, w, h);
      return n ? splitNode(n, w, h) : null;
    }
    function growDown(w: number, h: number): Node | null {
      root = { used: true, x: 0, y: 0, w: root.w, h: root.h + h, right: root, down: { x: 0, y: root.h, w: root.w, h } };
      const n = findNode(root, w, h);
      return n ? splitNode(n, w, h) : null;
    }
    function growNode(w: number, h: number): Node | null {
      const canDown = w <= root.w, canRight = h <= root.h;
      const shouldRight = canRight && root.h >= root.w + w;
      const shouldDown = canDown && root.w >= root.h + h;
      if (shouldRight) return growRight(w, h);
      if (shouldDown) return growDown(w, h);
      if (canRight) return growRight(w, h);
      if (canDown) return growDown(w, h);
      return null;
    }

    const fits: Record<number, Node> = {};
    for (const box of order) {
      const node = findNode(root, box.w, box.h);
      const fit = node ? splitNode(node, box.w, box.h) : growNode(box.w, box.h);
      if (fit) fits[box.i] = fit;
    }
    const place = frames.map((f, i) => {
      const n = fits[i];
      return { name: f.name, x: (n ? n.x : 0) + pad, y: (n ? n.y : 0) + pad, w: f.w, h: f.h };
    });
    return { w: root.w + pad, h: root.h + pad, place };
  }

  function render() {
    err.classList.add('hidden');
    colsWrap.style.display = modeEl.value === 'grid' ? '' : 'none';
    if (!frames.length) {
      canvas.width = 1; canvas.height = 1;
      placements = [];
      coordsEl.textContent = 'Add frames to see the atlas.';
      resetAnim();
      return;
    }
    const pad = Math.max(0, Number(padEl.value) || 0);
    const cols = Math.max(1, Number(colsEl.value) || 1);
    const { w, h, place } = modeEl.value === 'packed' ? layoutPacked(pad) : layoutGrid(pad, cols);
    placements = place;

    canvas.width = w; canvas.height = h;
    ctx.clearRect(0, 0, w, h);
    if (!transparentEl.checked) { ctx.fillStyle = bgEl.value; ctx.fillRect(0, 0, w, h); }
    frames.forEach((f, i) => { const p = placements[i]; ctx.drawImage(f.img, p.x, p.y); });

    coordsEl.textContent = JSON.stringify(buildAtlas(), null, 2);
    resetAnim();
  }

  // ---- Exports ----
  function buildAtlas() {
    const frameMap: Record<string, unknown> = {};
    placements.forEach((p) => {
      frameMap[p.name] = {
        frame: { x: p.x, y: p.y, w: p.w, h: p.h },
        rotated: false, trimmed: false,
        spriteSourceSize: { x: 0, y: 0, w: p.w, h: p.h },
        sourceSize: { w: p.w, h: p.h },
      };
    });
    return { frames: frameMap, meta: { app: 'toolcities.com sprite sheet maker', image: PNG_NAME, format: 'RGBA8888', size: { w: canvas.width, h: canvas.height }, scale: '1' } };
  }

  function buildCss() {
    const safe = (n: string) => n.replace(/[^a-z0-9_-]/gi, '-');
    return placements.map((p) =>
      `.sprite-${safe(p.name)} {\n  background: url('${PNG_NAME}') -${p.x}px -${p.y}px;\n  width: ${p.w}px;\n  height: ${p.h}px;\n}`
    ).join('\n\n');
  }

  function canvasBlob(): Promise<Blob> {
    return new Promise((resolve, reject) =>
      canvas.toBlob((b) => (b ? resolve(b) : reject(new Error('Could not render PNG.'))), 'image/png'));
  }

  function downloadBlob(blob: Blob, name: string) {
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.download = name; link.href = url; link.click();
    URL.revokeObjectURL(url);
  }

  function needFrames(): boolean {
    if (frames.length) return true;
    showError('Add at least one frame first.');
    return false;
  }

  document.getElementById('ssm-dl-png')!.addEventListener('click', async () => {
    if (!needFrames()) return;
    downloadBlob(await canvasBlob(), PNG_NAME);
  });
  document.getElementById('ssm-dl-json')!.addEventListener('click', () => {
    if (!needFrames()) return;
    downloadBlob(new Blob([JSON.stringify(buildAtlas(), null, 2)], { type: 'application/json' }), 'toolcities-sprite-sheet.json');
  });
  document.getElementById('ssm-dl-css')!.addEventListener('click', () => {
    if (!needFrames()) return;
    downloadBlob(new Blob([buildCss()], { type: 'text/css' }), 'toolcities-sprite-sheet.css');
  });
  document.getElementById('ssm-dl-zip')!.addEventListener('click', async () => {
    if (!needFrames()) return;
    const png = new Uint8Array(await (await canvasBlob()).arrayBuffer());
    const enc = new TextEncoder();
    const zip = makeZip([
      { name: PNG_NAME, data: png },
      { name: 'toolcities-sprite-sheet.json', data: enc.encode(JSON.stringify(buildAtlas(), null, 2)) },
      { name: 'toolcities-sprite-sheet.css', data: enc.encode(buildCss()) },
    ]);
    downloadBlob(zip, 'toolcities-sprite-sheet.zip');
  });

  // ---- Animation preview ----
  let playing = false;
  let animRAF = 0;
  let animIndex = 0;
  let lastTs = 0;

  function resetAnim() {
    stopAnim();
    animIndex = 0;
    drawAnimFrame();
  }
  function drawAnimFrame() {
    if (!frames.length) { animCanvas.width = 1; animCanvas.height = 1; return; }
    const f = frames[animIndex % frames.length];
    const max = 120;
    const scale = Math.min(1, max / Math.max(f.w, f.h));
    animCanvas.width = Math.max(1, Math.round(f.w * scale));
    animCanvas.height = Math.max(1, Math.round(f.h * scale));
    animCtx.clearRect(0, 0, animCanvas.width, animCanvas.height);
    animCtx.imageSmoothingEnabled = false;
    animCtx.drawImage(f.img, 0, 0, animCanvas.width, animCanvas.height);
  }
  function tick(ts: number) {
    if (!playing) return;
    const interval = 1000 / Math.max(1, Number(fpsEl.value) || 1);
    if (ts - lastTs >= interval) {
      lastTs = ts;
      animIndex = (animIndex + 1) % frames.length;
      drawAnimFrame();
    }
    animRAF = requestAnimationFrame(tick);
  }
  function startAnim() {
    if (!frames.length) return;
    playing = true; lastTs = 0; playBtn.textContent = 'Pause';
    animRAF = requestAnimationFrame(tick);
  }
  function stopAnim() {
    playing = false; playBtn.textContent = 'Play';
    if (animRAF) cancelAnimationFrame(animRAF);
  }
  playBtn.addEventListener('click', () => (playing ? stopAnim() : startAnim()));
  fpsEl.addEventListener('input', () => { fpsLabel.textContent = `${fpsEl.value} fps`; });

  // ---- Wiring ----
  filesEl.addEventListener('change', () => { if (filesEl.files?.length) addFiles(filesEl.files); });
  ['dragover', 'dragenter'].forEach((e) => dropEl.addEventListener(e, (ev) => { ev.preventDefault(); dropEl.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => dropEl.addEventListener(e, () => dropEl.classList.remove('bg-surface-2')));
  dropEl.addEventListener('drop', (ev) => {
    ev.preventDefault();
    const files = (ev as DragEvent).dataTransfer?.files;
    if (files?.length) addFiles(files);
  });

  splitGoEl.addEventListener('click', () => {
    const file = splitFileEl.files?.[0];
    if (!file) { showError('Choose a sheet to split first.'); return; }
    splitSheet(file, Math.max(1, Number(splitColsEl.value) || 1), Math.max(1, Number(splitRowsEl.value) || 1));
  });

  [modeEl, colsEl, padEl, bgEl, transparentEl].forEach((el) => el.addEventListener('input', render));

  render();
</script>

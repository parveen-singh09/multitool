---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ssn-generator">
  <div class="flex flex-col gap-4">
    <div class="panel flex items-start gap-3 p-4">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-ink-subtle" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20ZM12 8v5M12 16h.01"/></svg>
      <p class="text-[13px] leading-relaxed text-ink-subtle">These use the <strong class="text-ink">900–999 area range, which the SSA never issues</strong>, so they match the SSN format but can never belong to a real person. For form testing only — never use them to impersonate anyone.</p>
    </div>
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="sn-count" type="number" min="1" max="1000" value="10" class="field w-28" />
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="sn-dash" type="checkbox" class="accent-[#5e6ad2]" checked /> Include dashes
      </label>
      <button id="sn-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="sn-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <textarea id="sn-out" class="field min-h-64 resize-y font-mono text-[13px]" readonly aria-label="Generated SSNs"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SSN generator creates US Social Security number-formatted values
      for testing forms, parsers and validation. Crucially, it draws the area
      number from the 900–999 range that the Social Security Administration has
      never assigned and never will, so the results can't collide with a real
      person's SSN. Everything is generated locally in your browser and never
      uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { ssn } from '../../lib/fakegen';

  const $ = (id: string) => document.getElementById(id)!;
  const countEl = $('sn-count') as HTMLInputElement;
  const dashEl = $('sn-dash') as HTMLInputElement;
  const out = $('sn-out') as HTMLTextAreaElement;

  function generate() {
    const n = Math.max(1, Math.min(1000, Number(countEl.value) || 1));
    const list: string[] = [];
    for (let i = 0; i < n; i++) {
      const s = ssn();
      list.push(dashEl.checked ? s : s.replace(/-/g, ''));
    }
    out.value = list.join('\n');
  }

  [countEl, dashEl].forEach((el) => el.addEventListener('input', generate));
  $('sn-gen').addEventListener('click', generate);
  $('sn-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

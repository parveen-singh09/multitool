---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ColorFormats from '../../components/ColorFormats.astro';
---

<ToolLayout slug="rgb-to-hex">
  <ColorFormats focus="hex" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free RGB to HEX converter turns red, green and blue values into a
      hex color code instantly. Enter an <code>rgb(94, 106, 210)</code> value
      (or use the picker) and copy the matching <code>#5e6ad2</code> hex string
      for CSS, HTML or design tools. It also shows HSL, HSV and CMYK, plus the
      nearest named color. All conversion runs locally in your browser.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { DIALECTS } from '../../lib/sqlvalidate';
---

<ToolLayout slug="sql-validator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Dialect
        <select id="sv-dialect" class="field w-48">
          {DIALECTS.map((d) => <option value={d.value}>{d.label}</option>)}
        </select>
      </label>
      <div id="sv-status" class="hidden flex-1 rounded-md border px-3 py-2 text-sm" role="status"></div>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">SQL to validate
      <div class="hl-edit field p-0" style="height:24rem;resize:vertical;overflow:hidden">
        <pre class="hl-block" aria-hidden="true"><code id="sv-in-hl" class="hljs" style="background:transparent"></code></pre>
        <textarea id="sv-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder="Paste SQL here, e.g. SELECT id, name FROM users WHERE age > 21;"></textarea>
      </div>
    </label>

    <ul id="sv-issues" class="hidden flex-col gap-2"></ul>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SQL validator checks your query against a real per-dialect
      parser for 19 databases — MySQL, PostgreSQL, SQL Server (T-SQL), Oracle
      (PL/SQL), SQLite, BigQuery, Snowflake, Redshift, Spark, Trino, DuckDB,
      ClickHouse and more. Pick your dialect and it flags genuine syntax errors
      with line numbers, then layers on structural lint notes: unbalanced
      parentheses, unterminated strings or quoted identifiers, trailing commas,
      a SELECT with no FROM, misplaced clause ordering (e.g. WHERE after GROUP
      BY), and unclosed block comments. It validates well-formedness, not table
      or column existence, so it won't run your query — and because everything
      runs in your browser, nothing is ever uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { wireInput } from '../../lib/highlight';
  import { validate, type Issue } from '../../lib/sqlvalidate';
  import type { SqlLanguage } from 'sql-formatter';

  const input = document.getElementById('sv-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('sv-in-hl')!;
  const status = document.getElementById('sv-status')!;
  const issuesEl = document.getElementById('sv-issues')!;
  const dialect = document.getElementById('sv-dialect') as HTMLSelectElement;

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  const esc = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  function render(issues: Issue[]) {
    issuesEl.classList.remove('hidden');
    issuesEl.innerHTML = issues
      .map((x) => {
        const color = x.level === 'error' ? '#e08585' : '#e0c185';
        const label = x.level === 'error' ? 'Error' : 'Note';
        const loc = x.line ? `<span class="shrink-0 text-ink-subtle">line ${x.line}</span>` : '';
        return `<li class="panel flex items-start gap-3 p-3 text-[13px]">
          <span class="mt-0.5 shrink-0 rounded-xs px-1.5 py-0.5 text-[11px] font-medium" style="color:${color};border:1px solid ${color}55">${label}</span>
          <span class="flex-1 text-ink-muted">${esc(x.msg)}</span>
          ${loc}
        </li>`;
      })
      .join('');
  }

  function run() {
    issuesEl.classList.add('hidden');
    issuesEl.innerHTML = '';
    const text = input.value;
    if (!text.trim()) { status.classList.add('hidden'); return; }

    const { issues, statementCount } = validate(text, dialect.value as SqlLanguage);
    const errors = issues.filter((x) => x.level === 'error');
    const stmts = `${statementCount} statement${statementCount === 1 ? '' : 's'}`;

    if (issues.length === 0) {
      showStatus(`Valid ✓ — ${stmts}, no problems found.`, true);
      return;
    }
    if (errors.length === 0) {
      showStatus(`Well-formed — ${stmts}, ${issues.length} note${issues.length === 1 ? '' : 's'} below.`, true);
    } else {
      showStatus(`${errors.length} problem${errors.length === 1 ? '' : 's'} found.`, false);
    }
    render(issues);
  }

  const refresh = wireInput(input, inHl, () => 'sql', () => run());
  dialect.addEventListener('change', () => run());
  input.value = 'SELECT id, name, FROM users WHERE age > 21';
  refresh();
  run();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';

const templates = [
  { id: 'classic', name: 'Classic', desc: 'Diagonal gradient, centered' },
  { id: 'split', name: 'Split', desc: 'Two-tone side blocks' },
  { id: 'neon', name: 'Neon', desc: 'Glow text on grid' },
  { id: 'minimal', name: 'Minimal', desc: 'Left text, accent line' },
  { id: 'mesh', name: 'Mesh', desc: 'Soft gradient blobs' },
  { id: 'corporate', name: 'Corporate', desc: 'Accent bar, stacked' },
  { id: 'promo', name: 'Promo', desc: 'Badge + bold headline' },
  { id: 'stripes', name: 'Stripes', desc: 'Diagonal bands' },
  { id: 'spotlight', name: 'Spotlight', desc: 'Radial vignette' },
  { id: 'outline', name: 'Outline', desc: 'Hollow stroke type' },
  { id: 'photo', name: 'Photo', desc: 'Your image + overlay' },
];
---

<ToolLayout slug="banner-generator">
  <div class="flex flex-col gap-6">

    <div class="flex flex-col gap-3">
      <span class="eyebrow text-primary-hover">Template</span>
      <div id="bn-templates" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        {templates.map((t, i) => (
          <button
            type="button"
            data-tpl={t.id}
            class="tpl-card panel panel-lift group flex flex-col overflow-hidden p-0 text-left transition-colors"
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            <canvas class="tpl-thumb block w-full" width="240" height="80"></canvas>
            <span class="flex flex-col gap-0.5 px-2.5 py-2">
              <span class="font-display text-[13px] font-medium text-ink">{t.name}</span>
              <span class="text-[11px] leading-snug text-ink-tertiary">{t.desc}</span>
            </span>
          </button>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">

      <div class="flex flex-col gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Size preset
          <select id="bn-size" class="field">
            <option value="1500,500">Twitter/X header (1500×500)</option>
            <option value="1200,630">Open Graph / Facebook (1200×630)</option>
            <option value="1584,396">LinkedIn cover (1584×396)</option>
            <option value="2560,1440">YouTube channel art (2560×1440)</option>
            <option value="1280,720">Web banner (1280×720)</option>
            <option value="600,200">Email header (600×200)</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Heading
          <input id="bn-title" class="field" value="Your Brand" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Subtext
          <input id="bn-sub" class="field" value="Tagline goes here" />
        </label>
        <div class="grid grid-cols-3 gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Color A
            <input id="bn-c1" type="color" value="#5e6ad2" class="field h-10 cursor-pointer p-1" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Color B
            <input id="bn-c2" type="color" value="#010102" class="field h-10 cursor-pointer p-1" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Text
            <input id="bn-fg" type="color" value="#ffffff" class="field h-10 cursor-pointer p-1" />
          </label>
        </div>

        <div class="flex flex-col gap-2 rounded-md border border-hairline bg-surface-1 p-3">
          <div class="flex items-center justify-between gap-2">
            <span class="text-sm text-ink-subtle">Background image</span>
            <button id="bn-img-clear" type="button" class="btn btn-tertiary hidden !min-h-0 !px-2 !py-1 text-xs">Remove</button>
          </div>
          <input id="bn-img" type="file" accept="image/*"
            class="field cursor-pointer text-sm file:mr-3 file:cursor-pointer file:rounded-sm file:border-0 file:bg-surface-3 file:px-3 file:py-1.5 file:text-sm file:text-ink" />
          <label class="mt-1 flex flex-col gap-1 text-sm text-ink-subtle">
            <span class="flex items-center justify-between">Overlay <span id="bn-ovl-val" class="text-ink-tertiary">45%</span></span>
            <input id="bn-ovl" type="range" min="0" max="90" value="45" class="w-full cursor-pointer accent-[var(--color-primary)]" />
          </label>
          <p class="text-xs leading-snug text-ink-tertiary">Uploading switches to the Photo template. Images stay in your browser.</p>
        </div>
      </div>

      <div class="flex flex-col items-center gap-4">
        <div class="flex w-full items-center justify-center overflow-auto rounded-lg border border-hairline bg-surface-2 p-4">
          <canvas id="bn-canvas" class="max-w-full"></canvas>
        </div>
        <button id="bn-dl" class="btn btn-primary">Download PNG</button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free banner generator creates social media and web banners at the exact
      preset sizes each platform expects — Twitter/X, Facebook, LinkedIn, YouTube,
      email headers and a general web banner. Pick from ten design templates,
      from a clean diagonal gradient to neon gaming glow, two-tone splits,
      corporate accent bars and bold promo badges.
    </p>
    <p>
      Every template is a starting point: change the heading and subtext, then
      recolor it with your brand colors. The preview and template thumbnails
      redraw live, and downloads are pixel-perfect PNGs at full resolution.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const canvas = $('bn-canvas') as HTMLCanvasElement;

  type Opts = { w: number; h: number; c1: string; c2: string; fg: string; title: string; sub: string; img: HTMLImageElement | null; ovl: number };
  let current = 'classic';
  let bgImage: HTMLImageElement | null = null;
  let imgUrl: string | null = null;

  function rgba(hex: string, a: number) {
    const h = hex.replace('#', '');
    const n = h.length === 3 ? h.split('').map((c) => c + c).join('') : h;
    const r = parseInt(n.slice(0, 2), 16), g = parseInt(n.slice(2, 4), 16), b = parseInt(n.slice(4, 6), 16);
    return `rgba(${r},${g},${b},${a})`;
  }
  function roundRect(ctx: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
  }
  // draw an image cropped to cover the whole w×h box (like CSS object-fit: cover)
  function drawCover(ctx: CanvasRenderingContext2D, img: HTMLImageElement, w: number, h: number) {
    const ir = img.width / img.height, br = w / h;
    let dw = w, dh = h, dx = 0, dy = 0;
    if (ir > br) { dw = h * ir; dx = (w - dw) / 2; } else { dh = w / ir; dy = (h - dh) / 2; }
    ctx.drawImage(img, dx, dy, dw, dh);
  }
  // shrink font until the text fits maxWidth
  function fitFont(ctx: CanvasRenderingContext2D, text: string, weight: number, base: number, maxWidth: number, family = 'Inter, system-ui, sans-serif') {
    let size = base;
    do {
      ctx.font = `${weight} ${size}px ${family}`;
      if (ctx.measureText(text).width <= maxWidth || size <= 10) break;
      size -= Math.max(1, Math.round(size * 0.04));
    } while (size > 10);
    return size;
  }

  // ---- templates --------------------------------------------------------
  const TEMPLATES: Record<string, (ctx: CanvasRenderingContext2D, o: Opts) => void> = {
    classic(ctx, o) {
      const g = ctx.createLinearGradient(0, 0, o.w, o.h);
      g.addColorStop(0, o.c1); g.addColorStop(1, o.c2);
      ctx.fillStyle = g; ctx.fillRect(0, 0, o.w, o.h);
      ctx.fillStyle = o.fg; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      const ts = fitFont(ctx, o.title, 700, o.h * 0.22, o.w * 0.86);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      ctx.fillText(o.title, o.w / 2, o.h / 2 - (o.sub ? ts * 0.35 : 0));
      if (o.sub) {
        ctx.font = `400 ${ts * 0.42}px Inter, system-ui, sans-serif`;
        ctx.globalAlpha = 0.9; ctx.fillText(o.sub, o.w / 2, o.h / 2 + ts * 0.55); ctx.globalAlpha = 1;
      }
    },

    split(ctx, o) {
      const cut = o.w * 0.62;
      ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
      ctx.fillStyle = o.c1; ctx.fillRect(cut, 0, o.w - cut, o.h);
      // diagonal seam
      ctx.fillStyle = o.c1; ctx.beginPath();
      ctx.moveTo(cut - o.h * 0.18, 0); ctx.lineTo(cut, 0); ctx.lineTo(cut, o.h); ctx.lineTo(cut - o.h * 0.18, o.h); ctx.closePath(); ctx.fill();
      ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      const pad = o.w * 0.06;
      ctx.fillStyle = o.fg;
      const ts = fitFont(ctx, o.title, 700, o.h * 0.24, cut - pad * 1.6);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      ctx.fillText(o.title, pad, o.h / 2 - (o.sub ? ts * 0.35 : 0));
      if (o.sub) {
        ctx.font = `400 ${ts * 0.42}px Inter, system-ui, sans-serif`;
        ctx.globalAlpha = 0.85; ctx.fillText(o.sub, pad, o.h / 2 + ts * 0.55); ctx.globalAlpha = 1;
      }
    },

    neon(ctx, o) {
      ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
      // grid
      ctx.strokeStyle = rgba(o.c1, 0.18); ctx.lineWidth = Math.max(1, o.h * 0.004);
      const step = o.h * 0.16;
      for (let x = 0; x <= o.w; x += step) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, o.h); ctx.stroke(); }
      for (let y = 0; y <= o.h; y += step) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(o.w, y); ctx.stroke(); }
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      const ts = fitFont(ctx, o.title, 700, o.h * 0.26, o.w * 0.8);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      ctx.shadowColor = o.c1; ctx.shadowBlur = ts * 0.5;
      ctx.fillStyle = o.fg;
      ctx.fillText(o.title, o.w / 2, o.h / 2 - (o.sub ? ts * 0.32 : 0));
      ctx.shadowBlur = 0;
      if (o.sub) {
        ctx.font = `500 ${ts * 0.38}px Inter, system-ui, sans-serif`;
        ctx.fillStyle = o.c1; ctx.fillText(o.sub.toUpperCase(), o.w / 2, o.h / 2 + ts * 0.5);
      }
    },

    minimal(ctx, o) {
      ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
      const pad = o.w * 0.07;
      // accent line
      ctx.fillStyle = o.c1; ctx.fillRect(pad, o.h * 0.5 - o.h * 0.16, o.h * 0.02, o.h * 0.32);
      const tx = pad + o.h * 0.09;
      ctx.textAlign = 'left'; ctx.textBaseline = 'middle';
      ctx.fillStyle = o.fg;
      const ts = fitFont(ctx, o.title, 600, o.h * 0.2, o.w - tx - pad);
      ctx.font = `600 ${ts}px Inter, system-ui, sans-serif`;
      ctx.fillText(o.title, tx, o.h / 2 - (o.sub ? ts * 0.38 : 0));
      if (o.sub) {
        ctx.font = `400 ${ts * 0.44}px Inter, system-ui, sans-serif`;
        ctx.globalAlpha = 0.6; ctx.fillText(o.sub, tx, o.h / 2 + ts * 0.55); ctx.globalAlpha = 1;
      }
    },

    mesh(ctx, o) {
      ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
      const blob = (cx: number, cy: number, r: number, col: string, a: number) => {
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
        g.addColorStop(0, rgba(col, a)); g.addColorStop(1, rgba(col, 0));
        ctx.fillStyle = g; ctx.fillRect(0, 0, o.w, o.h);
      };
      blob(o.w * 0.2, o.h * 0.25, o.h * 0.9, o.c1, 0.85);
      blob(o.w * 0.85, o.h * 0.8, o.h * 0.8, o.c1, 0.5);
      blob(o.w * 0.6, o.h * 0.1, o.h * 0.7, o.fg, 0.12);
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillStyle = o.fg;
      const ts = fitFont(ctx, o.title, 700, o.h * 0.22, o.w * 0.84);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      ctx.fillText(o.title, o.w / 2, o.h / 2 - (o.sub ? ts * 0.35 : 0));
      if (o.sub) {
        ctx.font = `400 ${ts * 0.42}px Inter, system-ui, sans-serif`;
        ctx.globalAlpha = 0.9; ctx.fillText(o.sub, o.w / 2, o.h / 2 + ts * 0.55); ctx.globalAlpha = 1;
      }
    },

    corporate(ctx, o) {
      ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
      const pad = o.w * 0.06;
      ctx.fillStyle = o.c1; ctx.fillRect(0, 0, o.h * 0.05, o.h);
      ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
      ctx.fillStyle = o.fg;
      const ts = fitFont(ctx, o.title, 700, o.h * 0.2, o.w - pad * 2);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      const cy = o.h / 2;
      ctx.fillText(o.title, pad, cy + ts * 0.1);
      if (o.sub) {
        ctx.font = `400 ${ts * 0.4}px Inter, system-ui, sans-serif`;
        ctx.fillStyle = o.c1; ctx.fillText(o.sub, pad, cy + ts * 0.75);
      }
    },

    promo(ctx, o) {
      const g = ctx.createLinearGradient(0, 0, 0, o.h);
      g.addColorStop(0, o.c2); g.addColorStop(1, rgba(o.c1, 0.35));
      ctx.fillStyle = g; ctx.fillRect(0, 0, o.w, o.h);
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      // badge for subtext
      if (o.sub) {
        ctx.font = `600 ${o.h * 0.09}px Inter, system-ui, sans-serif`;
        const bw = ctx.measureText(o.sub.toUpperCase()).width + o.h * 0.16;
        const bh = o.h * 0.18, bx = (o.w - bw) / 2, by = o.h * 0.16;
        ctx.fillStyle = o.c1; roundRect(ctx, bx, by, bw, bh, bh / 2); ctx.fill();
        ctx.fillStyle = o.fg; ctx.fillText(o.sub.toUpperCase(), o.w / 2, by + bh / 2);
      }
      ctx.fillStyle = o.fg;
      const ty = o.sub ? o.h * 0.6 : o.h * 0.5;
      const ts = fitFont(ctx, o.title, 800, o.h * 0.3, o.w * 0.88);
      ctx.font = `800 ${ts}px Inter, system-ui, sans-serif`;
      ctx.fillText(o.title, o.w / 2, ty);
    },

    stripes(ctx, o) {
      ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
      ctx.save();
      ctx.fillStyle = rgba(o.c1, 0.9);
      const bw = o.h * 0.5;
      for (let x = -o.h; x < o.w + o.h; x += bw * 2) {
        ctx.beginPath();
        ctx.moveTo(x, 0); ctx.lineTo(x + bw, 0); ctx.lineTo(x + bw - o.h, o.h); ctx.lineTo(x - o.h, o.h);
        ctx.closePath(); ctx.fill();
      }
      ctx.restore();
      // center plate for legibility
      ctx.fillStyle = rgba(o.c2, 0.72);
      const ph = o.h * 0.5, pw = o.w * 0.7;
      roundRect(ctx, (o.w - pw) / 2, (o.h - ph) / 2, pw, ph, o.h * 0.06); ctx.fill();
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillStyle = o.fg;
      const ts = fitFont(ctx, o.title, 700, o.h * 0.2, pw * 0.9);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      ctx.fillText(o.title, o.w / 2, o.h / 2 - (o.sub ? ts * 0.33 : 0));
      if (o.sub) {
        ctx.font = `400 ${ts * 0.42}px Inter, system-ui, sans-serif`;
        ctx.globalAlpha = 0.9; ctx.fillText(o.sub, o.w / 2, o.h / 2 + ts * 0.52); ctx.globalAlpha = 1;
      }
    },

    spotlight(ctx, o) {
      ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
      const g = ctx.createRadialGradient(o.w / 2, o.h / 2, 0, o.w / 2, o.h / 2, o.w * 0.6);
      g.addColorStop(0, rgba(o.c1, 0.55)); g.addColorStop(1, rgba(o.c1, 0));
      ctx.fillStyle = g; ctx.fillRect(0, 0, o.w, o.h);
      // vignette
      const v = ctx.createRadialGradient(o.w / 2, o.h / 2, o.h * 0.2, o.w / 2, o.h / 2, o.w * 0.7);
      v.addColorStop(0, rgba(o.c2, 0)); v.addColorStop(1, rgba(o.c2, 0.85));
      ctx.fillStyle = v; ctx.fillRect(0, 0, o.w, o.h);
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillStyle = o.fg;
      const ts = fitFont(ctx, o.title, 700, o.h * 0.24, o.w * 0.82);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      ctx.fillText(o.title, o.w / 2, o.h / 2 - (o.sub ? ts * 0.35 : 0));
      if (o.sub) {
        ctx.font = `300 ${ts * 0.4}px Inter, system-ui, sans-serif`;
        ctx.globalAlpha = 0.8; ctx.fillText(o.sub, o.w / 2, o.h / 2 + ts * 0.55); ctx.globalAlpha = 1;
      }
    },

    outline(ctx, o) {
      const g = ctx.createLinearGradient(0, 0, o.w, o.h);
      g.addColorStop(0, o.c1); g.addColorStop(1, o.c2);
      ctx.fillStyle = g; ctx.fillRect(0, 0, o.w, o.h);
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      const ts = fitFont(ctx, o.title, 800, o.h * 0.34, o.w * 0.86);
      ctx.font = `800 ${ts}px Inter, system-ui, sans-serif`;
      ctx.lineWidth = Math.max(2, ts * 0.03);
      ctx.strokeStyle = o.fg;
      ctx.strokeText(o.title, o.w / 2, o.h / 2 - (o.sub ? ts * 0.3 : 0));
      if (o.sub) {
        ctx.font = `500 ${ts * 0.3}px Inter, system-ui, sans-serif`;
        ctx.fillStyle = o.fg; ctx.globalAlpha = 0.9;
        ctx.fillText(o.sub.toUpperCase(), o.w / 2, o.h / 2 + ts * 0.5); ctx.globalAlpha = 1;
      }
    },

    photo(ctx, o) {
      if (o.img) {
        drawCover(ctx, o.img, o.w, o.h);
      } else {
        // placeholder when no image uploaded yet
        ctx.fillStyle = o.c2; ctx.fillRect(0, 0, o.w, o.h);
        ctx.fillStyle = rgba(o.c1, 0.25);
        ctx.font = `500 ${o.h * 0.09}px Inter, system-ui, sans-serif`;
        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        ctx.fillText('Upload an image →', o.w / 2, o.h / 2);
      }
      // bottom-up dark scrim for legibility, strength from the overlay slider
      if (o.ovl > 0) {
        const g = ctx.createLinearGradient(0, o.h, 0, 0);
        g.addColorStop(0, rgba(o.c2, o.ovl)); g.addColorStop(0.7, rgba(o.c2, o.ovl * 0.55)); g.addColorStop(1, rgba(o.c2, o.ovl * 0.15));
        ctx.fillStyle = g; ctx.fillRect(0, 0, o.w, o.h);
      }
      ctx.textAlign = 'left'; ctx.textBaseline = 'alphabetic';
      const pad = o.w * 0.06;
      ctx.fillStyle = o.fg;
      const ts = fitFont(ctx, o.title, 700, o.h * 0.2, o.w - pad * 2);
      ctx.font = `700 ${ts}px Inter, system-ui, sans-serif`;
      ctx.shadowColor = rgba(o.c2, 0.6); ctx.shadowBlur = ts * 0.12; ctx.shadowOffsetY = ts * 0.03;
      const baseY = o.sub ? o.h - o.h * 0.14 : o.h - o.h * 0.12;
      ctx.fillText(o.title, pad, baseY);
      if (o.sub) {
        ctx.font = `400 ${ts * 0.44}px Inter, system-ui, sans-serif`;
        ctx.globalAlpha = 0.92; ctx.fillText(o.sub, pad, baseY + ts * 0.62); ctx.globalAlpha = 1;
      }
      ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
    },
  };

  function opts(w: number, h: number): Opts {
    return {
      w, h,
      c1: ($('bn-c1') as HTMLInputElement).value,
      c2: ($('bn-c2') as HTMLInputElement).value,
      fg: ($('bn-fg') as HTMLInputElement).value,
      title: ($('bn-title') as HTMLInputElement).value,
      sub: ($('bn-sub') as HTMLInputElement).value,
      img: bgImage,
      ovl: Number(($('bn-ovl') as HTMLInputElement).value) / 100,
    };
  }

  function draw() {
    const [w, h] = ($('bn-size') as HTMLSelectElement).value.split(',').map(Number);
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d')!;
    (TEMPLATES[current] || TEMPLATES.classic)(ctx, opts(w, h));
    drawThumbs();
  }

  function drawThumbs() {
    document.querySelectorAll<HTMLCanvasElement>('.tpl-thumb').forEach((cv) => {
      const id = (cv.closest('[data-tpl]') as HTMLElement).dataset.tpl!;
      const ctx = cv.getContext('2d')!;
      ctx.clearRect(0, 0, cv.width, cv.height);
      (TEMPLATES[id] || TEMPLATES.classic)(ctx, opts(cv.width, cv.height));
    });
  }

  // template selection
  document.querySelectorAll<HTMLElement>('.tpl-card').forEach((card) => {
    card.addEventListener('click', () => {
      current = card.dataset.tpl!;
      document.querySelectorAll<HTMLElement>('.tpl-card').forEach((c) =>
        c.setAttribute('aria-pressed', c === card ? 'true' : 'false'));
      draw();
    });
  });

  ['bn-size', 'bn-title', 'bn-sub', 'bn-c1', 'bn-c2', 'bn-fg', 'bn-ovl'].forEach((id) => $(id).addEventListener('input', draw));

  // overlay slider readout
  $('bn-ovl').addEventListener('input', () => {
    $('bn-ovl-val').textContent = ($('bn-ovl') as HTMLInputElement).value + '%';
  });

  // image upload → switch to Photo template
  const imgInput = $('bn-img') as HTMLInputElement;
  imgInput.addEventListener('change', () => {
    const file = imgInput.files?.[0];
    if (!file) return;
    if (imgUrl) URL.revokeObjectURL(imgUrl);
    imgUrl = URL.createObjectURL(file);
    const img = new Image();
    img.onload = () => {
      bgImage = img;
      // select the Photo template card
      current = 'photo';
      document.querySelectorAll<HTMLElement>('.tpl-card').forEach((c) =>
        c.setAttribute('aria-pressed', c.dataset.tpl === 'photo' ? 'true' : 'false'));
      $('bn-img-clear').classList.remove('hidden');
      draw();
    };
    img.src = imgUrl;
  });

  $('bn-img-clear').addEventListener('click', () => {
    bgImage = null;
    if (imgUrl) { URL.revokeObjectURL(imgUrl); imgUrl = null; }
    imgInput.value = '';
    $('bn-img-clear').classList.add('hidden');
    draw();
  });

  $('bn-dl').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = `banner-${current}.png`; a.click();
  });

  draw();
</script>


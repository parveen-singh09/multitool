---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="slot-machine-simulator">
  <div class="flex flex-col gap-5">
    <!-- Stat tiles -->
    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel panel-lift p-3"><div id="sm-credits" class="font-display text-xl font-semibold text-primary-hover">1,000</div><div class="mt-1 text-[13px] text-ink-subtle">Credits</div></div>
      <div class="panel p-3"><div id="sm-lastwin" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Last win</div></div>
      <div class="panel p-3"><div id="sm-spins" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Spins</div></div>
      <div class="panel p-3"><div id="sm-rtp" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Return</div></div>
    </div>

    <!-- Reels -->
    <div class="panel panel-lift relative p-4 sm:p-6">
      <div id="sm-fsbanner" class="sm-fsbanner" hidden></div>
      <div id="sm-grid" class="sm-grid" aria-label="Slot reels"></div>
      <div id="sm-winline" class="sm-winline"></div>
    </div>

    <p id="sm-msg" class="min-h-5 text-center text-[13px] text-ink-subtle" role="status" aria-live="polite">Set your bet and hit Spin.</p>

    <!-- Controls -->
    <div class="flex flex-wrap items-end justify-center gap-3">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">Bet per line
        <div class="flex items-center gap-1">
          <button id="sm-bet-down" class="btn btn-secondary px-3" aria-label="Lower bet">−</button>
          <input id="sm-linebet" type="number" min="1" max="1000" value="1" class="field w-20 text-center" />
          <button id="sm-bet-up" class="btn btn-secondary px-3" aria-label="Raise bet">+</button>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">Total bet
        <div id="sm-totalbet" class="field flex w-24 items-center justify-center font-mono text-ink">10</div>
      </div>
      <button id="sm-spin" class="btn btn-primary min-w-24">Spin</button>
      <button id="sm-max" class="btn btn-secondary">Max bet</button>
      <button id="sm-auto" class="btn btn-secondary" aria-pressed="false">Autoplay</button>
      <button id="sm-turbo" class="btn btn-secondary" aria-pressed="false">Turbo</button>
      <button id="sm-reset" class="btn btn-secondary">Reset credits</button>
    </div>

    <div class="grid grid-cols-1 gap-3 lg:grid-cols-[1fr_260px]">
      <!-- Paytable -->
      <div class="panel panel-lift p-4">
        <div class="mb-2 text-[13px] text-ink-subtle">Paytable — pays × your line bet, left to right on 10 lines</div>
        <div id="sm-paytable" class="grid grid-cols-1 gap-x-6 gap-y-1 font-mono text-[13px] text-ink-muted sm:grid-cols-2"></div>
        <div class="mt-3 text-[12px] leading-relaxed text-ink-tertiary">
          🃏 Wild substitutes for any symbol except 🎰. 🎰 Scatter pays on your
          total bet anywhere on the grid; 3 or more awards 10 free spins with
          every win doubled.
        </div>
      </div>

      <!-- Session stats + recent wins -->
      <div class="flex flex-col gap-3">
        <div class="panel panel-lift p-4">
          <div class="mb-2 text-[13px] text-ink-subtle">Session</div>
          <div id="sm-session" class="flex flex-col gap-1 font-mono text-[13px] text-ink-muted"></div>
        </div>
        <div class="panel panel-lift p-4">
          <div class="mb-2 text-[13px] text-ink-subtle">Recent wins</div>
          <div id="sm-recent" class="flex max-h-36 flex-col gap-1 overflow-y-auto font-mono text-[13px] text-ink-muted"><span class="text-ink-tertiary">No spins yet.</span></div>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free slot machine simulator plays a five-reel, three-row video slot
      with ten fixed paylines, virtual credits, and no real money. Set your bet
      per line and the total updates across all ten lines; hit spin and the reels
      roll and stop one after another before wins are scored left to right. Wild
      symbols substitute for anything except the scatter, and landing three or
      more scatters anywhere on the grid awards ten free spins with every win
      doubled. Use max bet to stake the top amount, turbo to skip the spin
      animation, or autoplay to run a long session hands-free and watch how the
      balance trends. A live credit balance, spin count, measured return-to-player,
      biggest win, and a running list of recent wins track how the session goes.
      Every spin uses your browser's secure random source and runs entirely on
      your device — nothing is uploaded and there are no purchases.
    </p>
  </div>
</ToolLayout>

<style is:global>
  .sm-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px;
    max-width: 520px; margin: 0 auto;
  }
  .sm-cell {
    display: grid; place-items: center; aspect-ratio: 1;
    border-radius: 10px; border: 1px solid var(--color-hairline, #23252b);
    background: var(--color-surface-2, #141516);
    font-size: clamp(28px, 8vw, 46px); line-height: 1; user-select: none;
    transition: box-shadow 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .sm-cell.sm-hit {
    border-color: var(--color-primary-hover, #828fff);
    background: color-mix(in srgb, var(--color-primary, #5e6ad2) 16%, var(--color-surface-2, #141516));
    box-shadow: 0 0 0 1px var(--color-primary-hover, #828fff), 0 0 18px -4px var(--color-primary, #5e6ad2);
  }
  .sm-cell.sm-scatter {
    border-color: #f5a623;
    box-shadow: 0 0 0 1px #f5a623, 0 0 18px -4px #f5a623;
  }
  .sm-cell.sm-spinning { animation: sm-blur 0.12s linear infinite; }
  @keyframes sm-blur { 0%,100% { transform: translateY(-1px); } 50% { transform: translateY(1px); } }

  .sm-fsbanner {
    position: absolute; top: 8px; left: 50%; transform: translateX(-50%);
    padding: 3px 12px; border-radius: 999px; z-index: 3;
    background: #f5a623; color: #10121a; font-weight: 700; font-size: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }
  .sm-winline { min-height: 1rem; margin-top: 8px; text-align: center;
    font-family: var(--font-mono, monospace); font-size: 13px; }
</style>

<script>
  import { randInt } from '../../lib/random';
  import {
    PAYLINES, PAYTABLE, SCATTER_PAY, SYM_NAME, WILD, SCATTER,
    FREE_SPINS, FREE_MULT, spinGrid, evaluate, type Sym, type SpinResult,
  } from '../../lib/slot';

  const $ = (id: string) => document.getElementById(id)!;

  const START = 1000;
  const MAX_LINEBET = 1000;
  const LINES = PAYLINES.length;

  let credits = START;
  let lineBet = 1;
  let spins = 0;
  let wagered = 0;
  let returned = 0;
  let biggest = 0;
  let freeSpins = 0;         // remaining free spins
  let freeWon = 0;           // credits won across the current free-spin run
  let autoplaying = false;
  let turbo = false;
  let busy = false;          // a spin animation is in flight

  const gridEl = $('sm-grid');
  const msg = $('sm-msg');
  const winlineEl = $('sm-winline');
  const cells: HTMLElement[][] = [];   // cells[reel][row]

  // Build the 5×3 grid of cells (column-major so index math matches grid[reel][row]).
  for (let reel = 0; reel < 5; reel++) cells.push([]);
  // DOM order must be row-major for CSS grid, but we keep a column-major lookup.
  const initial: Sym[][] = [['🍒','🔔','⭐'],['🍋','💎','🍒'],['🔔','7️⃣','🍋'],['⭐','🍒','🔔'],['💎','🍋','⭐']];
  for (let row = 0; row < 3; row++) {
    for (let reel = 0; reel < 5; reel++) {
      const c = document.createElement('div');
      c.className = 'sm-cell';
      c.textContent = initial[reel][row];
      gridEl.appendChild(c);
      cells[reel][row] = c;
    }
  }

  function totalBet() { return lineBet * LINES; }

  function renderBet() {
    ($('sm-linebet') as HTMLInputElement).value = String(lineBet);
    $('sm-totalbet').textContent = totalBet().toLocaleString();
  }

  function renderStats() {
    $('sm-credits').textContent = credits.toLocaleString();
    $('sm-spins').textContent = spins.toLocaleString();
    $('sm-rtp').textContent = wagered > 0 ? ((returned / wagered) * 100).toFixed(1) + '%' : '—';
    const net = returned - wagered;
    $('sm-session').innerHTML = [
      `Wagered<span class="float-right text-ink">${wagered.toLocaleString()}</span>`,
      `Won<span class="float-right text-ink">${returned.toLocaleString()}</span>`,
      `Net<span class="float-right ${net >= 0 ? 'text-emerald-400' : 'text-red-400'}">${net >= 0 ? '+' : ''}${net.toLocaleString()}</span>`,
      `Biggest win<span class="float-right text-ink">${biggest.toLocaleString()}</span>`,
    ].map((h) => `<div>${h}</div>`).join('');
  }

  function clearHighlights() {
    for (const reel of cells) for (const c of reel) c.classList.remove('sm-hit', 'sm-scatter');
  }

  function paintGrid(grid: Sym[][]) {
    for (let reel = 0; reel < 5; reel++)
      for (let row = 0; row < 3; row++) cells[reel][row].textContent = grid[reel][row];
  }

  function highlight(res: SpinResult) {
    clearHighlights();
    for (const w of res.lineWins) {
      const rows = PAYLINES[w.line];
      for (let reel = 0; reel < w.count; reel++) cells[reel][rows[reel]].classList.add('sm-hit');
    }
    if (res.scatterCount >= 3)
      for (let reel = 0; reel < 5; reel++)
        for (let row = 0; row < 3; row++)
          if (res.grid[reel][row] === SCATTER) cells[reel][row].classList.add('sm-scatter');
  }

  function pushRecent(text: string) {
    const box = $('sm-recent');
    if (box.querySelector('.text-ink-tertiary')) box.innerHTML = '';
    const row = document.createElement('div');
    row.textContent = text;
    box.prepend(row);
    while (box.children.length > 40) box.lastChild!.remove();
  }

  function fsBanner() {
    const b = $('sm-fsbanner');
    if (freeSpins > 0) { b.hidden = false; b.textContent = `Free spins: ${freeSpins} left · ${FREE_MULT}× wins`; }
    else b.hidden = true;
  }

  // Resolve a scored spin into balance, stats, highlights and messaging.
  function settle(res: SpinResult, free: boolean) {
    spins++;
    if (!free) { credits -= totalBet(); wagered += totalBet(); }
    credits += res.totalWin;
    returned += res.totalWin;
    if (res.totalWin > biggest) biggest = res.totalWin;
    if (free) freeWon += res.totalWin;
    $('sm-lastwin').textContent = res.totalWin.toLocaleString();

    paintGrid(res.grid);
    highlight(res);

    const parts: string[] = [];
    if (res.lineWins.length) {
      const best = [...res.lineWins].sort((a, b) => b.amount - a.amount)[0];
      parts.push(`${res.lineWins.length} line${res.lineWins.length > 1 ? 's' : ''} · best ${best.count}× ${SYM_NAME[best.sym]}`);
    }
    if (res.scatterWin > 0) parts.push(`${res.scatterCount} scatter`);
    winlineEl.textContent = res.totalWin > 0
      ? `Won ${res.totalWin.toLocaleString()} — ${parts.join(', ')}`
      : (free ? 'No win' : '');

    if (res.totalWin > 0) pushRecent(`+${res.totalWin.toLocaleString()}${free ? ' (free)' : ''} — ${parts.join(', ') || 'win'}`);

    // Award / retrigger free spins.
    if (res.freeSpinsAwarded > 0) {
      freeSpins += res.freeSpinsAwarded;
      pushRecent(`🎰 ${res.freeSpinsAwarded} free spins awarded`);
    }

    renderStats();
    fsBanner();
  }

  const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

  // Animate reels stopping left→right, then reveal the pre-decided grid.
  async function animate(finalGrid: Sym[][]) {
    const rollFor = turbo ? 0 : 260;
    const stagger = turbo ? 0 : 130;
    for (const reel of cells) for (const c of reel) c.classList.add('sm-spinning');

    for (let reel = 0; reel < 5; reel++) {
      if (!turbo) {
        // spin this reel a touch longer than the previous
        const until = performance.now() + rollFor + reel * stagger;
        while (performance.now() < until) {
          for (let row = 0; row < 3; row++) cells[reel][row].textContent = REEL_FACES[randInt(0, REEL_FACES.length - 1)];
          await sleep(70);
        }
      }
      for (let row = 0; row < 3; row++) cells[reel][row].textContent = finalGrid[reel][row];
      cells[reel].forEach((c) => c.classList.remove('sm-spinning'));
    }
    for (const reel of cells) for (const c of reel) c.classList.remove('sm-spinning');
  }
  const REEL_FACES: Sym[] = ['🍒', '🍋', '🔔', '⭐', '💎', '7️⃣', '🃏', '🎰'];

  async function doSpin() {
    if (busy) return;
    const free = freeSpins > 0;

    if (!free) {
      if (credits < totalBet()) {
        msg.textContent = 'Not enough credits for that bet. Lower your bet or reset.';
        stopAuto();
        return;
      }
    }

    busy = true;
    clearHighlights();
    winlineEl.textContent = '';
    msg.textContent = free ? `Free spin — ${FREE_MULT}× wins!` : 'Spinning…';

    const grid = spinGrid();
    const res = evaluate(grid, lineBet, free ? FREE_MULT : 1);

    await animate(grid);

    if (free) freeSpins--;
    settle(res, free);

    if (freeSpins === 0 && free) {
      msg.textContent = `Free spins done — won ${freeWon.toLocaleString()} credits.`;
      freeWon = 0;
    } else if (!free) {
      msg.textContent = res.totalWin > 0 ? `Nice — ${res.totalWin.toLocaleString()} credits!` : 'No win this time.';
    }

    busy = false;

    // Chain free spins automatically, then continue autoplay.
    if (freeSpins > 0) { await sleep(turbo ? 120 : 420); doSpin(); return; }
    if (autoplaying) {
      if (credits < totalBet()) { stopAuto(); msg.textContent = 'Autoplay stopped — out of credits.'; return; }
      await sleep(turbo ? 90 : 480);
      if (autoplaying) doSpin();
    }
  }

  function setLineBet(v: number) {
    lineBet = Math.max(1, Math.min(MAX_LINEBET, Math.floor(v || 1)));
    renderBet();
  }

  function stopAuto() {
    autoplaying = false;
    const b = $('sm-auto');
    b.setAttribute('aria-pressed', 'false');
    b.textContent = 'Autoplay';
  }

  function reset() {
    autoplaying = false; freeSpins = 0; freeWon = 0;
    credits = START; spins = 0; wagered = 0; returned = 0; biggest = 0;
    setLineBet(1);
    clearHighlights();
    paintGrid(initial);
    $('sm-lastwin').textContent = '0';
    winlineEl.textContent = '';
    $('sm-recent').innerHTML = '<span class="text-ink-tertiary">No spins yet.</span>';
    stopAuto();
    fsBanner();
    renderStats();
    msg.textContent = 'Credits reset to 1,000.';
  }

  function renderPaytable() {
    const order: Sym[] = ['🃏', '7️⃣', '💎', '⭐', '🔔', '🍋', '🍒'];
    const rows = order.map((s) => {
      const [t3, t4, t5] = PAYTABLE[s as Exclude<Sym, '🎰'>];
      return `<div>${s} ${SYM_NAME[s]}<span class="float-right text-ink">${t3} / ${t4} / ${t5}</span></div>`;
    });
    rows.push(`<div>🎰 Scatter (×total)<span class="float-right text-ink">${SCATTER_PAY[3]} / ${SCATTER_PAY[4]} / ${SCATTER_PAY[5]}</span></div>`);
    $('sm-paytable').innerHTML = rows.join('');
  }

  // ---- wire up -----------------------------------------------------------
  $('sm-spin').addEventListener('click', () => { if (!autoplaying) doSpin(); });
  $('sm-max').addEventListener('click', () => {
    // largest line bet still affordable, capped at MAX
    const affordable = Math.max(1, Math.floor(credits / LINES));
    setLineBet(Math.min(MAX_LINEBET, affordable));
  });
  $('sm-bet-up').addEventListener('click', () => setLineBet(lineBet + 1));
  $('sm-bet-down').addEventListener('click', () => setLineBet(lineBet - 1));
  ($('sm-linebet') as HTMLInputElement).addEventListener('change', (e) => setLineBet(Number((e.target as HTMLInputElement).value)));

  $('sm-auto').addEventListener('click', () => {
    autoplaying = !autoplaying;
    const b = $('sm-auto');
    b.setAttribute('aria-pressed', String(autoplaying));
    b.textContent = autoplaying ? 'Stop auto' : 'Autoplay';
    if (autoplaying && !busy) doSpin();
  });
  $('sm-turbo').addEventListener('click', () => {
    turbo = !turbo;
    const b = $('sm-turbo');
    b.setAttribute('aria-pressed', String(turbo));
    b.textContent = turbo ? 'Turbo on' : 'Turbo';
  });
  $('sm-reset').addEventListener('click', reset);

  renderBet();
  renderPaytable();
  renderStats();
  fsBanner();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="cover-letter-generator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="flex flex-col gap-3">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Your name<input id="cl-name" class="field" value="Jane Doe" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Job title<input id="cl-role" class="field" value="Product Designer" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Company<input id="cl-company" class="field" value="Acme Inc" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Hiring manager<input id="cl-manager" class="field" value="Hiring Team" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Years of experience<input id="cl-years" type="number" min="0" value="6" class="field" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Tone
          <select id="cl-tone" class="field"><option value="professional">Professional</option><option value="enthusiastic">Enthusiastic</option><option value="concise">Concise</option></select>
        </label>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Key strength / skill<input id="cl-skill" class="field" value="building intuitive user experiences" /></label>
      <div class="flex gap-2">
        <button id="cl-gen" class="btn btn-primary">Generate</button>
        <button id="cl-copy" class="btn btn-secondary">Copy</button>
        <button id="cl-print" class="btn btn-secondary">Print PDF</button>
      </div>
    </div>

    <textarea id="cl-out" class="field min-h-96 resize-y text-[14px] leading-relaxed" aria-label="Cover letter"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free cover letter generator drafts a tailored cover letter from a few
      details — your name, the role and company, your experience and a key
      strength — in the tone you choose. The result is fully editable, so you can
      refine it and make it your own, then copy it or print to PDF. Everything runs
      in your browser and nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const out = $('cl-out') as HTMLTextAreaElement;
  const v = (id: string) => ($(id) as HTMLInputElement | HTMLSelectElement).value;

  function generate() {
    const name = v('cl-name'), role = v('cl-role'), company = v('cl-company');
    const manager = v('cl-manager') || 'Hiring Team';
    const years = v('cl-years'), skill = v('cl-skill'), tone = v('cl-tone');
    const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

    const openers: Record<string, string> = {
      professional: `I am writing to express my interest in the ${role} position at ${company}.`,
      enthusiastic: `I was thrilled to see the ${role} opening at ${company} — it is exactly the role I have been hoping to find.`,
      concise: `I'm applying for the ${role} role at ${company}.`,
    };
    const body = `With ${years}+ years of experience and a focus on ${skill}, I am confident I would bring real value to your team. Throughout my career I have consistently delivered results, collaborated across disciplines, and taken ownership of the problems in front of me.`;
    const close = tone === 'concise'
      ? `I'd welcome the chance to talk. Thank you for your consideration.`
      : `I would welcome the opportunity to discuss how my background aligns with your needs. Thank you for considering my application.`;

    out.value = `${today}\n\nDear ${manager},\n\n${openers[tone]} ${body}\n\nWhat draws me to ${company} in particular is the chance to apply my skills where they can make a difference. I am eager to contribute and to keep growing alongside a strong team.\n\n${close}\n\nSincerely,\n${name}`;
  }

  ['cl-name', 'cl-role', 'cl-company', 'cl-manager', 'cl-years', 'cl-skill', 'cl-tone'].forEach((id) => $(id).addEventListener('input', generate));
  $('cl-gen').addEventListener('click', generate);
  $('cl-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!'; setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
  $('cl-print').addEventListener('click', () => {
    const w = window.open('', '_blank'); if (!w) return;
    const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    w.document.write(`<html><head><title>Cover Letter</title></head><body style="margin:48px;font-family:Georgia,serif;line-height:1.6;white-space:pre-wrap;font-size:14px">${esc(out.value)}</body></html>`);
    w.document.close(); w.focus(); setTimeout(() => w.print(), 250);
  });
  generate();
</script>

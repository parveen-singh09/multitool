---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="calorie-burn-estimator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Activity
        <select id="cbe-activity" class="field"></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Duration (minutes)
        <input id="cbe-minutes" type="number" min="0" step="1" class="field" value="30" inputmode="numeric" />
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Body weight
        <input id="cbe-weight" type="number" min="0" step="any" class="field" value="70" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight unit
        <select id="cbe-unit" class="field">
          <option value="kg">Kilograms (kg)</option>
          <option value="lb">Pounds (lb)</option>
        </select>
      </label>
    </div>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="cbe-calories" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Calories burned</div></div>
      <div class="panel p-4"><div id="cbe-permin" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Per minute</div></div>
      <div class="panel p-4"><div id="cbe-met" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">MET value</div></div>
    </div>

    <p id="cbe-note" class="text-[13px] text-ink-subtle"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free calorie burn estimator uses MET (metabolic equivalent of task)
      values to estimate how many calories an activity burns. Calories are
      calculated as MET × 3.5 × body weight in kg ÷ 200 × minutes. Pick an
      activity, set your weight in kilograms or pounds, and enter the duration to
      see the estimated energy expenditure. Actual calorie burn varies with
      fitness, intensity and metabolism.
    </p>
  </div>
</ToolLayout>

<script>
  interface Activity { name: string; met: number; note: string; }

  const activities: Activity[] = [
    { name: 'Walking (slow, 3 km/h)', met: 2.8, note: 'A gentle stroll, easy on the joints.' },
    { name: 'Walking (brisk, 5.5 km/h)', met: 4.3, note: 'Purposeful walking that raises the heart rate a little.' },
    { name: 'Hiking (cross-country)', met: 6.0, note: 'Uneven terrain and inclines add to the burn.' },
    { name: 'Running (8 km/h)', met: 8.3, note: 'A steady jog at a conversational pace.' },
    { name: 'Running (11 km/h)', met: 11.0, note: 'A fast, sustained run.' },
    { name: 'Cycling (leisure, <16 km/h)', met: 4.0, note: 'Easy recreational riding.' },
    { name: 'Cycling (moderate, 19–22 km/h)', met: 8.0, note: 'A solid road-riding pace.' },
    { name: 'Cycling (vigorous, >22 km/h)', met: 10.0, note: 'Fast riding or spirited group rides.' },
    { name: 'Swimming (leisure)', met: 6.0, note: 'Relaxed laps or general swimming.' },
    { name: 'Swimming (vigorous laps)', met: 9.8, note: 'Fast, continuous freestyle swimming.' },
    { name: 'Rowing machine (moderate)', met: 7.0, note: 'A full-body cardio workout.' },
    { name: 'Elliptical trainer', met: 5.0, note: 'Low-impact cardio for legs and arms.' },
    { name: 'Jump rope', met: 11.8, note: 'High-intensity and great for coordination.' },
    { name: 'Yoga (Hatha)', met: 2.5, note: 'Gentle stretching and breathing.' },
    { name: 'Pilates', met: 3.0, note: 'Core-focused, controlled movement.' },
    { name: 'Weight training (general)', met: 3.5, note: 'Free weights or machines at a steady pace.' },
    { name: 'Weight training (vigorous)', met: 6.0, note: 'Heavy lifting with short rests.' },
    { name: 'HIIT / circuit training', met: 8.0, note: 'Alternating bursts of high effort.' },
    { name: 'Dancing (aerobic)', met: 7.3, note: 'High-energy dance workouts.' },
    { name: 'Basketball (game)', met: 8.0, note: 'Constant movement and sprinting.' },
    { name: 'Soccer (casual)', met: 7.0, note: 'Recreational play with plenty of running.' },
    { name: 'Tennis (singles)', met: 8.0, note: 'Fast-paced with lots of direction changes.' },
    { name: 'Housework (moderate)', met: 3.3, note: 'Cleaning, vacuuming and general chores.' },
    { name: 'Gardening', met: 3.8, note: 'Digging, weeding and general yard work.' },
  ];

  const activitySel = document.getElementById('cbe-activity') as HTMLSelectElement;
  const minutes = document.getElementById('cbe-minutes') as HTMLInputElement;
  const weight = document.getElementById('cbe-weight') as HTMLInputElement;
  const unit = document.getElementById('cbe-unit') as HTMLSelectElement;

  activities.forEach((a, i) => {
    const opt = document.createElement('option');
    opt.value = String(i);
    opt.textContent = `${a.name} (MET ${a.met})`;
    activitySel.append(opt);
  });
  activitySel.value = '1';

  function calc() {
    const activity = activities[Number(activitySel.value) || 0];
    const kg = unit.value === 'lb'
      ? (Number(weight.value) || 0) * 0.45359237
      : (Number(weight.value) || 0);
    const mins = Math.max(0, Number(minutes.value) || 0);

    const perMin = activity.met * 3.5 * kg / 200;
    const total = perMin * mins;

    document.getElementById('cbe-calories')!.textContent = `${Math.round(total).toLocaleString()} kcal`;
    document.getElementById('cbe-permin')!.textContent = `${perMin.toFixed(1)} kcal`;
    document.getElementById('cbe-met')!.textContent = String(activity.met);
    document.getElementById('cbe-note')!.textContent = activity.note;
  }

  [activitySel, minutes, weight, unit].forEach((el) => el.addEventListener('input', calc));
  [activitySel, unit].forEach((el) => el.addEventListener('change', calc));
  calc();
</script>

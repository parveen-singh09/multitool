---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="random-date-generator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">From
        <input id="rd-from" type="date" value="2000-01-01" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">To
        <input id="rd-to" type="date" value="2030-12-31" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="rd-count" type="number" min="1" max="500" value="10" class="field" />
      </label>
      <label class="flex items-center gap-2 pt-6 text-sm text-ink-subtle"><input id="rd-time" type="checkbox" class="accent-[#5e6ad2]" /> Include time</label>
    </div>
    <div class="flex gap-2">
      <button id="rd-gen" class="btn btn-primary">Generate</button>
      <button id="rd-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <textarea id="rd-out" class="field min-h-56 resize-y font-mono text-[13px]" readonly aria-label="Generated dates"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free random date generator produces random dates within any range you
      set, optionally with a random time of day, in bulk. It's handy for seeding
      test data, sampling, scheduling experiments and games. Dates are returned in
      ISO format and drawn with your browser's secure random source. Runs entirely
      in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { randInt } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('rd-out') as HTMLTextAreaElement;

  function generate() {
    const from = new Date(($('rd-from') as HTMLInputElement).value || '2000-01-01').getTime();
    const to = new Date(($('rd-to') as HTMLInputElement).value || '2030-12-31').getTime();
    const withTime = ($('rd-time') as HTMLInputElement).checked;
    const n = Math.max(1, Math.min(500, Number(($('rd-count') as HTMLInputElement).value) || 10));
    const lo = Math.min(from, to), hi = Math.max(from, to);
    const spanDays = Math.max(1, Math.floor((hi - lo) / 86400000));
    const list: string[] = [];
    for (let i = 0; i < n; i++) {
      let ms = lo + randInt(0, spanDays) * 86400000;
      if (withTime) ms += randInt(0, 86399) * 1000;
      const d = new Date(ms);
      list.push(withTime ? d.toISOString().slice(0, 19).replace('T', ' ') : d.toISOString().slice(0, 10));
    }
    out.value = list.join('\n');
  }

  ['rd-from', 'rd-to', 'rd-count', 'rd-time'].forEach((id) => $(id).addEventListener('input', generate));
  $('rd-gen').addEventListener('click', generate);
  $('rd-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

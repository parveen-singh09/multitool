---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="password-analyzer">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Password to analyze
      <input id="pa-in" type="text" class="field font-mono text-[13px]" placeholder="Type a password…" spellcheck="false" autocomplete="off" autocapitalize="off" autocorrect="off" />
    </label>
    <p class="text-[13px] text-ink-muted">Runs entirely in your browser. Nothing is sent anywhere.</p>

    <div class="flex flex-col gap-2">
      <div class="h-2 w-full overflow-hidden rounded-full bg-surface-2">
        <div id="pa-bar" class="h-full w-0 transition-all" style="background:#e5484d"></div>
      </div>
      <div id="pa-label" class="text-sm font-medium text-ink-subtle">—</div>
    </div>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="pa-entropy" class="font-display text-xl font-semibold text-primary-hover">0</div><div class="mt-1 text-[13px] text-ink-subtle">Entropy (bits)</div></div>
      <div class="panel p-4"><div id="pa-length" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Length</div></div>
      <div class="panel p-4"><div id="pa-pool" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Charset size</div></div>
      <div class="panel p-4"><div id="pa-crack" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Est. crack time</div></div>
    </div>

    <div>
      <h2 class="mb-2 font-display text-sm font-semibold text-ink">Character classes</h2>
      <div id="pa-classes" class="flex flex-wrap gap-2 text-[13px]"></div>
    </div>

    <div>
      <h2 class="mb-2 font-display text-sm font-semibold text-ink">Tips</h2>
      <ul id="pa-tips" class="flex list-disc flex-col gap-1 pl-5 text-[13px] text-ink-subtle"></ul>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free password analyzer estimates how strong a password is by measuring
      its length, character variety and entropy in bits, then approximates how
      long a fast offline attacker would need to crack it. It also lists practical
      tips to strengthen weak passwords. The tool runs locally in your browser —
      your password is never transmitted or stored.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('pa-in') as HTMLInputElement;
  const bar = document.getElementById('pa-bar') as HTMLElement;
  const label = document.getElementById('pa-label')!;
  const classesEl = document.getElementById('pa-classes')!;
  const tipsEl = document.getElementById('pa-tips')!;
  const set = (id: string, val: string) => { document.getElementById(id)!.textContent = val; };

  const CLASSES: { name: string; re: RegExp; size: number }[] = [
    { name: 'Lowercase', re: /[a-z]/, size: 26 },
    { name: 'Uppercase', re: /[A-Z]/, size: 26 },
    { name: 'Digits', re: /[0-9]/, size: 10 },
    { name: 'Symbols', re: /[^a-zA-Z0-9]/, size: 33 },
  ];

  function humanTime(seconds: number): string {
    if (seconds < 1) return 'instant';
    const units: [number, string][] = [
      [60, 'second'], [60, 'minute'], [24, 'hour'], [365, 'day'],
      [100, 'year'], [10, 'century'],
    ];
    let value = seconds;
    let unit = 'second';
    for (const [factor, name] of units) {
      if (value < factor) { unit = name; break; }
      value /= factor;
      unit = name;
    }
    if (value >= 1e6) return `${value.toExponential(1)} ${unit}s`;
    const rounded = Math.round(value);
    return `${rounded} ${unit}${rounded === 1 ? '' : 's'}`;
  }

  function analyze() {
    const pw = input.value;
    const len = pw.length;
    let pool = 0;
    classesEl.innerHTML = '';
    for (const c of CLASSES) {
      const has = c.re.test(pw);
      if (has) pool += c.size;
      const chip = document.createElement('span');
      chip.className = 'panel px-3 py-1';
      chip.style.color = has ? '#27a644' : '#6b7280';
      chip.textContent = `${has ? '✓' : '○'} ${c.name}`;
      classesEl.appendChild(chip);
    }

    const entropy = len && pool ? len * Math.log2(pool) : 0;
    set('pa-entropy', entropy.toFixed(1));
    set('pa-length', String(len));
    set('pa-pool', String(pool));

    // Assume 1e10 guesses/second (fast offline attack), search half the space on average.
    const guesses = pool > 0 ? Math.pow(pool, len) / 2 : 0;
    const seconds = guesses / 1e10;
    set('pa-crack', len ? humanTime(seconds) : '—');

    const levels = [
      { max: 28, label: 'Very weak', color: '#e5484d', pct: 15 },
      { max: 40, label: 'Weak', color: '#f5a623', pct: 35 },
      { max: 60, label: 'Fair', color: '#e2c541', pct: 55 },
      { max: 80, label: 'Strong', color: '#27a644', pct: 80 },
      { max: Infinity, label: 'Very strong', color: '#1f9d55', pct: 100 },
    ];
    const level = len ? levels.find((l) => entropy < l.max)! : { label: '—', color: '#e5484d', pct: 0 };
    bar.style.width = `${level.pct}%`;
    bar.style.background = level.color;
    label.textContent = len ? `${level.label} — ${entropy.toFixed(0)} bits` : '—';
    label.style.color = len ? level.color : '';

    const tips: string[] = [];
    if (len < 12) tips.push('Use at least 12 characters — length matters more than complexity.');
    if (!/[A-Z]/.test(pw)) tips.push('Add uppercase letters.');
    if (!/[a-z]/.test(pw)) tips.push('Add lowercase letters.');
    if (!/[0-9]/.test(pw)) tips.push('Add digits.');
    if (!/[^a-zA-Z0-9]/.test(pw)) tips.push('Add symbols such as ! @ # $ %.');
    if (/^[a-zA-Z]+$/.test(pw) && len) tips.push('Avoid words alone — mix in numbers and symbols.');
    if (/(.)\1{2,}/.test(pw)) tips.push('Avoid repeated characters like "aaa".');
    if (/(0123|1234|2345|abcd|qwer)/i.test(pw)) tips.push('Avoid common sequences like "1234" or "qwerty".');
    if (!tips.length && len) tips.push('This password looks solid. Use a password manager to store it.');
    if (!len) tips.push('Type a password above to see analysis.');
    tipsEl.innerHTML = '';
    for (const t of tips) {
      const li = document.createElement('li');
      li.textContent = t;
      tipsEl.appendChild(li);
    }
  }

  input.addEventListener('input', analyze);
  analyze();
</script>

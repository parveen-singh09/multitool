---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="open-graph-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Title
        <input id="og-title" class="field" value="My Awesome Page" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Description
        <textarea id="og-desc" class="field min-h-20 resize-y">A short, compelling description shown in the link preview.</textarea>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Canonical URL
        <input id="og-url" class="field" value="https://example.com/page" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Image URL
        <input id="og-image" class="field" value="https://example.com/og-image.png" spellcheck="false" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Type
          <select id="og-type" class="field">
            <option value="website">Website</option>
            <option value="article">Article</option>
            <option value="book">Book</option>
            <option value="business.business">Business</option>
            <option value="product">Product</option>
            <option value="profile">Profile</option>
            <option value="music.song">Music Song</option>
            <option value="music.album">Music Album</option>
            <option value="music.playlist">Music Playlist</option>
            <option value="music.radio_station">Music Radio Station</option>
            <option value="video.movie">Video Movie</option>
            <option value="video.episode">Video Episode</option>
            <option value="video.tv_show">Video TV Show</option>
            <option value="video.other">Video</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Twitter card
          <select id="og-card" class="field"><option value="summary_large_image">Large image</option><option value="summary">Summary</option></select>
        </label>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Site name
        <input id="og-site" class="field" value="Example" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Locale
        <input id="og-locale" class="field" value="en_US" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Twitter @site
        <input id="og-tw" class="field" placeholder="@yoursite" spellcheck="false" />
      </label>

      <div id="og-extra" class="flex flex-col gap-3"></div>
    </div>

    <div class="flex flex-col gap-4">

      <div class="flex flex-col gap-2">
        <label class="text-sm text-ink-subtle">Preview</label>
        <div class="overflow-hidden rounded-lg border border-line bg-surface-2">
          <div id="og-prev-img" class="aspect-[1.91/1] w-full bg-surface-3 bg-cover bg-center"></div>
          <div class="flex flex-col gap-1 p-3">
            <div id="og-prev-url" class="truncate text-xs uppercase tracking-wide text-ink-faint"></div>
            <div id="og-prev-title" class="truncate text-sm font-medium text-ink"></div>
            <div id="og-prev-desc" class="line-clamp-2 text-xs text-ink-subtle"></div>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-sm text-ink-subtle">Generated tags</label>
        <div class="relative">
          <pre class="hl-block field min-h-72" style="resize:vertical;overflow:auto"><code id="og-out" class="hljs" style="background:transparent;padding:0"></code></pre>
          <button id="og-copy" title="Copy tags" aria-label="Copy tags" class="btn btn-secondary absolute bottom-2 right-2 flex items-center gap-1.5 px-2 py-1 text-xs">
            <svg id="og-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            <span id="og-copy-label">Copy</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Open Graph generator builds the <code class="font-mono text-ink">og:</code>
      and Twitter card meta tags that control how your links look when shared on
      Facebook, LinkedIn, X and messaging apps. Pick a type — website, article,
      product, profile, book, video or music — and the tool adds the matching
      type-specific properties (<code class="font-mono text-ink">article:author</code>,
      <code class="font-mono text-ink">product:price:amount</code>, and so on). The live
      preview shows roughly how the link card will look. Add a large image
      (1200×630 works well) for the best results. Paste the tags into your HTML
      head. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl } from '../../lib/highlight';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('og-out') as HTMLElement;
  let rawOutput = '';
  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const val = (id: string) => {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    return el ? el.value.trim() : '';
  };

  type F = [string, string, string?, boolean?];
  const SPEC: Record<string, F[]> = {
    article: [
      ['article:author', 'Author URL or name', 'https://example.com/author'],
      ['article:published_time', 'Published time (ISO 8601)', '2026-01-01T08:00:00Z'],
      ['article:modified_time', 'Modified time (ISO 8601)', '2026-01-02T09:00:00Z'],
      ['article:section', 'Section', 'Technology'],
      ['article:tag', 'Tags (comma separated)', 'seo, meta, open graph', true],
    ],
    book: [
      ['book:author', 'Author', 'Jane Doe'],
      ['book:isbn', 'ISBN', '978-3-16-148410-0'],
      ['book:release_date', 'Release date (ISO 8601)', '2026-01-01'],
      ['book:tag', 'Tags (comma separated)', 'fiction, sci-fi', true],
    ],
    'business.business': [
      ['business:contact_data:street_address', 'Street address', '123 Main St'],
      ['business:contact_data:locality', 'City', 'Springfield'],
      ['business:contact_data:region', 'State / province / region', 'IL'],
      ['business:contact_data:postal_code', 'Postal code', '62704'],
      ['business:contact_data:country_name', 'Country', 'United States of America'],
    ],
    product: [
      ['product:price:amount', 'Price amount', '19.99'],
      ['product:price:currency', 'Price currency', 'USD'],
    ],
    profile: [
      ['profile:first_name', 'First name', 'Jane'],
      ['profile:last_name', 'Last name', 'Doe'],
      ['profile:username', 'Username', 'janedoe'],
      ['profile:gender', 'Gender', 'female'],
    ],
    'music.song': [
      ['music:duration', 'Duration (seconds)', '210'],
      ['music:album', 'Album URL', 'https://example.com/album'],
      ['music:musician', 'Musician URL', 'https://example.com/artist'],
    ],
    'music.album': [
      ['music:song', 'Song URL', 'https://example.com/song'],
      ['music:musician', 'Musician URL', 'https://example.com/artist'],
      ['music:release_date', 'Release date (ISO 8601)', '2026-01-01'],
    ],
    'music.playlist': [
      ['music:song', 'Song URL', 'https://example.com/song'],
      ['music:creator', 'Creator URL', 'https://example.com/creator'],
    ],
    'music.radio_station': [
      ['music:creator', 'Creator URL', 'https://example.com/creator'],
    ],
    'video.movie': [
      ['video:actor', 'Actor URL', 'https://example.com/actor'],
      ['video:director', 'Director URL', 'https://example.com/director'],
      ['video:duration', 'Duration (seconds)', '5400'],
      ['video:release_date', 'Release date (ISO 8601)', '2026-01-01'],
      ['video:tag', 'Tags (comma separated)', 'action, drama', true],
    ],
    'video.episode': [
      ['video:series', 'Series URL', 'https://example.com/series'],
      ['video:actor', 'Actor URL', 'https://example.com/actor'],
      ['video:duration', 'Duration (seconds)', '1800'],
      ['video:release_date', 'Release date (ISO 8601)', '2026-01-01'],
    ],
    'video.tv_show': [
      ['video:actor', 'Actor URL', 'https://example.com/actor'],
      ['video:director', 'Director URL', 'https://example.com/director'],
      ['video:tag', 'Tags (comma separated)', 'comedy', true],
    ],
    'video.other': [
      ['video:duration', 'Duration (seconds)', '300'],
      ['video:tag', 'Tags (comma separated)', 'clip', true],
    ],
  };

  const inputType = (prop: string) =>
    prop.endsWith('_time') ? 'datetime-local' : prop.endsWith('_date') ? 'date' : 'text';

  function renderExtra() {
    const defs = SPEC[val('og-type')] || [];
    const container = $('og-extra');
    container.innerHTML = defs.map(([prop, label, ph], i) =>
      `<label class="flex flex-col gap-1 text-sm text-ink-subtle">${label}
        <input id="ex-${i}" type="${inputType(prop)}" class="field" placeholder="${ph || ''}" spellcheck="false" /></label>`
    ).join('');
    defs.forEach((_, i) => document.getElementById(`ex-${i}`)!.addEventListener('input', build));
  }

  function build() {
    const lines: string[] = [];
    const title = val('og-title'), desc = val('og-desc'), url = val('og-url'), image = val('og-image');
    const type = val('og-type'), card = val('og-card'), site = val('og-site'), locale = val('og-locale'), tw = val('og-tw');
    if (title) lines.push(`<meta property="og:title" content="${esc(title)}">`);
    if (desc) lines.push(`<meta property="og:description" content="${esc(desc)}">`);
    if (type) lines.push(`<meta property="og:type" content="${type}">`);
    if (url) lines.push(`<meta property="og:url" content="${esc(url)}">`);
    if (image) lines.push(`<meta property="og:image" content="${esc(image)}">`);
    if (site) lines.push(`<meta property="og:site_name" content="${esc(site)}">`);
    if (locale) lines.push(`<meta property="og:locale" content="${esc(locale)}">`);

    // Type-specific properties, driven by SPEC.
    (SPEC[type] || []).forEach(([prop, , , isList], i) => {
      const raw = val(`ex-${i}`);
      if (!raw) return;
      if (isList) {
        raw.split(',').map(t => t.trim()).filter(Boolean)
          .forEach(t => lines.push(`<meta property="${prop}" content="${esc(t)}">`));
      } else {
        lines.push(`<meta property="${prop}" content="${esc(raw)}">`);
      }
    });

    lines.push('');
    if (card) lines.push(`<meta name="twitter:card" content="${card}">`);
    if (tw) lines.push(`<meta name="twitter:site" content="${esc(tw)}">`);
    if (title) lines.push(`<meta name="twitter:title" content="${esc(title)}">`);
    if (desc) lines.push(`<meta name="twitter:description" content="${esc(desc)}">`);
    if (image) lines.push(`<meta name="twitter:image" content="${esc(image)}">`);
    rawOutput = lines.join('\n');
    hl(out, rawOutput, 'html');

    // Live preview.
    const pImg = $('og-prev-img'), pUrl = $('og-prev-url'), pTitle = $('og-prev-title'), pDesc = $('og-prev-desc');
    pImg.style.backgroundImage = image ? `url("${image.replace(/"/g, '%22')}")` : '';
    try { pUrl.textContent = url ? new URL(url).hostname : ''; } catch { pUrl.textContent = url; }
    pTitle.textContent = title || 'Title';
    pDesc.textContent = desc;
  }

  function onTypeChange() { renderExtra(); build(); }

  ['og-title', 'og-desc', 'og-url', 'og-image', 'og-card', 'og-site', 'og-locale', 'og-tw']
    .forEach((id) => $(id).addEventListener('input', build));
  $('og-type').addEventListener('change', onTypeChange);
  $('og-copy').addEventListener('click', async () => {
    const label = $('og-copy-label');
    await navigator.clipboard.writeText(rawOutput);
    label.textContent = 'Copied!';
    setTimeout(() => (label.textContent = 'Copy'), 1500);
  });

  renderExtra();
  build();
</script>

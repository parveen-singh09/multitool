---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="fake-name-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Gender
        <select id="fn-sex" class="field w-32"><option value="any" selected>Any</option><option value="male">Male</option><option value="female">Female</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="fn-count" type="number" min="1" max="1000" value="10" class="field w-28" />
      </label>
      <button id="fn-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="fn-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <textarea id="fn-out" class="field min-h-64 resize-y font-mono text-[13px]" readonly aria-label="Generated names"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free fake name generator creates random, realistic full names for
      testing forms, seeding databases, designing mockups and writing sample
      content. Pick a gender or leave it random, choose how many you need, and
      generate a whole batch at once. All names are fictional and generated
      locally in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { fullName, type Sex } from '../../lib/fakegen';

  const $ = (id: string) => document.getElementById(id)!;
  const sexEl = $('fn-sex') as HTMLSelectElement;
  const countEl = $('fn-count') as HTMLInputElement;
  const out = $('fn-out') as HTMLTextAreaElement;

  function generate() {
    const n = Math.max(1, Math.min(1000, Number(countEl.value) || 1));
    const list: string[] = [];
    for (let i = 0; i < n; i++) list.push(fullName(sexEl.value as Sex));
    out.value = list.join('\n');
  }

  [sexEl, countEl].forEach((el) => el.addEventListener('input', generate));
  $('fn-gen').addEventListener('click', generate);
  $('fn-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ImageConverter from '../../components/ImageConverter.astro';
---

<ToolLayout slug="jpg-to-webp">
  <ImageConverter to="image/webp" accept="image/jpeg,.jpg,.jpeg" ext="webp" quality={true} />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free JPG to WebP converter turns JPEG photos into modern WebP format,
      which is typically much smaller at the same visual quality — great for
      faster-loading web pages. Adjust the quality slider, preview the result,
      and download. Everything runs in your browser and your image is never
      uploaded.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="angle-converter">
  <UnitConverter slug="angle-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free angle converter converts angles between degrees, radians, gradians, arcminutes, arcseconds and full revolutions using exact math — handy for geometry, trigonometry and programming. All conversion runs in your browser.
    </p>
  </div>
</ToolLayout>

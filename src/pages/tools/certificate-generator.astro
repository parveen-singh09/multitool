---
import ToolLayout from '../../layouts/ToolLayout.astro';

const templates = [
  { id: 'classic',   name: 'Classic Gold' },
  { id: 'modern',    name: 'Modern Blue' },
  { id: 'elegant',   name: 'Elegant Rose' },
  { id: 'corporate', name: 'Corporate Navy' },
  { id: 'academic',  name: 'Academic Green' },
  { id: 'minimal',   name: 'Minimalist' },
  { id: 'vintage',   name: 'Vintage Sepia' },
  { id: 'bold',      name: 'Bold Contrast' },
  { id: 'royal',     name: 'Royal Purple' },
  { id: 'teal',      name: 'Teal Fresh' },
];
---

<ToolLayout slug="certificate-generator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="flex flex-col gap-4">
      <!-- Template picker -->
      <div class="flex flex-col gap-2">
        <span class="text-sm text-ink-subtle">Template</span>
        <div id="ce-templates" class="grid grid-cols-2 gap-2 sm:grid-cols-3">
          {templates.map((t) => (
            <button
              type="button"
              data-tpl={t.id}
              class="ce-tpl flex items-center gap-2 rounded-[6px] border border-hairline bg-surface-1 px-2.5 py-2 text-left text-[13px] text-ink-muted transition-colors hover:border-hairline-strong hover:bg-surface-2"
            >
              <span data-swatch class="h-4 w-4 shrink-0 rounded-full border border-hairline"></span>
              <span class="truncate">{t.name}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Custom template upload -->
      <div class="flex flex-col gap-2">
        <span class="text-sm text-ink-subtle">Custom template</span>
        <div class="flex flex-wrap items-center gap-2">
          <label class="btn btn-secondary cursor-pointer">
            Upload background
            <input id="ce-upload" type="file" accept="image/*" class="hidden" />
          </label>
          <button id="ce-clear-upload" class="btn btn-secondary hidden" type="button">Remove</button>
          <span id="ce-upload-name" class="truncate text-[13px] text-ink-subtle"></span>
        </div>
        <p class="text-[12px] leading-snug text-ink-tertiary">
          Upload your own certificate background (PNG or JPG, landscape works best). Text is drawn on top with a light panel for legibility.
        </p>
      </div>

      <div class="h-px bg-hairline"></div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Certificate title
        <input id="ce-title" class="field" value="Certificate of Achievement" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Recipient name
        <input id="ce-name" class="field" value="Jane Doe" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Description line
        <input id="ce-desc" class="field" value="has successfully completed the Web Development course" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Date
          <input id="ce-date" class="field" value="July 4, 2026" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Signature name
          <input id="ce-sig" class="field" value="A. Director" />
        </label>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Accent color
          <input id="ce-color" type="color" value="#5e6ad2" class="field h-10 cursor-pointer p-1" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Border style
          <select id="ce-border" class="field"><option value="template">Match template</option><option value="classic">Classic</option><option value="modern">Modern</option><option value="double">Double line</option><option value="corners">Corners</option><option value="none">None</option></select>
        </label>
      </div>
      <div class="flex gap-2">
        <button id="ce-png" class="btn btn-primary">Download PNG</button>
        <button id="ce-pdf" class="btn btn-secondary">Download PDF</button>
      </div>
    </div>

    <div class="flex items-start justify-center">
      <canvas id="ce-canvas" width="1000" height="720" class="w-full rounded-[8px] border border-hairline"></canvas>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free certificate generator designs award, completion and appreciation
      certificates from ten built-in templates — classic gold, modern blue, elegant
      rose, corporate navy, academic green, minimalist, vintage sepia, bold contrast,
      royal purple and teal fresh. Each template sets its own colors, fonts and
      border, and you can override the accent color and border style on top.
    </p>
    <p>
      Prefer your own design? Upload a custom background image and the recipient's
      name, description, date and signature are drawn over it. Preview everything live
      and download a print-ready PNG or PDF. All rendering happens in your browser —
      nothing is uploaded to a server.
    </p>
  </div>
</ToolLayout>

<script>
  type Border = 'classic' | 'modern' | 'double' | 'corners' | 'band' | 'inset' | 'ornate' | 'side' | 'none';

  interface Template {
    id: string;
    bg: string;
    accent: string;
    titleColor: string;
    subColor: string;
    nameColor: string;
    bodyColor: string;
    lineColor: string;
    labelColor: string;
    family: string;
    border: Border;
  }

  const TEMPLATES: Record<string, Template> = {
    classic:   { id: 'classic',   bg: '#fffdf8', accent: '#b8860b', titleColor: '#b8860b', subColor: '#666666', nameColor: '#111111', bodyColor: '#444444', lineColor: '#cccccc', labelColor: '#888888', family: 'Georgia, "Times New Roman", serif', border: 'double' },
    modern:    { id: 'modern',    bg: '#ffffff', accent: '#2563eb', titleColor: '#2563eb', subColor: '#6b7280', nameColor: '#111827', bodyColor: '#4b5563', lineColor: '#d1d5db', labelColor: '#9ca3af', family: 'Helvetica, Arial, sans-serif', border: 'modern' },
    elegant:   { id: 'elegant',   bg: '#fffafb', accent: '#be185d', titleColor: '#be185d', subColor: '#9d5c73', nameColor: '#3b1220', bodyColor: '#6b4451', lineColor: '#e7c9d3', labelColor: '#b08594', family: 'Georgia, "Times New Roman", serif', border: 'inset' },
    corporate: { id: 'corporate', bg: '#f8fafc', accent: '#1e3a8a', titleColor: '#ffffff', subColor: '#64748b', nameColor: '#0f172a', bodyColor: '#475569', lineColor: '#cbd5e1', labelColor: '#94a3b8', family: 'Helvetica, Arial, sans-serif', border: 'band' },
    academic:  { id: 'academic',  bg: '#fbfef9', accent: '#15803d', titleColor: '#15803d', subColor: '#5f7a63', nameColor: '#14281a', bodyColor: '#3f5744', lineColor: '#c3ddc7', labelColor: '#8aa88f', family: 'Georgia, "Times New Roman", serif', border: 'corners' },
    minimal:   { id: 'minimal',   bg: '#ffffff', accent: '#111111', titleColor: '#111111', subColor: '#9ca3af', nameColor: '#111111', bodyColor: '#6b7280', lineColor: '#e5e7eb', labelColor: '#b0b0b0', family: 'Helvetica, Arial, sans-serif', border: 'none' },
    vintage:   { id: 'vintage',   bg: '#f5ecd7', accent: '#7c5c2e', titleColor: '#5e451f', subColor: '#8a7248', nameColor: '#3d2c14', bodyColor: '#6b573a', lineColor: '#cbb78e', labelColor: '#a08b63', family: 'Georgia, "Times New Roman", serif', border: 'ornate' },
    bold:      { id: 'bold',      bg: '#111827', accent: '#f59e0b', titleColor: '#f59e0b', subColor: '#9ca3af', nameColor: '#f9fafb', bodyColor: '#d1d5db', lineColor: '#374151', labelColor: '#6b7280', family: 'Helvetica, Arial, sans-serif', border: 'modern' },
    royal:     { id: 'royal',     bg: '#faf5ff', accent: '#7c3aed', titleColor: '#7c3aed', subColor: '#7c6f8a', nameColor: '#2e1065', bodyColor: '#574374', lineColor: '#ddd0f0', labelColor: '#a996c2', family: 'Georgia, "Times New Roman", serif', border: 'double' },
    teal:      { id: 'teal',      bg: '#f0fdfa', accent: '#0d9488', titleColor: '#0d9488', subColor: '#5b807b', nameColor: '#0f2e2a', bodyColor: '#3f5f5b', lineColor: '#b7e0da', labelColor: '#84aaa4', family: 'Helvetica, Arial, sans-serif', border: 'side' },
  };

  const $ = (id: string) => document.getElementById(id)!;
  const canvas = $('ce-canvas') as HTMLCanvasElement;
  const v = (id: string) => ($(id) as HTMLInputElement | HTMLSelectElement).value;

  let currentTpl = 'classic';
  let customImg: HTMLImageElement | null = null;
  // Track whether the user has manually picked an accent so template switches can update it.
  let accentTouched = false;

  function activeAccent(tpl: Template): string {
    return accentTouched ? v('ce-color') : tpl.accent;
  }

  function drawBorder(ctx: CanvasRenderingContext2D, type: Border, accent: string, W: number, H: number) {
    ctx.strokeStyle = accent;
    ctx.fillStyle = accent;
    switch (type) {
      case 'double':
        ctx.lineWidth = 6; ctx.strokeRect(24, 24, W - 48, H - 48);
        ctx.lineWidth = 2; ctx.strokeRect(40, 40, W - 80, H - 80);
        break;
      case 'modern':
        ctx.lineWidth = 14; ctx.strokeRect(30, 30, W - 60, H - 60);
        break;
      case 'classic':
        ctx.lineWidth = 4; ctx.strokeRect(28, 28, W - 56, H - 56);
        ctx.lineWidth = 1; ctx.strokeRect(38, 38, W - 76, H - 76);
        break;
      case 'inset':
        ctx.lineWidth = 2; ctx.strokeRect(46, 46, W - 92, H - 92);
        break;
      case 'corners': {
        const m = 34, len = 90;
        ctx.lineWidth = 4;
        const corner = (x: number, y: number, dx: number, dy: number) => {
          ctx.beginPath();
          ctx.moveTo(x, y + dy * len); ctx.lineTo(x, y); ctx.lineTo(x + dx * len, y);
          ctx.stroke();
        };
        corner(m, m, 1, 1); corner(W - m, m, -1, 1);
        corner(m, H - m, 1, -1); corner(W - m, H - m, -1, -1);
        break;
      }
      case 'ornate': {
        ctx.lineWidth = 5; ctx.strokeRect(26, 26, W - 52, H - 52);
        ctx.lineWidth = 1.5; ctx.strokeRect(42, 42, W - 84, H - 84);
        const dot = (x: number, y: number) => { ctx.beginPath(); ctx.arc(x, y, 6, 0, Math.PI * 2); ctx.fill(); };
        dot(42, 42); dot(W - 42, 42); dot(42, H - 42); dot(W - 42, H - 42);
        break;
      }
      case 'side':
        ctx.fillRect(0, 0, 22, H);
        ctx.lineWidth = 2; ctx.strokeRect(46, 30, W - 76, H - 60);
        break;
      case 'band':
        // Drawn separately in draw() before the title.
        break;
      case 'none':
      default:
        break;
    }
  }

  function draw() {
    const W = canvas.width, H = canvas.height;
    const ctx = canvas.getContext('2d')!;
    const tpl = TEMPLATES[currentTpl];
    const accent = activeAccent(tpl);
    const borderSel = v('ce-border');
    const border: Border = borderSel === 'template' ? tpl.border : (borderSel as Border);

    // Background.
    if (customImg) {
      // Stretch the artwork to fill the certificate exactly — no crop, no dimming.
      ctx.drawImage(customImg, 0, 0, W, H);
    } else {
      ctx.fillStyle = tpl.bg; ctx.fillRect(0, 0, W, H);
    }

    // Text colors (custom uses dark neutral text on the light panel).
    const titleColor = customImg ? accent : tpl.titleColor;
    const subColor = customImg ? '#666666' : tpl.subColor;
    const nameColor = customImg ? '#111111' : tpl.nameColor;
    const bodyColor = customImg ? '#444444' : tpl.bodyColor;
    const lineColor = customImg ? '#cccccc' : tpl.lineColor;
    const labelColor = customImg ? '#888888' : tpl.labelColor;
    const family = customImg ? 'Georgia, "Times New Roman", serif' : tpl.family;

    let titleY = 175;
    // Border / band.
    if (!customImg) {
      if (border === 'band') {
        ctx.fillStyle = accent;
        ctx.fillRect(0, 0, W, 235);
      } else {
        drawBorder(ctx, border, accent, W, H);
      }
    }

    ctx.textAlign = 'center';
    // Over custom artwork, a soft shadow keeps text readable without dimming the image.
    if (customImg) {
      ctx.shadowColor = 'rgba(255,255,255,0.85)';
      ctx.shadowBlur = 8;
    }
    // Title.
    ctx.fillStyle = border === 'band' && !customImg ? tpl.titleColor : titleColor;
    ctx.font = `700 46px ${family}`;
    ctx.fillText(v('ce-title'), W / 2, titleY);
    // Sub line.
    ctx.fillStyle = subColor;
    ctx.font = `italic 20px ${family}`;
    ctx.fillText('This certificate is proudly presented to', W / 2, 250);
    // Name.
    ctx.fillStyle = nameColor;
    ctx.font = `700 56px ${family}`;
    ctx.fillText(v('ce-name'), W / 2, 340);
    // Underline.
    ctx.strokeStyle = lineColor; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(W / 2 - 250, 360); ctx.lineTo(W / 2 + 250, 360); ctx.stroke();
    // Description (wrapped).
    ctx.fillStyle = bodyColor; ctx.font = `22px ${family}`;
    wrap(ctx, v('ce-desc'), W - 320).forEach((line, i) => ctx.fillText(line, W / 2, 420 + i * 30));
    // Date + signature.
    ctx.strokeStyle = labelColor; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(180, 620); ctx.lineTo(400, 620); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(600, 620); ctx.lineTo(820, 620); ctx.stroke();
    ctx.fillStyle = nameColor; ctx.font = `18px ${family}`;
    ctx.fillText(v('ce-date'), 290, 650); ctx.fillText(v('ce-sig'), 710, 650);
    ctx.fillStyle = labelColor; ctx.font = `13px ${family}`;
    ctx.fillText('DATE', 290, 672); ctx.fillText('SIGNATURE', 710, 672);

    // Reset shadow so it never bleeds into the next redraw's background or borders.
    ctx.shadowColor = 'transparent';
    ctx.shadowBlur = 0;
  }

  function wrap(ctx: CanvasRenderingContext2D, s: string, maxW: number): string[] {
    const words = s.split(/\s+/); const lines: string[] = []; let line = '';
    for (const w of words) {
      const test = line ? line + ' ' + w : w;
      if (ctx.measureText(test).width > maxW && line) { lines.push(line); line = w; }
      else line = test;
    }
    if (line) lines.push(line);
    return lines;
  }

  // Template swatches + selection.
  const tplButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.ce-tpl'));
  tplButtons.forEach((btn) => {
    const id = btn.dataset.tpl!;
    const tpl = TEMPLATES[id];
    const sw = btn.querySelector<HTMLElement>('[data-swatch]')!;
    sw.style.background = tpl.accent;
    btn.addEventListener('click', () => {
      currentTpl = id;
      if (!accentTouched) (($('ce-color')) as HTMLInputElement).value = tpl.accent;
      highlight();
      draw();
    });
  });

  function highlight() {
    tplButtons.forEach((btn) => {
      const on = btn.dataset.tpl === currentTpl && !customImg;
      btn.classList.toggle('border-primary', on);
      btn.classList.toggle('text-ink', on);
      btn.classList.toggle('bg-surface-2', on);
    });
  }

  // Custom upload.
  $('ce-upload').addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        customImg = img;
        $('ce-upload-name').textContent = file.name;
        $('ce-clear-upload').classList.remove('hidden');
        highlight();
        draw();
      };
      img.src = reader.result as string;
    };
    reader.readAsDataURL(file);
  });

  $('ce-clear-upload').addEventListener('click', () => {
    customImg = null;
    ($('ce-upload') as HTMLInputElement).value = '';
    $('ce-upload-name').textContent = '';
    $('ce-clear-upload').classList.add('hidden');
    highlight();
    draw();
  });

  $('ce-color').addEventListener('input', () => { accentTouched = true; draw(); });

  ['ce-title', 'ce-name', 'ce-desc', 'ce-date', 'ce-sig', 'ce-border'].forEach((id) => $(id).addEventListener('input', draw));

  $('ce-png').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = 'certificate.png'; a.click();
  });
  $('ce-pdf').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Generating…';
    try {
      const { PDFDocument } = await import('pdf-lib');
      const pdf = await PDFDocument.create();
      const pngBytes = await new Promise<Uint8Array>((res) => canvas.toBlob(async (b) => res(new Uint8Array(await b!.arrayBuffer())), 'image/png'));
      const png = await pdf.embedPng(pngBytes);
      const page = pdf.addPage([canvas.width, canvas.height]);
      page.drawImage(png, { x: 0, y: 0, width: canvas.width, height: canvas.height });
      const bytes = await pdf.save();
      const url = URL.createObjectURL(new Blob([bytes.slice()], { type: 'application/pdf' }));
      const a = document.createElement('a'); a.href = url; a.download = 'certificate.pdf'; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } finally { btn.disabled = false; btn.textContent = 'Download PDF'; }
  });

  highlight();
  draw();
</script>

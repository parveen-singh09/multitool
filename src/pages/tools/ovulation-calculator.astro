---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ovulation-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">First day of last menstrual period
        <input id="ov-lmp" type="date" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Average cycle length (days)
        <input id="ov-cycle" type="number" min="20" max="45" step="1" class="field" value="28" inputmode="numeric" />
      </label>
    </div>

    <div class="panel panel-lift p-6 text-center">
      <div id="ov-date" class="font-display text-3xl font-semibold text-primary-hover">—</div>
      <div class="mt-2 text-sm text-ink-muted">estimated ovulation date</div>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="panel p-5 text-center"><div id="ov-window" class="font-mono text-base text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Fertile window</div></div>
      <div class="panel p-5 text-center"><div id="ov-peak" class="font-mono text-base text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Peak (most fertile) days</div></div>
      <div class="panel p-5 text-center"><div id="ov-next" class="font-mono text-base text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Next period</div></div>
    </div>

    <div class="panel p-5 text-center">
      <div id="ov-due" class="font-mono text-lg text-ink">—</div>
      <div class="mt-1 text-[13px] text-ink-subtle">Estimated due date if you conceive this cycle</div>
    </div>

    <div class="panel p-0">
      <div class="px-5 py-3 text-sm text-ink-muted">Next 6 cycles</div>
      <div class="overflow-x-auto border-t border-hairline">
        <table class="w-full text-left text-[13px]">
          <thead class="text-ink-subtle"><tr class="border-b border-hairline"><th class="px-4 py-2 font-medium">Cycle</th><th class="px-4 py-2 font-medium">Ovulation</th><th class="px-4 py-2 font-medium">Fertile window</th></tr></thead>
          <tbody id="ov-proj" class="text-ink-muted"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>This free ovulation calculator estimates your most fertile days and next period from the first day of your last menstrual period and your average cycle length. Ovulation is estimated at about 14 days before your next period, with the fertile window spanning the five days before ovulation through the day after. These are estimates based on cycle averages and can shift from month to month — they are a guide, not a reliable form of contraception.</p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

  function fmt(d: Date) {
    return d.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });
  }

  const addDays = (d: Date, n: number) => { const r = new Date(d); r.setDate(r.getDate() + n); return r; };
  const fmtShort = (d: Date) => d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });

  function calc() {
    const lmp = $('ov-lmp').value;
    const cycle = Number($('ov-cycle').value) || 28;
    const dateEl = document.getElementById('ov-date')!;
    const windowEl = document.getElementById('ov-window')!;
    const peakEl = document.getElementById('ov-peak')!;
    const nextEl = document.getElementById('ov-next')!;
    const dueEl = document.getElementById('ov-due')!;
    const projEl = document.getElementById('ov-proj')!;

    if (!lmp || !(cycle >= 20 && cycle <= 45)) {
      dateEl.textContent = windowEl.textContent = peakEl.textContent = nextEl.textContent = dueEl.textContent = '—';
      projEl.innerHTML = '';
      return;
    }

    const start = new Date(lmp + 'T00:00:00');
    const nextPeriod = addDays(start, cycle);
    const ovulation = addDays(nextPeriod, -14);
    const windowStart = addDays(ovulation, -5);
    const windowEnd = addDays(ovulation, 1);

    dateEl.textContent = fmt(ovulation);
    windowEl.textContent = `${fmt(windowStart)} – ${fmt(windowEnd)}`;
    // Peak = ovulation day and the day before (highest conception odds).
    peakEl.textContent = `${fmtShort(addDays(ovulation, -1))} – ${fmtShort(ovulation)}`;
    nextEl.textContent = fmt(nextPeriod);
    // Due date if conception occurs this cycle (ovulation + 266 days).
    dueEl.textContent = fmt(addDays(ovulation, 266));

    // Project the next 6 cycles.
    const rows: string[] = [];
    for (let i = 0; i < 6; i++) {
      const cLmp = addDays(start, cycle * i);
      const cOv = addDays(cLmp, cycle - 14);
      rows.push(`<tr class="border-b border-hairline/50"><td class="px-4 py-1.5">${i + 1}</td><td class="px-4 py-1.5">${fmt(cOv)}</td><td class="px-4 py-1.5">${fmtShort(addDays(cOv, -5))} – ${fmtShort(addDays(cOv, 1))}</td></tr>`);
    }
    projEl.innerHTML = rows.join('');
  }

  document.querySelectorAll('#ov-lmp, #ov-cycle').forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

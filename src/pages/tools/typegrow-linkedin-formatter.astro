---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="typegrow-linkedin-formatter">
  <div class="flex flex-col gap-5">
    <!-- Style toolbar -->
    <div class="flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <span class="eyebrow w-full text-ink-subtle">Text styles</span>
        <button data-fmt="bold" class="btn btn-secondary" title="Bold serif"><span class="font-bold">𝐁</span></button>
        <button data-fmt="boldSans" class="btn btn-secondary" title="Bold sans"><span class="font-bold">𝗕</span></button>
        <button data-fmt="italic" class="btn btn-secondary" title="Italic serif"><span class="italic">𝐼</span></button>
        <button data-fmt="italicSans" class="btn btn-secondary" title="Italic sans"><span class="italic">𝘐</span></button>
        <button data-fmt="boldItalic" class="btn btn-secondary" title="Bold italic serif">𝑩𝑰</button>
        <button data-fmt="boldItalicSans" class="btn btn-secondary" title="Bold italic sans">𝘽𝙄</button>
        <button data-fmt="sans" class="btn btn-secondary" title="Sans-serif">𝖠𝖺</button>
        <button data-fmt="script" class="btn btn-secondary" title="Cursive script">𝒮</button>
        <button data-fmt="doublestruck" class="btn btn-secondary" title="Doublestruck">𝔻</button>
        <button data-fmt="monospace" class="btn btn-secondary" title="Monospace">𝙼</button>
        <button data-fmt="fullwidth" class="btn btn-secondary" title="Fullwidth">Ａ</button>
        <button data-fmt="underline" class="btn btn-secondary" title="Underline">U̲</button>
        <button data-fmt="strike" class="btn btn-secondary" title="Strikethrough">S̶</button>
        <button data-fmt="boldUnderline" class="btn btn-secondary" title="Bold underline"><span class="font-bold">B̲</span></button>
        <button data-fmt="boldStrike" class="btn btn-secondary" title="Bold strikethrough"><span class="font-bold">S̶</span></button>
        <button data-fmt="upper" class="btn btn-secondary" title="UPPERCASE">AB</button>
        <button data-fmt="lower" class="btn btn-secondary" title="lowercase">ab</button>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <span class="eyebrow w-full text-ink-subtle">Lists</span>
        <button data-list="bullet" class="btn btn-secondary" title="Bullet list">• List</button>
        <button data-list="number" class="btn btn-secondary" title="Numbered list">1. List</button>
        <button data-list="checklist" class="btn btn-secondary" title="Checklist">✅ List</button>
        <button data-list="arrow" class="btn btn-secondary" title="Arrow list">→ List</button>
        <button data-list="ascending" class="btn btn-secondary" title="Ascending emphasis">▸ Asc</button>
        <button data-list="descending" class="btn btn-secondary" title="Descending emphasis">▾ Desc</button>
        <button id="tg-clear" class="btn btn-tertiary ml-auto" title="Strip formatting back to plain text">Clear format</button>
      </div>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Your post
      <textarea id="tg-in" class="field min-h-56 resize-y text-[15px]" placeholder="Write your LinkedIn post here. Select text and tap a style above to make it bold, italic and more — the Unicode formatting survives copy-paste into LinkedIn.">Big news 🎉

I'm thrilled to share that our team just shipped something we're really proud of.</textarea>
    </label>

    <div class="flex flex-wrap items-center gap-2">
      <div class="eyebrow">Preview</div>
      <span id="tg-count" class="status-badge ml-auto">0 characters</span>
      <button id="tg-copy" class="btn btn-primary">Copy formatted</button>
    </div>

    <!-- LinkedIn-style post preview -->
    <div class="panel panel-lift p-4">
      <div class="flex items-center gap-3">
        <div class="h-11 w-11 shrink-0 rounded-full bg-surface-3 ring-1 ring-hairline"></div>
        <div class="flex flex-col">
          <span class="text-[14px] font-semibold text-ink">Your Name</span>
          <span class="text-[12px] text-ink-subtle">Founder · Building in public</span>
          <span class="text-[12px] text-ink-subtle">12h · 🌐</span>
        </div>
      </div>
      <div id="tg-out" class="mt-3 whitespace-pre-wrap break-words text-[15px] leading-relaxed text-ink"></div>
      <div id="tg-more" class="mt-1 hidden text-[13px] text-ink-subtle">…more</div>
      <div class="mt-3 flex items-center gap-4 border-t border-hairline pt-3 text-[13px] text-ink-subtle">
        <span>👍 Like</span>
        <span>💬 Comment</span>
        <span>🔁 Repost</span>
        <span>➤ Send</span>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free LinkedIn text formatter adds <strong>bold</strong>, <em>italic</em>, underline,
      strikethrough, cursive, monospace, doublestruck, fullwidth and combined styles to your LinkedIn
      posts, comments and headline. LinkedIn strips normal rich-text, so this tool swaps your letters
      for their Unicode "mathematical alphanumeric" look-alikes, which paste in and keep their styling
      anywhere Unicode is supported. It also builds clean bullet, numbered, checklist, arrow and
      emphasis lists. Select text, tap a style, then copy — nothing is uploaded and everything runs in
      your browser.
    </p>
    <p>
      The live preview mirrors how your post appears in the LinkedIn feed, including the "…more"
      truncation that hides everything past roughly the first 210 characters on mobile. One caveat:
      Unicode-styled text isn't searchable on LinkedIn and isn't read cleanly by screen-readers, so
      use it for emphasis, not entire posts.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('tg-in') as HTMLTextAreaElement;
  const out = document.getElementById('tg-out')!;
  const count = document.getElementById('tg-count')!;
  const more = document.getElementById('tg-more')!;

  // LinkedIn truncates the feed preview at roughly this many characters on mobile.
  const TRUNCATE_AT = 210;

  type Style = { map?: Record<string, string>; marks?: string[]; transform?: (s: string) => string };

  // Build a letter/digit map from ASCII into a contiguous Unicode alphabet range,
  // then patch the code points that live outside the range (Unicode scatters a few
  // "mathematical" letters into the Letterlike Symbols block).
  function buildAlphabet(
    upperStart: number,
    lowerStart: number,
    digitStart?: number,
    patches?: Record<string, string>,
  ): Record<string, string> {
    const map: Record<string, string> = {};
    for (let i = 0; i < 26; i++) {
      map[String.fromCharCode(65 + i)] = String.fromCodePoint(upperStart + i);
      map[String.fromCharCode(97 + i)] = String.fromCodePoint(lowerStart + i);
    }
    if (digitStart !== undefined) {
      for (let i = 0; i < 10; i++) map[String.fromCharCode(48 + i)] = String.fromCodePoint(digitStart + i);
    }
    if (patches) Object.assign(map, patches);
    return map;
  }

  const bold = buildAlphabet(0x1d400, 0x1d41a, 0x1d7ce);
  const boldSans = buildAlphabet(0x1d5d4, 0x1d5ee, 0x1d7ec);
  const italic = buildAlphabet(0x1d434, 0x1d44e, undefined, { h: 'ℎ' });
  const italicSans = buildAlphabet(0x1d608, 0x1d622);
  const boldItalic = buildAlphabet(0x1d468, 0x1d482);
  const boldItalicSans = buildAlphabet(0x1d63c, 0x1d656);
  const sans = buildAlphabet(0x1d5a0, 0x1d5ba, 0x1d7e2);
  const monospace = buildAlphabet(0x1d670, 0x1d68a, 0x1d7f6);
  const fullwidth = buildAlphabet(0xff21, 0xff41, 0xff10);

  // Script and doublestruck scatter several letters into Letterlike Symbols.
  const script = buildAlphabet(0x1d49c, 0x1d4b6, undefined, {
    B: 'ℬ', E: 'ℰ', F: 'ℱ', H: 'ℋ', I: 'ℐ', L: 'ℒ',
    M: 'ℳ', R: 'ℛ', e: 'ℯ', g: 'ℊ', o: 'ℴ',
  });
  const doublestruck = buildAlphabet(0x1d538, 0x1d552, 0x1d7d8, {
    C: 'ℂ', H: 'ℍ', N: 'ℕ', P: 'ℙ', Q: 'ℚ', R: 'ℝ', Z: 'ℤ',
  });

  const UNDERLINE = '̲';
  const STRIKE = '̶';

  const STYLES: Record<string, Style> = {
    bold: { map: bold },
    boldSans: { map: boldSans },
    italic: { map: italic },
    italicSans: { map: italicSans },
    boldItalic: { map: boldItalic },
    boldItalicSans: { map: boldItalicSans },
    sans: { map: sans },
    script: { map: script },
    doublestruck: { map: doublestruck },
    monospace: { map: monospace },
    fullwidth: { map: fullwidth },
    underline: { marks: [UNDERLINE] },
    strike: { marks: [STRIKE] },
    boldUnderline: { map: bold, marks: [UNDERLINE] },
    boldStrike: { map: bold, marks: [STRIKE] },
    upper: { transform: (s) => s.toUpperCase() },
    lower: { transform: (s) => s.toLowerCase() },
  };

  function transform(text: string, styleKey: string): string {
    const style = STYLES[styleKey];
    if (!style) return text;
    if (style.transform) return style.transform(text);
    return [...text]
      .map((ch) => {
        if (ch === '\n' || ch === ' ') return ch;
        const base = style.map ? style.map[ch] ?? ch : ch;
        return style.marks ? base + style.marks.join('') : base;
      })
      .join('');
  }

  // Normalise mathematical alphabets and strip combining marks back to plain ASCII.
  function toPlain(text: string): string {
    return text.normalize('NFKD').replace(/[̀-ͯ]/g, '');
  }

  function applyToSelection(fn: (s: string) => string) {
    const start = input.selectionStart;
    const end = input.selectionEnd;
    const value = input.value;
    const target = end > start ? { s: start, e: end } : { s: 0, e: value.length };
    const replaced = fn(value.slice(target.s, target.e));
    input.value = value.slice(0, target.s) + replaced + value.slice(target.e);
    input.focus();
    input.setSelectionRange(target.s, target.s + replaced.length);
    render();
  }

  function applyList(kind: string) {
    const start = input.selectionStart;
    const end = input.selectionEnd;
    const value = input.value;
    const hasSelection = end > start;
    const region = hasSelection ? value.slice(start, end) : value;
    const lines = region.split('\n');
    let n = 1;
    // For descending we count down from the number of non-empty lines.
    let remaining = lines.filter((l) => l.replace(/^\s*([•\-→▸▾✅☐]|\d+\.)\s*/, '').trim()).length;
    const marked = lines
      .map((line) => {
        const t = line.replace(/^\s*([•\-→▸▾✅☐]|\d+\.)\s*/, '').trim();
        if (!t) return line;
        if (kind === 'bullet') return `• ${t}`;
        if (kind === 'arrow') return `→ ${t}`;
        if (kind === 'checklist') return `☐ ${t}`;
        if (kind === 'ascending') return `${n++}. ${t}`;
        if (kind === 'descending') return `${remaining--}. ${t}`;
        return `${n++}. ${t}`;
      })
      .join('\n');
    if (hasSelection) {
      input.value = value.slice(0, start) + marked + value.slice(end);
    } else {
      input.value = marked;
    }
    input.focus();
    render();
  }

  function render() {
    const value = input.value;
    out.textContent = value || ' ';
    const len = [...value].length;
    count.textContent = `${len.toLocaleString()} character${len === 1 ? '' : 's'}`;
    more.classList.toggle('hidden', len <= TRUNCATE_AT);
  }

  document.querySelectorAll<HTMLButtonElement>('[data-fmt]').forEach((btn) => {
    btn.addEventListener('click', () => applyToSelection((s) => transform(s, btn.dataset.fmt!)));
  });
  document.querySelectorAll<HTMLButtonElement>('[data-list]').forEach((btn) => {
    btn.addEventListener('click', () => applyList(btn.dataset.list!));
  });
  document.getElementById('tg-clear')!.addEventListener('click', () => applyToSelection(toPlain));

  document.getElementById('tg-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('tg-copy')!;
    await navigator.clipboard.writeText(input.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy formatted'), 1500);
  });

  input.addEventListener('input', render);
  render();
</script>

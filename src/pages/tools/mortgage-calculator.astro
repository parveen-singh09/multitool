---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="mortgage-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Home price
        <input id="mg-price" type="number" min="0" class="field" value="300000" inputmode="decimal" />
      </label>

      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <div class="flex items-center justify-between">
          <span>Down payment</span>
          <div class="flex gap-1" role="tablist" aria-label="Down payment unit">
            <button type="button" id="mg-down-dollar" class="mg-dp-tab btn btn-primary !min-h-0 !px-2 !py-0.5 !text-xs" aria-selected="true">$</button>
            <button type="button" id="mg-down-pct" class="mg-dp-tab btn btn-secondary !min-h-0 !px-2 !py-0.5 !text-xs" aria-selected="false">%</button>
          </div>
        </div>
        <input id="mg-down" type="number" min="0" class="field" value="60000" inputmode="decimal" />
        <span id="mg-down-hint" class="text-[12px] text-ink-tertiary">20% of home price</span>
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Interest rate (%)
        <input id="mg-rate" type="number" min="0" step="0.01" class="field" value="6.5" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Term (years)
        <input id="mg-years" type="number" min="1" class="field" value="30" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Annual property tax
        <input id="mg-tax" type="number" min="0" class="field" value="3000" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Annual home insurance
        <input id="mg-ins" type="number" min="0" class="field" value="1200" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">PMI (% of loan / year)
        <input id="mg-pmi" type="number" min="0" step="0.01" class="field" value="0.5" inputmode="decimal" />
        <span class="text-[12px] text-ink-tertiary">Auto-drops once you owe ≤ 80% of price</span>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">HOA (per month)
        <input id="mg-hoa" type="number" min="0" class="field" value="0" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Extra payment / month
        <input id="mg-extra" type="number" min="0" class="field" value="0" inputmode="decimal" />
      </label>
    </div>

    <div class="copy-wrap panel panel-lift p-6 text-center">
      <div id="mg-total" class="font-display text-3xl font-semibold text-primary-hover">—</div>
      <div class="mt-1 text-[13px] text-ink-subtle">Estimated monthly payment</div>
      <button type="button" class="copy-icon" data-copy-target="#mg-total" aria-label="Copy"></button>
    </div>

    <div class="panel p-5">
      <div class="flex flex-col items-center gap-5 sm:flex-row sm:items-center">
        <svg id="mg-donut" viewBox="0 0 42 42" class="h-32 w-32 shrink-0" role="img" aria-label="Monthly payment breakdown">
          <circle cx="21" cy="21" r="15.915" fill="none" stroke="var(--color-surface-3)" stroke-width="6"></circle>
          <g id="mg-donut-segs"></g>
          <text id="mg-donut-center" x="21" y="21.8" text-anchor="middle" class="fill-ink font-mono" style="font-size:5px" dominant-baseline="middle">—</text>
        </svg>
        <div class="grid w-full grid-cols-2 gap-x-4 gap-y-2 text-sm" id="mg-legend"></div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel p-4"><div id="mg-totint" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Total interest</div></div>
      <div class="panel p-4"><div id="mg-totpaid" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Total of payments</div></div>
      <div class="panel p-4"><div id="mg-payoff" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Payoff date</div></div>
      <div class="panel p-4"><div id="mg-saved" class="font-mono text-lg text-success">—</div><div class="mt-1 text-[13px] text-ink-subtle">Interest saved (extra)</div></div>
    </div>

    <details class="panel p-0">
      <summary class="cursor-pointer list-none px-5 py-4 text-sm font-medium text-ink hover:text-primary-hover">
        <span class="inline-flex items-center gap-2">▸ Amortization schedule (by year)</span>
      </summary>
      <div class="overflow-x-auto border-t border-hairline">
        <table class="w-full text-right text-[13px]">
          <thead class="text-ink-subtle">
            <tr class="border-b border-hairline">
              <th class="px-4 py-2 text-left font-medium">Year</th>
              <th class="px-4 py-2 font-medium">Principal</th>
              <th class="px-4 py-2 font-medium">Interest</th>
              <th class="px-4 py-2 font-medium">Balance</th>
            </tr>
          </thead>
          <tbody id="mg-sched" class="font-mono text-ink-muted"></tbody>
        </table>
      </div>
    </details>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free mortgage calculator estimates your full monthly home loan payment
      — principal and interest plus property tax, home insurance, PMI and HOA
      dues (PITI). It builds a complete amortization schedule so you can see your
      payoff date, total interest over the life of the loan, and how much interest
      an extra monthly payment saves. PMI is automatically dropped once your loan
      balance falls to 80% of the home price. Everything is calculated in your
      browser — nothing is sent anywhere.
    </p>
  </div>
</ToolLayout>

<script>
  const ids = ['mg-price', 'mg-down', 'mg-rate', 'mg-years', 'mg-tax', 'mg-ins', 'mg-pmi', 'mg-hoa', 'mg-extra'];
  const el: Record<string, HTMLInputElement> = {};
  ids.forEach((id) => (el[id] = document.getElementById(id) as HTMLInputElement));
  const money = (n: number) => n.toLocaleString(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });
  const money0 = (n: number) => Math.round(n).toLocaleString();

  let downMode: 'dollar' | 'pct' = 'dollar';

  const COMP = [
    { key: 'pi', label: 'Principal & interest', color: '#5e6ad2' },
    { key: 'tax', label: 'Property tax', color: '#8a8f98' },
    { key: 'ins', label: 'Home insurance', color: '#62666d' },
    { key: 'pmi', label: 'PMI', color: '#d0d6e0' },
    { key: 'hoa', label: 'HOA', color: '#3e3e44' },
  ];

  function downDollars(price: number): number {
    const v = Number(el['mg-down'].value);
    return downMode === 'pct' ? (price * v) / 100 : v;
  }

  function amortize(principal: number, monthlyRate: number, basePI: number, extra: number, price: number, pmiMonthly: number) {
    let bal = principal;
    let totalInterest = 0;
    let month = 0;
    const years: { principal: number; interest: number; balance: number }[] = [];
    let yrP = 0, yrI = 0;
    const maxMonths = 1200; 
    while (bal > 0.005 && month < maxMonths) {
      const interest = bal * monthlyRate;
      let principalPaid = basePI - interest + extra;
      if (principalPaid <= 0) break; 
      if (principalPaid > bal) principalPaid = bal;
      bal -= principalPaid;
      totalInterest += interest;
      yrP += principalPaid; yrI += interest;
      month++;
      if (month % 12 === 0 || bal <= 0.005) {
        years.push({ principal: yrP, interest: yrI, balance: Math.max(0, bal) });
        yrP = 0; yrI = 0;
      }
    }
    return { totalInterest, months: month, years, paysOff: bal <= 0.005 };
  }

  function calc() {
    const price = Number(el['mg-price'].value);
    const down = downDollars(price);
    const principal = price - down;
    const n = Number(el['mg-years'].value) * 12;
    const r = Number(el['mg-rate'].value) / 12 / 100;
    const extra = Math.max(0, Number(el['mg-extra'].value) || 0);

    const hint = document.getElementById('mg-down-hint')!;
    hint.textContent = price > 0
      ? downMode === 'pct'
        ? `= ${money0(down)}`
        : `${((down / price) * 100).toFixed(1)}% of home price`
      : '';

    let pi = 0;
    if (principal > 0 && n > 0) pi = r === 0 ? principal / n : (principal * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);

    const mtax = Number(el['mg-tax'].value) / 12;
    const mins = Number(el['mg-ins'].value) / 12;
    const hoa = Number(el['mg-hoa'].value) || 0;
    // PMI applies only while LTV > 80%; the initial monthly figure reflects month 1.
    const pmiRate = Number(el['mg-pmi'].value) / 100;
    const pmiFull = (principal * pmiRate) / 12;
    const pmiNow = price > 0 && principal / price > 0.8 ? pmiFull : 0;

    const comps: Record<string, number> = { pi, tax: mtax, ins: mins, pmi: pmiNow, hoa };
    const total = pi + mtax + mins + pmiNow + hoa;
    document.getElementById('mg-total')!.textContent = money(total);

    // Donut + legend
    const segG = document.getElementById('mg-donut-segs')!;
    const legend = document.getElementById('mg-legend')!;
    segG.innerHTML = '';
    legend.innerHTML = '';
    let offset = 25; // start at 12 o'clock
    for (const c of COMP) {
      const val = comps[c.key];
      const pct = total > 0 ? (val / total) * 100 : 0;
      if (pct > 0) {
        const circ = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circ.setAttribute('cx', '21'); circ.setAttribute('cy', '21'); circ.setAttribute('r', '15.915');
        circ.setAttribute('fill', 'none'); circ.setAttribute('stroke', c.color); circ.setAttribute('stroke-width', '6');
        circ.setAttribute('stroke-dasharray', `${pct} ${100 - pct}`);
        circ.setAttribute('stroke-dashoffset', String(offset));
        segG.appendChild(circ);
        offset = (offset - pct + 100) % 100;
      }
      if (val > 0) {
        const row = document.createElement('div');
        row.className = 'flex items-center justify-between gap-2';
        row.innerHTML = `<span class="flex items-center gap-1.5 text-ink-subtle"><span class="h-2.5 w-2.5 rounded-full" style="background:${c.color}"></span>${c.label}</span><span class="font-mono text-ink">${money(val)}</span>`;
        legend.appendChild(row);
      }
    }
    document.getElementById('mg-donut-center')!.textContent = total > 0 ? money0(total) : '—';

    // Amortization — with and without extra, to show interest saved.
    const sched = document.getElementById('mg-sched')!;
    sched.innerHTML = '';
    if (principal > 0 && n > 0 && pi > 0) {
      const withExtra = amortize(principal, r, pi, extra, price, pmiFull);
      const baseline = amortize(principal, r, pi, 0, price, pmiFull);

      document.getElementById('mg-totint')!.textContent = money0(withExtra.totalInterest);
      document.getElementById('mg-totpaid')!.textContent = money0(principal + withExtra.totalInterest);

      // payoff date from today
      const now = new Date();
      const payoff = new Date(now.getFullYear(), now.getMonth() + withExtra.months, 1);
      document.getElementById('mg-payoff')!.textContent = withExtra.paysOff
        ? payoff.toLocaleDateString(undefined, { month: 'short', year: 'numeric' })
        : '—';

      const saved = baseline.totalInterest - withExtra.totalInterest;
      const monthsSaved = baseline.months - withExtra.months;
      const savedEl = document.getElementById('mg-saved')!;
      savedEl.textContent = extra > 0 && saved > 0.5 ? money0(saved) : '—';
      savedEl.title = monthsSaved > 0 ? `${monthsSaved} fewer payments (${Math.floor(monthsSaved / 12)}y ${monthsSaved % 12}m earlier)` : '';

      let yr = now.getFullYear();
      for (const y of withExtra.years) {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-hairline/50';
        tr.innerHTML = `<td class="px-4 py-1.5 text-left text-ink-subtle">${yr}</td><td class="px-4 py-1.5">${money0(y.principal)}</td><td class="px-4 py-1.5">${money0(y.interest)}</td><td class="px-4 py-1.5">${money0(y.balance)}</td>`;
        sched.appendChild(tr);
        yr++;
      }
    } else {
      ['mg-totint', 'mg-totpaid', 'mg-payoff', 'mg-saved'].forEach((id) => (document.getElementById(id)!.textContent = '—'));
    }
  }

  // Down-payment unit toggle. Convert the value so the effective dollars stay put.
  const tabs = document.querySelectorAll<HTMLButtonElement>('.mg-dp-tab');
  function setMode(mode: 'dollar' | 'pct') {
    const price = Number(el['mg-price'].value);
    if (mode !== downMode && price > 0) {
      const cur = Number(el['mg-down'].value);
      el['mg-down'].value = mode === 'pct'
        ? String(+((cur / price) * 100).toFixed(2))
        : String(Math.round((cur / 100) * price));
    }
    downMode = mode;
    tabs.forEach((t) => {
      const active = t.id === (mode === 'dollar' ? 'mg-down-dollar' : 'mg-down-pct');
      t.setAttribute('aria-selected', String(active));
      t.classList.toggle('btn-primary', active);
      t.classList.toggle('btn-secondary', !active);
    });
    el['mg-down'].step = mode === 'pct' ? '0.1' : '1';
    calc();
  }
  document.getElementById('mg-down-dollar')!.addEventListener('click', () => setMode('dollar'));
  document.getElementById('mg-down-pct')!.addEventListener('click', () => setMode('pct'));

  ids.forEach((id) => el[id].addEventListener('input', calc));
  calc();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="audio-compressor">
  <div class="flex flex-col gap-4">
    <label id="ac-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an audio file or drop it here</span>
      <input id="ac-file" type="file" accept="audio/*" class="sr-only" />
    </label>

    <div id="ac-panel" class="hidden flex-col gap-4">

      <div class="flex flex-wrap gap-1 rounded-full bg-surface-1 p-1 w-fit border border-hairline">
        <button id="ac-mode-bitrate" class="ac-tab rounded-full px-4 py-1.5 text-[13px] font-medium">By bitrate</button>
        <button id="ac-mode-size" class="ac-tab rounded-full px-4 py-1.5 text-[13px] font-medium">Target file size</button>
      </div>

      <div class="flex flex-wrap items-end gap-3">
        <label id="ac-bitrate-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">Bitrate
          <select id="ac-bitrate" class="field w-40">
            <option value="320">320 kbps (best)</option>
            <option value="256">256 kbps (high)</option>
            <option value="192">192 kbps</option>
            <option value="128" selected>128 kbps (standard)</option>
            <option value="96">96 kbps (small)</option>
            <option value="64">64 kbps (voice)</option>
          </select>
        </label>
        <label id="ac-target-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Target size (MB)
          <input id="ac-target" type="number" min="0.1" step="0.5" value="5" class="field w-40" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sample rate
          <select id="ac-samplerate" class="field w-40">
            <option value="0" selected>Keep original</option>
            <option value="48000">48 kHz</option>
            <option value="44100">44.1 kHz</option>
            <option value="32000">32 kHz</option>
            <option value="22050">22.05 kHz</option>
            <option value="16000">16 kHz (voice)</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Channels
          <select id="ac-channels" class="field w-36">
            <option value="0" selected>Keep original</option>
            <option value="1">Mono</option>
            <option value="2">Stereo</option>
          </select>
        </label>
        <label class="flex items-center gap-2 pb-2.5 text-sm text-ink-subtle" title="EBU R128 loudness normalization">
          <input id="ac-normalize" type="checkbox" class="accent-primary" /> Normalize
        </label>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="ac-go" class="btn btn-primary">Compress to MP3</button>
        <span id="ac-estimate" class="text-[13px] text-ink-subtle"></span>
      </div>

      <div id="ac-progwrap" class="hidden flex-col gap-1">
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-surface-3"><div id="ac-bar" class="h-full w-0 rounded-full transition-all" style="background:var(--color-primary)"></div></div>
        <span id="ac-status" class="text-[13px] text-ink-subtle"></span>
      </div>

      <div id="ac-result" class="hidden flex-col gap-3">
        <div class="grid grid-cols-2 gap-3 text-center">
          <div class="panel p-4"><div id="ac-before" class="font-mono text-lg text-ink">â€”</div><div class="mt-1 text-[13px] text-ink-subtle">Original</div></div>
          <div class="panel p-4"><div id="ac-after" class="font-mono text-lg" style="color:var(--color-success)">â€”</div><div class="mt-1 text-[13px] text-ink-subtle">Compressed (<span id="ac-saved">0%</span> smaller)</div></div>
        </div>
        <button id="ac-download" class="btn btn-primary w-fit">Download MP3</button>
        <audio id="ac-preview" controls class="w-full"></audio>
      </div>
    </div>
    <p id="ac-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free audio compressor reduces the file size of MP3, WAV, M4A and other
      audio by re-encoding to MP3. Pick a bitrate, or switch to target-size mode
      and hit a specific size like 5 MB â€” the bitrate is worked out from the
      track length automatically. Downsample, mix down to mono for voice, and
      normalize loudness so quiet files come up to a consistent level. See the
      before-and-after sizes and preview the result. All compression runs in your
      browser, so your audio is never uploaded and there is no size limit.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .ac-tab { color: var(--color-ink-subtle); transition: background-color .15s, color .15s; }
  .ac-tab[data-active] { background-color: var(--color-surface-3); color: var(--color-ink); }
</style>

<script>
  import { getFFmpeg, fetchFile } from '../../lib/ffmpeg';

  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('ac-file') as HTMLInputElement;
  const drop = $('ac-drop');
  const panel = $('ac-panel');
  const goBtn = $('ac-go') as HTMLButtonElement;
  const progWrap = $('ac-progwrap');
  const bar = $('ac-bar');
  const statusEl = $('ac-status');
  const result = $('ac-result');
  const beforeEl = $('ac-before');
  const afterEl = $('ac-after');
  const savedEl = $('ac-saved');
  const estimate = $('ac-estimate');
  const preview = $('ac-preview') as HTMLAudioElement;
  const err = $('ac-error');

  let file: File | null = null;
  let duration = 0;
  let outUrl = '';
  let mode: 'bitrate' | 'size' = 'bitrate';
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const fmtSize = (n: number) => n < 1048576 ? `${(n / 1024).toFixed(0)} KB` : `${(n / 1048576).toFixed(2)} MB`;
  const numVal = (id: string) => { const v = Number(($(id) as HTMLInputElement).value); return Number.isFinite(v) && v > 0 ? v : 0; };

  function setMode(m: 'bitrate' | 'size') {
    mode = m;
    $('ac-mode-bitrate').toggleAttribute('data-active', m === 'bitrate');
    $('ac-mode-size').toggleAttribute('data-active', m === 'size');
    $('ac-bitrate-wrap').classList.toggle('hidden', m === 'size');
    $('ac-target-wrap').classList.toggle('hidden', m === 'bitrate');
    $('ac-target-wrap').classList.toggle('flex', m === 'size');
    updateEstimate();
  }
  $('ac-mode-bitrate').addEventListener('click', () => setMode('bitrate'));
  $('ac-mode-size').addEventListener('click', () => setMode('size'));

  function targetBitrate(): number {
    const targetMB = numVal('ac-target') || 5;
    const dur = duration || 1;
    return Math.max(32, Math.min(320, Math.floor((targetMB * 8192) / dur * 0.98)));
  }
  function updateEstimate() {
    if (!file) { estimate.textContent = ''; return; }
    if (mode === 'size') {
      estimate.textContent = duration ? `â‰ˆ ${targetBitrate()} kbps` : `Target ${numVal('ac-target')} MB`;
    } else if (duration) {
      const kbps = numVal('ac-bitrate');
      estimate.textContent = `Estimated â‰ˆ ${fmtSize(kbps * 1000 / 8 * duration)}`;
    } else estimate.textContent = '';
  }
  ['ac-bitrate', 'ac-target'].forEach((id) => $(id).addEventListener('input', updateEstimate));

  function probe(f: File) {
    const a = document.createElement('audio');
    a.preload = 'metadata';
    const url = URL.createObjectURL(f);
    a.onloadedmetadata = () => { duration = isFinite(a.duration) ? a.duration : 0; URL.revokeObjectURL(url); updateEstimate(); };
    a.src = url;
  }

  function pick(f: File) {
    file = f; duration = 0;
    panel.classList.remove('hidden'); panel.classList.add('flex');
    result.classList.add('hidden'); setErr(''); probe(f);
  }

  async function compress() {
    if (!file) return;
    setErr(''); goBtn.disabled = true;
    progWrap.classList.remove('hidden'); progWrap.classList.add('flex'); result.classList.add('hidden'); bar.style.width = '0%';
    const br = mode === 'size' ? targetBitrate() : numVal('ac-bitrate');
    const ch = Number(($('ac-channels') as HTMLSelectElement).value);
    const sr = Number(($('ac-samplerate') as HTMLSelectElement).value);
    const normalize = ($('ac-normalize') as HTMLInputElement).checked;
    try {
      const ff = await getFFmpeg({
        onProgress: (r) => { bar.style.width = Math.min(100, Math.round(r * 100)) + '%'; },
        onDownload: (n) => { if (n) statusEl.textContent = n; },
      });
      statusEl.textContent = 'Compressingâ€¦';
      const inName = 'in.' + (file.name.split('.').pop() || 'mp3');
      await ff.writeFile(inName, await fetchFile(file));
      const args = ['-i', inName, '-vn', '-c:a', 'libmp3lame', '-b:a', `${br}k`];
      if (sr) args.push('-ar', String(sr));
      if (ch) args.push('-ac', String(ch));
      if (normalize) args.push('-af', 'loudnorm=I=-16:TP=-1.5:LRA=11');
      args.push('out.mp3');
      await ff.exec(args);
      const data = await ff.readFile('out.mp3');
      const blob = new Blob([data as BlobPart], { type: 'audio/mpeg' });
      if (outUrl) URL.revokeObjectURL(outUrl);
      outUrl = URL.createObjectURL(blob);
      try { await ff.deleteFile(inName); await ff.deleteFile('out.mp3'); } catch {}
      preview.src = outUrl;
      beforeEl.textContent = fmtSize(file.size);
      afterEl.textContent = fmtSize(blob.size);
      savedEl.textContent = Math.max(0, Math.round((1 - blob.size / file.size) * 100)) + '%';
      progWrap.classList.add('hidden');
      result.classList.remove('hidden'); result.classList.add('flex');
    } catch (e) { progWrap.classList.add('hidden'); setErr('Compression failed: ' + (e as Error).message); }
    finally { goBtn.disabled = false; }
  }

  $('ac-download').addEventListener('click', () => {
    if (!outUrl || !file) return;
    const a = document.createElement('a'); a.href = outUrl; a.download = file.name.replace(/\.[^.]+$/, '') + '-compressed.mp3'; a.click();
  });

  fileInput.addEventListener('change', () => fileInput.files?.[0] && pick(fileInput.files[0]));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) pick(f); });
  goBtn.addEventListener('click', compress);
  setMode('bitrate');
</script>

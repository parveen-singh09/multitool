---
import ToolLayout from '../../layouts/ToolLayout.astro';

// Self-contained length converter. Superset of the shared UnitConverter
// (from/to + swap + formula + reference table) plus: all-units-at-once
// output, precision control, feet+inches compound readout, preset quick
// conversions, batch (multi-line) conversion, and copy buttons.
// All math runs in-browser. Factors are metres per unit.
const UNITS: Record<string, number> = {
  Ångström: 1e-10,
  Nanometre: 1e-9,
  'Micrometre (micron)': 1e-6,
  Millimetre: 0.001,
  Centimetre: 0.01,
  Metre: 1,
  Kilometre: 1000,
  'Thou (mil)': 0.0000254,
  Inch: 0.0254,
  Hand: 0.1016,
  Foot: 0.3048,
  Yard: 0.9144,
  Fathom: 1.8288,
  Rod: 5.0292,
  Chain: 20.1168,
  Furlong: 201.168,
  Mile: 1609.344,
  'Nautical mile': 1852,
  'Astronomical unit': 1.495978707e11,
  'Light year': 9.4607304725808e15,
  Parsec: 3.0856775814913673e16,
};
const PRESETS = [
  ['Centimetre', 'Inch'],
  ['Inch', 'Centimetre'],
  ['Metre', 'Foot'],
  ['Foot', 'Metre'],
  ['Kilometre', 'Mile'],
  ['Mile', 'Kilometre'],
  ['Metre', 'Yard'],
  ['Millimetre', 'Inch'],
  ['Nautical mile', 'Kilometre'],
];
---

<ToolLayout slug="length-converter">
  <div id="lc-root" class="flex flex-col gap-4" data-units={JSON.stringify(UNITS)} data-presets={JSON.stringify(PRESETS)}>
    <!-- Primary converter -->
    <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="lc-from-val">From</label>
        <input id="lc-from-val" type="text" class="field" value="1" inputmode="decimal" autocomplete="off" spellcheck="false" />
        <select id="lc-from-unit" class="field mt-1"></select>
      </div>
      <button
        id="lc-swap"
        type="button"
        class="btn btn-secondary mb-1 h-10 w-10 shrink-0 justify-self-center p-0"
        aria-label="Swap units"
        title="Swap units"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4"/></svg>
      </button>
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="lc-to-val">To</label>
        <div class="relative">
          <input id="lc-to-val" type="text" class="field pr-11" readonly />
          <button id="lc-copy-to" type="button" class="btn btn-tertiary absolute right-1 top-1 h-8 w-9 p-0" aria-label="Copy result" title="Copy result">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
          </button>
        </div>
        <select id="lc-to-unit" class="field mt-1"></select>
      </div>
    </div>

    <p id="lc-error" class="hidden text-[13px] text-primary-hover" role="alert"></p>
    <p id="lc-formula" class="text-[13px] text-ink-tertiary"></p>
    <p id="lc-compound" class="text-[13px] text-ink-subtle"></p>

    <!-- Precision -->
    <div class="flex flex-wrap items-center gap-2">
      <label class="text-[13px] text-ink-subtle" for="lc-precision">Precision</label>
      <select id="lc-precision" class="field h-9 w-auto py-1 text-[13px]">
        <option value="auto" selected>Auto</option>
        <option value="0">0 decimals</option>
        <option value="2">2 decimals</option>
        <option value="4">4 decimals</option>
        <option value="6">6 decimals</option>
        <option value="8">8 decimals</option>
        <option value="10">10 decimals</option>
      </select>
      <label class="ml-2 flex items-center gap-1.5 text-[13px] text-ink-subtle">
        <input id="lc-thousands" type="checkbox" class="accent-[#5e6ad2]" /> Thousands separators
      </label>
    </div>

    <!-- Preset quick conversions -->
    <div class="flex flex-col gap-2">
      <p class="text-[13px] text-ink-subtle">Quick conversions</p>
      <div id="lc-presets" class="flex flex-wrap gap-2"></div>
    </div>

    <!-- All units at once -->
    <div>
      <div class="mb-2 flex items-center justify-between">
        <p class="text-[13px] text-ink-subtle">All units</p>
        <button id="lc-copy-all" type="button" class="btn btn-tertiary h-8 px-2 text-[12px]">Copy all</button>
      </div>
      <div id="lc-table" class="overflow-hidden rounded-md border border-hairline"></div>
    </div>

    <!-- Batch conversion -->
    <details class="rounded-md border border-hairline">
      <summary class="cursor-pointer select-none px-3 py-2 text-[13px] text-ink-subtle">Batch convert (one value per line)</summary>
      <div class="flex flex-col gap-2 border-t border-hairline p-3">
        <p class="text-[12px] text-ink-tertiary">Converts every line from the “From” unit to the “To” unit. Blank or non-numeric lines are skipped.</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <textarea id="lc-batch-in" class="field" rows="6" spellcheck="false" placeholder="1&#10;2.5&#10;100"></textarea>
          <textarea id="lc-batch-out" class="field" rows="6" readonly placeholder="Results appear here"></textarea>
        </div>
        <div class="flex gap-2">
          <button id="lc-batch-run" type="button" class="btn btn-secondary h-9 px-3 text-[13px]">Convert lines</button>
          <button id="lc-batch-copy" type="button" class="btn btn-tertiary h-9 px-3 text-[13px]">Copy results</button>
        </div>
      </div>
    </details>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free length converter converts between metric, imperial, nautical, scientific and astronomical units of length — from ångströms and microns through metres, feet, miles and nautical miles up to astronomical units, light years and parsecs. Every conversion runs entirely in your browser, so nothing you type is uploaded.
    </p>
    <p>
      Beyond a simple from/to conversion it shows the value in <strong>every unit at once</strong>, a plain-language formula, and a feet-and-inches compound readout for heights. You control the output <strong>precision</strong> (auto significant figures or a fixed number of decimals) and optional thousands separators, tap <strong>quick-conversion presets</strong> like cm→in or m→ft, and use <strong>batch mode</strong> to convert a whole column of values at once. Copy any single result or the entire table with one click.
    </p>
  </div>
</ToolLayout>

<script>
  const root = document.getElementById('lc-root') as HTMLElement;
  const UNITS: Record<string, number> = JSON.parse(root.dataset.units!);
  const PRESETS: [string, string][] = JSON.parse(root.dataset.presets!);
  const NAMES = Object.keys(UNITS);

  const fromVal = document.getElementById('lc-from-val') as HTMLInputElement;
  const toVal = document.getElementById('lc-to-val') as HTMLInputElement;
  const fromUnit = document.getElementById('lc-from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('lc-to-unit') as HTMLSelectElement;
  const swap = document.getElementById('lc-swap') as HTMLButtonElement;
  const formula = document.getElementById('lc-formula') as HTMLElement;
  const compound = document.getElementById('lc-compound') as HTMLElement;
  const errEl = document.getElementById('lc-error') as HTMLElement;
  const precision = document.getElementById('lc-precision') as HTMLSelectElement;
  const thousands = document.getElementById('lc-thousands') as HTMLInputElement;
  const presetsEl = document.getElementById('lc-presets') as HTMLElement;
  const table = document.getElementById('lc-table') as HTMLElement;
  const copyTo = document.getElementById('lc-copy-to') as HTMLButtonElement;
  const copyAll = document.getElementById('lc-copy-all') as HTMLButtonElement;
  const batchIn = document.getElementById('lc-batch-in') as HTMLTextAreaElement;
  const batchOut = document.getElementById('lc-batch-out') as HTMLTextAreaElement;
  const batchRun = document.getElementById('lc-batch-run') as HTMLButtonElement;
  const batchCopy = document.getElementById('lc-batch-copy') as HTMLButtonElement;

  const convert = (v: number, from: string, to: string) => (v * UNITS[from]) / UNITS[to];

  // Format a number honouring the precision + separators controls.
  function fmt(n: number): string {
    if (!isFinite(n)) return '∞';
    if (n === 0) return '0';
    const p = precision.value;
    let out: string;
    if (p === 'auto') {
      const abs = Math.abs(n);
      if (abs >= 1e15 || abs < 1e-6) return n.toExponential(6); // sep skipped in sci form
      out = String(Math.round(n * 1e9) / 1e9);
    } else {
      const d = Number(p);
      const abs = Math.abs(n);
      if (abs !== 0 && abs < Math.pow(10, -d) / 2) return n.toExponential(Math.max(2, d));
      out = n.toFixed(d);
    }
    if (thousands.checked && !out.includes('e')) {
      const [int, frac] = out.split('.');
      const sign = int.startsWith('-') ? '-' : '';
      const digits = sign ? int.slice(1) : int;
      const grouped = digits.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      out = sign + grouped + (frac ? '.' + frac : '');
    }
    return out;
  }

  // Parse the input: allows a leading number with optional separators.
  function parseVal(raw: string): number | null {
    const s = raw.trim().replace(/,/g, '');
    if (s === '') return null;
    const n = Number(s);
    return isNaN(n) ? null : n;
  }

  function feetInches(metres: number): string {
    if (!isFinite(metres)) return '';
    const totalInches = metres / 0.0254;
    const neg = totalInches < 0 ? '-' : '';
    const abs = Math.abs(totalInches);
    let ft = Math.floor(abs / 12);
    let inch = abs - ft * 12;
    // guard floating error pushing inches to 12
    if (Math.round(inch * 100) / 100 >= 12) { ft += 1; inch = 0; }
    return `${neg}${ft} ft ${Math.round(inch * 100) / 100} in`;
  }

  function fillUnits() {
    const opts = NAMES.map((u) => `<option>${u}</option>`).join('');
    fromUnit.innerHTML = opts;
    toUnit.innerHTML = opts;
    fromUnit.value = 'Metre';
    toUnit.value = 'Foot';
  }

  function fillPresets() {
    presetsEl.innerHTML = PRESETS.map(([f, t], i) => {
      const label = `${f.replace('Micrometre (micron)', 'µm').replace('Nautical mile', 'nmi')} → ${t.replace('Nautical mile', 'nmi')}`;
      return `<button type="button" data-i="${i}" class="btn btn-tertiary h-8 px-2.5 text-[12px]">${label}</button>`;
    }).join('');
    presetsEl.querySelectorAll('button').forEach((b) => {
      b.addEventListener('click', () => {
        const [f, t] = PRESETS[Number((b as HTMLElement).dataset.i)];
        fromUnit.value = f;
        toUnit.value = t;
        if (parseVal(fromVal.value) === null) fromVal.value = '1';
        run();
      });
    });
  }

  function showError(msg: string) {
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
  }
  function clearError() {
    errEl.classList.add('hidden');
    errEl.textContent = '';
  }

  function run() {
    const v = parseVal(fromVal.value);
    if (v === null) {
      toVal.value = '';
      formula.textContent = '';
      compound.textContent = '';
      table.innerHTML = '';
      if (fromVal.value.trim() !== '') showError('Enter a valid number.');
      else clearError();
      return;
    }
    clearError();
    const result = convert(v, fromUnit.value, toUnit.value);
    toVal.value = fmt(result);
    formula.textContent = `${fmt(v)} ${fromUnit.value} = ${fmt(result)} ${toUnit.value}`;
    compound.textContent = `= ${feetInches(v * UNITS[fromUnit.value])} (feet & inches)`;
    renderTable(v);
  }

  // All-units output: the "from" value expressed in every unit.
  function renderTable(v: number) {
    const rows = NAMES.map((u) => {
      const r = convert(v, fromUnit.value, u);
      const hot = u === toUnit.value ? ' bg-surface-2' : '';
      return `<tr class="border-t border-hairline${hot}">
        <td class="px-3 py-2 text-ink-subtle">${u}</td>
        <td class="px-3 py-2 text-right font-mono text-ink" data-val="${fmt(r)}">${fmt(r)} <span class="text-ink-tertiary">${abbr(u)}</span></td>
      </tr>`;
    }).join('');
    table.innerHTML = `<table class="w-full text-[13px]">${rows}</table>`;
  }

  const ABBR: Record<string, string> = {
    'Ångström': 'Å', Nanometre: 'nm', 'Micrometre (micron)': 'µm', Millimetre: 'mm',
    Centimetre: 'cm', Metre: 'm', Kilometre: 'km', 'Thou (mil)': 'mil', Inch: 'in',
    Hand: 'hh', Foot: 'ft', Yard: 'yd', Fathom: 'ftm', Rod: 'rod', Chain: 'ch',
    Furlong: 'fur', Mile: 'mi', 'Nautical mile': 'nmi', 'Astronomical unit': 'au',
    'Light year': 'ly', Parsec: 'pc',
  };
  const abbr = (u: string) => ABBR[u] || '';

  async function copy(text: string, btn: HTMLElement, ok = 'Copied') {
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      if (btn.textContent && btn.textContent.trim()) { const t = btn.textContent; btn.textContent = ok; setTimeout(() => (btn.textContent = t), 1200); }
    } catch { showError('Clipboard unavailable — copy manually.'); }
  }

  function runBatch() {
    const lines = batchIn.value.split('\n');
    const out = lines.map((line) => {
      if (line.trim() === '') return '';
      const v = parseVal(line);
      if (v === null) return '(invalid)';
      return fmt(convert(v, fromUnit.value, toUnit.value));
    });
    batchOut.value = out.join('\n');
  }

  fromVal.addEventListener('input', run);
  fromUnit.addEventListener('change', run);
  toUnit.addEventListener('change', run);
  precision.addEventListener('change', () => { run(); if (batchOut.value) runBatch(); });
  thousands.addEventListener('change', () => { run(); if (batchOut.value) runBatch(); });
  swap.addEventListener('click', () => {
    const a = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = a;
    const parsed = parseVal(toVal.value);
    if (parsed !== null) fromVal.value = toVal.value.replace(/,/g, '');
    run();
  });
  copyTo.addEventListener('click', () => copy(toVal.value, copyTo));
  copyAll.addEventListener('click', () => {
    const text = NAMES.map((u) => `${u}\t${fmt(convert(parseVal(fromVal.value) ?? 0, fromUnit.value, u))} ${abbr(u)}`).join('\n');
    copy(text, copyAll);
  });
  batchRun.addEventListener('click', runBatch);
  batchCopy.addEventListener('click', () => copy(batchOut.value, batchCopy));

  fillUnits();
  fillPresets();
  run();
</script>

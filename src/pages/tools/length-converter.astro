---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="length-converter">
  <UnitConverter slug="length-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free length converter converts between metric and imperial units of length — metres, kilometres, centimetres, miles, yards, feet and inches — with a live reference table. Every conversion runs entirely in your browser, so nothing you type is uploaded.
    </p>
  </div>
</ToolLayout>

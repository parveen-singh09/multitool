---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="png-to-svg">
  <div class="flex flex-col gap-4">
    <label id="pv-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose a PNG or image and drop it here</span>
      <input id="pv-file" type="file" accept="image/png,image/jpeg,image/webp,image/gif,image/bmp" class="sr-only" />
    </label>

    <div id="pv-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Detail
          <select id="pv-preset" class="field w-40">
            <option value="poster2">Flat (2 colors)</option>
            <option value="poster4">Simple (4 colors)</option>
            <option value="default" selected>Balanced</option>
            <option value="detailed">Detailed</option>
            <option value="custom">Customâ€¦</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Mode
          <select id="pv-mode" class="field w-36">
            <option value="color" selected>Color</option>
            <option value="grayscale">Grayscale</option>
            <option value="bw">Black &amp; white</option>
          </select>
        </label>
        <button id="pv-trace" class="btn btn-primary">Vectorize</button>
        <button id="pv-download" class="btn btn-secondary hidden">Download SVG</button>
      </div>

      <details id="pv-adv" class="panel p-3">
        <summary class="cursor-pointer text-[13px] text-ink-subtle select-none">Advanced tracing controls</summary>
        <div class="mt-3 grid grid-cols-2 gap-x-4 gap-y-3 sm:grid-cols-4">
          <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Colors
            <input id="pv-colors" type="number" min="2" max="64" step="1" value="16" class="field" />
          </label>
          <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Detail (line res)
            <input id="pv-ltres" type="number" min="0.1" max="10" step="0.1" value="1" class="field" />
          </label>
          <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Curve res
            <input id="pv-qtres" type="number" min="0.1" max="10" step="0.1" value="1" class="field" />
          </label>
          <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Despeckle
            <input id="pv-pathomit" type="number" min="0" max="50" step="1" value="8" class="field" title="Discard paths smaller than this (px)" />
          </label>
          <label class="flex flex-col gap-1 text-[13px] text-ink-subtle">Smoothing (blur)
            <input id="pv-blur" type="number" min="0" max="5" step="1" value="0" class="field" />
          </label>
          <label class="flex items-center gap-2 text-[13px] text-ink-subtle sm:col-span-2 sm:self-end">
            <input id="pv-bg" type="checkbox" checked class="h-4 w-4" />
            Keep transparency
          </label>
        </div>
        <p class="mt-2 text-[12px] text-ink-tertiary">Fewer colors and higher despeckle produce smaller, cleaner SVGs. Editing any control switches Detail to Custom.</p>
      </details>

      <p id="pv-status" class="text-[13px] text-ink-subtle"></p>

      <div class="flex flex-wrap items-center gap-2 text-[13px]">
        <span class="text-ink-subtle">View</span>
        <div class="flex gap-1">
          <button id="pv-view-render" class="btn btn-tertiary px-3 py-1" aria-pressed="true">Rendered</button>
          <button id="pv-view-code" class="btn btn-tertiary px-3 py-1" aria-pressed="false">SVG code</button>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div>
          <span class="text-[13px] text-ink-subtle">Original</span>
          <div class="panel mt-1 flex justify-center overflow-hidden p-3"><img id="pv-src" class="max-h-72 w-auto max-w-full rounded-sm" alt="Source" /></div>
        </div>
        <div>
          <span class="text-[13px] text-ink-subtle">SVG result</span>
          <div id="pv-out" class="pv-checker panel mt-1 flex max-h-80 items-center justify-center overflow-auto p-3 text-ink-tertiary text-[13px]">Not vectorized yet</div>
          <div id="pv-code-wrap" class="copy-wrap mt-1 hidden"><pre class="hl-block field" style="height:20rem;margin:0;overflow:auto;white-space:pre"><code id="pv-code" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#pv-code" aria-label="Copy"></button></div>
        </div>
      </div>
    </div>
    <p id="pv-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PNG to SVG converter vectorizes raster images (PNG, JPG, WebP,
      GIF and BMP) into scalable vector graphics by tracing areas of color into
      paths. It works best on logos, icons and simple flat graphics rather than
      detailed photos. Pick a detail preset, choose color, grayscale or
      black-and-white output, then vectorize and download a
      resolution-independent SVG.
    </p>
    <p>
      Advanced controls let you tune the number of colors, line and curve
      precision, despeckling (which drops tiny stray paths), and smoothing, and
      you can preserve or flatten transparency. Switch between the rendered
      preview â€” shown on a checkerboard so transparency is visible â€” and the raw
      SVG code, which is syntax-highlighted so you can inspect the generated
      markup, copy it to the clipboard, or download it as a file. The status line
      reports the output size and how many paths were produced so you can trade
      detail against file size.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }

  .pv-checker {
    background-image:
      linear-gradient(45deg, #1b1c1d 25%, transparent 25%),
      linear-gradient(-45deg, #1b1c1d 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #1b1c1d 75%),
      linear-gradient(-45deg, transparent 75%, #1b1c1d 75%);
    background-size: 16px 16px;
    background-position: 0 0, 0 8px, 8px -8px, -8px 0;
  }
  .pv-checker.pv-flat { background-image: none; }
</style>

<script>
  import ImageTracer from 'imagetracerjs';
  import { hl } from '../../lib/highlight';

  const fileInput = document.getElementById('pv-file') as HTMLInputElement;
  const drop = document.getElementById('pv-drop')!;
  const panel = document.getElementById('pv-panel')!;
  const srcImg = document.getElementById('pv-src') as HTMLImageElement;
  const outBox = document.getElementById('pv-out')!;
  const codeWrap = document.getElementById('pv-code-wrap')!;
  const codeEl = document.getElementById('pv-code')!;
  const status = document.getElementById('pv-status')!;
  const err = document.getElementById('pv-error')!;
  const presetSel = document.getElementById('pv-preset') as HTMLSelectElement;
  const modeSel = document.getElementById('pv-mode') as HTMLSelectElement;
  const dlBtn = document.getElementById('pv-download') as HTMLButtonElement;
  const viewRenderBtn = document.getElementById('pv-view-render') as HTMLButtonElement;
  const viewCodeBtn = document.getElementById('pv-view-code') as HTMLButtonElement;

  const colorsEl = document.getElementById('pv-colors') as HTMLInputElement;
  const ltresEl = document.getElementById('pv-ltres') as HTMLInputElement;
  const qtresEl = document.getElementById('pv-qtres') as HTMLInputElement;
  const pathomitEl = document.getElementById('pv-pathomit') as HTMLInputElement;
  const blurEl = document.getElementById('pv-blur') as HTMLInputElement;
  const bgEl = document.getElementById('pv-bg') as HTMLInputElement;
  const advCtl = [colorsEl, ltresEl, qtresEl, pathomitEl, blurEl];

  let dataUrl = '';
  let fileName = 'image';
  let svg = '';
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  const PRESETS: Record<string, { colors: number; ltres: number; qtres: number; pathomit: number }> = {
    poster2: { colors: 2, ltres: 1, qtres: 1, pathomit: 8 },
    poster4: { colors: 4, ltres: 1, qtres: 1, pathomit: 8 },
    default: { colors: 16, ltres: 1, qtres: 1, pathomit: 8 },
    detailed: { colors: 32, ltres: 0.5, qtres: 0.5, pathomit: 1 },
  };

  function applyPreset() {
    const p = PRESETS[presetSel.value];
    if (!p) return; 
    colorsEl.value = String(p.colors);
    ltresEl.value = String(p.ltres);
    qtresEl.value = String(p.qtres);
    pathomitEl.value = String(p.pathomit);
    blurEl.value = '0';
  }

  const clampNum = (el: HTMLInputElement, def: number) => {
    const v = Number(el.value);
    if (!Number.isFinite(v)) return def;
    const min = Number(el.min), max = Number(el.max);
    return Math.min(Math.max(v, min), max);
  };

  const BW_PAL = [{ r: 0, g: 0, b: 0, a: 255 }, { r: 255, g: 255, b: 255, a: 255 }];

  const grayPal = (n: number) => Array.from({ length: n }, (_, i) => {
    const v = n === 1 ? 0 : Math.round((i / (n - 1)) * 255);
    return { r: v, g: v, b: v, a: 255 };
  });

  function buildOptions(): any {
    const mode = modeSel.value;
    const colors = Math.round(clampNum(colorsEl, 16));
    const o: any = {
      numberofcolors: colors,
      ltres: clampNum(ltresEl, 1),
      qtres: clampNum(qtresEl, 1),
      pathomit: Math.round(clampNum(pathomitEl, 8)),
      blurradius: Math.round(clampNum(blurEl, 0)),
      viewbox: true,
    };
    if (mode === 'bw') { o.pal = BW_PAL; o.numberofcolors = 2; }
    else if (mode === 'grayscale') { o.pal = grayPal(Math.max(2, colors)); }
    return o;
  }

  function loadFile(file: File) {
    setErr('');
    if (!/^image\//.test(file.type)) {
      setErr('That does not look like an image file. Use a PNG, JPG, WebP, GIF or BMP.');
      return;
    }
    fileName = file.name.replace(/\.[^.]+$/, '') || 'image';
    const reader = new FileReader();
    reader.onerror = () => setErr('Could not read that file.');
    reader.onload = () => {
      dataUrl = reader.result as string;
      srcImg.src = dataUrl;
      panel.classList.remove('hidden'); panel.classList.add('flex');
      status.textContent = `${file.name} ready â€” click Vectorize.`;
      outBox.textContent = 'Not vectorized yet';
      svg = '';
      dlBtn.classList.add('hidden');
      showView('render');
    };
    reader.readAsDataURL(file);
  }

  function showView(which: 'render' | 'code') {
    const code = which === 'code';
    outBox.classList.toggle('hidden', code);
    codeWrap.classList.toggle('hidden', !code);
    viewCodeBtn.setAttribute('aria-pressed', String(code));
    viewRenderBtn.setAttribute('aria-pressed', String(!code));
  }

  function trace() {
    if (!dataUrl) return;
    setErr('');
    status.textContent = 'Vectorizingâ€¦ this can take a few seconds for large images.';
    // let the status paint before the heavy synchronous trace
    setTimeout(() => {
      try {
        ImageTracer.imageToSVG(dataUrl, async (svgstr: string) => {
          try {
            svg = svgstr;
            // Flatten transparency to white if the user opted out of keeping it.
            if (!bgEl.checked) {
              svg = svg.replace(/<svg([^>]*)>/, '<svg$1><rect width="100%" height="100%" fill="#ffffff"/>');
            }
            outBox.innerHTML = svg;
            outBox.classList.toggle('pv-flat', !bgEl.checked);
            const el = outBox.querySelector('svg');
            if (el) {
              el.removeAttribute('width'); el.removeAttribute('height');
              (el as SVGElement).style.maxWidth = '100%';
              (el as SVGElement).style.maxHeight = '18rem';
            }
            await hl(codeEl, svg, 'xml');
            const kb = (new Blob([svg]).size / 1024).toFixed(1);
            const paths = (svg.match(/<path/g) || []).length;
            status.textContent = `Done â€” ${kb} KB Â· ${paths} ${paths === 1 ? 'path' : 'paths'}.`;
            dlBtn.classList.remove('hidden');
          } catch (e) {
            setErr('Could not render the result: ' + (e as Error).message); status.textContent = '';
          }
        }, buildOptions());
      } catch (e) { setErr('Could not vectorize that image: ' + (e as Error).message); status.textContent = ''; }
    }, 30);
  }

  // Editing any advanced control means the preset no longer describes the settings.
  advCtl.forEach((el) => el.addEventListener('input', () => { presetSel.value = 'custom'; }));
  presetSel.addEventListener('change', applyPreset);

  dlBtn.addEventListener('click', () => {
    if (!svg) return;
    const blob = new Blob([svg], { type: 'image/svg+xml' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = `${fileName}.svg`; a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 1000);
  });

  viewRenderBtn.addEventListener('click', () => showView('render'));
  viewCodeBtn.addEventListener('click', () => showView('code'));

  fileInput.addEventListener('change', () => fileInput.files?.[0] && loadFile(fileInput.files[0]));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) loadFile(f); });
  document.getElementById('pv-trace')!.addEventListener('click', trace);
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ColorFormats from '../../components/ColorFormats.astro';
---

<ToolLayout slug="hex-to-rgb">
  <ColorFormats focus="rgb" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free HEX to RGB converter turns any hex color code into its red,
      green and blue values instantly. Type a hex code like <code>#5e6ad2</code>
      (or use the picker) and read the matching <code>rgb()</code> string, ready
      to paste into CSS. It also shows HSL, HSV and CMYK, plus the nearest named
      color. All conversion runs in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

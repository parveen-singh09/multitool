---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="workout-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Focus
        <select id="wo-focus" class="field w-40"><option value="full">Full body</option><option value="upper">Upper body</option><option value="lower">Lower body</option><option value="core">Core</option><option value="cardio">Cardio</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Level
        <select id="wo-level" class="field w-36"><option value="beginner">Beginner</option><option value="intermediate" selected>Intermediate</option><option value="advanced">Advanced</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Exercises
        <input id="wo-count" type="number" min="3" max="10" value="6" class="field w-24" />
      </label>
      <button id="wo-gen" class="btn btn-primary ml-auto">Generate</button>
    </div>
    <div id="wo-out" class="panel panel-lift flex flex-col gap-2 p-5"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free workout generator builds a random routine by focus area — full
      body, upper, lower, core or cardio — with sets and reps scaled to your level.
      Most moves are bodyweight or lightly-equipped so you can do them at home or
      the gym. Always warm up first and stop if something hurts; this is general
      inspiration, not medical or fitness advice. Runs in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { sample, pick } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('wo-out')!;

  const MOVES: Record<string, string[]> = {
    upper: ['Push-ups', 'Pike push-ups', 'Dips', 'Pull-ups', 'Bicep curls', 'Shoulder press', 'Tricep extensions', 'Bent-over rows'],
    lower: ['Squats', 'Lunges', 'Glute bridges', 'Calf raises', 'Wall sit', 'Step-ups', 'Bulgarian split squats', 'Deadlifts'],
    core: ['Plank', 'Bicycle crunches', 'Russian twists', 'Leg raises', 'Mountain climbers', 'Dead bug', 'Hollow hold', 'Side plank'],
    cardio: ['Jumping jacks', 'High knees', 'Burpees', 'Butt kicks', 'Skater hops', 'Jump rope', 'Sprint intervals', 'Mountain climbers'],
  };

  const REPS: Record<string, [number, number]> = { beginner: [2, 10], intermediate: [3, 12], advanced: [4, 15] };

  function pool(focus: string): string[] {
    if (focus === 'full') return [...MOVES.upper, ...MOVES.lower, ...MOVES.core];
    return MOVES[focus];
  }

  function generate() {
    const focus = ($('wo-focus') as HTMLSelectElement).value;
    const level = ($('wo-level') as HTMLSelectElement).value;
    const n = Math.max(3, Math.min(10, Number(($('wo-count') as HTMLInputElement).value) || 6));
    const [sets, baseReps] = REPS[level];
    const moves = sample(pool(focus), Math.min(n, pool(focus).length));
    const isCardio = focus === 'cardio';
    out.innerHTML = `
      <h2 class="mb-2 text-lg font-semibold text-ink">${focus === 'full' ? 'Full body' : focus[0].toUpperCase() + focus.slice(1)} • ${level}</h2>
      <ol class="flex flex-col gap-2">${moves.map((m, i) => {
        const reps = isCardio ? `${30 + Number(level === 'advanced') * 15}s` : `${baseReps + (i % 3)} reps`;
        return `<li class="flex items-center justify-between border-b border-hairline pb-2"><span class="text-[15px] text-ink">${i + 1}. ${m}</span><span class="font-mono text-[13px] text-ink-subtle">${sets} × ${reps}</span></li>`;
      }).join('')}</ol>
      <p class="mt-2 text-[13px] text-ink-tertiary">Rest 45–90s between sets. Warm up before and stretch after.</p>`;
  }

  ['wo-focus', 'wo-level', 'wo-count'].forEach((id) => $(id).addEventListener('input', generate));
  $('wo-gen').addEventListener('click', generate);
  generate();
</script>

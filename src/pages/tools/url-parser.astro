---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="url-parser">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      URL
      <input
        id="up-in"
        type="text"
        class="field font-mono text-[13px]"
        placeholder="https://user:pass@example.com:8080/path/page?q=hello%20world&lang=en#section"
        spellcheck="false"
        value="https://user:pass@example.com:8080/path/page?q=hello%20world&lang=en&lang=fr#section"
      />
    </label>

    <p id="up-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="up-results" class="flex flex-col gap-4">
      <div class="panel p-4">
        <div class="grid grid-cols-[minmax(90px,auto)_1fr] gap-x-4 gap-y-2 text-sm">
          <div class="text-ink-subtle">Protocol</div><div id="up-protocol" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Username</div><div id="up-username" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Password</div><div id="up-password" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Host</div><div id="up-host" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Hostname</div><div id="up-hostname" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Port</div><div id="up-port" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Pathname</div><div id="up-pathname" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Search</div><div id="up-search" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Hash</div><div id="up-hash" class="font-mono text-[13px] text-ink break-all">—</div>
          <div class="text-ink-subtle">Origin</div><div id="up-origin" class="font-mono text-[13px] text-ink break-all">—</div>
        </div>
      </div>

      <div id="up-params-wrap" class="panel p-4">
        <div class="mb-2 text-sm text-ink-subtle">Query parameters (decoded)</div>
        <div id="up-params" class="flex flex-col gap-2"></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free URL parser splits any URL into its components using the browser's
      native <code>URL</code> API. It shows the protocol, host, hostname, port,
      pathname, search string and fragment, and lists every query parameter as a
      decoded key-value pair. Paste a link to inspect its structure or debug a
      redirect. Parsing runs entirely in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('up-in') as HTMLInputElement;
  const err = document.getElementById('up-error')!;
  const results = document.getElementById('up-results')!;
  const paramsWrap = document.getElementById('up-params-wrap')!;
  const paramsEl = document.getElementById('up-params')!;

  const fields: Record<string, string> = {
    protocol: 'up-protocol',
    username: 'up-username',
    password: 'up-password',
    host: 'up-host',
    hostname: 'up-hostname',
    port: 'up-port',
    pathname: 'up-pathname',
    search: 'up-search',
    hash: 'up-hash',
    origin: 'up-origin',
  };

  function setError(msg: string) {
    err.textContent = msg;
    err.classList.remove('hidden');
    results.classList.add('hidden');
  }

  function parse() {
    const raw = input.value.trim();
    if (!raw) {
      err.classList.add('hidden');
      results.classList.add('hidden');
      return;
    }

    let url: URL;
    try {
      url = new URL(raw);
    } catch {
      setError('Invalid URL. Include a scheme, e.g. https://example.com/path?a=1');
      return;
    }

    err.classList.add('hidden');
    results.classList.remove('hidden');

    for (const [key, id] of Object.entries(fields)) {
      const val = (url as unknown as Record<string, string>)[key];
      document.getElementById(id)!.textContent = val && val !== '' ? val : '—';
    }

    paramsEl.textContent = '';
    const entries = [...url.searchParams.entries()];
    if (!entries.length) {
      paramsWrap.classList.add('hidden');
      return;
    }
    paramsWrap.classList.remove('hidden');
    for (const [key, value] of entries) {
      const row = document.createElement('div');
      row.className = 'grid grid-cols-[minmax(90px,auto)_1fr] gap-x-4 border-t border-white/5 pt-2 text-sm first:border-0 first:pt-0';
      const k = document.createElement('div');
      k.className = 'font-mono text-[13px] text-primary-hover break-all';
      k.textContent = key;
      const v = document.createElement('div');
      v.className = 'font-mono text-[13px] text-ink break-all';
      v.textContent = value === '' ? '(empty)' : value;
      row.append(k, v);
      paramsEl.append(row);
    }
  }

  input.addEventListener('input', parse);
  parse();
</script>

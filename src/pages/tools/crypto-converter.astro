---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="crypto-converter">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-2">
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="cr-from-val">Cryptocurrency</label>
        <input id="cr-from-val" type="number" class="field" value="1" inputmode="decimal" />
        <div class="relative mt-1">
          <button
            id="cr-from-trigger"
            type="button"
            class="field flex w-full items-center gap-2 text-left"
            aria-haspopup="listbox"
            aria-expanded="false"
          >
            <span id="cr-from-icon" class="flex shrink-0 items-center"></span>
            <span id="cr-from-label" class="min-w-0 flex-1 truncate">Bitcoin</span>
            <svg class="shrink-0 text-ink-tertiary" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <ul
            id="cr-from-list"
            role="listbox"
            tabindex="-1"
            aria-label="Cryptocurrency"
            class="absolute z-20 mt-1 hidden max-h-72 w-full overflow-auto rounded-[8px] border border-hairline bg-surface-1 py-1 shadow-xl"
          ></ul>
        </div>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="cr-to-val">Currency</label>
        <input id="cr-to-val" type="number" class="field" readonly />
        <select id="cr-to" class="field mt-1"></select>
      </div>
    </div>

    <p id="cr-rate" class="flex items-center gap-1.5 text-[13px] text-ink-tertiary"></p>

    <div>
      <p id="cr-table-label" class="mb-2 text-[13px] text-ink-subtle">Market prices</p>
      <div id="cr-table" class="max-h-80 overflow-auto rounded-[8px] border border-hairline"></div>
    </div>

    <p id="cr-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free cryptocurrency converter uses live market prices to convert from
      any of 100 major coins — Bitcoin, Ethereum, Solana and more — into any of
      166 world currencies. Enter an amount, choose the coin and target currency,
      and see the value plus a live price table. Crypto prices come from a public
      market-data service and exchange rates from a public FX service, fetched
      directly from your browser; no account is needed and nothing you enter is
      stored. Crypto prices are volatile, so treat figures as indicative.
    </p>
  </div>
</ToolLayout>

<script>
  // CoinGecko coin id -> [symbol, name]. 100 major coins.
  const COINS: Record<string, [string, string]> = {
    bitcoin: ['BTC', 'Bitcoin'], ethereum: ['ETH', 'Ethereum'], tether: ['USDT', 'Tether'],
    ripple: ['XRP', 'XRP'], binancecoin: ['BNB', 'BNB'], solana: ['SOL', 'Solana'],
    'usd-coin': ['USDC', 'USD Coin'], dogecoin: ['DOGE', 'Dogecoin'], cardano: ['ADA', 'Cardano'],
    tron: ['TRX', 'TRON'], 'the-open-network': ['TON', 'Toncoin'], chainlink: ['LINK', 'Chainlink'],
    'avalanche-2': ['AVAX', 'Avalanche'], 'shiba-inu': ['SHIB', 'Shiba Inu'], 'wrapped-bitcoin': ['WBTC', 'Wrapped Bitcoin'],
    sui: ['SUI', 'Sui'], stellar: ['XLM', 'Stellar'], 'hedera-hashgraph': ['HBAR', 'Hedera'],
    polkadot: ['DOT', 'Polkadot'], 'bitcoin-cash': ['BCH', 'Bitcoin Cash'], litecoin: ['LTC', 'Litecoin'],
    'leo-token': ['LEO', 'LEO Token'], hyperliquid: ['HYPE', 'Hyperliquid'], uniswap: ['UNI', 'Uniswap'],
    dai: ['DAI', 'Dai'], monero: ['XMR', 'Monero'], pepe: ['PEPE', 'Pepe'],
    aptos: ['APT', 'Aptos'], near: ['NEAR', 'NEAR Protocol'], aave: ['AAVE', 'Aave'],
    okb: ['OKB', 'OKB'], 'internet-computer': ['ICP', 'Internet Computer'], 'ethereum-classic': ['ETC', 'Ethereum Classic'],
    'ondo-finance': ['ONDO', 'Ondo'], mantle: ['MNT', 'Mantle'], 'crypto-com-chain': ['CRO', 'Cronos'],
    vechain: ['VET', 'VeChain'], 'render-token': ['RENDER', 'Render'], arbitrum: ['ARB', 'Arbitrum'],
    cosmos: ['ATOM', 'Cosmos'], filecoin: ['FIL', 'Filecoin'], kaspa: ['KAS', 'Kaspa'],
    algorand: ['ALGO', 'Algorand'], 'fetch-ai': ['FET', 'Artificial Superintelligence'], optimism: ['OP', 'Optimism'],
    'injective-protocol': ['INJ', 'Injective'], blockstack: ['STX', 'Stacks'], 'first-digital-usd': ['FDUSD', 'First Digital USD'],
    maker: ['MKR', 'Maker'], 'immutable-x': ['IMX', 'Immutable'], bonk: ['BONK', 'Bonk'],
    'the-graph': ['GRT', 'The Graph'], 'theta-token': ['THETA', 'Theta Network'], 'worldcoin-wld': ['WLD', 'Worldcoin'],
    'sei-network': ['SEI', 'Sei'], floki: ['FLOKI', 'Floki'], 'jupiter-exchange-solana': ['JUP', 'Jupiter'],
    gala: ['GALA', 'Gala'], tezos: ['XTZ', 'Tezos'], flow: ['FLOW', 'Flow'],
    'quant-network': ['QNT', 'Quant'], bittensor: ['TAO', 'Bittensor'], celestia: ['TIA', 'Celestia'],
    thorchain: ['RUNE', 'THORChain'], jasmycoin: ['JASMY', 'JasmyCoin'], 'kucoin-shares': ['KCS', 'KuCoin'],
    'lido-dao': ['LDO', 'Lido DAO'], 'pyth-network': ['PYTH', 'Pyth Network'], 'gatechain-token': ['GT', 'Gate'],
    nexo: ['NEXO', 'Nexo'], raydium: ['RAY', 'Raydium'], ethena: ['ENA', 'Ethena'],
    dogwifcoin: ['WIF', 'dogwifhat'], 'akash-network': ['AKT', 'Akash Network'], helium: ['HNT', 'Helium'],
    'curve-dao-token': ['CRV', 'Curve DAO'], 'mina-protocol': ['MINA', 'Mina'], dydx: ['DYDX', 'dYdX'],
    'pancakeswap-token': ['CAKE', 'PancakeSwap'], ecash: ['XEC', 'eCash'], neo: ['NEO', 'NEO'],
    iota: ['IOTA', 'IOTA'], 'oasis-network': ['ROSE', 'Oasis'], chiliz: ['CHZ', 'Chiliz'],
    'conflux-token': ['CFX', 'Conflux'], kava: ['KAVA', 'Kava'], 'elrond-erd-2': ['EGLD', 'MultiversX'],
    zcash: ['ZEC', 'Zcash'], eos: ['EOS', 'EOS'], arweave: ['AR', 'Arweave'],
    gnosis: ['GNO', 'Gnosis'], blur: ['BLUR', 'Blur'], 'axie-infinity': ['AXS', 'Axie Infinity'],
    'the-sandbox': ['SAND', 'The Sandbox'], decentraland: ['MANA', 'Decentraland'], 'compound-governance-token': ['COMP', 'Compound'],
    '1inch': ['1INCH', '1inch'], 'basic-attention-token': ['BAT', 'Basic Attention Token'], zilliqa: ['ZIL', 'Zilliqa'],
    'dash': ['DASH', 'Dash'],
  };

  // ISO 4217 currency codes. 166 world currencies; names via Intl.DisplayNames.
  const FIAT_CODES: string[] = [
    'USD','EUR','GBP','JPY','CNY','INR','AUD','CAD','CHF','HKD','SGD','SEK','KRW','NOK','NZD',
    'MXN','ZAR','BRL','DKK','PLN','TWD','THB','MYR','RUB','SAR','AED','TRY','IDR','CZK','ILS',
    'CLP','PHP','COP','HUF','ARS','EGP','QAR','KWD','NGN','VND','BDT','PKR','RON','UAH','PEN',
    'KZT','DZD','MAD','KES','IQD','OMR','LKR','GHS','BHD','TND','LBP','JOD','BYN','MMK','UZS',
    'NPR','AFN','ALL','AMD','ANG','AOA','AWG','AZN','BAM','BBD','BGN','BIF','BMD','BND','BOB',
    'BSD','BTN','BWP','BZD','CDF','CRC','CUP','CVE','DJF','DOP','ERN','ETB','FJD','FKP','GEL',
    'GGP','GIP','GMD','GNF','GTQ','GYD','HNL','HRK','HTG','IMP','IRR','ISK','JEP','JMD','KGS',
    'KHR','KMF','KYD','LAK','LRD','LSL','LYD','MDL','MGA','MKD','MNT','MOP','MRU','MUR','MVR',
    'MWK','MZN','NAD','NIO','PAB','PGK','PYG','RSD','RWF','SBD','SCR','SDG','SHP','SLE','SOS',
    'SRD','SSP','STN','SYP','SZL','TJS','TMT','TOP','TTD','TZS','UGX','UYU','VES','VUV','WST',
    'XAF','XCD','XOF','XPF','YER','ZMW','ZWL','FOK','KID','TVD','XDR',
    'CUC','SVC','ZWG','VED','SLL',
  ];

  const fromVal = document.getElementById('cr-from-val') as HTMLInputElement;
  const toVal = document.getElementById('cr-to-val') as HTMLInputElement;
  const fromTrigger = document.getElementById('cr-from-trigger') as HTMLButtonElement;
  const fromList = document.getElementById('cr-from-list') as HTMLUListElement;
  const fromIcon = document.getElementById('cr-from-icon')!;
  const fromLabel = document.getElementById('cr-from-label')!;
  const toSel = document.getElementById('cr-to') as HTMLSelectElement;
  const rateLine = document.getElementById('cr-rate')!;
  const table = document.getElementById('cr-table')!;
  const tableLabel = document.getElementById('cr-table-label')!;
  const err = document.getElementById('cr-error')!;

  // Selected CoinGecko id for the custom cryptocurrency dropdown.
  let fromId = 'bitcoin';

  // USD price of one coin, keyed by CoinGecko id.
  let coinUsd: Record<string, number> = {};
  // Icon URL for one coin, keyed by CoinGecko id.
  let coinImg: Record<string, string> = {};
  // Units of currency per 1 USD, keyed by ISO code.
  let fx: Record<string, number> = {};

  let ccyName: { of: (c: string) => string | undefined };
  try { ccyName = new Intl.DisplayNames(undefined, { type: 'currency' }); }
  catch { ccyName = { of: (c) => c }; }
  const currencyName = (code: string) => {
    const n = ccyName.of(code);
    return n && n !== code ? n : code;
  };

  const fmt = (n: number, max = 6) =>
    new Intl.NumberFormat(undefined, { maximumFractionDigits: max }).format(n);

  // Coin icon <img>; empty string when no icon is known so layout stays stable.
  const iconImg = (id: string, size = 16) => {
    const src = coinImg[id];
    if (!src) return '';
    return `<img src="${src}" width="${size}" height="${size}" loading="lazy" alt=""
      class="inline-block shrink-0 rounded-full" style="width:${size}px;height:${size}px" />`;
  };

  // Format with the currency's own symbol (e.g. $, €, £); fall back to code
  // for non-ISO or unsupported codes.
  const fmtCcy = (n: number, code: string) => {
    try {
      return new Intl.NumberFormat(undefined, {
        style: 'currency', currency: code, maximumFractionDigits: 2,
      }).format(n);
    } catch {
      return `${fmt(n, 2)} ${code}`;
    }
  };

  function fillSelects() {
    // Custom cryptocurrency listbox: one option row per coin, icon + symbol + name.
    fromList.innerHTML = Object.entries(COINS)
      .map(([id, [sym, name]], i) => `
        <li role="option" id="cr-opt-${i}" data-id="${id}" aria-selected="${id === fromId}"
          class="flex cursor-pointer items-center gap-2 px-3 py-2 text-[15px] text-ink-subtle aria-selected:bg-surface-2 hover:bg-surface-2">
          <span class="cr-opt-icon flex shrink-0 items-center"></span>
          <span class="min-w-0 flex-1 truncate">${sym} <span class="text-ink-tertiary">${name}</span></span>
        </li>`)
      .join('');
    updateFromTrigger();

    // De-duplicate codes while preserving order, then sort names alphabetically.
    const seen = new Set<string>();
    const codes = FIAT_CODES.filter((c) => (seen.has(c) ? false : seen.add(c)));
    codes.sort((a, b) => currencyName(a).localeCompare(currencyName(b)));
    toSel.innerHTML = codes
      .map((code) => `<option value="${code}">${code} — ${currencyName(code)}</option>`)
      .join('');
    toSel.value = 'USD';
  }

  // Reflect the selected coin in the trigger button (icon + name).
  function updateFromTrigger() {
    const entry = COINS[fromId];
    if (!entry) return;
    const [sym, name] = entry;
    fromIcon.innerHTML = iconImg(fromId);
    fromLabel.textContent = `${sym} — ${name}`;
  }

  // Paint icons into the trigger and every listbox row once images have loaded.
  function paintCoinIcons() {
    fromIcon.innerHTML = iconImg(fromId);
    fromList.querySelectorAll<HTMLElement>('li[data-id]').forEach((li) => {
      const holder = li.querySelector<HTMLElement>('.cr-opt-icon');
      if (holder) holder.innerHTML = iconImg(li.dataset.id!);
    });
  }

  function openList() {
    fromList.classList.remove('hidden');
    fromTrigger.setAttribute('aria-expanded', 'true');
    const sel = fromList.querySelector<HTMLElement>('li[aria-selected="true"]');
    (sel ?? fromList.querySelector<HTMLElement>('li'))?.scrollIntoView({ block: 'nearest' });
  }

  function closeList() {
    fromList.classList.add('hidden');
    fromTrigger.setAttribute('aria-expanded', 'false');
  }

  function selectFrom(id: string) {
    fromId = id;
    fromList.querySelectorAll<HTMLElement>('li[data-id]').forEach((li) =>
      li.setAttribute('aria-selected', String(li.dataset.id === id)),
    );
    updateFromTrigger();
    closeList();
    fromTrigger.focus();
    convert();
  }

  function convert() {
    if (!Object.keys(coinUsd).length || !Object.keys(fx).length) return;
    const v = Number(fromVal.value);
    const usd = coinUsd[fromId];
    const rate = fx[toSel.value];
    if (isNaN(v) || usd === undefined || rate === undefined) { toVal.value = ''; rateLine.textContent = ''; return; }
    const perUnit = usd * rate; // value of 1 coin in the target currency
    toVal.value = String(Math.round(v * perUnit * 1e8) / 1e8);
    const sym = COINS[fromId][0];
    rateLine.innerHTML = `${iconImg(fromId)}<span>1 ${sym} = ${fmtCcy(perUnit, toSel.value)}</span>`;
  }

  function renderTable() {
    const rate = fx[toSel.value];
    if (rate === undefined) { table.innerHTML = ''; return; }
    tableLabel.textContent = `Market prices (${toSel.value})`;
    const rows = Object.entries(COINS).map(([id, [sym, name]]) => {
      const usd = coinUsd[id];
      if (usd === undefined) return '';
      return `<tr class="border-t border-hairline">
        <td class="px-3 py-2 text-ink-subtle">
          <span class="flex items-center gap-2">${iconImg(id)}<span>${sym} <span class="text-ink-tertiary">${name}</span></span></span>
        </td>
        <td class="px-3 py-2 text-right font-mono text-ink">${fmtCcy(usd * rate, toSel.value)}</td>
      </tr>`;
    }).join('');
    table.innerHTML = `<table class="w-full text-[13px]">${rows}</table>`;
  }

  async function loadPrices() {
    try {
      const ids = Object.keys(COINS).join(',');
      // /coins/markets returns price and an official icon URL per coin in one call.
      const [priceRes, fxRes] = await Promise.all([
        fetch(`https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids=${ids}&per_page=250`),
        fetch('https://open.er-api.com/v6/latest/USD'),
      ]);
      if (!priceRes.ok) throw new Error('price status ' + priceRes.status);
      if (!fxRes.ok) throw new Error('fx status ' + fxRes.status);
      const priceJson = await priceRes.json();
      const fxJson = await fxRes.json();
      const markets = priceJson as Array<{ id: string; current_price?: number; image?: string }>;
      coinUsd = Object.fromEntries(
        markets
          .filter((m) => typeof m.current_price === 'number')
          .map((m) => [m.id, m.current_price as number]),
      );
      coinImg = Object.fromEntries(
        markets
          .filter((m) => typeof m.image === 'string')
          .map((m) => [m.id, m.image as string]),
      );
      fx = (fxJson.rates ?? {}) as Record<string, number>;
      if (!Object.keys(coinUsd).length || !Object.keys(fx).length) throw new Error('empty');
      paintCoinIcons();
      convert();
      renderTable();
    } catch (e) {
      err.textContent = 'Could not load live prices. The market-data or FX service may be rate-limited — wait a moment and refresh. An internet connection is required.';
      err.classList.remove('hidden');
    }
  }

  fromVal.addEventListener('input', convert);
  toSel.addEventListener('change', () => { convert(); renderTable(); });

  // --- Custom cryptocurrency dropdown interaction ---
  const isOpen = () => !fromList.classList.contains('hidden');

  fromTrigger.addEventListener('click', () => (isOpen() ? closeList() : openList()));

  fromList.addEventListener('click', (e) => {
    const li = (e.target as HTMLElement).closest<HTMLElement>('li[data-id]');
    if (li) selectFrom(li.dataset.id!);
  });

  // Roving highlight for keyboard users; tracks the "active" option separately
  // from the committed selection.
  const options = () => Array.from(fromList.querySelectorAll<HTMLElement>('li[data-id]'));
  const setActive = (el: HTMLElement | null) => {
    if (!el) return;
    fromList.querySelectorAll('li.cr-active').forEach((n) => n.classList.remove('cr-active', 'bg-surface-2'));
    el.classList.add('cr-active', 'bg-surface-2');
    el.scrollIntoView({ block: 'nearest' });
    fromList.setAttribute('aria-activedescendant', el.id);
  };
  const activeEl = () => fromList.querySelector<HTMLElement>('li.cr-active');

  fromTrigger.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      openList();
      setActive(fromList.querySelector<HTMLElement>('li[aria-selected="true"]') ?? options()[0]);
      fromList.focus();
    }
  });

  fromList.addEventListener('keydown', (e) => {
    const opts = options();
    const cur = activeEl();
    const idx = cur ? opts.indexOf(cur) : -1;
    if (e.key === 'ArrowDown') { e.preventDefault(); setActive(opts[Math.min(idx + 1, opts.length - 1)] ?? opts[0]); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(opts[Math.max(idx - 1, 0)]); }
    else if (e.key === 'Home') { e.preventDefault(); setActive(opts[0]); }
    else if (e.key === 'End') { e.preventDefault(); setActive(opts[opts.length - 1]); }
    else if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); if (cur) selectFrom(cur.dataset.id!); }
    else if (e.key === 'Escape') { e.preventDefault(); closeList(); fromTrigger.focus(); }
  });

  document.addEventListener('click', (e) => {
    if (isOpen() && !fromTrigger.contains(e.target as Node) && !fromList.contains(e.target as Node)) closeList();
  });

  fillSelects();
  loadPrices();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="music-analyzer">
  <div class="flex flex-col gap-5">
    <label id="ma-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      <span class="text-sm text-ink">Choose a song or drop it here</span>
      <span class="text-[13px] text-ink-tertiary">Analyzed in your browser — never uploaded, no size limit</span>
      <input id="ma-file" type="file" accept="audio/*" class="sr-only" />
    </label>

    <div class="flex flex-wrap items-center gap-2">
      <button id="ma-mic" class="btn btn-secondary">Analyze from microphone</button>
      <button id="ma-sample" class="btn btn-secondary">Try a sample</button>
      <span id="ma-name" class="text-[13px] text-ink-subtle"></span>
    </div>

    <div id="ma-progwrap" class="hidden flex-col gap-1">
      <div class="h-1.5 w-full overflow-hidden rounded-full bg-surface-3"><div id="ma-bar" class="h-full w-0 rounded-full transition-all" style="background:var(--color-primary)"></div></div>
      <span id="ma-status" class="text-[13px] text-ink-subtle"></span>
    </div>

    <div id="ma-results" class="hidden flex-col gap-5">
      <!-- Primary metric tiles -->
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        <div class="panel panel-lift flex flex-col gap-1 p-4">
          <span class="text-xs text-ink-tertiary">Tempo</span>
          <span class="font-display text-3xl font-semibold text-ink"><span id="ma-bpm">—</span><span class="ml-1 text-base font-normal text-ink-subtle">BPM</span></span>
          <span id="ma-bpm-conf" class="text-xs text-ink-tertiary"></span>
        </div>
        <div class="panel panel-lift flex flex-col gap-1 p-4">
          <span class="text-xs text-ink-tertiary">Key</span>
          <span id="ma-key" class="font-display text-3xl font-semibold text-ink">—</span>
          <span id="ma-key-conf" class="text-xs text-ink-tertiary"></span>
        </div>
        <div class="panel panel-lift flex flex-col gap-1 p-4">
          <span class="text-xs text-ink-tertiary">Camelot</span>
          <span id="ma-camelot" class="font-display text-3xl font-semibold text-ink">—</span>
          <span class="text-xs text-ink-tertiary">for harmonic mixing</span>
        </div>
        <div class="panel panel-lift flex flex-col gap-1 p-4">
          <span class="text-xs text-ink-tertiary">Mood</span>
          <span id="ma-mood" class="font-display text-3xl font-semibold text-ink">—</span>
          <span id="ma-loudness" class="text-xs text-ink-tertiary"></span>
        </div>
      </div>

      <!-- Perceptual meters + chroma wheel -->
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="panel p-4">
          <div class="eyebrow mb-3">Feel</div>
          <div id="ma-meters" class="flex flex-col gap-3"></div>
        </div>
        <div class="panel p-4">
          <div class="eyebrow mb-3">Harmonic profile (HPCP chroma)</div>
          <div class="flex items-center justify-center">
            <canvas id="ma-chroma" width="260" height="260" class="max-w-full"></canvas>
          </div>
        </div>
      </div>

      <!-- Genre / auto-tagging (lazy ML model) -->
      <div class="panel p-4">
        <div class="flex items-center justify-between gap-3">
          <div class="eyebrow">Genre &amp; tags</div>
          <button id="ma-genre-btn" class="btn btn-secondary text-[13px]">Detect genre</button>
        </div>
        <p id="ma-genre-hint" class="mt-2 text-[13px] text-ink-tertiary">Runs a neural network (MSD-MusiCNN) in your browser. First use downloads ~13 MB.</p>
        <div id="ma-genre-body" class="mt-3 hidden flex-col gap-4">
          <div>
            <div class="mb-2 text-xs text-ink-tertiary">Top genres</div>
            <div id="ma-genres" class="flex flex-col gap-2"></div>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <div class="mb-2 text-xs text-ink-tertiary">Descriptive tags</div>
              <div id="ma-tags" class="flex flex-wrap gap-2"></div>
            </div>
            <div>
              <div class="mb-2 text-xs text-ink-tertiary">Likely era</div>
              <div id="ma-eras" class="flex flex-wrap gap-2"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Emotion breakdown -->
      <div class="panel p-4">
        <div class="eyebrow mb-3">Emotional profile</div>
        <div id="ma-emotions" class="flex flex-col gap-2.5"></div>
      </div>

      <!-- Technical detail -->
      <div class="panel p-4">
        <div class="eyebrow mb-3">Signal detail</div>
        <div id="ma-tech" class="grid grid-cols-2 gap-x-6 gap-y-2 font-mono text-[13px] sm:grid-cols-3"></div>
      </div>

      <!-- Plain-language summary -->
      <div class="panel p-4">
        <div class="eyebrow mb-2">Summary</div>
        <p id="ma-summary" class="text-sm leading-relaxed text-ink-muted"></p>
      </div>
    </div>

    <p id="ma-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free music analyzer extracts the musical DNA of any track right in your
      browser. Drop in a song and it detects the <strong>tempo (BPM)</strong>, the
      <strong>musical key</strong> and its <strong>Camelot code</strong> for
      harmonic DJ mixing, then profiles the <strong>mood</strong>, energy,
      danceability and emotional character. It measures broadcast-standard
      <strong>loudness (LUFS)</strong>, true peak and dynamic range, draws the
      harmonic pitch-class (HPCP) chroma wheel, and reports spectral features like
      brightness and spectral flatness. It can also detect <strong>genre and
      descriptive tags</strong> with a neural network (MSD-MusiCNN) that runs
      entirely in your browser. Analyze a file or your microphone — everything is
      computed locally with the Web Audio API and a custom DSP engine, so your
      music is never uploaded and there is no file-size limit.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .ma-meter-track { height:8px; border-radius:9999px; background:var(--color-surface-3); overflow:hidden; }
  .ma-meter-fill { height:100%; border-radius:9999px; transition:width .8s cubic-bezier(.2,.8,.2,1); }
</style>

<script>
  import { analyzeBuffer, NOTE_NAMES, type AnalysisResult } from '../../lib/audio-analysis';
  import { loadGenreModel, classifyGenre, type GenreResult } from '../../lib/genre-model';

  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('ma-file') as HTMLInputElement;
  const drop = $('ma-drop');
  const progWrap = $('ma-progwrap');
  const bar = $('ma-bar');
  const statusEl = $('ma-status');
  const results = $('ma-results');
  const err = $('ma-error');
  const nameEl = $('ma-name');
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  function show(el: HTMLElement, on: boolean, disp = 'flex') {
    el.classList.toggle('hidden', !on);
    if (on) el.classList.add(disp); else el.classList.remove(disp);
  }

  // Kept around so the (lazy) genre model can run on the same decoded audio
  // without re-decoding when the user clicks "Detect genre".
  let currentBuffer: AudioBuffer | null = null;

  async function decodeToBuffer(data: ArrayBuffer): Promise<AudioBuffer> {
    const actx = new (window.AudioContext || (window as any).webkitAudioContext)();
    try {
      return await actx.decodeAudioData(data);
    } finally {
      actx.close();
    }
  }

  // For very long tracks, analyze a representative window (drop the first/last
  // few seconds of intro/outro) to keep it fast without hurting accuracy.
  function trimForAnalysis(buf: AudioBuffer): AudioBuffer {
    const maxSec = 120;
    if (buf.duration <= maxSec) return buf;
    const sr = buf.sampleRate;
    const start = Math.floor(buf.duration * 0.15) * sr;
    const len = maxSec * sr;
    const actx = new (window.OfflineAudioContext || (window as any).webkitOfflineAudioContext)(buf.numberOfChannels, len, sr);
    const out = actx.createBuffer(buf.numberOfChannels, len, sr);
    for (let c = 0; c < buf.numberOfChannels; c++) {
      const src = buf.getChannelData(c);
      out.copyToChannel(src.subarray(start, start + len), c);
    }
    return out;
  }

  async function run(data: ArrayBuffer, label: string) {
    setErr('');
    nameEl.textContent = label;
    show(results, false);
    show(progWrap, true);
    bar.style.width = '15%';
    statusEl.textContent = 'Decoding audio…';
    try {
      const raw = await decodeToBuffer(data);
      bar.style.width = '45%';
      statusEl.textContent = 'Analyzing tempo, key and loudness…';
      await new Promise((r) => setTimeout(r, 20));
      const buf = trimForAnalysis(raw);
      currentBuffer = buf;
      const result = analyzeBuffer(buf);
      bar.style.width = '100%';
      await new Promise((r) => setTimeout(r, 120));
      render(result, raw.duration);
      resetGenre();
      show(progWrap, false);
      show(results, true);
    } catch (e) {
      show(progWrap, false);
      setErr('Could not decode or analyze that file. Try a WAV, MP3, M4A, OGG or FLAC.');
    }
  }

  function fmtDur(s: number) {
    const m = Math.floor(s / 60), sec = Math.round(s % 60);
    return `${m}:${sec.toString().padStart(2, '0')}`;
  }
  const pct = (x: number) => Math.round(x * 100);

  function meterRow(label: string, value: number, color: string) {
    return `<div class="flex flex-col gap-1">
      <div class="flex items-center justify-between text-[13px]">
        <span class="text-ink-subtle">${label}</span>
        <span class="font-mono text-ink">${pct(value)}%</span>
      </div>
      <div class="ma-meter-track"><div class="ma-meter-fill" data-w="${pct(value)}" style="width:0%;background:${color}"></div></div>
    </div>`;
  }

  function drawChroma(chroma: number[]) {
    const canvas = $('ma-chroma') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const W = canvas.width, H = canvas.height, cx = W / 2, cy = H / 2;
    const rMax = Math.min(cx, cy) - 26;
    ctx.clearRect(0, 0, W, H);
    const n = 12;
    // Grid rings.
    ctx.strokeStyle = 'rgba(255,255,255,0.08)';
    for (let r = 1; r <= 3; r++) { ctx.beginPath(); ctx.arc(cx, cy, (rMax * r) / 3, 0, Math.PI * 2); ctx.stroke(); }
    // Highlight the strongest pitch class.
    let peak = 0; for (let i = 1; i < n; i++) if (chroma[i] > chroma[peak]) peak = i;
    for (let i = 0; i < n; i++) {
      const a0 = (i / n) * Math.PI * 2 - Math.PI / 2 - Math.PI / n;
      const a1 = a0 + (Math.PI * 2) / n;
      const r = 12 + chroma[i] * (rMax - 12);
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.arc(cx, cy, r, a0 + 0.02, a1 - 0.02);
      ctx.closePath();
      ctx.fillStyle = i === peak ? 'rgba(130,143,255,0.95)' : 'rgba(94,106,210,0.55)';
      ctx.fill();
      // Note label.
      const am = (a0 + a1) / 2;
      ctx.fillStyle = i === peak ? '#f7f8f8' : '#8a8f98';
      ctx.font = '11px ui-monospace, monospace';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(NOTE_NAMES[i], cx + Math.cos(am) * (rMax + 12), cy + Math.sin(am) * (rMax + 12));
    }
  }

  function summarize(r: AnalysisResult): string {
    const tempoWord = r.bpm < 90 ? 'a laid-back' : r.bpm < 120 ? 'a moderate' : r.bpm < 140 ? 'an upbeat' : 'a fast';
    const bright = r.spectralCentroid > 3500 ? 'bright' : r.spectralCentroid > 1800 ? 'balanced' : 'warm';
    const loud = r.loudnessLufs > -9 ? 'very loud, heavily compressed' : r.loudnessLufs > -14 ? 'loud, streaming-ready' : r.loudnessLufs > -20 ? 'dynamic' : 'quiet and dynamic';
    const dance = r.danceability > 0.66 ? 'highly danceable' : r.danceability > 0.4 ? 'moderately danceable' : 'not especially danceable';
    return `This track runs at ${tempoWord} ${r.bpm} BPM in ${r.key} (Camelot ${r.camelot}). ` +
      `It reads as ${r.mood.toLowerCase()} and ${dance}, with a ${bright} tonal balance. ` +
      `Integrated loudness is ${r.loudnessLufs.toFixed(1)} LUFS — ${loud} — with a peak of ${r.peakDb.toFixed(1)} dBFS ` +
      `and roughly ${r.dynamicRange.toFixed(0)} dB of crest. Use the Camelot code ${r.camelot} to find harmonically compatible tracks for mixing.`;
  }

  function render(r: AnalysisResult, fullDuration: number) {
    $('ma-bpm').textContent = r.bpm ? String(r.bpm) : '—';
    $('ma-bpm-conf').textContent = r.bpm ? `${pct(r.bpmConfidence)}% confidence` : 'not detected';
    $('ma-key').textContent = r.key.replace('major', 'maj').replace('minor', 'min');
    $('ma-key-conf').textContent = `${pct(r.keyConfidence)}% confidence`;
    $('ma-camelot').textContent = r.camelot;
    $('ma-mood').textContent = r.mood;
    $('ma-loudness').textContent = `${r.loudnessLufs.toFixed(1)} LUFS`;

    $('ma-meters').innerHTML =
      meterRow('Energy', r.energy, 'var(--color-primary)') +
      meterRow('Danceability', r.danceability, 'var(--color-primary)') +
      meterRow('Valence (positivity)', r.valence, 'var(--color-primary)');

    $('ma-emotions').innerHTML = r.emotions
      .slice().sort((a, b) => b.value - a.value)
      .map((e) => meterRow(e.label, e.value, 'var(--color-primary-hover)')).join('');

    const tech: [string, string][] = [
      ['Duration', fmtDur(fullDuration)],
      ['Sample rate', `${(r.sampleRate / 1000).toFixed(1)} kHz`],
      ['Channels', r.channels === 1 ? 'Mono' : r.channels === 2 ? 'Stereo' : String(r.channels)],
      ['Integrated loudness', `${r.loudnessLufs.toFixed(1)} LUFS`],
      ['True peak', `${r.peakDb.toFixed(1)} dBFS`],
      ['RMS level', `${r.rmsDb.toFixed(1)} dBFS`],
      ['Dynamic range', `${r.dynamicRange.toFixed(1)} dB`],
      ['Spectral centroid', `${Math.round(r.spectralCentroid)} Hz`],
      ['Spectral rolloff', `${Math.round(r.spectralRolloff)} Hz`],
      ['Spectral flatness', r.spectralFlatness.toFixed(3)],
      ['Zero-crossing rate', `${Math.round(r.zeroCrossingRate)} /s`],
    ];
    $('ma-tech').innerHTML = tech
      .map(([k, v]) => `<div class="flex justify-between gap-2"><span class="text-ink-tertiary">${k}</span><span class="text-ink">${v}</span></div>`)
      .join('');

    $('ma-summary').textContent = summarize(r);
    drawChroma(r.chroma);
    // Animate meters in on next frame.
    requestAnimationFrame(() => {
      document.querySelectorAll<HTMLElement>('.ma-meter-fill').forEach((el) => {
        el.style.width = (el.dataset.w || '0') + '%';
      });
    });
  }

  // ---- Microphone capture (record ~12s, then analyze) ----
  async function fromMic() {
    setErr('');
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      const rec = new MediaRecorder(stream);
      const chunks: BlobPart[] = [];
      rec.ondataavailable = (e) => chunks.push(e.data);
      rec.onstop = async () => {
        stream.getTracks().forEach((t) => t.stop());
        const blob = new Blob(chunks, { type: rec.mimeType || 'audio/webm' });
        await run(await blob.arrayBuffer(), 'Microphone capture');
      };
      rec.start();
      show(progWrap, true); bar.style.width = '0%';
      let left = 12;
      statusEl.textContent = `Recording from microphone… ${left}s`;
      const iv = setInterval(() => {
        left--; bar.style.width = `${((12 - left) / 12) * 100}%`;
        statusEl.textContent = `Recording from microphone… ${left}s`;
        if (left <= 0) { clearInterval(iv); rec.stop(); }
      }, 1000);
    } catch {
      setErr('Could not access the microphone.');
    }
  }

  // ---- Synthesized sample (A-minor-ish loop @ 120 BPM) so the tool is usable with no file ----
  async function sample() {
    const sr = 44100, dur = 8;
    const actx = new (window.OfflineAudioContext || (window as any).webkitOfflineAudioContext)(1, sr * dur, sr);
    const notes = [220, 261.63, 329.63, 220, 246.94, 293.66, 349.23, 246.94]; // A C E A / B D F B
    const beat = 0.5; // 120 BPM
    for (let i = 0; i < dur / beat; i++) {
      const o = actx.createOscillator(); const g = actx.createGain();
      o.type = 'triangle'; o.frequency.value = notes[i % notes.length];
      const t0 = i * beat;
      g.gain.setValueAtTime(0, t0); g.gain.linearRampToValueAtTime(0.3, t0 + 0.02);
      g.gain.exponentialRampToValueAtTime(0.001, t0 + beat * 0.9);
      o.connect(g).connect(actx.destination); o.start(t0); o.stop(t0 + beat);
      // kick on every beat
      const k = actx.createOscillator(); const kg = actx.createGain();
      k.frequency.setValueAtTime(120, t0); k.frequency.exponentialRampToValueAtTime(40, t0 + 0.12);
      kg.gain.setValueAtTime(0.7, t0); kg.gain.exponentialRampToValueAtTime(0.001, t0 + 0.15);
      k.connect(kg).connect(actx.destination); k.start(t0); k.stop(t0 + 0.2);
    }
    const rendered = await actx.startRendering();
    // Serialize to a WAV ArrayBuffer so it flows through the same decode path.
    const wav = bufferToWav(rendered);
    await run(wav, 'Sample loop (120 BPM, A minor)');
  }

  function bufferToWav(buf: AudioBuffer): ArrayBuffer {
    const numCh = buf.numberOfChannels, sr = buf.sampleRate, len = buf.length;
    const bytes = 44 + len * numCh * 2;
    const ab = new ArrayBuffer(bytes); const view = new DataView(ab);
    const wr = (o: number, s: string) => { for (let i = 0; i < s.length; i++) view.setUint8(o + i, s.charCodeAt(i)); };
    wr(0, 'RIFF'); view.setUint32(4, bytes - 8, true); wr(8, 'WAVE'); wr(12, 'fmt ');
    view.setUint32(16, 16, true); view.setUint16(20, 1, true); view.setUint16(22, numCh, true);
    view.setUint32(24, sr, true); view.setUint32(28, sr * numCh * 2, true);
    view.setUint16(32, numCh * 2, true); view.setUint16(34, 16, true); wr(36, 'data');
    view.setUint32(40, len * numCh * 2, true);
    let off = 44;
    for (let i = 0; i < len; i++) for (let c = 0; c < numCh; c++) {
      const s = Math.max(-1, Math.min(1, buf.getChannelData(c)[i]));
      view.setInt16(off, s < 0 ? s * 0x8000 : s * 0x7fff, true); off += 2;
    }
    return ab;
  }

  // ---- Genre detection (lazy ONNX model) ----
  const genreBtn = $('ma-genre-btn') as HTMLButtonElement;
  const genreHint = $('ma-genre-hint');
  const genreBody = $('ma-genre-body');

  // Reset the genre panel whenever a new track is analyzed.
  function resetGenre() {
    show(genreBody, false);
    genreBtn.disabled = false;
    genreBtn.textContent = 'Detect genre';
    genreHint.textContent = 'Runs a neural network (MSD-MusiCNN) in your browser. First use downloads ~13 MB.';
  }

  function renderGenre(g: GenreResult) {
    $('ma-genres').innerHTML = g.genres.slice(0, 6)
      .map((p) => meterRow(p.label, p.value, 'var(--color-primary)')).join('');
    const chip = (p: { label: string; value: number }) =>
      `<span class="status-badge">${p.label} <span class="text-ink-tertiary">${pct(p.value)}%</span></span>`;
    $('ma-tags').innerHTML = g.moods.slice(0, 6).map(chip).join('') || '<span class="text-ink-tertiary text-[13px]">—</span>';
    $('ma-eras').innerHTML = g.eras.slice(0, 3).map(chip).join('') || '<span class="text-ink-tertiary text-[13px]">—</span>';
    show(genreBody, true);
    requestAnimationFrame(() => {
      genreBody.querySelectorAll<HTMLElement>('.ma-meter-fill').forEach((el) => { el.style.width = (el.dataset.w || '0') + '%'; });
    });
  }

  async function detectGenre() {
    if (!currentBuffer) { setErr('Analyze a track first.'); return; }
    setErr('');
    genreBtn.disabled = true;
    try {
      await loadGenreModel((note) => { if (note) genreHint.textContent = note; });
      genreBtn.textContent = 'Classifying…';
      genreHint.textContent = 'Running the model on your audio…';
      const g = await classifyGenre(currentBuffer);
      renderGenre(g);
      genreBtn.textContent = 'Re-run genre';
      genreHint.textContent = 'Predicted with MSD-MusiCNN (50 tags, MagnaTagATune/MSD). Averaged across the track.';
      genreBtn.disabled = false;
    } catch (e) {
      setErr('Genre detection failed to load or run. ' + (e as Error).message);
      genreBtn.disabled = false;
      genreBtn.textContent = 'Detect genre';
    }
  }
  genreBtn.addEventListener('click', detectGenre);

  async function pick(f: File) { await run(await f.arrayBuffer(), f.name); }

  fileInput.addEventListener('change', () => fileInput.files?.[0] && pick(fileInput.files[0]));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) pick(f); });
  $('ma-mic').addEventListener('click', fromMic);
  $('ma-sample').addEventListener('click', sample);
</script>

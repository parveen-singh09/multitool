---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="recipe-idea-generator">
  <div class="flex flex-col gap-6">

    <div class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">What's in your kitchen?
        <input id="rg-search" class="field" placeholder="Search ingredients (e.g. chicken, rice, tomato)" spellcheck="false" autocomplete="off" />
      </label>
      <div id="rg-picker" class="flex flex-col gap-4"></div>
    </div>

    <div class="flex flex-col gap-3 border-t border-hairline pt-4">
      <div class="flex items-center justify-between">
        <span class="text-[13px] font-medium uppercase tracking-wide text-ink-tertiary">Your ingredients</span>
        <button id="rg-clear" class="btn btn-tertiary text-sm">Clear all</button>
      </div>
      <div id="rg-selected" class="flex flex-wrap gap-2"></div>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 pt-1">
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          <input id="rg-staples" type="checkbox" class="accent-primary" checked /> I have basic staples (salt, oil, butter, flour…)
        </label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          Diet
          <select id="rg-diet" class="field w-auto py-1.5">
            <option value="">Any</option>
            <option value="vegetarian">Vegetarian</option>
            <option value="vegan">Vegan</option>
          </select>
        </label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          Show
          <select id="rg-missing" class="field w-auto py-1.5">
            <option value="0">Can make now</option>
            <option value="1" selected>Missing ≤ 1</option>
            <option value="2">Missing ≤ 2</option>
          </select>
        </label>
      </div>
    </div>

    <div class="flex flex-col gap-4 border-t border-hairline pt-4">
      <p id="rg-summary" class="text-sm text-ink-subtle"></p>
      <div id="rg-results" class="grid gap-4 sm:grid-cols-2"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free recipe idea generator works the way you actually cook: tell it what you
      already have, and it shows the recipes you can make right now — no shopping trip
      required. Search or tap the ingredients in your kitchen and matching recipes appear
      instantly, sorted so the ones you can cook this minute come first.
    </p>
    <p>
      Unlike a search box that needs an exact dish name, it matches on the ingredients
      themselves, and it also surfaces "almost there" recipes that need just one or two
      more items — a smarter version of the classic what-can-I-make-with-what-I-have tool.
      Filter by vegetarian or vegan, keep or drop the pantry staples, and your ingredient
      list is saved in your browser for next time.
    </p>
  </div>
</ToolLayout>

<script>
  import {
    INGREDIENTS,
    INGREDIENT_NAME,
    STAPLES,
    matchRecipes,
    type Diet,
    type Match,
  } from '../../lib/recipes';

  const $ = (id: string) => document.getElementById(id)!;
  const searchEl = $('rg-search') as HTMLInputElement;
  const pickerEl = $('rg-picker');
  const selectedEl = $('rg-selected');
  const staplesEl = $('rg-staples') as HTMLInputElement;
  const dietEl = $('rg-diet') as HTMLSelectElement;
  const missingEl = $('rg-missing') as HTMLSelectElement;
  const summaryEl = $('rg-summary');
  const resultsEl = $('rg-results');

  const STORE = 'toolsilk:recipe-pantry';
  const owned = new Set<string>(load());

  function load(): string[] {
    try {
      const raw = localStorage.getItem(STORE);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }
  function save() {
    try {
      localStorage.setItem(STORE, JSON.stringify([...owned]));
    } catch {

    }
  }

  const esc = (s: string) =>
    s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);

  const GROUPS = [...new Set(INGREDIENTS.map((i) => i.group))];

  function renderPicker() {
    const q = searchEl.value.trim().toLowerCase();
    pickerEl.innerHTML = GROUPS.map((group) => {
      const items = INGREDIENTS.filter(
        (i) => i.group === group && (!q || i.name.toLowerCase().includes(q)),
      );
      if (!items.length) return '';
      const chips = items
        .map((i) => {
          const on = owned.has(i.id);
          return `<button type="button" data-id="${i.id}" aria-pressed="${on}"
            class="rounded-md border px-2.5 py-1 text-[15px] transition-colors ${
              on
                ? 'border-primary bg-primary/15 text-ink'
                : 'border-hairline bg-surface-1 text-ink-subtle hover:border-hairline-strong'
            }">${esc(i.name)}</button>`;
        })
        .join('');
      return `<div class="flex flex-col gap-2">
        <span class="text-[13px] font-medium uppercase tracking-wide text-ink-tertiary">${esc(group)}</span>
        <div class="flex flex-wrap gap-2">${chips}</div>
      </div>`;
    }).join('');
  }

  function renderSelected() {
    if (!owned.size) {
      selectedEl.innerHTML = `<span class="text-sm text-ink-tertiary">Nothing selected yet — pick ingredients above.</span>`;
      return;
    }
    selectedEl.innerHTML = [...owned]
      .map(
        (id) =>
          `<button type="button" data-remove="${id}"
            class="inline-flex items-center gap-1.5 rounded-md border border-primary bg-primary/15 px-2.5 py-1 text-[15px] text-ink">
            ${esc(INGREDIENT_NAME.get(id) ?? id)}<span aria-hidden="true" class="text-ink-tertiary">×</span></button>`,
      )
      .join('');
  }

  function card(m: Match): string {
    const r = m.recipe;
    const canMake = m.missing.length === 0;
    const badge = canMake
      ? `<span class="status-badge" style="color:#7dd88f">✓ Can make now</span>`
      : `<span class="status-badge">Missing ${m.missing.length}</span>`;
    const missingList = m.missing.length
      ? `<p class="text-sm text-ink-subtle">Missing: <span class="text-ink">${m.missing
          .map((id) => esc(INGREDIENT_NAME.get(id) ?? id))
          .join(', ')}</span></p>`
      : '';
    const steps = r.steps.map((s) => `<li>${esc(s)}</li>`).join('');
    return `<article class="flex flex-col gap-2 rounded-lg border border-hairline bg-surface-1 p-4">
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-[17px] font-medium text-ink">${esc(r.name)}</h3>
        ${badge}
      </div>
      <p class="text-sm text-ink-subtle">${esc(r.blurb)}</p>
      <p class="text-[13px] text-ink-tertiary">⏱ ${r.minutes} min · uses ${m.have.length} of your ingredients</p>
      ${missingList}
      <details class="mt-1">
        <summary class="cursor-pointer text-sm text-primary">Show steps</summary>
        <ol class="mt-2 flex list-decimal flex-col gap-1 pl-5 text-sm text-ink-subtle">${steps}</ol>
      </details>
    </article>`;
  }

  function update() {
    const diet = (dietEl.value || null) as Diet | null;
    const maxMissing = Number(missingEl.value);
    const matches = matchRecipes(owned, staplesEl.checked, diet, maxMissing);

    renderSelected();

    if (!owned.size) {
      summaryEl.textContent = 'Pick a few ingredients to see what you can cook.';
      resultsEl.innerHTML = '';
      return;
    }
    const now = matches.filter((m) => m.missing.length === 0).length;
    if (!matches.length) {
      summaryEl.textContent = 'No matches yet — add more ingredients or raise the "missing" limit.';
      resultsEl.innerHTML = '';
      return;
    }
    summaryEl.textContent = `${matches.length} recipe${matches.length === 1 ? '' : 's'} · ${now} you can make right now.`;
    resultsEl.innerHTML = matches.map(card).join('');
  }

  function toggle(id: string) {
    if (owned.has(id)) owned.delete(id);
    else owned.add(id);
    save();
    renderPicker();
    update();
  }

  pickerEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-id]') as HTMLElement | null;
    if (btn) toggle(btn.dataset.id!);
  });
  selectedEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-remove]') as HTMLElement | null;
    if (btn) toggle(btn.dataset.remove!);
  });
  searchEl.addEventListener('input', renderPicker);
  [staplesEl, dietEl, missingEl].forEach((el) => el.addEventListener('change', update));
  $('rg-clear').addEventListener('click', () => {
    owned.clear();
    save();
    renderPicker();
    update();
  });

  renderPicker();
  update();
</script>

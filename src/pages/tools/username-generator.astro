---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="username-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="un-count" type="number" min="1" max="500" value="15" class="field w-28" />
      </label>
      <button id="un-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="un-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <textarea id="un-out" class="field min-h-64 resize-y font-mono text-[13px]" readonly aria-label="Generated usernames"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free username generator creates unique, memorable usernames and handles
      by combining adjectives, nouns and numbers in a few different styles — great
      for games, social media, forums and new sign-ups when your first choice is
      taken. Generate a batch and pick your favorite. Everything runs in your
      browser and nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { username } from '../../lib/fakegen';

  const $ = (id: string) => document.getElementById(id)!;
  const countEl = $('un-count') as HTMLInputElement;
  const out = $('un-out') as HTMLTextAreaElement;

  function generate() {
    const n = Math.max(1, Math.min(500, Number(countEl.value) || 1));
    const set = new Set<string>();
    let guard = 0;
    while (set.size < n && guard < n * 20) { set.add(username()); guard++; }
    out.value = [...set].join('\n');
  }

  countEl.addEventListener('input', generate);
  $('un-gen').addEventListener('click', generate);
  $('un-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

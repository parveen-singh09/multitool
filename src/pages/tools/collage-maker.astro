---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="collage-maker">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Images
      <input id="cm-files" type="file" accept="image/*" multiple class="field" />
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Layout
        <select id="cm-layout" class="field">
          <option value="2x2">2 × 2</option>
          <option value="3x3">3 × 3</option>
          <option value="1x2">1 × 2 (side by side)</option>
          <option value="2x1">2 × 1 (stacked)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Cell size (px)
        <input id="cm-cell" type="number" min="100" max="1200" step="10" value="400" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Spacing (px)
        <input id="cm-gap" type="number" min="0" max="200" step="1" value="12" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Background
        <input id="cm-bg" type="color" value="#ffffff" class="field h-10 cursor-pointer p-1" />
      </label>
    </div>

    <p id="cm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="panel p-4">
      <canvas id="cm-canvas" class="max-w-full h-auto rounded-md" aria-label="Collage preview"></canvas>
    </div>

    <div class="flex gap-2">
      <button id="cm-download" class="btn btn-primary">Download PNG</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free collage maker combines several photos into a grid. Pick a layout,
      set the cell size, spacing and background color, then download the finished
      collage as a PNG. Images are cropped to fill each cell so nothing looks
      stretched. Every photo is processed locally in your browser and is never
      uploaded to a server.
    </p>
  </div>
</ToolLayout>

<script>
  const filesEl = document.getElementById('cm-files') as HTMLInputElement;
  const layoutEl = document.getElementById('cm-layout') as HTMLSelectElement;
  const cellEl = document.getElementById('cm-cell') as HTMLInputElement;
  const gapEl = document.getElementById('cm-gap') as HTMLInputElement;
  const bgEl = document.getElementById('cm-bg') as HTMLInputElement;
  const canvas = document.getElementById('cm-canvas') as HTMLCanvasElement;
  const err = document.getElementById('cm-error')!;
  const ctx = canvas.getContext('2d')!;

  let images: HTMLImageElement[] = [];

  function showError(msg: string) {
    err.textContent = msg;
    err.classList.remove('hidden');
  }

  function clearError() {
    err.classList.add('hidden');
  }

  function loadFile(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = () => reject(new Error('Could not decode ' + file.name));
        img.src = reader.result as string;
      };
      reader.onerror = () => reject(new Error('Could not read ' + file.name));
      reader.readAsDataURL(file);
    });
  }

  function gridFor(layout: string): { cols: number; rows: number } {
    switch (layout) {
      case '3x3':
        return { cols: 3, rows: 3 };
      case '1x2':
        return { cols: 2, rows: 1 };
      case '2x1':
        return { cols: 1, rows: 2 };
      default:
        return { cols: 2, rows: 2 };
    }
  }

  function drawCover(img: HTMLImageElement, dx: number, dy: number, dw: number, dh: number) {
    const scale = Math.max(dw / img.width, dh / img.height);
    const sw = dw / scale;
    const sh = dh / scale;
    const sx = (img.width - sw) / 2;
    const sy = (img.height - sh) / 2;
    ctx.drawImage(img, sx, sy, sw, sh, dx, dy, dw, dh);
  }

  function render() {
    clearError();
    const { cols, rows } = gridFor(layoutEl.value);
    const cell = Math.max(100, Number(cellEl.value) || 400);
    const gap = Math.max(0, Number(gapEl.value) || 0);

    canvas.width = cols * cell + (cols + 1) * gap;
    canvas.height = rows * cell + (rows + 1) * gap;

    ctx.fillStyle = bgEl.value;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    for (let i = 0; i < cols * rows; i++) {
      const img = images[i];
      if (!img) continue;
      const c = i % cols;
      const r = Math.floor(i / cols);
      const dx = gap + c * (cell + gap);
      const dy = gap + r * (cell + gap);
      drawCover(img, dx, dy, cell, cell);
    }
  }

  filesEl.addEventListener('change', async () => {
    const list = filesEl.files;
    if (!list || !list.length) return;
    try {
      images = await Promise.all(Array.from(list).map(loadFile));
      render();
    } catch (e) {
      showError((e as Error).message);
    }
  });

  [layoutEl, cellEl, gapEl, bgEl].forEach((el) => el.addEventListener('input', render));

  document.getElementById('cm-download')!.addEventListener('click', () => {
    if (!images.length) {
      showError('Add at least one image first.');
      return;
    }
    canvas.toBlob((blob) => {
      if (!blob) return;
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.download = 'toolcities-collage.png';
      link.href = url;
      link.click();
      URL.revokeObjectURL(url);
    }, 'image/png');
  });

  render();
</script>

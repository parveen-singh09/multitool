---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="yaml-to-json-converter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="y2j-convert" class="btn btn-primary">Convert to JSON</button>
      <button id="y2j-copy" class="btn btn-secondary">Copy</button>
      <button id="y2j-download" class="btn btn-secondary">Download</button>
      <label class="btn btn-tertiary cursor-pointer">
        Upload
        <input id="y2j-file" type="file" accept=".yaml,.yml,.txt,text/plain,text/yaml" class="hidden" />
      </label>
      <button id="y2j-sample" class="btn btn-tertiary">Sample</button>
      <button id="y2j-clear" class="btn btn-tertiary">Clear</button>

      <label class="ml-auto flex items-center gap-2 text-sm text-ink-subtle">
        <input id="y2j-minify" type="checkbox" class="h-4 w-4" />
        Minify
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="y2j-sort" type="checkbox" class="h-4 w-4" />
        Sort keys
      </label>
      <label id="y2j-indent-wrap" class="flex items-center gap-2 text-sm text-ink-subtle">
        Indent
        <select id="y2j-indent" class="field w-auto py-1">
          <option value="2">2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
    </div>

    <div id="y2j-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid gap-4 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span>YAML input</span>
        <div id="y2j-drop" class="hl-edit field p-0" style="height:22rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="y2j-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea id="y2j-input" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="YAML input"></textarea>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span>JSON output</span>
        <pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre"><code id="y2j-output" class="hljs" style="background:transparent;padding:0"></code></pre>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free YAML to JSON converter parses YAML — nested maps, lists, scalars,
      quoted strings, numbers, booleans, null and inline flow collections
      (<code>[..]</code> / <code>{"{..}"}</code>) — and returns clean, formatted
      JSON. Conversion is live as you type, both panes are syntax-highlighted, and
      syntax problems are flagged with the exact line number so you can fix them
      fast. It handles the common subset of YAML used in config files rather than
      every edge of the specification. Everything runs in your browser, so nothing
      you paste is ever uploaded.
    </p>
    <p>
      Pretty-print the JSON at 2 spaces, 4 spaces or a tab, or tick
      <strong>Minify</strong> for a single compact line. <strong>Sort keys</strong>
      alphabetizes every object for stable diffs. Paste, drag-and-drop or upload a
      <code>.yaml</code>/<code>.yml</code> file, then copy the result or download it
      as a <code>.json</code> file. A live line and byte count sits in the status bar.
    </p>
  </div>
</ToolLayout>

<script>
  import { parseYaml, type Json } from '../../lib/dataformats';
  import { hl, wireInput } from '../../lib/highlight';

  const input = document.getElementById('y2j-input') as HTMLTextAreaElement;
  const inHl = document.getElementById('y2j-in-hl')!;
  const output = document.getElementById('y2j-output')!;
  const statusEl = document.getElementById('y2j-status')!;
  const indentSel = document.getElementById('y2j-indent') as HTMLSelectElement;
  const indentWrap = document.getElementById('y2j-indent-wrap')!;
  const minifyBox = document.getElementById('y2j-minify') as HTMLInputElement;
  const sortBox = document.getElementById('y2j-sort') as HTMLInputElement;
  const drop = document.getElementById('y2j-drop')!;
  let rawOutput = '';

  function getIndent(): string | number {
    const v = indentSel.value;
    return v === 'tab' ? '\t' : Number(v);
  }

  function sortKeys(v: Json): Json {
    if (Array.isArray(v)) return v.map(sortKeys);
    if (v !== null && typeof v === 'object') {
      const o: { [k: string]: Json } = {};
      for (const k of Object.keys(v).sort()) o[k] = sortKeys((v as { [k: string]: Json })[k]);
      return o;
    }
    return v;
  }

  function showStatus(msg: string, ok: boolean) {
    statusEl.textContent = msg;
    statusEl.classList.remove('hidden');
    statusEl.style.borderColor = ok ? '#27a644' : '#e5484d';
    statusEl.style.color = ok ? '#27a644' : '#e08585';
  }

  async function convert() {
    indentWrap.style.display = minifyBox.checked ? 'none' : '';
    if (!input.value.trim()) {
      rawOutput = ''; output.textContent = ''; statusEl.classList.add('hidden');
      return;
    }
    try {
      let parsed = parseYaml(input.value);
      if (sortBox.checked) parsed = sortKeys(parsed);
      rawOutput = JSON.stringify(parsed, null, minifyBox.checked ? undefined : getIndent());
      await hl(output, rawOutput, 'json');
      const bytes = new Blob([rawOutput]).size;
      const lines = rawOutput.split('\n').length;
      showStatus(`YAML → JSON · ${lines} ${lines === 1 ? 'line' : 'lines'} · ${bytes} bytes ✓`, true);
    } catch (e) {
      rawOutput = ''; output.textContent = '';
      showStatus((e as Error).message, false);
    }
  }

  const rerender = wireInput(input, inHl, () => 'yaml', () => { void convert(); });

  document.getElementById('y2j-convert')!.addEventListener('click', () => { void convert(); });
  indentSel.addEventListener('change', () => { if (input.value.trim()) void convert(); });
  minifyBox.addEventListener('change', () => { void convert(); });
  sortBox.addEventListener('change', () => { void convert(); });

  document.getElementById('y2j-clear')!.addEventListener('click', () => {
    input.value = ''; rawOutput = ''; output.textContent = '';
    statusEl.classList.add('hidden');
    rerender();
  });

  document.getElementById('y2j-copy')!.addEventListener('click', async (e) => {
    if (!rawOutput) return;
    await navigator.clipboard.writeText(rawOutput);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1500);
  });

  document.getElementById('y2j-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const blob = new Blob([rawOutput], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'converted.json';
    a.click();
    URL.revokeObjectURL(url);
  });

  const SAMPLE = 'name: ToolSilk\nport: 8080\nfeatures:\n  - fast\n  - local\n  - private\nlimits:\n  max: 100\n  enabled: true\nowner: ~';
  document.getElementById('y2j-sample')!.addEventListener('click', () => {
    input.value = SAMPLE; rerender(); void convert();
  });

  // Upload / drag-and-drop a YAML file onto the input pane.
  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => { input.value = String(reader.result ?? ''); rerender(); void convert(); };
    reader.onerror = () => showStatus('Could not read file.', false);
    reader.readAsText(file);
  }
  const fileInput = document.getElementById('y2j-file') as HTMLInputElement;
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });

  ['dragover', 'dragenter'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.style.outline = '2px solid #5e6ad2'; }));
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, () => { drop.style.outline = ''; }));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) loadFile(file);
  });

  input.value = SAMPLE;
  rerender();
  void convert();
</script>

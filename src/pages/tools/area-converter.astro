---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="area-converter">
  <UnitConverter slug="area-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free area converter converts area between square metres, square feet, square kilometres, square miles, acres and hectares — ideal for land, flooring and real-estate work. All conversions run locally in your browser with no uploads.
    </p>
  </div>
</ToolLayout>

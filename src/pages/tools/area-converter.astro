---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="area-converter">
  <div id="ac-root" class="flex flex-col gap-6">
    <!-- Primary from / to converter -->
    <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="ac-from-val">From</label>
        <input id="ac-from-val" type="text" class="field" value="1" inputmode="decimal" autocomplete="off" spellcheck="false" />
        <select id="ac-from-unit" class="field mt-1"></select>
      </div>
      <button
        id="ac-swap"
        type="button"
        class="btn btn-secondary mb-1 h-10 w-10 shrink-0 justify-self-center p-0"
        aria-label="Swap units"
        title="Swap units"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4"/></svg>
      </button>
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="ac-to-val">To</label>
        <div class="relative">
          <input id="ac-to-val" type="text" class="field pr-11" readonly />
          <button id="ac-copy-to" type="button" class="btn btn-tertiary absolute right-1 top-1/2 h-8 w-9 -translate-y-1/2 p-0" aria-label="Copy result" title="Copy result">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
          </button>
        </div>
        <select id="ac-to-unit" class="field mt-1"></select>
      </div>
    </div>

    <!-- Precision control -->
    <div class="flex flex-wrap items-center gap-3">
      <label class="text-sm text-ink-subtle" for="ac-precision">Decimal places</label>
      <select id="ac-precision" class="field w-auto">
        <option value="auto" selected>Auto</option>
        <option value="0">0</option>
        <option value="2">2</option>
        <option value="4">4</option>
        <option value="6">6</option>
        <option value="8">8</option>
        <option value="10">10</option>
      </select>
      <label class="ml-1 flex cursor-pointer select-none items-center gap-2 text-sm text-ink-subtle">
        <input id="ac-thousands" type="checkbox" class="h-4 w-4 accent-primary" checked />
        Group thousands
      </label>
    </div>

    <p id="ac-error" class="hidden text-[13px] text-primary-hover" role="alert" aria-live="polite"></p>
    <p id="ac-formula" class="text-[13px] text-ink-tertiary"></p>

    <!-- Convert all units at once -->
    <div>
      <div class="mb-2 flex items-center justify-between">
        <p class="text-[13px] text-ink-subtle">All units at once</p>
        <span id="ac-all-label" class="text-[13px] text-ink-tertiary"></span>
      </div>
      <div id="ac-all" class="overflow-hidden rounded-md border border-hairline"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free area converter converts area between square metres, square feet, square kilometres, square miles, acres, hectares, ares, roods, square perch, cents, gunthas and survey sections — ideal for land, flooring, agriculture and real-estate work. Enter a value once and see it in every unit at the same time, with adjustable precision. All conversions run locally in your browser with no uploads.
    </p>
    <p>
      Pick your source and target units, or read the full "all units at once" table below the converter. Use the decimal-places control to switch between rounded, human-readable figures and high-precision output, toggle thousands grouping for large land areas, and copy any result to your clipboard with one click. Swap the two units instantly with the swap button.
    </p>
    <p>
      Common conversions include square feet to square metres, acres to hectares, square metres to square feet, hectares to acres and square kilometres to square miles. Land units such as the acre (43,560 sq ft), hectare (10,000 m²), are (100 m²), rood (quarter acre), square perch/rod, cent (1/100 acre), guntha (1/40 acre) and the US survey section (one square mile) are all defined exactly, so results stay accurate at any precision.
    </p>
  </div>
</ToolLayout>

<script>
  // Self-contained area converter. Units are factors to the base unit
  // (square metre). All land units below are exact definitions so results
  // hold at any precision. ponytail: inline data — page-specific, richer
  // than the shared units.ts list which this page intentionally supersedes.
  const UNITS: Record<string, number> = {
    'Square millimetre (mm²)': 1e-6,
    'Square centimetre (cm²)': 1e-4,
    'Square metre (m²)': 1,
    'Are (a)': 100,
    'Hectare (ha)': 1e4,
    'Square kilometre (km²)': 1e6,
    'Square inch (in²)': 0.00064516,
    'Square foot (ft²)': 0.09290304,
    'Square yard (yd²)': 0.83612736,
    'Square perch / rod (rd²)': 25.29285264,
    'Rood': 1011.7141056,
    'Acre': 4046.8564224,
    'Square mile (mi²)': 2589988.110336,
    'Cent': 40.468564224,
    'Guntha': 101.17141056,
    'Section (survey)': 2589988.110336,
  };
  const NAMES = Object.keys(UNITS);
  const DEFAULT_FROM = 'Square metre (m²)';
  const DEFAULT_TO = 'Square foot (ft²)';

  const $ = (id: string) => document.getElementById(id)!;
  const fromVal = $('ac-from-val') as HTMLInputElement;
  const toVal = $('ac-to-val') as HTMLInputElement;
  const fromUnit = $('ac-from-unit') as HTMLSelectElement;
  const toUnit = $('ac-to-unit') as HTMLSelectElement;
  const precision = $('ac-precision') as HTMLSelectElement;
  const thousands = $('ac-thousands') as HTMLInputElement;
  const swap = $('ac-swap') as HTMLButtonElement;
  const copyTo = $('ac-copy-to') as HTMLButtonElement;
  const formula = $('ac-formula') as HTMLElement;
  const errorEl = $('ac-error') as HTMLElement;
  const allBox = $('ac-all') as HTMLElement;
  const allLabel = $('ac-all-label') as HTMLElement;

  function parseInput(raw: string): number {
    // Accept commas as thousands separators and surrounding whitespace.
    const cleaned = raw.trim().replace(/,/g, '');
    if (cleaned === '') return NaN;
    return Number(cleaned);
  }

  // Format a number: honour the precision selector, else pick sensible
  // significant figures without trailing noise. Optionally group thousands.
  function fmt(n: number): string {
    if (!isFinite(n)) return n > 0 ? '∞' : '-∞';
    if (n === 0) return '0';
    const p = precision.value;
    let out: string;
    const abs = Math.abs(n);
    if (p === 'auto') {
      if (abs >= 1e15 || abs < 1e-6) return n.toExponential(6); // exp form: skip grouping
      out = String(Math.round(n * 1e9) / 1e9);
    } else {
      const d = Number(p);
      // Respect the chosen precision literally; only escape to exponential for
      // magnitudes where toFixed loses digits.
      if (abs >= 1e16) return n.toExponential(Math.min(d, 10) || 6);
      out = n.toFixed(d);
    }
    if (thousands.checked && !out.includes('e')) {
      const [int, frac] = out.split('.');
      const sign = int.startsWith('-') ? '-' : '';
      const digits = sign ? int.slice(1) : int;
      const grouped = digits.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      out = sign + grouped + (frac !== undefined ? '.' + frac : '');
    }
    return out;
  }

  function convert(value: number, from: string, to: string): number {
    return (value * UNITS[from]) / UNITS[to];
  }

  function fillUnits() {
    const opts = NAMES.map((u) => `<option>${u}</option>`).join('');
    fromUnit.innerHTML = opts;
    toUnit.innerHTML = opts;
    fromUnit.value = DEFAULT_FROM;
    toUnit.value = DEFAULT_TO;
  }

  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }
  function clearError() {
    errorEl.classList.add('hidden');
    errorEl.textContent = '';
  }

  function render() {
    const raw = fromVal.value;
    const v = parseInput(raw);
    if (raw.trim() === '') {
      clearError();
      toVal.value = '';
      formula.textContent = '';
      allBox.innerHTML = '';
      allLabel.textContent = '';
      return;
    }
    if (isNaN(v)) {
      showError(`"${raw.trim()}" is not a valid number. Enter a numeric area value.`);
      toVal.value = '';
      formula.textContent = '';
      allBox.innerHTML = '';
      allLabel.textContent = '';
      return;
    }
    if (v < 0) {
      showError('Area cannot be negative. Enter a value of 0 or greater.');
    } else {
      clearError();
    }

    const result = convert(v, fromUnit.value, toUnit.value);
    toVal.value = fmt(result);
    formula.textContent = `${fmt(v)} ${short(fromUnit.value)} = ${fmt(result)} ${short(toUnit.value)}`;
    allLabel.textContent = `${fmt(v)} ${short(fromUnit.value)} equals`;
    renderAll(v);
  }

  // Trim the parenthetical symbol for the compact formula line.
  function short(name: string): string {
    const m = name.match(/\(([^)]+)\)/);
    return m ? m[1] : name;
  }

  function renderAll(v: number) {
    const rows = NAMES.map((u) => {
      const r = convert(v, fromUnit.value, u);
      const isFrom = u === fromUnit.value;
      const val = fmt(r);
      return `<tr class="border-t border-hairline first:border-t-0 ${isFrom ? 'bg-surface-2' : ''}">
        <td class="px-3 py-2 text-ink-subtle">${u}</td>
        <td class="px-3 py-2 text-right font-mono text-ink">${val}</td>
        <td class="px-2 py-2 text-right">
          <button type="button" class="ac-copy-row btn btn-tertiary h-7 w-8 p-0 align-middle" data-val="${val}" aria-label="Copy ${u} value" title="Copy value">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
          </button>
        </td>
      </tr>`;
    }).join('');
    allBox.innerHTML = `<table class="w-full text-[13px]"><tbody>${rows}</tbody></table>`;
  }

  async function copy(text: string, btn: HTMLElement) {
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      // Fallback for non-secure contexts.
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); } catch { /* ignore */ }
      document.body.removeChild(ta);
    }
    const prev = btn.getAttribute('title');
    btn.setAttribute('title', 'Copied!');
    btn.classList.add('text-success');
    setTimeout(() => {
      btn.setAttribute('title', prev || 'Copy');
      btn.classList.remove('text-success');
    }, 1200);
  }

  fromVal.addEventListener('input', render);
  fromUnit.addEventListener('change', render);
  toUnit.addEventListener('change', render);
  precision.addEventListener('change', render);
  thousands.addEventListener('change', render);
  swap.addEventListener('click', () => {
    const a = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = a;
    if (toVal.value !== '') fromVal.value = toVal.value.replace(/,/g, '');
    render();
  });
  copyTo.addEventListener('click', () => copy(toVal.value, copyTo));
  allBox.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.ac-copy-row') as HTMLElement | null;
    if (btn) copy(btn.dataset.val || '', btn);
  });

  fillUnits();
  render();
</script>

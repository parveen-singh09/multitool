---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="internet-speed-test">
  <div class="flex flex-col gap-6">
    <!-- Connection info -->
    <div id="st-conn" class="panel flex flex-wrap items-center justify-center gap-x-6 gap-y-2 px-4 py-3 text-[13px] text-ink-subtle">
      <span class="flex items-center gap-1.5">
        <span class="text-ink-tertiary">ISP</span>
        <span id="st-isp" class="font-mono text-ink-muted">—</span>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="text-ink-tertiary">IP</span>
        <span id="st-ip" class="font-mono text-ink-muted">—</span>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="text-ink-tertiary">Server</span>
        <span id="st-server" class="font-mono text-ink-muted">—</span>
      </span>
    </div>

    <!-- Speedometer gauge -->
    <div class="panel panel-lift flex flex-col items-center gap-3 p-6">
      <svg id="st-gauge" viewBox="0 0 300 180" class="w-full max-w-md" role="img" aria-label="Speed gauge">
        <!-- track -->
        <path id="st-track" fill="none" stroke="#23252a" stroke-width="14" stroke-linecap="round" />
        <!-- active arc -->
        <path id="st-arc" fill="none" stroke="#5e6ad2" stroke-width="14" stroke-linecap="round" />
        <!-- tick labels are injected by script -->
        <g id="st-ticks" font-size="10" fill="#62666d" font-family="var(--font-mono)"></g>
        <!-- needle -->
        <line id="st-needle" x1="150" y1="150" x2="150" y2="55" stroke="#f7f8f8" stroke-width="3" stroke-linecap="round" />
        <circle cx="150" cy="150" r="6" fill="#f7f8f8" />
      </svg>

      <div class="text-center">
        <div class="flex items-baseline justify-center gap-2">
          <span id="st-readout" class="font-display text-4xl font-semibold tabular-nums text-ink">0.00</span>
          <span id="st-unit" class="font-mono text-sm text-ink-subtle">Mbps</span>
        </div>
        <div id="st-phase" class="mt-1 text-[13px] text-ink-subtle">Ready to test</div>
      </div>

      <button id="st-start" class="btn btn-primary mt-1">Start test</button>
    </div>

    <!-- Result tiles -->
    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel p-4">
        <div id="st-down" class="font-mono text-lg tabular-nums text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Download<span class="text-ink-tertiary"> Mbps</span></div>
      </div>
      <div class="panel p-4">
        <div id="st-up" class="font-mono text-lg tabular-nums text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Upload<span class="text-ink-tertiary"> Mbps</span></div>
      </div>
      <div class="panel p-4">
        <div id="st-ping" class="font-mono text-lg tabular-nums text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Ping<span class="text-ink-tertiary"> ms</span></div>
      </div>
      <div class="panel p-4">
        <div id="st-jitter" class="font-mono text-lg tabular-nums text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Jitter<span class="text-ink-tertiary"> ms</span></div>
      </div>
      <div class="panel p-4">
        <div id="st-loaded" class="font-mono text-lg tabular-nums text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Under load<span class="text-ink-tertiary"> ms</span></div>
      </div>
      <div class="panel p-4">
        <div id="st-grade" class="font-mono text-lg tabular-nums text-ink">—</div>
        <div class="mt-1 text-[13px] text-ink-subtle">Bufferbloat</div>
      </div>
    </div>

    <!-- Connection quality verdict -->
    <div id="st-verdict" class="panel hidden flex-col gap-2 p-4">
      <div class="text-[13px] font-medium text-ink-subtle">Your connection is good for</div>
      <div id="st-verdict-rows" class="flex flex-col gap-1.5"></div>
    </div>

    <!-- Actions -->
    <div id="st-actions" class="hidden flex-wrap items-center gap-3">
      <button id="st-copy" class="btn btn-secondary text-[13px]">Copy result</button>
      <span id="st-copied" class="hidden text-[13px] text-[color:var(--color-success)]">Copied</span>
    </div>

    <!-- Recent tests -->
    <div id="st-history-wrap" class="panel hidden flex-col gap-2 p-4">
      <div class="flex items-center justify-between">
        <div class="text-[13px] font-medium text-ink-subtle">Recent tests</div>
        <button id="st-clear" class="text-[13px] text-ink-tertiary hover:text-ink-subtle">Clear</button>
      </div>
      <div id="st-history" class="flex flex-col gap-1 font-mono text-[12px] text-ink-subtle"></div>
    </div>

    <p id="st-error" class="hidden text-[13px] leading-relaxed text-[#e5484d]"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free internet speed test measures your connection’s download and
      upload throughput in megabits per second (Mbps), along with ping latency
      and jitter in milliseconds. Unlike a simple single-stream check, it opens
      several parallel connections at once, so it can saturate — and accurately
      report — fast fibre and gigabit links that a single stream would badly
      under-measure.
    </p>
    <p>
      It also measures <strong class="text-ink-muted">latency under load</strong>
      and grades your <strong class="text-ink-muted">bufferbloat</strong>: how much
      your ping degrades while the connection is busy. This is the single best
      predictor of whether video calls, gaming and streaming stay smooth when
      someone else on the network starts a big download. A low ping at idle means
      little if it balloons under load, so we probe latency during the transfers,
      not just before them.
    </p>
    <p>
      The test runs entirely in your browser against Cloudflare’s global edge
      network, so results reflect the path between you and a nearby Cloudflare
      data center. Your ISP, IP address and the test server location are detected
      client-side. Real-world speeds vary with Wi-Fi signal, network congestion
      and the server on the other end. For the most accurate reading, connect over
      a wired link if you can, close other bandwidth-heavy tabs and apps, and run
      the test a few times.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const readout = $('st-readout');
  const unitEl = $('st-unit');
  const phaseEl = $('st-phase');
  const startBtn = $('st-start') as HTMLButtonElement;
  const arc = $('st-arc') as unknown as SVGPathElement;
  const track = $('st-track') as unknown as SVGPathElement;
  const needle = $('st-needle') as unknown as SVGLineElement;
  const ticksEl = $('st-ticks');
  const errEl = $('st-error');
  const out = {
    down: $('st-down'),
    up: $('st-up'),
    ping: $('st-ping'),
    jitter: $('st-jitter'),
    loaded: $('st-loaded'),
    grade: $('st-grade'),
  };

  const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
  const median = (a: number[]) => {
    if (!a.length) return 0;
    const s = [...a].sort((x, y) => x - y);
    const m = Math.floor(s.length / 2);
    return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2;
  };
  const percentile = (sorted: number[], p: number) => {
    if (!sorted.length) return 0;
    const i = Math.min(sorted.length - 1, Math.max(0, Math.floor((p / 100) * sorted.length)));
    return sorted[i];
  };

  const GOOD = '#27a644';
  const WARN = '#d99a2b';
  const BAD = '#e5484d';

  // ---- Gauge geometry: 240° arc from 150° (bottom-left) sweeping clockwise ----
  const CX = 150, CY = 150, R = 95;
  const START_ANGLE = 150; // degrees
  const SWEEP = 240; // degrees total
  // Non-linear scale so the common 0–100 Mbps range fills most of the dial.
  const SCALE_STOPS = [0, 10, 25, 50, 100, 250, 500, 1000];

  function polar(angleDeg: number, r = R) {
    const a = (angleDeg * Math.PI) / 180;
    return { x: CX + r * Math.cos(a), y: CY + r * Math.sin(a) };
  }

  function arcPath(fromDeg: number, toDeg: number, r = R) {
    const s = polar(fromDeg, r);
    const e = polar(toDeg, r);
    const large = Math.abs(toDeg - fromDeg) > 180 ? 1 : 0;
    return `M ${s.x} ${s.y} A ${r} ${r} 0 ${large} 1 ${e.x} ${e.y}`;
  }

  // Map a speed value to a 0..1 fraction along the piecewise scale.
  function speedToFrac(v: number) {
    const stops = SCALE_STOPS;
    const max = stops[stops.length - 1];
    if (v <= 0) return 0;
    if (v >= max) return 1;
    for (let i = 1; i < stops.length; i++) {
      if (v <= stops[i]) {
        const seg = (i - 1 + (v - stops[i - 1]) / (stops[i] - stops[i - 1])) / (stops.length - 1);
        return seg;
      }
    }
    return 1;
  }

  function setGauge(v: number) {
    const frac = speedToFrac(v);
    const angle = START_ANGLE + SWEEP * frac;
    arc.setAttribute('d', arcPath(START_ANGLE, Math.max(START_ANGLE + 0.01, angle)));
    const tip = polar(angle, R - 10);
    needle.setAttribute('x2', String(tip.x));
    needle.setAttribute('y2', String(tip.y));
  }

  // Build static track + tick labels once.
  track.setAttribute('d', arcPath(START_ANGLE, START_ANGLE + SWEEP));
  SCALE_STOPS.forEach((stop, i) => {
    const frac = i / (SCALE_STOPS.length - 1);
    const angle = START_ANGLE + SWEEP * frac;
    const p = polar(angle, R + 16);
    const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    t.setAttribute('x', String(p.x));
    t.setAttribute('y', String(p.y));
    t.setAttribute('text-anchor', 'middle');
    t.setAttribute('dominant-baseline', 'middle');
    t.textContent = String(stop);
    ticksEl.appendChild(t);
  });
  setGauge(0);

  // Smoothly animate the readout + gauge toward a target value.
  let displayed = 0;
  let raf = 0;
  function animateTo(target: number) {
    cancelAnimationFrame(raf);
    const step = () => {
      displayed += (target - displayed) * 0.15;
      if (Math.abs(target - displayed) < 0.05) displayed = target;
      readout.textContent = displayed.toFixed(2);
      setGauge(displayed);
      if (displayed !== target) raf = requestAnimationFrame(step);
    };
    raf = requestAnimationFrame(step);
  }
  function resetGauge() {
    cancelAnimationFrame(raf);
    displayed = 0;
    readout.textContent = '0.00';
    setGauge(0);
  }

  // ---- Cloudflare endpoints ----
  const DOWN = 'https://speed.cloudflare.com/__down?bytes=';
  const UP = 'https://speed.cloudflare.com/__up';
  const TRACE = 'https://speed.cloudflare.com/cdn-cgi/trace';
  const META = 'https://speed.cloudflare.com/meta';

  const STREAMS = 6; // parallel connections — saturates fast links
  const WARMUP_MS = 1200; // ramp-up, discarded from the reported figure
  const MEASURE_MS = 8000; // measured window
  const DOWN_CHUNK = 25_000_000;
  const UP_CHUNK = 3_000_000;

  const bitsToMbps = (bits: number) => bits / 1_000_000;

  // ---- Connection info (ISP / IP / server), client-side only ----
  const COLO: Record<string, string> = {
    SIN: 'Singapore', BOM: 'Mumbai', DEL: 'New Delhi', MAA: 'Chennai', BLR: 'Bengaluru',
    LHR: 'London', CDG: 'Paris', FRA: 'Frankfurt', AMS: 'Amsterdam', MAD: 'Madrid',
    IAD: 'Ashburn', EWR: 'Newark', LAX: 'Los Angeles', SJC: 'San Jose', ORD: 'Chicago',
    DFW: 'Dallas', SEA: 'Seattle', MIA: 'Miami', ATL: 'Atlanta', DEN: 'Denver',
    NRT: 'Tokyo', KIX: 'Osaka', HKG: 'Hong Kong', ICN: 'Seoul', SYD: 'Sydney',
    GRU: 'São Paulo', DXB: 'Dubai', JNB: 'Johannesburg', YYZ: 'Toronto', WAW: 'Warsaw',
  };

  async function loadConnInfo() {
    let ip = '', colo = '', loc = '', isp = '', city = '';
    try {
      const text = await (await fetch(TRACE, { cache: 'no-store' })).text();
      const m: Record<string, string> = {};
      text.trim().split('\n').forEach((line) => {
        const i = line.indexOf('=');
        if (i > 0) m[line.slice(0, i)] = line.slice(i + 1);
      });
      ip = m.ip || '';
      colo = (m.colo || '').toUpperCase();
      loc = m.loc || '';
    } catch {
      /* trace unreachable — leave placeholders */
    }
    // Enrichment: /meta returns ISP name + city in a real browser. Degrade gracefully.
    try {
      const meta = await (await fetch(META, { cache: 'no-store' })).json();
      isp = meta.asOrganization || meta.isp || '';
      city = meta.city || '';
    } catch {
      /* meta gated/blocked — trace-only is fine */
    }
    if (ip) $('st-ip').textContent = ip;
    if (isp) $('st-isp').textContent = isp;
    const place = COLO[colo] || city || loc;
    if (place || colo) $('st-server').textContent = colo ? `${place || colo} (${colo})` : place;
  }

  // ---- Latency ----
  async function measureLatency(samples = 10): Promise<{ ping: number; jitter: number }> {
    const times: number[] = [];
    for (let i = 0; i < samples; i++) {
      const t0 = performance.now();
      try {
        await fetch(DOWN + '0', { cache: 'no-store' });
        times.push(performance.now() - t0);
      } catch {
        /* skip failed probe */
      }
    }
    if (!times.length) throw new Error('no latency');
    times.sort((a, b) => a - b);
    const kept = times.slice(0, -1); // drop slowest outlier
    const ping = kept.reduce((s, t) => s + t, 0) / kept.length;
    let jitter = 0;
    for (let i = 1; i < kept.length; i++) jitter += Math.abs(kept[i] - kept[i - 1]);
    jitter = kept.length > 1 ? jitter / (kept.length - 1) : 0;
    return { ping, jitter };
  }

  // ---- Multi-stream throughput with concurrent latency probing under load ----
  type PhaseState = { stop: boolean; bytes: number };

  async function downStream(state: PhaseState) {
    while (!state.stop) {
      try {
        const res = await fetch(DOWN + DOWN_CHUNK, { cache: 'no-store' });
        const reader = res.body!.getReader();
        while (!state.stop) {
          const { done, value } = await reader.read();
          if (done) break;
          state.bytes += value!.length;
        }
        reader.cancel().catch(() => {});
      } catch {
        if (state.stop) break;
        await sleep(50);
      }
    }
  }

  async function upStream(state: PhaseState) {
    const payload = new Uint8Array(UP_CHUNK);
    while (!state.stop) {
      try {
        await fetch(UP, { method: 'POST', body: payload, cache: 'no-store' });
        state.bytes += UP_CHUNK;
      } catch {
        if (state.stop) break;
        await sleep(50);
      }
    }
  }

  async function measurePhase(kind: 'down' | 'up'): Promise<{ mbps: number; loaded: number }> {
    const state: PhaseState = { stop: false, bytes: 0 };
    const start = performance.now();
    const samples: number[] = [];
    const latencies: number[] = [];
    let lastBytes = 0;
    let lastT = start;

    const sampler = window.setInterval(() => {
      const now = performance.now();
      const dt = (now - lastT) / 1000;
      if (dt <= 0) return;
      const mbps = bitsToMbps(((state.bytes - lastBytes) * 8) / dt);
      lastBytes = state.bytes;
      lastT = now;
      if (isFinite(mbps) && mbps >= 0) {
        if (now - start > WARMUP_MS) samples.push(mbps);
        animateTo(mbps);
      }
    }, 200);

    // Probe round-trip latency *while the link is loaded* — the bufferbloat signal.
    const prober = (async () => {
      while (!state.stop) {
        const t0 = performance.now();
        try {
          await fetch(DOWN + '0', { cache: 'no-store' });
          if (performance.now() - start > WARMUP_MS) latencies.push(performance.now() - t0);
        } catch {
          /* ignore */
        }
        await sleep(250);
      }
    })();

    const streams: Promise<void>[] = [];
    for (let i = 0; i < STREAMS; i++) {
      streams.push(kind === 'down' ? downStream(state) : upStream(state));
    }

    await sleep(WARMUP_MS + MEASURE_MS);
    state.stop = true;
    await Promise.allSettled([...streams, prober]);
    window.clearInterval(sampler);

    samples.sort((a, b) => a - b);
    // Report the 90th-percentile sustained rate; fall back to overall average.
    const elapsed = (performance.now() - start) / 1000;
    const avg = elapsed > 0 ? bitsToMbps((state.bytes * 8) / elapsed) : 0;
    const mbps = samples.length ? Math.max(percentile(samples, 90), avg) : avg;
    latencies.sort((a, b) => a - b);
    return { mbps, loaded: median(latencies) };
  }

  // ---- Grading + verdict ----
  function bufferbloatGrade(deltaMs: number): { g: string; c: string } {
    if (deltaMs < 20) return { g: 'A+', c: GOOD };
    if (deltaMs < 40) return { g: 'A', c: GOOD };
    if (deltaMs < 75) return { g: 'B', c: GOOD };
    if (deltaMs < 150) return { g: 'C', c: WARN };
    if (deltaMs < 300) return { g: 'D', c: WARN };
    return { g: 'F', c: BAD };
  }

  type Result = {
    down: number; up: number; ping: number; jitter: number;
    loaded: number; grade: string;
  };

  function verdict(r: Result): { label: string; status: 'good' | 'ok' | 'poor' }[] {
    const status = (good: boolean, ok: boolean): 'good' | 'ok' | 'poor' =>
      good ? 'good' : ok ? 'ok' : 'poor';
    return [
      {
        label: 'Video calls',
        status: status(r.down >= 4 && r.up >= 3 && r.loaded < 150, r.down >= 1.5 && r.up >= 1),
      },
      {
        label: '4K streaming',
        status: status(r.down >= 25, r.down >= 15),
      },
      {
        label: 'Online gaming',
        status: status(r.ping < 50 && r.loaded < 100, r.ping < 100 && r.loaded < 200),
      },
      {
        label: 'Large downloads',
        status: status(r.down >= 100, r.down >= 25),
      },
    ];
  }

  function renderVerdict(r: Result) {
    const rows = $('st-verdict-rows');
    rows.innerHTML = '';
    const mark = { good: ['✓', GOOD], ok: ['~', WARN], poor: ['✗', BAD] } as const;
    for (const v of verdict(r)) {
      const [sym, col] = mark[v.status];
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2 text-[13px] text-ink-muted';
      row.innerHTML =
        `<span class="font-mono" style="color:${col}">${sym}</span>` +
        `<span>${v.label}</span>`;
      rows.appendChild(row);
    }
    $('st-verdict').classList.remove('hidden');
    $('st-verdict').classList.add('flex');
  }

  // ---- History (localStorage) ----
  const HKEY = 'toolcities-speedtest-history';
  function loadHistory(): (Result & { t: number })[] {
    try {
      return JSON.parse(localStorage.getItem(HKEY) || '[]');
    } catch {
      return [];
    }
  }
  function saveHistory(r: Result) {
    const list = loadHistory();
    list.unshift({ ...r, t: Date.now() });
    try {
      localStorage.setItem(HKEY, JSON.stringify(list.slice(0, 10)));
    } catch {
      /* storage full/blocked — non-fatal */
    }
    renderHistory();
  }
  function renderHistory() {
    const list = loadHistory();
    const wrap = $('st-history-wrap');
    const el = $('st-history');
    if (!list.length) {
      wrap.classList.add('hidden');
      wrap.classList.remove('flex');
      return;
    }
    el.innerHTML = '';
    for (const r of list.slice(0, 5)) {
      const d = new Date(r.t);
      const when = d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) +
        ' ' + d.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
      const row = document.createElement('div');
      row.className = 'flex items-center justify-between gap-4';
      row.innerHTML =
        `<span class="text-ink-tertiary">${when}</span>` +
        `<span>↓ ${r.down.toFixed(1)} · ↑ ${r.up.toFixed(1)} Mbps · ${r.ping.toFixed(0)} ms · ${r.grade}</span>`;
      el.appendChild(row);
    }
    wrap.classList.remove('hidden');
    wrap.classList.add('flex');
  }

  let lastResult: Result | null = null;

  function copyResult() {
    if (!lastResult) return;
    const r = lastResult;
    const server = $('st-server').textContent;
    const isp = $('st-isp').textContent;
    const text =
      `Internet Speed Test — toolcities.com\n` +
      `Download: ${r.down.toFixed(2)} Mbps\n` +
      `Upload:   ${r.up.toFixed(2)} Mbps\n` +
      `Ping:     ${r.ping.toFixed(0)} ms (idle) / ${r.loaded.toFixed(0)} ms (under load)\n` +
      `Jitter:   ${r.jitter.toFixed(0)} ms\n` +
      `Bufferbloat: ${r.grade}\n` +
      `ISP: ${isp} · Server: ${server}`;
    navigator.clipboard?.writeText(text).then(() => {
      const c = $('st-copied');
      c.classList.remove('hidden');
      setTimeout(() => c.classList.add('hidden'), 1800);
    });
  }

  function setPhase(label: string) {
    phaseEl.textContent = label;
  }
  function setUnit(u: string) {
    unitEl.textContent = u;
  }

  async function runTest() {
    errEl.classList.add('hidden');
    startBtn.disabled = true;
    startBtn.textContent = 'Testing…';
    $('st-actions').classList.add('hidden');
    out.down.textContent = out.up.textContent = out.ping.textContent =
      out.jitter.textContent = out.loaded.textContent = out.grade.textContent = '…';
    out.grade.removeAttribute('style');
    setUnit('Mbps');

    try {
      setPhase('Measuring latency…');
      resetGauge();
      const { ping, jitter } = await measureLatency();
      out.ping.textContent = ping.toFixed(0);
      out.jitter.textContent = jitter.toFixed(0);

      setPhase('Testing download…');
      resetGauge();
      const dl = await measurePhase('down');
      animateTo(dl.mbps);
      out.down.textContent = dl.mbps.toFixed(2);

      setPhase('Testing upload…');
      resetGauge();
      const ul = await measurePhase('up');
      animateTo(ul.mbps);
      out.up.textContent = ul.mbps.toFixed(2);

      // Loaded latency = worst of the two loaded phases; bufferbloat = increase over idle.
      const loaded = Math.max(dl.loaded, ul.loaded) || ping;
      const delta = Math.max(0, loaded - ping);
      const grade = bufferbloatGrade(delta);
      out.loaded.textContent = loaded.toFixed(0);
      out.grade.textContent = grade.g;
      out.grade.style.color = grade.c;

      const result: Result = {
        down: dl.mbps, up: ul.mbps, ping, jitter, loaded, grade: grade.g,
      };
      lastResult = result;
      renderVerdict(result);
      saveHistory(result);
      $('st-actions').classList.remove('hidden');
      $('st-actions').classList.add('flex');
      setPhase('Test complete');
    } catch {
      setPhase('Ready to test');
      resetGauge();
      errEl.textContent =
        'Could not reach the speed-test server. Check your connection or a blocker/extension, then try again.';
      errEl.classList.remove('hidden');
      out.down.textContent = out.up.textContent = out.ping.textContent =
        out.jitter.textContent = out.loaded.textContent = out.grade.textContent = '—';
    } finally {
      startBtn.disabled = false;
      startBtn.textContent = 'Test again';
    }
  }

  $('st-copy').addEventListener('click', copyResult);
  $('st-clear').addEventListener('click', () => {
    try {
      localStorage.removeItem(HKEY);
    } catch {
      /* ignore */
    }
    renderHistory();
  });
  startBtn.addEventListener('click', runTest);

  // Kick off info + history on load.
  loadConnInfo();
  renderHistory();
</script>

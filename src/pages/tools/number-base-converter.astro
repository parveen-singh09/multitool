---
import ToolLayout from '../../layouts/ToolLayout.astro';

// 2–36, with the common ones labelled.
const names: Record<number, string> = { 2: 'binary', 8: 'octal', 10: 'decimal', 16: 'hex' };
const baseOptions = Array.from({ length: 35 }, (_, i) => {
  const b = i + 2;
  return { value: b, label: names[b] ? `${b} (${names[b]})` : String(b) };
});
---

<ToolLayout slug="number-base-converter">
  <div class="panel flex flex-col gap-4 p-5">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Enter number
      <input id="nb-in" type="text" class="field font-mono" placeholder="10" spellcheck="false" autocomplete="off" autocapitalize="off" />
    </label>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        From base
        <select id="nb-from" class="field">
          {baseOptions.map((o) => <option value={o.value} selected={o.value === 10}>{o.label}</option>)}
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        To base
        <select id="nb-to" class="field">
          {baseOptions.map((o) => <option value={o.value} selected={o.value === 16}>{o.label}</option>)}
        </select>
      </label>
    </div>

    <div class="flex flex-wrap gap-3">
      <button id="nb-convert" type="button" class="btn btn-primary">Convert</button>
      <button id="nb-reset" type="button" class="btn btn-secondary">Reset</button>
      <button id="nb-swap" type="button" class="btn btn-secondary">⇅ Swap</button>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Result number
      <textarea id="nb-out" class="field min-h-24 resize-y font-mono break-all" readonly aria-label="Result number"></textarea>
    </label>

    <div>
      <button id="nb-copy" type="button" class="btn btn-secondary">Copy</button>
    </div>

    <p id="nb-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free number base converter translates a number from any base to any
      other base, from binary and octal through decimal, hexadecimal and every
      base in between (2–36). Pick a “from” and “to” base, hit Convert, and copy
      the result — or use Swap to reverse the direction instantly.
    </p>
    <p>
      Unlike most online converters, this one uses arbitrary-precision integers,
      so numbers far larger than 2<sup>53</sup> convert exactly instead of silently
      rounding. Negative values and leading zeros are supported too, and every
      conversion runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('nb-in') as HTMLInputElement;
  const from = document.getElementById('nb-from') as HTMLSelectElement;
  const to = document.getElementById('nb-to') as HTMLSelectElement;
  const out = document.getElementById('nb-out') as HTMLTextAreaElement;
  const err = document.getElementById('nb-error')!;

  // Arbitrary-precision parse: BigInt has no radix parser, so build it digit by digit.
  function parseBig(raw: string, base: number): bigint | null {
    let s = raw.trim().toLowerCase();
    let neg = false;
    if (s[0] === '+' || s[0] === '-') { neg = s[0] === '-'; s = s.slice(1); }
    if (!s) return null;
    const B = BigInt(base);
    let n = 0n;
    for (const ch of s) {
      const d = parseInt(ch, 36); // 0–35, NaN for non-alphanumerics
      if (isNaN(d) || d >= base) return null;
      n = n * B + BigInt(d);
    }
    return neg ? -n : n;
  }

  function convert() {
    err.classList.add('hidden');
    const raw = input.value.trim();
    if (!raw) { out.value = ''; return; }
    const n = parseBig(raw, Number(from.value));
    if (n === null) {
      out.value = '';
      err.textContent = `“${raw}” is not a valid base-${from.value} number.`;
      err.classList.remove('hidden');
      return;
    }
    out.value = n.toString(Number(to.value));
  }

  input.addEventListener('input', convert);
  from.addEventListener('change', convert);
  to.addEventListener('change', convert);
  document.getElementById('nb-convert')!.addEventListener('click', convert);

  document.getElementById('nb-reset')!.addEventListener('click', () => {
    input.value = '';
    out.value = '';
    from.value = '10';
    to.value = '16';
    err.classList.add('hidden');
    input.focus();
  });

  document.getElementById('nb-swap')!.addEventListener('click', () => {
    [from.value, to.value] = [to.value, from.value];
    if (out.value) input.value = out.value; // carry the result back as the new input
    convert();
  });

  const copyBtn = document.getElementById('nb-copy') as HTMLButtonElement;
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    copyBtn.textContent = 'Copied!';
    setTimeout(() => (copyBtn.textContent = 'Copy'), 1200);
  });
</script>

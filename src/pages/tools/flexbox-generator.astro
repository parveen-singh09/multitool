---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="flexbox-generator">
  <div class="flex flex-col gap-4">
    <div class="flex gap-2">
      <button id="fx-tab-flex" class="btn btn-primary">Flexbox</button>
      <button id="fx-tab-grid" class="btn btn-secondary">Grid</button>
    </div>

    <div id="fx-flex-ctrls" class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">display
        <select id="fx-display" class="field"><option>flex</option><option>inline-flex</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">flex-direction
        <select id="fx-dir" class="field"><option>row</option><option>row-reverse</option><option>column</option><option>column-reverse</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">flex-wrap
        <select id="fx-wrap" class="field"><option>nowrap</option><option>wrap</option><option>wrap-reverse</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">justify-content
        <select id="fx-justify" class="field"><option>flex-start</option><option>center</option><option>flex-end</option><option>space-between</option><option>space-around</option><option>space-evenly</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">align-items
        <select id="fx-align" class="field"><option>stretch</option><option>flex-start</option><option>center</option><option>flex-end</option><option>baseline</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">align-content
        <select id="fx-content" class="field"><option>stretch</option><option>flex-start</option><option>center</option><option>flex-end</option><option>space-between</option><option>space-around</option><option>space-evenly</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">gap: <span id="fx-gapv" class="text-ink">12px</span>
        <input id="fx-gap" type="range" min="0" max="48" value="12" class="w-full accent-primary" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Items
        <input id="fx-items" type="number" min="1" max="12" value="4" class="field" />
      </label>
    </div>

    <div id="fx-grid-ctrls" class="hidden grid-cols-2 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Columns
        <input id="fx-cols" type="number" min="1" max="6" value="3" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">gap: <span id="fx-ggapv" class="text-ink">12px</span>
        <input id="fx-ggap" type="range" min="0" max="48" value="12" class="w-full accent-primary" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Items
        <input id="fx-gitems" type="number" min="1" max="18" value="6" class="field" />
      </label>
    </div>

    <div id="fx-preview" class="min-h-40 rounded-lg border border-hairline bg-surface-2 p-4"></div>

    <div id="fx-item-panel" class="hidden flex-col gap-2 rounded-lg border border-hairline bg-surface-2 p-3">
      <div class="flex items-center justify-between">
        <span class="text-sm text-ink">Item <span id="fx-item-n">1</span> properties</span>
        <button id="fx-item-reset" class="btn btn-secondary text-xs">Reset item</button>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">order
          <input id="it-order" type="number" value="0" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">flex-grow
          <input id="it-grow" type="number" min="0" value="0" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">flex-shrink
          <input id="it-shrink" type="number" min="0" value="1" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">flex-basis
          <input id="it-basis" type="text" value="auto" placeholder="auto, 100px, 25%" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">align-self
          <select id="it-self" class="field"><option>auto</option><option>stretch</option><option>flex-start</option><option>center</option><option>flex-end</option><option>baseline</option></select>
        </label>
      </div>
    </div>

    <div class="copy-wrap">
      <pre class="hl-block field min-h-72" style="resize:vertical;overflow:auto"><code id="fx-css" class="hljs" style="background:transparent;padding:0"></code></pre>
      <button type="button" class="copy-icon" data-copy-target="#fx-css" aria-label="Copy"></button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Flexbox and CSS Grid generator lets you build layouts visually. In
      Flexbox mode, set every container property (display, direction, wrap,
      justify-content, align-items, align-content and gap), then click any item in
      the preview to edit its individual order, flex-grow, flex-shrink, flex-basis
      and align-self. Grid mode covers columns and gap. The preview updates live and
      the full CSS, including per-item rules, is ready to copy.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl } from '../../lib/highlight';
  const $ = (id: string) => document.getElementById(id)!;
  const preview = $('fx-preview') as HTMLElement;
  const cssEl = $('fx-css')!;
  const itemPanel = $('fx-item-panel') as HTMLElement;
  let rawOutput = '';
  let mode: 'flex' | 'grid' = 'flex';

  type ItemState = { order: number; grow: number; shrink: number; basis: string; self: string };
  const DEFAULT_ITEM: ItemState = { order: 0, grow: 0, shrink: 1, basis: 'auto', self: 'auto' };
  let items: ItemState[] = [];
  let selected = -1;

  const isDefault = (it: ItemState) =>
    it.order === 0 && it.grow === 0 && it.shrink === 1 && it.basis === 'auto' && it.self === 'auto';

  function box(i: number, custom: boolean): string {
    const it = items[i];
    const sel = i === selected;
    const style = [
      `order:${it.order}`,
      `flex-grow:${it.grow}`,
      `flex-shrink:${it.shrink}`,
      `flex-basis:${it.basis}`,
      `align-self:${it.self}`,
      'background:#5e6ad2', 'color:#fff', 'border-radius:8px', 'padding:16px 20px',
      'font:500 14px sans-serif', 'text-align:center', 'cursor:pointer',
      sel ? 'outline:2px solid #fff;outline-offset:2px' : '',
      custom ? 'box-shadow:inset 0 0 0 2px rgba(255,255,255,.4)' : '',
    ].filter(Boolean).join(';');
    return `<div data-idx="${i}" style="${style}">${i + 1}</div>`;
  }

  function itemRule(i: number): string {
    const it = items[i];
    const lines: string[] = [];
    if (it.order !== 0) lines.push(`order: ${it.order};`);
    if (it.grow !== 0) lines.push(`flex-grow: ${it.grow};`);
    if (it.shrink !== 1) lines.push(`flex-shrink: ${it.shrink};`);
    if (it.basis !== 'auto' && it.basis.trim() !== '') lines.push(`flex-basis: ${it.basis};`);
    if (it.self !== 'auto') lines.push(`align-self: ${it.self};`);
    if (!lines.length) return '';
    return `.container > .item-${i + 1} {\n  ${lines.join('\n  ')}\n}`;
  }

  function resize(n: number) {
    if (items.length > n) items.length = n;
    while (items.length < n) items.push({ ...DEFAULT_ITEM });
    if (selected >= n) { selected = -1; itemPanel.classList.add('hidden'); itemPanel.classList.remove('flex'); }
  }

  function loadItemPanel() {
    if (selected < 0) return;
    const it = items[selected];
    $('fx-item-n').textContent = String(selected + 1);
    ($('it-order') as HTMLInputElement).value = String(it.order);
    ($('it-grow') as HTMLInputElement).value = String(it.grow);
    ($('it-shrink') as HTMLInputElement).value = String(it.shrink);
    ($('it-basis') as HTMLInputElement).value = it.basis;
    ($('it-self') as HTMLSelectElement).value = it.self;
  }

  function update() {
    let containerCss = '';
    if (mode === 'flex') {
      const display = ($('fx-display') as HTMLSelectElement).value;
      const dir = ($('fx-dir') as HTMLSelectElement).value;
      const wrap = ($('fx-wrap') as HTMLSelectElement).value;
      const justify = ($('fx-justify') as HTMLSelectElement).value;
      const align = ($('fx-align') as HTMLSelectElement).value;
      const content = ($('fx-content') as HTMLSelectElement).value;
      const gap = ($('fx-gap') as HTMLInputElement).value;
      const count = Math.max(1, Math.min(12, Number(($('fx-items') as HTMLInputElement).value) || 4));
      resize(count);
      $('fx-gapv').textContent = `${gap}px`;
      Object.assign(preview.style, {
        display, flexDirection: dir, flexWrap: wrap, justifyContent: justify,
        alignItems: align, alignContent: content, gap: `${gap}px`, gridTemplateColumns: '',
      } as any);
      preview.innerHTML = items.map((it, i) => box(i, !isDefault(it))).join('');
      containerCss = `display: ${display};\nflex-direction: ${dir};\nflex-wrap: ${wrap};\njustify-content: ${justify};\nalign-items: ${align};\nalign-content: ${content};\ngap: ${gap}px;`;
      const itemRules = items.map((_, i) => itemRule(i)).filter(Boolean);
      rawOutput = `.container {\n  ${containerCss.replace(/\n/g, '\n  ')}\n}` + (itemRules.length ? '\n\n' + itemRules.join('\n\n') : '');
    } else {
      const cols = Math.max(1, Math.min(6, Number(($('fx-cols') as HTMLInputElement).value) || 3));
      const gap = ($('fx-ggap') as HTMLInputElement).value;
      const count = Math.max(1, Math.min(18, Number(($('fx-gitems') as HTMLInputElement).value) || 6));
      $('fx-ggapv').textContent = `${gap}px`;
      Object.assign(preview.style, {
        display: 'grid', gridTemplateColumns: `repeat(${cols}, 1fr)`, gap: `${gap}px`,
        flexDirection: '', flexWrap: '', justifyContent: '', alignItems: '', alignContent: '',
      } as any);
      preview.innerHTML = Array.from({ length: count }, (_, i) =>
        `<div style="background:#5e6ad2;color:#fff;border-radius:8px;padding:16px 20px;font:500 14px sans-serif;text-align:center">${i + 1}</div>`).join('');
      containerCss = `display: grid;\ngrid-template-columns: repeat(${cols}, 1fr);\ngap: ${gap}px;`;
      rawOutput = `.container {\n  ${containerCss.replace(/\n/g, '\n  ')}\n}`;
    }
    hl(cssEl, rawOutput, 'css');
  }

  function setMode(m: 'flex' | 'grid') {
    mode = m;
    selected = -1;
    itemPanel.classList.add('hidden');
    itemPanel.classList.remove('flex');
    $('fx-flex-ctrls').classList.toggle('hidden', m !== 'flex');
    $('fx-flex-ctrls').classList.toggle('grid', m === 'flex');
    $('fx-grid-ctrls').classList.toggle('hidden', m !== 'grid');
    $('fx-grid-ctrls').classList.toggle('grid', m === 'grid');
    ($('fx-tab-flex') as HTMLElement).className = `btn ${m === 'flex' ? 'btn-primary' : 'btn-secondary'}`;
    ($('fx-tab-grid') as HTMLElement).className = `btn ${m === 'grid' ? 'btn-primary' : 'btn-secondary'}`;
    update();
  }

  // Select an item by clicking it (flex mode only)
  preview.addEventListener('click', (e) => {
    if (mode !== 'flex') return;
    const target = (e.target as HTMLElement).closest('[data-idx]') as HTMLElement | null;
    if (!target) return;
    selected = Number(target.dataset.idx);
    itemPanel.classList.remove('hidden');
    itemPanel.classList.add('flex');
    loadItemPanel();
    update();
  });

  // Item property edits
  const itemInput = () => {
    if (selected < 0) return;
    items[selected] = {
      order: Math.trunc(Number(($('it-order') as HTMLInputElement).value) || 0),
      grow: Math.max(0, Number(($('it-grow') as HTMLInputElement).value) || 0),
      shrink: Math.max(0, Number(($('it-shrink') as HTMLInputElement).value) || 0),
      basis: (($('it-basis') as HTMLInputElement).value || 'auto').trim() || 'auto',
      self: ($('it-self') as HTMLSelectElement).value,
    };
    update();
  };
  ['it-order', 'it-grow', 'it-shrink', 'it-basis', 'it-self'].forEach((id) =>
    $(id).addEventListener('input', itemInput));

  $('fx-item-reset').addEventListener('click', () => {
    if (selected < 0) return;
    items[selected] = { ...DEFAULT_ITEM };
    loadItemPanel();
    update();
  });

  document.querySelectorAll('#fx-flex-ctrls select, #fx-flex-ctrls input, #fx-grid-ctrls input')
    .forEach((el) => el.addEventListener('input', update));
  $('fx-tab-flex').addEventListener('click', () => setMode('flex'));
  $('fx-tab-grid').addEventListener('click', () => setMode('grid'));
  setMode('flex');
</script>

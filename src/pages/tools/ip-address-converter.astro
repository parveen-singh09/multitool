---
import ToolLayout from '../../layouts/ToolLayout.astro';

const FORMATS = [
  { id: 'int', label: 'Integer (decimal)' },
  { id: 'hex', label: 'Hexadecimal' },
  { id: 'hexdot', label: 'Hex (dotted)' },
  { id: 'oct', label: 'Octal (integer)' },
  { id: 'octdot', label: 'Octal (dotted)' },
  { id: 'bin', label: 'Binary (dotted)' },
  { id: 'ipv6', label: 'IPv6-mapped' },
  { id: 'arpa', label: 'Reverse DNS (PTR)' },
];
---

<ToolLayout slug="ip-address-converter">
  <div class="flex flex-col gap-5">
    <div class="flex flex-col gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        IPv4 address
        <input id="ip-dotted" class="field font-mono" placeholder="192.168.1.1" spellcheck="false" autocomplete="off" />
      </label>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {FORMATS.map((f) => (
          <div class="panel p-3">
            <div class="flex items-center justify-between">
              <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">{f.label}</span>
              <button class="ip-copy btn btn-secondary px-2 py-1 text-xs" data-t={`ip-${f.id}`} type="button">Copy</button>
            </div>
            <div id={`ip-${f.id}`} class="mt-1 break-all font-mono text-sm text-ink"></div>
          </div>
        ))}
      </div>

      <div class="panel p-3">
        <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Address details</span>
        <div class="mt-2 grid grid-cols-1 gap-x-6 gap-y-1 text-sm sm:grid-cols-3">
          <div class="flex justify-between gap-2"><span class="text-ink-subtle">Class</span><span id="ip-class" class="font-mono text-ink"></span></div>
          <div class="flex justify-between gap-2"><span class="text-ink-subtle">Default mask</span><span id="ip-mask" class="font-mono text-ink"></span></div>
          <div class="flex justify-between gap-2"><span class="text-ink-subtle">Type</span><span id="ip-type" class="font-mono text-ink"></span></div>
        </div>
      </div>
    </div>

    <div class="border-t border-hairline pt-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Convert back to IPv4 — accepts decimal, <span class="font-mono">0x</span> hex, <span class="font-mono">0o</span> octal or <span class="font-mono">0b</span> binary
        <input id="ip-fromint" type="text" class="field font-mono" placeholder="3232235777  ·  0xC0A80101  ·  0b11000000..." spellcheck="false" autocomplete="off" />
      </label>
    </div>

    <div class="border-t border-hairline pt-4">
      <div class="flex items-center justify-between">
        <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Batch convert</span>
        <span class="flex gap-2">
          <button id="ip-batch-copy" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy CSV</button>
          <button id="ip-batch-dl" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download CSV</button>
        </span>
      </div>
      <div class="mt-2 grid grid-cols-1 gap-3 md:grid-cols-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          One IPv4 (or integer/hex/octal/binary) per line
          <textarea id="ip-batch-in" class="field font-mono" style="height:12rem;resize:vertical" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder="192.168.1.1&#10;10.0.0.1&#10;8.8.8.8"></textarea>
        </label>
        <div class="flex flex-col gap-1 text-sm text-ink-subtle">
          Result (CSV)
          <pre id="ip-batch-out" class="field font-mono" style="height:12rem;margin:0;overflow:auto;white-space:pre;font-size:13px;line-height:1.55"></pre>
        </div>
      </div>
    </div>

    <p id="ip-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free IP address converter turns an IPv4 address between its familiar
      dotted-decimal form and its 32-bit integer, hexadecimal (both
      <span class="font-mono">0x</span> and dotted), octal (integer and dotted),
      binary and IPv4-mapped IPv6 notation. It also derives the reverse-DNS
      (<span class="font-mono">in-addr.arpa</span> PTR) name so you can build
      rDNS zones directly. Integer and hex forms are handy for databases, access
      lists and low-level networking; the decimal form is what a browser resolves
      when you paste something like <span class="font-mono">http://3232235777</span>.
    </p>
    <p>
      Every conversion runs instantly in your browser — nothing is uploaded. The
      address details panel classifies the address (Class A–E, its default
      classful subnet mask, and whether it is private, loopback, link-local,
      CGNAT, multicast, reserved, documentation or public per the IANA special
      registries). The reverse box accepts any of those numeric formats, so you
      can paste a decimal, <span class="font-mono">0x</span> hex,
      <span class="font-mono">0o</span> octal or <span class="font-mono">0b</span>
      binary value and get the dotted address back. The batch tool converts a
      whole list at once and exports it as copy-ready CSV.
    </p>
  </div>
</ToolLayout>

<script>
  const dotted = document.getElementById('ip-dotted') as HTMLInputElement;
  const out = Object.fromEntries(
    ['int', 'hex', 'hexdot', 'oct', 'octdot', 'bin', 'ipv6', 'arpa'].map((k) => [k, document.getElementById('ip-' + k)!]),
  );
  const classEl = document.getElementById('ip-class')!;
  const maskEl = document.getElementById('ip-mask')!;
  const typeEl = document.getElementById('ip-type')!;
  const fromInt = document.getElementById('ip-fromint') as HTMLInputElement;
  const err = document.getElementById('ip-error')!;
  const batchIn = document.getElementById('ip-batch-in') as HTMLTextAreaElement;
  const batchOut = document.getElementById('ip-batch-out')!;
  let batchCsv = '';

  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }

  function parseIpv4(s: string): number | null {
    const parts = s.trim().split('.');
    if (parts.length !== 4) return null;
    let n = 0;
    for (const p of parts) {
      if (!/^\d{1,3}$/.test(p)) return null;
      const v = Number(p);
      if (v > 255) return null;
      n = n * 256 + v;
    }
    return n >>> 0;
  }

  // Flexible parse: dotted IPv4, or a single value in decimal / 0x hex / 0o octal / 0b binary.
  function parseAny(raw: string): { n: number } | { err: string } {
    const s = raw.trim();
    if (!s) return { err: 'empty' };
    if (s.includes('.')) {
      const n = parseIpv4(s);
      return n === null ? { err: 'not a valid IPv4 address' } : { n };
    }
    let base = 10, body = s;
    const m = /^0([xob])(.+)$/i.exec(s);
    if (m) { base = { x: 16, o: 8, b: 2 }[m[1].toLowerCase()]!; body = m[2]; }
    const re = { 16: /^[0-9a-f]+$/i, 8: /^[0-7]+$/, 10: /^\d+$/, 2: /^[01]+$/ }[base]!;
    if (!re.test(body)) return { err: 'not a valid number' };
    const n = parseInt(body, base);
    if (!Number.isFinite(n) || n < 0 || n > 4294967295) return { err: 'out of the 0–4294967295 range' };
    return { n: n >>> 0 };
  }

  const octets = (n: number) => [24, 16, 8, 0].map((sh) => (n >>> sh) & 255);
  const intToIpv4 = (n: number) => octets(n).join('.');

  function classify(o: number[]): { cls: string; mask: string; type: string } {
    const [a, b] = o;
    let cls = 'E (reserved)', mask = '—';
    if (a < 128) { cls = 'A'; mask = '255.0.0.0 (/8)'; }
    else if (a < 192) { cls = 'B'; mask = '255.255.0.0 (/16)'; }
    else if (a < 224) { cls = 'C'; mask = '255.255.255.0 (/24)'; }
    else if (a < 240) { cls = 'D (multicast)'; mask = '—'; }

    // IANA special-purpose ranges, most specific first.
    let type = 'Public';
    if (a === 0) type = 'This network (0.0.0.0/8)';
    else if (a === 10) type = 'Private (10.0.0.0/8)';
    else if (a === 100 && b >= 64 && b < 128) type = 'CGNAT / shared (100.64.0.0/10)';
    else if (a === 127) type = 'Loopback (127.0.0.0/8)';
    else if (a === 169 && b === 254) type = 'Link-local / APIPA (169.254.0.0/16)';
    else if (a === 172 && b >= 16 && b < 32) type = 'Private (172.16.0.0/12)';
    else if (a === 192 && b === 0 && o[2] === 0) type = 'IETF protocol (192.0.0.0/24)';
    else if (a === 192 && b === 0 && o[2] === 2) type = 'Documentation TEST-NET-1';
    else if (a === 192 && b === 88 && o[2] === 99) type = '6to4 relay anycast';
    else if (a === 192 && b === 168) type = 'Private (192.168.0.0/16)';
    else if (a === 198 && (b === 18 || b === 19)) type = 'Benchmarking (198.18.0.0/15)';
    else if (a === 198 && b === 51 && o[2] === 100) type = 'Documentation TEST-NET-2';
    else if (a === 203 && b === 0 && o[2] === 113) type = 'Documentation TEST-NET-3';
    else if (a === 255 && b === 255 && o[2] === 255 && o[3] === 255) type = 'Broadcast (255.255.255.255)';
    else if (a >= 224 && a < 240) type = 'Multicast (224.0.0.0/4)';
    else if (a >= 240) type = 'Reserved (240.0.0.0/4)';
    return { cls, mask, type };
  }

  function render(n: number) {
    setErr('');
    const o = octets(n);
    const u = n >>> 0;
    out.int.textContent = String(u);
    out.hex.textContent = '0x' + u.toString(16).toUpperCase().padStart(8, '0');
    out.hexdot.textContent = o.map((v) => v.toString(16).toUpperCase().padStart(2, '0')).join('.');
    out.oct.textContent = '0o' + u.toString(8);
    out.octdot.textContent = o.map((v) => v.toString(8).padStart(3, '0')).join('.');
    out.bin.textContent = o.map((v) => v.toString(2).padStart(8, '0')).join('.');
    out.ipv6.textContent = `::ffff:${((o[0] << 8) + o[1]).toString(16)}:${((o[2] << 8) + o[3]).toString(16)}`;
    out.arpa.textContent = `${o[3]}.${o[2]}.${o[1]}.${o[0]}.in-addr.arpa`;
    const c = classify(o);
    classEl.textContent = c.cls;
    maskEl.textContent = c.mask;
    typeEl.textContent = c.type;
  }

  function clearOut() {
    Object.values(out).forEach((e) => (e.textContent = ''));
    classEl.textContent = maskEl.textContent = typeEl.textContent = '';
  }

  dotted.addEventListener('input', () => {
    if (!dotted.value.trim()) { setErr(''); clearOut(); return; }
    const n = parseIpv4(dotted.value);
    if (n === null) { setErr('Enter a valid IPv4 address like 192.168.1.1'); return; }
    fromInt.value = String(n);
    render(n);
  });

  fromInt.addEventListener('input', () => {
    if (!fromInt.value.trim()) return;
    const r = parseAny(fromInt.value);
    if ('err' in r) { setErr(`Value is ${r.err}. Use decimal, 0x hex, 0o octal or 0b binary (0–4294967295).`); return; }
    dotted.value = intToIpv4(r.n);
    render(r.n);
  });

  // Batch conversion → CSV.
  function runBatch() {
    const lines = batchIn.value.split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
    if (!lines.length) { batchCsv = ''; batchOut.textContent = ''; return; }
    const rows = ['input,dotted,decimal,hex,binary,class,type'];
    for (const line of lines) {
      const r = parseAny(line);
      if ('err' in r) { rows.push(`${line},ERROR: ${r.err},,,,,`); continue; }
      const o = octets(r.n);
      const c = classify(o);
      rows.push([
        line,
        intToIpv4(r.n),
        String(r.n >>> 0),
        '0x' + (r.n >>> 0).toString(16).toUpperCase().padStart(8, '0'),
        o.map((v) => v.toString(2).padStart(8, '0')).join('.'),
        c.cls,
        `"${c.type}"`,
      ].join(','));
    }
    batchCsv = rows.join('\n');
    batchOut.textContent = batchCsv;
  }
  batchIn.addEventListener('input', runBatch);

  document.getElementById('ip-batch-copy')!.addEventListener('click', async (e) => {
    if (!batchCsv) return;
    await navigator.clipboard.writeText(batchCsv);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy CSV'), 1400);
  });

  document.getElementById('ip-batch-dl')!.addEventListener('click', () => {
    if (!batchCsv) return;
    const url = URL.createObjectURL(new Blob([batchCsv], { type: 'text/csv' }));
    const a = document.createElement('a');
    a.href = url; a.download = 'ip-conversions.csv';
    a.click();
    URL.revokeObjectURL(url);
  });

  document.querySelectorAll<HTMLButtonElement>('.ip-copy').forEach((b) => {
    b.addEventListener('click', async () => {
      await navigator.clipboard.writeText(document.getElementById(b.dataset.t!)!.textContent || '');
      b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
    });
  });

  dotted.value = '192.168.1.1'; dotted.dispatchEvent(new Event('input'));
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ip-address-converter">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      IPv4 address
      <input id="ip-dotted" class="field font-mono" placeholder="192.168.1.1" spellcheck="false" autocomplete="off" />
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {[
        { id: 'int', label: 'Integer (decimal)' },
        { id: 'hex', label: 'Hexadecimal' },
        { id: 'bin', label: 'Binary' },
        { id: 'ipv6', label: 'IPv6-mapped' },
      ].map((f) => (
        <div class="panel p-3">
          <div class="flex items-center justify-between">
            <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">{f.label}</span>
            <button class="ip-copy btn btn-secondary px-2 py-1 text-xs" data-t={`ip-${f.id}`} type="button">Copy</button>
          </div>
          <div id={`ip-${f.id}`} class="mt-1 break-all font-mono text-sm text-ink"></div>
        </div>
      ))}
    </div>

    <div class="border-t border-hairline pt-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Or enter an integer to convert back to IPv4
        <input id="ip-fromint" type="text" class="field font-mono" placeholder="3232235777" inputmode="numeric" spellcheck="false" autocomplete="off" />
      </label>
    </div>
    <p id="ip-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free IP address converter turns an IPv4 address between its familiar
      dotted-decimal form and its 32-bit integer, hexadecimal and binary
      representations, plus the IPv4-mapped IPv6 notation. Integer and hex forms
      are handy for databases, access lists and low-level networking. Enter an
      address or an integer and everything updates instantly in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const dotted = document.getElementById('ip-dotted') as HTMLInputElement;
  const intEl = document.getElementById('ip-int')!;
  const hexEl = document.getElementById('ip-hex')!;
  const binEl = document.getElementById('ip-bin')!;
  const ipv6El = document.getElementById('ip-ipv6')!;
  const fromInt = document.getElementById('ip-fromint') as HTMLInputElement;
  const err = document.getElementById('ip-error')!;

  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }

  function parseIpv4(s: string): number | null {
    const parts = s.trim().split('.');
    if (parts.length !== 4) return null;
    let n = 0;
    for (const p of parts) {
      if (!/^\d{1,3}$/.test(p)) return null;
      const v = Number(p);
      if (v > 255) return null;
      n = n * 256 + v;
    }
    return n >>> 0;
  }
  const intToIpv4 = (n: number) => [24, 16, 8, 0].map((sh) => (n >>> sh) & 255).join('.');

  function render(n: number) {
    setErr('');
    intEl.textContent = String(n >>> 0);
    hexEl.textContent = '0x' + (n >>> 0).toString(16).toUpperCase().padStart(8, '0');
    binEl.textContent = [24, 16, 8, 0].map((sh) => ((n >>> sh) & 255).toString(2).padStart(8, '0')).join('.');
    const octets = [24, 16, 8, 0].map((sh) => (n >>> sh) & 255);
    ipv6El.textContent = `::ffff:${((octets[0] << 8) + octets[1]).toString(16)}:${((octets[2] << 8) + octets[3]).toString(16)}`;
  }

  dotted.addEventListener('input', () => {
    if (!dotted.value.trim()) { setErr(''); [intEl, hexEl, binEl, ipv6El].forEach((e) => (e.textContent = '')); return; }
    const n = parseIpv4(dotted.value);
    if (n === null) { setErr('Enter a valid IPv4 address like 192.168.1.1'); return; }
    fromInt.value = String(n);
    render(n);
  });

  fromInt.addEventListener('input', () => {
    const v = fromInt.value.trim();
    if (!v) return;
    if (!/^\d+$/.test(v) || Number(v) > 4294967295) { setErr('Enter an integer from 0 to 4294967295.'); return; }
    const n = Number(v);
    dotted.value = intToIpv4(n);
    render(n);
  });

  document.querySelectorAll<HTMLButtonElement>('.ip-copy').forEach((b) => {
    b.addEventListener('click', async () => {
      await navigator.clipboard.writeText(document.getElementById(b.dataset.t!)!.textContent || '');
      b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
    });
  });

  dotted.value = '192.168.1.1'; dotted.dispatchEvent(new Event('input'));
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="placeholder-image-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-3">
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Width
          <input id="pl-w" type="number" min="16" max="4000" value="600" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height
          <input id="pl-h" type="number" min="16" max="4000" value="400" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Background
          <input id="pl-bg" type="color" value="#141516" class="field h-10 cursor-pointer p-1" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Text color
          <input id="pl-fg" type="color" value="#8a8f98" class="field h-10 cursor-pointer p-1" />
        </label>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Custom text (blank = show size)
        <input id="pl-text" class="field" placeholder="e.g. Hero image" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Format
        <select id="pl-fmt" class="field"><option value="image/png">PNG</option><option value="image/jpeg">JPG</option><option value="image/webp">WebP</option></select>
      </label>
    </div>

    <div class="flex flex-col items-center gap-4">
      <div class="flex w-full items-center justify-center overflow-auto rounded-lg border border-hairline bg-surface-2 p-4">
        <canvas id="pl-canvas" class="max-w-full"></canvas>
      </div>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    <button id="pl-dl" class="btn btn-primary">Download</button>
    <button id="pl-copy" class="btn btn-secondary">Copy data URI</button>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free placeholder image generator creates blank placeholder images at any
      dimensions with custom background and text colors, and either the size label
      or your own caption. Download it as PNG, JPG or WebP, or copy a data URI to
      paste straight into your HTML or CSS — no external placeholder service
      needed. Everything is drawn in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const canvas = $('pl-canvas') as HTMLCanvasElement;

  function draw() {
    const w = Math.max(16, Math.min(4000, Number(($('pl-w') as HTMLInputElement).value) || 600));
    const h = Math.max(16, Math.min(4000, Number(($('pl-h') as HTMLInputElement).value) || 400));
    const bg = ($('pl-bg') as HTMLInputElement).value;
    const fg = ($('pl-fg') as HTMLInputElement).value;
    const custom = ($('pl-text') as HTMLInputElement).value.trim();
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d')!;
    ctx.fillStyle = bg; ctx.fillRect(0, 0, w, h);
    ctx.fillStyle = fg;
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    const label = custom || `${w} × ${h}`;
    ctx.font = `${Math.max(12, Math.min(w, h) / 8)}px Inter, system-ui, sans-serif`;
    ctx.fillText(label, w / 2, h / 2);
  }

  ['pl-w', 'pl-h', 'pl-bg', 'pl-fg', 'pl-text'].forEach((id) => $(id).addEventListener('input', draw));

  $('pl-dl').addEventListener('click', () => {
    const fmt = ($('pl-fmt') as HTMLSelectElement).value;
    const ext = fmt === 'image/jpeg' ? 'jpg' : fmt === 'image/webp' ? 'webp' : 'png';
    const a = document.createElement('a');
    a.href = canvas.toDataURL(fmt, 0.92);
    a.download = `placeholder-${canvas.width}x${canvas.height}.${ext}`;
    a.click();
  });
  $('pl-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(canvas.toDataURL(($('pl-fmt') as HTMLSelectElement).value, 0.92));
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy data URI'), 1500);
  });
  draw();
</script>

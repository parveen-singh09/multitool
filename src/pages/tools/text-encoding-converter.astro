---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="text-encoding-converter">
  <div class="flex flex-col gap-4">
    <div class="flex gap-2" role="tablist" aria-label="Direction">
      <button id="te-mode-encode" data-mode="encode" class="te-mode btn btn-primary" aria-selected="true">Text → Bytes</button>
      <button id="te-mode-decode" data-mode="decode" class="te-mode btn btn-secondary" aria-selected="false">Bytes → Text</button>
    </div>

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Encoding
        <select id="te-enc" class="field w-auto py-1 text-[13px]"></select>
      </label>

      <label id="te-fmt-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span id="te-fmt-label">Byte format</span>
        <select id="te-fmt" class="field w-auto py-1 text-[13px]">
          <option value="16">Hexadecimal</option>
          <option value="10">Decimal</option>
          <option value="2">Binary</option>
          <option value="8">Octal</option>
          <option value="cp">Code points (U+)</option>
          <option value="base64">Base64</option>
        </select>
      </label>

      <label id="te-sep-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">
        Separator
        <select id="te-sep" class="field w-auto py-1 text-[13px]">
          <option value=" ">Space</option>
          <option value=", ">Comma</option>
          <option value="">None</option>
          <option value="\n">Newline</option>
        </select>
      </label>

      <label id="te-prefix-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">
        Prefix
        <select id="te-prefix" class="field w-auto py-1 text-[13px]">
          <option value="">None</option>
          <option value="0x">0x</option>
          <option value="\x">\x</option>
        </select>
      </label>

      <label id="te-upper-wrap" class="flex items-center gap-2 pb-2 text-sm text-ink-subtle">
        <input id="te-upper" type="checkbox" class="h-4 w-4" /> Uppercase
      </label>

      <label id="te-bom-wrap" class="flex items-center gap-2 pb-2 text-sm text-ink-subtle">
        <input id="te-bom" type="checkbox" class="h-4 w-4" /> Add BOM
      </label>
    </div>

    <div id="te-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span id="te-in-label">Text input</span>
          <button id="te-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
        </span>
        <div class="hl-edit field p-0" style="height:22rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="te-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea id="te-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="Input"></textarea>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span id="te-out-label">Byte output</span>
          <span class="flex gap-2">
            <button id="te-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
          </span>
        </span>
        <div class="copy-wrap"><pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre-wrap;word-break:break-all"><code id="te-out" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#te-out" aria-label="Copy"></button></div>
      </div>
    </div>

    <p id="te-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free text encoding converter turns any text into its raw bytes and
      back again, entirely in your browser. Encode to UTF-8, UTF-16 (LE/BE),
      UTF-32 (LE/BE), ASCII or Latin-1 (ISO-8859-1), and view the result as
      hexadecimal, decimal, binary, octal, Unicode code points or Base64. Choose
      a separator (space, comma, newline or none) and an optional <code>0x</code>
      or <code>\x</code> prefix, force uppercase hex, and prepend a byte-order
      mark. A live byte, character and code-point count sits above both panes.
    </p>
    <p>
      Switch to <strong>Bytes → Text</strong> to decode. Paste bytes in any base
      (or Base64) and decode them with a full set of legacy and Unicode charsets
      — UTF-8, UTF-16, ASCII, the ISO-8859 family, the Windows code pages, plus
      Shift_JIS, EUC-JP, Big5, GBK, KOI8-R and more via the browser's native
      <code>TextDecoder</code>. It's a practical way to see how multi-byte
      characters and emoji are stored, debug mojibake and encoding mismatches,
      inspect byte counts, and recover text from a byte dump. Copy or download the result with one click.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl, wireInput } from '../../lib/highlight';

  const inEl = document.getElementById('te-in') as HTMLTextAreaElement;
  const inHlEl = document.getElementById('te-in-hl')!;
  const outEl = document.getElementById('te-out')!;
  const encSel = document.getElementById('te-enc') as HTMLSelectElement;
  const fmtSel = document.getElementById('te-fmt') as HTMLSelectElement;
  const sepSel = document.getElementById('te-sep') as HTMLSelectElement;
  const prefixSel = document.getElementById('te-prefix') as HTMLSelectElement;
  const upperBox = document.getElementById('te-upper') as HTMLInputElement;
  const bomBox = document.getElementById('te-bom') as HTMLInputElement;
  const statusEl = document.getElementById('te-status')!;
  const errEl = document.getElementById('te-error')!;
  const inLabel = document.getElementById('te-in-label')!;
  const outLabel = document.getElementById('te-out-label')!;
  const fmtLabel = document.getElementById('te-fmt-label')!;
  const fmtWrap = document.getElementById('te-fmt-wrap')!;
  const sepWrap = document.getElementById('te-sep-wrap')!;
  const prefixWrap = document.getElementById('te-prefix-wrap')!;
  const upperWrap = document.getElementById('te-upper-wrap')!;
  const bomWrap = document.getElementById('te-bom-wrap')!;

  let mode: 'encode' | 'decode' = 'encode';
  let rawOutput = '';

  const ENCODE_OPTS: [string, string][] = [
    ['utf-8', 'UTF-8'],
    ['utf-16le', 'UTF-16 LE'],
    ['utf-16be', 'UTF-16 BE'],
    ['utf-32le', 'UTF-32 LE'],
    ['utf-32be', 'UTF-32 BE'],
    ['ascii', 'ASCII (7-bit)'],
    ['iso-8859-1', 'Latin-1 (ISO-8859-1)'],
  ];

  const DECODE_OPTS: [string, string][] = [
    ['utf-8', 'UTF-8'],
    ['utf-16le', 'UTF-16 LE'],
    ['utf-16be', 'UTF-16 BE'],
    ['ascii', 'ASCII / Latin-1'],
    ['iso-8859-1', 'ISO-8859-1 (Latin-1)'],
    ['iso-8859-2', 'ISO-8859-2 (Latin-2)'],
    ['iso-8859-5', 'ISO-8859-5 (Cyrillic)'],
    ['iso-8859-15', 'ISO-8859-15 (Latin-9)'],
    ['windows-1250', 'Windows-1250'],
    ['windows-1251', 'Windows-1251 (Cyrillic)'],
    ['windows-1252', 'Windows-1252'],
    ['shift_jis', 'Shift_JIS'],
    ['euc-jp', 'EUC-JP'],
    ['euc-kr', 'EUC-KR'],
    ['big5', 'Big5'],
    ['gbk', 'GBK'],
    ['gb18030', 'GB18030'],
    ['koi8-r', 'KOI8-R'],
    ['macintosh', 'Macintosh (Mac Roman)'],
  ];

  function fillEncodings(prev?: string) {
    const opts = mode === 'encode' ? ENCODE_OPTS : DECODE_OPTS;
    encSel.innerHTML = opts.map(([v, l]) => `<option value="${v}">${l}</option>`).join('');
    if (prev && opts.some(([v]) => v === prev)) encSel.value = prev;
  }

  function encodeText(text: string, label: string): Uint8Array {
    if (label === 'utf-8') return new TextEncoder().encode(text);
    if (label === 'utf-16le' || label === 'utf-16be') {
      const be = label === 'utf-16be';
      const out: number[] = [];
      for (let i = 0; i < text.length; i++) {
        const c = text.charCodeAt(i); 
        if (be) out.push((c >> 8) & 0xff, c & 0xff);
        else out.push(c & 0xff, (c >> 8) & 0xff);
      }
      return Uint8Array.from(out);
    }
    if (label === 'utf-32le' || label === 'utf-32be') {
      const be = label === 'utf-32be';
      const out: number[] = [];
      for (const ch of text) {
        const cp = ch.codePointAt(0)!;
        const b = [cp & 0xff, (cp >> 8) & 0xff, (cp >> 16) & 0xff, (cp >> 24) & 0xff];
        out.push(...(be ? b.reverse() : b));
      }
      return Uint8Array.from(out);
    }

    const max = label === 'ascii' ? 0x7f : 0xff;
    return Uint8Array.from(Array.from(text, (ch) => {
      const c = ch.codePointAt(0)!;
      return c > max ? 0x3f : c;
    }));
  }

  function bomFor(label: string): number[] {
    switch (label) {
      case 'utf-8': return [0xef, 0xbb, 0xbf];
      case 'utf-16le': return [0xff, 0xfe];
      case 'utf-16be': return [0xfe, 0xff];
      case 'utf-32le': return [0xff, 0xfe, 0x00, 0x00];
      case 'utf-32be': return [0x00, 0x00, 0xfe, 0xff];
      default: return [];
    }
  }

  function formatBytes(bytes: Uint8Array, text: string): string {
    const fmt = fmtSel.value;
    const sep = sepSel.value === '\\n' ? '\n' : sepSel.value;

    if (fmt === 'base64') {
      let bin = '';
      for (const b of bytes) bin += String.fromCharCode(b);
      return btoa(bin);
    }
    if (fmt === 'cp') {

      return Array.from(text, (ch) => 'U+' + ch.codePointAt(0)!.toString(16).toUpperCase().padStart(4, '0')).join(sep || ' ');
    }
    const r = Number(fmt);
    const pad = r === 16 ? 2 : r === 8 ? 3 : r === 2 ? 8 : 0;
    const prefix = prefixSel.value === '\\x' ? '\\x' : prefixSel.value;
    return Array.from(bytes, (b) => {
      let s = b.toString(r);
      if (pad) s = s.padStart(pad, '0');
      if (upperBox.checked && r === 16) s = s.toUpperCase();
      return prefix + s;
    }).join(sep);
  }

  function parseBytes(raw: string): Uint8Array {
    const fmt = fmtSel.value;
    if (fmt === 'base64') {
      const bin = atob(raw.replace(/\s+/g, ''));
      return Uint8Array.from(bin, (c) => c.charCodeAt(0));
    }
    if (fmt === 'cp') {

      const cps = raw.replace(/U\+/gi, '').split(/[\s,]+/).filter(Boolean);
      const chars = cps.map((c) => {
        const n = parseInt(c, 16);
        if (!Number.isInteger(n) || n < 0 || n > 0x10ffff) throw new Error(`invalid code point "${c}"`);
        return String.fromCodePoint(n);
      }).join('');
      return encodeText(chars, encSel.value);
    }
    const r = Number(fmt);
    const groups = raw.replace(/0x/gi, '').replace(/\\x/gi, '').split(/[\s,]+/).filter(Boolean);
    const nums = groups.map((g) => {
      const n = parseInt(g, r);
      if (!Number.isInteger(n) || n < 0 || n > 255) throw new Error(`"${g}" is not a valid byte in base ${r}`);
      return n;
    });
    return Uint8Array.from(nums);
  }

  function showStatus(msg: string) {
    statusEl.textContent = msg;
    statusEl.style.borderColor = '#27a644';
    statusEl.style.color = '#27a644';
    statusEl.classList.remove('hidden');
  }
  function showError(msg: string) {
    rawOutput = ''; outEl.textContent = ''; statusEl.classList.add('hidden');
    errEl.textContent = msg; errEl.classList.remove('hidden');
  }

  function syncUI() {
    if (mode === 'encode') {
      inLabel.textContent = 'Text input';
      outLabel.textContent = 'Byte output';
      fmtLabel.textContent = 'Byte format';
      sepWrap.style.display = fmtSel.value === 'base64' ? 'none' : '';
      prefixWrap.style.display = fmtSel.value === '16' || fmtSel.value === '8' ? '' : 'none';
      upperWrap.style.display = fmtSel.value === '16' ? '' : 'none';
      bomWrap.style.display = bomFor(encSel.value).length ? '' : 'none';
    } else {
      inLabel.textContent = 'Bytes input';
      outLabel.textContent = 'Decoded text';
      fmtLabel.textContent = 'Input format';
      sepWrap.style.display = 'none';
      prefixWrap.style.display = 'none';
      upperWrap.style.display = 'none';
      bomWrap.style.display = 'none';
    }
  }

  async function convert() {
    syncUI();
    errEl.classList.add('hidden');
    const raw = inEl.value;
    if (!raw.trim()) {
      rawOutput = ''; outEl.textContent = ''; statusEl.classList.add('hidden');
      return;
    }
    try {
      if (mode === 'encode') {
        let bytes = encodeText(raw, encSel.value);
        if (bomBox.checked) {
          const bom = bomFor(encSel.value);
          if (bom.length) bytes = Uint8Array.from([...bom, ...bytes]);
        }
        rawOutput = formatBytes(bytes, raw);
        await hl(outEl, rawOutput, 'plaintext');
        const chars = Array.from(raw).length;
        showStatus(`${bytes.length} bytes · ${chars} code points · ${raw.length} UTF-16 units · ${encSel.selectedOptions[0].text}`);
      } else {
        const bytes = parseBytes(raw);
        // TextDecoder with fatal:false substitutes U+FFFD on bad sequences rather than throwing.
        const text = new TextDecoder(encSel.value, { fatal: false }).decode(bytes);
        rawOutput = text;
        await hl(outEl, rawOutput, 'plaintext');
        const bad = (text.match(/�/g) || []).length;
        showStatus(`${bytes.length} bytes → ${Array.from(text).length} code points · ${encSel.selectedOptions[0].text}${bad ? ` · ${bad} replacement char${bad > 1 ? 's' : ''}` : ''}`);
      }
    } catch (e) {
      showError(`${mode === 'encode' ? 'Encoding' : 'Decoding'} failed: ${(e as Error).message}`);
    }
  }

  const rerender = wireInput(inEl, inHlEl, () => 'plaintext', () => { void convert(); });

  // Mode tabs
  document.querySelectorAll<HTMLButtonElement>('.te-mode').forEach((tab) => {
    tab.addEventListener('click', () => {
      const next = tab.dataset.mode as 'encode' | 'decode';
      if (next === mode) return;
      const prevEnc = encSel.value;
      mode = next;
      document.querySelectorAll('.te-mode').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      fillEncodings(prevEnc);
      // Swap panes: previous output becomes the new input (round-trip friendly).
      if (rawOutput) { inEl.value = rawOutput; rerender(); }
      void convert();
    });
  });

  [encSel, fmtSel, sepSel, prefixSel].forEach((el) => el.addEventListener('change', () => { void convert(); }));
  [upperBox, bomBox].forEach((el) => el.addEventListener('change', () => { void convert(); }));

  document.getElementById('te-clear')!.addEventListener('click', () => {
    inEl.value = ''; rawOutput = ''; outEl.textContent = '';
    errEl.classList.add('hidden'); statusEl.classList.add('hidden');
    rerender();
  });

  document.getElementById('te-download')!.addEventListener('click', () => {
    if (!rawOutput) return;
    const blob = new Blob([rawOutput], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = mode === 'encode' ? 'bytes.txt' : 'decoded.txt';
    a.click();
    URL.revokeObjectURL(url);
  });

  // Seed
  fillEncodings('utf-8');
  inEl.value = 'Héllo 😀';
  rerender();
  void convert();
</script>

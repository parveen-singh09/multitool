---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="aisong-analyzer">
  <div class="flex flex-col gap-5">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Song lyrics
      <textarea id="as-in" class="field min-h-64 resize-y text-[14px] leading-relaxed" placeholder="Paste lyrics here. Use section tags like [Verse], [Chorus], [Bridge] (as in Suno / Udio) and the analyzer will map the structure." spellcheck="false"></textarea>
    </label>

    <div id="as-grid" class="grid grid-cols-2 gap-3 sm:grid-cols-4"></div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="panel p-4">
        <div class="eyebrow mb-3">Structure</div>
        <div id="as-structure" class="flex flex-col gap-1.5 text-[13px]"></div>
      </div>
      <div class="panel p-4">
        <div class="eyebrow mb-3">Rhyme scheme (per section)</div>
        <div id="as-rhyme" class="flex flex-col gap-2 font-mono text-[13px]"></div>
      </div>
    </div>

    <div class="panel p-4">
      <div class="eyebrow mb-2">Suggested style tags</div>
      <div id="as-tags" class="flex flex-wrap gap-2"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free AI song analyzer breaks down lyrics written for AI music tools like
      Suno and Udio. It maps the song structure from <code>[Verse]</code>,
      <code>[Chorus]</code> and <code>[Bridge]</code> tags, counts sections, lines
      and words, estimates syllables per line and reading level, detects the rhyme
      scheme of each section (labelled A/B/C…), flags the repeated hook, and
      suggests style/genre tags you can feed back into your prompt. Everything runs
      in your browser — your lyrics are never uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('as-in') as HTMLTextAreaElement;
  const grid = document.getElementById('as-grid')!;

  interface Section { tag: string; lines: string[]; }

  function parseSections(text: string): Section[] {
    const lines = text.split('\n');
    const sections: Section[] = [];
    let current: Section = { tag: 'Intro', lines: [] };
    let started = false;
    for (const raw of lines) {
      const line = raw.trim();
      const m = line.match(/^\[([^\]]+)\]$/);
      if (m) {
        if (started || current.lines.length) sections.push(current);
        current = { tag: m[1].trim(), lines: [] };
        started = true;
        continue;
      }
      if (line) current.lines.push(line);
    }
    if (current.lines.length || started) sections.push(current);
    return sections.filter((s) => s.lines.length || s.tag);
  }

  function countSyllables(word: string): number {
    const w = word.toLowerCase().replace(/[^a-z]/g, '');
    if (!w) return 0;
    if (w.length <= 3) return 1;
    const groups = w.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '').replace(/^y/, '').match(/[aeiouy]{1,2}/g);
    return groups ? groups.length : 1;
  }

  function lineSyllables(line: string): number {
    return line.split(/\s+/).reduce((a, w) => a + countSyllables(w), 0);
  }

  // Rhyme key: last vowel-cluster onward of the last word (very rough).
  function rhymeKey(line: string): string {
    const words = line.toLowerCase().replace(/[^a-z\s]/g, '').trim().split(/\s+/);
    const last = words[words.length - 1] || '';
    const m = last.match(/[aeiouy][a-z]*$/);
    return m ? m[0] : last;
  }

  function schemeFor(lines: string[]): string {
    const keys = lines.map(rhymeKey);
    const labels: Record<string, string> = {};
    let next = 0;
    return keys
      .map((k) => {
        if (!k) return '·';
        if (!(k in labels)) labels[k] = String.fromCharCode(65 + (next++ % 26));
        return labels[k];
      })
      .join(' ');
  }

  const GENRE_HINTS: [RegExp, string][] = [
    [/love|heart|kiss|forever|baby/i, 'romantic'],
    [/night|dance|club|floor|lights/i, 'dance-pop'],
    [/road|truck|town|whiskey|country/i, 'country'],
    [/street|money|grind|flow|real/i, 'hip-hop'],
    [/god|soul|rise|glory|heaven/i, 'gospel / anthemic'],
    [/dark|pain|scream|break|burn/i, 'rock / emo'],
    [/dream|stars|sky|float|glow/i, 'dream-pop'],
    [/sad|cry|alone|tears|goodbye/i, 'ballad'],
  ];

  function tile(label: string, value: string): string {
    return `<div class="panel panel-lift flex flex-col gap-1 p-4">
      <span class="text-[12px] text-ink-tertiary">${label}</span>
      <span class="font-display text-2xl font-semibold text-ink">${value}</span>
    </div>`;
  }

  function analyze() {
    const text = input.value;
    const sections = parseSections(text);
    const allLines = sections.flatMap((s) => s.lines);
    const words = text.replace(/\[[^\]]*\]/g, '').split(/\s+/).filter(Boolean);
    const totalSyll = allLines.reduce((a, l) => a + lineSyllables(l), 0);
    const avgSyll = allLines.length ? (totalSyll / allLines.length) : 0;

    // Reading ease (Flesch, approximate) on the plain text.
    const sentences = Math.max(1, (text.match(/[.!?]+/g) || []).length || allLines.length);
    const ease = words.length ? 206.835 - 1.015 * (words.length / sentences) - 84.6 * (totalSyll / words.length) : 0;

    grid.innerHTML =
      tile('Sections', String(sections.length)) +
      tile('Lines', String(allLines.length)) +
      tile('Words', String(words.length)) +
      tile('Avg syllables/line', avgSyll.toFixed(1));

    // Structure list with repeated-hook detection.
    const tagCounts: Record<string, number> = {};
    sections.forEach((s) => { tagCounts[s.tag.toLowerCase()] = (tagCounts[s.tag.toLowerCase()] || 0) + 1; });
    document.getElementById('as-structure')!.innerHTML = sections
      .map((s, i) => {
        const repeated = tagCounts[s.tag.toLowerCase()] > 1;
        return `<div class="flex items-center gap-2">
          <span class="w-6 text-ink-tertiary">${i + 1}.</span>
          <span class="rounded-[4px] bg-surface-2 px-2 py-0.5 text-ink">${s.tag}</span>
          <span class="text-ink-tertiary">${s.lines.length} line${s.lines.length === 1 ? '' : 's'}</span>
          ${repeated ? '<span class="text-primary-hover">↻ repeated</span>' : ''}
        </div>`;
      })
      .join('') || '<span class="text-ink-tertiary">No lines yet.</span>';

    // Rhyme scheme per section.
    document.getElementById('as-rhyme')!.innerHTML = sections
      .filter((s) => s.lines.length)
      .map((s) => `<div><span class="text-ink-subtle">${s.tag}:</span> <span class="text-ink">${schemeFor(s.lines)}</span></div>`)
      .join('') || '<span class="text-ink-tertiary">—</span>';

    // Style tags.
    const tags = new Set<string>();
    for (const [re, tag] of GENRE_HINTS) if (re.test(text)) tags.add(tag);
    if (ease > 80) tags.add('simple / catchy');
    if (avgSyll > 10) tags.add('wordy / rap-leaning');
    if (tagCounts['chorus'] > 1) tags.add('hook-driven');
    if (!tags.size) tags.add('pop');
    document.getElementById('as-tags')!.innerHTML = [...tags]
      .map((t) => `<span class="status-badge">${t}</span>`)
      .join('') + `<span class="status-badge">reading ease ${Math.round(ease)}</span>`;
  }

  input.addEventListener('input', analyze);
  input.value = '[Verse]\nCity lights are calling out my name\nDriving through the neon and the rain\n\n[Chorus]\nWe are the fire, we are the flame\nBurning up the night, we feel no shame\n\n[Verse]\nEvery shadow hiding what we know\nHolding onto something we let go\n\n[Chorus]\nWe are the fire, we are the flame\nBurning up the night, we feel no shame';
  analyze();
</script>

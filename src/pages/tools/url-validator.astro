---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="url-validator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      URL(s) — one per line
      <textarea id="uv-in" class="field min-h-32 resize-y font-mono text-[13px]" placeholder="https://example.com/path?q=1#top" spellcheck="false">https://user@example.com:8080/path/page?q=1&sort=asc#section</textarea>
    </label>

    <div class="grid grid-cols-3 gap-3 text-center">
      <div class="panel panel-lift p-4"><div id="uv-total" class="font-display text-xl font-semibold text-primary-hover">0</div><div class="mt-1 text-[13px] text-ink-subtle">Total</div></div>
      <div class="panel p-4"><div id="uv-valid" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Valid</div></div>
      <div class="panel p-4"><div id="uv-invalid" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Invalid</div></div>
    </div>

    <div id="uv-results" class="flex flex-col gap-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free URL validator checks whether one URL or a whole list is
      well-formed using the browser's own URL parser. For every valid URL it
      breaks the address into its protocol, host, port, path, query and
      fragment so you can inspect each part. Invalid URLs are flagged clearly.
      Paste one URL per line to validate them in bulk — everything runs entirely
      in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('uv-in') as HTMLTextAreaElement;
  const results = document.getElementById('uv-results')!;
  const totalEl = document.getElementById('uv-total')!;
  const validEl = document.getElementById('uv-valid')!;
  const invalidEl = document.getElementById('uv-invalid')!;

  function part(label: string, value: string): HTMLDivElement {
    const row = document.createElement('div');
    row.className = 'flex gap-2 text-[13px]';
    const k = document.createElement('span');
    k.className = 'text-ink-muted w-20 shrink-0';
    k.textContent = label;
    const v = document.createElement('span');
    v.className = 'font-mono text-ink break-all';
    v.textContent = value || '—';
    row.appendChild(k);
    row.appendChild(v);
    return row;
  }

  function card(line: string): { el: HTMLDivElement; ok: boolean } {
    const el = document.createElement('div');
    el.className = 'panel p-4 flex flex-col gap-2';
    const head = document.createElement('div');
    head.className = 'flex flex-wrap items-center gap-2';
    const badge = document.createElement('span');
    badge.className = 'font-mono text-[13px] font-semibold';
    const addr = document.createElement('span');
    addr.className = 'font-mono text-[13px] text-ink break-all';
    addr.textContent = line;
    head.appendChild(badge);
    head.appendChild(addr);
    el.appendChild(head);

    let ok = true;
    try {
      const u = new URL(line);
      badge.textContent = '✓ valid';
      badge.style.color = '#27a644';
      el.appendChild(part('Protocol', u.protocol));
      el.appendChild(part('Host', u.hostname));
      el.appendChild(part('Port', u.port));
      el.appendChild(part('Path', u.pathname));
      el.appendChild(part('Query', u.search));
      el.appendChild(part('Fragment', u.hash));
    } catch {
      ok = false;
      badge.textContent = '✕ invalid';
      badge.style.color = '#e5484d';
    }
    return { el, ok };
  }

  function validate() {
    const lines = input.value.split('\n').map((l) => l.trim()).filter((l) => l !== '');
    results.replaceChildren();
    let valid = 0;
    for (const line of lines) {
      const { el, ok } = card(line);
      if (ok) valid++;
      results.appendChild(el);
    }
    totalEl.textContent = String(lines.length);
    validEl.textContent = String(valid);
    invalidEl.textContent = String(lines.length - valid);
  }

  input.addEventListener('input', validate);
  validate();
</script>

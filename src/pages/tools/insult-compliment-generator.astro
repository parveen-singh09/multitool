---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="insult-compliment-generator">
  <div class="flex flex-col gap-4">
    <div class="flex gap-2">
      <button id="ic-tab-comp" class="btn btn-primary">Compliment</button>
      <button id="ic-tab-insult" class="btn btn-secondary">Playful insult</button>
    </div>
    <div class="panel panel-lift flex min-h-24 items-center p-5">
      <p id="ic-out" class="text-lg leading-relaxed text-ink"></p>
    </div>
    <div class="flex gap-2">
      <button id="ic-gen" class="btn btn-primary">Generate</button>
      <button id="ic-copy" class="btn btn-secondary">Copy</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free compliment and insult generator serves up warm, genuine
      compliments to brighten someone's day, or lighthearted, Shakespeare-style
      playful insults for friendly banter. Everything is kept good-natured and in
      fun — pick a mode, generate, and share. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { pick } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('ic-out')!;
  let mode: 'comp' | 'insult' = 'comp';

  const COMPLIMENTS = [
    'You have a knack for making people feel at ease.',
    'Your curiosity is genuinely contagious.',
    'You bring a calm that a room can feel.',
    'The way you think about problems is refreshing.',
    'You are far more capable than you give yourself credit for.',
    'Your kindness shows up in the small things.',
    'People remember how thoughtful you are.',
    'You have excellent taste — this website, for example.',
  ];
  const INSULTS = [
    'Thou art a boil, a plague-sore, a most toad-spotted knave!',
    'You have the charisma of a damp sock and the timing of a broken clock.',
    'Thou clay-brained guts, thou knotty-pated fool!',
    'You are proof that even autocorrect gives up sometimes.',
    'Thou art as useful as a screen door on a submarine.',
    'Your secrets are safe with me — I never even listen when you talk.',
    'Thou spongy onion-eyed measle!',
    'You bring everyone so much joy — when you leave the room.',
  ];

  function generate() {
    out.textContent = pick(mode === 'comp' ? COMPLIMENTS : INSULTS);
  }

  function setMode(m: 'comp' | 'insult') {
    mode = m;
    ($('ic-tab-comp') as HTMLElement).className = `btn ${m === 'comp' ? 'btn-primary' : 'btn-secondary'}`;
    ($('ic-tab-insult') as HTMLElement).className = `btn ${m === 'insult' ? 'btn-primary' : 'btn-secondary'}`;
    generate();
  }

  $('ic-tab-comp').addEventListener('click', () => setMode('comp'));
  $('ic-tab-insult').addEventListener('click', () => setMode('insult'));
  $('ic-gen').addEventListener('click', generate);
  $('ic-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.textContent || '');
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
  generate();
</script>

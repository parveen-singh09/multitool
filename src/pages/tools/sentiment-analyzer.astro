---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="sentiment-analyzer">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Paste text to analyze
      <textarea id="sa-in" class="field min-h-32 resize-y font-mono text-[13px]" placeholder="Paste a review, comment or message to gauge its tone…" spellcheck="false">I absolutely love this product. The build quality is excellent and the setup was smooth and easy. Support was friendly and helpful too. My only complaint is that shipping was slow and the packaging felt cheap, which was a little disappointing. Overall a great experience and I would recommend it.</textarea>
    </label>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="sa-label" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Sentiment</div></div>
      <div class="panel p-4"><div id="sa-score" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Net score</div></div>
      <div class="panel p-4"><div id="sa-norm" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Score / 100 words</div></div>
      <div class="panel p-4"><div id="sa-pos" class="font-mono text-lg" style="color:#27a644">0</div><div class="mt-1 text-[13px] text-ink-subtle">Positive hits</div></div>
      <div class="panel p-4"><div id="sa-neg" class="font-mono text-lg" style="color:#e5484d">0</div><div class="mt-1 text-[13px] text-ink-subtle">Negative hits</div></div>
      <div class="panel p-4"><div id="sa-words" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Total words</div></div>
    </div>

    <div>
      <h2 class="mb-2 font-display text-sm font-semibold text-ink">Matched words</h2>
      <div id="sa-matched" class="flex flex-wrap gap-2 text-[13px]">Paste text above to see matched sentiment words.</div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free sentiment analyzer scores your text as positive, neutral or
      negative by matching it against a built-in lexicon of common positive and
      negative words. It shows the net score, a length-normalised score and the
      exact words that drove the result, so you can see why a message reads the
      way it does. It is a lightweight, rule-based estimate rather than a machine
      learning model, and it runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('sa-in') as HTMLTextAreaElement;
  const matchedEl = document.getElementById('sa-matched')!;
  const set = (id: string, val: string) => { document.getElementById(id)!.textContent = val; };

  const POSITIVE = new Set([
    'good', 'great', 'excellent', 'amazing', 'awesome', 'wonderful', 'fantastic',
    'love', 'loved', 'like', 'liked', 'happy', 'happiness', 'joy', 'joyful',
    'best', 'better', 'perfect', 'perfectly', 'nice', 'beautiful', 'brilliant',
    'delight', 'delightful', 'pleasant', 'pleased', 'pleasure', 'positive',
    'superb', 'terrific', 'outstanding', 'impressive', 'impressed', 'enjoy',
    'enjoyed', 'enjoyable', 'recommend', 'recommended', 'favorite', 'favourite',
    'success', 'successful', 'win', 'winning', 'gain', 'benefit', 'helpful',
    'thank', 'thanks', 'grateful', 'appreciate', 'appreciated', 'fun', 'exciting',
    'excited', 'glad', 'satisfied', 'satisfying', 'comfortable', 'easy', 'smooth',
    'fast', 'friendly', 'kind', 'generous', 'safe', 'reliable', 'quality',
    'worth', 'worthy', 'clear', 'clean', 'fresh', 'strong', 'valuable',
  ]);

  const NEGATIVE = new Set([
    'bad', 'terrible', 'awful', 'horrible', 'worst', 'worse', 'hate', 'hated',
    'dislike', 'disliked', 'sad', 'sadness', 'angry', 'anger', 'annoying',
    'annoyed', 'poor', 'poorly', 'ugly', 'nasty', 'disgusting', 'disappointing',
    'disappointed', 'disappointment', 'fail', 'failed', 'failure', 'broken',
    'break', 'bug', 'buggy', 'slow', 'sluggish', 'expensive', 'overpriced',
    'cheap', 'useless', 'worthless', 'waste', 'wasted', 'wrong', 'error',
    'problem', 'problems', 'issue', 'issues', 'difficult', 'hard', 'confusing',
    'confused', 'frustrating', 'frustrated', 'frustration', 'unhappy', 'unhelpful',
    'rude', 'unfriendly', 'dirty', 'weak', 'lacking', 'lack', 'missing', 'crash',
    'crashed', 'unreliable', 'unsafe', 'scam', 'fake', 'boring', 'painful',
    'regret', 'complaint', 'complain', 'negative', 'defective', 'faulty',
  ]);

  const NEGATORS = new Set(['not', 'no', 'never', "n't", 'cannot', "can't", "don't", "didn't", "isn't", "wasn't", "won't", 'without']);

  function analyze() {
    const tokens = input.value.toLowerCase().match(/[a-z']+/g) || [];
    let pos = 0, neg = 0;
    const matched: { word: string; polarity: number }[] = [];

    for (let i = 0; i < tokens.length; i++) {
      const w = tokens[i];
      let polarity = 0;
      if (POSITIVE.has(w)) polarity = 1;
      else if (NEGATIVE.has(w)) polarity = -1;
      if (polarity === 0) continue;
      const prev = i > 0 ? tokens[i - 1] : '';
      if (NEGATORS.has(prev)) polarity = -polarity;
      if (polarity > 0) pos++; else neg++;
      matched.push({ word: prev && NEGATORS.has(prev) ? `${prev} ${w}` : w, polarity });
    }

    const score = pos - neg;
    const totalWords = tokens.length;
    const norm = totalWords ? ((score / totalWords) * 100).toFixed(1) : '0';

    let label = 'Neutral';
    if (score > 0) label = 'Positive';
    else if (score < 0) label = 'Negative';

    set('sa-label', totalWords ? label : '—');
    const labelEl = document.getElementById('sa-label')!;
    labelEl.style.color = score > 0 ? '#27a644' : score < 0 ? '#e5484d' : '';
    set('sa-score', String(score));
    set('sa-norm', norm);
    set('sa-pos', String(pos));
    set('sa-neg', String(neg));
    set('sa-words', String(totalWords));

    if (!matched.length) {
      matchedEl.textContent = totalWords ? 'No lexicon words matched — tone reads neutral.' : 'Paste text above to see matched sentiment words.';
      return;
    }
    matchedEl.innerHTML = '';
    for (const m of matched.slice(0, 100)) {
      const chip = document.createElement('span');
      chip.className = 'panel px-3 py-1 font-mono';
      chip.style.color = m.polarity > 0 ? '#27a644' : '#e5484d';
      chip.textContent = `${m.polarity > 0 ? '+' : '−'} ${m.word}`;
      matchedEl.appendChild(chip);
    }
  }

  input.addEventListener('input', analyze);
  analyze();
</script>

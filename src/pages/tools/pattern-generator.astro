---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="pattern-generator">
  <div class="flex flex-col gap-5">

    <div class="flex flex-wrap gap-2">
      <button id="pt-mode-lib" class="mode-chip" aria-pressed="true">Pattern library</button>
      <button id="pt-mode-custom" class="mode-chip" aria-pressed="false">Custom image</button>
    </div>

    <div id="pt-lib" class="flex flex-col gap-4">
      <div>
        <div class="mb-2 flex items-center justify-between gap-3">
          <span class="text-[13px] text-ink-subtle">
            Selected: <span id="pt-selected" class="text-ink">—</span>
          </span>
          <input id="pt-search" class="field w-44 py-1 text-[13px]" placeholder="Search patterns…" spellcheck="false" autocomplete="off" />
        </div>
        <div id="pt-grid" class="grid max-h-72 grid-cols-3 gap-2 overflow-y-auto rounded-[10px] border border-hairline p-2 sm:grid-cols-5 md:grid-cols-6"></div>
        <p id="pt-empty" class="mt-2 hidden text-[13px] text-ink-subtle">No patterns match that search.</p>
      </div>

      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <div class="flex items-center justify-between">
          <span>Colors</span>
          <button id="pt-random" class="btn btn-secondary px-2 py-1 text-[13px]">Randomize</button>
        </div>
        <div id="pt-colors" class="flex flex-wrap gap-2"></div>
      </div>

      <div class="grid grid-cols-2 gap-x-4 gap-y-3 sm:grid-cols-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Stroke: <span id="pt-stroke-v" class="text-ink">1</span>
          <input id="pt-stroke" type="range" min="0.5" max="10" step="0.5" value="1" class="w-full accent-primary" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Scale: <span id="pt-scale-v" class="text-ink">2</span>
          <input id="pt-scale" type="range" min="1" max="16" step="0.5" value="2" class="w-full accent-primary" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Spacing X: <span id="pt-spx-v" class="text-ink">0</span>
          <input id="pt-spx" type="range" min="0" max="100" value="0" class="w-full accent-primary" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Spacing Y: <span id="pt-spy-v" class="text-ink">0</span>
          <input id="pt-spy" type="range" min="0" max="100" value="0" class="w-full accent-primary" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Angle: <span id="pt-angle-v" class="text-ink">0</span>°
          <input id="pt-angle" type="range" min="0" max="180" value="0" class="w-full accent-primary" />
        </label>
        <label id="pt-join-row" class="hidden flex-col gap-1 text-sm text-ink-subtle">Corners
          <select id="pt-join" class="field">
            <option value="square">Square</option>
            <option value="rounded">Rounded</option>
          </select>
        </label>
      </div>
    </div>

    <div id="pt-custom" class="hidden flex-col gap-4">
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Tile size: <span id="pt-csize-v" class="text-ink">120</span>
          <input id="pt-csize" type="range" min="20" max="400" value="120" class="w-full accent-primary" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Background
          <input id="pt-cbg" type="color" value="#010102" class="field h-10 cursor-pointer p-1" />
        </label>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Custom image
        <input id="pt-file" type="file" accept="image/*" class="field cursor-pointer p-2 file:mr-3 file:cursor-pointer file:rounded-md file:border-0 file:bg-surface-2 file:px-3 file:py-1 file:text-ink" />
      </label>
    </div>

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">Size
      <div id="pt-ratios" class="flex flex-wrap gap-2"></div>
    </div>

    <div class="flex min-h-64 items-center justify-center overflow-hidden rounded-lg border border-hairline p-4">
      <div id="pt-preview" class="rounded-md"></div>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="pt-dl" class="btn btn-primary">Download SVG</button>
      <button id="pt-copycss" class="btn btn-secondary">Copy CSS</button>
      <button id="pt-copysvg" class="btn btn-secondary">Copy SVG</button>
    </div>
  </div>

  <style is:global>
    .ratio-chip,
    .mode-chip {
      min-width: 44px;
      padding: 6px 12px;
      border-radius: 8px;
      border: 1px solid #23252a;
      background-color: #0f1011;
      color: #8a8f98;
      font-size: 13px;
      font-weight: 500;
      line-height: 1.2;
      cursor: pointer;
      transition: border-color 0.12s ease, color 0.12s ease, background-color 0.12s ease;
    }
    .ratio-chip:hover,
    .mode-chip:hover {
      color: #f7f8f8;
      border-color: #34343a;
    }
    .ratio-chip[aria-pressed='true'],
    .mode-chip[aria-pressed='true'] {
      color: #f7f8f8;
      border-color: #5e6ad2;
      background-color: #141516;
    }
    .pt-cell-wrap {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
    }
    .pt-cell-wrap.hidden {
      display: none;
    }
    .pt-cell {
      aspect-ratio: 1 / 1;
      border-radius: 6px;
      border: 1px solid #23252a;
      background-size: cover;
      background-position: center;
      cursor: pointer;
      transition: border-color 0.12s ease, transform 0.12s ease;
    }
    .pt-cell:hover {
      border-color: #34343a;
    }
    .pt-cell[aria-pressed='true'] {
      border-color: #5e6ad2;
      border-width: 2px;
    }
    .pt-cell-name {
      overflow: hidden;
      font-size: 11px;
      line-height: 1.3;
      text-align: center;
      color: #8a8f98;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .pt-cell[aria-pressed='true'] + .pt-cell-name {
      color: #f7f8f8;
    }
  </style>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free pattern background generator gives you a library of 300+
      seamless, repeating SVG patterns — waves, chevrons, herringbone, dots,
      grids, triangles and many more. Pick a pattern, set up to five colors, then
      fine-tune the stroke, scale, spacing and rotation. Download the tile as an
      SVG or copy a CSS
      <code class="font-mono text-ink">background-image</code> that embeds it as a
      data URI so it tiles perfectly across any element. You can also switch to
      Custom image mode to tile your own uploaded image. Everything is generated
      in your browser.
    </p>
    <p>
      Patterns are based on the open-source
      <a href="https://github.com/Toshinaki/svgpm" class="text-ink underline decoration-hairline underline-offset-2 hover:decoration-ink-subtle">svgpm</a>
      library (MIT), a JavaScript port of pattern.monster.
    </p>
  </div>
</ToolLayout>

<script>
  import {
    PATTERNS,
    PALETTES,
    generateSVG,
    randomConfig,
    randomPalette,
    type Pattern,
    type PatternConfig,
    type JoinMode,
  } from '../../lib/patterns';

  const $ = (id: string) => document.getElementById(id)!;
  const preview = $('pt-preview');

  type Mode = 'library' | 'custom';
  let mode: Mode = 'library';

  let pattern: Pattern = PATTERNS[0];
  let colors: string[] = PALETTES[0].slice();
  const cfg = (): Partial<PatternConfig> => ({
    colors,
    colorCounts: pattern.colors,
    stroke: Number(($('pt-stroke') as HTMLInputElement).value),
    scale: Number(($('pt-scale') as HTMLInputElement).value),
    spacing: [
      Number(($('pt-spx') as HTMLInputElement).value),
      Number(($('pt-spy') as HTMLInputElement).value),
    ],
    angle: Number(($('pt-angle') as HTMLInputElement).value),
    join: ($('pt-join') as HTMLSelectElement).value as JoinMode,
    moveLeft: 0,
    moveTop: 0,
  });

  let customImg = '';

  const RATIOS: [string, number, number][] = [
    ['1:1', 1, 1], ['2:1', 2, 1], ['1:2', 1, 2], ['3:4', 3, 4], ['4:3', 4, 3],
    ['9:16', 9, 16], ['16:9', 16, 9], ['4:5', 4, 5], ['5:4', 5, 4],
  ];
  const LONG_EDGE = 1200; 
  let ratio: [string, number, number] = RATIOS[0];

  function dims(): { w: number; h: number } {
    const [, rw, rh] = ratio;
    return rw >= rh
      ? { w: LONG_EDGE, h: Math.round((LONG_EDGE * rh) / rw) }
      : { w: Math.round((LONG_EDGE * rw) / rh), h: LONG_EDGE };
  }

  function dataUri(svg: string): string {
    return `url("data:image/svg+xml,${encodeURIComponent(svg)}")`;
  }

  function libSvg(): string {
    return generateSVG(pattern, cfg());
  }

  function libArtwork(): string {
    const { w, h } = dims();
    return libSvg().replace(
      "width='100%' height='100%'",
      `width='${w}' height='${h}' viewBox='0 0 ${w} ${h}'`
    );
  }

  function render() {
    const [, rw, rh] = ratio;
    const parent = preview.parentElement as HTMLElement;
    const availW = Math.max(0, parent.clientWidth - 32); 
    const availH = 360;
    let w = availW;
    let h = (w * rh) / rw;
    if (h > availH) { h = availH; w = (h * rw) / rh; }
    preview.style.width = `${Math.round(w)}px`;
    preview.style.height = `${Math.round(h)}px`;

    if (mode === 'custom') {
      const size = Number(($('pt-csize') as HTMLInputElement).value);
      $('pt-csize-v').textContent = String(size);
      preview.style.backgroundColor = ($('pt-cbg') as HTMLInputElement).value;
      preview.style.backgroundImage = customImg ? `url("${customImg}")` : '';
      preview.style.backgroundSize = `${size}px ${size}px`;
      preview.style.backgroundRepeat = 'repeat';
    } else {
      // Reflect slider values, then paint. The engine's SVG fills the element.
      $('pt-stroke-v').textContent = ($('pt-stroke') as HTMLInputElement).value;
      $('pt-scale-v').textContent = ($('pt-scale') as HTMLInputElement).value;
      $('pt-spx-v').textContent = ($('pt-spx') as HTMLInputElement).value;
      $('pt-spy-v').textContent = ($('pt-spy') as HTMLInputElement).value;
      $('pt-angle-v').textContent = ($('pt-angle') as HTMLInputElement).value;
      preview.style.backgroundColor = colors[0];
      preview.style.backgroundImage = dataUri(libSvg());
      preview.style.backgroundSize = 'cover';
      preview.style.backgroundRepeat = 'no-repeat';
    }
  }
  window.addEventListener('resize', render);

  // ---- Pattern grid (build once, filter by toggling hidden) ----
  const grid = $('pt-grid');
  const selected = $('pt-selected');
  // A neutral 2-color scheme so shapes read against the dark cells.
  const THUMB_COLORS = ['#0f1011', '#8a8f98', '#8a8f98', '#8a8f98', '#8a8f98'];
  const cells: HTMLButtonElement[] = [];
  const wraps: HTMLDivElement[] = [];

  PATTERNS.forEach((p, i) => {
    const wrap = document.createElement('div');
    wrap.className = 'pt-cell-wrap';

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'pt-cell';
    btn.title = p.title;
    btn.setAttribute('aria-label', p.title);
    btn.dataset.i = String(i);
    if (i === 0) btn.setAttribute('aria-pressed', 'true');
    const thumb = generateSVG(p, { colors: THUMB_COLORS, colorCounts: 2, scale: 1.4 });
    btn.style.backgroundImage = dataUri(thumb);
    btn.addEventListener('click', () => selectPattern(i));

    const name = document.createElement('span');
    name.className = 'pt-cell-name';
    name.textContent = p.title;

    wrap.append(btn, name);
    grid.appendChild(wrap);
    cells.push(btn);
    wraps.push(wrap);
  });

  function selectPattern(i: number) {
    pattern = PATTERNS[i];
    cells.forEach((c) => c.setAttribute('aria-pressed', 'false'));
    cells[i].setAttribute('aria-pressed', 'true');
    selected.textContent = pattern.title;
    applyPatternBounds();
    buildColorInputs();
    render();
  }

  // Clamp slider ranges + current values to the selected pattern's limits.
  function applyPatternBounds() {
    const stroke = $('pt-stroke') as HTMLInputElement;
    stroke.max = String(pattern.maxStroke);
    if (Number(stroke.value) > pattern.maxStroke) stroke.value = String(pattern.maxStroke);
    const scale = $('pt-scale') as HTMLInputElement;
    scale.max = String(pattern.maxScale);
    if (Number(scale.value) > pattern.maxScale) scale.value = String(pattern.maxScale);
    const spx = $('pt-spx') as HTMLInputElement;
    spx.max = String(pattern.maxSpacing[0]);
    spx.disabled = pattern.maxSpacing[0] === 0;
    if (Number(spx.value) > pattern.maxSpacing[0]) spx.value = String(pattern.maxSpacing[0]);
    const spy = $('pt-spy') as HTMLInputElement;
    spy.max = String(pattern.maxSpacing[1]);
    spy.disabled = pattern.maxSpacing[1] === 0;
    if (Number(spy.value) > pattern.maxSpacing[1]) spy.value = String(pattern.maxSpacing[1]);
    // Corner join only applies to stroke-join patterns.
    const joinRow = $('pt-join-row');
    const isJoin = pattern.mode === 'stroke-join';
    joinRow.classList.toggle('hidden', !isJoin);
    joinRow.classList.toggle('flex', isJoin);
  }

  // Rebuild color swatches to match the pattern's color count. Built fresh only
  // on pattern change (never mid-drag) so live <input type="color"> survives.
  function buildColorInputs() {
    const wrap = $('pt-colors');
    wrap.innerHTML = '';
    const n = Math.max(2, pattern.colors);
    for (let i = 0; i < n; i++) {
      if (colors[i] === undefined) colors[i] = PALETTES[0][i] ?? '#888888';
      const input = document.createElement('input');
      input.type = 'color';
      input.value = colors[i];
      input.className = 'h-9 w-12 shrink-0 cursor-pointer rounded-sm border border-hairline bg-surface-1';
      input.setAttribute('aria-label', i === 0 ? 'Background color' : `Color ${i}`);
      input.addEventListener('input', () => { colors[i] = input.value; render(); });
      wrap.appendChild(input);
    }
  }

  // ---- Search filter ----
  $('pt-search').addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.trim().toLowerCase();
    let visible = 0;
    PATTERNS.forEach((p, i) => {
      const hit = !q || p.title.toLowerCase().includes(q) || p.tags.some((t) => t.includes(q));
      wraps[i].classList.toggle('hidden', !hit);
      if (hit) visible++;
    });
    $('pt-empty').classList.toggle('hidden', visible > 0);
  });

  // ---- Randomize ----
  $('pt-random').addEventListener('click', () => {
    colors = randomPalette();
    const rc = randomConfig(pattern);
    ($('pt-stroke') as HTMLInputElement).value = String(rc.stroke);
    ($('pt-scale') as HTMLInputElement).value = String(rc.scale);
    ($('pt-spx') as HTMLInputElement).value = String(rc.spacing?.[0] ?? 0);
    ($('pt-spy') as HTMLInputElement).value = String(rc.spacing?.[1] ?? 0);
    ($('pt-angle') as HTMLInputElement).value = String(rc.angle);
    ($('pt-join') as HTMLSelectElement).value = rc.join ?? 'square';
    buildColorInputs();
    render();
  });

  // ---- Mode toggle ----
  function setMode(m: Mode) {
    mode = m;
    ($('pt-mode-lib')).setAttribute('aria-pressed', String(m === 'library'));
    ($('pt-mode-custom')).setAttribute('aria-pressed', String(m === 'custom'));
    $('pt-lib').classList.toggle('hidden', m !== 'library');
    $('pt-lib').classList.toggle('flex', m === 'library');
    $('pt-custom').classList.toggle('hidden', m !== 'custom');
    $('pt-custom').classList.toggle('flex', m === 'custom');
    render();
  }
  $('pt-mode-lib').addEventListener('click', () => setMode('library'));
  $('pt-mode-custom').addEventListener('click', () => setMode('custom'));

  // ---- Custom image upload ----
  $('pt-file').addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => { customImg = String(reader.result); render(); };
    reader.readAsDataURL(file);
  });
  ['pt-csize', 'pt-cbg'].forEach((id) => $(id).addEventListener('input', render));

  // ---- Library slider listeners ----
  ['pt-stroke', 'pt-scale', 'pt-spx', 'pt-spy', 'pt-angle', 'pt-join'].forEach((id) =>
    $(id).addEventListener('input', render)
  );

  // ---- Aspect-ratio picker (shared) ----
  const ratioWrap = $('pt-ratios');
  RATIOS.forEach((r, i) => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.textContent = r[0];
    btn.className = 'ratio-chip';
    if (i === 0) btn.setAttribute('aria-pressed', 'true');
    btn.addEventListener('click', () => {
      ratio = RATIOS[i];
      ratioWrap.querySelectorAll('button').forEach((b) => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      render();
    });
    ratioWrap.appendChild(btn);
  });

  // ---- Export ----
  function exportSvg(): string {
    if (mode === 'custom') {
      const { w, h } = dims();
      const size = Number(($('pt-csize') as HTMLInputElement).value);
      const bg = ($('pt-cbg') as HTMLInputElement).value;
      const img = customImg
        ? `<defs><pattern id="c" width="${size}" height="${size}" patternUnits="userSpaceOnUse"><image href="${customImg}" x="0" y="0" width="${size}" height="${size}" preserveAspectRatio="xMidYMid slice"/></pattern></defs><rect width="${w}" height="${h}" fill="url(#c)"/>`
        : '';
      return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}" viewBox="0 0 ${w} ${h}"><rect width="${w}" height="${h}" fill="${bg}"/>${img}</svg>`;
    }
    return libArtwork();
  }

  function cssText(): string {
    if (mode === 'custom') {
      const size = Number(($('pt-csize') as HTMLInputElement).value);
      const bg = ($('pt-cbg') as HTMLInputElement).value;
      return customImg
        ? `background-color: ${bg};\nbackground-image: url("${customImg}");\nbackground-size: ${size}px ${size}px;`
        : `background-color: ${bg};`;
    }
    return `background-color: ${colors[0]};\nbackground-image: ${dataUri(libSvg())};`;
  }

  $('pt-dl').addEventListener('click', () => {
    const url = URL.createObjectURL(new Blob([exportSvg()], { type: 'image/svg+xml' }));
    const a = document.createElement('a');
    a.href = url;
    a.download = `pattern-${ratio[0].replace(':', 'x')}.svg`;
    a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });
  $('pt-copycss').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(cssText());
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy CSS'), 1400);
  });
  $('pt-copysvg').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(exportSvg());
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy SVG'), 1400);
  });

  // ---- Init ----
  selected.textContent = pattern.title;
  applyPatternBounds();
  buildColorInputs();
  render();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="scientific-notation-converter">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Decimal number
      <input id="sn-dec" type="text" class="field font-mono" placeholder="0.00042" inputmode="decimal" spellcheck="false" autocomplete="off" />
    </label>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Scientific notation
      <div class="flex gap-2">
        <input id="sn-sci" type="text" class="field font-mono" placeholder="4.2 x 10^-4" spellcheck="false" autocomplete="off" />
        <button id="sn-copy" type="button" class="btn btn-secondary">Copy</button>
      </div>
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="panel p-3">
        <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">E-notation</span>
        <div id="sn-e" class="mt-1 font-mono text-[15px] text-ink">4.2e-4</div>
      </div>
      <div class="panel p-3">
        <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Engineering</span>
        <div id="sn-eng" class="mt-1 font-mono text-[15px] text-ink">420e-6</div>
      </div>
      <div class="panel p-3">
        <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Order of magnitude</span>
        <div id="sn-mag" class="mt-1 font-mono text-[15px] text-ink">10⁻⁴</div>
      </div>
    </div>

    <p id="sn-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free scientific notation converter turns ordinary decimal numbers
      into scientific notation and back. It also shows E-notation (as used in
      code and calculators), engineering notation (exponents in multiples of
      three) and the order of magnitude. Enter a value in either field —
      formats like <code>4.2e-4</code> or <code>4.2 x 10^-4</code> both work.
      Everything runs in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const decEl = document.getElementById('sn-dec') as HTMLInputElement;
  const sciEl = document.getElementById('sn-sci') as HTMLInputElement;
  const eEl = document.getElementById('sn-e')!;
  const engEl = document.getElementById('sn-eng')!;
  const magEl = document.getElementById('sn-mag')!;
  const err = document.getElementById('sn-error')!;

  const SUP: Record<string, string> = { '-': '⁻', '0': '⁰', '1': '¹', '2': '²', '3': '³', '4': '⁴', '5': '⁵', '6': '⁶', '7': '⁷', '8': '⁸', '9': '⁹' };
  const sup = (n: number) => String(n).split('').map((c) => SUP[c] ?? c).join('');

  function render(v: number, source: 'dec' | 'sci') {
    err.classList.add('hidden');
    if (v === 0) {
      if (source !== 'dec') decEl.value = '0';
      if (source !== 'sci') sciEl.value = '0';
      eEl.textContent = '0'; engEl.textContent = '0'; magEl.textContent = '10⁰';
      return;
    }
    const exp = Math.floor(Math.log10(Math.abs(v)));
    const mantissa = v / Math.pow(10, exp);
    const m = Math.round(mantissa * 1e10) / 1e10;
    if (source !== 'sci') sciEl.value = `${m} x 10^${exp}`;
    if (source !== 'dec') decEl.value = String(Number(v.toPrecision(12)));
    eEl.textContent = `${m}e${exp}`;
    // engineering: exponent to nearest lower multiple of 3
    const eng = Math.floor(exp / 3) * 3;
    const engM = Math.round((v / Math.pow(10, eng)) * 1e6) / 1e6;
    engEl.textContent = `${engM}e${eng}`;
    magEl.textContent = `10${sup(exp)}`;
  }

  decEl.addEventListener('input', () => {
    const raw = decEl.value.trim().replace(/,/g, '');
    if (!raw) return;
    const v = Number(raw);
    if (isNaN(v)) { err.textContent = 'Enter a valid decimal number.'; err.classList.remove('hidden'); return; }
    render(v, 'dec');
  });

  sciEl.addEventListener('input', () => {
    const raw = sciEl.value.trim().toLowerCase().replace(/\s/g, '');
    if (!raw) return;
    // accept 4.2e-4, 4.2e4, 4.2x10^-4, 4.2*10^4
    let v: number;
    const m = raw.match(/^(-?\d*\.?\d+)(?:e|x10\^|\*10\^)(-?\d+)$/);
    if (m) v = Number(m[1]) * Math.pow(10, Number(m[2]));
    else v = Number(raw);
    if (isNaN(v)) { err.textContent = 'Use a form like 4.2e-4 or 4.2 x 10^-4.'; err.classList.remove('hidden'); return; }
    render(v, 'sci');
  });

  decEl.value = '0.00042'; decEl.dispatchEvent(new Event('input'));
  document.getElementById('sn-copy')!.addEventListener('click', async (e) => {
    await navigator.clipboard.writeText(sciEl.value);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="scientific-notation-converter">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Decimal number
        <div class="flex gap-2">
          <input id="sn-dec" type="text" class="field font-mono" placeholder="0.00042" inputmode="decimal" spellcheck="false" autocomplete="off" />
          <button data-copy="sn-dec" type="button" class="btn btn-secondary" title="Copy decimal">Copy</button>
        </div>
      </label>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Scientific notation
        <div class="flex gap-2">
          <input id="sn-sci" type="text" class="field font-mono" placeholder="4.2 × 10^-4" spellcheck="false" autocomplete="off" />
          <button data-copy="sn-sci" type="button" class="btn btn-secondary" title="Copy scientific notation">Copy</button>
        </div>
      </label>
    </div>

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Significant figures
        <select id="sn-sig" class="field w-auto py-1">
          <option value="auto" selected>Auto (as typed)</option>
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
          <option value="6">6</option>
          <option value="7">7</option>
          <option value="8">8</option>
          <option value="10">10</option>
          <option value="12">12</option>
          <option value="15">15</option>
        </select>
      </label>
      <button id="sn-clear" type="button" class="btn btn-tertiary">Clear</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <div class="panel p-3">
        <div class="flex items-center justify-between">
          <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Scientific notation</span>
          <button data-copytext="sn-normv" type="button" class="btn btn-tertiary px-2 py-0.5 text-[12px]">Copy</button>
        </div>
        <div id="sn-norm" class="mt-1 font-mono text-[15px] text-ink">4.2 × 10⁻⁴</div>
      </div>
      <div class="panel p-3">
        <div class="flex items-center justify-between">
          <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">E-notation</span>
          <button data-copytext="sn-e" type="button" class="btn btn-tertiary px-2 py-0.5 text-[12px]">Copy</button>
        </div>
        <div id="sn-e" class="mt-1 font-mono text-[15px] text-ink">4.2e-4</div>
      </div>
      <div class="panel p-3">
        <div class="flex items-center justify-between">
          <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Engineering</span>
          <button data-copytext="sn-eng" type="button" class="btn btn-tertiary px-2 py-0.5 text-[12px]">Copy</button>
        </div>
        <div id="sn-eng" class="mt-1 font-mono text-[15px] text-ink">420e-6</div>
        <div id="sn-si" class="mt-0.5 text-[12px] text-ink-subtle">micro (µ)</div>
      </div>
      <div class="panel p-3">
        <div class="flex items-center justify-between">
          <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Real number</span>
          <button data-copytext="sn-real" type="button" class="btn btn-tertiary px-2 py-0.5 text-[12px]">Copy</button>
        </div>
        <div id="sn-real" class="mt-1 break-all font-mono text-[15px] text-ink">0.00042</div>
      </div>
      <div class="panel p-3">
        <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Order of magnitude</span>
        <div id="sn-mag" class="mt-1 font-mono text-[15px] text-ink">10⁻⁴</div>
      </div>
      <div class="panel p-3">
        <div class="flex items-center justify-between">
          <span class="text-[11px] uppercase tracking-wide text-ink-tertiary">Word form</span>
          <button data-copytext="sn-words" type="button" class="btn btn-tertiary px-2 py-0.5 text-[12px]">Copy</button>
        </div>
        <div id="sn-words" class="mt-1 text-[15px] leading-snug text-ink">four hundred twenty millionths</div>
      </div>
    </div>

    <p id="sn-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free scientific notation converter turns ordinary decimal numbers
      into scientific notation and back, and shows every related form at once.
      Type into either the <strong>decimal</strong> or the
      <strong>scientific notation</strong> field and the tool derives the rest
      live: standard scientific notation (<code>4.2 × 10⁻⁴</code>), E-notation as
      used in code and calculators (<code>4.2e-4</code>), engineering notation
      with the matching SI metric prefix (<code>420e-6</code>, micro / µ), the
      fully written-out real number, the order of magnitude and the English word
      form. Inputs like <code>4.2e-4</code>, <code>4.2 x 10^-4</code>,
      <code>4.2 × 10^-4</code> and <code>4.2*10^-4</code> are all accepted, and
      thousands separators are ignored.
    </p>
    <p>
      Use the <strong>significant figures</strong> control to round every output
      to a fixed number of significant digits (1–15), or leave it on
      <em>Auto</em> to preserve exactly what you typed. The real-number output is
      expanded from the digits you entered rather than a lossy floating-point
      value, so large integers and tiny fractions print in full without rounding
      artifacts. Errors are reported inline with a hint about the accepted
      formats. Everything runs entirely in your browser — nothing is uploaded to
      a server.
    </p>
  </div>
</ToolLayout>

<script>
  const decEl = document.getElementById('sn-dec') as HTMLInputElement;
  const sciEl = document.getElementById('sn-sci') as HTMLInputElement;
  const sigEl = document.getElementById('sn-sig') as HTMLSelectElement;
  const normEl = document.getElementById('sn-norm')!;
  const eEl = document.getElementById('sn-e')!;
  const engEl = document.getElementById('sn-eng')!;
  const siEl = document.getElementById('sn-si')!;
  const realEl = document.getElementById('sn-real')!;
  const magEl = document.getElementById('sn-mag')!;
  const wordsEl = document.getElementById('sn-words')!;
  const err = document.getElementById('sn-error')!;

  const SUP: Record<string, string> = { '-': '⁻', '+': '', '0': '⁰', '1': '¹', '2': '²', '3': '³', '4': '⁴', '5': '⁵', '6': '⁶', '7': '⁷', '8': '⁸', '9': '⁹' };
  const sup = (n: number | string) => String(n).split('').map((c) => SUP[c] ?? c).join('');

  // SI metric prefixes keyed by exponent (multiple of 3).
  const SI: Record<number, string> = {
    [-24]: 'yocto (y)', [-21]: 'zepto (z)', [-18]: 'atto (a)', [-15]: 'femto (f)',
    [-12]: 'pico (p)', [-9]: 'nano (n)', [-6]: 'micro (µ)', [-3]: 'milli (m)',
    0: '', 3: 'kilo (k)', 6: 'mega (M)', 9: 'giga (G)', 12: 'tera (T)',
    15: 'peta (P)', 18: 'exa (E)', 21: 'zetta (Z)', 24: 'yotta (Y)',
  };

  type Parsed = { neg: boolean; digits: string; decExp: number };

  // Parse any accepted form into an exact { sign, integer-significand-digits, decimal-exponent }
  // such that value = ±digits × 10^decExp. No float involved, so the real-number
  // expansion below is lossless for whatever the user typed.
  function parseInput(raw: string): Parsed | null {
    let s = raw.trim().replace(/,/g, '').replace(/\s+/g, '');
    if (!s) return null;
    s = s.replace(/×/gi, 'x');
    s = s.replace(/(?:x|\*)10\^?/i, 'e'); // 4.2x10^-4 / 4.2*10^-4 → 4.2e-4
    const m = s.match(/^([+-]?)(\d*)(?:\.(\d*))?(?:[eE]([+-]?\d+))?$/);
    if (!m) return null;
    const sign = m[1], intP = m[2] ?? '', fracP = m[3] ?? '', expP = m[4];
    if (intP === '' && fracP === '') return null; // no actual digits
    const digits = intP + fracP;
    const decExp = (expP ? parseInt(expP, 10) : 0) - fracP.length;
    return { neg: sign === '-', digits, decExp };
  }

  // value = digits × 10^decExp → full decimal string parts (no exponent, no float).
  function expand(digits: string, decExp: number): { int: string; frac: string } {
    const sig = digits.replace(/^0+/, ''); // leading zeros never change the integer value
    if (sig === '') return { int: '0', frac: '' };
    if (decExp >= 0) return { int: sig + '0'.repeat(decExp), frac: '' };
    const pointPos = sig.length + decExp;
    if (pointPos > 0) return { int: sig.slice(0, pointPos), frac: sig.slice(pointPos).replace(/0+$/, '') };
    return { int: '0', frac: ('0'.repeat(-pointPos) + sig).replace(/0+$/, '') };
  }

  // ---- number → English words (short scale) ----
  const ONES = ['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine', 'ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen'];
  const TENS = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];
  const SCALES = ['', 'thousand', 'million', 'billion', 'trillion', 'quadrillion', 'quintillion', 'sextillion', 'septillion', 'octillion', 'nonillion', 'decillion'];

  function threeToWords(n: number): string {
    let out = '';
    if (n >= 100) { out += ONES[Math.floor(n / 100)] + ' hundred'; n %= 100; if (n) out += ' '; }
    if (n >= 20) { out += TENS[Math.floor(n / 10)]; if (n % 10) out += '-' + ONES[n % 10]; }
    else if (n > 0) out += ONES[n];
    return out;
  }

  // ponytail: short scale up to decillion (10^36). Beyond that, or for the fractional
  // digits, we read digit-by-digit — extend SCALES if a caller needs bigger named groups.
  function integerToWords(intStr: string): string | null {
    intStr = intStr.replace(/^0+/, '') || '0';
    if (intStr === '0') return 'zero';
    const groups: number[] = [];
    for (let i = intStr.length; i > 0; i -= 3) groups.push(Number(intStr.slice(Math.max(0, i - 3), i)));
    if (groups.length > SCALES.length) return null; // too large to name
    const parts: string[] = [];
    for (let g = groups.length - 1; g >= 0; g--) {
      if (groups[g] === 0) continue;
      parts.push(threeToWords(groups[g]) + (SCALES[g] ? ' ' + SCALES[g] : ''));
    }
    return parts.join(' ');
  }

  function toWords(neg: boolean, int: string, frac: string): string {
    const intWords = integerToWords(int);
    if (intWords === null) return '—';
    let out = intWords;
    if (frac) out += ' point ' + frac.split('').map((d) => ONES[Number(d)]).join(' ');
    return (neg && out !== 'zero' ? 'negative ' : '') + out;
  }

  function setError(msg: string) {
    err.textContent = msg;
    err.classList.remove('hidden');
  }

  function render(p: Parsed, source: 'dec' | 'sci' | null) {
    err.classList.add('hidden');

    // Apply the significant-figures control by re-deriving from a rounded value.
    let { neg, digits, decExp } = p;
    const sig = sigEl.value;
    let vNum = Number((neg ? '-' : '') + (digits || '0') + 'e' + decExp);
    if (sig !== 'auto' && vNum !== 0 && Number.isFinite(vNum)) {
      const rp = parseInput(Math.abs(vNum).toPrecision(Number(sig)));
      if (rp) { digits = rp.digits; decExp = rp.decExp; }
    }

    const stripped = digits.replace(/^0+/, '');
    const isZero = stripped === '';

    if (isZero) {
      const zSci = sig === 'auto' ? '0' : (0).toPrecision(Number(sig));
      if (source !== 'dec') decEl.value = '0';
      if (source !== 'sci') sciEl.value = '0';
      normEl.textContent = '0'; eEl.textContent = zSci; engEl.textContent = zSci;
      siEl.textContent = ''; realEl.textContent = '0'; magEl.textContent = '10⁰'; wordsEl.textContent = 'zero';
      return;
    }

    // Scientific: value = stripped × 10^decExp = mantissa × 10^exp
    const exp = decExp + stripped.length - 1;
    let mant = stripped[0] + (stripped.length > 1 ? '.' + stripped.slice(1) : '');
    if (sig === 'auto') mant = mant.replace(/\.?0+$/, ''); // trim trailing zeros only when auto
    const signStr = neg ? '-' : '';

    normEl.textContent = `${signStr}${mant} × 10${sup(exp)}`;
    eEl.textContent = `${signStr}${mant}e${exp}`;

    // Engineering: exponent to nearest lower multiple of 3.
    const engExp = Math.floor(exp / 3) * 3;
    const engM = Number((neg ? -1 : 1) * Number(mant) * Math.pow(10, exp - engExp));
    const engMStr = parseFloat(engM.toPrecision(15)).toString();
    engEl.textContent = `${engMStr}e${engExp}`;
    siEl.textContent = SI[engExp] ?? '';

    // Real number: exact string expansion (lossless).
    const { int, frac } = expand(digits, decExp);
    realEl.textContent = `${signStr}${int}${frac ? '.' + frac : ''}`;

    magEl.textContent = `10${sup(exp)}`;
    wordsEl.textContent = toWords(neg, int, frac);

    // Reflect into the other input field (not the one being typed in).
    if (source !== 'sci') sciEl.value = `${signStr}${mant} × 10^${exp}`;
    if (source !== 'dec') decEl.value = `${signStr}${int}${frac ? '.' + frac : ''}`;
  }

  function fromDecimal() {
    const raw = decEl.value;
    if (!raw.trim()) return;
    const p = parseInput(raw);
    if (!p) { setError('Enter a valid decimal number, e.g. 0.00042 or -12300.'); return; }
    render(p, 'dec');
  }

  function fromScientific() {
    const raw = sciEl.value;
    if (!raw.trim()) return;
    const p = parseInput(raw);
    if (!p) { setError('Use a form like 4.2e-4, 4.2 × 10^-4 or 4.2*10^-4.'); return; }
    render(p, 'sci');
  }

  decEl.addEventListener('input', fromDecimal);
  sciEl.addEventListener('input', fromScientific);
  sigEl.addEventListener('change', () => {
    // Re-run from whichever field currently has content (prefer decimal).
    const p = parseInput(decEl.value) ?? parseInput(sciEl.value);
    if (p) render(p, null);
  });

  document.getElementById('sn-clear')!.addEventListener('click', () => {
    decEl.value = ''; sciEl.value = '';
    normEl.textContent = eEl.textContent = engEl.textContent = realEl.textContent = wordsEl.textContent = '';
    siEl.textContent = ''; magEl.textContent = '';
    err.classList.add('hidden');
    decEl.focus();
  });

  // Copy buttons: data-copy reads an input value; data-copytext reads an element's text.
  function flash(b: HTMLButtonElement) {
    const t = b.textContent;
    b.textContent = 'Copied!';
    setTimeout(() => (b.textContent = t), 1400);
  }
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((b) =>
    b.addEventListener('click', async () => {
      const v = (document.getElementById(b.dataset.copy!) as HTMLInputElement).value;
      if (v) { await navigator.clipboard.writeText(v); flash(b); }
    }));
  document.querySelectorAll<HTMLButtonElement>('[data-copytext]').forEach((b) =>
    b.addEventListener('click', async () => {
      const v = document.getElementById(b.dataset.copytext!)?.textContent ?? '';
      if (v && v !== '—') { await navigator.clipboard.writeText(v); flash(b); }
    }));

  // Seed with the demo value; also acts as the smoke check for the derivation chain.
  decEl.value = '0.00042';
  fromDecimal();
</script>

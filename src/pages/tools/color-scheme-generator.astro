---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="color-scheme-generator">
  <div class="flex flex-col gap-6">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Base color
        <input id="cs-base" type="color" value="#5e6ad2" class="field h-10 w-16 cursor-pointer p-1" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">or HEX
        <input id="cs-hex" class="field w-32 font-mono" value="#5e6ad2" spellcheck="false" />
      </label>
    </div>
    <div id="cs-schemes" class="flex flex-col gap-6"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free color scheme generator takes a single base color and derives the
      classic color-wheel harmonies — complementary, analogous, triadic, tetradic,
      split-complementary and a monochromatic tint-and-shade scale. Each swatch
      shows its HEX value and copies on click. It's a quick way to build a
      balanced, professional color scheme from one starting color. Runs entirely
      in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { hexToRgb, rgbToHex, rgbToHsl, hslToRgb } from '../../lib/colors';

  const $ = (id: string) => document.getElementById(id)!;
  const baseEl = $('cs-base') as HTMLInputElement;
  const hexEl = $('cs-hex') as HTMLInputElement;
  const wrap = $('cs-schemes')!;

  const hslHex = (h: number, s: number, l: number) => rgbToHex(hslToRgb({ h: ((h % 360) + 360) % 360, s: Math.max(0, Math.min(100, s)), l: Math.max(0, Math.min(100, l)) }));

  function schemes(hex: string) {
    const rgb = hexToRgb(hex); if (!rgb) return null;
    const { h, s, l } = rgbToHsl(rgb);
    return {
      Complementary: [hslHex(h, s, l), hslHex(h + 180, s, l)],
      Analogous: [hslHex(h - 30, s, l), hslHex(h, s, l), hslHex(h + 30, s, l)],
      Triadic: [hslHex(h, s, l), hslHex(h + 120, s, l), hslHex(h + 240, s, l)],
      Tetradic: [hslHex(h, s, l), hslHex(h + 90, s, l), hslHex(h + 180, s, l), hslHex(h + 270, s, l)],
      'Split-complementary': [hslHex(h, s, l), hslHex(h + 150, s, l), hslHex(h + 210, s, l)],
      Monochromatic: [hslHex(h, s, 20), hslHex(h, s, 35), hslHex(h, s, 50), hslHex(h, s, 65), hslHex(h, s, 80)],
    };
  }

  function render(hex: string) {
    const s = schemes(hex);
    if (!s) return;
    wrap.innerHTML = Object.entries(s).map(([name, cols]) => `
      <div class="flex flex-col gap-2">
        <span class="text-sm font-medium text-ink">${name}</span>
        <div class="flex gap-2">${cols.map((c) => `
          <button data-c="${c}" class="flex h-20 flex-1 flex-col justify-end overflow-hidden rounded-md border border-hairline p-1.5 text-left" style="background:${c}">
            <span class="rounded-xs bg-black/40 px-1.5 py-0.5 font-mono text-[11px] text-white">${c}</span>
          </button>`).join('')}
        </div>
      </div>`).join('');
    wrap.querySelectorAll('button').forEach((b) => b.addEventListener('click', async () => {
      const c = (b as HTMLElement).dataset.c!;
      await navigator.clipboard.writeText(c);
      const span = b.querySelector('span')!;
      const orig = span.textContent;
      span.textContent = 'Copied!';
      setTimeout(() => (span.textContent = orig), 1200);
    }));
  }

  baseEl.addEventListener('input', () => { hexEl.value = baseEl.value; render(baseEl.value); });
  hexEl.addEventListener('input', () => {
    if (/^#[0-9a-fA-F]{6}$/.test(hexEl.value)) { baseEl.value = hexEl.value; render(hexEl.value); }
  });
  render(baseEl.value);
</script>

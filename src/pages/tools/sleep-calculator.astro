---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="sleep-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Mode">
      <button type="button" class="btn btn-primary" data-mode="wake" aria-selected="true">I want to wake up at</button>
      <button type="button" class="btn btn-secondary" data-mode="bed" aria-selected="false">I'm going to bed at</button>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span id="sleep-label">Wake-up time</span>
      <input id="sleep-time" type="time" class="field" />
    </label>

    <div class="panel panel-lift p-6 text-center">
      <div id="sleep-headline" class="font-display text-2xl font-semibold text-primary-hover">—</div>
      <div id="sleep-sub" class="mt-2 text-sm text-ink-muted"></div>
    </div>

    <div id="sleep-results" class="flex flex-col gap-2"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free sleep calculator suggests bedtimes or wake times aligned to your
      body's natural 90-minute sleep cycles, so you wake between cycles rather
      than mid-cycle and feel more rested. It assumes about 14 minutes to fall
      asleep and offers options for 3 to 6 full cycles. These are general guides,
      not medical advice — real sleep needs vary from person to person. Runs
      entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const CYCLE = 90;
  const FALL_ASLEEP = 14;
  const CYCLES = [6, 5, 4, 3];

  let mode: 'wake' | 'bed' = 'wake';
  const tabs = Array.from(document.querySelectorAll('[data-mode]')) as HTMLButtonElement[];
  const timeInput = document.getElementById('sleep-time') as HTMLInputElement;

  function fmt12(totalMin: number): string {
    let m = ((totalMin % 1440) + 1440) % 1440;
    let h = Math.floor(m / 60);
    const min = m % 60;
    const ampm = h >= 12 ? 'pm' : 'am';
    h = h % 12;
    if (h === 0) h = 12;
    return `${h}:${String(min).padStart(2, '0')} ${ampm}`;
  }

  function setMode(next: 'wake' | 'bed') {
    mode = next;
    tabs.forEach((b) => {
      const active = b.dataset.mode === mode;
      b.classList.toggle('btn-primary', active);
      b.classList.toggle('btn-secondary', !active);
      b.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    document.getElementById('sleep-label')!.textContent =
      mode === 'wake' ? 'Wake-up time' : 'Bedtime';
    calc();
  }
  tabs.forEach((b) => b.addEventListener('click', () => setMode(b.dataset.mode as 'wake' | 'bed')));

  function calc() {
    const v = timeInput.value;
    const results = document.getElementById('sleep-results')!;
    if (!v) {
      document.getElementById('sleep-headline')!.textContent = '—';
      document.getElementById('sleep-sub')!.textContent = '';
      results.innerHTML = '';
      return;
    }
    const [hh, mm] = v.split(':').map(Number);
    const base = hh * 60 + mm;

    let items: { time: number; cycles: number; sleepMin: number }[];
    if (mode === 'wake') {
      // bedtime = wake - (cycles*90 + fallAsleep)
      items = CYCLES.map((c) => ({ time: base - (c * CYCLE + FALL_ASLEEP), cycles: c, sleepMin: c * CYCLE }));
      document.getElementById('sleep-headline')!.textContent = `Wake at ${fmt12(base)}`;
      document.getElementById('sleep-sub')!.textContent = 'Best bedtimes to fall asleep by';
    } else {
      // wake = bed + fallAsleep + cycles*90
      items = CYCLES.map((c) => ({ time: base + FALL_ASLEEP + c * CYCLE, cycles: c, sleepMin: c * CYCLE }));
      document.getElementById('sleep-headline')!.textContent = `Bedtime ${fmt12(base)}`;
      document.getElementById('sleep-sub')!.textContent = 'Best times to wake up';
    }

    results.innerHTML = items
      .map((it) => {
        const hrs = it.sleepMin / 60;
        const hrsLabel = Number.isInteger(hrs) ? `${hrs}h` : `${hrs.toFixed(1)}h`;
        return `<div class="flex items-center justify-between border-t border-hairline pt-2 first:border-0 first:pt-0"><span class="font-mono text-ink">${fmt12(it.time)}</span><span class="text-ink-subtle">${it.cycles} cycles · ${hrsLabel} sleep</span></div>`;
      })
      .join('');
  }

  // Default to now
  const now = new Date();
  timeInput.value = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
  timeInput.addEventListener('input', calc);
  calc();
</script>

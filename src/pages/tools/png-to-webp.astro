---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ImageConverter from '../../components/ImageConverter.astro';
---

<ToolLayout slug="png-to-webp">
  <ImageConverter to="image/webp" accept="image/png" ext="webp" quality={true} />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PNG to WebP converter turns PNG images into modern WebP format,
      which is typically far smaller at similar quality — great for faster web
      pages. WebP preserves transparency like PNG. Adjust the quality, preview
      the result on a checkerboard so you can see transparency, and download.
      Everything runs in your browser and your image is never uploaded.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="png-to-webp">
  <div id="pw-root" class="flex flex-col gap-4">

    <label id="pw-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose PNG images or drop them here</span>
      <input id="pw-file" type="file" accept="image/png,image/*" multiple class="sr-only" />
    </label>

    <div id="pw-controls" class="hidden panel p-4">
      <div class="flex flex-col gap-4">
        <div class="flex flex-wrap items-end gap-x-5 gap-y-3">
          <label class="flex min-w-48 flex-1 flex-col gap-1 text-sm text-ink-subtle">
            <span class="flex justify-between">Quality <span id="pw-qval" class="text-ink">90%</span></span>
            <input id="pw-q" type="range" min="1" max="100" value="90" class="w-full accent-primary" />
          </label>

          <label class="flex flex-col gap-1 text-sm text-ink-subtle">
            Resize
            <select id="pw-resize" class="field w-auto py-1">
              <option value="none" selected>Original size</option>
              <option value="percent">Scale %</option>
              <option value="longest">Longest edge (px)</option>
            </select>
          </label>

          <label id="pw-dim-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">
            <span id="pw-dim-label">Value</span>
            <input id="pw-dim" type="number" min="1" step="1" value="100" class="field w-28 py-1" />
          </label>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <button id="pw-download-all" class="btn btn-primary">Download all (.zip)</button>
          <button id="pw-add" class="btn btn-secondary">Add more</button>
          <button id="pw-clear" class="btn btn-tertiary">Clear</button>
          <span id="pw-summary" class="text-[13px] text-ink-subtle"></span>
        </div>
      </div>
    </div>

    <p id="pw-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="pw-list" class="hidden grid-cols-1 gap-4 sm:grid-cols-2"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PNG to WebP converter turns PNG images into modern WebP format,
      which is typically far smaller at similar quality â€” great for faster web
      pages. WebP preserves transparency like PNG, and every result is drawn on a
      checkerboard so you can see the transparent areas. Adjust the quality,
      optionally resize (scale by percentage or clamp the longest edge), then
      download each file â€” or grab everything at once as a single ZIP.
    </p>
    <p>
      Unlike single-file converters, this tool handles a <strong>whole batch</strong>
      at once: drop in dozens of PNGs, tune quality once, and every image
      re-encodes live. Each card shows the output dimensions and the exact
      before â†’ after size with the percentage saved, plus a running total across
      the batch so you can see how much you've shaved off. You can add more files
      to an in-progress batch, remove individual images, or clear everything.
    </p>
    <p>
      Encoding uses the native canvas encoder, there are no file-count or size
      limits beyond your device's memory, and there's no sign-up or watermark.
      If your browser can't encode WebP (rare on modern browsers), you'll get a
      clear message instead of a silent failure.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .pw-checker {
    background-image:
      linear-gradient(45deg,#2a2a2e 25%,transparent 25%),
      linear-gradient(-45deg,#2a2a2e 25%,transparent 25%),
      linear-gradient(45deg,transparent 75%,#2a2a2e 75%),
      linear-gradient(-45deg,transparent 75%,#2a2a2e 75%);
    background-size:16px 16px;
    background-position:0 0,0 8px,8px -8px,-8px 0;
  }
</style>

<script>

  const root = document.getElementById('pw-root') as HTMLElement;
  const fileInput = document.getElementById('pw-file') as HTMLInputElement;
  const drop = document.getElementById('pw-drop')!;
  const controls = document.getElementById('pw-controls')!;
  const listEl = document.getElementById('pw-list')!;
  const err = document.getElementById('pw-error')!;
  const summary = document.getElementById('pw-summary')!;
  const qEl = document.getElementById('pw-q') as HTMLInputElement;
  const qval = document.getElementById('pw-qval')!;
  const resizeSel = document.getElementById('pw-resize') as HTMLSelectElement;
  const dimWrap = document.getElementById('pw-dim-wrap')!;
  const dimLabel = document.getElementById('pw-dim-label')!;
  const dimEl = document.getElementById('pw-dim') as HTMLInputElement;

  type Item = {
    name: string;         
    img: HTMLImageElement | ImageBitmap;
    srcW: number; srcH: number;
    origSize: number;
    blob: Blob | null;
    outW: number; outH: number;
    error: string;
    card: HTMLElement;
    thumb: HTMLImageElement;
    caption: HTMLElement;
    thumbUrl: string;
  };
  const items: Item[] = [];

  const fmtSize = (n: number) =>
    n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;

  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }

  // WebP encode support check (some old browsers can't). Cached.
  let webpSupported: boolean | null = null;
  function checkWebp(): boolean {
    if (webpSupported === null) {
      const c = document.createElement('canvas');
      c.width = c.height = 1;
      webpSupported = c.toDataURL('image/webp').startsWith('data:image/webp');
    }
    return webpSupported;
  }

  // Compute output dimensions from the resize controls.
  function targetSize(srcW: number, srcH: number): { w: number; h: number } {
    const mode = resizeSel.value;
    const v = Math.max(1, Number(dimEl.value) || 0);
    if (mode === 'percent') {
      const s = v / 100;
      return { w: Math.max(1, Math.round(srcW * s)), h: Math.max(1, Math.round(srcH * s)) };
    }
    if (mode === 'longest') {
      const longest = Math.max(srcW, srcH);
      const s = v / longest;
      return { w: Math.max(1, Math.round(srcW * s)), h: Math.max(1, Math.round(srcH * s)) };
    }
    return { w: srcW, h: srcH };
  }

  // Encode one item to WebP with the current settings.
  function encode(it: Item): Promise<void> {
    return new Promise((resolve) => {
      const { w, h } = targetSize(it.srcW, it.srcH);
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      const ctx = canvas.getContext('2d');
      if (!ctx) { it.error = 'Canvas unavailable.'; it.blob = null; resolve(); return; }
      ctx.imageSmoothingEnabled = true;
      ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(it.img as CanvasImageSource, 0, 0, w, h);
      it.outW = w; it.outH = h;
      const quality = Number(qEl.value) / 100;
      canvas.toBlob((b) => {
        if (!b) { it.error = 'Browser could not encode WebP.'; it.blob = null; }
        else { it.error = ''; it.blob = b; }
        resolve();
      }, 'image/webp', quality);
    });
  }

  function renderCard(it: Item) {
    if (it.error) {
      it.thumb.classList.add('hidden');
      it.caption.innerHTML = `<span style="color:#e5484d">${it.error}</span>`;
      return;
    }
    it.thumb.classList.remove('hidden');
    if (it.thumbUrl) URL.revokeObjectURL(it.thumbUrl);
    it.thumbUrl = URL.createObjectURL(it.blob!);
    it.thumb.src = it.thumbUrl;
    const saved = it.origSize > 0 ? Math.round((1 - it.blob!.size / it.origSize) * 100) : 0;
    const savedTxt = saved >= 0 ? `âˆ’${saved}%` : `+${-saved}%`;
    const savedColor = saved >= 0 ? 'var(--color-semantic-success, #27a644)' : '#e5484d';
    it.caption.innerHTML =
      `${it.outW}Ã—${it.outH} Â· ${fmtSize(it.origSize)} â†’ ${fmtSize(it.blob!.size)} ` +
      `<span style="color:${savedColor}">(${savedTxt})</span>`;
  }

  function updateSummary() {
    const ok = items.filter((i) => i.blob && !i.error);
    if (!ok.length) { summary.textContent = ''; return; }
    const orig = ok.reduce((s, i) => s + i.origSize, 0);
    const out = ok.reduce((s, i) => s + i.blob!.size, 0);
    const saved = orig > 0 ? Math.round((1 - out / orig) * 100) : 0;
    summary.textContent =
      `${ok.length} image${ok.length === 1 ? '' : 's'} Â· ${fmtSize(orig)} â†’ ${fmtSize(out)} ` +
      `(${saved >= 0 ? 'âˆ’' : '+'}${Math.abs(saved)}% overall)`;
  }

  async function reencodeAll() {
    if (!items.length) return;
    if (!checkWebp()) { setErr('Your browser does not support encoding WebP images.'); return; }
    await Promise.all(items.map((it) => encode(it)));
    items.forEach(renderCard);
    updateSummary();
  }

  function buildCard(it: Item) {
    const card = document.createElement('div');
    card.className = 'panel flex flex-col gap-2 p-3';

    const head = document.createElement('div');
    head.className = 'flex items-center justify-between gap-2';
    const nameEl = document.createElement('span');
    nameEl.className = 'truncate text-[13px] text-ink';
    nameEl.textContent = it.name;
    nameEl.title = it.name;
    const remove = document.createElement('button');
    remove.className = 'btn btn-tertiary px-2 py-1 text-[13px]';
    remove.textContent = 'Remove';
    remove.addEventListener('click', () => removeItem(it));
    head.append(nameEl, remove);

    const frame = document.createElement('div');
    frame.className = 'pw-checker flex justify-center overflow-hidden rounded-md p-3';
    const thumb = document.createElement('img');
    thumb.className = 'max-h-56 w-auto max-w-full rounded-sm';
    thumb.alt = `WebP preview of ${it.name}`;
    frame.append(thumb);

    const foot = document.createElement('div');
    foot.className = 'flex items-center justify-between gap-2';
    const caption = document.createElement('span');
    caption.className = 'text-[13px] text-ink-subtle';
    const dl = document.createElement('button');
    dl.className = 'btn btn-secondary px-2 py-1 text-[13px]';
    dl.textContent = 'Download';
    dl.addEventListener('click', () => downloadItem(it));
    foot.append(caption, dl);

    card.append(head, frame, foot);
    it.card = card; it.thumb = thumb; it.caption = caption;
    listEl.append(card);
  }

  function removeItem(it: Item) {
    const idx = items.indexOf(it);
    if (idx >= 0) items.splice(idx, 1);
    if (it.thumbUrl) URL.revokeObjectURL(it.thumbUrl);
    if ('close' in it.img && typeof (it.img as ImageBitmap).close === 'function') (it.img as ImageBitmap).close();
    it.card.remove();
    if (!items.length) { controls.classList.add('hidden'); listEl.classList.add('hidden'); }
    updateSummary();
  }

  function downloadItem(it: Item) {
    if (!it.blob) return;
    const a = document.createElement('a');
    a.download = it.name;
    a.href = URL.createObjectURL(it.blob);
    a.click();
    URL.revokeObjectURL(a.href);
  }

  // Decode a file to a drawable image. createImageBitmap is fast; fall back to
  // <img> for browsers/edge cases where it rejects.
  async function decode(file: File): Promise<HTMLImageElement | ImageBitmap> {
    try {
      return await createImageBitmap(file);
    } catch {
      return await new Promise((resolve, reject) => {
        const url = URL.createObjectURL(file);
        const im = new Image();
        im.onload = () => { URL.revokeObjectURL(url); resolve(im); };
        im.onerror = () => { URL.revokeObjectURL(url); reject(new Error('decode failed')); };
        im.src = url;
      });
    }
  }

  async function addFiles(files: FileList | File[]) {
    setErr('');
    const arr = Array.from(files).filter((f) => f.type.startsWith('image/') || /\.(png|jpe?g|gif|bmp|webp|svg)$/i.test(f.name));
    if (!arr.length) { setErr('No image files found. Choose PNG images to convert.'); return; }
    if (!checkWebp()) { setErr('Your browser does not support encoding WebP images.'); return; }

    controls.classList.remove('hidden');
    listEl.classList.remove('hidden'); listEl.classList.add('grid');

    for (const file of arr) {
      let img: HTMLImageElement | ImageBitmap;
      try { img = await decode(file); }
      catch { setErr(`Could not read "${file.name}".`); continue; }
      const w = (img as ImageBitmap).width || (img as HTMLImageElement).naturalWidth || 512;
      const h = (img as ImageBitmap).height || (img as HTMLImageElement).naturalHeight || 512;
      const base = file.name.replace(/\.[^./\\]+$/, '');
      const it: Item = {
        name: `${base}.webp`, img, srcW: w, srcH: h, origSize: file.size,
        blob: null, outW: w, outH: h, error: '',
        card: null as any, thumb: null as any, caption: null as any, thumbUrl: '',
      };
      buildCard(it);
      items.push(it);
      await encode(it);
      renderCard(it);
    }
    updateSummary();
  }

  // --- Minimal store-only ZIP (no compression). WebP is already compressed, so
  // "store" is the standard, correct choice and needs no deflate dependency.
  // ponytail: store method only; add deflate if archive size ever matters.
  const crcTable = (() => {
    const t = new Uint32Array(256);
    for (let n = 0; n < 256; n++) {
      let c = n;
      for (let k = 0; k < 8; k++) c = c & 1 ? 0xedb88320 ^ (c >>> 1) : c >>> 1;
      t[n] = c >>> 0;
    }
    return t;
  })();
  function crc32(buf: Uint8Array): number {
    let c = 0xffffffff;
    for (let i = 0; i < buf.length; i++) c = crcTable[(c ^ buf[i]) & 0xff] ^ (c >>> 8);
    return (c ^ 0xffffffff) >>> 0;
  }
  function makeZip(files: { name: string; data: Uint8Array }[]): Blob {
    const enc = new TextEncoder();
    const locals: Uint8Array[] = [];
    const centrals: Uint8Array[] = [];
    let offset = 0;
    for (const f of files) {
      const nameBytes = enc.encode(f.name);
      const crc = crc32(f.data);
      const size = f.data.length;

      const local = new Uint8Array(30 + nameBytes.length);
      const lv = new DataView(local.buffer);
      lv.setUint32(0, 0x04034b50, true);   // local file header sig
      lv.setUint16(4, 20, true);           // version needed
      lv.setUint16(6, 0, true);            // flags
      lv.setUint16(8, 0, true);            // method = store
      lv.setUint16(10, 0, true);           // mod time
      lv.setUint16(12, 0, true);           // mod date
      lv.setUint32(14, crc, true);
      lv.setUint32(18, size, true);        // compressed size
      lv.setUint32(22, size, true);        // uncompressed size
      lv.setUint16(26, nameBytes.length, true);
      lv.setUint16(28, 0, true);           // extra len
      local.set(nameBytes, 30);
      locals.push(local, f.data);

      const central = new Uint8Array(46 + nameBytes.length);
      const cv = new DataView(central.buffer);
      cv.setUint32(0, 0x02014b50, true);   // central dir sig
      cv.setUint16(4, 20, true);           // version made by
      cv.setUint16(6, 20, true);           // version needed
      cv.setUint16(8, 0, true);
      cv.setUint16(10, 0, true);           // method
      cv.setUint16(12, 0, true);
      cv.setUint16(14, 0, true);
      cv.setUint32(16, crc, true);
      cv.setUint32(20, size, true);
      cv.setUint32(24, size, true);
      cv.setUint16(28, nameBytes.length, true);
      cv.setUint16(30, 0, true);           // extra
      cv.setUint16(32, 0, true);           // comment
      cv.setUint16(34, 0, true);           // disk
      cv.setUint16(36, 0, true);           // internal attrs
      cv.setUint32(38, 0, true);           // external attrs
      cv.setUint32(42, offset, true);      // local header offset
      central.set(nameBytes, 46);
      centrals.push(central);

      offset += local.length + f.data.length;
    }
    const centralSize = centrals.reduce((s, c) => s + c.length, 0);
    const end = new Uint8Array(22);
    const ev = new DataView(end.buffer);
    ev.setUint32(0, 0x06054b50, true);     // end of central dir sig
    ev.setUint16(8, files.length, true);   // entries on disk
    ev.setUint16(10, files.length, true);  // total entries
    ev.setUint32(12, centralSize, true);   // central dir size
    ev.setUint32(16, offset, true);        // central dir offset
    return new Blob([...locals, ...centrals, end] as BlobPart[], { type: 'application/zip' });
  }

  async function downloadAll() {
    const ok = items.filter((i) => i.blob && !i.error);
    if (!ok.length) { setErr('Nothing to download yet.'); return; }
    if (ok.length === 1) { downloadItem(ok[0]); return; }
    // Dedupe names inside the archive.
    const seen: Record<string, number> = {};
    const files: { name: string; data: Uint8Array }[] = [];
    for (const it of ok) {
      let name = it.name;
      if (seen[name] != null) { const n = ++seen[name]; name = name.replace(/\.webp$/i, `-${n}.webp`); }
      else seen[name] = 0;
      files.push({ name, data: new Uint8Array(await it.blob!.arrayBuffer()) });
    }
    const zip = makeZip(files);
    const a = document.createElement('a');
    a.download = 'webp-images.zip';
    a.href = URL.createObjectURL(zip);
    a.click();
    URL.revokeObjectURL(a.href);
  }

  // --- Wiring
  qEl.addEventListener('input', () => { qval.textContent = qEl.value + '%'; void reencodeAll(); });
  resizeSel.addEventListener('change', () => {
    const mode = resizeSel.value;
    dimWrap.classList.toggle('hidden', mode === 'none');
    dimWrap.classList.toggle('flex', mode !== 'none');
    if (mode === 'percent') { dimLabel.textContent = 'Scale %'; dimEl.value = '100'; }
    else if (mode === 'longest') { dimLabel.textContent = 'Longest edge (px)'; dimEl.value = '1920'; }
    void reencodeAll();
  });
  dimEl.addEventListener('input', () => { void reencodeAll(); });

  fileInput.addEventListener('change', () => { if (fileInput.files?.length) void addFiles(fileInput.files); fileInput.value = ''; });
  document.getElementById('pw-add')!.addEventListener('click', () => fileInput.click());
  document.getElementById('pw-download-all')!.addEventListener('click', () => { void downloadAll(); });
  document.getElementById('pw-clear')!.addEventListener('click', () => {
    [...items].forEach(removeItem);
    setErr('');
  });

  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => {
    ev.preventDefault();
    const f = (ev as DragEvent).dataTransfer?.files;
    if (f?.length) void addFiles(f);
  });
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ColorFormats from '../../components/ColorFormats.astro';

const CHANNELS = [
  { key: 'c', label: 'Cyan',    dot: '#00aeef' },
  { key: 'm', label: 'Magenta', dot: '#ec008c' },
  { key: 'y', label: 'Yellow',  dot: '#fff200' },
  { key: 'k', label: 'Key / Black', dot: '#4b4b4b' },
];
---

<ToolLayout slug="cmyk-converter">
  <div class="flex flex-col gap-6">
    <ColorFormats focus="cmyk" />

    <div class="panel flex flex-col gap-4 rounded-lg p-4">
      <div class="flex items-baseline justify-between gap-3">
        <span class="eyebrow text-ink-subtle">CMYK sliders</span>
        <span id="ck-out" class="font-mono text-[13px] text-ink-muted"></span>
      </div>

      <div class="flex flex-col gap-3">
        {CHANNELS.map((ch) => (
          <div class="flex items-center gap-3" data-chan={ch.key}>
            <span class="flex w-28 shrink-0 items-center gap-2 text-[13px] text-ink-subtle">
              <span class="h-3 w-3 shrink-0 rounded-full border border-hairline" style={`background:${ch.dot}`}></span>
              {ch.label}
            </span>
            <input
              class="ck-range h-2 flex-1 cursor-pointer accent-primary"
              type="range" min="0" max="100" step="1" value="0"
              aria-label={`${ch.label} percentage`} />
            <input
              class="ck-num field w-20 shrink-0 text-center font-mono"
              type="number" min="0" max="100" step="1" value="0"
              inputmode="numeric" spellcheck="false" aria-label={`${ch.label} value`} />
            <span class="w-4 shrink-0 text-[13px] text-ink-subtle">%</span>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap gap-2">
        <button id="ck-copy" class="btn btn-secondary" type="button">Copy cmyk(…)</button>
        <button id="ck-reset" class="btn btn-tertiary" type="button">Reset to black (0,0,0,100)</button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CMYK converter turns colors between the CMYK print model —
      cyan, magenta, yellow and key (black) — and the screen models HEX, RGB,
      HSL and HSV. CMYK is subtractive and used for physical printing, so a
      screen color and its CMYK equivalent can look slightly different; this
      tool gives a faithful mathematical conversion. Everything runs in your browser.
    </p>
    <p>
      Type into any field, drag the dedicated C, M, Y and K sliders, or pick a
      color visually — every representation updates live and stays in sync. Copy
      any value with one click, or grab a tint or shade from the strip. The
      nearest CSS color name is shown for reference. No uploads, no sign-up, no
      limits; the conversion happens entirely on your device.
    </p>
  </div>
</ToolLayout>

<script>

  const cmykField = document.getElementById('cf-cmyk') as HTMLInputElement | null;
  const rows = Array.from(document.querySelectorAll<HTMLElement>('[data-chan]'));
  const outEl = document.getElementById('ck-out');
  if (cmykField && rows.length === 4) {
    const KEYS = ['c', 'm', 'y', 'k'] as const;
    type Ch = (typeof KEYS)[number];
    const ranges: Record<Ch, HTMLInputElement> = {} as any;
    const nums: Record<Ch, HTMLInputElement> = {} as any;
    for (const row of rows) {
      const k = row.dataset.chan as Ch;
      ranges[k] = row.querySelector('.ck-range') as HTMLInputElement;
      nums[k] = row.querySelector('.ck-num') as HTMLInputElement;
    }

    const clamp = (n: number) => Math.min(100, Math.max(0, Math.round(n || 0)));

    const readField = () => {
      const m = cmykField.value.match(/(-?\d+)\D+(-?\d+)\D+(-?\d+)\D+(-?\d+)/);
      return m ? { c: +m[1], m: +m[2], y: +m[3], k: +m[4] } : null;
    };

    const format = (v: Record<Ch, number>) =>
      `cmyk(${v.c}%, ${v.m}%, ${v.y}%, ${v.k}%)`;

    let last = '';

    // Push slider state into the shared converter.
    const pushToConverter = () => {
      const v = { c: clamp(+ranges.c.value), m: clamp(+ranges.m.value),
                  y: clamp(+ranges.y.value), k: clamp(+ranges.k.value) };
      last = `${v.c},${v.m},${v.y},${v.k}`;
      if (outEl) outEl.textContent = format(v);
      cmykField.value = format(v);
      cmykField.dispatchEvent(new Event('input', { bubbles: true }));
    };

    // Pull converter state into the sliders (from any source).
    const pullFromConverter = (v: Record<Ch, number>) => {
      for (const k of KEYS) {
        const val = String(clamp(v[k]));
        ranges[k].value = val;
        nums[k].value = val;
      }
      last = `${clamp(v.c)},${clamp(v.m)},${clamp(v.y)},${clamp(v.k)}`;
      if (outEl) outEl.textContent = format({ c: clamp(v.c), m: clamp(v.m), y: clamp(v.y), k: clamp(v.k) });
    };

    for (const k of KEYS) {
      ranges[k].addEventListener('input', () => { nums[k].value = ranges[k].value; pushToConverter(); });
      nums[k].addEventListener('input', () => {
        const val = clamp(+nums[k].value);
        ranges[k].value = String(val);
        pushToConverter();
      });
    }

    document.getElementById('ck-copy')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      try {
        await navigator.clipboard.writeText(outEl?.textContent || cmykField.value);
        const old = btn.textContent; btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = old), 1400);
      } catch 
    });

    document.getElementById('ck-reset')?.addEventListener('click', () => {
      pullFromConverter({ c: 0, m: 0, y: 0, k: 100 });
      pushToConverter();
    });

    // Initialize + keep in sync with external changes.
    const init = readField();
    if (init) pullFromConverter(init);
    // ponytail: 120ms poll — the shared component doesn't emit events on
    // programmatic field updates; a poll is smaller than re-listening to every
    // source input. Swap for an event if ColorFormats ever dispatches one.
    setInterval(() => {
      const v = readField();
      if (!v) return;
      const s = `${clamp(v.c)},${clamp(v.m)},${clamp(v.y)},${clamp(v.k)}`;
      if (s !== last) pullFromConverter(v);
    }, 120);
  }
</script>

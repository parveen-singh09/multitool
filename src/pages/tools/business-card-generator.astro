---
import ToolLayout from '../../layouts/ToolLayout.astro';

// Template gallery. Each entry is a distinct designed layout + palette, not a
// color swap — the swatch preview is rendered live on a mini-canvas by the
// client script so the grid mirrors what you'll download.
const templates = [
  { id: 'bar-left',    name: 'Accent Bar' },
  { id: 'top-band',    name: 'Header Band' },
  { id: 'centered',    name: 'Centered Serif' },
  { id: 'monogram',    name: 'Monogram' },
  { id: 'split-diag',  name: 'Diagonal Split' },
  { id: 'sidebar',     name: 'Sidebar' },
  { id: 'dark-modern', name: 'Dark Modern' },
  { id: 'minimal',     name: 'Minimal' },
  { id: 'stripe',      name: 'Bottom Stripe' },
  { id: 'corner',      name: 'Corner Frame' },
  { id: 'outline',     name: 'Outline' },
  { id: 'gradient',    name: 'Gradient' },
];
---

<ToolLayout slug="business-card-generator">
  <div class="flex flex-col gap-6">
    <!-- Template gallery -->
    <div class="flex flex-col gap-2">
      <span class="text-sm text-ink-subtle">Template</span>
      <div id="bc-templates" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
        {templates.map((t) => (
          <button
            type="button"
            data-tpl={t.id}
            class="bc-tpl group flex flex-col gap-1.5 rounded-[10px] border border-hairline bg-surface-1 p-2 text-left transition-colors hover:border-hairline-strong hover:bg-surface-2"
          >
            <canvas
              data-thumb={t.id}
              width="350"
              height="200"
              class="w-full rounded-sm border border-hairline bg-white"
            ></canvas>
            <span class="truncate px-0.5 text-xs text-ink-muted">{t.name}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      <!-- Controls -->
      <div class="flex flex-col gap-4">
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Full name
            <input id="bc-name" class="field" value="Jane Doe" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Job title
            <input id="bc-title" class="field" value="Product Designer" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Company
            <input id="bc-company" class="field" value="ToolCities" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Tagline / slogan
            <input id="bc-tagline" class="field" value="Tools for makers" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Phone
            <input id="bc-phone" class="field" value="(555) 010-1234" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Email
            <input id="bc-email" class="field" value="jane@toolcities.com" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Website
            <input id="bc-web" class="field" value="toolcities.com" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Address
            <input id="bc-address" class="field" value="San Francisco, CA" />
          </label>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Accent color
            <input id="bc-accent" type="color" value="#5e6ad2" class="field h-10 cursor-pointer p-1" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Font
            <select id="bc-font" class="field">
              <option value="template">Match template</option>
              <option value="sans">Sans (Inter)</option>
              <option value="serif">Serif (Georgia)</option>
              <option value="mono">Mono (JetBrains)</option>
            </select>
          </label>
        </div>

        <!-- Logo + background upload -->
        <div class="flex flex-col gap-2">
          <span class="text-sm text-ink-subtle">Logo &amp; background</span>
          <div class="flex flex-wrap items-center gap-2">
            <label class="btn btn-secondary cursor-pointer">
              Upload logo
              <input id="bc-logo" type="file" accept="image/*" class="hidden" />
            </label>
            <button id="bc-logo-clear" class="btn btn-secondary hidden" type="button">Remove logo</button>
            <label class="btn btn-secondary cursor-pointer">
              <span id="bc-bgimg-label">Upload front background</span>
              <input id="bc-bgimg" type="file" accept="image/*" class="hidden" />
            </label>
            <button id="bc-bgimg-clear" class="btn btn-secondary hidden" type="button">Remove background</button>
          </div>
          <p class="text-xs leading-snug text-ink-tertiary">
            Logo (transparent PNG works best) sits in the card's brand slot. A
            background image fills the card full-bleed with a soft legibility panel behind text.
          </p>
        </div>

        <!-- Background-mode panel controls -->
        <div class="flex flex-col gap-2">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">
            <span class="flex items-center justify-between">Panel opacity <span id="bc-opacity-val" class="text-ink-tertiary">82%</span></span>
            <input id="bc-opacity" type="range" min="0" max="100" value="82" class="w-full accent-primary" />
          </label>
          <p class="text-xs leading-snug text-ink-tertiary">
            With a background image set, drag the white panel or logo on the preview to
            reposition, and drag the corner handle to resize.
          </p>
        </div>

        <!-- QR toggle -->
        <label class="flex items-center gap-2 text-sm text-ink-muted">
          <input id="bc-qr" type="checkbox" class="h-4 w-4 accent-primary" checked />
          Add a contact QR code (vCard) on the back
        </label>
      </div>

      <!-- Preview -->
      <div class="flex flex-col items-center gap-4">
        <!-- Side toggle -->
        <div class="inline-flex rounded-full border border-hairline bg-canvas p-1">
          <button id="bc-side-front" type="button" class="rounded-full px-4 py-1.5 text-[13px] font-medium text-ink transition-colors">Front</button>
          <button id="bc-side-back" type="button" class="rounded-full px-4 py-1.5 text-[13px] font-medium text-ink-subtle transition-colors">Back</button>
        </div>

        <canvas id="bc-canvas" width="1050" height="600" class="w-full rounded-lg border border-hairline shadow-[0_10px_40px_-15px_rgba(0,0,0,0.6)]"></canvas>
        <span class="text-xs text-ink-tertiary">3.5 × 2 in &middot; 1050 × 600 px &middot; 300 DPI print</span>

        <div class="flex flex-wrap justify-center gap-2">
          <button id="bc-dl-front" class="btn btn-primary">Download front PNG</button>
          <button id="bc-dl-back" class="btn btn-secondary">Download back PNG</button>
          <button id="bc-dl-pdf" class="btn btn-secondary">Download PDF (both)</button>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free business card generator designs a print-ready 3.5 × 2 inch card
      from twelve professionally designed templates — accent bar, header band,
      centered serif, monogram, diagonal split, sidebar, dark modern, minimal,
      bottom stripe, corner frame, outline and gradient. Each template is a
      distinct layout with its own palette and typography, and the gallery shows
      a live preview of your details in every style at once.
    </p>
    <p>
      Enter your name, title, company, tagline and contact details, override the
      accent color and font, and upload your own logo or a full-bleed background
      image. Every card has a matching front and back, and you can add a scannable
      vCard QR code so people can save your contact in one tap. Preview both sides
      live and download high-resolution 300-DPI PNGs or a two-page PDF ready for a
      print shop. All rendering happens in your browser — nothing is uploaded to a server.
    </p>
  </div>
</ToolLayout>

<script>
  type Layout =
    | 'bar-left' | 'top-band' | 'centered' | 'monogram' | 'split-diag'
    | 'sidebar' | 'dark-modern' | 'minimal' | 'stripe' | 'corner'
    | 'outline' | 'gradient';

  interface Template {
    id: Layout;
    bg: string;      // card background
    ink: string;     // primary text (name)
    sub: string;     // secondary text (contacts / meta)
    accent: string;  // default accent (overridable)
    onAccent: string;// text drawn on top of accent fills
    font: 'sans' | 'serif' | 'mono';
  }

  const FONTS: Record<string, string> = {
    sans: 'Inter, "SF Pro Display", system-ui, sans-serif',
    serif: 'Georgia, "Times New Roman", serif',
    mono: '"JetBrains Mono", ui-monospace, "SF Mono", monospace',
  };

  const TEMPLATES: Record<string, Template> = {
    'bar-left':    { id: 'bar-left',    bg: '#ffffff', ink: '#111318', sub: '#5b616e', accent: '#5e6ad2', onAccent: '#ffffff', font: 'sans' },
    'top-band':    { id: 'top-band',    bg: '#ffffff', ink: '#0f172a', sub: '#64748b', accent: '#0d9488', onAccent: '#ffffff', font: 'sans' },
    'centered':    { id: 'centered',    bg: '#fbfaf7', ink: '#1c1a16', sub: '#7a7266', accent: '#b8860b', onAccent: '#ffffff', font: 'serif' },
    'monogram':    { id: 'monogram',    bg: '#ffffff', ink: '#1a1a1a', sub: '#6b7280', accent: '#be185d', onAccent: '#ffffff', font: 'serif' },
    'split-diag':  { id: 'split-diag',  bg: '#ffffff', ink: '#0f172a', sub: '#64748b', accent: '#1e3a8a', onAccent: '#ffffff', font: 'sans' },
    'sidebar':     { id: 'sidebar',     bg: '#ffffff', ink: '#14281a', sub: '#4f6455', accent: '#15803d', onAccent: '#ffffff', font: 'sans' },
    'dark-modern': { id: 'dark-modern', bg: '#0f1011', ink: '#f7f8f8', sub: '#9aa0aa', accent: '#5e6ad2', onAccent: '#ffffff', font: 'sans' },
    'minimal':     { id: 'minimal',     bg: '#ffffff', ink: '#111111', sub: '#8a8f98', accent: '#111111', onAccent: '#ffffff', font: 'sans' },
    'stripe':      { id: 'stripe',      bg: '#ffffff', ink: '#111827', sub: '#6b7280', accent: '#ea580c', onAccent: '#ffffff', font: 'sans' },
    'corner':      { id: 'corner',      bg: '#ffffff', ink: '#1f2937', sub: '#6b7280', accent: '#7c3aed', onAccent: '#ffffff', font: 'sans' },
    'outline':     { id: 'outline',     bg: '#ffffff', ink: '#1c1c1c', sub: '#767676', accent: '#111111', onAccent: '#ffffff', font: 'serif' },
    'gradient':    { id: 'gradient',    bg: '#0b1220', ink: '#ffffff', sub: '#c7cfdb', accent: '#5e6ad2', onAccent: '#ffffff', font: 'sans' },
  };

  const $ = (id: string) => document.getElementById(id)!;
  const val = (id: string) => ($(id) as HTMLInputElement | HTMLSelectElement).value.trim();

  const canvas = $('bc-canvas') as HTMLCanvasElement;

  // ---- State ----
  let currentTpl: Layout = 'bar-left';
  let side: 'front' | 'back' = 'front';
  let accentTouched = false;
  let logoImg: HTMLImageElement | null = null;
  let bgImg: HTMLImageElement | null = null;
  let bgImgBack: HTMLImageElement | null = null;
  let qrImg: HTMLImageElement | null = null;
  let qrKey = '';

  // Background-image mode: free-form white legibility panel + draggable logos.
  interface Rect { x: number; y: number; w: number; h: number; }
  let panelOpacity = 0.82;
  let panelRect: Rect = { x: 60, y: 60, w: 930, h: 480 };
  let logoRect: Rect = { x: 770, y: 90, w: 180, h: 90 };
  let logoRectBack: Rect = { x: 440, y: 90, w: 170, h: 80 };
  // Until the user drags the back logo, keep it centered above the heading so it
  // tracks the layout's center (which shifts when the QR is shown/hidden).
  let logoBackTouched = false;

  interface CardData {
    name: string; title: string; company: string; tagline: string;
    phone: string; email: string; web: string; address: string;
  }

  const data = (): CardData => ({
    name: val('bc-name'), title: val('bc-title'), company: val('bc-company'),
    tagline: val('bc-tagline'), phone: val('bc-phone'), email: val('bc-email'),
    web: val('bc-web'), address: val('bc-address'),
  });

  const activeAccent = (t: Template) => (accentTouched ? val('bc-accent') : t.accent);
  const activeFont = (t: Template) => {
    const sel = val('bc-font');
    return FONTS[sel === 'template' ? t.font : sel];
  };

  // ---- Helpers ----
  function initials(name: string): string {
    const parts = name.split(/\s+/).filter(Boolean);
    if (!parts.length) return '?';
    if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
    return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  }

  // Draw an image contained within a box, preserving aspect ratio.
  function drawContain(ctx: CanvasRenderingContext2D, img: HTMLImageElement, x: number, y: number, w: number, h: number) {
    const r = Math.min(w / img.width, h / img.height);
    const dw = img.width * r, dh = img.height * r;
    ctx.drawImage(img, x + (w - dw) / 2, y + (h - dh) / 2, dw, dh);
  }

  // Draw an image covering a box (crop overflow).
  function drawCover(ctx: CanvasRenderingContext2D, img: HTMLImageElement, x: number, y: number, w: number, h: number) {
    const r = Math.max(w / img.width, h / img.height);
    const dw = img.width * r, dh = img.height * r;
    ctx.save();
    ctx.beginPath(); ctx.rect(x, y, w, h); ctx.clip();
    ctx.drawImage(img, x + (w - dw) / 2, y + (h - dh) / 2, dw, dh);
    ctx.restore();
  }

  function contactList(d: CardData): string[] {
    return [d.phone, d.email, d.web, d.address].filter(Boolean);
  }

  // ---- Front renderers (base coordinate space is always 1050 × 600) ----
  function drawFront(ctx: CanvasRenderingContext2D, tpl: Template, accent: string, font: string) {
    const W = 1050, H = 600, d = data();
    ctx.clearRect(0, 0, W, H);

    // Full-bleed uploaded background wins the canvas; text gets a legibility panel.
    if (bgImg) {
      drawCover(ctx, bgImg, 0, 0, W, H);
      // Stretchable / draggable white legibility panel.
      const p = panelRect;
      ctx.fillStyle = `rgba(255,255,255,${panelOpacity})`;
      ctx.fillRect(p.x, p.y, p.w, p.h);
      // Text block anchored inside the panel, with padding.
      drawGenericBlock(ctx, accent, font, '#111318', '#5b616e', d, p.x + 50, p.y + 90);
      // Draggable logo on the front.
      if (logoImg) drawContain(ctx, logoImg, logoRect.x, logoRect.y, logoRect.w, logoRect.h);
      return;
    }

    // Base background.
    ctx.fillStyle = tpl.bg;
    ctx.fillRect(0, 0, W, H);

    switch (tpl.id) {
      case 'bar-left':    return frontBarLeft(ctx, tpl, accent, font, d);
      case 'top-band':    return frontTopBand(ctx, tpl, accent, font, d);
      case 'centered':    return frontCentered(ctx, tpl, accent, font, d);
      case 'monogram':    return frontMonogram(ctx, tpl, accent, font, d);
      case 'split-diag':  return frontSplitDiag(ctx, tpl, accent, font, d);
      case 'sidebar':     return frontSidebar(ctx, tpl, accent, font, d);
      case 'dark-modern': return frontDarkModern(ctx, tpl, accent, font, d);
      case 'minimal':     return frontMinimal(ctx, tpl, accent, font, d);
      case 'stripe':      return frontStripe(ctx, tpl, accent, font, d);
      case 'corner':      return frontCorner(ctx, tpl, accent, font, d);
      case 'outline':     return frontOutline(ctx, tpl, accent, font, d);
      case 'gradient':    return frontGradient(ctx, tpl, accent, font, d);
    }
  }

  // Small logo helper for a top/brand slot.
  function maybeLogo(ctx: CanvasRenderingContext2D, x: number, y: number, w: number, h: number) {
    if (logoImg) { drawContain(ctx, logoImg, x, y, w, h); return true; }
    return false;
  }

  function contactsColumn(ctx: CanvasRenderingContext2D, lines: string[], x: number, yStart: number, color: string, accent: string, font: string, size = 26, gap = 44) {
    ctx.textAlign = 'left';
    ctx.font = `400 ${size}px ${font}`;
    lines.forEach((l, i) => {
      const y = yStart + i * gap;
      ctx.fillStyle = accent;
      ctx.beginPath(); ctx.arc(x + 5, y - size / 2.6, 4, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = color;
      ctx.fillText(l, x + 22, y);
    });
  }

  // Generic block reused by the upload-background path.
  function drawGenericBlock(ctx: CanvasRenderingContext2D, accent: string, font: string, ink: string, sub: string, d: CardData, x: number, y: number) {
    ctx.textAlign = 'left';
    ctx.fillStyle = ink; ctx.font = `700 60px ${font}`;
    ctx.fillText(d.name, x, y);
    ctx.fillStyle = accent; ctx.font = `500 30px ${font}`;
    ctx.fillText([d.title, d.company].filter(Boolean).join(' · '), x, y + 46);
    contactsColumn(ctx, contactList(d), x, y + 130, ink, accent, font);
  }

  function frontBarLeft(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    ctx.fillStyle = accent; ctx.fillRect(0, 0, 26, 600);
    const x = 100;
    if (maybeLogo(ctx, x, 70, 120, 60)) { /* logo drawn */ }
    ctx.textAlign = 'left';
    ctx.fillStyle = t.ink; ctx.font = `700 66px ${font}`;
    ctx.fillText(d.name, x, 210);
    ctx.fillStyle = accent; ctx.font = `500 32px ${font}`;
    ctx.fillText(d.title, x, 258);
    ctx.fillStyle = t.ink; ctx.font = `600 34px ${font}`;
    ctx.fillText(d.company, x, 320);
    contactsColumn(ctx, contactList(d), x, 420, t.sub, accent, font);
  }

  function frontTopBand(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    ctx.fillStyle = accent; ctx.fillRect(0, 0, 1050, 190);
    ctx.textAlign = 'left';
    if (logoImg) drawContain(ctx, logoImg, 70, 45, 100, 100);
    ctx.fillStyle = t.onAccent; ctx.font = `700 52px ${font}`;
    ctx.fillText(d.company, logoImg ? 190 : 70, 115);
    if (d.tagline) { ctx.font = `400 24px ${font}`; ctx.globalAlpha = 0.9; ctx.fillText(d.tagline, logoImg ? 190 : 70, 152); ctx.globalAlpha = 1; }
    ctx.fillStyle = t.ink; ctx.font = `700 50px ${font}`;
    ctx.fillText(d.name, 70, 300);
    ctx.fillStyle = accent; ctx.font = `500 28px ${font}`;
    ctx.fillText(d.title, 70, 342);
    contactsColumn(ctx, contactList(d), 70, 430, t.sub, accent, font);
  }

  function frontCentered(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    const cx = 525;
    ctx.textAlign = 'center';
    if (logoImg) drawContain(ctx, logoImg, cx - 45, 70, 90, 70);
    ctx.strokeStyle = accent; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(cx - 90, 185); ctx.lineTo(cx + 90, 185); ctx.stroke();
    ctx.fillStyle = t.ink; ctx.font = `600 62px ${font}`;
    ctx.fillText(d.name, cx, 275);
    ctx.fillStyle = accent; ctx.font = `italic 400 30px ${font}`;
    ctx.fillText(d.title, cx, 320);
    ctx.beginPath(); ctx.moveTo(cx - 90, 360); ctx.lineTo(cx + 90, 360); ctx.stroke();
    ctx.fillStyle = t.ink; ctx.font = `600 32px ${font}`;
    ctx.fillText(d.company, cx, 415);
    ctx.fillStyle = t.sub; ctx.font = `400 24px ${font}`;
    const lines = contactList(d);
    lines.forEach((l, i) => ctx.fillText(l, cx, 470 + i * 34));
  }

  function frontMonogram(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    const r = 95, cx = 190, cy = 200;
    ctx.fillStyle = accent;
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.fill();
    if (logoImg) {
      ctx.save(); ctx.beginPath(); ctx.arc(cx, cy, r - 6, 0, Math.PI * 2); ctx.clip();
      drawCover(ctx, logoImg, cx - r, cy - r, r * 2, r * 2); ctx.restore();
    } else {
      ctx.fillStyle = t.onAccent; ctx.textAlign = 'center'; ctx.font = `700 82px ${font}`;
      ctx.fillText(initials(d.name), cx, cy + 28);
    }
    ctx.textAlign = 'left';
    ctx.fillStyle = t.ink; ctx.font = `700 58px ${font}`;
    ctx.fillText(d.name, 330, 175);
    ctx.fillStyle = accent; ctx.font = `500 28px ${font}`;
    ctx.fillText([d.title, d.company].filter(Boolean).join(' · '), 330, 220);
    contactsColumn(ctx, contactList(d), 100, 400, t.sub, accent, font);
  }

  function frontSplitDiag(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    ctx.fillStyle = accent;
    ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(430, 0); ctx.lineTo(300, 600); ctx.lineTo(0, 600); ctx.closePath(); ctx.fill();
    ctx.textAlign = 'left';
    if (logoImg) drawContain(ctx, logoImg, 70, 90, 150, 90);
    else { ctx.fillStyle = t.onAccent; ctx.font = `700 74px ${font}`; ctx.fillText(initials(d.name), 90, 330); }
    if (d.company) { ctx.fillStyle = t.onAccent; ctx.font = `600 30px ${font}`; ctx.fillText(d.company, 70, 520); }
    const x = 500;
    ctx.fillStyle = t.ink; ctx.font = `700 60px ${font}`;
    ctx.fillText(d.name, x, 190);
    ctx.fillStyle = accent; ctx.font = `500 30px ${font}`;
    ctx.fillText(d.title, x, 236);
    contactsColumn(ctx, contactList(d), x, 340, t.sub, accent, font);
  }

  function frontSidebar(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    const sw = 360;
    ctx.fillStyle = accent; ctx.fillRect(1050 - sw, 0, sw, 600);
    // Left: name block.
    ctx.textAlign = 'left';
    if (maybeLogo(ctx, 80, 80, 130, 70)) { /* logo */ }
    ctx.fillStyle = t.ink; ctx.font = `700 60px ${font}`;
    ctx.fillText(d.name, 80, 300);
    ctx.fillStyle = accent; ctx.font = `500 30px ${font}`;
    ctx.fillText(d.title, 80, 348);
    ctx.fillStyle = t.sub; ctx.font = `600 28px ${font}`;
    ctx.fillText(d.company, 80, 420);
    // Right sidebar: contacts on accent.
    contactsColumn(ctx, contactList(d), 1050 - sw + 40, 150, t.onAccent, t.onAccent, font, 24, 52);
  }

  function frontDarkModern(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    // bg already dark
    ctx.fillStyle = accent; ctx.fillRect(0, 0, 1050, 8);
    ctx.textAlign = 'left';
    if (maybeLogo(ctx, 90, 80, 120, 60)) { /* logo */ }
    ctx.fillStyle = t.ink; ctx.font = `700 68px ${font}`;
    ctx.fillText(d.name, 90, 240);
    ctx.fillStyle = accent; ctx.font = `500 30px ${font}`;
    ctx.fillText([d.title, d.company].filter(Boolean).join('  /  '), 90, 288);
    contactsColumn(ctx, contactList(d), 90, 400, t.sub, accent, font);
  }

  function frontMinimal(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    ctx.textAlign = 'left';
    if (maybeLogo(ctx, 90, 80, 110, 55)) { /* logo */ }
    ctx.fillStyle = t.ink; ctx.font = `500 54px ${font}`;
    ctx.fillText(d.name, 90, 200);
    ctx.fillStyle = t.sub; ctx.font = `400 26px ${font}`;
    ctx.fillText([d.title, d.company].filter(Boolean).join(', '), 90, 244);
    // Contacts bottom-left, quiet.
    ctx.font = `400 24px ${font}`;
    const lines = contactList(d);
    lines.forEach((l, i) => { ctx.fillStyle = t.sub; ctx.fillText(l, 90, 470 + i * 34); });
    // Single accent tick.
    ctx.fillStyle = accent; ctx.fillRect(90, 150, 44, 4);
  }

  function frontStripe(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    ctx.textAlign = 'left';
    if (maybeLogo(ctx, 90, 70, 120, 60)) { /* logo */ }
    ctx.fillStyle = t.ink; ctx.font = `700 64px ${font}`;
    ctx.fillText(d.name, 90, 250);
    ctx.fillStyle = t.sub; ctx.font = `500 30px ${font}`;
    ctx.fillText([d.title, d.company].filter(Boolean).join(' · '), 90, 296);
    // Accent stripe bottom third with contacts on it.
    ctx.fillStyle = accent; ctx.fillRect(0, 400, 1050, 200);
    contactsColumn(ctx, contactList(d), 90, 470, t.onAccent, t.onAccent, font, 24, 44);
  }

  function frontCorner(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    // L-shaped accent corners.
    ctx.fillStyle = accent;
    const len = 150, th = 14;
    ctx.fillRect(50, 50, len, th); ctx.fillRect(50, 50, th, len);
    ctx.fillRect(1050 - 50 - len, 600 - 50 - th, len, th); ctx.fillRect(1050 - 50 - th, 600 - 50 - len, th, len);
    const cx = 525;
    ctx.textAlign = 'center';
    if (logoImg) drawContain(ctx, logoImg, cx - 55, 130, 110, 70);
    ctx.fillStyle = t.ink; ctx.font = `700 60px ${font}`;
    ctx.fillText(d.name, cx, 300);
    ctx.fillStyle = accent; ctx.font = `500 28px ${font}`;
    ctx.fillText([d.title, d.company].filter(Boolean).join(' · '), cx, 344);
    ctx.fillStyle = t.sub; ctx.font = `400 24px ${font}`;
    ctx.fillText(contactList(d).join('   ·   '), cx, 420);
  }

  function frontOutline(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    ctx.strokeStyle = accent; ctx.lineWidth = 3;
    ctx.strokeRect(45, 45, 960, 510);
    const cx = 525;
    ctx.textAlign = 'center';
    if (logoImg) drawContain(ctx, logoImg, cx - 50, 100, 100, 64);
    ctx.fillStyle = t.ink; ctx.font = `600 58px ${font}`;
    ctx.fillText(d.name, cx, 260);
    ctx.fillStyle = t.sub; ctx.font = `italic 400 28px ${font}`;
    ctx.fillText(d.title, cx, 306);
    ctx.strokeStyle = accent; ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(cx - 70, 344); ctx.lineTo(cx + 70, 344); ctx.stroke();
    ctx.fillStyle = t.ink; ctx.font = `600 30px ${font}`;
    ctx.fillText(d.company, cx, 400);
    ctx.fillStyle = t.sub; ctx.font = `400 23px ${font}`;
    contactList(d).forEach((l, i) => ctx.fillText(l, cx, 450 + i * 32));
  }

  function frontGradient(ctx: CanvasRenderingContext2D, t: Template, accent: string, font: string, d: CardData) {
    const g = ctx.createLinearGradient(0, 0, 1050, 600);
    g.addColorStop(0, '#0b1220');
    g.addColorStop(1, accent);
    ctx.fillStyle = g; ctx.fillRect(0, 0, 1050, 600);
    ctx.textAlign = 'left';
    if (maybeLogo(ctx, 90, 80, 120, 60)) { /* logo */ }
    ctx.fillStyle = t.ink; ctx.font = `700 66px ${font}`;
    ctx.fillText(d.name, 90, 250);
    ctx.fillStyle = 'rgba(255,255,255,0.92)'; ctx.font = `500 30px ${font}`;
    ctx.fillText([d.title, d.company].filter(Boolean).join('  ·  '), 90, 296);
    contactsColumn(ctx, contactList(d), 90, 400, t.sub, t.ink, font);
  }

  // ---- Back renderer (branded, shared with per-template palette) ----
  function drawBack(ctx: CanvasRenderingContext2D, tpl: Template, accent: string, font: string) {
    const W = 1050, H = 600, d = data();
    ctx.clearRect(0, 0, W, H);
    const dark = tpl.id === 'dark-modern' || tpl.id === 'gradient';

    // Background: uploaded back image wins; otherwise accent-filled for light
    // templates, dark surface for dark ones.
    if (bgImgBack) {
      drawCover(ctx, bgImgBack, 0, 0, W, H);
    } else if (dark) {
      if (tpl.id === 'gradient') {
        const g = ctx.createLinearGradient(0, 0, W, H);
        g.addColorStop(0, '#0b1220'); g.addColorStop(1, accent);
        ctx.fillStyle = g;
      } else { ctx.fillStyle = tpl.bg; }
      ctx.fillRect(0, 0, W, H);
    } else {
      ctx.fillStyle = accent; ctx.fillRect(0, 0, W, H);
    }

    // Over an uploaded image, force white text with a soft shadow for legibility.
    const fg = bgImgBack ? '#ffffff' : (dark ? tpl.ink : tpl.onAccent);
    if (bgImgBack) { ctx.shadowColor = 'rgba(0,0,0,0.55)'; ctx.shadowBlur = 8; }
    const cx = qrImg ? 380 : 525;

    // Brand: logo (draggable when a back background is set) or company + initials.
    ctx.textAlign = 'center';
    if (logoImg) {
      // Until dragged, keep the logo centered on the same axis as the heading/QR
      // layout (cx), so it never floats off-center when the QR toggles.
      if (!logoBackTouched) logoRectBack.x = cx - logoRectBack.w / 2;
      // Logo is draggable on the back (positioned via logoRectBack). Suppress
      // the legibility shadow so the logo art itself stays crisp.
      ctx.save(); ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
      drawContain(ctx, logoImg, logoRectBack.x, logoRectBack.y, logoRectBack.w, logoRectBack.h);
      ctx.restore();
      // Without a back background, keep the company heading beneath the logo.
      // Same size as the no-logo case so it never shifts when a logo is added.
      if (!bgImgBack) {
        ctx.fillStyle = fg; ctx.font = `700 72px ${font}`;
        ctx.fillText(d.company || d.name, cx, 250);
      }
    } else {
      ctx.fillStyle = fg; ctx.font = `700 72px ${font}`;
      ctx.fillText(d.company || d.name, cx, 250);
    }
    if (d.tagline) {
      ctx.fillStyle = fg; ctx.globalAlpha = 0.85;
      ctx.font = `400 26px ${font}`;
      ctx.fillText(d.tagline, cx, 320);
      ctx.globalAlpha = 1;
    }
    if (d.web) {
      ctx.fillStyle = fg; ctx.globalAlpha = 0.9;
      ctx.font = `500 24px ${font}`;
      ctx.fillText(d.web, cx, 400);
      ctx.globalAlpha = 1;
    }

    // QR panel on the right.
    if (qrImg) {
      const s = 260, qx = 690, qy = (H - s) / 2;
      ctx.save();
      ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
      ctx.fillStyle = '#ffffff';
      const pad = 16;
      ctx.fillRect(qx - pad, qy - pad, s + pad * 2, s + pad * 2);
      ctx.drawImage(qrImg, qx, qy, s, s);
      ctx.restore();
      ctx.fillStyle = fg; ctx.globalAlpha = 0.8;
      ctx.textAlign = 'center'; ctx.font = `400 20px ${font}`;
      ctx.fillText('Scan to save contact', qx + s / 2, qy + s + 48);
      ctx.globalAlpha = 1;
    }

    // Clear any legibility shadow so it never leaks past this renderer.
    ctx.shadowColor = 'transparent'; ctx.shadowBlur = 0;
  }

  // ---- vCard QR ----
  function vCard(d: CardData): string {
    return [
      'BEGIN:VCARD', 'VERSION:3.0',
      `FN:${d.name}`,
      d.company ? `ORG:${d.company}` : '',
      d.title ? `TITLE:${d.title}` : '',
      d.phone ? `TEL:${d.phone}` : '',
      d.email ? `EMAIL:${d.email}` : '',
      d.web ? `URL:${d.web}` : '',
      d.address ? `ADR:;;${d.address};;;` : '',
      'END:VCARD',
    ].filter(Boolean).join('\n');
  }

  async function ensureQR(): Promise<void> {
    const enabled = ($('bc-qr') as HTMLInputElement).checked;
    if (!enabled) { qrImg = null; qrKey = ''; return; }
    const payload = vCard(data());
    if (payload === qrKey && qrImg) return;
    const QRCode = (await import('qrcode')).default;
    const url = await QRCode.toDataURL(payload, { margin: 0, width: 520, color: { dark: '#000000', light: '#ffffff' } });
    await new Promise<void>((res) => {
      const img = new Image();
      img.onload = () => { qrImg = img; qrKey = payload; res(); };
      img.src = url;
    });
  }

  // ---- Rendering orchestration ----
  function renderMain() {
    const ctx = canvas.getContext('2d')!;
    const tpl = TEMPLATES[currentTpl];
    const accent = activeAccent(tpl);
    const font = activeFont(tpl);
    if (side === 'front') drawFront(ctx, tpl, accent, font);
    else drawBack(ctx, tpl, accent, font);
    drawHandles(ctx);
  }

  function renderThumbs() {
    document.querySelectorAll<HTMLCanvasElement>('canvas[data-thumb]').forEach((c) => {
      const id = c.dataset.thumb as Layout;
      const tpl = TEMPLATES[id];
      const ctx = c.getContext('2d')!;
      const accent = accentTouched ? val('bc-accent') : tpl.accent;
      const font = activeFont(tpl);
      ctx.save();
      ctx.scale(350 / 1050, 200 / 600);
      drawFront(ctx, tpl, accent, font);
      ctx.restore();
    });
  }

  async function renderAll() {
    await ensureQR();
    renderThumbs();
    renderMain();
  }

  // ---- Wiring ----
  const tplButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.bc-tpl'));
  function highlightTpl() {
    tplButtons.forEach((b) => {
      const on = b.dataset.tpl === currentTpl;
      b.classList.toggle('border-primary', on);
      b.classList.toggle('bg-surface-2', on);
    });
  }
  tplButtons.forEach((b) => b.addEventListener('click', () => {
    currentTpl = b.dataset.tpl as Layout;
    highlightTpl();
    renderMain();
  }));

  function setSide(s: 'front' | 'back') {
    side = s;
    const f = $('bc-side-front'), bk = $('bc-side-back');
    f.classList.toggle('bg-surface-2', s === 'front');
    f.classList.toggle('text-ink', s === 'front');
    f.classList.toggle('text-ink-subtle', s !== 'front');
    bk.classList.toggle('bg-surface-2', s === 'back');
    bk.classList.toggle('text-ink', s === 'back');
    bk.classList.toggle('text-ink-subtle', s !== 'back');
    syncBgControls();
    renderMain();
  }
  $('bc-side-front').addEventListener('click', () => setSide('front'));
  $('bc-side-back').addEventListener('click', () => setSide('back'));

  // Text + option inputs.
  ['bc-name', 'bc-title', 'bc-company', 'bc-tagline', 'bc-phone', 'bc-email', 'bc-web', 'bc-address']
    .forEach((id) => $(id).addEventListener('input', () => { renderAll(); }));
  $('bc-accent').addEventListener('input', () => { accentTouched = true; renderAll(); });
  $('bc-font').addEventListener('change', () => renderAll());
  $('bc-qr').addEventListener('change', () => renderAll());
  $('bc-opacity').addEventListener('input', (e) => {
    const v = Number((e.target as HTMLInputElement).value);
    panelOpacity = v / 100;
    $('bc-opacity-val').textContent = `${v}%`;
    renderMain();
  });

  // ---- Drag / resize interaction (background-image mode, front side only) ----
  const HANDLE = 40; // hit radius for the resize corner, in canvas coords
  type DragTarget = 'panel' | 'logo';
  type DragMode = 'move' | 'resize';
  let drag: { target: DragTarget; mode: DragMode; dx: number; dy: number } | null = null;

  function rectOf(t: DragTarget): Rect {
    if (t === 'panel') return panelRect;
    return side === 'front' ? logoRect : logoRectBack;
  }

  // Map a pointer event to 1050×600 canvas coordinates.
  function toCanvasCoords(e: PointerEvent): { x: number; y: number } {
    const r = canvas.getBoundingClientRect();
    return { x: (e.clientX - r.left) * (1050 / r.width), y: (e.clientY - r.top) * (600 / r.height) };
  }

  function nearCorner(p: { x: number; y: number }, rc: Rect): boolean {
    return Math.abs(p.x - (rc.x + rc.w)) <= HANDLE && Math.abs(p.y - (rc.y + rc.h)) <= HANDLE;
  }
  function inside(p: { x: number; y: number }, rc: Rect): boolean {
    return p.x >= rc.x && p.x <= rc.x + rc.w && p.y >= rc.y && p.y <= rc.y + rc.h;
  }

  // Which target (if any) is under the pointer, honoring z-order (logo above panel).
  // Front has a movable panel + logo; back (over an uploaded image) has just the logo.
  function hitTest(p: { x: number; y: number }): { target: DragTarget; mode: DragMode } | null {
    if (side === 'front') {
      if (logoImg) {
        if (nearCorner(p, logoRect)) return { target: 'logo', mode: 'resize' };
        if (inside(p, logoRect)) return { target: 'logo', mode: 'move' };
      }
      if (nearCorner(p, panelRect)) return { target: 'panel', mode: 'resize' };
      if (inside(p, panelRect)) return { target: 'panel', mode: 'move' };
    } else if (logoImg) {
      if (nearCorner(p, logoRectBack)) return { target: 'logo', mode: 'resize' };
      if (inside(p, logoRectBack)) return { target: 'logo', mode: 'move' };
    }
    return null;
  }

  // Front is editable once a front background is set; back is editable whenever
  // there's a logo to drag or a back background whose panel-free layout applies.
  function bgEditable(): boolean {
    return side === 'front' ? !!bgImg : (!!logoImg || !!bgImgBack);
  }

  function cursorFor(mode: DragMode | null): string {
    if (mode === 'resize') return 'nwse-resize';
    if (mode === 'move') return 'move';
    return 'default';
  }

  canvas.addEventListener('pointermove', (e) => {
    if (!bgEditable()) { canvas.style.cursor = 'default'; return; }
    const p = toCanvasCoords(e);
    if (drag) {
      const rc = rectOf(drag.target);
      if (drag.mode === 'move') {
        rc.x = p.x - drag.dx;
        rc.y = p.y - drag.dy;
        rc.x = Math.max(0, Math.min(rc.x, 1050 - rc.w));
        rc.y = Math.max(0, Math.min(rc.y, 600 - rc.h));
      } else {
        rc.w = Math.max(60, Math.min(p.x - rc.x, 1050 - rc.x));
        rc.h = Math.max(40, Math.min(p.y - rc.y, 600 - rc.y));
      }
      renderMain();
      return;
    }
    canvas.style.cursor = cursorFor(hitTest(p)?.mode ?? null);
  });

  canvas.addEventListener('pointerdown', (e) => {
    if (!bgEditable()) return;
    const p = toCanvasCoords(e);
    const hit = hitTest(p);
    if (!hit) return;
    const rc = rectOf(hit.target);
    // Once the user grabs the back logo, stop auto-centering it on cx.
    if (side === 'back' && hit.target === 'logo') logoBackTouched = true;
    drag = { target: hit.target, mode: hit.mode, dx: p.x - rc.x, dy: p.y - rc.y };
    canvas.setPointerCapture(e.pointerId);
    canvas.style.cursor = cursorFor(hit.mode);
  });

  const endDrag = () => { drag = null; };
  canvas.addEventListener('pointerup', endDrag);
  canvas.addEventListener('pointercancel', endDrag);

  // Draw drag handles as an on-screen-only overlay (not baked into downloads).
  function drawHandles(ctx: CanvasRenderingContext2D) {
    if (!bgEditable()) return;
    const targets: Rect[] = side === 'front'
      ? (logoImg ? [panelRect, logoRect] : [panelRect])
      : (logoImg ? [logoRectBack] : []);
    ctx.save();
    for (const rc of targets) {
      ctx.strokeStyle = 'rgba(94,106,210,0.9)';
      ctx.lineWidth = 2;
      ctx.setLineDash([8, 6]);
      ctx.strokeRect(rc.x, rc.y, rc.w, rc.h);
      ctx.setLineDash([]);
      // Corner resize grip.
      ctx.fillStyle = '#5e6ad2';
      const g = 18;
      ctx.fillRect(rc.x + rc.w - g, rc.y + rc.h - g, g, g);
    }
    ctx.restore();
  }

  // Uploads.
  function readImage(file: File, onload: (img: HTMLImageElement) => void) {
    const reader = new FileReader();
    reader.onload = () => { const img = new Image(); img.onload = () => onload(img); img.src = reader.result as string; };
    reader.readAsDataURL(file);
  }
  $('bc-logo').addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    readImage(file, (img) => { logoImg = img; logoBackTouched = false; $('bc-logo-clear').classList.remove('hidden'); renderAll(); });
  });
  $('bc-logo-clear').addEventListener('click', () => {
    logoImg = null; logoBackTouched = false; ($('bc-logo') as HTMLInputElement).value = '';
    $('bc-logo-clear').classList.add('hidden'); renderAll();
  });
  // One background control that targets whichever side is currently shown.
  function syncBgControls() {
    const has = side === 'front' ? !!bgImg : !!bgImgBack;
    $('bc-bgimg-label').textContent = `Upload ${side} background`;
    $('bc-bgimg-clear').classList.toggle('hidden', !has);
  }
  $('bc-bgimg').addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    readImage(file, (img) => {
      if (side === 'front') bgImg = img; else bgImgBack = img;
      ($('bc-bgimg') as HTMLInputElement).value = '';
      syncBgControls(); renderAll();
    });
  });
  $('bc-bgimg-clear').addEventListener('click', () => {
    if (side === 'front') bgImg = null; else bgImgBack = null;
    syncBgControls(); renderAll();
  });

  // ---- Downloads ----
  // Render a side onto an offscreen full-res canvas.
  function renderTo(side: 'front' | 'back'): HTMLCanvasElement {
    const off = document.createElement('canvas');
    off.width = 1050; off.height = 600;
    const ctx = off.getContext('2d')!;
    const tpl = TEMPLATES[currentTpl];
    const accent = activeAccent(tpl);
    const font = activeFont(tpl);
    if (side === 'front') drawFront(ctx, tpl, accent, font);
    else drawBack(ctx, tpl, accent, font);
    return off;
  }

  function downloadPNG(which: 'front' | 'back') {
    const off = renderTo(which);
    const a = document.createElement('a');
    a.href = off.toDataURL('image/png');
    a.download = `business-card-${which}.png`;
    a.click();
  }

  $('bc-dl-front').addEventListener('click', async () => { await ensureQR(); downloadPNG('front'); });
  $('bc-dl-back').addEventListener('click', async () => { await ensureQR(); downloadPNG('back'); });

  $('bc-dl-pdf').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true; const label = btn.textContent; btn.textContent = 'Generating…';
    try {
      await ensureQR();
      const { PDFDocument } = await import('pdf-lib');
      const pdf = await PDFDocument.create();
      // 3.5 × 2 in at 72pt/in.
      const wPt = 3.5 * 72, hPt = 2 * 72;
      for (const which of ['front', 'back'] as const) {
        const off = renderTo(which);
        const bytes = await new Promise<Uint8Array>((res) =>
          off.toBlob(async (b) => res(new Uint8Array(await b!.arrayBuffer())), 'image/png'));
        const png = await pdf.embedPng(bytes);
        const page = pdf.addPage([wPt, hPt]);
        page.drawImage(png, { x: 0, y: 0, width: wPt, height: hPt });
      }
      const out = await pdf.save();
      const url = URL.createObjectURL(new Blob([out.slice()], { type: 'application/pdf' }));
      const a = document.createElement('a'); a.href = url; a.download = 'business-card.pdf'; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } finally { btn.disabled = false; btn.textContent = label; }
  });

  // ---- Init ----
  highlightTpl();
  setSide('front');
  renderAll();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="wallpaper-estimator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Total wall width / perimeter (m)
        <input id="we-width" type="number" min="0" step="any" class="field" value="14" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Wall height (m)
        <input id="we-height" type="number" min="0" step="any" class="field" value="2.4" inputmode="decimal" />
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Roll width (cm)
        <input id="we-roll-width" type="number" min="0" step="any" class="field" value="53" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Roll length (m)
        <input id="we-roll-length" type="number" min="0" step="any" class="field" value="10" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Pattern repeat (cm)
        <input id="we-repeat" type="number" min="0" step="any" class="field" value="0" inputmode="decimal" />
      </label>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Waste allowance (%)
      <input id="we-waste" type="number" min="0" step="1" class="field w-auto" value="10" inputmode="decimal" />
    </label>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel p-4"><div id="we-strip-len" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Strip length</div></div>
      <div class="panel p-4"><div id="we-strips-roll" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Strips per roll</div></div>
      <div class="panel p-4"><div id="we-strips-needed" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Strips needed</div></div>
      <div class="panel panel-lift p-4"><div id="we-rolls" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Rolls needed</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free wallpaper estimator tells you how many rolls to buy for a room.
      Enter the total width (or perimeter) of the walls and their height, then
      the roll's width and length. Each strip must be at least as long as the
      wall height plus the pattern repeat, so patterned papers use more. The
      estimator counts how many full strips you can cut from a roll, how many
      strips the walls need, and rounds up to whole rolls after adding a waste
      allowance. Everything is calculated in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const wallWidth = document.getElementById('we-width') as HTMLInputElement;
  const wallHeight = document.getElementById('we-height') as HTMLInputElement;
  const rollWidth = document.getElementById('we-roll-width') as HTMLInputElement;
  const rollLength = document.getElementById('we-roll-length') as HTMLInputElement;
  const repeat = document.getElementById('we-repeat') as HTMLInputElement;
  const waste = document.getElementById('we-waste') as HTMLInputElement;

  function calc() {
    const wWidth = Number(wallWidth.value) || 0;      // m
    const wHeight = Number(wallHeight.value) || 0;    // m
    const rWidth = (Number(rollWidth.value) || 0) / 100;   // cm -> m
    const rLength = Number(rollLength.value) || 0;    // m
    const rep = (Number(repeat.value) || 0) / 100;    // cm -> m
    const wastePct = Math.max(0, Number(waste.value) || 0);

    // Each strip needs the wall height, rounded up to the next pattern repeat.
    const stripLen = rep > 0 ? Math.ceil(wHeight / rep) * rep : wHeight;

    const stripsPerRoll = stripLen > 0 ? Math.floor(rLength / stripLen) : 0;
    const stripsNeededRaw = rWidth > 0 ? Math.ceil(wWidth / rWidth) : 0;
    const stripsNeeded = Math.ceil(stripsNeededRaw * (1 + wastePct / 100));
    const rolls = stripsPerRoll > 0 ? Math.ceil(stripsNeeded / stripsPerRoll) : 0;

    document.getElementById('we-strip-len')!.textContent =
      `${stripLen.toLocaleString(undefined, { maximumFractionDigits: 2 })} m`;
    document.getElementById('we-strips-roll')!.textContent = String(stripsPerRoll);
    document.getElementById('we-strips-needed')!.textContent = String(stripsNeeded);
    document.getElementById('we-rolls')!.textContent = String(rolls);
  }

  [wallWidth, wallHeight, rollWidth, rollLength, repeat, waste].forEach((el) =>
    el.addEventListener('input', calc));
  calc();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="fraction-calculator">
  <div class="flex flex-col gap-5">
    <div class="flex flex-wrap items-end gap-3">
      <div class="flex items-end gap-2">
        <input id="fr-w1" type="number" class="field w-16 text-center font-mono" value="0" inputmode="numeric" aria-label="First whole number" />
        <div class="flex flex-col gap-1">
          <input id="fr-n1" type="number" class="field w-20 text-center font-mono" value="1" inputmode="numeric" aria-label="First numerator" />
          <div class="h-px bg-hairline-strong"></div>
          <input id="fr-d1" type="number" class="field w-20 text-center font-mono" value="2" inputmode="numeric" aria-label="First denominator" />
        </div>
      </div>
      <select id="fr-op" class="field w-20 text-center font-mono text-lg" aria-label="Operation">
        <option value="+">+</option>
        <option value="-">−</option>
        <option value="*">×</option>
        <option value="/">÷</option>
      </select>
      <div class="flex items-end gap-2">
        <input id="fr-w2" type="number" class="field w-16 text-center font-mono" value="0" inputmode="numeric" aria-label="Second whole number" />
        <div class="flex flex-col gap-1">
          <input id="fr-n2" type="number" class="field w-20 text-center font-mono" value="1" inputmode="numeric" aria-label="Second numerator" />
          <div class="h-px bg-hairline-strong"></div>
          <input id="fr-d2" type="number" class="field w-20 text-center font-mono" value="3" inputmode="numeric" aria-label="Second denominator" />
        </div>
      </div>
      <span class="pb-2 font-mono text-lg text-ink-subtle">=</span>
      <div id="fr-result" class="pb-1 font-display text-3xl font-semibold text-primary-hover">—</div>
    </div>
    <p class="text-[12px] text-ink-tertiary">Whole-number boxes are optional — leave them 0 for a plain fraction.</p>
    <p id="fr-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="flex flex-wrap items-center gap-2">
      <span class="text-[13px] text-ink-subtle">Show answer as</span>
      <button type="button" data-form="mixed" class="fr-form btn btn-primary !min-h-0 !px-3 !py-1 text-xs" aria-selected="true">Mixed number</button>
      <button type="button" data-form="improper" class="fr-form btn btn-secondary !min-h-0 !px-3 !py-1 text-xs" aria-selected="false">Improper</button>
    </div>
    <p id="fr-decimal" class="text-[13px] text-ink-subtle"></p>

    <div class="panel p-5">
      <div class="mb-2 text-sm text-ink-muted">Steps</div>
      <ol id="fr-steps" class="flex flex-col gap-1 font-mono text-[13px] text-ink-subtle"></ol>
    </div>

    <div class="panel p-5">
      <div class="mb-3 text-sm text-ink-muted">Convert a decimal to a fraction</div>
      <div class="flex flex-wrap items-center gap-2 text-sm text-ink-subtle">
        <input id="fr-dec-in" type="number" step="any" class="field w-32 font-mono" value="0.75" inputmode="decimal" aria-label="Decimal to convert" />
        <span>=</span>
        <span id="fr-dec-out" class="font-mono text-ink">—</span>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free fraction calculator adds, subtracts, multiplies and divides
      fractions and mixed numbers, showing the answer reduced to lowest terms as
      both a mixed number and an improper fraction, plus the decimal value and the
      steps used to get there. It also converts a decimal to a fraction. A handy
      helper for homework and cooking measurements. All calculations run in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const gcd = (a: number, b: number): number => (b === 0 ? Math.abs(a) : gcd(b, a % b));
  let form: 'mixed' | 'improper' = 'mixed';

  function format(num: number, den: number): string {
    if (den === 1) return String(num);
    if (form === 'improper' || Math.abs(num) < den) return `${num}/${den}`;
    const sign = num < 0 ? '-' : '';
    const a = Math.abs(num);
    const whole = Math.floor(a / den);
    const rem = a % den;
    return rem === 0 ? `${sign}${whole}` : `${sign}${whole} ${rem}/${den}`;
  }

  // Combine whole + fraction into a single improper fraction (sign on numerator).
  function toImproper(w: number, n: number, d: number): number {
    // whole and fraction share a sign; treat a negative whole as negating the fraction too
    const mag = Math.abs(w) * d + Math.abs(n);
    const neg = w < 0 || (w === 0 && n < 0);
    return neg ? -mag : mag;
  }

  function calc() {
    const err = document.getElementById('fr-error')!;
    err.classList.add('hidden');
    const w1 = Math.trunc(Number($('fr-w1').value));
    const w2 = Math.trunc(Number($('fr-w2').value));
    const rawN1 = Math.trunc(Number($('fr-n1').value));
    const d1 = Math.trunc(Number($('fr-d1').value));
    const rawN2 = Math.trunc(Number($('fr-n2').value));
    const d2 = Math.trunc(Number($('fr-d2').value));
    const op = (document.getElementById('fr-op') as HTMLSelectElement).value;
    const resEl = document.getElementById('fr-result')!;
    const decEl = document.getElementById('fr-decimal')!;
    const stepsEl = document.getElementById('fr-steps')!;

    const fail = (msg: string) => { err.textContent = msg; err.classList.remove('hidden'); resEl.textContent = '—'; decEl.textContent = ''; stepsEl.innerHTML = ''; };
    if (d1 === 0 || d2 === 0) { fail('Denominators cannot be zero.'); return; }

    const n1 = toImproper(w1, rawN1, d1);
    const n2 = toImproper(w2, rawN2, d2);
    const steps: string[] = [];
    if (w1 !== 0 || w2 !== 0) steps.push(`Convert to improper fractions: ${n1}/${d1} and ${n2}/${d2}`);

    let num: number, den: number;
    if (op === '+') { num = n1 * d2 + n2 * d1; den = d1 * d2; steps.push(`Common denominator ${den}: ${n1 * d2}/${den} + ${n2 * d1}/${den}`); }
    else if (op === '-') { num = n1 * d2 - n2 * d1; den = d1 * d2; steps.push(`Common denominator ${den}: ${n1 * d2}/${den} − ${n2 * d1}/${den}`); }
    else if (op === '*') { num = n1 * n2; den = d1 * d2; steps.push(`Multiply across: (${n1}×${n2})/(${d1}×${d2}) = ${num}/${den}`); }
    else {
      if (n2 === 0) { fail('Cannot divide by a zero fraction.'); return; }
      num = n1 * d2; den = d1 * n2; steps.push(`Multiply by the reciprocal: (${n1}×${d2})/(${d1}×${n2}) = ${num}/${den}`);
    }

    if (den < 0) { num = -num; den = -den; }
    const combined = `${num}/${den}`;
    const g = gcd(num, den) || 1;
    num /= g; den /= g;
    if (g > 1) steps.push(`Reduce by GCD ${g}: ${combined} = ${num}/${den}`);

    resEl.textContent = format(num, den);
    // Show both forms in the decimal line for completeness.
    const improper = den === 1 ? String(num) : `${num}/${den}`;
    const mixed = format(num, den);
    const extra = improper !== mixed ? ` = ${form === 'mixed' ? improper : mixed}` : '';
    decEl.textContent = `= ${(num / den).toFixed(6).replace(/\.?0+$/, '')} as a decimal${extra}`;
    stepsEl.innerHTML = steps.map((s) => `<li>${s}</li>`).join('');
  }

  // Decimal → fraction via denominator = 10^(decimal places), then reduce.
  function decToFrac() {
    const out = document.getElementById('fr-dec-out')!;
    const raw = $('fr-dec-in').value.trim();
    const v = Number(raw);
    if (!raw || !isFinite(v)) { out.textContent = '—'; return; }
    const decimals = (raw.split('.')[1] || '').length;
    let den = Math.pow(10, decimals);
    let num = Math.round(v * den);
    const g = gcd(num, den) || 1;
    num /= g; den /= g;
    out.textContent = den === 1 ? String(num) : `${format(num, den)}  (${num}/${den})`;
  }

  document.querySelectorAll('#fr-w1, #fr-n1, #fr-d1, #fr-w2, #fr-n2, #fr-d2, #fr-op').forEach((el) => el.addEventListener('input', calc));
  $('fr-dec-in').addEventListener('input', decToFrac);
  document.querySelectorAll<HTMLButtonElement>('.fr-form').forEach((btn) => {
    btn.addEventListener('click', () => {
      form = btn.dataset.form as 'mixed' | 'improper';
      document.querySelectorAll('.fr-form').forEach((b) => {
        const active = b === btn;
        b.setAttribute('aria-selected', String(active));
        b.classList.toggle('btn-primary', active);
        b.classList.toggle('btn-secondary', !active);
      });
      calc();
      decToFrac();
    });
  });
  calc();
  decToFrac();
</script>

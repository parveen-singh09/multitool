---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="fraction-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <div class="flex flex-col gap-1">
        <input id="fr-n1" type="number" class="field w-24 text-center font-mono" value="1" inputmode="numeric" aria-label="First numerator" />
        <div class="h-px bg-hairline-strong"></div>
        <input id="fr-d1" type="number" class="field w-24 text-center font-mono" value="2" inputmode="numeric" aria-label="First denominator" />
      </div>
      <select id="fr-op" class="field w-20 font-mono text-center text-lg" aria-label="Operation">
        <option value="+">+</option>
        <option value="-">−</option>
        <option value="*">×</option>
        <option value="/">÷</option>
      </select>
      <div class="flex flex-col gap-1">
        <input id="fr-n2" type="number" class="field w-24 text-center font-mono" value="1" inputmode="numeric" aria-label="Second numerator" />
        <div class="h-px bg-hairline-strong"></div>
        <input id="fr-d2" type="number" class="field w-24 text-center font-mono" value="3" inputmode="numeric" aria-label="Second denominator" />
      </div>
      <span class="pb-2 font-mono text-lg text-ink-subtle">=</span>
      <div id="fr-result" class="pb-1 font-display text-3xl font-semibold text-primary-hover">—</div>
    </div>
    <p id="fr-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
    <p id="fr-decimal" class="text-[13px] text-ink-subtle"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free fraction calculator adds, subtracts, multiplies and divides two
      fractions and shows the answer reduced to its lowest terms, along with the
      decimal value. It is a handy helper for homework and cooking measurements.
      All calculations run in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const gcd = (a: number, b: number): number => (b === 0 ? Math.abs(a) : gcd(b, a % b));

  function calc() {
    const err = document.getElementById('fr-error')!;
    err.classList.add('hidden');
    const n1 = Math.trunc(Number($('fr-n1').value));
    const d1 = Math.trunc(Number($('fr-d1').value));
    const n2 = Math.trunc(Number($('fr-n2').value));
    const d2 = Math.trunc(Number($('fr-d2').value));
    const op = (document.getElementById('fr-op') as HTMLSelectElement).value;
    const resEl = document.getElementById('fr-result')!;
    const decEl = document.getElementById('fr-decimal')!;

    if (d1 === 0 || d2 === 0) { err.textContent = 'Denominators cannot be zero.'; err.classList.remove('hidden'); resEl.textContent = '—'; decEl.textContent = ''; return; }

    let num: number, den: number;
    if (op === '+') { num = n1 * d2 + n2 * d1; den = d1 * d2; }
    else if (op === '-') { num = n1 * d2 - n2 * d1; den = d1 * d2; }
    else if (op === '*') { num = n1 * n2; den = d1 * d2; }
    else {
      if (n2 === 0) { err.textContent = 'Cannot divide by a zero fraction.'; err.classList.remove('hidden'); resEl.textContent = '—'; decEl.textContent = ''; return; }
      num = n1 * d2; den = d1 * n2;
    }

    if (den < 0) { num = -num; den = -den; }
    const g = gcd(num, den) || 1;
    num /= g; den /= g;
    resEl.textContent = den === 1 ? String(num) : `${num}/${den}`;
    decEl.textContent = `= ${(num / den).toFixed(6).replace(/\.?0+$/, '')} as a decimal`;
  }

  document.querySelectorAll('#fr-n1, #fr-d1, #fr-n2, #fr-d2, #fr-op').forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

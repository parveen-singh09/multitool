---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="barcode-generator">
  <div class="grid gap-6 lg:grid-cols-[1fr_320px]">

    <div class="flex flex-col gap-4">
      <div id="bg-stage" class="flex min-h-55 items-center justify-center rounded-md border border-hairline bg-white p-6">
        <canvas id="bg-canvas" class="max-w-full"></canvas>
      </div>
      <p id="bg-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
      <div class="flex flex-wrap gap-2">
        <button id="bg-png" type="button" class="btn btn-primary">Download PNG</button>
        <button id="bg-svg" type="button" class="btn btn-secondary">Download SVG</button>
        <button id="bg-copy" type="button" class="btn btn-tertiary">Copy PNG</button>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Barcode type
        <select id="bg-type" class="field"></select>
      </label>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Data to encode
        <div class="copy-wrap">
          <textarea id="bg-text" class="field min-h-20 resize-y font-mono text-[13px]" spellcheck="false" autocomplete="off"></textarea>
          <button type="button" class="copy-icon" data-copy-target="#bg-text" aria-label="Copy"></button>
        </div>
      </label>

      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Scale <span id="bg-scale-v" class="text-ink-tertiary">3</span>
          <input id="bg-scale" type="range" min="1" max="8" value="3" />
        </label>
        <label id="bg-height-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">
          Bar height <span id="bg-height-v" class="text-ink-tertiary">10</span>
          <input id="bg-height" type="range" min="4" max="40" value="10" />
        </label>
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Rotation
        <select id="bg-rotate" class="field">
          <option value="N">None</option>
          <option value="R">90° right</option>
          <option value="L">90° left</option>
          <option value="I">180°</option>
        </select>
      </label>

      <div class="grid grid-cols-3 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Bars
          <input id="bg-bar" type="color" value="#000000" class="h-9 w-full cursor-pointer rounded-md border border-hairline bg-transparent" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Background
          <input id="bg-bg" type="color" value="#ffffff" class="h-9 w-full cursor-pointer rounded-md border border-hairline bg-transparent" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Text
          <input id="bg-textcolor" type="color" value="#000000" class="h-9 w-full cursor-pointer rounded-md border border-hairline bg-transparent" />
        </label>
      </div>

      <label id="bg-label-wrap" class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="bg-label" type="checkbox" class="accent-primary" checked /> Show human-readable text
      </label>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free barcode generator creates over 30 barcode symbologies — Code 128,
      Code 39, EAN/UPC, GS1, QR Code, Data Matrix, PDF417, Aztec, MaxiCode and the
      major postal codes — from any text or numbers. Pick a type, adjust the size,
      colors, rotation and human-readable label, then download a crisp PNG or a
      scalable SVG — no accounts, no watermarks.
    </p>
  </div>
</ToolLayout>

<script>
  import { toCanvas, toSVG, type RenderOpts } from '../../lib/barcode';

  type Sym = { bcid: string; name: string; linear: boolean; example: string };
  const GROUPS: { label: string; items: Sym[] }[] = [
    { label: 'Linear', items: [
      { bcid: 'code128', name: 'Code 128', linear: true, example: 'TOOLSILK-2026' },
      { bcid: 'code39', name: 'Code 39', linear: true, example: 'CODE39' },
      { bcid: 'code93', name: 'Code 93', linear: true, example: 'CODE93' },
      { bcid: 'code11', name: 'Code 11', linear: true, example: '01234567' },
      { bcid: 'rationalizedCodabar', name: 'Codabar', linear: true, example: 'A12345B' },
      { bcid: 'interleaved2of5', name: 'Interleaved 2 of 5', linear: true, example: '12345670' },
      { bcid: 'itf14', name: 'ITF-14', linear: true, example: '00012345678905' },
      { bcid: 'msi', name: 'MSI Plessey', linear: true, example: '1234567' },
      { bcid: 'pharmacode', name: 'Pharmacode', linear: true, example: '117480' },
      { bcid: 'code32', name: 'Code 32 (Italian Pharma)', linear: true, example: '01234567' },
      { bcid: 'telepen', name: 'Telepen', linear: true, example: 'ABC123' },
    ]},
    { label: 'EAN / UPC', items: [
      { bcid: 'ean13', name: 'EAN-13', linear: true, example: '5901234123457' },
      { bcid: 'ean8', name: 'EAN-8', linear: true, example: '96385074' },
      { bcid: 'upca', name: 'UPC-A', linear: true, example: '036000291452' },
      { bcid: 'upce', name: 'UPC-E', linear: true, example: '00123457' },
      { bcid: 'isbn', name: 'ISBN', linear: true, example: '978-1-56581-231-4' },
    ]},
    { label: 'GS1', items: [
      { bcid: 'gs1-128', name: 'GS1-128', linear: true, example: '(01)09521234543213' },
      { bcid: 'gs1datamatrix', name: 'GS1 DataMatrix', linear: false, example: '(01)09521234543213' },
      { bcid: 'gs1qrcode', name: 'GS1 QR Code', linear: false, example: '(01)09521234543213' },
      { bcid: 'databaromni', name: 'GS1 DataBar Omnidirectional', linear: true, example: '0361234567890' },
      { bcid: 'databarexpanded', name: 'GS1 DataBar Expanded', linear: true, example: '(01)93712345678904' },
    ]},
    { label: '2D', items: [
      { bcid: 'qrcode', name: 'QR Code', linear: false, example: 'https://toolsilk.com' },
      { bcid: 'microqrcode', name: 'Micro QR Code', linear: false, example: '12345' },
      { bcid: 'datamatrix', name: 'Data Matrix', linear: false, example: 'TOOLSILK-2026' },
      { bcid: 'pdf417', name: 'PDF417', linear: false, example: 'TOOLSILK-2026' },
      { bcid: 'micropdf417', name: 'MicroPDF417', linear: false, example: 'TOOLSILK' },
      { bcid: 'azteccode', name: 'Aztec Code', linear: false, example: 'TOOLSILK-2026' },
      { bcid: 'maxicode', name: 'MaxiCode', linear: false, example: 'TOOLSILK' },
      { bcid: 'dotcode', name: 'DotCode', linear: false, example: 'TOOLSILK' },
      { bcid: 'hanxin', name: 'Han Xin Code', linear: false, example: 'TOOLSILK' },
    ]},
    { label: 'Postal', items: [
      { bcid: 'onecode', name: 'USPS Intelligent Mail', linear: false, example: '01234567094987654321' },
      { bcid: 'postnet', name: 'POSTNET', linear: false, example: '01234' },
      { bcid: 'planet', name: 'PLANET', linear: false, example: '01234567890' },
      { bcid: 'royalmail', name: 'Royal Mail (RM4SCC)', linear: false, example: 'LE28HS9Z' },
      { bcid: 'kix', name: 'Dutch KIX', linear: false, example: '1231FZ13XHS' },
      { bcid: 'japanpost', name: 'Japan Post', linear: false, example: '1310022' },
      { bcid: 'auspost', name: 'Australia Post', linear: false, example: '5765289012' },
    ]},
  ];
  const ALL: Record<string, Sym> = {};
  for (const g of GROUPS) for (const s of g.items) ALL[s.bcid] = s;

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const typeEl = $<HTMLSelectElement>('bg-type');
  const textEl = $<HTMLTextAreaElement>('bg-text');
  const scaleEl = $<HTMLInputElement>('bg-scale');
  const heightEl = $<HTMLInputElement>('bg-height');
  const heightWrap = $<HTMLElement>('bg-height-wrap');
  const rotateEl = $<HTMLSelectElement>('bg-rotate');
  const barEl = $<HTMLInputElement>('bg-bar');
  const bgEl = $<HTMLInputElement>('bg-bg');
  const textColorEl = $<HTMLInputElement>('bg-textcolor');
  const labelEl = $<HTMLInputElement>('bg-label');
  const labelWrap = $<HTMLElement>('bg-label-wrap');
  const canvas = $<HTMLCanvasElement>('bg-canvas');
  const err = $<HTMLElement>('bg-error');

  for (const g of GROUPS) {
    const og = document.createElement('optgroup');
    og.label = g.label;
    for (const s of g.items) {
      const o = document.createElement('option');
      o.value = s.bcid; o.textContent = s.name;
      og.appendChild(o);
    }
    typeEl.appendChild(og);
  }

  const noHash = (c: string) => c.replace('#', '');
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  function opts(): RenderOpts {
    const sym = ALL[typeEl.value];
    const o: RenderOpts = {
      bcid: sym.bcid,
      text: textEl.value.trim(),
      scale: Number(scaleEl.value),
      rotate: rotateEl.value,
      barcolor: noHash(barEl.value),
      backgroundcolor: noHash(bgEl.value),
      textcolor: noHash(textColorEl.value),
      paddingwidth: 4,
      paddingheight: 4,
    };
    if (sym.linear) {
      o.height = Number(heightEl.value);
      o.includetext = labelEl.checked;
    }
    return o;
  }

  async function draw() {
    const sym = ALL[typeEl.value];
    heightWrap.style.display = sym.linear ? '' : 'none';
    labelWrap.style.display = sym.linear ? '' : 'none';
    if (!textEl.value.trim()) { setErr('Enter some data to encode.'); return; }
    try {
      await toCanvas(canvas, opts());
      setErr('');
    } catch (e) {
      setErr(`Could not encode that data for ${sym.name}. Check the format (see the example when you switch types).`);
    }
  }

  function download(href: string, name: string) {
    const a = document.createElement('a'); a.href = href; a.download = name; a.click();
  }

  // Live redraw (debounced for text).
  let t: number;
  textEl.addEventListener('input', () => { clearTimeout(t); t = window.setTimeout(draw, 180); });
  [scaleEl, heightEl].forEach((el) => el.addEventListener('input', () => {
    $('bg-scale-v').textContent = scaleEl.value;
    $('bg-height-v').textContent = heightEl.value;
    draw();
  }));
  [rotateEl, barEl, bgEl, textColorEl, labelEl].forEach((el) => el.addEventListener('input', draw));
  typeEl.addEventListener('change', () => { textEl.value = ALL[typeEl.value].example; draw(); });

  $('bg-png').addEventListener('click', () => download(canvas.toDataURL('image/png'), `${typeEl.value}.png`));
  $('bg-svg').addEventListener('click', async () => {
    try {
      const url = URL.createObjectURL(new Blob([await toSVG(opts())], { type: 'image/svg+xml' }));
      download(url, `${typeEl.value}.svg`);
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch { setErr('Could not export SVG for that data.'); }
  });
  $('bg-copy').addEventListener('click', () => {
    canvas.toBlob(async (blob) => {
      if (!blob || !navigator.clipboard?.write) return;
      try { await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]); } catch {}
    });
  });

  // Init: Code 128 with its example.
  typeEl.value = 'code128';
  textEl.value = ALL['code128'].example;
  draw();
</script>

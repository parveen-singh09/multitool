---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="barcode-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Data
      <input id="bg-text" class="field font-mono" placeholder="123456789" spellcheck="false" autocomplete="off" />
    </label>

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Bar height
        <input id="bg-height" type="range" min="40" max="180" value="100" class="w-40" />
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="bg-label" type="checkbox" class="accent-[#5e6ad2]" checked /> Show text
      </label>
    </div>

    <div class="flex justify-center rounded-[8px] border border-hairline bg-white p-6">
      <canvas id="bg-canvas" class="max-w-full"></canvas>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="bg-png" type="button" class="btn btn-primary">Download PNG</button>
      <button id="bg-svg" type="button" class="btn btn-secondary">Download SVG</button>
    </div>
    <p id="bg-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free barcode generator creates Code 128 barcodes from any text or
      numbers — the format widely used for shipping labels, inventory and
      product tracking. Adjust the bar height, toggle the human-readable label,
      and download the result as a crisp PNG or scalable SVG. The barcode is
      drawn entirely in your browser, so your data never leaves your device.
    </p>
  </div>
</ToolLayout>

<script>
  // Code 128 (auto A/B/C is complex; we use Code 128B for full ASCII 32–126,
  // switching to 128C for long digit runs would add complexity — 128B covers
  // the common cases cleanly).
  const PATTERNS = [
    '11011001100','11001101100','11001100110','10010011000','10010001100','10001001100','10011001000','10011000100','10001100100','11001001000',
    '11001000100','11000100100','10110011100','10011011100','10011001110','10111001100','10011101100','10011100110','11001110010','11001011100',
    '11001001110','11011100100','11001110100','11101101110','11101001100','11100101100','11100100110','11101100100','11100110100','11100110010',
    '11011011000','11011000110','11000110110','10100011000','10001011000','10001000110','10110001000','10001101000','10001100010','11010001000',
    '11000101000','11000100010','10110111000','10110001110','10001101110','10111011000','10111000110','10001110110','11101110110','11010001110',
    '11000101110','11011101000','11011100010','11011101110','11101011000','11101000110','11100010110','11101101000','11101100010','11100011010',
    '11101111010','11001000010','11110001010','10100110000','10100001100','10010110000','10010000110','10000101100','10000100110','10110010000',
    '10110000100','10011010000','10011000010','10000110100','10000110010','11000010010','11001010000','11110111010','11000010100','10001111010',
    '10100111100','10010111100','10010011110','10111100100','10011110100','10011110010','11110100100','11110010100','11110010010','11011011110',
    '11011110110','11110110110','10101111000','10100011110','10001011110','10111101000','10111100010','11110101000','11110100010','10111011110',
    '10111101110','11101011110','11110101110','11010000100','11010010000','11010011100','11000111010',
  ];
  const STOP = '1100011101011';

  const textEl = document.getElementById('bg-text') as HTMLInputElement;
  const heightEl = document.getElementById('bg-height') as HTMLInputElement;
  const labelEl = document.getElementById('bg-label') as HTMLInputElement;
  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
  const err = document.getElementById('bg-error')!;

  function encode128B(data: string): string | null {
    const codes: number[] = [104]; // Start B
    for (const ch of data) {
      const v = ch.charCodeAt(0);
      if (v < 32 || v > 126) return null;
      codes.push(v - 32);
    }
    let sum = 104;
    for (let i = 1; i < codes.length; i++) sum += codes[i] * i;
    codes.push(sum % 103); // checksum
    codes.push(106); // stop marker index -> use STOP
    let bits = '';
    for (let i = 0; i < codes.length - 1; i++) bits += PATTERNS[codes[i]];
    bits += STOP;
    return bits;
  }

  function draw() {
    err.classList.add('hidden');
    const data = textEl.value || '123456789';
    const bits = encode128B(data);
    if (!bits) { err.textContent = 'Code 128 supports standard ASCII characters (32–126) only.'; err.classList.remove('hidden'); return; }
    const barW = 2;
    const h = Number(heightEl.value);
    const quiet = 10 * barW;
    const showLabel = labelEl.checked;
    const labelH = showLabel ? 22 : 0;
    const w = bits.length * barW + quiet * 2;
    canvas.width = w;
    canvas.height = h + labelH + 10;
    const ctx = canvas.getContext('2d')!;
    ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#000';
    for (let i = 0; i < bits.length; i++) {
      if (bits[i] === '1') ctx.fillRect(quiet + i * barW, 5, barW, h);
    }
    if (showLabel) {
      ctx.fillStyle = '#000';
      ctx.font = '16px monospace';
      ctx.textAlign = 'center';
      ctx.fillText(data, canvas.width / 2, h + labelH);
    }
    canvas.dataset.bits = bits;
    canvas.dataset.barw = String(barW);
    canvas.dataset.h = String(h);
    canvas.dataset.quiet = String(quiet);
  }

  function svgString(): string {
    const bits = canvas.dataset.bits || '';
    const barW = Number(canvas.dataset.barw), h = Number(canvas.dataset.h), quiet = Number(canvas.dataset.quiet);
    const showLabel = labelEl.checked;
    const labelH = showLabel ? 22 : 0;
    const w = bits.length * barW + quiet * 2;
    let rects = '';
    for (let i = 0; i < bits.length; i++) if (bits[i] === '1') rects += `<rect x="${quiet + i * barW}" y="5" width="${barW}" height="${h}"/>`;
    const label = showLabel ? `<text x="${w / 2}" y="${h + labelH}" font-family="monospace" font-size="16" text-anchor="middle">${(textEl.value || '123456789').replace(/[<&>]/g, '')}</text>` : '';
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h + labelH + 10}" viewBox="0 0 ${w} ${h + labelH + 10}"><rect width="100%" height="100%" fill="#fff"/><g fill="#000">${rects}</g>${label}</svg>`;
  }

  function download(href: string, name: string) {
    const a = document.createElement('a'); a.href = href; a.download = name; a.click();
  }

  [textEl, heightEl, labelEl].forEach((el) => el.addEventListener('input', draw));
  document.getElementById('bg-png')!.addEventListener('click', () => download(canvas.toDataURL('image/png'), 'barcode.png'));
  document.getElementById('bg-svg')!.addEventListener('click', () => {
    const blob = new Blob([svgString()], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    download(url, 'barcode.svg');
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });

  textEl.value = '123456789'; draw();
</script>

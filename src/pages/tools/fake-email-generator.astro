---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="fake-email-generator">
  <div class="flex flex-col gap-8">

    <section class="flex flex-col gap-4">
      <div class="panel flex flex-col gap-3 p-4">
        <span class="text-xs uppercase tracking-wide text-ink-subtle">Your temporary address</span>
        <div class="flex flex-wrap items-center gap-3">
          <code id="ti-addr" class="flex-1 min-w-0 truncate rounded-md bg-surface-2 px-3 py-2 font-mono text-[15px] text-ink">…</code>
          <button id="ti-copy" class="btn btn-secondary">Copy</button>
          <button id="ti-qr" class="btn btn-secondary" aria-label="Show QR code" title="Show QR code">QR</button>
          <button id="ti-new" class="btn btn-secondary">New address</button>
        </div>
        <div class="flex items-center gap-3 text-[13px] text-ink-subtle">
          <span id="ti-status" class="flex items-center gap-2"><span id="ti-dot" class="inline-block h-2 w-2 rounded-full bg-primary"></span>Waiting for mail…</span>
          <button id="ti-refresh" class="btn btn-ghost ml-auto text-[13px]">Refresh now</button>
        </div>
        <canvas id="ti-qrc" width="200" height="200" class="mx-auto hidden rounded-md bg-white p-2"></canvas>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-[minmax(0,340px)_minmax(0,1fr)]">
        <ul id="ti-list" class="panel flex max-h-[28rem] min-h-40 flex-col divide-y divide-hairline overflow-y-auto p-0"></ul>
        <div id="ti-view" class="panel min-h-40 overflow-hidden p-0">
          <div class="p-6 text-[15px] text-ink-subtle">Select a message to read it here.</div>
        </div>
      </div>
    </section>

    <section class="flex flex-col gap-3 border-t border-hairline pt-8">
      <div class="flex flex-wrap items-end gap-3">
        <span class="mr-auto text-sm font-medium text-ink">Bulk test addresses</span>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
          <input id="fe-count" type="number" min="1" max="1000" value="10" class="field w-28" />
        </label>
        <button id="fe-gen" class="btn btn-primary">Generate</button>
        <button id="fe-copy" class="btn btn-secondary">Copy all</button>
      </div>
      <textarea id="fe-out" class="field min-h-40 resize-y font-mono text-[13px]" readonly aria-label="Generated emails"></textarea>
    </section>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free temporary email generator gives you a real, disposable inbox that
      actually receives mail — no signup, no password, nothing to remember. Use it
      to confirm signups, grab verification codes and download links, or dodge spam
      on sites you don't fully trust, then throw the address away. Messages appear
      automatically; hit <em>New address</em> any time to start fresh.
    </p>
    <p>
      Everything runs against the public
      <a class="text-primary-hover underline" href="https://mail.tm" rel="nofollow noopener" target="_blank">mail.tm</a>
      service. Need dummy addresses for testing forms or
      seeding a database instead? The bulk generator below produces random
      <code>@example.com</code> addresses that never deliver.
    </p>
  </div>
</ToolLayout>

<script>
  import {
    activeDomains, createAccount, login, listMessages, getMessage, deleteAccount,
    randomLocalPart, randomPassword, type MessageSummary,
  } from '../../lib/tempmail';
  import { firstName, lastName, email } from '../../lib/fakegen';
  import { renderToCanvas, DEFAULT_OPTIONS } from '../../lib/qr';
  import DOMPurify from 'dompurify';

  const $ = (id: string) => document.getElementById(id)!;
  const KEY = 'toolsilk.tempmail.v1';
  const POLL_MS = 8000;

  interface Session { id: string; address: string; token: string; }
  let session: Session | null = null;
  let messages: MessageSummary[] = [];
  let openId: string | null = null;
  let poll: ReturnType<typeof setInterval> | null = null;

  const addrEl = $('ti-addr');
  const statusEl = $('ti-status');
  const dotEl = $('ti-dot');
  const listEl = $('ti-list') as HTMLUListElement;
  const viewEl = $('ti-view');
  const qrCanvas = $('ti-qrc') as HTMLCanvasElement;

  function setStatus(text: string, busy = false) {
    statusEl.lastChild!.textContent = text;
    dotEl.classList.toggle('animate-pulse', busy);
  }

  async function newAddress() {
    stopPoll();
    setStatus('Creating address…', true);
    addrEl.textContent = '…';
    messages = [];
    openId = null;
    renderList();
    renderView();
    qrCanvas.classList.add('hidden');
    try {
      const domains = await activeDomains();
      const domain = domains[0];
      if (!domain) throw new Error('no domain');
      const address = `${randomLocalPart()}@${domain}`;
      const password = randomPassword();
      const acct = await createAccount(address, password);
      const token = await login(address, password);
      session = { id: acct.id, address, token };
      sessionStorage.setItem(KEY, JSON.stringify(session));
      addrEl.textContent = address;
      setStatus('Waiting for mail…');
      startPoll();
      refresh();
    } catch {
      setStatus('Could not reach the mail service — try again.');
    }
  }

  async function refresh() {
    if (!session) return;
    try {
      const next = await listMessages(session.token);
      // Only re-render if the id set changed, so reading isn't interrupted.
      if (next.length !== messages.length || next.some((m, i) => m.id !== messages[i]?.id)) {
        messages = next;
        renderList();
      }
      setStatus(messages.length ? `${messages.length} message${messages.length > 1 ? 's' : ''}` : 'Waiting for mail…');
    } catch {
      setStatus('Connection issue — retrying…');
    }
  }

  function startPoll() {
    stopPoll();
    poll = setInterval(refresh, POLL_MS);
  }
  function stopPoll() {
    if (poll) clearInterval(poll);
    poll = null;
  }

  function renderList() {
    if (!messages.length) {
      listEl.innerHTML = '<li class="p-6 text-[15px] text-ink-subtle">No messages yet. Send mail to the address above and it appears here.</li>';
      return;
    }
    listEl.innerHTML = '';
    for (const m of messages) {
      const li = document.createElement('li');
      li.className = `cursor-pointer p-3 transition-colors hover:bg-surface-2 ${m.id === openId ? 'bg-surface-2' : ''}`;
      const from = document.createElement('div');
      from.className = 'flex items-center gap-2 text-[13px]';
      from.innerHTML = `${m.seen ? '' : '<span class="inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-primary"></span>'}<span class="truncate font-medium text-ink">${escapeHtml(m.from.name || m.from.address)}</span>`;
      const subj = document.createElement('div');
      subj.className = 'truncate text-[14px] text-ink';
      subj.textContent = m.subject || '(no subject)';
      const intro = document.createElement('div');
      intro.className = 'truncate text-[13px] text-ink-subtle';
      intro.textContent = m.intro || '';
      li.append(from, subj, intro);
      li.addEventListener('click', () => openMessage(m.id));
      listEl.append(li);
    }
  }

  async function openMessage(id: string) {
    if (!session) return;
    openId = id;
    renderList();
    viewEl.innerHTML = '<div class="p-6 text-[15px] text-ink-subtle">Loading…</div>';
    try {
      const msg = await getMessage(session.token, id);
      const body = msg.html?.length
        ? DOMPurify.sanitize(msg.html.join(''))
        : `<pre class="whitespace-pre-wrap font-sans text-[15px]">${escapeHtml(msg.text || '')}</pre>`;
      viewEl.innerHTML = `
        <div class="border-b border-hairline p-4">
          <div class="text-[16px] font-medium text-ink">${escapeHtml(msg.subject || '(no subject)')}</div>
          <div class="mt-1 text-[13px] text-ink-subtle">From ${escapeHtml(msg.from.name || '')} &lt;${escapeHtml(msg.from.address)}&gt;</div>
        </div>
        <div class="ti-body max-w-none overflow-x-auto p-4 text-[15px] leading-relaxed text-ink">${body}</div>`;
    } catch {
      viewEl.innerHTML = '<div class="p-6 text-[15px] text-ink-subtle">Could not load this message.</div>';
    }
  }

  function renderView() {
    viewEl.innerHTML = '<div class="p-6 text-[15px] text-ink-subtle">Select a message to read it here.</div>';
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));
  }

  // ---- controls ----
  $('ti-copy').addEventListener('click', async (e) => {
    if (!session) return;
    await navigator.clipboard.writeText(session.address);
    const btn = e.currentTarget as HTMLButtonElement;
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
  $('ti-new').addEventListener('click', async () => {
    if (session) { try { await deleteAccount(session.token, session.id); } catch  }
    sessionStorage.removeItem(KEY);
    session = null;
    newAddress();
  });
  $('ti-refresh').addEventListener('click', refresh);
  $('ti-qr').addEventListener('click', () => {
    if (!session) return;
    const hidden = qrCanvas.classList.toggle('hidden');
    if (!hidden) renderToCanvas(qrCanvas, `mailto:${session.address}`, DEFAULT_OPTIONS, 200);
  });

  // ---- boot: reuse a saved session across reloads, else mint a new one ----
  (async () => {
    const saved = sessionStorage.getItem(KEY);
    if (saved) {
      try {
        session = JSON.parse(saved) as Session;
        addrEl.textContent = session.address;
        // Validate the token still works; listMessages throws on 401.
        await listMessages(session.token);
        setStatus('Waiting for mail…');
        startPoll();
        refresh();
        return;
      } catch {
        sessionStorage.removeItem(KEY);
        session = null;
      }
    }
    newAddress();
  })();

  window.addEventListener('beforeunload', stopPoll);

  // ===== Bulk generator (dummy @example.com, never delivers) =====
  const countEl = $('fe-count') as HTMLInputElement;
  const out = $('fe-out') as HTMLTextAreaElement;
  function generate() {
    const n = Math.max(1, Math.min(1000, Number(countEl.value) || 1));
    const list: string[] = [];
    for (let i = 0; i < n; i++) list.push(email(firstName(), lastName()));
    out.value = list.join('\n');
  }
  countEl.addEventListener('input', generate);
  $('fe-gen').addEventListener('click', generate);
  $('fe-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

<style>

  .ti-body :global(img) { max-width: 100%; height: auto; }
  .ti-body :global(a) { color: var(--color-primary-hover, #7c83e0); text-decoration: underline; }
  .ti-body :global(table) { max-width: 100%; }
</style>

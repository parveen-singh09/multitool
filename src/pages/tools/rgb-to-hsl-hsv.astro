---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ColorFormats from '../../components/ColorFormats.astro';

const rgbChannels = [
  { id: 'r', label: 'R', max: 255, accent: '#ef4444' },
  { id: 'g', label: 'G', max: 255, accent: '#22c55e' },
  { id: 'b', label: 'B', max: 255, accent: '#3b82f6' },
];
const hslChannels = [
  { id: 'h', label: 'H', max: 360, suffix: '°', accent: '#5e6ad2' },
  { id: 's', label: 'S', max: 100, suffix: '%', accent: '#5e6ad2' },
  { id: 'l', label: 'L', max: 100, suffix: '%', accent: '#5e6ad2' },
];
---

<ToolLayout slug="rgb-to-hsl-hsv">
  <ColorFormats focus="hsl" />

  <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-2">
    <div class="panel rounded-lg p-4">
      <div class="mb-3 flex items-center justify-between">
        <span class="text-[13px] text-ink-subtle">RGB channels</span>
        <button id="cf-random" type="button" class="btn btn-secondary">Random</button>
      </div>
      <div class="flex flex-col gap-3">
        {rgbChannels.map((c) => (
          <div class="flex items-center gap-3">
            <span class="w-4 text-[13px] font-mono text-ink-subtle">{c.label}</span>
            <input
              type="range" min="0" max={c.max} value="0"
              id={`sl-${c.id}`} data-kind="rgb" data-ch={c.id}
              class="cf-slider h-1.5 flex-1 cursor-pointer"
              style={`accent-color:${c.accent}`}
              aria-label={`${c.label} channel`}
            />
            <output id={`sv-${c.id}`} class="w-10 text-right text-[13px] font-mono text-ink">0</output>
          </div>
        ))}
      </div>
    </div>

    <div class="panel rounded-lg p-4">
      <span class="mb-3 block text-[13px] text-ink-subtle">HSL channels</span>
      <div class="flex flex-col gap-3">
        {hslChannels.map((c) => (
          <div class="flex items-center gap-3">
            <span class="w-4 text-[13px] font-mono text-ink-subtle">{c.label}</span>
            <input
              type="range" min="0" max={c.max} value="0"
              id={`sl-${c.id}`} data-kind="hsl" data-ch={c.id}
              class="cf-slider h-1.5 flex-1 cursor-pointer"
              style={`accent-color:${c.accent}`}
              aria-label={`${c.label} channel`}
            />
            <output id={`sv-${c.id}`} class="w-10 text-right text-[13px] font-mono text-ink">0{c.suffix}</output>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="mt-6">
    <span class="text-[13px] text-ink-subtle">Color harmonies</span>
    <div id="cf-harmony" class="mt-2 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free RGB to HSL and HSV converter turns red, green and blue values
      into hue, saturation, lightness (HSL) and hue, saturation, value (HSB/HSV).
      These cylindrical models make it far easier to tweak a color — adjust
      lightness for tints and shades, or spin the hue for a new color entirely.
      HEX and CMYK are shown too.
    </p>
    <p>
      Grab the RGB or HSL channel sliders to dial a color in by eye, or type an
      exact value in any field — the picker, swatch, sliders and every readout
      stay in sync. The color harmonies row shows the complementary, analogous
      and triadic partners of your current color; click any swatch to load it.
      Copy any format with one click, sample the tints and shades, or hit
      Random to explore.
    </p>
  </div>
</ToolLayout>

<script>
  import { hexToRgb, rgbToHsl, hslToRgb, rgbToHex, type RGB } from '../../lib/colors';

  const $ = (id: string) => document.getElementById(id);
  const picker = $('cf-picker') as HTMLInputElement | null;
  const hexIn = $('cf-hex') as HTMLInputElement | null;
  const rgbIn = $('cf-rgb') as HTMLInputElement | null;
  const hslIn = $('cf-hsl') as HTMLInputElement | null;
  const preview = $('cf-preview');
  const harmonyWrap = $('cf-harmony');
  if (picker && hexIn && rgbIn && hslIn && preview && harmonyWrap) {
    const sliders = Array.from(document.querySelectorAll<HTMLInputElement>('.cf-slider'));
    const suffix: Record<string, string> = { h: '°', s: '%', l: '%' };

    const currentRgb = (): RGB => hexToRgb(picker.value) || { r: 0, g: 0, b: 0 };

    function loadRgb(rgb: RGB) {
      hexIn!.value = rgbToHex(rgb);
      hexIn!.dispatchEvent(new Event('input', { bubbles: true }));
    }

    function sync() {
      const rgb = currentRgb();
      const hsl = rgbToHsl(rgb);
      const vals: Record<string, number> = { ...rgb, ...hsl };
      for (const sl of sliders) {
        const ch = sl.dataset.ch!;
        sl.value = String(vals[ch]);
        const out = $(`sv-${ch}`);
        if (out) out.textContent = vals[ch] + (suffix[ch] || '');
      }
      renderHarmonies(hsl.h, hsl.s, hsl.l);
    }

    function renderHarmonies(h: number, s: number, l: number) {
      const spin = (deg: number) => ((h + deg) % 360 + 360) % 360;
      const items = [
        { name: 'Complementary', h: spin(180) },
        { name: 'Analogous −30', h: spin(-30) },
        { name: 'Analogous +30', h: spin(30) },
        { name: 'Triadic +120', h: spin(120) },
        { name: 'Triadic +240', h: spin(240) },
      ];
      harmonyWrap!.innerHTML = '';
      for (const it of items) {
        const rgb = hslToRgb({ h: it.h, s, l });
        const hex = rgbToHex(rgb);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'panel panel-lift flex flex-col gap-2 rounded-md p-2 text-left transition-colors hover:border-hairline-strong';
        btn.title = `Load ${hex}`;
        const sw = document.createElement('div');
        sw.className = 'h-10 w-full rounded-sm border border-hairline';
        sw.style.background = hex;
        const lbl = document.createElement('span');
        lbl.className = 'text-[11px] leading-tight text-ink-subtle';
        lbl.textContent = it.name;
        const code = document.createElement('span');
        code.className = 'text-[12px] font-mono text-ink';
        code.textContent = hex;
        btn.append(sw, lbl, code);
        btn.addEventListener('click', () => loadRgb(rgb));
        harmonyWrap!.appendChild(btn);
      }
    }

    // Slider drag → rebuild the color from whichever model that slider belongs to.
    for (const sl of sliders) {
      sl.addEventListener('input', () => {
        const read = (ch: string) => Number(($(`sl-${ch}`) as HTMLInputElement).value);
        if (sl.dataset.kind === 'rgb') {
          loadRgb({ r: read('r'), g: read('g'), b: read('b') });
        } else {
          loadRgb(hslToRgb({ h: read('h'), s: read('s'), l: read('l') }));
        }
      });
    }

    $('cf-random')?.addEventListener('click', () => {
      const rand = () => Math.floor(Math.random() * 256);
      loadRgb({ r: rand(), g: rand(), b: rand() });
    });

    // Catch every update from the shared converter (typing, picker, shade
    // clicks) via its preview background changing, then re-sync our UI.
    new MutationObserver(sync).observe(preview, { attributes: true, attributeFilter: ['style'] });
    sync();
  }
</script>

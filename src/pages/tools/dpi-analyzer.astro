---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    q: 'How does this mouse DPI analyzer work?',
    a: 'Set the physical distance you plan to move your mouse, then press and drag that exact distance across your mousepad in one straight swipe. The tool counts how many pixels the pointer travelled and divides by your physical distance to estimate your real DPI (dots/counts per inch). Averaging a few swipes gives the most reliable number.',
  },
  {
    q: 'What is mouse DPI?',
    a: 'DPI (dots per inch), more precisely CPI (counts per inch), is how many pixels your cursor moves for every inch you move the mouse. Higher DPI means the cursor travels farther for the same hand movement — more sensitivity, less physical effort.',
  },
  {
    q: 'How accurate is a browser-based DPI test?',
    a: 'Browsers report pointer movement in CSS pixels, so display scaling and OS pointer acceleration affect the reading. Disable "Enhance pointer precision" on Windows (or mouse acceleration on macOS), set display scaling to 100%, and average several swipes for the closest estimate. Treat the result as a very good approximation, not a lab measurement.',
  },
  {
    q: 'What DPI should I use for gaming?',
    a: 'Most FPS pros play at 400–800 DPI with low in-game sensitivity for precise aim. 800–1600 DPI suits general gaming and desktop use, while 1600–3200+ helps on 4K or multi-monitor setups. There is no single best value — pick what feels controllable.',
  },
  {
    q: 'What is eDPI?',
    a: 'eDPI (effective DPI) = mouse DPI × in-game sensitivity. It lets you compare sensitivity across players regardless of their hardware DPI. Two setups with the same eDPI move the crosshair the same amount for the same hand motion.',
  },
  {
    q: 'How do I change my mouse DPI?',
    a: 'Many mice have a dedicated DPI button that cycles preset stages. For fine control, use the manufacturer software (Logitech G HUB, Razer Synapse, SteelSeries GG, Corsair iCUE, Glorious CORE) to set an exact DPI. Basic mice rely on the OS pointer-speed slider instead.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<ToolLayout slug="dpi-analyzer">
  <div class="flex flex-col gap-5">
    <!-- Steps -->
    <div class="panel p-4 text-[13px] leading-relaxed text-ink-subtle">
      <span class="font-medium text-ink">How to measure:</span>
      1. Set the distance you'll move the mouse. 2. Place the mouse at a start
      point on your pad, then press and hold inside the box below. 3. Drag the mouse
      exactly that distance in one straight swipe and release. 4. Repeat a few
      times — the average DPI is your most accurate reading.
    </div>

    <!-- Controls -->
    <div class="flex flex-wrap items-end gap-3">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        Distance moved
        <div class="flex items-stretch">
          <button id="dp-dec" type="button" aria-label="Decrease distance" class="btn btn-secondary rounded-r-none px-3">–</button>
          <input id="dp-dist" type="number" min="0.1" step="0.5" value="10" class="field w-24 rounded-none text-center" />
          <button id="dp-inc" type="button" aria-label="Increase distance" class="btn btn-secondary rounded-l-none px-3">+</button>
        </div>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Unit
        <select id="dp-unit" class="field w-32">
          <option value="cm">Centimeters</option>
          <option value="in">Inches</option>
          <option value="mm">Millimeters</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Configured DPI
        <input id="dp-set" type="number" min="1" step="50" value="800" class="field w-28" />
      </label>
      <button id="dp-clear" type="button" class="btn btn-secondary ml-auto">Clear swipes</button>
    </div>

    <!-- Tracking pad -->
    <div
      id="dp-pad"
      class="panel panel-lift relative flex h-72 cursor-crosshair select-none items-center justify-center overflow-hidden text-center"
      role="button"
      tabindex="0"
      aria-label="DPI measuring area"
    >
      <span id="dp-hint" class="pointer-events-none px-6 text-sm text-ink-tertiary">
        Start measuring by pressing anywhere in this box, then drag your set distance
      </span>
      <svg id="dp-trail" class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true">
        <line id="dp-line" x1="0" y1="0" x2="0" y2="0" stroke="#5e6ad2" stroke-width="2" stroke-dasharray="4 4" />
      </svg>
      <div id="dp-marker" class="pointer-events-none absolute hidden h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#5e6ad2]"></div>
    </div>

    <!-- Live stats -->
    <div id="dp-stats" class="grid grid-cols-2 gap-3 sm:grid-cols-4"></div>

    <!-- Swipe history / average -->
    <div id="dp-history-wrap" class="panel p-4 hidden">
      <div class="mb-3 flex items-center justify-between">
        <span class="font-display text-[15px] font-medium text-ink">Swipe history</span>
        <span id="dp-avg" class="text-sm text-ink-subtle"></span>
      </div>
      <ul id="dp-history" class="flex flex-col gap-1 text-[13px] text-ink-subtle"></ul>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-8 text-[15px] leading-relaxed text-ink-subtle">
    <div class="flex flex-col gap-4">
      <p>
        This free mouse DPI analyzer measures your mouse's true DPI — dots per inch,
        technically counts per inch (CPI). Enter the physical distance you'll move the
        mouse, press and drag across your pad in one straight swipe, and the tool
        records how many pixels the pointer travelled and divides by that distance to
        estimate the effective DPI. It shows a live reading while you drag, keeps a
        history of every swipe, and averages them so you land on a dependable number.
        It also compares the result against the DPI you think your mouse is set to, so
        you can catch a mis-configured sensor. Everything runs in your browser —
        nothing is uploaded.
      </p>
      <p>
        Because browsers report movement in CSS pixels, accuracy depends on your
        display scaling and pointer settings. For the closest result, set display
        scaling to 100%, turn off "Enhance pointer precision" (Windows) or mouse
        acceleration (macOS), and average several swipes.
      </p>
    </div>

    <!-- Recommended DPI table -->
    <div>
      <h2 class="mb-3 font-display text-lg font-semibold text-ink">Recommended DPI by use case</h2>
      <div class="panel overflow-hidden">
        <table class="w-full text-left text-sm">
          <thead class="text-ink-muted">
            <tr class="border-b border-hairline">
              <th class="px-4 py-3 font-medium">Use case</th>
              <th class="px-4 py-3 font-medium">Typical DPI</th>
              <th class="px-4 py-3 font-medium">Notes</th>
            </tr>
          </thead>
          <tbody class="text-ink-subtle">
            <tr class="border-b border-hairline">
              <td class="px-4 py-3 text-ink">FPS / competitive gaming</td>
              <td class="px-4 py-3 font-mono">400–800</td>
              <td class="px-4 py-3">Low DPI + low sensitivity for precise aim.</td>
            </tr>
            <tr class="border-b border-hairline">
              <td class="px-4 py-3 text-ink">General gaming</td>
              <td class="px-4 py-3 font-mono">800–1600</td>
              <td class="px-4 py-3">Balanced control and speed.</td>
            </tr>
            <tr class="border-b border-hairline">
              <td class="px-4 py-3 text-ink">Office / everyday</td>
              <td class="px-4 py-3 font-mono">1000–1600</td>
              <td class="px-4 py-3">Comfortable on 1080p–1440p displays.</td>
            </tr>
            <tr class="border-b border-hairline">
              <td class="px-4 py-3 text-ink">Graphic design</td>
              <td class="px-4 py-3 font-mono">600–1200</td>
              <td class="px-4 py-3">Lower DPI for fine, deliberate strokes.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-ink">4K / multi-monitor</td>
              <td class="px-4 py-3 font-mono">1600–3200+</td>
              <td class="px-4 py-3">Higher DPI to cross large pixel areas.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- FAQ -->
    <div>
      <h2 class="mb-3 font-display text-lg font-semibold text-ink">Frequently asked questions</h2>
      <div class="flex flex-col gap-3">
        {faqs.map((f) => (
          <details class="panel p-4">
            <summary class="cursor-pointer font-medium text-ink marker:text-ink-tertiary">{f.q}</summary>
            <p class="mt-2 text-[14px] leading-relaxed text-ink-subtle">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</ToolLayout>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline />

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const pad = $('dp-pad');
  const marker = $('dp-marker');
  const hint = $('dp-hint');
  const stats = $('dp-stats');
  const line = $('dp-line') as unknown as SVGLineElement;
  const distEl = $('dp-dist') as HTMLInputElement;
  const unitEl = $('dp-unit') as HTMLSelectElement;
  const setEl = $('dp-set') as HTMLInputElement;
  const historyWrap = $('dp-history-wrap');
  const historyList = $('dp-history');
  const avgEl = $('dp-avg');

  let dragging = false;
  let startX = 0, startY = 0;
  let totalPx = 0;
  const swipes: number[] = []; // measured pixel counts per swipe

  function physicalInches(): number {
    const d = parseFloat(distEl.value) || 0;
    if (unitEl.value === 'in') return d;
    if (unitEl.value === 'mm') return d / 25.4;
    return d / 2.54; // cm
  }

  function dpiFromPx(px: number): number {
    const inches = physicalInches();
    return inches > 0 ? Math.round(px / inches) : 0;
  }

  function tile(label: string, value: string, accent = false): string {
    return `<div class="panel panel-lift flex flex-col gap-1 p-4">
      <span class="text-xs text-ink-tertiary">${label}</span>
      <span class="font-display text-2xl font-semibold ${accent ? 'text-primary-hover' : 'text-ink'}">${value}</span>
    </div>`;
  }

  function averageDpi(): number {
    if (!swipes.length) return 0;
    const dpis = swipes.map(dpiFromPx);
    return Math.round(dpis.reduce((a, b) => a + b, 0) / dpis.length);
  }

  function render(livePx: number) {
    const dpi = dpiFromPx(livePx);
    const avg = averageDpi();
    const best = avg || dpi;
    const setDpi = parseFloat(setEl.value) || 0;
    const ratio = setDpi > 0 && best > 0 ? best / setDpi : 0;
    stats.innerHTML =
      tile('Pixels moved', Math.round(livePx).toLocaleString()) +
      tile(swipes.length ? 'Average DPI' : 'Estimated DPI', best ? best.toLocaleString() : '—', true) +
      tile('Swipes', String(swipes.length)) +
      tile('vs configured', setDpi && ratio ? `${(ratio * 100).toFixed(0)}%` : '—');
  }

  function renderHistory() {
    if (!swipes.length) {
      historyWrap.classList.add('hidden');
      return;
    }
    historyWrap.classList.remove('hidden');
    historyList.innerHTML = swipes
      .map((px, i) => `<li class="flex justify-between border-b border-hairline pb-1 last:border-0">
        <span>Swipe ${i + 1}</span>
        <span class="font-mono text-ink">${dpiFromPx(px).toLocaleString()} DPI · ${Math.round(px).toLocaleString()} px</span>
      </li>`)
      .join('');
    avgEl.textContent = `Average: ${averageDpi().toLocaleString()} DPI over ${swipes.length} swipe${swipes.length > 1 ? 's' : ''}`;
  }

  function positionMarker(e: PointerEvent) {
    const rect = pad.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    marker.style.left = `${x}px`;
    marker.style.top = `${y}px`;
    line.setAttribute('x2', String(x));
    line.setAttribute('y2', String(y));
  }

  function start(e: PointerEvent) {
    dragging = true;
    totalPx = 0;
    startX = e.clientX;
    startY = e.clientY;
    hint.classList.add('hidden');
    marker.classList.remove('hidden');
    const rect = pad.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    line.setAttribute('x1', String(x));
    line.setAttribute('y1', String(y));
    line.setAttribute('x2', String(x));
    line.setAttribute('y2', String(y));
    pad.setPointerCapture(e.pointerId);
    positionMarker(e);
    render(0);
  }

  function move(e: PointerEvent) {
    if (!dragging) return;
    totalPx += Math.hypot(e.movementX || 0, e.movementY || 0);
    positionMarker(e);
    render(totalPx);
  }

  function end(e: PointerEvent) {
    if (!dragging) return;
    dragging = false;
    marker.classList.add('hidden');
    // Fall back to straight-line distance if movement deltas were unavailable.
    const straight = Math.hypot(e.clientX - startX, e.clientY - startY);
    const measured = Math.max(totalPx, straight);
    if (measured > 4) {
      swipes.push(measured);
      renderHistory();
    }
    render(measured);
    line.setAttribute('x2', line.getAttribute('x1') || '0');
    line.setAttribute('y2', line.getAttribute('y1') || '0');
  }

  function stepDistance(delta: number) {
    const cur = parseFloat(distEl.value) || 0;
    const next = Math.max(0.1, Math.round((cur + delta) * 10) / 10);
    distEl.value = String(next);
    render(0);
    renderHistory();
  }

  pad.addEventListener('pointerdown', start);
  pad.addEventListener('pointermove', move);
  pad.addEventListener('pointerup', end);
  pad.addEventListener('pointercancel', end);

  $('dp-inc').addEventListener('click', () => stepDistance(1));
  $('dp-dec').addEventListener('click', () => stepDistance(-1));
  $('dp-clear').addEventListener('click', () => {
    swipes.length = 0;
    renderHistory();
    render(0);
  });

  [distEl, unitEl, setEl].forEach((el) =>
    el.addEventListener('input', () => {
      render(0);
      renderHistory();
    }),
  );

  render(0);
</script>

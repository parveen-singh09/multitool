---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="nickname-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Your name
        <input id="nk-name" class="field" value="Alex" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Style
        <select id="nk-style" class="field w-36"><option value="cute">Cute</option><option value="cool">Cool</option><option value="gamer">Gamer</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="nk-count" type="number" min="4" max="40" value="16" class="field w-24" />
      </label>
      <button id="nk-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="nk-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <div id="nk-out" class="grid grid-cols-2 gap-2 sm:grid-cols-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free nickname generator turns your name into fun nicknames in three
      flavors — cute, cool and gamer-style — using playful prefixes, suffixes and
      word pairings. It's perfect for games, social handles, group chats and giving
      a friend a new tag. Click any nickname to copy it. Everything runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { shuffle, pick, randInt } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const nameEl = $('nk-name') as HTMLInputElement;
  const styleEl = $('nk-style') as HTMLSelectElement;
  const countEl = $('nk-count') as HTMLInputElement;
  const out = $('nk-out')!;

  const CUTE = { pre: ['Sweet', 'Little', 'Lil', 'Bubbly', 'Sunny', 'Honey'], suf: ['bug', 'bear', 'boo', 'kins', 'pie', 'cake'] };
  const COOL = { pre: ['Ace', 'Neo', 'Max', 'Shadow', 'Blaze', 'Steel'], suf: ['X', 'Prime', 'Storm', 'Wolf', 'Star', 'Zero'] };
  const GAMER = { pre: ['xX', 'Pro', 'Dark', 'Toxic', 'Epic', 'Ghost'], suf: ['Slayer', 'Sniper', '99', 'YT', 'Gg', 'TTV'] };

  const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();

  function generate() {
    const name = cap(nameEl.value.trim().replace(/[^a-zA-Z]/g, '') || 'Alex');
    const style = styleEl.value === 'cute' ? CUTE : styleEl.value === 'cool' ? COOL : GAMER;
    const gamer = styleEl.value === 'gamer';
    const n = Math.max(4, Math.min(40, Number(countEl.value) || 16));
    const set = new Set<string>();
    let guard = 0;
    while (set.size < n && guard < n * 20) {
      guard++;
      const p = pick(style.pre), s = pick(style.suf);
      const style3 = randInt(0, 3);
      if (gamer && style3 === 0) set.add(`xX${name}Xx`);
      else if (style3 === 1) set.add(`${p}${name}`);
      else if (style3 === 2) set.add(`${name}${s}`);
      else set.add(`${p}${name}${s}`);
    }
    const list = shuffle([...set]).slice(0, n);
    out.innerHTML = list.map((nn) => `<button class="panel px-3 py-2.5 text-center text-[15px] font-medium text-ink hover:border-hairline-strong" data-n="${nn}">${nn}</button>`).join('');
    out.querySelectorAll('button').forEach((b) => b.addEventListener('click', async () => {
      await navigator.clipboard.writeText((b as HTMLElement).dataset.n!);
      const orig = b.textContent; b.textContent = 'Copied!';
      setTimeout(() => (b.textContent = orig), 1000);
    }));
  }

  [nameEl, styleEl, countEl].forEach((el) => el.addEventListener('input', generate));
  $('nk-gen').addEventListener('click', generate);
  $('nk-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText([...out.querySelectorAll('button')].map((b) => (b as HTMLElement).dataset.n).join('\n'));
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="roman-numeral-converter">
  <div class="flex flex-col gap-4">
    <p class="text-[13px] text-ink-subtle">Type an Arabic number (1–3,999,999) or a Roman numeral — the other updates instantly, with a place-value breakdown below.</p>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Number
      <div class="flex gap-2">
        <input id="rn-num" type="text" class="field font-mono" placeholder="2026" inputmode="numeric" spellcheck="false" autocomplete="off" />
        <button id="rn-copy-num" type="button" class="btn btn-secondary">Copy</button>
      </div>
    </label>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Roman numeral
      <div class="flex gap-2">
        <input id="rn-rom" type="text" class="field font-mono uppercase" placeholder="MMXXVI" spellcheck="false" autocomplete="off" />
        <button id="rn-copy" type="button" class="btn btn-secondary">Copy</button>
      </div>
    </label>

    <p id="rn-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="rn-breakdown" class="hidden flex-col gap-2">
      <span class="eyebrow text-ink-tertiary">Breakdown</span>
      <div class="panel flex flex-wrap items-center gap-2 p-3 font-mono text-sm">
        <div id="rn-parts" class="flex flex-wrap items-center gap-2"></div>
        <span class="text-ink-tertiary">=</span>
        <span id="rn-total" class="text-ink"></span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2 text-[13px] text-ink-subtle">
      <span>Try:</span>
      <button type="button" class="rn-eg btn btn-tertiary px-2 py-1" data-n="4">4</button>
      <button type="button" class="rn-eg btn btn-tertiary px-2 py-1" data-n="49">49</button>
      <button type="button" class="rn-eg btn btn-tertiary px-2 py-1" data-n="2026">2026</button>
      <button type="button" class="rn-eg btn btn-tertiary px-2 py-1" data-n="3999">3999</button>
      <button type="button" class="rn-eg btn btn-tertiary px-2 py-1" data-n="50000">50,000</button>
    </div>

    <p class="text-[13px] text-ink-tertiary">A bar over a numeral (a vinculum, shown here as a combining overline, e.g. <span class="font-mono">V̄</span> = 5,000) multiplies it by 1,000 for values above 3,999.</p>

    <div class="flex flex-col gap-3 border-t pt-4" style="border-color:var(--color-hairline)">
      <span class="eyebrow text-ink-tertiary">Date to Roman numerals</span>
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Date
          <input id="rn-date" type="date" class="field" value="2026-07-13" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Format
          <select id="rn-date-fmt" class="field w-auto py-1">
            <option value="D/M/Y" selected>Day · Month · Year</option>
            <option value="M/D/Y">Month · Day · Year</option>
            <option value="Y/M/D">Year · Month · Day</option>
            <option value="Y">Year only</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Separator
          <select id="rn-date-sep" class="field w-auto py-1">
            <option value="·" selected>· (middot)</option>
            <option value=".">. (dot)</option>
            <option value="/">/ (slash)</option>
            <option value="-">- (dash)</option>
            <option value=" "> (space)</option>
          </select>
        </label>
      </div>
      <div class="flex gap-2">
        <input id="rn-date-out" type="text" class="field font-mono" readonly aria-label="Roman numeral date" />
        <button id="rn-copy-date" type="button" class="btn btn-secondary">Copy</button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Roman numeral converter translates between ordinary numbers and
      Roman numerals in both directions. Enter a number to see its Roman form,
      or type a numeral like <code>MMXXVI</code> to read its value. It follows
      the standard subtractive rules (IV, IX, XL, XC, CD, CM) and rejects
      malformed numerals such as <code>IIII</code> or <code>VX</code> with a
      clear message. Every result comes with a place-value breakdown showing
      how each part adds up, and large values above 3,999 use vinculum
      (overline) notation, supported all the way to 3,999,999.
    </p>
    <p>
      A built-in date converter renders any calendar date in Roman numerals —
      pick day/month/year order, year-only, and your preferred separator — the
      way dates appear on cornerstones, film credits, and monuments. Copy any
      field with one click.
    </p>
    <div class="flex flex-col gap-1">
      <span class="eyebrow text-ink-tertiary">Reference chart</span>
      <div class="font-mono text-sm text-ink-muted">
        I = 1 · V = 5 · X = 10 · L = 50 · C = 100 · D = 500 · M = 1,000<br />
        IV = 4 · IX = 9 · XL = 40 · XC = 90 · CD = 400 · CM = 900<br />
        V̄ = 5,000 · X̄ = 10,000 · L̄ = 50,000 · C̄ = 100,000 · M̄ = 1,000,000
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  const numEl = document.getElementById('rn-num') as HTMLInputElement;
  const romEl = document.getElementById('rn-rom') as HTMLInputElement;
  const err = document.getElementById('rn-error')!;
  const breakdown = document.getElementById('rn-breakdown')!;
  const partsEl = document.getElementById('rn-parts')!;
  const totalEl = document.getElementById('rn-total')!;

  const MAP: [number, string][] = [
    [1000, 'M'], [900, 'CM'], [500, 'D'], [400, 'CD'], [100, 'C'],
    [90, 'XC'], [50, 'L'], [40, 'XL'], [10, 'X'], [9, 'IX'],
    [5, 'V'], [4, 'IV'], [1, 'I'],
  ];

  function segments(n: number): { sym: string; val: number }[] {
    const out: { sym: string; val: number }[] = [];
    let thousands = Math.floor(n / 1000);
    const rest = n % 1000;
    if (thousands >= 4) {
      let big = thousands;
      for (const [v, s] of MAP) { while (big >= v) { out.push({ sym: s.split('').map((c) => c + '̄').join(''), val: v * 1000 }); big -= v; } }
      thousands = 0;
    }
    let base = thousands * 1000 + rest;
    for (const [v, s] of MAP) { while (base >= v) { out.push({ sym: s, val: v }); base -= v; } }
    return out;
  }

  function toRoman(n: number): string {
    if (n < 1 || n > 3_999_999) return '';
    return segments(n).map((s) => s.sym).join('');
  }

  function fromRoman(raw: string): number | null {
    const s = raw.toUpperCase().replace(/̄/g, '').trim();
    if (!s) return null;
    if (!/^[MDCLXVI]+$/.test(s)) return null;
    const vals: Record<string, number> = { I: 1, V: 5, X: 10, L: 50, C: 100, D: 500, M: 1000 };
    let total = 0, prev = 0;
    for (let i = s.length - 1; i >= 0; i--) {
      const v = vals[s[i]];
      if (v < prev) total -= v; else { total += v; prev = v; }
    }

    if (toRoman(total).replace(/̄/g, '') !== s) return null;
    return total;
  }

  function showBreakdown(n: number) {
    partsEl.replaceChildren();
    for (const seg of segments(n)) {
      const chip = document.createElement('span');
      chip.className = 'text-ink';
      chip.textContent = `${seg.sym}=${seg.val.toLocaleString()}`;
      partsEl.appendChild(chip);
      const plus = document.createElement('span');
      plus.className = 'text-ink-tertiary';
      plus.textContent = '+';
      partsEl.appendChild(plus);
    }
    if (partsEl.lastChild) partsEl.removeChild(partsEl.lastChild); // drop trailing '+'
    totalEl.textContent = n.toLocaleString();
    breakdown.classList.remove('hidden');
    breakdown.classList.add('flex');
  }

  function hideBreakdown() {
    breakdown.classList.add('hidden');
    breakdown.classList.remove('flex');
  }

  function fromNum() {
    err.classList.add('hidden');
    const v = numEl.value.trim().replace(/,/g, '');
    if (!v) { romEl.value = ''; hideBreakdown(); return; }
    const n = Number(v);
    if (!Number.isInteger(n) || n < 1 || n > 3_999_999) {
      romEl.value = ''; hideBreakdown();
      err.textContent = 'Enter a whole number from 1 to 3,999,999.';
      err.classList.remove('hidden');
      return;
    }
    romEl.value = toRoman(n);
    showBreakdown(n);
  }

  function fromRom() {
    err.classList.add('hidden');
    const n = fromRoman(romEl.value);
    if (romEl.value.trim() && n === null) {
      numEl.value = ''; hideBreakdown();
      err.textContent = 'That is not a valid Roman numeral.';
      err.classList.remove('hidden');
      return;
    }
    if (n === null) { numEl.value = ''; hideBreakdown(); return; }
    numEl.value = String(n);
    showBreakdown(n);
  }

  numEl.addEventListener('input', fromNum);
  romEl.addEventListener('input', fromRom);

  async function copyFrom(el: HTMLInputElement, btn: HTMLButtonElement) {
    if (!el.value) return;
    await navigator.clipboard.writeText(el.value);
    btn.textContent = 'Copied!'; setTimeout(() => (btn.textContent = 'Copy'), 1400);
  }
  document.getElementById('rn-copy')!.addEventListener('click', (e) => copyFrom(romEl, e.currentTarget as HTMLButtonElement));
  document.getElementById('rn-copy-num')!.addEventListener('click', (e) => copyFrom(numEl, e.currentTarget as HTMLButtonElement));

  document.querySelectorAll<HTMLButtonElement>('.rn-eg').forEach((b) =>
    b.addEventListener('click', () => { numEl.value = b.dataset.n!; fromNum(); }));

  // Date → Roman numerals.
  const dateEl = document.getElementById('rn-date') as HTMLInputElement;
  const dateFmt = document.getElementById('rn-date-fmt') as HTMLSelectElement;
  const dateSep = document.getElementById('rn-date-sep') as HTMLSelectElement;
  const dateOut = document.getElementById('rn-date-out') as HTMLInputElement;

  function updateDate() {
    const v = dateEl.value; // YYYY-MM-DD from native picker
    if (!v) { dateOut.value = ''; return; }
    const [y, m, d] = v.split('-').map(Number);
    const parts: Record<string, string> = { D: toRoman(d), M: toRoman(m), Y: toRoman(y) };
    const order = dateFmt.value.split('/');
    dateOut.value = order.map((k) => parts[k]).join(dateSep.value);
  }
  dateEl.addEventListener('input', updateDate);
  dateFmt.addEventListener('change', updateDate);
  dateSep.addEventListener('change', updateDate);
  document.getElementById('rn-copy-date')!.addEventListener('click', (e) => copyFrom(dateOut, e.currentTarget as HTMLButtonElement));

  numEl.value = '2026'; fromNum();
  updateDate();
</script>

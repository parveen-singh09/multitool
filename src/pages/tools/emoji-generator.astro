---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="emoji-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Category
        <select id="em-cat" class="field w-44">
          <option value="any">Any</option>
          <option value="smileys">Smileys</option>
          <option value="animals">Animals</option>
          <option value="food">Food</option>
          <option value="activities">Activities</option>
          <option value="travel">Travel</option>
          <option value="objects">Objects</option>
          <option value="symbols">Symbols</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Mode
        <select id="em-mode" class="field w-40"><option value="random">Random set</option><option value="combo">Fun combo</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="em-count" type="number" min="1" max="60" value="12" class="field w-24" />
      </label>
      <button id="em-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="em-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <div id="em-out" class="flex flex-wrap gap-2 text-3xl"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free emoji generator gives you random emojis by category, or builds fun
      emoji combos and reactions for your chats, captions and posts. Click any
      emoji to copy it on its own, or copy the whole set at once. It's a quick way
      to add personality to a message or spark an idea. Everything runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { sample, pick } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('em-out')!;

  const EMOJI: Record<string, string[]> = {
    smileys: ['😀', '😂', '🥹', '😊', '😍', '🤩', '😎', '🤔', '😴', '🥳', '😇', '🙃', '😜', '🤗', '😌', '🥰'],
    animals: ['🐶', '🐱', '🦊', '🐼', '🦁', '🐯', '🦄', '🐨', '🐸', '🐙', '🦉', '🦋', '🐢', '🦕', '🐝', '🦔'],
    food: ['🍕', '🍔', '🌮', '🍜', '🍣', '🍩', '🍦', '🍓', '🥑', '🍿', '🧁', '☕', '🍫', '🥞', '🍉', '🌶️'],
    activities: ['⚽', '🏀', '🎮', '🎨', '🎸', '🎯', '🎲', '🏆', '🎳', '🧗', '🚴', '🏄', '🎤', '🎧', '♟️', '🎬'],
    travel: ['✈️', '🚗', '🚀', '🏝️', '🗻', '🏰', '🗺️', '🧳', '⛵', '🚁', '🎡', '🏕️', '🌋', '🗽', '🚂', '🌍'],
    objects: ['💡', '📱', '💻', '📷', '🔑', '🎁', '📚', '✏️', '🔮', '⌛', '🔋', '🧭', '🕯️', '🎈', '💎', '🧲'],
    symbols: ['❤️', '⭐', '🔥', '✨', '💯', '⚡', '🌈', '☮️', '♻️', '✅', '🎵', '💫', '❄️', '🌸', '💥', '🔆'],
  };

  function poolFor(cat: string): string[] {
    if (cat === 'any') return Object.values(EMOJI).flat();
    return EMOJI[cat];
  }

  function generate() {
    const cat = ($('em-cat') as HTMLSelectElement).value;
    const mode = ($('em-mode') as HTMLSelectElement).value;
    const n = Math.max(1, Math.min(60, Number(($('em-count') as HTMLInputElement).value) || 12));
    const pool = poolFor(cat);
    let list: string[];
    if (mode === 'combo') {
      list = Array.from({ length: Math.ceil(n / 3) }, () => sample(pool, 3).join(''));
    } else {
      list = Array.from({ length: n }, () => pick(pool));
    }
    out.innerHTML = list.map((e) => `<button class="rounded-md px-1 hover:bg-surface-2" data-e="${e}" title="Click to copy">${e}</button>`).join('');
    out.querySelectorAll('button').forEach((b) => b.addEventListener('click', async () => {
      await navigator.clipboard.writeText((b as HTMLElement).dataset.e!);
    }));
  }

  ['em-cat', 'em-mode', 'em-count'].forEach((id) => $(id).addEventListener('input', generate));
  $('em-gen').addEventListener('click', generate);
  $('em-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const all = [...out.querySelectorAll('button')].map((b) => (b as HTMLElement).dataset.e).join(' ');
    await navigator.clipboard.writeText(all);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="monty-hall-simulator">
  <div class="flex flex-col gap-6">

    <div class="flex flex-col gap-4">
      <div class="flex items-center justify-between">
        <h2 class="font-display text-lg font-semibold text-ink">Play a round</h2>
        <span id="mh-round-stats" class="text-[13px] text-ink-subtle">Stay 0/0 · Switch 0/0</span>
      </div>
      <p id="mh-prompt" class="min-h-5 text-[15px] text-ink-muted" role="status">Pick a door to start.</p>
      <div class="grid grid-cols-3 gap-3">
        <button id="mh-door-0" class="mh-door panel panel-lift flex h-32 flex-col items-center justify-center gap-2 p-4 text-4xl transition-colors hover:bg-surface-2" data-door="0">🚪<span class="text-[13px] text-ink-subtle">Door 1</span></button>
        <button id="mh-door-1" class="mh-door panel panel-lift flex h-32 flex-col items-center justify-center gap-2 p-4 text-4xl transition-colors hover:bg-surface-2" data-door="1">🚪<span class="text-[13px] text-ink-subtle">Door 2</span></button>
        <button id="mh-door-2" class="mh-door panel panel-lift flex h-32 flex-col items-center justify-center gap-2 p-4 text-4xl transition-colors hover:bg-surface-2" data-door="2">🚪<span class="text-[13px] text-ink-subtle">Door 3</span></button>
      </div>
      <div id="mh-actions" class="hidden flex-wrap gap-3">
        <button id="mh-stay" class="btn btn-primary">Stay</button>
        <button id="mh-switch" class="btn btn-primary">Switch</button>
      </div>
      <button id="mh-new" class="btn btn-secondary hidden w-fit">New round</button>
    </div>

    <div class="flex flex-col gap-4 border-t border-hairline pt-6">
      <h2 class="font-display text-lg font-semibold text-ink">Auto-run trials</h2>
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Number of trials
          <input id="mh-trials" type="number" min="1" max="1000000" value="10000" class="field w-40" />
        </label>
        <button id="mh-run" class="btn btn-primary">Run</button>
      </div>
      <div class="grid grid-cols-2 gap-3 text-center">
        <div class="panel panel-lift p-4"><div id="mh-stay-pct" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Stay win rate</div></div>
        <div class="panel panel-lift p-4"><div id="mh-switch-pct" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Switch win rate</div></div>
      </div>
      <div class="panel panel-lift flex flex-col gap-3 p-4 text-[13px]">
        <div class="flex flex-col gap-1">
          <div class="flex justify-between text-ink-subtle"><span class="text-ink">Stay</span><span id="mh-stay-detail" class="font-mono">—</span></div>
          <div class="h-3 w-full overflow-hidden rounded-xs bg-surface-2"><div id="mh-stay-bar" class="h-full rounded-xs" style="width:0%;background:#8a8f98"></div></div>
        </div>
        <div class="flex flex-col gap-1">
          <div class="flex justify-between text-ink-subtle"><span class="text-ink">Switch</span><span id="mh-switch-detail" class="font-mono">—</span></div>
          <div class="h-3 w-full overflow-hidden rounded-xs bg-surface-2"><div id="mh-switch-bar" class="h-full rounded-xs" style="width:0%;background:#5e6ad2"></div></div>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Monty Hall simulator lets you play the famous three-door
      probability puzzle: pick a door, watch the host reveal a goat behind one of
      the others, then decide whether to stay or switch. Play round by round to
      build intuition, then auto-run thousands of trials to see the counter-intuitive
      result for yourself — staying wins about one third of the time while switching
      wins about two thirds. Every trial uses your browser's secure random source
      and runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { randInt } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;

  const doorBtns = [$('mh-door-0'), $('mh-door-1'), $('mh-door-2')] as HTMLButtonElement[];
  const prompt = $('mh-prompt')!;
  const actions = $('mh-actions')!;
  const newBtn = $('mh-new') as HTMLButtonElement;

  let carDoor = 0;
  let picked = -1;
  let revealed = -1;
  let phase: 'pick' | 'decide' | 'done' = 'pick';

  let stayPlays = 0, stayWins = 0, switchPlays = 0, switchWins = 0;

  function setFace(i: number, face: string, label: string, highlight = false) {
    const btn = doorBtns[i];
    btn.innerHTML = `${face}<span class="text-[13px] text-ink-subtle">${label}</span>`;
    btn.style.borderColor = highlight ? '#5e6ad2' : '';
  }

  function newRound() {
    carDoor = randInt(0, 2);
    picked = -1; revealed = -1; phase = 'pick';
    doorBtns.forEach((b, i) => { b.disabled = false; setFace(i, '🚪', `Door ${i + 1}`); });
    actions.classList.add('hidden');
    actions.classList.remove('flex');
    newBtn.classList.add('hidden');
    prompt.textContent = 'Pick a door to start.';
  }

  function pick(i: number) {
    if (phase !== 'pick') return;
    picked = i;
    // Host opens a door that is neither the pick nor the car.
    const options = [0, 1, 2].filter((d) => d !== picked && d !== carDoor);
    revealed = options[randInt(0, options.length - 1)];

    doorBtns.forEach((b, d) => {
      b.disabled = true;
      if (d === revealed) setFace(d, '🐐', `Door ${d + 1} — goat`);
      else if (d === picked) setFace(d, '🚪', `Door ${d + 1} — your pick`, true);
      else setFace(d, '🚪', `Door ${d + 1}`);
    });

    phase = 'decide';
    actions.classList.remove('hidden');
    actions.classList.add('flex');
    prompt.textContent = `You picked door ${picked + 1}. The host opened door ${revealed + 1} to reveal a goat. Stay or switch?`;
  }

  function decide(doSwitch: boolean) {
    if (phase !== 'decide') return;
    const other = [0, 1, 2].find((d) => d !== picked && d !== revealed)!;
    const finalPick = doSwitch ? other : picked;
    const won = finalPick === carDoor;

    if (doSwitch) { switchPlays++; if (won) switchWins++; }
    else { stayPlays++; if (won) stayWins++; }

    doorBtns.forEach((d, i) => setFace(i, i === carDoor ? '🚗' : '🐐', `Door ${i + 1}`, i === finalPick));
    phase = 'done';
    actions.classList.add('hidden');
    actions.classList.remove('flex');
    newBtn.classList.remove('hidden');
    prompt.textContent = won
      ? `You ${doSwitch ? 'switched' : 'stayed'} and won the car! 🎉`
      : `You ${doSwitch ? 'switched' : 'stayed'} and got a goat. The car was behind door ${carDoor + 1}.`;
    updateRoundStats();
  }

  function updateRoundStats() {
    $('mh-round-stats').textContent = `Stay ${stayWins}/${stayPlays} · Switch ${switchWins}/${switchPlays}`;
  }

  function autoRun() {
    const n = Math.max(1, Math.min(1000000, Number(($('mh-trials') as HTMLInputElement).value) || 1));
    let sWins = 0, swWins = 0;
    for (let i = 0; i < n; i++) {
      const car = randInt(0, 2);
      const choice = randInt(0, 2);
      // Staying wins exactly when the first choice is the car.
      if (choice === car) sWins++;
      // Switching wins exactly when the first choice is NOT the car.
      else swWins++;
    }
    const stayPct = (sWins / n) * 100;
    const switchPct = (swWins / n) * 100;
    $('mh-stay-pct').textContent = stayPct.toFixed(1) + '%';
    $('mh-switch-pct').textContent = switchPct.toFixed(1) + '%';
    $('mh-stay-detail').textContent = `${sWins.toLocaleString()} / ${n.toLocaleString()}`;
    $('mh-switch-detail').textContent = `${swWins.toLocaleString()} / ${n.toLocaleString()}`;
    ($('mh-stay-bar') as HTMLElement).style.width = stayPct + '%';
    ($('mh-switch-bar') as HTMLElement).style.width = switchPct + '%';
  }

  doorBtns.forEach((b, i) => b.addEventListener('click', () => pick(i)));
  $('mh-stay').addEventListener('click', () => decide(false));
  $('mh-switch').addEventListener('click', () => decide(true));
  newBtn.addEventListener('click', newRound);
  $('mh-run').addEventListener('click', autoRun);

  newRound();
  updateRoundStats();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="temperature-converter">
  <div id="tc-root" class="flex flex-col gap-5">

    <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="tc-from-val">From</label>
        <input id="tc-from-val" type="number" class="field" value="0" inputmode="decimal" step="any" />
        <select id="tc-from-unit" class="field mt-1"></select>
      </div>
      <button
        id="tc-swap"
        type="button"
        class="btn btn-secondary mb-1 h-10 w-10 shrink-0 justify-self-center p-0"
        aria-label="Swap units"
        title="Swap units"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4"/></svg>
      </button>
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="tc-to-val">To</label>
        <div class="copy-wrap">
          <input id="tc-to-val" type="text" class="field font-mono" readonly />
          <button type="button" class="copy-icon" data-copy-target="#tc-to-val" aria-label="Copy"></button>
        </div>
        <select id="tc-to-unit" class="field mt-1"></select>
      </div>
    </div>

    <div class="flex flex-wrap items-end gap-x-4 gap-y-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Precision
        <select id="tc-precision" class="field w-auto py-1">
          <option value="auto" selected>Auto</option>
          <option value="0">0 decimals</option>
          <option value="1">1 decimal</option>
          <option value="2">2 decimals</option>
          <option value="3">3 decimals</option>
          <option value="4">4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="8">8 decimals</option>
        </select>
      </label>
      <div class="flex flex-col gap-1">
        <span class="text-sm text-ink-subtle">Quick presets</span>
        <div id="tc-presets" class="flex flex-wrap gap-2"></div>
      </div>
    </div>

    <p id="tc-formula" class="text-[13px] text-ink-tertiary"></p>
    <p id="tc-warn" class="hidden text-[13px]" style="color:#e5a23d" role="alert"></p>

    <div>
      <p class="mb-2 text-[13px] text-ink-subtle">All scales at once</p>
      <div id="tc-all" class="overflow-hidden rounded-md border border-hairline"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free temperature converter converts between eight temperature scales —
      Celsius, Fahrenheit, Kelvin, Rankine, Réaumur, Delisle, Newton and Rømer —
      using exact offset formulas. Unlike simple multiplication, temperature needs
      offset handling (each scale has a different zero point and step size), which
      this converter does correctly for every pair.
    </p>
    <p>
      Pick a source and target scale and type a value for an instant result, or read
      the "all scales at once" table to see the same temperature in every scale
      simultaneously. Choose how many decimal places you want (or leave it on Auto),
      copy any value with one click, and use the quick presets — absolute zero, water
      freezing, room temperature, body temperature and water boiling — to jump to
      common reference points. The converter shows the exact formula for the selected
      pair and warns when a value falls below absolute zero (−273.15 °C), which is not
      physically possible.
    </p>
  </div>
</ToolLayout>

<script>

  type Scale = { name: string; sym: string; toC: (v: number) => number; fromC: (c: number) => number };

  const SCALES: Scale[] = [
    { name: 'Celsius',    sym: '°C',  toC: (v) => v,                 fromC: (c) => c },
    { name: 'Fahrenheit', sym: '°F',  toC: (v) => (v - 32) * 5 / 9,  fromC: (c) => c * 9 / 5 + 32 },
    { name: 'Kelvin',     sym: 'K',   toC: (v) => v - 273.15,        fromC: (c) => c + 273.15 },
    { name: 'Rankine',    sym: '°R',  toC: (v) => v * 5 / 9 - 273.15, fromC: (c) => (c + 273.15) * 9 / 5 },
    { name: 'Réaumur',    sym: '°Ré', toC: (v) => v * 5 / 4,         fromC: (c) => c * 4 / 5 },
    { name: 'Delisle',    sym: '°De', toC: (v) => 100 - v * 2 / 3,   fromC: (c) => (100 - c) * 3 / 2 },
    { name: 'Newton',     sym: '°N',  toC: (v) => v * 100 / 33,      fromC: (c) => c * 33 / 100 },
    { name: 'Rømer',      sym: '°Rø', toC: (v) => (v - 7.5) * 40 / 21, fromC: (c) => c * 21 / 40 + 7.5 },
  ];
  const byName = (n: string) => SCALES.find((s) => s.name === n)!;
  const ABS_ZERO_C = -273.15;

  const fromVal = document.getElementById('tc-from-val') as HTMLInputElement;
  const toVal = document.getElementById('tc-to-val') as HTMLInputElement;
  const fromUnit = document.getElementById('tc-from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('tc-to-unit') as HTMLSelectElement;
  const swap = document.getElementById('tc-swap') as HTMLButtonElement;
  const precisionSel = document.getElementById('tc-precision') as HTMLSelectElement;
  const formula = document.getElementById('tc-formula') as HTMLElement;
  const warn = document.getElementById('tc-warn') as HTMLElement;
  const presetsWrap = document.getElementById('tc-presets') as HTMLElement;
  const allTable = document.getElementById('tc-all') as HTMLElement;

  function fmt(n: number): string {
    if (!isFinite(n)) return n < 0 ? '−∞' : '∞';
    const p = precisionSel.value;
    if (p !== 'auto') {
      const s = n.toFixed(Number(p));
      return s === '-0' || /^-0\.0+$/.test(s) ? s.slice(1) : s;
    }
    if (n === 0) return '0';
    const abs = Math.abs(n);
    if (abs >= 1e15 || abs < 1e-6) return n.toExponential(6);
    return String(Math.round(n * 1e9) / 1e9);
  }

  function convertValue(v: number, from: string, to: string): number {
    return byName(to).fromC(byName(from).toC(v));
  }

  function currentCelsius(): number | null {
    const v = Number(fromVal.value);
    if (fromVal.value.trim() === '' || isNaN(v)) return null;
    return byName(fromUnit.value).toC(v);
  }

  const FORMULAS: Record<string, string> = {
    'Celsius→Fahrenheit': '°F = °C × 9/5 + 32',
    'Fahrenheit→Celsius': '°C = (°F − 32) × 5/9',
    'Celsius→Kelvin': 'K = °C + 273.15',
    'Kelvin→Celsius': '°C = K − 273.15',
    'Fahrenheit→Kelvin': 'K = (°F − 32) × 5/9 + 273.15',
    'Kelvin→Fahrenheit': '°F = (K − 273.15) × 9/5 + 32',
    'Celsius→Rankine': '°R = (°C + 273.15) × 9/5',
    'Celsius→Réaumur': '°Ré = °C × 4/5',
    'Celsius→Newton': '°N = °C × 33/100',
    'Celsius→Delisle': '°De = (100 − °C) × 3/2',
    'Celsius→Rømer': '°Rø = °C × 21/40 + 7.5',
  };

  function fillUnits() {
    const opts = SCALES.map((s) => `<option value="${s.name}">${s.name} (${s.sym})</option>`).join('');
    fromUnit.innerHTML = opts;
    toUnit.innerHTML = opts;
    fromUnit.value = 'Celsius';
    toUnit.value = 'Fahrenheit';
  }

  function convert() {
    warn.classList.add('hidden');
    const v = Number(fromVal.value);
    const empty = fromVal.value.trim() === '' || isNaN(v);

    if (empty) {
      toVal.value = '';
      formula.textContent = '';
    } else {
      const result = convertValue(v, fromUnit.value, toUnit.value);
      toVal.value = fmt(result);
      const f = byName(fromUnit.value), t = byName(toUnit.value);
      const key = `${fromUnit.value}→${toUnit.value}`;
      const rule = FORMULAS[key] ? `  ·  ${FORMULAS[key]}` : '';
      formula.textContent = `${fmt(v)} ${f.sym} = ${fmt(result)} ${t.sym}${rule}`;

      const c = byName(fromUnit.value).toC(v);
      if (c < ABS_ZERO_C - 1e-9) {
        warn.textContent = 'Below absolute zero (−273.15 °C / 0 K) — not physically possible.';
        warn.classList.remove('hidden');
      }
    }
    renderAll(empty ? null : v);
  }

  // Every scale for the current input value, live. Beats competitors that only
  // show one target at a time.
  function renderAll(v: number | null) {
    const from = byName(fromUnit.value);
    const rows = SCALES.map((s) => {
      const out = v === null ? '' : fmt(s.fromC(from.toC(v)));
      const active = s.name === fromUnit.value ? ' text-ink' : ' text-ink-subtle';
      return `<tr class="border-t border-hairline first:border-t-0">
        <td class="px-3 py-2${active}">${s.name} <span class="text-ink-tertiary">${s.sym}</span></td>
        <td class="px-3 py-2 text-right font-mono text-ink">${out}</td>
        <td class="px-3 py-2 text-right">
          <button type="button" class="tc-rowcopy btn btn-tertiary px-2 py-0.5 text-[12px]" data-val="${out}" ${out === '' ? 'disabled' : ''}>Copy</button>
        </td>
      </tr>`;
    }).join('');
    allTable.innerHTML = `<table class="w-full text-[13px]">${rows}</table>`;
  }

  function renderPresets() {
    const presets: { label: string; c: number }[] = [
      { label: 'Absolute zero', c: -273.15 },
      { label: 'Water freezes', c: 0 },
      { label: 'Room temp', c: 20 },
      { label: 'Body temp', c: 37 },
      { label: 'Water boils', c: 100 },
    ];
    presetsWrap.innerHTML = presets
      .map((p) => `<button type="button" class="tc-preset btn btn-tertiary px-2 py-1 text-[13px]" data-c="${p.c}">${p.label}</button>`)
      .join('');
  }

  async function copyText(text: string, btn: HTMLButtonElement) {
    if (text === '') return;
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      // Clipboard API blocked (insecure context / permissions) — fall back.
      const ta = document.createElement('textarea');
      ta.value = text; document.body.appendChild(ta); ta.select();
      document.execCommand('copy'); ta.remove();
    }
    const prev = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = prev), 1200);
  }

  fromVal.addEventListener('input', convert);
  fromUnit.addEventListener('change', convert);
  toUnit.addEventListener('change', convert);
  precisionSel.addEventListener('change', convert);

  swap.addEventListener('click', () => {
    const a = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = a;
    if (toVal.value !== '') fromVal.value = String(convertValue(Number(fromVal.value), a, fromUnit.value));
    convert();
  });

  presetsWrap.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tc-preset') as HTMLButtonElement | null;
    if (!btn) return;
    fromUnit.value = 'Celsius';
    fromVal.value = btn.dataset.c!;
    convert();
  });

  allTable.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tc-rowcopy') as HTMLButtonElement | null;
    if (btn) copyText(btn.dataset.val ?? '', btn);
  });

  fillUnits();
  renderPresets();
  convert();

  // ponytail: one runnable check for the offset math (freezing / boiling / abs zero).
  const approx = (a: number, b: number) => Math.abs(a - b) < 1e-9;
  console.assert(approx(convertValue(0, 'Celsius', 'Fahrenheit'), 32), 'C→F freeze');
  console.assert(approx(convertValue(100, 'Celsius', 'Fahrenheit'), 212), 'C→F boil');
  console.assert(approx(convertValue(0, 'Celsius', 'Kelvin'), 273.15), 'C→K');
  console.assert(approx(convertValue(-273.15, 'Celsius', 'Kelvin'), 0), 'abs zero');
  console.assert(approx(convertValue(0, 'Celsius', 'Rankine'), 491.67), 'C→Rankine');
  console.assert(approx(convertValue(100, 'Celsius', 'Réaumur'), 80), 'C→Réaumur');
  console.assert(approx(convertValue(100, 'Celsius', 'Newton'), 33), 'C→Newton');
  console.assert(approx(convertValue(0, 'Celsius', 'Delisle'), 150), 'C→Delisle');
  console.assert(approx(convertValue(100, 'Celsius', 'Rømer'), 60), 'C→Rømer');
</script>

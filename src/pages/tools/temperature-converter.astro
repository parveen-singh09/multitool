---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="temperature-converter">
  <UnitConverter slug="temperature-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free temperature converter converts temperatures between Celsius, Fahrenheit, Kelvin and Rankine using exact offset formulas. Unlike simple multiplication, temperature needs offset handling, which this converter does correctly. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

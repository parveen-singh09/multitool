---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="domain-name-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Keyword
      <input id="dn-word" class="field" value="pixel" spellcheck="false" />
    </label>
    <div class="flex flex-wrap items-center gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="dn-count" type="number" min="6" max="60" value="24" class="field w-28" />
      </label>
      <button id="dn-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="dn-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <div id="dn-out" class="grid grid-cols-1 gap-2 sm:grid-cols-2"></div>
    <p class="text-[13px] text-ink-tertiary">Ideas only — check availability with a registrar before you buy.</p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free domain name generator turns a keyword into domain ideas across
      popular TLDs — .com, .io, .app, .dev, .co and more — using prefixes,
      suffixes and blends to surface names that stand a better chance of being
      available. It's a fast way to brainstorm a memorable web address. Click any
      idea to copy it, then check availability with your registrar. Runs in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { shuffle, pick } from '../../lib/random';
  import { TLDS } from '../../lib/fakedata';

  const $ = (id: string) => document.getElementById(id)!;
  const wordEl = $('dn-word') as HTMLInputElement;
  const countEl = $('dn-count') as HTMLInputElement;
  const out = $('dn-out')!;

  const PREFIX = ['get', 'try', 'go', 'my', 'the', 'join', 'use'];
  const SUFFIX = ['app', 'hq', 'ly', 'hub', 'lab', 'io', 'now', 'kit'];

  function generate() {
    const w = (wordEl.value.trim().toLowerCase().replace(/[^a-z0-9]/g, '') || 'brand');
    const n = Math.max(6, Math.min(60, Number(countEl.value) || 24));
    const roots = new Set<string>([w]);
    for (const p of PREFIX) roots.add(p + w);
    for (const s of SUFFIX) roots.add(w + s);
    const domains = new Set<string>();
    for (const r of roots) {
      const tld = pick(TLDS);
      domains.add(`${r}.${tld}`);
    }
    // Add a few explicit .com/.io for the base word.
    domains.add(`${w}.com`); domains.add(`${w}.io`); domains.add(`get${w}.com`);
    const list = shuffle([...domains]).slice(0, n);
    out.innerHTML = list.map((d) => `<button class="panel flex items-center justify-between px-4 py-2.5 text-left font-mono text-[14px] text-ink hover:border-hairline-strong" data-d="${d}"><span>${d}</span></button>`).join('');
    out.querySelectorAll('button').forEach((b) => b.addEventListener('click', async () => {
      await navigator.clipboard.writeText((b as HTMLElement).dataset.d!);
      const span = b.querySelector('span')!; const orig = span.textContent;
      span.textContent = 'Copied!'; setTimeout(() => (span.textContent = orig), 1000);
    }));
  }

  [wordEl, countEl].forEach((el) => el.addEventListener('input', generate));
  $('dn-gen').addEventListener('click', generate);
  $('dn-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const text = [...out.querySelectorAll('button')].map((b) => (b as HTMLElement).dataset.d).join('\n');
    await navigator.clipboard.writeText(text);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="domain-name-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Your keyword or idea
      <input
        id="dn-word"
        class="field text-lg"
        value="tool"
        spellcheck="false"
        autocomplete="off"
        placeholder="type an idea…"
      />
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Word style
        <select id="dn-style" class="field">
          <option value="common">Common words</option>
          <option value="daily">Daily-use words</option>
          <option value="professional">Professional</option>
          <option value="creative">Creative / invented</option>
          <option value="techy">Techy / startup</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Syllables (approx.)
        <input id="dn-syl" type="number" min="1" max="6" value="2" class="field" />
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="panel flex items-center justify-between gap-3 px-3 py-2">
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          <input id="dn-prefix-on" type="checkbox" class="h-4 w-4 accent-primary" />
          Add a prefix
        </label>
        <label class="flex items-center gap-1.5 text-[13px] text-ink-tertiary">
          letters
          <input id="dn-prefix-n" type="number" min="1" max="6" value="2" class="field w-16 py-1" />
        </label>
      </div>
      <div class="panel flex items-center justify-between gap-3 px-3 py-2">
        <label class="flex items-center gap-2 text-sm text-ink-subtle">
          <input id="dn-suffix-on" type="checkbox" class="h-4 w-4 accent-primary" />
          Add a suffix
        </label>
        <label class="flex items-center gap-1.5 text-[13px] text-ink-tertiary">
          letters
          <input id="dn-suffix-n" type="number" min="1" max="6" value="2" class="field w-16 py-1" />
        </label>
      </div>
    </div>

    <div class="flex flex-col gap-1.5">
      <div class="flex items-center gap-3 text-sm text-ink-subtle">
        <span>Domain types</span>
        <button id="dn-all" type="button" class="text-[12px] text-ink-tertiary hover:text-ink">Select all</button>
        <button id="dn-none" type="button" class="text-[12px] text-ink-tertiary hover:text-ink">Clear</button>
      </div>
      <div id="dn-tlds" class="flex flex-wrap gap-1.5" role="group" aria-label="Filter domain types"></div>
    </div>

    <div class="flex flex-wrap items-center gap-2.5">
      <button id="dn-gen" type="button" class="btn btn-primary">Generate names</button>
      <button id="dn-ai-gen" type="button" class="btn btn-primary bg-gradient-to-r from-primary via-[#7c5cff] to-[#a855f7] hover:opacity-90">✦ AI generate</button>
      <button id="dn-more" type="button" class="btn btn-secondary ml-auto hidden">Show more</button>
    </div>

    <div id="dn-status" class="text-[13px] text-ink-tertiary" aria-live="polite">Type an idea and hit Generate.</div>
    <div id="dn-out" class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3"></div>
    <p class="text-[13px] text-ink">
      Availability is a live DNS check — a green dot means the domain isn't
      resolving and is likely free, but only a registrar can confirm. Click any
      name to search it at a registrar.
    </p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink">
    <p>
      This free domain name generator turns a keyword into domain ideas across
      popular TLDs — .com, .io, .app, .dev, .co and more. Tune the word style
      (common, daily-use, professional, creative or techy), the number of
      syllables, and whether to add a short prefix or suffix of a given length,
      and the generator drafts brandable names to match. Each idea is then checked
      live against public DNS: a green dot means the name isn't resolving and is
      probably available, while a taken name is dimmed. The DNS check is a
      strong hint, not a guarantee — a registered domain that simply has no DNS
      records can still read as free — so click any name to confirm and register
      it.
    </p>
  </div>
</ToolLayout>


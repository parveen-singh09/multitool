  const MAX = 60;

  const TARGET = 30;

  const MAX_ROUNDS = 5;
  const MAX_CHECK = 300;

  const active = new Set<string>(['com', 'net', 'org', 'ai', 'io']);

  type State = 'checking' | 'free' | 'taken' | 'error';

  interface Settings {
    word: string;
    style: string;
    syllables: number;
    prefixLen: number; 
    suffixLen: number; 
  }

  function readSettings(): Settings {
    return {
      word: wordEl.value.trim().toLowerCase().replace(/[^a-z0-9]/g, ''),
      style: styleEl.value,
      syllables: clampNum(sylEl.value, 1, 6, 2),
      prefixLen: prefixOnEl.checked ? clampNum(prefixNEl.value, 1, 6, 2) : 0,
      suffixLen: suffixOnEl.checked ? clampNum(suffixNEl.value, 1, 6, 2) : 0,
    };
  }
  const clampNum = (v: string, lo: number, hi: number, dflt: number) =>
    Math.max(lo, Math.min(hi, Number(v) || dflt));

  const STYLE_HINT: Record<string, string> = {
    common: 'plain, common English words everyone knows',
    daily: 'everyday, daily-use conversational words',
    professional: 'polished, professional, business-appropriate words',
    creative: 'creative, invented, made-up brandable coinages',
    techy: 'modern techy / startup-flavored words',
  };

  function buildPrompt(s: Settings, exclude: string[] = []): string {
    const w = s.word;

    const parts = [
      `Generate 24 brandable domain name ideas. Every single name MUST contain the exact word "${w}" as a literal substring — do not replace it with synonyms or themed words.`,
    ];
    const style = STYLE_HINT[s.style] ?? 'brandable';

    if (s.prefixLen && s.suffixLen) {
      parts.push(`Build each name as: a ~${s.prefixLen}-letter prefix, then "${w}", then a ~${s.suffixLen}-letter suffix (e.g. "go${w}ify").`);
    } else if (s.prefixLen) {
      parts.push(`Build each name by prepending a ~${s.prefixLen}-letter prefix directly before "${w}" (e.g. "get${w}").`);
    } else if (s.suffixLen) {
      parts.push(`Build each name by appending a ~${s.suffixLen}-letter suffix directly after "${w}" (e.g. "${w}zone").`);
    } else {
      parts.push(`Combine "${w}" with another short word to make each name (e.g. "${w}hub", "my${w}").`);
    }
    parts.push(`Use ${style} vocabulary for the added prefix/suffix, roughly ${s.syllables} syllable(s) each.`);
    if (exclude.length) {
      // Keep the exclusion list bounded so the prompt can't balloon over rounds.
      const recent = exclude.slice(-80).join(', ');
      parts.push(`Do NOT reuse any of these already-suggested names: ${recent}. Give fresh, different ideas.`);
    }
    parts.push(
      'Return ONLY a JSON array of lowercase strings — just the name part, no TLD, no dots, no spaces, letters and digits only. No prose.',
    );
    return parts.join(' ');
  }

  /**
   * Extract clean second-level labels (no TLD) from the reply. Tolerates a
   * bare array, a ```json fence, or an array embedded in prose.
   */
  function parseNames(text: string): string[] {
    let arr: unknown;
    const match = text.match(/\[[\s\S]*\]/);
    try {
      arr = JSON.parse(match ? match[0] : text);
    } catch {
      return [];
    }
    if (!Array.isArray(arr)) return [];
    const seen = new Set<string>();
    for (const item of arr) {
      if (typeof item !== 'string') continue;

      const label = item.split('.')[0].toLowerCase().replace(/[^a-z0-9]/g, '');
      if (label.length >= 2 && label.length <= 30) seen.add(label);
    }
    return [...seen];
  }

  async function aiNames(s: Settings, exclude: string[] = []): Promise<string[]> {
    const content = await aiChat(
      [
        { role: 'system', content: 'You are a brandable domain name generator. You reply with a JSON array of lowercase name labels and nothing else.' },
        { role: 'user', content: buildPrompt(s, exclude) },
      ],
      { temperature: 0.9 },
    );

    const names = parseNames(content).filter((n) => n.includes(s.word));
    if (!names.length) throw new Error('no names parsed');
    return names;
  }

  function fallbackNames(s: Settings): string[] {
    const w = s.word;
    const labels = new Set<string>([w]);
    for (const p of PREFIX) labels.add(`${p}${w}`);
    for (const suf of SUFFIX) labels.add(`${w}${suf}`);
    return [...labels];
  }

  /** Expand name labels into full domains across the active TLDs, capped at MAX. */
  function expand(labels: string[]): string[] {
    const domains = new Set<string>();
    for (const label of labels) {
      for (const tld of TLDS) if (active.has(tld)) domains.add(`${label}.${tld}`);
    }
    return shuffle([...domains]).slice(0, MAX);
  }

  /**
   * Cloudflare DNS-over-HTTPS (CORS-enabled). Status 3 = NXDOMAIN → the name
   * doesn't resolve, so it's likely unregistered. Anything that resolves is
   * treated as taken. Network/parse failure → 'error' (shown as unknown).
   * ponytail: DNS is a heuristic, not a registry lookup — good enough for a
   * "which of these is free?" scan; the UI says so and links out to confirm.
   */
  async function checkDoh(domain: string, signal: AbortSignal): Promise<State> {
    try {
      const res = await fetch(
        `https://cloudflare-dns.com/dns-query?name=${encodeURIComponent(domain)}&type=A`,
        { headers: { accept: 'application/dns-json' }, signal },
      );
      if (!res.ok) return 'error';
      const data = await res.json();
      return data.Status === 3 ? 'free' : 'taken';
    } catch (e) {
      if ((e as Error).name === 'AbortError') throw e;
      return 'error';
    }
  }

  const DOT: Record<State, string> = {
    checking: 'bg-hairline-strong animate-pulse',
    free: 'bg-success',
    taken: 'bg-ink-tertiary',
    error: 'bg-ink-tertiary',
  };
  const LABEL: Record<State, string> = {
    checking: 'Checking…',
    free: 'Available',
    taken: 'Taken',
    error: 'Unknown',
  };

  function row(domain: string, state: State): string {
    const registrar = `https://www.namecheap.com/domains/registration/results/?domain=${encodeURIComponent(domain)}`;
    return `<a href="${registrar}" target="_blank" rel="noopener"
      class="panel flex items-center gap-3 px-4 py-2.5 font-mono text-sm text-ink hover:border-hairline-strong ${state === 'taken' ? 'opacity-55' : ''}"
      data-domain="${domain}">
      <span class="inline-block h-2 w-2 shrink-0 rounded-full ${DOT[state]}"></span>
      <span class="truncate">${domain}</span>
      <span class="ml-auto shrink-0 text-[12px] ${state === 'free' ? 'text-success' : 'text-ink-tertiary'}">${LABEL[state]}</span>
    </a>`;
  }

  // Bump on every new run so stale in-flight checks can bail out.
  let runId = 0;
  const CONCURRENCY = 8;
  // Last generated name labels, so TLD toggles re-expand without a new request.
  let currentLabels: string[] = [];

  // Persistent AI-run state so "Show more" resumes the same search instead of
  // restarting: results and tried labels accumulate across clicks.
  const moreEl = $('dn-more') as HTMLButtonElement;
  let aiStates: Map<string, State> | null = null;
  let aiTried: string[] = [];
  let aiSettings: Settings | null = null;
  // Each "Show more" click looks for this many additional available domains.
  const MORE_TARGET = 15;

  /** Hide the Show-more button and drop any resumable AI state. */
  function resetAi() {
    aiStates = null;
    aiTried = [];
    aiSettings = null;
    moreEl.classList.add('hidden');
  }

  /** Render the state map: available first, keyword-exact first, then short & alphabetical. */
  function renderStates(states: Map<string, State>, w: string) {
    const order: Record<State, number> = { free: 0, checking: 1, error: 2, taken: 3 };
    const sld = (d: string) => d.split('.')[0];
    const sorted = [...states].sort(([da, sa], [db, sb]) => {
      if (order[sa] !== order[sb]) return order[sa] - order[sb];
      const ma = sld(da) === w ? 0 : 1, mb = sld(db) === w ? 0 : 1;
      if (ma !== mb) return ma - mb;
      if (da.length !== db.length) return da.length - db.length;
      return da.localeCompare(db);
    });
    out.innerHTML = sorted.map(([d, s]) => row(d, s)).join('');
  }

  const freeCount = (states: Map<string, State>) =>
    [...states.values()].filter((s) => s === 'free').length;

  /**
   * DNS-check `list`, writing results into the shared `states` map and
   * re-rendering as each lands. Domains already in the map are left untouched,
   * so this can be called repeatedly to accumulate across AI rounds.
   */
  async function checkList(
    states: Map<string, State>,
    list: string[],
    controller: AbortController,
    mine: number,
    w: string,
  ) {
    for (const d of list) if (!states.has(d)) states.set(d, 'checking');
    renderStates(states, w);

    const queue = [...list];
    async function worker() {
      while (queue.length) {
        const domain = queue.shift()!;
        let state: State;
        try {
          state = await checkDoh(domain, controller.signal);
        } catch {
          return; // aborted — a newer run took over
        }
        if (mine !== runId) return; // superseded while awaiting
        states.set(domain, state);
        renderStates(states, w);
      }
    }
    await Promise.all(Array.from({ length: CONCURRENCY }, worker));
  }

  /** One-shot check of a full domain list (local path + TLD re-checks). */
  async function checkAll(list: string[], controller: AbortController) {
    const mine = runId;
    const w = readSettings().word;
    const states = new Map<string, State>();
    statusEl.textContent = `Checking ${list.length} names…`;
    await checkList(states, list, controller, mine, w);
    if (mine !== runId) return;
    statusEl.textContent = `${freeCount(states)} of ${list.length} look available.`;
  }

  /** Re-expand the current labels across the active TLDs and re-check. */
  function recheck() {
    if (!currentLabels.length) return;
    runId++;
    resetAi(); // TLD re-check owns the display now — drop resumable AI state.
    const list = expand(currentLabels);
    if (!list.length) {
      out.innerHTML = '';
      statusEl.textContent = 'Pick at least one domain type above.';
      return;
    }
    checkAll(list, new AbortController());
  }

  /** Local single pass: build affix names, then DNS-check them once. */
  async function generateLocal() {
    const s = readSettings();
    if (!s.word) {
      out.innerHTML = '';
      currentLabels = [];
      statusEl.textContent = 'Type a keyword to see available domains.';
      resetAi();
      return;
    }
    const mine = ++runId;
    resetAi();
    const labels = fallbackNames(s);
    currentLabels = labels;
    const list = expand(labels);
    if (!list.length) {
      out.innerHTML = '';
      statusEl.textContent = 'Pick at least one domain type above.';
      return;
    }
    if (mine !== runId) return;
    await checkAll(list, new AbortController());
  }

  /**
   * Shared AI loop: ask the model for fresh labels and DNS-check them,
   * accumulating into the module-scope aiStates/aiTried until `target` domains
   * look available or a backstop trips (MAX_ROUNDS requests / MAX_CHECK names
   * per invocation). Returns false if a newer run superseded this one.
   */
  async function runAiRounds(mine: number, controller: AbortController, target: number): Promise<boolean> {
    const s = aiSettings!;
    const states = aiStates!;
    const w = s.word;
    let checked = 0; // fresh per-invocation budget, so each "Show more" can work

    for (let round = 0; round < MAX_ROUNDS; round++) {
      if (freeCount(states) >= target || checked >= MAX_CHECK) break;

      statusEl.textContent =
        states.size === 0
          ? 'Generating name ideas…'
          : `Found ${freeCount(states)}/${target} available — searching more…`;

      let labels: string[];
      try {
        labels = await aiNames(s, aiTried);
      } catch {
        if (mine !== runId) return false;
        // First AI call of a fresh run failed — degrade to a single local
        // pass. Any later failure just stops and keeps what we've found.
        if (states.size === 0 && round === 0) {
          const fb = fallbackNames(s);
          currentLabels = fb;
          await checkList(states, expand(fb), controller, mine, w);
        }
        break;
      }
      if (mine !== runId) return false;

      // Only labels we haven't tried yet, expanded to unchecked domains,
      // trimmed to stay within this invocation's MAX_CHECK budget.
      const fresh = labels.filter((l) => !aiTried.includes(l));
      aiTried.push(...fresh);
      currentLabels = [...aiTried];
      let list = expand(fresh).filter((d) => !states.has(d));
      const remaining = MAX_CHECK - checked;
      if (list.length > remaining) list = list.slice(0, remaining);
      if (!list.length) continue;
      checked += list.length;

      await checkList(states, list, controller, mine, w);
      if (mine !== runId) return false;
    }
    return true;
  }

  /** Settle the AI status line and reveal "Show more" once results exist. */
  function finishAi() {
    const states = aiStates!;
    if (states.size === 0) {
      out.innerHTML = '';
      statusEl.textContent = 'No names to check — try a different keyword.';
      resetAi();
      return;
    }
    statusEl.textContent = `Found ${freeCount(states)} available after checking ${states.size} names.`;
    moreEl.classList.remove('hidden');
  }

  /**
   * AI run: keep asking the model until TARGET (30) domains look available.
   * Taken names stay visible, dimmed below the available ones. "Show more"
   * then resumes this same search for another batch.
   */
  async function generateAi() {
    const s = readSettings();
    if (!s.word) {
      out.innerHTML = '';
      currentLabels = [];
      statusEl.textContent = 'Type a keyword to see available domains.';
      resetAi();
      return;
    }
    if (active.size === 0) {
      out.innerHTML = '';
      statusEl.textContent = 'Pick at least one domain type above.';
      resetAi();
      return;
    }

    const mine = ++runId;
    aiSettings = s;
    aiStates = new Map<string, State>();
    aiTried = [];
    moreEl.classList.add('hidden');

    const ok = await runAiRounds(mine, new AbortController(), TARGET);
    if (!ok || mine !== runId) return;
    finishAi();
  }

  /** Resume the last AI search, looking for MORE_TARGET additional available names. */
  async function showMoreAi() {
    if (!aiStates || !aiSettings) return;
    const mine = ++runId;
    moreEl.disabled = true;
    const target = freeCount(aiStates) + MORE_TARGET;
    const ok = await runAiRounds(mine, new AbortController(), target);
    moreEl.disabled = false;
    if (!ok || mine !== runId) return;
    finishAi();
  }

  // ---- TLD filter chips ----
  const tldsEl = $('dn-tlds')!;
  function renderChips() {
    tldsEl.innerHTML = TLDS.map((tld) => {
      const on = active.has(tld);
      return `<button type="button" data-tld="${tld}" aria-pressed="${on}"
        class="rounded-full border px-2.5 py-1 font-mono text-[12px] transition-colors ${
          on
            ? 'border-primary/50 bg-primary/15 text-ink'
            : 'border-hairline text-ink hover:border-hairline-strong'
        }">.${tld}</button>`;
    }).join('');
  }
  tldsEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    const tld = btn.dataset.tld!;
    if (active.has(tld)) active.delete(tld);
    else active.add(tld);
    renderChips();
    recheck(); 
  });
  $('dn-all').addEventListener('click', () => {
    TLDS.forEach((t) => active.add(t));
    renderChips();
    recheck();
  });
  $('dn-none').addEventListener('click', () => {
    active.clear();
    renderChips();
    recheck();
  });
  renderChips();

  $('dn-gen').addEventListener('click', () => generateLocal());
  $('dn-ai-gen').addEventListener('click', () => generateAi());
  moreEl.addEventListener('click', () => showMoreAi());
  wordEl.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') generateLocal();
  });

  if (import.meta.env.DEV) {
    console.assert(JSON.stringify(parseNames('```json\n["Pixel","pixel.com","a b","zz"]\n```')) === JSON.stringify(['pixel', 'zz']), 'parseNames should clean, dedupe, strip TLDs');
    console.assert(parseNames('not json').length === 0, 'parseNames tolerates junk');
  }

  generateLocal(); 
</script>

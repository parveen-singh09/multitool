---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="htpasswd-generator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Username
        <input id="ht-user" class="field font-mono text-[13px]" value="admin" spellcheck="false" autocomplete="off" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Password
        <input id="ht-pass" class="field font-mono text-[13px]" value="s3cret" spellcheck="false" autocomplete="off" />
      </label>
    </div>
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Algorithm
        <select id="ht-alg" class="field w-56">
          <option value="bcrypt" selected>bcrypt (recommended)</option>
          <option value="sha1">SHA-1 (Apache SHA)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">bcrypt cost
        <input id="ht-cost" type="number" min="4" max="15" value="10" class="field w-24" />
      </label>
      <button id="ht-gen" type="button" class="btn btn-primary ml-auto">Generate</button>
    </div>
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">.htpasswd line
      <div class="copy-wrap">
        <input id="ht-out" class="field font-mono text-[13px]" readonly aria-label="htpasswd line" />
        <button type="button" class="copy-icon" data-copy-target="#ht-out" aria-label="Copy"></button>
      </div>
    </label>
    <p id="ht-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free .htpasswd generator creates the credential lines used for HTTP
      basic authentication on Apache and Nginx. Enter a username and password and
      pick a hashing scheme — bcrypt is strongly recommended over the legacy
      Apache SHA-1 form. Copy the resulting <code class="font-mono text-ink">user:hash</code>
      line into your <code class="font-mono text-ink">.htpasswd</code> file.
    </p>
  </div>
</ToolLayout>

<script>
  import { utf8, toBase64 } from '../../lib/encoding';

  const $ = (id: string) => document.getElementById(id)!;
  const userEl = $('ht-user') as HTMLInputElement;
  const passEl = $('ht-pass') as HTMLInputElement;
  const algEl = $('ht-alg') as HTMLSelectElement;
  const costEl = $('ht-cost') as HTMLInputElement;
  const outEl = $('ht-out') as HTMLInputElement;
  const err = $('ht-error')!;
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  async function generate() {
    const user = userEl.value.trim();
    if (!user) { setErr('Enter a username.'); return; }
    if (/[:]/.test(user)) { setErr('Username cannot contain a colon.'); return; }
    setErr('');
    let hash = '';
    if (algEl.value === 'bcrypt') {
      const mod = await import('bcryptjs');
      const bcrypt = (mod.default ?? mod) as typeof import('bcryptjs');
      const cost = Math.max(4, Math.min(15, Number(costEl.value) || 10));

      hash = bcrypt.hashSync(passEl.value, bcrypt.genSaltSync(cost)).replace(/^\$2[ab]\$/, '$2y$');
    } else {
      const digest = new Uint8Array(await crypto.subtle.digest('SHA-1', utf8(passEl.value)));
      hash = '{SHA}' + toBase64(digest);
    }
    outEl.value = `${user}:${hash}`;
  }

  [userEl, passEl, algEl, costEl].forEach((el) => el.addEventListener('input', generate));
  $('ht-gen').addEventListener('click', generate);
  generate();
</script>

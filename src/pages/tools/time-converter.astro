---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="time-converter">
  <UnitConverter slug="time-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free time converter converts durations between milliseconds, seconds, minutes, hours, days, weeks, months and years. Useful for scheduling, timeouts and quick estimates. All conversion happens in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

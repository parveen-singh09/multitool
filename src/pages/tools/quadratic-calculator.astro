---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="quadratic-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        a (x²)
        <input id="q-a" type="number" inputmode="decimal" step="any" class="field font-mono" value="3" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        b (x)
        <input id="q-b" type="number" inputmode="decimal" step="any" class="field font-mono" value="2" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        c
        <input id="q-c" type="number" inputmode="decimal" step="any" class="field font-mono" value="-5" />
      </label>
    </div>

    <div id="q-eq" class="text-center font-mono text-sm text-ink-muted">—</div>

    <p id="q-note" class="hidden text-[13px] text-ink-subtle" role="status"></p>
    <p id="q-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="panel panel-lift p-6 text-center"><div id="q-x1" class="font-mono text-2xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Root x₁</div></div>
      <div class="panel panel-lift p-6 text-center"><div id="q-x2" class="font-mono text-2xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Root x₂</div></div>
    </div>

    <div class="panel p-5">
      <div class="flex flex-col gap-2 text-sm">
        <div class="flex items-center justify-between border-t border-hairline pt-2 first:border-0 first:pt-0"><span class="text-ink-subtle">Discriminant (b²−4ac)</span><span id="q-disc" class="font-mono text-ink-muted">—</span></div>
        <div class="flex items-center justify-between border-t border-hairline pt-2 first:border-0 first:pt-0"><span class="text-ink-subtle">Nature of roots</span><span id="q-nature" class="font-mono text-ink-muted">—</span></div>
        <div class="flex items-center justify-between border-t border-hairline pt-2 first:border-0 first:pt-0"><span class="text-ink-subtle">Vertex</span><span id="q-vertex" class="font-mono text-ink-muted">—</span></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free quadratic equation calculator solves any equation of the form
      ax² + bx + c = 0 using the quadratic formula. Enter the coefficients a, b
      and c to get the real or complex roots, the discriminant, and the vertex of
      the parabola. It handles repeated roots and linear cases as well. All
      calculations run in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const aEl = document.getElementById('q-a') as HTMLInputElement;
  const bEl = document.getElementById('q-b') as HTMLInputElement;
  const cEl = document.getElementById('q-c') as HTMLInputElement;
  const eqEl = document.getElementById('q-eq')!;
  const noteEl = document.getElementById('q-note')!;
  const errEl = document.getElementById('q-error')!;
  const x1El = document.getElementById('q-x1')!;
  const x2El = document.getElementById('q-x2')!;
  const discEl = document.getElementById('q-disc')!;
  const natureEl = document.getElementById('q-nature')!;
  const vertexEl = document.getElementById('q-vertex')!;

  const fmt = (n: number): string => {
    if (!isFinite(n)) return '—';
    const r = Math.round(n * 1e6) / 1e6;
    return String(r);
  };

  // Build "3x² + 2x − 5 = 0" style echo.
  function term(coef: number, suffix: string, first: boolean): string {
    if (coef === 0) return '';
    const sign = coef < 0 ? '−' : first ? '' : '+';
    const abs = Math.abs(coef);
    const shown = abs === 1 && suffix !== '' ? '' : fmt(abs);
    const sep = first ? sign : ` ${sign} `;
    return `${sep}${shown}${suffix}`;
  }

  function echoEq(a: number, b: number, c: number): string {
    let out = term(a, 'x²', true);
    out += term(b, 'x', out === '');
    out += term(c, '', out === '');
    if (out === '') out = '0';
    return `${out} = 0`;
  }

  function setEmpty() {
    x1El.textContent = x2El.textContent = '—';
    discEl.textContent = natureEl.textContent = vertexEl.textContent = '—';
  }

  function calc() {
    noteEl.classList.add('hidden');
    errEl.classList.add('hidden');

    const a = parseFloat(aEl.value);
    const b = parseFloat(bEl.value);
    const c = parseFloat(cEl.value);

    if ([a, b, c].some((v) => isNaN(v))) {
      eqEl.textContent = '—';
      setEmpty();
      return;
    }

    eqEl.textContent = echoEq(a, b, c);

    // Linear / degenerate case.
    if (a === 0) {
      discEl.textContent = '—';
      vertexEl.textContent = '—';
      if (b === 0) {
        natureEl.textContent = c === 0 ? 'infinite' : 'none';
        x1El.textContent = x2El.textContent = '—';
        noteEl.textContent = c === 0 ? 'a = b = c = 0: every value of x is a solution.' : 'a = b = 0: no solution.';
        noteEl.classList.remove('hidden');
        return;
      }
      const x = -c / b;
      x1El.textContent = fmt(x);
      x2El.textContent = '—';
      natureEl.textContent = 'linear';
      noteEl.textContent = 'a = 0, so this is a linear equation with a single root.';
      noteEl.classList.remove('hidden');
      return;
    }

    const D = b * b - 4 * a * c;
    discEl.textContent = fmt(D);

    const vx = -b / (2 * a);
    const vy = a * vx * vx + b * vx + c;
    vertexEl.textContent = `(${fmt(vx)}, ${fmt(vy)})`;

    if (D > 0) {
      const sq = Math.sqrt(D);
      x1El.textContent = fmt((-b + sq) / (2 * a));
      x2El.textContent = fmt((-b - sq) / (2 * a));
      natureEl.textContent = 'two real roots';
    } else if (D === 0) {
      const r = -b / (2 * a);
      x1El.textContent = fmt(r);
      x2El.textContent = fmt(r);
      natureEl.textContent = 'one repeated root';
    } else {
      const p = -b / (2 * a);
      const q = Math.sqrt(-D) / (2 * a);
      const qa = Math.abs(q);
      x1El.textContent = `${fmt(p)} + ${fmt(qa)}i`;
      x2El.textContent = `${fmt(p)} − ${fmt(qa)}i`;
      natureEl.textContent = 'two complex roots';
    }
  }

  [aEl, bEl, cEl].forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

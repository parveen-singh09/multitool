---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="bmp-converter">
  <div class="flex flex-col gap-4">
    <label id="bm-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose images or drop them here</span>
      <span class="text-[13px] text-ink-tertiary">Converted to BMP in your browser — never uploaded. Batch supported.</span>
      <input id="bm-file" type="file" accept="image/*" multiple class="sr-only" />
    </label>

    <div id="bm-panel" class="hidden flex-col gap-4">
      <div class="panel panel-lift flex flex-wrap items-end gap-4 p-4">
        <label class="flex flex-col gap-1">
          <span class="eyebrow text-ink-subtle">Color depth</span>
          <select id="bm-depth" class="field" style="width:auto">
            <option value="24">24-bit (RGB, no compression)</option>
            <option value="32">32-bit (RGBA, keep transparency)</option>
            <option value="8">8-bit grayscale (256 levels)</option>
            <option value="1">1-bit monochrome (black &amp; white)</option>
          </select>
        </label>
        <label id="bm-bg-wrap" class="flex flex-col gap-1">
          <span class="eyebrow text-ink-subtle">Background</span>
          <span class="flex items-center gap-2">
            <input id="bm-bg" type="color" value="#ffffff" class="field" style="width:2.75rem;height:2.4rem;padding:0.15rem;cursor:pointer" aria-label="Flatten transparency onto this color" />
            <span class="text-[13px] text-ink-tertiary">for transparent pixels</span>
          </span>
        </label>
        <label id="bm-thresh-wrap" class="hidden flex-col gap-1">
          <span class="eyebrow text-ink-subtle">Threshold <span id="bm-thresh-val" class="text-ink-subtle">128</span></span>
          <input id="bm-thresh" type="range" min="1" max="254" value="128" class="accent-[#5e6ad2]" style="width:10rem" />
        </label>
        <div class="ml-auto flex items-center gap-3">
          <button id="bm-download-all" class="btn btn-secondary hidden">Download all</button>
        </div>
      </div>

      <div id="bm-list" class="grid gap-4" style="grid-template-columns:repeat(auto-fill,minmax(220px,1fr))"></div>
    </div>
    <p id="bm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free BMP converter turns JPG, PNG, WebP, GIF and other images into
      uncompressed Windows Bitmap (.bmp) files — one at a time or in a batch.
      BMP stores raw pixels with no compression, which some legacy software,
      embedded displays and imaging hardware require. Every file is encoded
      byte-by-byte in your browser from the image's pixels, so nothing is ever
      uploaded to a server.
    </p>
    <p>
      Pick the color depth that fits your target. <strong>24-bit</strong> is the
      universal default. <strong>32-bit</strong> keeps a real alpha channel for
      software that reads BMP transparency. <strong>8-bit grayscale</strong>
      writes a 256-level palette for compact monochrome output, and
      <strong>1-bit monochrome</strong> produces a true black-and-white bitmap
      with an adjustable threshold — ideal for fax, thermal printers and
      laser-engraving toolchains. For the palette and true-color depths,
      transparent pixels are flattened onto the background color you choose.
    </p>
    <p>
      Drop several images at once to convert them together, download each
      result individually, or grab them all in one click. Live previews render
      the actual encoded BMP so you see exactly what you'll get.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const fileInput = document.getElementById('bm-file') as HTMLInputElement;
  const drop = document.getElementById('bm-drop')!;
  const panel = document.getElementById('bm-panel')!;
  const list = document.getElementById('bm-list')!;
  const err = document.getElementById('bm-error')!;
  const depthSel = document.getElementById('bm-depth') as HTMLSelectElement;
  const bgInput = document.getElementById('bm-bg') as HTMLInputElement;
  const bgWrap = document.getElementById('bm-bg-wrap')!;
  const threshWrap = document.getElementById('bm-thresh-wrap')!;
  const threshInput = document.getElementById('bm-thresh') as HTMLInputElement;
  const threshVal = document.getElementById('bm-thresh-val')!;
  const downloadAll = document.getElementById('bm-download-all') as HTMLButtonElement;

  type Item = { name: string; data: ImageData; srcSize: number; blob: Blob | null; url: string; els: { img: HTMLImageElement; info: HTMLElement; btn: HTMLButtonElement } };
  const items: Item[] = [];

  const fmtSize = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;
  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }
  const bmpName = (n: string) => n.replace(/\.[^.]+$/, '') + '.bmp';
  const luma = (r: number, g: number, b: number) => 0.299 * r + 0.587 * g + 0.114 * b;
  function hexRgb(hex: string) { return { r: parseInt(hex.slice(1, 3), 16), g: parseInt(hex.slice(3, 5), 16), b: parseInt(hex.slice(5, 7), 16) }; }

  // Encode ImageData into an uncompressed BMP at the requested depth.
  // depth 24: BGR · 32: BGRA (alpha kept) · 8: grayscale palette · 1: monochrome palette.
  function encodeBmp(data: ImageData, depth: number, bg: { r: number; g: number; b: number }, threshold: number): Blob {
    const { width, height, data: px } = data;
    const palette = depth === 8 ? 256 : depth === 1 ? 2 : 0;
    const rowSize = Math.floor((depth * width + 31) / 32) * 4; // 4-byte aligned
    const pixelArraySize = rowSize * height;
    const dataOffset = 54 + palette * 4;
    const fileSize = dataOffset + pixelArraySize;
    const buf = new ArrayBuffer(fileSize);
    const dv = new DataView(buf);
    const u8 = new Uint8Array(buf);
    // BITMAPFILEHEADER
    dv.setUint16(0, 0x4d42, true);            // 'BM'
    dv.setUint32(2, fileSize, true);
    dv.setUint32(10, dataOffset, true);       // pixel data offset
    // BITMAPINFOHEADER
    dv.setUint32(14, 40, true);
    dv.setInt32(18, width, true);
    dv.setInt32(22, height, true);            // positive => bottom-up
    dv.setUint16(26, 1, true);                // planes
    dv.setUint16(28, depth, true);            // bpp
    dv.setUint32(34, pixelArraySize, true);
    dv.setInt32(38, 2835, true);              // 72 DPI x
    dv.setInt32(42, 2835, true);              // 72 DPI y
    dv.setUint32(46, palette, true);          // biClrUsed
    // Color table (grayscale / monochrome)
    if (depth === 8) {
      for (let i = 0; i < 256; i++) { const p = 54 + i * 4; u8[p] = i; u8[p + 1] = i; u8[p + 2] = i; }
    } else if (depth === 1) {
      // index 0 = black, index 1 = white
      u8[54] = 0; u8[55] = 0; u8[56] = 0;
      u8[58] = 255; u8[59] = 255; u8[60] = 255;
    }
    // composite RGBA onto the chosen background (for non-alpha depths)
    const compose = (i: number) => {
      const a = px[i + 3] / 255;
      return {
        r: Math.round(px[i] * a + bg.r * (1 - a)),
        g: Math.round(px[i + 1] * a + bg.g * (1 - a)),
        b: Math.round(px[i + 2] * a + bg.b * (1 - a)),
      };
    };
    // pixel array, bottom-up
    let off = dataOffset;
    for (let y = height - 1; y >= 0; y--) {
      const rowStart = off;
      if (depth === 1) {
        let bits = 0, nbits = 0;
        for (let x = 0; x < width; x++) {
          const { r, g, b } = compose((y * width + x) * 4);
          const white = luma(r, g, b) >= threshold ? 1 : 0;
          bits = (bits << 1) | white; nbits++;
          if (nbits === 8) { u8[off++] = bits; bits = 0; nbits = 0; }
        }
        if (nbits > 0) u8[off++] = bits << (8 - nbits); // pad final partial byte
      } else {
        for (let x = 0; x < width; x++) {
          const i = (y * width + x) * 4;
          if (depth === 32) {
            u8[off++] = px[i + 2]; u8[off++] = px[i + 1]; u8[off++] = px[i]; u8[off++] = px[i + 3];
          } else {
            const { r, g, b } = compose(i);
            if (depth === 8) { u8[off++] = Math.round(luma(r, g, b)); }
            else { u8[off++] = b; u8[off++] = g; u8[off++] = r; }
          }
        }
      }
      off = rowStart + rowSize; // pad row to alignment
    }
    return new Blob([buf], { type: 'image/bmp' });
  }

  function reencode(item: Item) {
    const depth = Number(depthSel.value);
    const bg = hexRgb(bgInput.value);
    const threshold = Number(threshInput.value);
    if (item.url) URL.revokeObjectURL(item.url);
    item.blob = encodeBmp(item.data, depth, bg, threshold);
    item.url = URL.createObjectURL(item.blob);
    item.els.img.src = item.url;
    const labels: Record<number, string> = { 24: '24-bit', 32: '32-bit', 8: '8-bit gray', 1: '1-bit' };
    item.els.info.textContent = `${item.data.width}×${item.data.height} · ${labels[depth]} · ${fmtSize(item.srcSize)} → ${fmtSize(item.blob.size)}`;
  }

  function reencodeAll() {
    const depth = Number(depthSel.value);
    bgWrap.classList.toggle('hidden', depth === 32);
    threshWrap.classList.toggle('hidden', depth !== 1);
    threshWrap.classList.toggle('flex', depth === 1);
    for (const it of items) reencode(it);
  }

  function download(blob: Blob, name: string) {
    const a = document.createElement('a');
    a.download = name; a.href = URL.createObjectURL(blob); a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 4000);
  }

  function addItem(file: File, data: ImageData) {
    const card = document.createElement('div');
    card.className = 'panel flex flex-col gap-3 p-3';
    card.innerHTML = `
      <div class="flex items-center justify-center overflow-hidden rounded-md" style="background:repeating-conic-gradient(#141516 0 25%,#0f1011 0 50%) 0 0/16px 16px;min-height:9rem">
        <img class="max-h-40 w-auto max-w-full" alt="BMP preview" />
      </div>
      <div class="truncate text-[13px] text-ink" title="${bmpName(file.name)}">${bmpName(file.name)}</div>
      <div class="text-[12px] text-ink-subtle"></div>
      <button class="btn btn-primary" style="padding:6px 12px">Download</button>`;
    const img = card.querySelector('img') as HTMLImageElement;
    const info = card.querySelector('.text-\\[12px\\]') as HTMLElement;
    const btn = card.querySelector('button') as HTMLButtonElement;
    const item: Item = { name: bmpName(file.name), data, srcSize: file.size, blob: null, url: '', els: { img, info, btn } };
    btn.addEventListener('click', () => { if (item.blob) download(item.blob, item.name); });
    items.push(item);
    list.appendChild(card);
    reencode(item);
  }

  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth; canvas.height = img.naturalHeight;
        const ctx = canvas.getContext('2d')!;
        ctx.drawImage(img, 0, 0);
        try {
          const data = ctx.getImageData(0, 0, canvas.width, canvas.height);
          addItem(file, data);
          panel.classList.remove('hidden'); panel.classList.add('flex');
          downloadAll.classList.toggle('hidden', items.length < 2);
        } catch { setErr('Could not read image pixels (the image may be from another origin).'); }
      };
      img.onerror = () => setErr(`Could not read "${file.name}".`);
      img.src = reader.result as string;
    };
    reader.onerror = () => setErr(`Could not read "${file.name}".`);
    reader.readAsDataURL(file);
  }

  function loadFiles(files: FileList | File[]) {
    setErr('');
    const imgs = Array.from(files).filter((f) => f.type.startsWith('image/'));
    if (!imgs.length) { setErr('Please choose image files.'); return; }
    imgs.forEach(loadFile);
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.length) loadFiles(fileInput.files); });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files; if (f?.length) loadFiles(f); });

  depthSel.addEventListener('change', reencodeAll);
  bgInput.addEventListener('input', reencodeAll);
  threshInput.addEventListener('input', () => { threshVal.textContent = threshInput.value; reencodeAll(); });
  downloadAll.addEventListener('click', () => { items.forEach((it, i) => { if (it.blob) setTimeout(() => download(it.blob!, it.name), i * 150); }); });
</script>

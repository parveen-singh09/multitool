---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="bmp-converter">
  <div class="flex flex-col gap-4">
    <label id="bm-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an image or drop it here</span>
      <span class="text-[13px] text-ink-tertiary">Converted to BMP in your browser — never uploaded</span>
      <input id="bm-file" type="file" accept="image/*" class="sr-only" />
    </label>

    <div id="bm-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-center gap-3">
        <button id="bm-download" class="btn btn-primary">Download BMP</button>
        <span id="bm-info" class="text-[13px] text-ink-subtle"></span>
      </div>
      <div class="panel flex justify-center overflow-hidden p-4"><img id="bm-preview" class="max-h-96 w-auto max-w-full rounded-md" alt="BMP preview" /></div>
    </div>
    <p id="bm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free BMP converter turns JPG, PNG, WebP and other images into
      uncompressed 24-bit Windows Bitmap (.bmp) files. BMP stores raw pixels
      with no compression, which some legacy software and hardware require. The
      BMP is encoded byte-by-byte in your browser from the image's pixels, so
      your file is never uploaded to any server.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const fileInput = document.getElementById('bm-file') as HTMLInputElement;
  const drop = document.getElementById('bm-drop')!;
  const panel = document.getElementById('bm-panel')!;
  const preview = document.getElementById('bm-preview') as HTMLImageElement;
  const info = document.getElementById('bm-info')!;
  const err = document.getElementById('bm-error')!;
  let bmpBlob: Blob | null = null;

  const fmtSize = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;
  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }

  // Encode ImageData into a 24-bit uncompressed BMP (BITMAPINFOHEADER).
  function encodeBmp(data: ImageData): Blob {
    const { width, height, data: px } = data;
    const rowSize = Math.floor((24 * width + 31) / 32) * 4; // padded to 4 bytes
    const pixelArraySize = rowSize * height;
    const fileSize = 54 + pixelArraySize;
    const buf = new ArrayBuffer(fileSize);
    const dv = new DataView(buf);
    // BITMAPFILEHEADER
    dv.setUint16(0, 0x4d42, true); // 'BM'
    dv.setUint32(2, fileSize, true);
    dv.setUint32(10, 54, true); // pixel data offset
    // BITMAPINFOHEADER
    dv.setUint32(14, 40, true);
    dv.setInt32(18, width, true);
    dv.setInt32(22, height, true); // positive => bottom-up
    dv.setUint16(26, 1, true); // planes
    dv.setUint16(28, 24, true); // bpp
    dv.setUint32(34, pixelArraySize, true);
    dv.setInt32(38, 2835, true); // 72 DPI x
    dv.setInt32(42, 2835, true); // 72 DPI y
    // pixel array, bottom-up, BGR
    let offset = 54;
    for (let y = height - 1; y >= 0; y--) {
      let rowStart = offset;
      for (let x = 0; x < width; x++) {
        const i = (y * width + x) * 4;
        // composite onto white for transparency
        const a = px[i + 3] / 255;
        const r = Math.round(px[i] * a + 255 * (1 - a));
        const g = Math.round(px[i + 1] * a + 255 * (1 - a));
        const b = Math.round(px[i + 2] * a + 255 * (1 - a));
        dv.setUint8(offset++, b);
        dv.setUint8(offset++, g);
        dv.setUint8(offset++, r);
      }
      offset = rowStart + rowSize; // pad
    }
    return new Blob([buf], { type: 'image/bmp' });
  }

  function loadFile(file: File) {
    setErr('');
    const reader = new FileReader();
    reader.onload = () => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth; canvas.height = img.naturalHeight;
        const ctx = canvas.getContext('2d')!;
        ctx.drawImage(img, 0, 0);
        try {
          const data = ctx.getImageData(0, 0, canvas.width, canvas.height);
          bmpBlob = encodeBmp(data);
          preview.src = URL.createObjectURL(bmpBlob);
          info.textContent = `${canvas.width}×${canvas.height} · ${fmtSize(file.size)} → ${fmtSize(bmpBlob.size)}`;
          panel.classList.remove('hidden'); panel.classList.add('flex');
        } catch { setErr('Could not read image pixels (the image may be from another origin).'); }
      };
      img.onerror = () => setErr('Could not read that image file.');
      img.src = reader.result as string;
    };
    reader.readAsDataURL(file);
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) loadFile(f); });
  document.getElementById('bm-download')!.addEventListener('click', () => {
    if (!bmpBlob) return;
    const a = document.createElement('a'); a.download = 'converted.bmp'; a.href = URL.createObjectURL(bmpBlob); a.click();
  });
</script>

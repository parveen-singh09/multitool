---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="javascript-formatter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="jsf-beautify" class="btn btn-primary">Beautify</button>
      <button id="jsf-minify" class="btn btn-secondary">Minify</button>
      <button id="jsf-copy" class="btn btn-secondary">Copy</button>
      <button id="jsf-clear" class="btn btn-tertiary">Clear</button>
      <span id="jsf-stats" class="ml-auto text-xs text-ink-tertiary"></span>
    </div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <label class="flex items-center gap-2">
        Indent
        <select id="jsf-indent" class="field w-auto py-1">
          <option value="2">2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <label class="flex items-center gap-2">
        Wrap
        <select id="jsf-width" class="field w-auto py-1">
          <option value="80" selected>80 cols</option>
          <option value="100">100 cols</option>
          <option value="120">120 cols</option>
          <option value="999999">No wrap</option>
        </select>
      </label>
      <label class="flex items-center gap-2">
        Quotes
        <select id="jsf-quote" class="field w-auto py-1">
          <option value="double">Double</option>
          <option value="single">Single</option>
        </select>
      </label>
      <label class="flex items-center gap-2">
        <input id="jsf-semi" type="checkbox" class="accent-primary" checked />
        Semicolons
      </label>
    </div>

    <div id="jsf-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="hl-edit field p-0" style="height:22rem;resize:vertical;overflow:hidden">
      <pre class="hl-block" aria-hidden="true"><code id="jsf-input-hl" class="hljs" style="background:transparent"></code></pre>
      <textarea
        id="jsf-input"
        spellcheck="false"
        autocapitalize="off"
        autocomplete="off"
        autocorrect="off"
        placeholder="Paste JavaScript here, e.g. function add(a,b){return a+b}"
        aria-label="JavaScript input"
      ></textarea>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free JavaScript formatter runs your code through the Prettier engine
      for clean, standards-compliant output — consistent indentation, line
      breaks, quote style and spacing that goes beyond a simple re-indenter.
      Choose 2-space, 4-space or tab indentation, set a wrap width, switch
      between single and double quotes, and toggle semicolons. A Minify option
      strips comments and extra whitespace to shrink file size while preserving
      strings, template literals and regular expressions. If Prettier can't
      parse a partial or invalid snippet, the formatter falls back to a
      brace-depth re-indenter so you still get readable output.
    </p>
  </div>
</ToolLayout>

<script>
  import { wireInput } from '../../lib/highlight';

  const input = document.getElementById('jsf-input') as HTMLTextAreaElement;
  const inHl = document.getElementById('jsf-input-hl')!;
  const status = document.getElementById('jsf-status')!;
  const stats = document.getElementById('jsf-stats')!;
  const indentSel = document.getElementById('jsf-indent') as HTMLSelectElement;
  const widthSel = document.getElementById('jsf-width') as HTMLSelectElement;
  const quoteSel = document.getElementById('jsf-quote') as HTMLSelectElement;
  const semiChk = document.getElementById('jsf-semi') as HTMLInputElement;

  const refresh = wireInput(input, inHl, () => 'javascript');

  function indentInfo() {
    const v = indentSel.value;
    return v === 'tab'
      ? { useTabs: true, tabWidth: 2, unit: '\t' }
      : { useTabs: false, tabWidth: Number(v), unit: ' '.repeat(Number(v)) };
  }

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  let prettier: any = null;
  let plugins: any[] = [];
  let loading: Promise<void> | null = null;
  function loadPrettier() {
    if (prettier) return Promise.resolve();
    if (loading) return loading;
    loading = Promise.all([
      import('prettier/standalone'),
      import('prettier/plugins/babel'),
      import('prettier/plugins/estree'),
    ]).then(([p, babel, estree]) => {
      prettier = (p as any).default ?? p;
      plugins = [(babel as any).default ?? babel, (estree as any).default ?? estree];
    });
    return loading;
  }

  function fallbackBeautify(code: string, unit: string): string {
    const src = code.replace(/\r\n/g, '\n');
    let out = '';
    let depth = 0;
    let i = 0;
    const n = src.length;

    const newline = () => {
      out = out.replace(/[ \t]+$/, '');
      out += '\n' + unit.repeat(Math.max(depth, 0));
    };

    while (i < n) {
      const c = src[i];
      const next = src[i + 1];

      if (c === '/' && next === '/') {
        const end = src.indexOf('\n', i);
        const stop = end === -1 ? n : end;
        out = out.replace(/[ \t]+$/, '') + (out.endsWith('\n') || out === '' ? '' : ' ') + src.slice(i, stop);
        i = stop;
        continue;
      }
      if (c === '/' && next === '*') {
        const end = src.indexOf('*/', i + 2);
        const stop = end === -1 ? n : end + 2;
        out += src.slice(i, stop);
        i = stop;
        continue;
      }
      if (c === '"' || c === "'" || c === '`') {
        const quote = c;
        let j = i + 1;
        let buf = c;
        while (j < n) {
          const ch = src[j];
          buf += ch;
          if (ch === '\\') {
            buf += src[j + 1] ?? '';
            j += 2;
            continue;
          }
          if (ch === quote) {
            j++;
            break;
          }
          j++;
        }
        out += buf;
        i = j;
        continue;
      }

      if (c === '{') {
        out = out.replace(/[ \t]+$/, '');
        if (out !== '' && !out.endsWith('\n')) out += ' ';
        out += '{';
        depth++;
        newline();
        i++;
        while (i < n && /[ \t]/.test(src[i])) i++;
        continue;
      }
      if (c === '}') {
        depth = Math.max(depth - 1, 0);
        out = out.replace(/[ \t]*$/, '');
        if (!out.endsWith('\n')) out += '\n';
        out += unit.repeat(depth) + '}';
        i++;
        while (i < n && /[ \t]/.test(src[i])) i++;
        if (src[i] === ';') {
          out += ';';
          i++;
        }
        newline();
        while (i < n && /[ \t]/.test(src[i])) i++;
        continue;
      }
      if (c === ';') {
        out += ';';
        i++;
        while (i < n && /[ \t]/.test(src[i])) i++;
        if (src[i] !== '\n') newline();
        continue;
      }
      if (c === '\n') {
        if (!out.endsWith('\n')) newline();
        i++;
        while (i < n && /[ \t]/.test(src[i])) i++;
        continue;
      }
      if (/[ \t]/.test(c)) {
        if (!/[ \t]$/.test(out) && !out.endsWith('\n') && out !== '') out += ' ';
        i++;
        continue;
      }
      out += c;
      i++;
    }

    return out
      .split('\n')
      .map((l) => l.replace(/[ \t]+$/, ''))
      .filter((l, idx, arr) => !(l.trim() === '' && arr[idx - 1]?.trim() === ''))
      .join('\n')
      .trim();
  }

  async function beautify(code: string): Promise<{ text: string; fell_back: boolean }> {
    const { useTabs, tabWidth, unit } = indentInfo();
    await loadPrettier();
    try {
      const text = (await prettier.format(code, {
        parser: 'babel',
        plugins,
        useTabs,
        tabWidth,
        printWidth: Number(widthSel.value),
        singleQuote: quoteSel.value === 'single',
        semi: semiChk.checked,
      })).replace(/\n$/, '');
      return { text, fell_back: false };
    } catch {

      return { text: fallbackBeautify(code, unit), fell_back: true };
    }
  }

  function minify(code: string): string {
    const src = code.replace(/\r\n/g, '\n');
    let out = '';
    let i = 0;
    const n = src.length;
    while (i < n) {
      const c = src[i];
      const next = src[i + 1];
      if (c === '/' && next === '/') {
        const end = src.indexOf('\n', i);
        i = end === -1 ? n : end;
        continue;
      }
      if (c === '/' && next === '*') {
        const end = src.indexOf('*/', i + 2);
        i = end === -1 ? n : end + 2;
        continue;
      }
      if (c === '"' || c === "'" || c === '`') {
        const quote = c;
        let j = i + 1;
        out += c;
        while (j < n) {
          const ch = src[j];
          out += ch;
          if (ch === '\\') {
            out += src[j + 1] ?? '';
            j += 2;
            continue;
          }
          if (ch === quote) {
            j++;
            break;
          }
          j++;
        }
        i = j;
        continue;
      }
      if (/\s/.test(c)) {

        let j = i;
        while (j < n && /\s/.test(src[j])) j++;
        const prev = out[out.length - 1] || '';
        const nextCh = src[j] || '';
        if (/[\w$]/.test(prev) && /[\w$]/.test(nextCh)) out += ' ';
        i = j;
        continue;
      }
      out += c;
      i++;
    }
    return out.trim();
  }

  async function process(doMinify: boolean) {
    const src = input.value.trim();
    if (!src) return;
    if (doMinify) {
      const before = src.length;
      const result = minify(src);
      input.value = result;
      refresh();
      stats.textContent = `${before} → ${result.length} chars (${Math.round((1 - result.length / before) * 100)}% smaller)`;
      showStatus('Minified ✓', true);
    } else {
      const { text, fell_back } = await beautify(src);
      input.value = text;
      refresh();
      stats.textContent = `${text.length} chars · ${text.split('\n').length} lines`;
      if (fell_back) showStatus("Formatted with fallback (Prettier couldn't parse the input)", false);
      else showStatus('Formatted ✓', true);
    }
  }

  document.getElementById('jsf-beautify')!.addEventListener('click', () => process(false));
  document.getElementById('jsf-minify')!.addEventListener('click', () => process(true));
  document.getElementById('jsf-clear')!.addEventListener('click', () => {
    input.value = '';
    refresh();
    stats.textContent = '';
    status.classList.add('hidden');
  });
  document.getElementById('jsf-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('jsf-copy')!;
    await navigator.clipboard.writeText(input.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { LOCALES } from '../../lib/locales';
---

<ToolLayout slug="random-user-profile-generator">
  <div class="flex flex-col gap-5">

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="ru-count" type="number" min="1" max="500" value="6" class="field w-24" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Gender
        <select id="ru-sex" class="field w-32">
          <option value="any" selected>Any</option>
          <option value="female">Female</option>
          <option value="male">Male</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Nationality
        <select id="ru-nat" class="field w-48">
          <option value="any" selected>Any nationality</option>
          {LOCALES.map((l) => <option value={l.key}>{l.flag} {l.label}</option>)}
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center gap-1 whitespace-nowrap">Seed <span class="text-ink-tertiary">(optional)</span></span>
        <input id="ru-seed" type="text" placeholder="e.g. project-x" class="field w-40" />
      </label>
      <button id="ru-gen" class="btn btn-primary ml-auto">Generate</button>
    </div>

    <div id="ru-cards" class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>

    <div class="flex flex-col gap-3">
      <div class="flex flex-wrap items-center gap-2">
        <div class="flex overflow-hidden rounded-md border border-hairline" role="tablist" aria-label="Export format">
          <button data-fmt="json" class="ru-fmt btn-fmt is-active">JSON</button>
          <button data-fmt="csv" class="ru-fmt btn-fmt">CSV</button>
          <button data-fmt="xml" class="ru-fmt btn-fmt">XML</button>
          <button data-fmt="yaml" class="ru-fmt btn-fmt">YAML</button>
        </div>
        <button id="ru-download" class="btn btn-secondary ml-auto">Download</button>
      </div>
      <div class="copy-wrap">
        <pre class="hl-block field min-h-80" style="resize:vertical;overflow:auto" aria-label="Generated profiles"><code id="ru-out" class="hljs font-mono text-[13px]" style="background:transparent;padding:0"></code></pre>
        <button type="button" class="copy-icon" data-copy-target="#ru-out" aria-label="Copy"></button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free random user profile generator creates complete fake user records —
      title, name, username, email, password, phone, cell, UUID, full address with
      coordinates and timezone, date of birth, age, and registration date — for
      <strong class="text-ink-muted">25 nationalities</strong>, each with locally
      authentic names, cities, phone and postcode formats. Every profile comes with a
      deterministic SVG avatar.
    </p>
    <p>
      Enter a <strong class="text-ink-muted">seed</strong> to make output fully
      reproducible — the same seed always regenerates the exact same people, so your
      test fixtures stay stable across runs. Leave it blank for cryptographically
      random results. Export as JSON, CSV, XML, or YAML and drop the data straight
      into tests, seeds, and API mocks.
    </p>
  </div>
</ToolLayout>

<style>

  @font-face {
    font-family: 'Twemoji Country Flags';
    unicode-range: U+1F1E6-1F1FF;
    src: url('https://cdn.jsdelivr.net/npm/country-flag-emoji-polyfill@0.1/dist/TwemojiCountryFlags.woff2') format('woff2');
    font-display: swap;
  }
  #ru-nat { font-family: 'Twemoji Country Flags', var(--font-sans); }

  .btn-fmt {
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-ink-subtle, #8a8f98);
    background: var(--color-canvas, #010102);
    border-right: 1px solid var(--color-hairline, #23252a);
  }
  .btn-fmt:last-child { border-right: 0; }
  .btn-fmt.is-active {
    background: var(--color-surface-2, #141516);
    color: var(--color-ink, #f7f8f8);
  }
</style>

<script>
  import { createAvatar } from '@dicebear/core';
  import { avataaars } from '@dicebear/collection';
  import { setSeed } from '../../lib/random';
  import { profile, type Sex, type Profile } from '../../lib/fakegen';
  import { serialize, MIME, type Format } from '../../lib/exportformats';

  const $ = (id: string) => document.getElementById(id)!;
  const countEl = $('ru-count') as HTMLInputElement;
  const sexEl = $('ru-sex') as HTMLSelectElement;
  const natEl = $('ru-nat') as HTMLSelectElement;
  const seedEl = $('ru-seed') as HTMLInputElement;
  const out = $('ru-out') as HTMLElement;
  const cards = $('ru-cards');

  let profiles: Profile[] = [];
  let fmt: Format = 'json';
  let raw = ''; 

  const HL_LANG: Record<Format, string> = { json: 'json', csv: 'plaintext', xml: 'xml', yaml: 'yaml' };

  let hljs: any = null;
  async function loadHljs() {
    if (!hljs) hljs = (await import('highlight.js')).default;
    return hljs;
  }

  function avatarSvg(p: Profile): string {
    return createAvatar(avataaars, { seed: p.uuid, size: 56, radius: 50 }).toString();
  }

  function card(p: Profile): string {
    const l = p.location;

    const flag = `<img src="https://flagcdn.com/24x18/${p.nat.toLowerCase()}.png" width="20" height="15" alt="${esc(p.nationality)}" title="${esc(p.nationality)}" class="shrink-0 rounded-[2px]" loading="lazy" />`;
    return `<div class="panel flex items-center gap-3 p-3">
      <div class="shrink-0">${avatarSvg(p)}</div>
      <div class="min-w-0 flex flex-col gap-0.5">
        <span class="flex items-center gap-1.5 truncate font-display text-[15px] font-medium text-ink">${flag}<span class="truncate">${p.title}. ${esc(p.fullName)}</span></span>
        <span class="truncate text-[13px] text-ink-subtle">${esc(p.email)}</span>
        <span class="truncate text-[12px] text-ink-tertiary">${esc(l.city)}, ${p.nat} · age ${p.age}</span>
      </div>
    </div>`;
  }

  function esc(s: string): string {
    return s.replace(/[<>&"]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' }[c]!));
  }

  async function renderOutput() {
    raw = serialize(profiles, fmt);
    const h = await loadHljs();
    const lang = h.getLanguage(HL_LANG[fmt]) ? HL_LANG[fmt] : 'plaintext';
    out.innerHTML = h.highlight(raw, { language: lang, ignoreIllegal: true }).value;
  }

  function render() {
    cards.innerHTML = profiles.slice(0, 60).map(card).join('');
    void renderOutput();
  }

  function generate() {
    const n = Math.max(1, Math.min(500, Number(countEl.value) || 1));
    // Seed the shared RNG so a seed reproduces avatars, addresses, everything.
    setSeed(seedEl.value.trim() || null);
    profiles = [];
    for (let i = 0; i < n; i++) {
      profiles.push(profile({ sex: sexEl.value as Sex, nat: natEl.value }));
    }
    setSeed(null); // restore CSPRNG for any other tool on the page
    render();
  }

  // Format tabs
  document.querySelectorAll<HTMLButtonElement>('.ru-fmt').forEach((b) => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.ru-fmt').forEach((x) => x.classList.remove('is-active'));
      b.classList.add('is-active');
      fmt = b.dataset.fmt as Format;
      void renderOutput();
    });
  });

  [countEl, sexEl, natEl].forEach((el) => el.addEventListener('input', generate));
  seedEl.addEventListener('input', generate);
  $('ru-gen').addEventListener('click', generate);

  $('ru-download').addEventListener('click', () => {
    const blob = new Blob([raw], { type: MIME[fmt] });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `profiles.${fmt}`;
    a.click();
    URL.revokeObjectURL(url);
  });

  generate();
</script>

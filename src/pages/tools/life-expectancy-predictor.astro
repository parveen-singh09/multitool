---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="life-expectancy-predictor">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Your current age
        <input id="lep-age" type="number" min="1" max="110" step="1" value="30" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Sex
        <select id="lep-sex" class="field">
          <option value="f">Female</option>
          <option value="m">Male</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Smoking
        <select id="lep-smoke" class="field">
          <option value="0">Never smoked</option>
          <option value="1">Former smoker</option>
          <option value="2">Current smoker</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Exercise
        <select id="lep-exercise" class="field">
          <option value="2">Active (most days)</option>
          <option value="1">Some (weekly)</option>
          <option value="0">Rarely / never</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Diet
        <select id="lep-diet" class="field">
          <option value="2">Healthy &amp; balanced</option>
          <option value="1">Average</option>
          <option value="0">Poor</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Alcohol
        <select id="lep-alcohol" class="field">
          <option value="0">None / rare</option>
          <option value="1">Moderate</option>
          <option value="2">Heavy</option>
        </select>
      </label>
    </div>

    <button id="lep-go" type="button" class="btn btn-primary self-start">Estimate lifespan</button>

    <p id="lep-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="panel panel-lift p-4 text-center">
      <div id="lep-result" class="font-display text-2xl font-semibold text-primary-hover">—</div>
      <div class="mt-1 text-[13px] text-ink-subtle">Rough estimated life expectancy</div>
    </div>

    <div class="grid grid-cols-2 gap-3 text-center">
      <div class="panel p-4"><div id="lep-remaining" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Estimated years remaining</div></div>
      <div class="panel p-4"><div id="lep-baseline" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Baseline for your sex</div></div>
    </div>

    <div class="panel p-4 text-[13px] text-ink-muted">
      This adjusts a rough baseline using broad averages. It is not a medical
      calculation and cannot account for your individual health.
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free life expectancy predictor gives a rough estimate of how long you
      might live based on a few lifestyle inputs: your age, sex, smoking status,
      exercise, diet and alcohol use. It starts from a general baseline and nudges
      it up or down using broad population averages. Everything runs in your
      browser and nothing is stored.
    </p>
    <p>
      For entertainment only — this is a novelty tool and not medical, scientific
      or professional advice.
    </p>
  </div>
</ToolLayout>

<script>
  const ageEl = document.getElementById('lep-age') as HTMLInputElement;
  const sexEl = document.getElementById('lep-sex') as HTMLSelectElement;
  const smokeEl = document.getElementById('lep-smoke') as HTMLSelectElement;
  const exerciseEl = document.getElementById('lep-exercise') as HTMLSelectElement;
  const dietEl = document.getElementById('lep-diet') as HTMLSelectElement;
  const alcoholEl = document.getElementById('lep-alcohol') as HTMLSelectElement;
  const go = document.getElementById('lep-go') as HTMLButtonElement;
  const err = document.getElementById('lep-error')!;
  const result = document.getElementById('lep-result')!;
  const remaining = document.getElementById('lep-remaining')!;
  const baselineEl = document.getElementById('lep-baseline')!;

  function estimate() {
    err.classList.add('hidden');
    const age = parseInt(ageEl.value, 10);

    if (isNaN(age) || age < 1 || age > 110) {
      err.textContent = 'Enter an age between 1 and 110.';
      err.classList.remove('hidden');
      result.textContent = '—';
      remaining.textContent = '—';
      baselineEl.textContent = '—';
      return;
    }

    const baseline = sexEl.value === 'm' ? 76 : 81;
    let years = baseline;

    // Smoking
    if (smokeEl.value === '1') years -= 2;
    else if (smokeEl.value === '2') years -= 9;

    // Exercise
    if (exerciseEl.value === '2') years += 3;
    else if (exerciseEl.value === '0') years -= 3;

    // Diet
    if (dietEl.value === '2') years += 2;
    else if (dietEl.value === '0') years -= 3;

    // Alcohol
    if (alcoholEl.value === '1') years -= 1;
    else if (alcoholEl.value === '2') years -= 5;

    // Keep the estimate at or beyond the person's current age.
    const finalAge = Math.max(years, age + 1);
    const yearsLeft = Math.max(finalAge - age, 0);

    result.textContent = `${Math.round(finalAge)} years`;
    remaining.textContent = String(Math.round(yearsLeft));
    baselineEl.textContent = `${baseline} years`;
  }

  go.addEventListener('click', estimate);
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="iban-generator">
  <div class="flex flex-col gap-4">
    <div class="panel flex items-start gap-3 p-4">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-ink-subtle" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20ZM12 8v5M12 16h.01"/></svg>
      <p class="text-[13px] leading-relaxed text-ink-subtle">These IBANs are <strong class="text-ink">format-valid test values</strong> with a correct mod-97 check — they are <strong class="text-ink">not real bank accounts</strong> and cannot receive funds. Use them for validation and form testing only.</p>
    </div>
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Country
        <select id="ib-country" class="field w-44">
          <option value="DE" selected>Germany (DE)</option>
          <option value="GB">United Kingdom (GB)</option>
          <option value="FR">France (FR)</option>
          <option value="ES">Spain (ES)</option>
          <option value="NL">Netherlands (NL)</option>
          <option value="IT">Italy (IT)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="ib-count" type="number" min="1" max="500" value="5" class="field w-28" />
      </label>
      <button id="ib-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="ib-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <textarea id="ib-out" class="field min-h-56 resize-y font-mono text-[13px]" readonly aria-label="Generated IBANs"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free IBAN generator creates international bank account numbers with a
      valid mod-97 checksum for several European countries. Each IBAN follows the
      correct country length and structure so it passes standard validation, which
      makes it ideal for testing payment and banking forms. The account numbers
      themselves are random and do not belong to anyone. Generated in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { iban } from '../../lib/fakegen';

  const $ = (id: string) => document.getElementById(id)!;
  const countryEl = $('ib-country') as HTMLSelectElement;
  const countEl = $('ib-count') as HTMLInputElement;
  const out = $('ib-out') as HTMLTextAreaElement;

  function generate() {
    const n = Math.max(1, Math.min(500, Number(countEl.value) || 1));
    const list: string[] = [];
    for (let i = 0; i < n; i++) list.push(iban(countryEl.value as any));
    out.value = list.join('\n');
  }

  [countryEl, countEl].forEach((el) => el.addEventListener('input', generate));
  $('ib-gen').addEventListener('click', generate);
  $('ib-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

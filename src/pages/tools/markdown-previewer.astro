---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="markdown-previewer">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="md-download" class="btn btn-secondary">Download .md</button>
      <button id="md-clear" class="btn btn-tertiary">Clear</button>
      <button id="md-reset" class="btn btn-tertiary">Reset</button>
      <label class="ml-auto flex items-center gap-2 text-[13px] text-ink-subtle">
        <input id="md-sync" type="checkbox" checked class="accent-primary" />
        Sync scroll
      </label>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Markdown
        <div class="copy-wrap">
          <div
            id="md-in"
            class="cm-host field min-h-[28rem] resize-y overflow-hidden p-0"
            aria-label="Markdown input"></div>
          <button type="button" id="md-copy-md" class="copy-icon" aria-label="Copy Markdown"></button>
        </div>
      </label>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        Preview
        <div class="copy-wrap">
          <div
            id="md-out"
            class="md-preview panel panel-lift min-h-[28rem] overflow-y-auto p-5 text-ink"
            aria-label="Rendered preview"
            aria-live="polite"></div>
          <button type="button" id="md-copy-html" class="copy-icon" aria-label="Copy HTML"></button>
        </div>
      </div>
    </div>

    <p id="md-stats" class="text-[13px] text-ink-tertiary"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Markdown previewer renders GitHub Flavored Markdown to HTML live
      as you type. It supports headings, bold, italic and strikethrough text,
      links and images, ordered, unordered and nested lists, task lists, tables,
      blockquotes, inline code and fenced code blocks, and horizontal rules.
    </p>
    <p>
      Copy the rendered HTML or the raw Markdown, download your document as a
      <code>.md</code> file, and toggle synced scrolling between the editor and
      preview.
    </p>
  </div>
</ToolLayout>

<style is:global>
  .md-preview { word-wrap: break-word; }
  .md-preview > :first-child { margin-top: 0; }
  .md-preview > :last-child { margin-bottom: 0; }
  .md-preview h1, .md-preview h2, .md-preview h3,
  .md-preview h4, .md-preview h5, .md-preview h6 {
    font-weight: 600; margin: 1em 0 0.4em; letter-spacing: -0.02em; line-height: 1.25;
  }
  .md-preview h1 { font-size: 1.7rem; padding-bottom: 0.3em; border-bottom: 1px solid var(--color-hairline); }
  .md-preview h2 { font-size: 1.35rem; padding-bottom: 0.25em; border-bottom: 1px solid var(--color-hairline); }
  .md-preview h3 { font-size: 1.15rem; }
  .md-preview h4 { font-size: 1rem; }
  .md-preview h5 { font-size: 0.9rem; }
  .md-preview h6 { font-size: 0.85rem; color: var(--color-ink-subtle); }
  .md-preview p { margin: 0.6em 0; line-height: 1.65; }
  .md-preview ul, .md-preview ol { margin: 0.6em 0; padding-left: 1.6em; }
  .md-preview ul { list-style: disc; }
  .md-preview ol { list-style: decimal; }
  .md-preview li { margin: 0.25em 0; }
  .md-preview li > ul, .md-preview li > ol { margin: 0.25em 0; }
  .md-preview li.task-list-item { list-style: none; margin-left: -1.4em; }
  .md-preview li.task-list-item input { margin-right: 0.5em; vertical-align: middle; }
  .md-preview a { color: var(--color-primary-hover); text-decoration: underline; }
  .md-preview blockquote {
    border-left: 3px solid var(--color-hairline-strong);
    padding: 0.1em 1em; margin: 0.8em 0; color: var(--color-ink-subtle);
  }
  .md-preview code {
    font-family: var(--font-mono); font-size: 0.85em;
    background: var(--color-surface-2); padding: 2px 6px; border-radius: 4px;
  }
  .md-preview pre {
    background: var(--color-surface-2); padding: 0.9em 1em; border-radius: 8px;
    overflow-x: auto; margin: 0.8em 0; border: 1px solid var(--color-hairline);
  }
  .md-preview pre code { background: none; padding: 0; font-size: 0.85em; line-height: 1.6; }
  .md-preview strong { font-weight: 600; color: var(--color-ink); }
  .md-preview del { color: var(--color-ink-subtle); }
  .md-preview hr { border: none; border-top: 1px solid var(--color-hairline); margin: 1.2em 0; }
  .md-preview img { max-width: 100%; border-radius: 8px; }
  .md-preview table { border-collapse: collapse; margin: 0.8em 0; width: 100%; font-size: 0.9em; }
  .md-preview th, .md-preview td { border: 1px solid var(--color-hairline-strong); padding: 6px 12px; text-align: left; }
  .md-preview th { background: var(--color-surface-2); font-weight: 600; }
  .md-preview tr:nth-child(even) td { background: var(--color-surface-1); }
  .md-preview .mermaid-diagram {
    margin: 0.8em 0; padding: 1em; text-align: center;
    background: var(--color-surface-2); border: 1px solid var(--color-hairline); border-radius: 8px;
  }
  .md-preview .mermaid-diagram svg { max-width: 100%; height: auto; }
</style>

<script>
  import { marked } from 'marked';
  import DOMPurify from 'dompurify';
  import { EditorView, basicSetup } from 'codemirror';
  import { EditorState } from '@codemirror/state';
  import { markdown } from '@codemirror/lang-markdown';
  import { HighlightStyle, syntaxHighlighting } from '@codemirror/language';
  import { tags as t } from '@lezer/highlight';

  const SAMPLE = `# Hello ToolSilk

Write **Markdown** on the left and see _rendered_ HTML on the right.

## Features

- GitHub Flavored Markdown
- Tables, task lists, ~~strikethrough~~
- Nested lists
  1. Ordered
  2. And nested
     - bullets too

- [x] Renders live
- [ ] Runs on a server

> Everything runs in your browser.

\`inline code\` and a fenced block:

\`\`\`js
const greet = (name) => \`Hello, \${name}!\`;
console.log(greet('world'));
\`\`\`

| Tool | Private | Free |
| --- | :---: | :---: |
| Markdown Previewer | ✅ | ✅ |

\`\`\`mermaid
graph TD
  A[Start] --> B{Decision}
  B -->|Yes| C[Finish]
  B -->|No| D[Alternate]
\`\`\`

[Free tools](https://toolsilk.com)
`;

  marked.setOptions({ gfm: true, breaks: false });

  const host = document.getElementById('md-in')!;
  const out = document.getElementById('md-out')!;
  const stats = document.getElementById('md-stats')!;
  const sync = document.getElementById('md-sync') as HTMLInputElement;

  const mdHighlight = HighlightStyle.define([
    { tag: t.heading, color: 'var(--color-primary-hover)', fontWeight: '600' },
    { tag: t.strong, color: 'var(--color-ink)', fontWeight: '600' },
    { tag: t.emphasis, color: 'var(--color-ink-muted)', fontStyle: 'italic' },
    { tag: t.strikethrough, textDecoration: 'line-through', color: 'var(--color-ink-subtle)' },
    { tag: [t.link, t.url], color: 'var(--color-primary)' },
    { tag: [t.monospace], color: 'var(--color-semantic-success)' },
    { tag: [t.list, t.quote], color: 'var(--color-ink-subtle)' },
    { tag: t.processingInstruction, color: 'var(--color-primary)' },
  ]);

  const cmTheme = EditorView.theme({
    '&': { backgroundColor: 'transparent', color: 'var(--color-ink)', height: '100%', fontSize: '13px' },
    '.cm-content': { fontFamily: 'var(--font-mono)', padding: '12px 0' },
    '.cm-gutters': { backgroundColor: 'transparent', color: 'var(--color-ink-tertiary)', border: 'none' },
    '.cm-activeLine, .cm-activeLineGutter': { backgroundColor: 'transparent' },
    '&.cm-focused': { outline: 'none' },
    '.cm-cursor': { borderLeftColor: 'var(--color-ink)' },
    '.cm-selectionBackground, ::selection': { backgroundColor: 'var(--color-surface-3)' },
  }, { dark: true });

  const editor = new EditorView({
    parent: host,
    state: EditorState.create({
      doc: '',
      extensions: [
        basicSetup,
        markdown(),
        syntaxHighlighting(mdHighlight),
        cmTheme,
        EditorView.lineWrapping,
        EditorView.updateListener.of((u) => { if (u.docChanged) render(); }),
      ],
    }),
  });

  const getDoc = () => editor.state.doc.toString();
  function setDoc(text: string) {
    editor.dispatch({ changes: { from: 0, to: editor.state.doc.length, insert: text } });
  }

  function render() {
    const src = getDoc();
    out.innerHTML = DOMPurify.sanitize(marked.parse(src) as string);
    const words = src.trim() ? src.trim().split(/\s+/).length : 0;
    const lines = src ? src.split('\n').length : 0;
    stats.textContent = `${words} words · ${src.length} characters · ${lines} lines`;
    renderMermaid();
  }

  // Mermaid renders on demand: the library only loads when a mermaid block is present.
  let mermaidReady = false;
  let mmdId = 0;
  let mermaidToken = 0;
  async function renderMermaid() {
    const token = ++mermaidToken;
    const blocks = out.querySelectorAll<HTMLElement>('code.language-mermaid');
    if (!blocks.length) return;
    const { default: mermaid } = await import('mermaid');
    if (!mermaidReady) {
      mermaid.initialize({ startOnLoad: false, theme: 'dark', securityLevel: 'strict' });
      mermaidReady = true;
    }
    if (token !== mermaidToken) return; // superseded by a newer render
    for (const code of blocks) {
      const pre = code.closest('pre') ?? code;
      try {
        const { svg } = await mermaid.render(`mmd-${mmdId++}`, code.textContent ?? '');
        if (token !== mermaidToken) return;
        const wrap = document.createElement('div');
        wrap.className = 'mermaid-diagram';
        wrap.innerHTML = svg;
        pre.replaceWith(wrap);
      } catch {
        // Incomplete/invalid diagram while typing — leave the code block as-is.
      }
    }
  }

  // Proportional sync scroll: editor drives preview. (render() runs via CodeMirror's updateListener.)
  editor.scrollDOM.addEventListener('scroll', () => {
    if (!sync.checked) return;
    const s = editor.scrollDOM;
    const ratio = s.scrollTop / (s.scrollHeight - s.clientHeight || 1);
    out.scrollTop = ratio * (out.scrollHeight - out.clientHeight);
  });

  // These copy JS-derived values (rendered HTML / editor doc), not the preview
  // elements' textContent, so they need a local handler. Reuses the global
  // `.copied` green-check styling.
  function iconCopy(id: string, label: string, getText: () => string) {
    const btn = document.getElementById(id)!;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(getText());
        btn.classList.add('copied');
        btn.setAttribute('aria-label', 'Copied');
        setTimeout(() => { btn.classList.remove('copied'); btn.setAttribute('aria-label', label); }, 1500);
      } catch {}
    });
  }
  iconCopy('md-copy-html', 'Copy HTML', () => out.innerHTML);
  iconCopy('md-copy-md', 'Copy Markdown', () => getDoc());
  document.getElementById('md-download')!.addEventListener('click', () => {
    const blob = new Blob([getDoc()], { type: 'text/markdown' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'document.md';
    a.click();
    URL.revokeObjectURL(a.href);
  });
  document.getElementById('md-clear')!.addEventListener('click', () => {
    setDoc('');
    editor.focus();
  });
  document.getElementById('md-reset')!.addEventListener('click', () => {
    setDoc(SAMPLE);
  });

  setDoc(SAMPLE);
</script>

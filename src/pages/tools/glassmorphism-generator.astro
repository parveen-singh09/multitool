---
import ToolLayout from '../../layouts/ToolLayout.astro';

const backgrounds = [
  'linear-gradient(135deg,#5e6ad2,#e05299 60%,#f5a623)',
  'linear-gradient(135deg,#0f2027,#203a43,#2c5364)',
  'radial-gradient(circle at 20% 20%,#ff8a00,#e52e71 60%,#9d50bb)',
  'conic-gradient(from 210deg at 50% 50%,#5e6ad2,#27a644,#f5a623,#e05299,#5e6ad2)',
  'linear-gradient(135deg,#141516,#23252a)',
];

const presets = [
  { name: 'Frosted', blur: 12, alpha: 15, sat: 180, refraction: 40, depth: 10, radius: 16, border: 30 },
  { name: 'Clear', blur: 6, alpha: 8, sat: 120, refraction: 25, depth: 6, radius: 20, border: 20 },
  { name: 'Heavy', blur: 28, alpha: 25, sat: 200, refraction: 60, depth: 22, radius: 24, border: 40 },
  { name: 'Crystal', blur: 18, alpha: 10, sat: 160, refraction: 80, depth: 14, radius: 28, border: 50 },
];
---

<ToolLayout slug="glassmorphism-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-3">
      <div class="flex flex-wrap gap-2">
        {presets.map((p) => (
          <button
            type="button"
            class="btn btn-secondary text-xs"
            data-preset={JSON.stringify(p)}
          >{p.name}</button>
        ))}
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Blur: <span id="gm-bv" class="text-ink">12px</span>
        <input id="gm-blur" type="range" min="0" max="40" value="12" class="w-full accent-[#5e6ad2]" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Transparency: <span id="gm-tv" class="text-ink">0.15</span>
        <input id="gm-alpha" type="range" min="0" max="100" value="15" class="w-full accent-[#5e6ad2]" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Saturation: <span id="gm-sv" class="text-ink">180%</span>
        <input id="gm-sat" type="range" min="100" max="300" value="180" class="w-full accent-[#5e6ad2]" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Refraction: <span id="gm-fv" class="text-ink">0.40</span>
        <input id="gm-refraction" type="range" min="0" max="100" value="40" class="w-full accent-[#5e6ad2]" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Depth: <span id="gm-dv" class="text-ink">10</span>
        <input id="gm-depth" type="range" min="0" max="40" value="10" class="w-full accent-[#5e6ad2]" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Radius: <span id="gm-rv" class="text-ink">16px</span>
        <input id="gm-radius" type="range" min="0" max="48" value="16" class="w-full accent-[#5e6ad2]" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Border: <span id="gm-brv" class="text-ink">0.30</span>
        <input id="gm-borderw" type="range" min="0" max="100" value="30" class="w-full accent-[#5e6ad2]" />
      </label>
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Tint
          <input id="gm-color" type="color" value="#ffffff" class="field h-10 w-16 cursor-pointer p-1" />
        </label>
      </div>
    </div>

    <div class="flex flex-col gap-4">
      <div id="gm-stage" class="flex min-h-56 items-center justify-center rounded-lg p-8" style={`background:${backgrounds[0]}`}>
        <div id="gm-box" class="glass-card flex h-32 w-48 items-center justify-center text-sm font-medium text-white">Glass card</div>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <button id="gm-photo" type="button" class="flex h-8 w-8 items-center justify-center rounded-md border border-hairline text-sm" aria-label="Random photo">🌳</button>
        {backgrounds.map((bg, i) => (
          <button
            type="button"
            class="h-8 w-8 rounded-md border border-hairline"
            style={`background:${bg}`}
            data-bg={bg}
            aria-label={`Background ${i + 1}`}
          ></button>
        ))}
      </div>
      <div class="flex items-start gap-2">
        <code id="gm-css" class="field whitespace-pre-wrap font-mono text-xs hl-block hljs"></code>
        <button id="gm-copy" class="btn btn-secondary whitespace-nowrap">Copy</button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free glassmorphism generator designs the frosted-glass effect popular
      in modern UI — a translucent surface with a background blur behind it. Tune
      the blur, transparency, saturation, refraction, depth, corner radius, border
      and tint, preview the card over several gradients, and copy the full CSS —
      including the multi-layer shadow and the edge-highlight
      <code class="font-mono text-ink">::before</code> /
      <code class="font-mono text-ink">::after</code> pseudo-elements. Refraction
      controls the strength of the light edges; depth controls the shadow lift.
      The <code class="font-mono text-ink">-webkit-</code> prefix for Safari is
      included. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<style is:global>
  #gm-box { position: relative; overflow: hidden; }
</style>

<script>
  import { hl } from '../../lib/highlight';
  const $ = (id: string) => document.getElementById(id)!;
  const cssEl = $('gm-css')!;
  let rawOutput = '';
  const styleTag = document.createElement('style');
  document.head.appendChild(styleTag);
  const inputs = ['gm-blur', 'gm-alpha', 'gm-sat', 'gm-refraction', 'gm-depth', 'gm-radius', 'gm-borderw', 'gm-color'];

  function buildCss(sel: string) {
    const blur = Number(($('gm-blur') as HTMLInputElement).value);
    const alpha = Number(($('gm-alpha') as HTMLInputElement).value) / 100;
    const sat = Number(($('gm-sat') as HTMLInputElement).value);
    const refr = Number(($('gm-refraction') as HTMLInputElement).value) / 100; 
    const depth = Number(($('gm-depth') as HTMLInputElement).value);
    const radius = Number(($('gm-radius') as HTMLInputElement).value);
    const bw = Number(($('gm-borderw') as HTMLInputElement).value) / 100; 
    const color = ($('gm-color') as HTMLInputElement).value;

    $('gm-bv').textContent = `${blur}px`;
    $('gm-tv').textContent = alpha.toFixed(2);
    $('gm-sv').textContent = `${sat}%`;
    $('gm-fv').textContent = refr.toFixed(2);
    $('gm-dv').textContent = `${depth}`;
    $('gm-rv').textContent = `${radius}px`;
    $('gm-brv').textContent = bw.toFixed(2);

    const n = parseInt(color.slice(1), 16);
    const rgb = `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
    // Depth drives an outer drop shadow; refraction drives the inset light highlights.
    const outer = `0 ${depth}px ${(depth * 2.5).toFixed(0)}px rgba(0, 0, 0, ${(0.08 + depth * 0.008).toFixed(2)})`;
    const insetTop = `inset 0 1px 1px rgba(255, 255, 255, ${(0.5 * refr).toFixed(2)})`;
    const insetBottom = `inset 0 -1px 1px rgba(255, 255, 255, ${(0.15 * refr).toFixed(2)})`;
    const edge = (0.6 * refr).toFixed(2);

    const base =
`${sel} {
  background: rgba(${rgb}, ${alpha});
  border-radius: ${radius}px;
  backdrop-filter: blur(${blur}px) saturate(${sat}%);
  -webkit-backdrop-filter: blur(${blur}px) saturate(${sat}%);
  border: 1px solid rgba(255, 255, 255, ${bw.toFixed(2)});
  box-shadow: ${outer}, ${insetTop}, ${insetBottom};
  position: relative;
  overflow: hidden;
}`;
    const before =
`${sel}::before {
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, ${edge}), transparent);
}`;
    const after =
`${sel}::after {
  content: "";
  position: absolute;
  inset: 0 auto 0 0;
  width: 1px;
  background: linear-gradient(180deg, transparent, rgba(255, 255, 255, ${edge}), transparent);
}`;
    return `${base}\n${before}\n${after}`;
  }

  function update() {
    styleTag.textContent = buildCss('#gm-box'); // live preview, exact incl. pseudo-elements
    rawOutput = buildCss('.glass-card'); // copyable output
    hl(cssEl, rawOutput, 'css');
  }

  inputs.forEach((id) => $(id).addEventListener('input', update));

  document.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((btn) =>
    btn.addEventListener('click', () => {
      const p = JSON.parse(btn.dataset.preset!);
      (['blur', 'alpha', 'sat', 'refraction', 'depth', 'radius'] as const).forEach((k) => {
        ($(`gm-${k}`) as HTMLInputElement).value = String(p[k]);
      });
      ($('gm-borderw') as HTMLInputElement).value = String(p.border);
      update();
    })
  );

  document.querySelectorAll<HTMLButtonElement>('[data-bg]').forEach((btn) =>
    btn.addEventListener('click', () => {
      $('gm-stage').style.background = btn.dataset.bg!;
    })
  );

  $('gm-photo').addEventListener('click', () => {
    // picsum: keyless random photo; nature-ish, new one each click via changing seed.
    const seed = Math.floor(Math.random() * 1000);
    const url = `https://picsum.photos/seed/${seed}/800/600`;
    $('gm-stage').style.background = `center / cover no-repeat url("${url}")`;
  });

  $('gm-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(rawOutput);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });

  update();
</script>

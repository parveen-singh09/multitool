---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="data-matrix-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Data to encode
      <textarea id="dm-text" class="field min-h-24 resize-y font-mono text-[13px]" placeholder="Enter text or numbers…" spellcheck="false">TOOLCITIES-2026</textarea>
    </label>

    <div class="flex justify-center rounded-[8px] border border-hairline bg-white p-6">
      <canvas id="dm-canvas" class="max-w-full"></canvas>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="dm-png" type="button" class="btn btn-primary">Download PNG</button>
      <button id="dm-svg" type="button" class="btn btn-secondary">Download SVG</button>
    </div>
    <p id="dm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Data Matrix generator encodes any text or numbers into a compact
      Data Matrix 2D barcode — the square dot-matrix code widely used to mark
      small parts, electronics and documents because it packs a lot of data into
      a tiny footprint. Type your content, preview the code, and download it as a
      crisp PNG or scalable SVG. Everything is encoded in your browser, so your
      data never leaves your device.
    </p>
  </div>
</ToolLayout>

<script>
  import { toCanvas, toSVG } from '../../lib/barcode';

  const textEl = document.getElementById('dm-text') as HTMLTextAreaElement;
  const canvas = document.getElementById('dm-canvas') as HTMLCanvasElement;
  const err = document.getElementById('dm-error')!;
  const BCID = 'datamatrix';

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  async function draw() {
    const text = textEl.value.trim();
    if (!text) { setErr('Enter some text to encode.'); return; }
    try {
      await toCanvas(canvas, { bcid: BCID, text, scale: 5 });
      setErr('');
    } catch (e) {
      setErr('Could not encode that data.');
    }
  }

  function download(href: string, name: string) {
    const a = document.createElement('a'); a.href = href; a.download = name; a.click();
  }

  let t: number;
  textEl.addEventListener('input', () => { clearTimeout(t); t = window.setTimeout(draw, 200); });
  document.getElementById('dm-png')!.addEventListener('click', () => download(canvas.toDataURL('image/png'), 'datamatrix.png'));
  document.getElementById('dm-svg')!.addEventListener('click', async () => {
    try {
      const svg = await toSVG({ bcid: BCID, text: textEl.value.trim(), scale: 5 });
      const url = URL.createObjectURL(new Blob([svg], { type: 'image/svg+xml' }));
      download(url, 'datamatrix.svg');
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch { setErr('Could not encode that data.'); }
  });

  draw();
</script>

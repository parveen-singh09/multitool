---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="api-key-generator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Prefix
        <input id="ak-prefix" class="field font-mono" placeholder="sk_live_" value="sk_live_" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bytes of entropy
        <select id="ak-bytes" class="field">
          <option value="16">16 bytes</option>
          <option value="24" selected>24 bytes</option>
          <option value="32">32 bytes</option>
          <option value="48">48 bytes</option>
          <option value="64">64 bytes</option>
          <option value="128">128 bytes</option>
          <option value="256">256 bytes</option>
          <option value="512">512 bytes</option>
          <option value="1024">1024 bytes</option>
          <option value="2048">2048 bytes</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Encoding
        <select id="ak-enc" class="field">
          <option value="base62" selected>base62</option>
          <option value="hex">hex</option>
          <option value="base64url">base64url</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="ak-count" type="number" min="1" max="200" value="5" class="field" />
      </label>
    </div>
    <div class="flex flex-wrap items-center gap-4">
      <button id="ak-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="ak-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <textarea id="ak-out" class="field min-h-56 resize-y font-mono text-[13px]" readonly aria-label="Generated API keys"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free API key generator creates high-entropy keys with an optional
      prefix — the <code class="font-mono text-ink">sk_live_</code>-style prefix
      pattern popularized by Stripe makes keys easy to recognize and scope. Choose
      how many random bytes to use and whether to encode them as base62, hex or
      base64url. Keys are generated with the Web Crypto API in your browser and
      never transmitted anywhere.
    </p>
  </div>
</ToolLayout>

<script>
  import { randBytes } from '../../lib/random';
  import { toHex, toBase62, toBase64Url } from '../../lib/encoding';

  const $ = (id: string) => document.getElementById(id)!;
  const prefixEl = $('ak-prefix') as HTMLInputElement;
  const bytesEl = $('ak-bytes') as HTMLSelectElement;
  const encEl = $('ak-enc') as HTMLSelectElement;
  const countEl = $('ak-count') as HTMLInputElement;
  const out = $('ak-out') as HTMLTextAreaElement;

  function encode(b: Uint8Array): string {
    if (encEl.value === 'hex') return toHex(b);
    if (encEl.value === 'base64url') return toBase64Url(b);
    return toBase62(b);
  }

  function generate() {
    const nbytes = Math.max(8, Math.min(2048, Number(bytesEl.value) || 24));
    const n = Math.max(1, Math.min(200, Number(countEl.value) || 1));
    const list: string[] = [];
    for (let i = 0; i < n; i++) list.push(prefixEl.value + encode(randBytes(nbytes)));
    out.value = list.join('\n');
  }

  ['ak-prefix', 'ak-bytes', 'ak-enc', 'ak-count'].forEach((id) => $(id).addEventListener('input', generate));
  $('ak-gen').addEventListener('click', generate);
  $('ak-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

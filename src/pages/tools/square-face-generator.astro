    { name: 'None', svg: `` },
    { name: 'Blush', svg: `<ellipse cx="82" cy="150" rx="10" ry="6" fill="{{C}}" opacity="0.5"/><ellipse cx="158" cy="150" rx="10" ry="6" fill="{{C}}" opacity="0.5"/>` },
    { name: 'Wrinkles', svg: `<path d="M78 140 q-6 8 0 16" fill="none" stroke="{{C}}" stroke-width="2.5" stroke-linecap="round"/><path d="M84 140 q-6 8 0 16" fill="none" stroke="{{C}}" stroke-width="2.5" stroke-linecap="round"/><path d="M162 140 q6 8 0 16" fill="none" stroke="{{C}}" stroke-width="2.5" stroke-linecap="round"/><path d="M156 140 q6 8 0 16" fill="none" stroke="{{C}}" stroke-width="2.5" stroke-linecap="round"/>` },
    { name: 'Freckles', svg: `<g fill="{{C}}"><circle cx="80" cy="148" r="2"/><circle cx="88" cy="152" r="2"/><circle cx="84" cy="156" r="2"/><circle cx="160" cy="148" r="2"/><circle cx="152" cy="152" r="2"/><circle cx="156" cy="156" r="2"/></g>` },
    { name: 'Smile lines', svg: `<path d="M86 156 q6 10 12 4" fill="none" stroke="{{C}}" stroke-width="2.5" stroke-linecap="round"/><path d="M154 156 q-6 10 -12 4" fill="none" stroke="{{C}}" stroke-width="2.5" stroke-linecap="round"/>` },
    { name: 'Rosy', svg: `<circle cx="82" cy="150" r="9" fill="{{C}}" opacity="0.45"/><circle cx="158" cy="150" r="9" fill="{{C}}" opacity="0.45"/>` },
    { name: 'Scar', svg: `<path d="M156 138 v20" stroke="{{C}}" stroke-width="2.5" stroke-linecap="round"/><path d="M150 144 h12 M150 152 h12" stroke="{{C}}" stroke-width="2" stroke-linecap="round"/>` },
    { name: 'Whiskers', svg: `<g stroke="{{C}}" stroke-width="2" stroke-linecap="round"><path d="M78 146 h-20 M78 152 h-22 M78 158 h-20"/><path d="M162 146 h20 M162 152 h22 M162 158 h20"/></g>` },
    { name: 'Tears', svg: `<path d="M96 128 q-4 10 0 16 q4 -6 0 -16 z" fill="{{C}}" opacity="0.7"/><path d="M144 128 q-4 10 0 16 q4 -6 0 -16 z" fill="{{C}}" opacity="0.7"/>` },
    { name: 'Dimples', svg: `<circle cx="88" cy="164" r="2.5" fill="{{C}}" opacity="0.5"/><circle cx="152" cy="164" r="2.5" fill="{{C}}" opacity="0.5"/>` },
  ];

  const accessory = [
    { name: 'None', svg: `` },
    { name: 'Glasses', svg: `<circle cx="96" cy="120" r="16" fill="none" stroke="{{C}}" stroke-width="4"/><circle cx="144" cy="120" r="16" fill="none" stroke="{{C}}" stroke-width="4"/><line x1="112" y1="118" x2="128" y2="118" stroke="{{C}}" stroke-width="4"/>` },
    { name: 'Shades', svg: `<rect x="80" y="110" width="32" height="20" rx="6" fill="{{C}}"/><rect x="128" y="110" width="32" height="20" rx="6" fill="{{C}}"/><line x1="112" y1="116" x2="128" y2="116" stroke="{{C}}" stroke-width="4"/>` },
    { name: 'Nerd', svg: `<rect x="80" y="108" width="32" height="26" rx="4" fill="none" stroke="{{C}}" stroke-width="4"/><rect x="128" y="108" width="32" height="26" rx="4" fill="none" stroke="{{C}}" stroke-width="4"/><line x1="112" y1="118" x2="128" y2="118" stroke="{{C}}" stroke-width="4"/>` },
    { name: 'Earrings', svg: `<circle cx="52" cy="150" r="5" fill="{{C}}"/><circle cx="188" cy="150" r="5" fill="{{C}}"/>` },
    { name: 'Round glasses', svg: `<circle cx="96" cy="120" r="17" fill="none" stroke="{{C}}" stroke-width="3"/><circle cx="144" cy="120" r="17" fill="none" stroke="{{C}}" stroke-width="3"/><path d="M113 118 q7 -4 14 0" fill="none" stroke="{{C}}" stroke-width="3"/><path d="M79 116 l-16 -4 M161 116 l16 -4" stroke="{{C}}" stroke-width="3" stroke-linecap="round"/>` },
    { name: 'Eyepatch', svg: `<path d="M78 108 h36 v24 h-36 z" fill="{{C}}"/><path d="M62 100 l100 20" stroke="{{C}}" stroke-width="3"/>` },
    { name: 'Monocle', svg: `<circle cx="144" cy="120" r="16" fill="none" stroke="{{C}}" stroke-width="3"/><path d="M144 136 v18" stroke="{{C}}" stroke-width="2"/>` },
    { name: 'Headband', svg: `<rect x="44" y="86" width="152" height="12" fill="{{C}}"/>` },
    { name: 'Mask', svg: `<path d="M70 108 q50 -14 100 0 v18 q-50 12 -100 0 z" fill="{{C}}" opacity="0.85"/><circle cx="96" cy="120" r="6" fill="#fff"/><circle cx="144" cy="120" r="6" fill="#fff"/>` },
    { name: 'Beanie', svg: `<path d="M50 66 q0 -34 70 -34 q70 0 70 34 z" fill="{{C}}"/><rect x="50" y="60" width="140" height="12" rx="6" fill="{{C}}"/>` },
    { name: 'Bandana', svg: `<path d="M44 66 q76 -20 152 0 v10 H44 z" fill="{{C}}"/><g fill="#ffffff55"><circle cx="72" cy="60" r="3"/><circle cx="120" cy="54" r="3"/><circle cx="168" cy="60" r="3"/></g>` },
    { name: 'Face paint', svg: `<path d="M88 108 l16 24 -16 4 z" fill="{{C}}" opacity="0.7"/><path d="M152 108 l-16 24 16 4 z" fill="{{C}}" opacity="0.7"/>` },
  ];

  const hat = [
    { name: 'None', svg: `` },
    { name: 'Cap', svg: `<path d="M52 74 q0 -22 68 -22 q68 0 68 22 z" fill="{{C}}"/><path d="M118 72 h60 q8 0 6 8 q-30 5 -64 2 z" fill="{{C}}"/>` },
    { name: 'Beanie', svg: `<path d="M54 76 q0 -24 66 -24 q66 0 66 24 z" fill="{{C}}"/><rect x="54" y="70" width="132" height="12" rx="6" fill="{{C}}"/>` },
    { name: 'Top hat', svg: `<rect x="74" y="52" width="92" height="22" rx="3" fill="{{C}}"/><rect x="46" y="70" width="148" height="12" rx="6" fill="{{C}}"/>` },
    { name: 'Cowboy', svg: `<path d="M80 72 q0 -20 40 -20 q40 0 40 20 z" fill="{{C}}"/><path d="M36 76 q84 -20 168 0 q-84 20 -168 0 z" fill="{{C}}"/>` },
    { name: 'Crown', svg: `<path d="M64 74 v-16 l18 10 18 -18 20 18 20 -18 20 18 18 -10 v16 z" fill="{{C}}"/>` },
    { name: 'Party', svg: `<path d="M120 52 l28 34 h-56 z" fill="{{C}}"/><circle cx="120" cy="54" r="6" fill="#fff"/>` },
    { name: 'Wizard', svg: `<path d="M120 52 q22 32 34 44 q-34 -8 -68 0 q12 -12 34 -44 z" fill="{{C}}"/>` },
    { name: 'Bow', svg: `<path d="M120 66 l-30 -12 q-6 12 0 24 z" fill="{{C}}"/><path d="M120 66 l30 -12 q6 12 0 24 z" fill="{{C}}"/><circle cx="120" cy="66" r="7" fill="{{C}}"/>` },
    { name: 'Headphones', svg: `<path d="M56 120 q0 -68 64 -68 q64 0 64 68" fill="none" stroke="{{C}}" stroke-width="8"/><rect x="48" y="112" width="18" height="32" rx="8" fill="{{C}}"/><rect x="174" y="112" width="18" height="32" rx="8" fill="{{C}}"/>` },
    { name: 'Halo', svg: `<ellipse cx="120" cy="60" rx="34" ry="9" fill="none" stroke="{{C}}" stroke-width="6"/>` },
  ];

  const clothes = [
    { name: 'None', svg: `` },
    { name: 'Crew', svg: `<path d="M44 210 v-16 q0 -12 24 -14 q14 12 52 12 q38 0 52 -12 q24 2 24 14 v16 z" fill="{{C}}"/>` },
    { name: 'Hoodie', svg: `<path d="M44 210 v-18 q0 -16 30 -18 q10 14 46 14 q36 0 46 -14 q30 2 30 18 v18 z" fill="{{C}}"/><path d="M74 176 q46 20 92 0 q-6 20 -46 20 q-40 0 -46 -20 z" fill="#00000022"/>` },
    { name: 'Collar', svg: `<path d="M44 210 v-16 q0 -12 24 -14 q14 12 52 12 q38 0 52 -12 q24 2 24 14 v16 z" fill="{{C}}"/><path d="M96 182 l24 18 -14 6 -14 -14 z" fill="#ffffffcc"/><path d="M144 182 l-24 18 14 6 14 -14 z" fill="#ffffffcc"/>` },
    { name: 'Suit', svg: `<path d="M44 210 v-16 q0 -12 24 -14 q14 12 52 12 q38 0 52 -12 q24 2 24 14 v16 z" fill="{{C}}"/><path d="M100 184 l20 14 20 -14 -8 26 h-24 z" fill="#fff"/><path d="M118 192 l4 6 -2 16 -4 0 -2 -16 z" fill="#c0392b"/>` },
    { name: 'Turtleneck', svg: `<path d="M44 210 v-20 q0 -14 28 -16 q12 10 48 10 q36 0 48 -10 q28 2 28 16 v20 z" fill="{{C}}"/><path d="M86 182 q34 14 68 0 v10 q-34 12 -68 0 z" fill="#ffffff22"/>` },
    { name: 'Tank', svg: `<path d="M44 210 v-12 q0 -8 20 -10 l14 -14 q20 12 84 0 l14 14 q20 2 20 10 v12 z" fill="{{C}}"/>` },
    { name: 'Scarf', svg: `<path d="M78 182 q42 22 84 0 q6 16 -8 22 q-34 12 -68 0 q-14 -6 -8 -22 z" fill="{{C}}"/><path d="M120 200 l-10 10 h20 z" fill="{{C}}"/>` },
    { name: 'Overalls', svg: `<path d="M44 210 v-16 q0 -12 24 -14 q14 12 52 12 q38 0 52 -12 q24 2 24 14 v16 z" fill="{{C}}"/><rect x="94" y="182" width="8" height="26" fill="#00000033"/><rect x="138" y="182" width="8" height="26" fill="#00000033"/>` },
    { name: 'Stripes', svg: `<path d="M44 210 v-16 q0 -12 24 -14 q14 12 52 12 q38 0 52 -12 q24 2 24 14 v16 z" fill="{{C}}"/><path d="M44 194 h152 M44 202 h152" stroke="#ffffff55" stroke-width="4"/>` },
  ];

  const libs: Record<string, { name: string; svg: string }[]> = { eyes, brows, nose, mouth, hair, bangs, sidehair, beard, cheeks, hat, clothes, accessory };

  const ORDER = ['clothes', 'hair', 'sidehair', 'bangs', 'brows', 'eyes', 'nose', 'cheeks', 'mouth', 'beard', 'hat', 'accessory'];

  const state: {
    variant: Record<string, number>;
    color: Record<string, string>;
  } = {
    variant: { eyes: 0, brows: 0, nose: 1, mouth: 0, hair: 1, bangs: 0, sidehair: 0, beard: 0, cheeks: 0, hat: 0, clothes: 0, accessory: 0 },
    color: {
      eyes: '#1f1f27', brows: '#1f1f27', nose: '#c98d6b', mouth: '#1f1f27',
      hair: '#5b3d2e', bangs: '#5b3d2e', sidehair: '#5b3d2e',
      beard: '#5b3d2e', cheeks: '#e78f8f', accessory: '#1f1f27',
      hat: '#c0392b', clothes: '#5e6ad2', skin: '#f2c9a0',
    },
  };

  const DARK = '#1f1f27';

  const skins = ['#f2c9a0', '#e8b98c', '#d19a6a', '#a9714b', '#8d5524', '#f7d7c4', '#c7f0c2', '#bcd4ff'];
  const hairColors = ['#3a2b22', '#5b3d2e', '#8a5a2b', '#d6a94b', '#c0392b', '#2c2c34', '#7d5fff', '#e0e0e6'];
  const cheekColors = ['#e78f8f', '#f0a6a6', '#d98b6b', '#b5651d', '#8a5a2b'];
  const clothesColors = ['#5e6ad2', '#c0392b', '#2c7a4b', '#d6a94b', '#2c2c34', '#7d5fff', '#e0e0e6', '#e07b39'];

  function buildSvg(): string {
    const parts = ORDER
      .map((cat) => libs[cat][state.variant[cat]].svg.replaceAll('{{C}}', state.color[cat]))
      .join('\n          ');
    return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 240 240" width="100%" role="img" aria-label="Square face avatar">
      <defs><clipPath id="sf-clip"><rect x="6" y="6" width="228" height="228" rx="28"/></clipPath></defs>
      <g clip-path="url(#sf-clip)">
        <rect x="6" y="6" width="228" height="228" fill="${state.color.skin}"/>
        <g transform="translate(-60,-72) scale(1.5)">
          ${parts}
        </g>
      </g>
    </svg>`;
  }

  function render() {
    $('sf-preview').innerHTML = buildSvg();
    for (const cat of Object.keys(libs)) {
      const el = document.querySelector(`.sf-name[data-cat="${cat}"]`);
      if (el) el.textContent = libs[cat][state.variant[cat]].name;
    }
    document.querySelectorAll<HTMLInputElement>('.sf-color').forEach((inp) => {
      inp.value = state.color[inp.dataset.cat!];
    });
  }

  // Category steppers (‹ ›).
  document.querySelectorAll('.sf-step').forEach((btn) =>
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const cat = el.dataset.cat!;
      const n = libs[cat].length;
      state.variant[cat] = (state.variant[cat] + Number(el.dataset.dir) + n) % n;
      render();
    }));

  // Per-part color pickers.
  document.querySelectorAll<HTMLInputElement>('.sf-color').forEach((inp) =>
    inp.addEventListener('input', () => {
      state.color[inp.dataset.cat!] = inp.value;
      render();
    }));

  // Randomize everything: shapes for all parts, palette colors for the visible ones.
  const pick = <T,>(a: T[]) => a[Math.floor(Math.random() * a.length)];
  const rand = (n: number) => Math.floor(Math.random() * n);
  $('sf-random').addEventListener('click', () => {
    for (const cat of Object.keys(libs)) state.variant[cat] = rand(libs[cat].length);
    const hairCol = pick(hairColors);
    state.color.skin = pick(skins);
    state.color.hair = hairCol;
    state.color.bangs = hairCol;
    state.color.sidehair = hairCol;
    state.color.beard = hairCol;
    state.color.brows = hairCol;
    state.color.nose = state.color.skin;
    state.color.cheeks = pick(cheekColors);
    state.color.eyes = DARK;
    state.color.mouth = DARK;
    state.color.accessory = DARK;
    state.color.hat = pick(clothesColors);
    state.color.clothes = pick(clothesColors);
    render();
  });

  // Rasterize the current SVG to a raster blob (JPG gets a white matte for its corners).
  function toRaster(size: number, type: 'image/png' | 'image/jpeg'): Promise<Blob> {
    return new Promise((resolve, reject) => {
      const url = URL.createObjectURL(new Blob([buildSvg()], { type: 'image/svg+xml' }));
      const img = new Image();
      img.onload = () => {
        const c = document.createElement('canvas');
        c.width = c.height = size;
        const g = c.getContext('2d')!;
        if (type === 'image/jpeg') { g.fillStyle = '#fff'; g.fillRect(0, 0, size, size); }
        g.drawImage(img, 0, 0, size, size);
        URL.revokeObjectURL(url);
        c.toBlob((b) => (b ? resolve(b) : reject(new Error('toBlob failed'))), type, 0.92);
      };
      img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('load failed')); };
      img.src = url;
    });
  }
  const toPng = () => toRaster(1024, 'image/png');

  const save = (blob: Blob, name: string) => {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  };

  $('sf-dl').addEventListener('click', async () => {
    const fmt = ($('sf-fmt') as unknown as HTMLSelectElement).value;
    try {
      if (fmt === 'svg') return save(new Blob([buildSvg()], { type: 'image/svg+xml' }), 'square-face.svg');
      const type = fmt === 'jpg' ? 'image/jpeg' : 'image/png';
      save(await toRaster(1024, type), `square-face.${fmt}`);
    } catch { $('sf-status').textContent = 'Export failed — try a different format.'; }
  });

  let copyTimer: number | undefined;
  $('sf-copy').addEventListener('click', async () => {
    const btn = $('sf-copy');
    if (!('clipboard' in navigator) || !(window as any).ClipboardItem) {
      $('sf-status').textContent = 'Clipboard copy is not supported here — use Download.';
      return;
    }
    try {
      const blob = await toPng();
      await (navigator.clipboard as any).write([new (window as any).ClipboardItem({ 'image/png': blob })]);
      clearTimeout(copyTimer);
      btn.textContent = 'Copied';
      copyTimer = window.setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
    } catch { $('sf-status').textContent = 'Copy failed — use Download instead.'; }
  });

  render();
</script>

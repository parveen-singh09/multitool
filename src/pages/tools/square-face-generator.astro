---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    q: 'What is a square face generator?',
    a: 'It is a photo tool that recreates the viral "square head" meme by warping a face toward a blocky, squared-off shape. You position a box over the face, dial in how square you want it, and download the result.',
  },
  {
    q: 'Do you upload my photo anywhere?',
    a: 'No. Your image is loaded and warped entirely inside your browser using the HTML canvas. Nothing is ever sent to a server, so it works offline and your photo stays private.',
  },
  {
    q: 'Does it detect the face automatically?',
    a: 'On browsers that support the native FaceDetector API (Chrome and Edge on most devices), the box is placed over the largest detected face automatically. On other browsers you position the box manually — just drag it over the face.',
  },
  {
    q: 'What image formats can I download?',
    a: 'You can download the squared result as a PNG (lossless, keeps transparency) or a JPG (smaller file). You can also copy it straight to your clipboard to paste into a chat or post.',
  },
  {
    q: 'Can I control how strong the effect is?',
    a: 'Yes. Squareness sets how hard the face is pulled toward a square, Effect size sets how far the warp reaches, and Sharpen corners makes the corners crisper. Presets give you Subtle, Strong and Full Cube in one tap.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<ToolLayout slug="square-face-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-[1fr_1.2fr]">
    <div class="flex flex-col gap-4">
      <!-- Upload / drop zone -->
      <div id="sf-drop" class="panel flex flex-col items-center justify-center gap-2 rounded-xl border border-dashed border-hairline-strong px-4 py-6 text-center transition-colors">
        <p class="text-sm text-ink-subtle">Drop a photo here, paste from clipboard, or</p>
        <label class="btn btn-secondary cursor-pointer">
          Choose photo
          <input id="sf-file" type="file" accept="image/*" class="hidden" />
        </label>
        <button id="sf-example" class="text-[13px] text-primary-hover underline underline-offset-2">Try an example</button>
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Squareness
        <input id="sf-strength" type="range" min="0" max="100" value="70" class="mt-2 w-full accent-primary" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Effect size
        <input id="sf-radius" type="range" min="20" max="95" value="60" class="mt-2 w-full accent-primary" />
      </label>

      <!-- Presets -->
      <div class="flex flex-wrap gap-2">
        <span class="self-center text-[13px] text-ink-tertiary">Presets:</span>
        <button class="btn btn-secondary sf-preset" data-s="35" data-r="45" data-sharp="0">Subtle</button>
        <button class="btn btn-secondary sf-preset" data-s="70" data-r="60" data-sharp="1">Strong</button>
        <button class="btn btn-secondary sf-preset" data-s="100" data-r="85" data-sharp="1">Full Cube</button>
      </div>

      <p class="text-[13px] leading-relaxed text-ink-tertiary">
        Drag the box on the preview over the face (it auto-detects where supported), then push
        <span class="text-ink-subtle">Squareness</span> up. The region inside the box gets pulled toward a square.
      </p>

      <div class="flex flex-wrap items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="sf-corners" type="checkbox" class="accent-primary" checked /> Sharpen corners</label>
        <button id="sf-reset" class="btn btn-secondary ml-auto">Reset box</button>
      </div>
    </div>

    <div class="flex flex-col items-center gap-4">
      <div id="sf-wrap" class="relative w-full touch-none select-none">
        <canvas id="sf-canvas" class="w-full rounded-xl border border-hairline" style="max-height:440px;object-fit:contain"></canvas>
        <div id="sf-box" class="pointer-events-none absolute rounded-sm border-2 border-primary" style="display:none">
          <span class="absolute -right-1 -bottom-1 h-3 w-3 rounded-sm bg-primary"></span>
        </div>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2">
        <button id="sf-compare" class="btn btn-secondary" disabled>Hold to compare</button>
        <button id="sf-copy" class="btn btn-secondary" disabled>Copy</button>
        <button id="sf-dl-jpg" class="btn btn-secondary" disabled>Download JPG</button>
        <button id="sf-dl" class="btn btn-primary" disabled>Download PNG</button>
      </div>
      <p id="sf-status" class="text-[13px] text-ink-tertiary" aria-live="polite"></p>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-6 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free square face generator recreates the viral "square head" meme: upload a
      photo and it warps the face toward a blocky, squared-off shape. On supported browsers
      the face is detected automatically; otherwise just drag the box over it. Then dial in
      how square you want it, how far the effect reaches, and how sharp the corners are.
      Unlike a one-tap filter, you stay in control, so you can go from a subtle chin-square
      to a full cartoon cube. Download the result as a PNG or JPG, or copy it to your
      clipboard. Your photo is warped entirely in your browser and never uploaded.
    </p>

    <div class="flex flex-col gap-4">
      <h2 class="font-display text-lg font-semibold text-ink">Frequently asked questions</h2>
      {faqs.map((f) => (
        <div class="flex flex-col gap-1">
          <h3 class="font-medium text-ink">{f.q}</h3>
          <p class="text-ink-subtle">{f.a}</p>
        </div>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline />
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const canvas = $('sf-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const boxEl = $('sf-box') as HTMLElement;
  const wrap = $('sf-wrap') as HTMLElement;
  const drop = $('sf-drop') as HTMLElement;
  const status = $('sf-status') as HTMLElement;

  let srcCanvas: HTMLCanvasElement | null = null; // undistorted image at canvas resolution
  let box = { x: 0, y: 0, w: 0, h: 0 }; // face box in canvas pixel coords

  const val = (id: string) => Number(($(id) as HTMLInputElement).value);
  const checked = (id: string) => ($(id) as HTMLInputElement).checked;
  const outputButtons = ['sf-dl', 'sf-dl-jpg', 'sf-copy', 'sf-compare'];
  const setReady = (ready: boolean) =>
    outputButtons.forEach((id) => (($(id) as HTMLButtonElement).disabled = !ready));

  function setStatus(msg: string) { status.textContent = msg; }

  // Prepare canvases from a loaded image (or image-like canvas element).
  function setSource(source: CanvasImageSource, w: number, h: number) {
    const maxW = 1000;
    const scale = Math.min(1, maxW / w);
    canvas.width = Math.round(w * scale);
    canvas.height = Math.round(h * scale);
    srcCanvas = document.createElement('canvas');
    srcCanvas.width = canvas.width;
    srcCanvas.height = canvas.height;
    srcCanvas.getContext('2d')!.drawImage(source, 0, 0, canvas.width, canvas.height);
    // Default box: centered square ~55% of the shorter side.
    const s = Math.min(canvas.width, canvas.height) * 0.55;
    box = { x: (canvas.width - s) / 2, y: (canvas.height - s) / 2, w: s, h: s };
    setReady(true);
    render();
    detectFace();
  }

  // Auto-detect the largest face where the browser supports it (Chrome/Edge).
  async function detectFace() {
    const FD = (window as any).FaceDetector;
    if (!FD || !srcCanvas) { setStatus('Drag the box over the face, then set Squareness.'); return; }
    try {
      const det = new FD({ fastMode: true, maxDetectedFaces: 1 });
      const faces = await det.detect(srcCanvas);
      if (faces && faces.length) {
        const b = faces[0].boundingBox;
        // Square the detection and pad slightly so it wraps the whole head.
        const s = Math.max(b.width, b.height) * 1.15;
        const cx = b.x + b.width / 2, cy = b.y + b.height / 2;
        box = {
          x: Math.max(0, Math.min(canvas.width - s, cx - s / 2)),
          y: Math.max(0, Math.min(canvas.height - s, cy - s / 2)),
          w: Math.min(s, canvas.width),
          h: Math.min(s, canvas.height),
        };
        setStatus('Face detected — fine-tune the box if needed.');
        render();
        return;
      }
      setStatus('No face detected — drag the box over the face.');
    } catch {
      setStatus('Drag the box over the face, then set Squareness.');
    }
  }

  // Backward map for the squarify warp. For a destination point (nx,ny) in the
  // effect square (chebyshev metric), return the SOURCE point to sample so the
  // source's circular content is stretched to fill the square. The square corner
  // (√2 out) pulls from the circle edge (r=1) → contraction, factor ≤ 1.
  function squarify(nx: number, ny: number, strength: number): [number, number] {
    const r = Math.hypot(nx, ny);
    const cheb = Math.max(Math.abs(nx), Math.abs(ny)); // distance to square edge along this ray
    if (r < 1e-4 || cheb < 1e-4) return [nx, ny];
    const squareScale = cheb / r; // ≤ 1: pulls the sample inward toward the circle
    const scale = 1 + strength * (squareScale - 1);
    return [nx * scale, ny * scale];
  }

  function render() {
    if (!srcCanvas) { drawPlaceholder(); return; }
    const strength = val('sf-strength') / 100;
    const radiusF = val('sf-radius') / 100;
    const sharpen = checked('sf-corners');
    const W = canvas.width, H = canvas.height;

    // Start from the clean source; outside the effect region stays untouched.
    ctx.clearRect(0, 0, W, H);
    ctx.drawImage(srcCanvas, 0, 0);
    if (strength <= 0.001) { drawBox(); return; }

    const cx = box.x + box.w / 2;
    const cy = box.y + box.h / 2;
    const rx = (box.w / 2) * (0.6 + radiusF);
    const ry = (box.h / 2) * (0.6 + radiusF);

    // Only process the region the effect actually touches — keeps big photos smooth.
    const x0 = Math.max(0, Math.floor(cx - rx));
    const y0 = Math.max(0, Math.floor(cy - ry));
    const x1 = Math.min(W, Math.ceil(cx + rx));
    const y1 = Math.min(H, Math.ceil(cy + ry));
    const rw = x1 - x0, rh = y1 - y0;
    if (rw <= 0 || rh <= 0) { drawBox(); return; }

    const sctx = srcCanvas.getContext('2d')!;
    const src = sctx.getImageData(x0, y0, rw, rh);
    const dst = ctx.createImageData(rw, rh);
    const sd = src.data, dd = dst.data;

    // Bilinear sample of the source region at region-local float coords.
    const sample = (fx: number, fy: number, di: number) => {
      if (fx < 0) fx = 0; else if (fx > rw - 1) fx = rw - 1;
      if (fy < 0) fy = 0; else if (fy > rh - 1) fy = rh - 1;
      const ix = Math.floor(fx), iy = Math.floor(fy);
      const ax = fx - ix, ay = fy - iy;
      const ix1 = ix < rw - 1 ? ix + 1 : ix;
      const iy1 = iy < rh - 1 ? iy + 1 : iy;
      const i00 = (iy * rw + ix) * 4, i10 = (iy * rw + ix1) * 4;
      const i01 = (iy1 * rw + ix) * 4, i11 = (iy1 * rw + ix1) * 4;
      for (let c = 0; c < 4; c++) {
        const top = sd[i00 + c] * (1 - ax) + sd[i10 + c] * ax;
        const bot = sd[i01 + c] * (1 - ax) + sd[i11 + c] * ax;
        dd[di + c] = top * (1 - ay) + bot * ay;
      }
    };

    for (let y = 0; y < rh; y++) {
      for (let x = 0; x < rw; x++) {
        const di = (y * rw + x) * 4;
        const px = x0 + x, py = y0 + y;
        const nx = (px - cx) / rx;
        const ny = (py - cy) / ry;
        const cheb = Math.max(Math.abs(nx), Math.abs(ny));
        if (cheb >= 1) {
          // Outside the effect square — copy straight through.
          dd[di] = sd[di]; dd[di + 1] = sd[di + 1]; dd[di + 2] = sd[di + 2]; dd[di + 3] = sd[di + 3];
          continue;
        }
        // Falloff so the warp eases to zero at the square's edge.
        const fall = sharpen ? 1 - Math.pow(cheb, 3) : 1 - cheb * cheb;
        const localStrength = strength * fall;
        const [sxn, syn] = squarify(nx, ny, localStrength);
        // Back to region-local float source coords, then bilinear sample.
        sample(cx + sxn * rx - x0, cy + syn * ry - y0, di);
      }
    }
    ctx.putImageData(dst, x0, y0);
    drawBox();
  }

  function drawPlaceholder() {
    canvas.width = 960; canvas.height = 600;
    const g = ctx.createLinearGradient(0, 0, 960, 600);
    g.addColorStop(0, '#26272b'); g.addColorStop(1, '#141516');
    ctx.fillStyle = g; ctx.fillRect(0, 0, 960, 600);
    ctx.fillStyle = '#8a8f98';
    ctx.font = '600 26px Inter, system-ui, sans-serif';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText('Upload a photo to squarify a face', 480, 300);
    ctx.textAlign = 'start';
    boxEl.style.display = 'none';
  }

  // Position the on-screen box overlay to match canvas pixel coords.
  function drawBox() {
    if (!srcCanvas) { boxEl.style.display = 'none'; return; }
    const rect = canvas.getBoundingClientRect();
    const sx = rect.width / canvas.width;
    const sy = rect.height / canvas.height;
    boxEl.style.display = 'block';
    boxEl.style.left = `${box.x * sx}px`;
    boxEl.style.top = `${box.y * sy}px`;
    boxEl.style.width = `${box.w * sx}px`;
    boxEl.style.height = `${box.h * sy}px`;
  }

  // --- Box dragging / resizing ---
  let mode: 'none' | 'move' | 'resize' = 'none';
  let start = { mx: 0, my: 0, bx: 0, by: 0, bw: 0, bh: 0 };

  function toCanvasPt(e: PointerEvent) {
    const rect = canvas.getBoundingClientRect();
    return {
      x: ((e.clientX - rect.left) / rect.width) * canvas.width,
      y: ((e.clientY - rect.top) / rect.height) * canvas.height,
    };
  }

  wrap.addEventListener('pointerdown', (e) => {
    if (!srcCanvas) return;
    const p = toCanvasPt(e);
    const nearHandle = Math.abs(p.x - (box.x + box.w)) < box.w * 0.2 && Math.abs(p.y - (box.y + box.h)) < box.h * 0.2;
    const inside = p.x >= box.x && p.x <= box.x + box.w && p.y >= box.y && p.y <= box.y + box.h;
    mode = nearHandle ? 'resize' : inside ? 'move' : 'none';
    if (mode === 'none') return;
    start = { mx: p.x, my: p.y, bx: box.x, by: box.y, bw: box.w, bh: box.h };
    wrap.setPointerCapture(e.pointerId);
  });

  wrap.addEventListener('pointermove', (e) => {
    if (mode === 'none' || !srcCanvas) return;
    const p = toCanvasPt(e);
    const dx = p.x - start.mx, dy = p.y - start.my;
    if (mode === 'move') {
      box.x = Math.max(0, Math.min(canvas.width - box.w, start.bx + dx));
      box.y = Math.max(0, Math.min(canvas.height - box.h, start.by + dy));
    } else {
      const s = Math.max(40, Math.min(start.bw + dx, start.bh + dy));
      box.w = Math.min(s, canvas.width - box.x);
      box.h = Math.min(s, canvas.height - box.y);
    }
    drawBox();
  });

  const endDrag = () => { if (mode !== 'none') { mode = 'none'; render(); } };
  wrap.addEventListener('pointerup', endDrag);
  wrap.addEventListener('pointercancel', endDrag);

  // --- Loading images from file / drop / paste / example ---
  function loadFile(file: File) {
    if (!file || !file.type.startsWith('image/')) { setStatus('That file is not an image.'); return; }
    const url = URL.createObjectURL(file);
    const im = new Image();
    im.onload = () => { URL.revokeObjectURL(url); setSource(im, im.naturalWidth, im.naturalHeight); };
    im.onerror = () => { URL.revokeObjectURL(url); setStatus('Could not load that image.'); };
    im.src = url;
  }

  $('sf-file').addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) loadFile(file);
  });

  // Drag & drop.
  ['dragenter', 'dragover'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('border-primary'); }));
  ['dragleave', 'drop'].forEach((ev) =>
    drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('border-primary'); }));
  drop.addEventListener('drop', (e) => {
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) loadFile(file);
  });

  // Clipboard paste.
  window.addEventListener('paste', (e) => {
    const items = (e as ClipboardEvent).clipboardData?.items;
    if (!items) return;
    for (const it of items) {
      if (it.type.startsWith('image/')) { const f = it.getAsFile(); if (f) { loadFile(f); break; } }
    }
  });

  // Synthetic example face so people can try it with no photo.
  $('sf-example').addEventListener('click', () => {
    const c = document.createElement('canvas');
    c.width = 800; c.height = 800;
    const g = c.getContext('2d')!;
    g.fillStyle = '#dfe7f5'; g.fillRect(0, 0, 800, 800);
    // Head
    g.fillStyle = '#f2c9a0';
    g.beginPath(); g.ellipse(400, 400, 240, 300, 0, 0, Math.PI * 2); g.fill();
    // Hair
    g.fillStyle = '#5b3d2e';
    g.beginPath(); g.ellipse(400, 220, 250, 140, 0, Math.PI, 0); g.fill();
    // Eyes
    g.fillStyle = '#2b2b2b';
    g.beginPath(); g.arc(320, 380, 26, 0, Math.PI * 2); g.fill();
    g.beginPath(); g.arc(480, 380, 26, 0, Math.PI * 2); g.fill();
    // Nose
    g.strokeStyle = '#c99b73'; g.lineWidth = 10; g.beginPath();
    g.moveTo(400, 400); g.lineTo(390, 470); g.lineTo(415, 475); g.stroke();
    // Mouth
    g.strokeStyle = '#b3574f'; g.lineWidth = 14; g.beginPath();
    g.arc(400, 520, 80, 0.15 * Math.PI, 0.85 * Math.PI); g.stroke();
    setSource(c, 800, 800);
  });

  // Presets.
  document.querySelectorAll('.sf-preset').forEach((btn) =>
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      ($('sf-strength') as HTMLInputElement).value = el.dataset.s!;
      ($('sf-radius') as HTMLInputElement).value = el.dataset.r!;
      ($('sf-corners') as HTMLInputElement).checked = el.dataset.sharp === '1';
      render();
    }));

  ['sf-strength', 'sf-radius', 'sf-corners'].forEach((id) => $(id).addEventListener('input', render));
  $('sf-reset').addEventListener('click', () => { if (srcCanvas) { setSource(srcCanvas, srcCanvas.width, srcCanvas.height); } });
  window.addEventListener('resize', () => drawBox());

  // Hold to compare — show the clean original while pressed.
  const cmp = $('sf-compare') as HTMLButtonElement;
  const showOriginal = () => { if (srcCanvas) { ctx.clearRect(0, 0, canvas.width, canvas.height); ctx.drawImage(srcCanvas, 0, 0); boxEl.style.display = 'none'; } };
  cmp.addEventListener('pointerdown', showOriginal);
  cmp.addEventListener('pointerup', render);
  cmp.addEventListener('pointerleave', () => { if (mode === 'none') render(); });

  // Downloads + copy. The box is a DOM overlay, so it never appears on the canvas bitmap.
  const emitBlob = (cb: (blob: Blob) => void, type: string, quality?: number) =>
    canvas.toBlob((b) => { if (b) cb(b); }, type, quality);
  const saveBlob = (b: Blob, name: string) => {
    const url = URL.createObjectURL(b);
    const a = document.createElement('a');
    a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  };
  $('sf-dl').addEventListener('click', () => emitBlob((b) => saveBlob(b, 'square-face.png'), 'image/png'));
  $('sf-dl-jpg').addEventListener('click', () => emitBlob((b) => saveBlob(b, 'square-face.jpg'), 'image/jpeg', 0.92));
  $('sf-copy').addEventListener('click', () => {
    if (!('clipboard' in navigator) || !(window as any).ClipboardItem) { setStatus('Clipboard copy is not supported here — use Download.'); return; }
    emitBlob(async (b) => {
      try {
        await (navigator.clipboard as any).write([new (window as any).ClipboardItem({ 'image/png': b })]);
        setStatus('Copied to clipboard.');
      } catch { setStatus('Copy failed — use Download instead.'); }
    }, 'image/png');
  });

  drawPlaceholder();
</script>

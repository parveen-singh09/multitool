---
import ToolLayout from '../../layouts/ToolLayout.astro';

const categories = [
  { key: 'eyes', label: 'Eyes', icon: '👀' },
  { key: 'brows', label: 'Eyebrows', icon: '🤨' },
  { key: 'nose', label: 'Nose', icon: '👃' },
  { key: 'mouth', label: 'Mouth', icon: '👄' },
  { key: 'hair', label: 'Hair', icon: '💇' },
  { key: 'bangs', label: 'Bangs', icon: '✂️' },
  { key: 'sidehair', label: 'Side hair', icon: '💇‍♂️' },
  { key: 'beard', label: 'Facial hair', icon: '🧔' },
  { key: 'cheeks', label: 'Cheeks', icon: '😊' },
  { key: 'hat', label: 'Hat', icon: '🎩' },
  { key: 'clothes', label: 'Clothes', icon: '👕' },
  { key: 'accessory', label: 'Accessory', icon: '👓' },
];

const colorParts = [
  { key: 'skin', label: 'Skin', icon: '✋' },
];
---

<ToolLayout slug="square-face-generator">
  <div class="grid grid-cols-1 items-start gap-6 md:grid-cols-[minmax(0,1fr)_340px]">

    <div class="order-1 flex flex-col items-center gap-4 md:order-2 md:sticky md:top-6">
      <div id="sf-preview" class="w-full max-w-85"></div>
      <div class="flex items-center justify-center gap-2">
        <button id="sf-random" class="btn btn-primary text-lg leading-none" aria-label="Randomize" title="Randomize">🎲</button>
        <button id="sf-copy" class="btn btn-secondary">Copy</button>
        <div class="flex overflow-hidden rounded-lg border border-hairline-strong">
          <button id="sf-dl" class="btn btn-secondary rounded-none border-0 focus-visible:outline-none">Download</button>
          <select id="sf-fmt" class="border-0 border-l border-hairline-strong bg-surface-2 px-2 text-[13px] text-ink-subtle focus-visible:outline-none" aria-label="Download format">
            <option value="png">PNG</option>
            <option value="svg">SVG</option>
            <option value="jpg">JPG</option>
          </select>
        </div>
      </div>
      <p id="sf-status" class="text-[13px] text-ink-tertiary" aria-live="polite"></p>
    </div>

    <div class="order-2 grid grid-cols-1 gap-2 sm:grid-cols-2 md:order-1">
      {categories.map((c) => (
        <div class="flex items-center justify-between gap-2 rounded-lg border border-hairline px-2.5 py-1.5">
          <span class="flex items-center gap-1.5 text-sm text-ink-subtle">{c.label}<span class="text-base leading-none" aria-hidden="true">{c.icon}</span></span>
          <div class="flex items-center gap-1.5">
            <button class="btn btn-secondary sf-step" data-cat={c.key} data-dir="-1" aria-label={`Previous ${c.label}`}>‹</button>
            <span class="sf-name w-16 text-center text-[13px] text-ink-tertiary" data-cat={c.key}></span>
            <button class="btn btn-secondary sf-step" data-cat={c.key} data-dir="1" aria-label={`Next ${c.label}`}>›</button>
            <input type="color" class="sf-color h-7 w-8 cursor-pointer rounded border border-hairline-strong bg-transparent p-0.5" data-cat={c.key} aria-label={`${c.label} color`} />
          </div>
        </div>
      ))}

      {colorParts.map((c) => (
        <div class="flex items-center justify-between gap-2 rounded-lg border border-hairline px-2.5 py-1.5">
          <span class="flex items-center gap-1.5 text-sm text-ink-subtle">{c.label}<span class="text-base leading-none" aria-hidden="true">{c.icon}</span></span>
          <input type="color" class="sf-color h-7 w-8 cursor-pointer rounded border border-hairline-strong bg-transparent p-0.5" data-cat={c.key} aria-label={`${c.label} color`} />
        </div>
      ))}
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-6 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free square face generator builds a blocky, square-headed character from parts.
      Cycle through eyes, eyebrows, nose, mouth, hair, bangs, side hair, facial hair,
      cheeks, hats, clothes and accessories, and pick a custom color for every part with
      its own color picker — or press Randomize to roll a whole new face in one tap. When you like it, download it as an SVG, PNG or JPG, or copy it
      to your clipboard.
    </p>
  </div>
</ToolLayout>


---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="jpg-to-png">
  <div id="jp-root" class="flex flex-col gap-4">

    <label id="jp-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose JPG images or drop them here</span>
      <input id="jp-file" type="file" accept="image/jpeg,image/jpg,.jpg,.jpeg,.jfif,.pjpeg,.pjp" multiple class="sr-only" />
    </label>

    <div id="jp-panel" class="hidden flex-col gap-4">

      <div class="panel flex flex-col gap-4 p-4">
        <span class="eyebrow text-ink-subtle">Output options</span>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Resize
            <select id="jp-resize" class="field">
              <option value="none" selected>Keep original size</option>
              <option value="scale">Scale by percent</option>
              <option value="fit">Fit within max dimensions</option>
            </select>
          </label>
          <label id="jp-scale-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Scale
            <span class="flex items-center gap-2">
              <input id="jp-scale" type="range" min="10" max="200" value="100" class="w-full accent-primary" />
              <span id="jp-scale-val" class="w-12 shrink-0 text-right text-ink">100%</span>
            </span>
          </label>
          <label id="jp-maxw-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Max width (px)
            <input id="jp-maxw" type="number" min="1" value="1920" class="field" />
          </label>
          <label id="jp-maxh-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Max height (px)
            <input id="jp-maxh" type="number" min="1" value="1920" class="field" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Background
            <select id="jp-bg" class="field">
              <option value="transparent" selected>Transparent</option>
              <option value="#ffffff">White</option>
              <option value="#000000">Black</option>
              <option value="custom">Custom colorâ€¦</option>
            </select>
          </label>
          <label id="jp-bgcolor-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Custom color
            <input id="jp-bgcolor" type="color" value="#5e6ad2" class="field h-10 cursor-pointer p-1" />
          </label>
        </div>
        <p class="text-[13px] text-ink-tertiary">
          PNG is lossless, so the output keeps every pixel of the source. JPEG has no
          transparency, so the background color only shows if you resize into padding or start
          from a transparent source.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="jp-download-all" class="btn btn-primary">Download all (.zip)</button>
        <button id="jp-add" class="btn btn-secondary">Add more images</button>
        <button id="jp-clear" class="btn btn-tertiary">Clear all</button>
        <span id="jp-summary" class="text-[13px] text-ink-subtle" aria-live="polite"></span>
      </div>

      <div id="jp-list" class="grid grid-cols-1 gap-4 sm:grid-cols-2"></div>
    </div>

    <p id="jp-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free JPG to PNG converter turns JPEG photos into lossless PNG images right in your
      browser. PNG is ideal when you need a lossless copy or plan to edit the image further
      without JPEG's generation loss. Drop one JPG or a whole batch, then download each PNG or
      grab them all in a single ZIP â€” your files are processed entirely on your device and never
      uploaded to a server.
    </p>
    <p>
      Beyond a plain one-to-one conversion, this tool converts many images at once, previews each
      result on a transparency checkerboard, and reports the exact pixel dimensions plus the size
      change from source to PNG. Optionally resize while you convert â€” scale everything by a
      percentage or fit each image inside a maximum width and height (aspect ratio preserved) â€” and
      choose a flat background color to fill any transparent or padded areas. Accepts
      <code class="font-mono text-ink">.jpg</code>, <code class="font-mono text-ink">.jpeg</code>,
      <code class="font-mono text-ink">.jfif</code> and progressive JPEGs. Every conversion runs
      offline through the browser's canvas, so it works without a network connection and nothing
      leaves your device.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .jp-checker {
    background-image:
      linear-gradient(45deg,#2a2a2e 25%,transparent 25%),
      linear-gradient(-45deg,#2a2a2e 25%,transparent 25%),
      linear-gradient(45deg,transparent 75%,#2a2a2e 75%),
      linear-gradient(-45deg,transparent 75%,#2a2a2e 75%);
    background-size:16px 16px;
    background-position:0 0,0 8px,8px -8px,-8px 0;
  }
</style>

<script>
  type Item = {
    id: number;
    name: string;
    baseName: string;
    origSize: number;
    img: HTMLImageElement;
    blob: Blob | null;
    outUrl: string | null;
    w: number;
    h: number;
    error: string | null;
  };

  const $ = (id: string) => document.getElementById(id)!;
  const root = $('jp-root');
  const fileInput = $('jp-file') as HTMLInputElement;
  const drop = $('jp-drop');
  const panel = $('jp-panel');
  const list = $('jp-list');
  const summary = $('jp-summary');
  const err = $('jp-error');

  const resizeSel = $('jp-resize') as HTMLSelectElement;
  const scaleWrap = $('jp-scale-wrap');
  const scale = $('jp-scale') as HTMLInputElement;
  const scaleVal = $('jp-scale-val');
  const maxwWrap = $('jp-maxw-wrap');
  const maxhWrap = $('jp-maxh-wrap');
  const maxw = $('jp-maxw') as HTMLInputElement;
  const maxh = $('jp-maxh') as HTMLInputElement;
  const bgSel = $('jp-bg') as HTMLSelectElement;
  const bgColorWrap = $('jp-bgcolor-wrap');
  const bgColor = $('jp-bgcolor') as HTMLInputElement;

  let items: Item[] = [];
  let uid = 0;

  const fmtSize = (n: number) =>
    n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;

  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }

  function currentBg(): string | null {
    if (bgSel.value === 'transparent') return null;
    if (bgSel.value === 'custom') return bgColor.value;
    return bgSel.value;
  }

  // Compute target dimensions from the active resize option.
  function targetDims(w: number, h: number): { w: number; h: number } {
    const mode = resizeSel.value;
    if (mode === 'scale') {
      const f = Math.max(1, Number(scale.value)) / 100;
      return { w: Math.max(1, Math.round(w * f)), h: Math.max(1, Math.round(h * f)) };
    }
    if (mode === 'fit') {
      const mw = Math.max(1, Number(maxw.value) || w);
      const mh = Math.max(1, Number(maxh.value) || h);
      const f = Math.min(1, mw / w, mh / h);
      return { w: Math.max(1, Math.round(w * f)), h: Math.max(1, Math.round(h * f)) };
    }
    return { w, h };
  }

  function convertItem(it: Item): Promise<void> {
    return new Promise((resolve) => {
      if (it.error) { resolve(); return; }
      const srcW = it.img.naturalWidth || 512;
      const srcH = it.img.naturalHeight || 512;
      const { w, h } = targetDims(srcW, srcH);
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      const ctx = canvas.getContext('2d');
      if (!ctx) { it.error = 'Canvas is not supported in this browser.'; resolve(); return; }
      const bg = currentBg();
      if (bg) { ctx.fillStyle = bg; ctx.fillRect(0, 0, w, h); }
      ctx.imageSmoothingEnabled = true;
      ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(it.img, 0, 0, w, h);
      canvas.toBlob((b) => {
        if (it.outUrl) { URL.revokeObjectURL(it.outUrl); it.outUrl = null; }
        if (!b) { it.error = 'Your browser could not encode this image as PNG.'; it.blob = null; }
        else { it.blob = b; it.outUrl = URL.createObjectURL(b); it.w = w; it.h = h; }
        resolve();
      }, 'image/png');
    });
  }

  async function convertAll() {
    for (const it of items) await convertItem(it);
    render();
  }

  function download(url: string, name: string) {
    const a = document.createElement('a');
    a.href = url; a.download = name; a.click();
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  function render() {
    list.innerHTML = '';
    const ok = items.filter((i) => !i.error && i.blob);
    const totalIn = ok.reduce((s, i) => s + i.origSize, 0);
    const totalOut = ok.reduce((s, i) => s + (i.blob?.size || 0), 0);
    const bad = items.length - ok.length;
    summary.textContent = items.length
      ? `${ok.length} ready${bad ? `, ${bad} failed` : ''} Â· ${fmtSize(totalIn)} â†’ ${fmtSize(totalOut)}`
      : '';
    ($('jp-download-all') as HTMLButtonElement).disabled = ok.length === 0;

    for (const it of items) {
      const card = document.createElement('div');
      card.className = 'panel flex flex-col gap-3 p-4';

      if (it.error) {
        const head = document.createElement('span');
        head.className = 'truncate text-sm text-ink';
        head.title = it.name;
        head.textContent = it.name;
        const msg = document.createElement('p');
        msg.className = 'text-[13px]';
        msg.style.color = '#e5484d';
        msg.textContent = it.error;
        const rm = document.createElement('button');
        rm.className = 'btn btn-tertiary self-start';
        rm.textContent = 'Remove';
        rm.addEventListener('click', () => removeItem(it.id));
        card.append(head, msg, rm);
        list.appendChild(card);
        continue;
      }

      const wrap = document.createElement('div');
      wrap.className = 'jp-checker flex justify-center overflow-hidden rounded-md p-3';
      const im = document.createElement('img');
      im.src = it.outUrl || '';
      im.alt = `${it.baseName} converted to PNG`;
      im.className = 'max-h-56 w-auto max-w-full rounded-sm';
      wrap.appendChild(im);

      const meta = document.createElement('div');
      meta.className = 'flex flex-col gap-0.5';
      meta.innerHTML =
        `<span class="truncate text-sm text-ink" title="${escapeHtml(it.name)}">${escapeHtml(it.baseName)}.png</span>` +
        `<span class="text-[13px] text-ink-subtle">${it.w}Ã—${it.h} Â· ${fmtSize(it.origSize)} â†’ ${fmtSize(it.blob!.size)}</span>`;

      const actions = document.createElement('div');
      actions.className = 'flex flex-wrap gap-2';
      const dl = document.createElement('button');
      dl.className = 'btn btn-secondary';
      dl.textContent = 'Download PNG';
      dl.addEventListener('click', () => download(it.outUrl!, `${it.baseName}.png`));
      const copy = document.createElement('button');
      copy.className = 'btn btn-tertiary';
      copy.textContent = 'Copy';
      copy.addEventListener('click', async () => {
        try {
          const ClipItem = (window as any).ClipboardItem;
          if (!ClipItem || !navigator.clipboard?.write) throw new Error('unsupported');
          await navigator.clipboard.write([new ClipItem({ 'image/png': it.blob! })]);
          copy.textContent = 'Copied';
        } catch {
          copy.textContent = 'Copy unsupported';
        }
        setTimeout(() => (copy.textContent = 'Copy'), 1600);
      });
      const rm = document.createElement('button');
      rm.className = 'btn btn-tertiary';
      rm.textContent = 'Remove';
      rm.addEventListener('click', () => removeItem(it.id));
      actions.append(dl, copy, rm);

      card.append(wrap, meta, actions);
      list.appendChild(card);
    }
  }

  function removeItem(id: number) {
    const it = items.find((i) => i.id === id);
    if (it?.outUrl) URL.revokeObjectURL(it.outUrl);
    items = items.filter((i) => i.id !== id);
    if (!items.length) { panel.classList.add('hidden'); panel.classList.remove('flex'); }
    render();
  }

  const JPEG_RE = /\.(jpe?g|jfif|pjpeg|pjp)$/i;
  function isJpeg(f: File) {
    return f.type === 'image/jpeg' || f.type === 'image/jpg' || (f.type === '' && JPEG_RE.test(f.name));
  }

  function addFiles(files: FileList | File[]) {
    setErr('');
    const arr = Array.from(files);
    if (!arr.length) return;
    const skipped: string[] = [];
    const pending: Promise<void>[] = [];

    for (const f of arr) {
      if (!isJpeg(f)) { skipped.push(f.name); continue; }
      const baseName = f.name.replace(JPEG_RE, '') || 'image';
      const it: Item = {
        id: ++uid, name: f.name, baseName, origSize: f.size,
        img: new Image(), blob: null, outUrl: null, w: 0, h: 0, error: null,
      };
      items.push(it);
      pending.push(new Promise<void>((resolve) => {
        const reader = new FileReader();
        reader.onload = () => {
          it.img.onload = () => resolve();
          it.img.onerror = () => { it.error = 'Could not decode this image â€” it may be corrupt.'; resolve(); };
          it.img.src = reader.result as string;
        };
        reader.onerror = () => { it.error = 'Could not read this file.'; resolve(); };
        reader.readAsDataURL(f);
      }));
    }

    if (skipped.length) {
      setErr(`Skipped ${skipped.length} non-JPG file${skipped.length > 1 ? 's' : ''}: ${skipped.slice(0, 3).join(', ')}${skipped.length > 3 ? 'â€¦' : ''}. This tool converts JPG/JPEG images.`);
    }

    if (items.length) { panel.classList.remove('hidden'); panel.classList.add('flex'); }
    if (pending.length) Promise.all(pending).then(convertAll);
    else render();
  }

  // ---- Minimal ZIP writer (store / no compression) â€” PNGs are already compressed. ----
  function crc32(bytes: Uint8Array): number {
    let crc = 0xffffffff;
    for (let i = 0; i < bytes.length; i++) {
      crc ^= bytes[i];
      for (let j = 0; j < 8; j++) crc = (crc >>> 1) ^ (0xedb88320 & -(crc & 1));
    }
    return (crc ^ 0xffffffff) >>> 0;
  }

  function buildZip(entries: { name: string; data: Uint8Array }[]): Blob {
    const enc = new TextEncoder();
    const parts: BlobPart[] = [];
    const centrals: Uint8Array[] = [];
    let offset = 0;

    for (const e of entries) {
      const nameBytes = enc.encode(e.name);
      const crc = crc32(e.data);
      const size = e.data.length;

      const local = new Uint8Array(30 + nameBytes.length);
      const ldv = new DataView(local.buffer);
      ldv.setUint32(0, 0x04034b50, true);
      ldv.setUint16(4, 20, true);
      ldv.setUint16(6, 0, true);
      ldv.setUint16(8, 0, true);
      ldv.setUint16(10, 0, true);
      ldv.setUint16(12, 0, true);
      ldv.setUint32(14, crc, true);
      ldv.setUint32(18, size, true);
      ldv.setUint32(22, size, true);
      ldv.setUint16(26, nameBytes.length, true);
      ldv.setUint16(28, 0, true);
      local.set(nameBytes, 30);
      parts.push(local, e.data);

      const central = new Uint8Array(46 + nameBytes.length);
      const cdv = new DataView(central.buffer);
      cdv.setUint32(0, 0x02014b50, true);
      cdv.setUint16(4, 20, true);
      cdv.setUint16(6, 20, true);
      cdv.setUint16(8, 0, true);
      cdv.setUint16(10, 0, true);
      cdv.setUint16(12, 0, true);
      cdv.setUint16(14, 0, true);
      cdv.setUint32(16, crc, true);
      cdv.setUint32(20, size, true);
      cdv.setUint32(24, size, true);
      cdv.setUint16(28, nameBytes.length, true);
      cdv.setUint32(42, offset, true);
      central.set(nameBytes, 46);
      centrals.push(central);

      offset += local.length + size;
    }

    const centralSize = centrals.reduce((s, c) => s + c.length, 0);
    const end = new Uint8Array(22);
    const edv = new DataView(end.buffer);
    edv.setUint32(0, 0x06054b50, true);
    edv.setUint16(8, entries.length, true);
    edv.setUint16(10, entries.length, true);
    edv.setUint32(12, centralSize, true);
    edv.setUint32(16, offset, true);

    return new Blob([...parts, ...centrals, end], { type: 'application/zip' });
  }

  // Ensure filenames inside the archive are unique.
  function uniqueNames(names: string[]): string[] {
    const seen = new Map<string, number>();
    return names.map((n) => {
      const c = seen.get(n) || 0;
      seen.set(n, c + 1);
      if (!c) return n;
      const dot = n.lastIndexOf('.');
      return dot < 0 ? `${n} (${c})` : `${n.slice(0, dot)} (${c})${n.slice(dot)}`;
    });
  }

  $('jp-download-all').addEventListener('click', async () => {
    const ok = items.filter((i) => !i.error && i.blob);
    if (!ok.length) return;
    if (ok.length === 1) { download(ok[0].outUrl!, `${ok[0].baseName}.png`); return; }
    const names = uniqueNames(ok.map((i) => `${i.baseName}.png`));
    const entries = await Promise.all(
      ok.map(async (i, idx) => ({ name: names[idx], data: new Uint8Array(await i.blob!.arrayBuffer()) }))
    );
    const url = URL.createObjectURL(buildZip(entries));
    download(url, 'converted-png.zip');
    setTimeout(() => URL.revokeObjectURL(url), 2000);
  });

  // ---- Option wiring ----
  function syncResizeUI() {
    const m = resizeSel.value;
    scaleWrap.classList.toggle('hidden', m !== 'scale');
    scaleWrap.classList.toggle('flex', m === 'scale');
    maxwWrap.classList.toggle('hidden', m !== 'fit');
    maxwWrap.classList.toggle('flex', m === 'fit');
    maxhWrap.classList.toggle('hidden', m !== 'fit');
    maxhWrap.classList.toggle('flex', m === 'fit');
  }
  function syncBgUI() {
    const custom = bgSel.value === 'custom';
    bgColorWrap.classList.toggle('hidden', !custom);
    bgColorWrap.classList.toggle('flex', custom);
  }

  resizeSel.addEventListener('change', () => { syncResizeUI(); convertAll(); });
  scale.addEventListener('input', () => { scaleVal.textContent = scale.value + '%'; });
  scale.addEventListener('change', convertAll);
  maxw.addEventListener('change', convertAll);
  maxh.addEventListener('change', convertAll);
  bgSel.addEventListener('change', () => { syncBgUI(); convertAll(); });
  bgColor.addEventListener('change', convertAll);

  fileInput.addEventListener('change', () => { if (fileInput.files) addFiles(fileInput.files); fileInput.value = ''; });
  $('jp-add').addEventListener('click', () => fileInput.click());
  $('jp-clear').addEventListener('click', () => {
    items.forEach((i) => i.outUrl && URL.revokeObjectURL(i.outUrl));
    items = [];
    panel.classList.add('hidden'); panel.classList.remove('flex');
    setErr(''); render();
  });

  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => {
    ev.preventDefault();
    const f = (ev as DragEvent).dataTransfer?.files;
    if (f && f.length) addFiles(f);
  });
  // Accept drops anywhere on the tool once the workspace is open.
  root.addEventListener('dragover', (ev) => ev.preventDefault());
  root.addEventListener('drop', (ev) => {
    if ((ev.target as HTMLElement)?.closest?.('#jp-drop')) return;
    ev.preventDefault();
    const f = (ev as DragEvent).dataTransfer?.files;
    if (f && f.length) addFiles(f);
  });

  syncResizeUI();
  syncBgUI();
</script>

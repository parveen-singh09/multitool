---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ImageConverter from '../../components/ImageConverter.astro';
---

<ToolLayout slug="jpg-to-png">
  <ImageConverter to="image/png" accept="image/jpeg,image/jpg" ext="png" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free JPG to PNG converter turns JPEG photos into lossless PNG images
      right in your browser. PNG is ideal when you need a lossless copy or plan
      to edit the image further without JPEG's generation loss. Drop a JPG, then
      download the PNG — your file is processed entirely on your device and never
      uploaded to a server.
    </p>
  </div>
</ToolLayout>

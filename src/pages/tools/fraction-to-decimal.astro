---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="fraction-to-decimal">
  <div class="flex flex-col gap-5">
    <div class="flex flex-col gap-3">
      <span class="text-[13px] text-ink-subtle">Fraction → decimal &amp; percent</span>
      <div class="flex flex-wrap items-center gap-2">
        <input id="fd-whole" type="number" class="field w-20 text-center" placeholder="0" aria-label="Whole number" />
        <div class="flex flex-col items-center">
          <input id="fd-num" type="number" class="field w-24 text-center" placeholder="1" aria-label="Numerator" />
          <div class="my-1 h-px w-24 bg-hairline-strong"></div>
          <input id="fd-den" type="number" class="field w-24 text-center" placeholder="4" aria-label="Denominator" />
        </div>
        <span class="text-ink-tertiary">=</span>
        <div class="flex flex-col gap-1">
          <span id="fd-dec" class="font-mono text-lg text-ink">0.25</span>
          <span id="fd-pct" class="font-mono text-[13px] text-ink-subtle">25%</span>
        </div>
      </div>
      <p id="fd-note" class="text-[13px] text-ink-tertiary"></p>
    </div>

    <div class="border-t border-hairline pt-5">
      <span class="text-[13px] text-ink-subtle">Decimal → fraction</span>
      <div class="mt-2 flex flex-wrap items-center gap-2">
        <input id="fd-decin" type="text" class="field w-40 font-mono" placeholder="0.375" inputmode="decimal" spellcheck="false" />
        <span class="text-ink-tertiary">=</span>
        <span id="fd-frac" class="font-mono text-lg text-ink">3/8</span>
      </div>
      <p class="mt-2 text-[13px] text-ink-tertiary">Repeating decimals: enter with a trailing “…”, e.g. <span class="font-mono">0.333…</span></p>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free fraction to decimal converter turns any fraction — including
      mixed numbers — into its decimal and percentage form, and converts
      decimals back into a simplified fraction. It reduces fractions to lowest
      terms using the greatest common divisor and even handles repeating
      decimals like 0.333… → 1/3. Everything runs instantly in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const whole = document.getElementById('fd-whole') as HTMLInputElement;
  const num = document.getElementById('fd-num') as HTMLInputElement;
  const den = document.getElementById('fd-den') as HTMLInputElement;
  const dec = document.getElementById('fd-dec')!;
  const pct = document.getElementById('fd-pct')!;
  const note = document.getElementById('fd-note')!;
  const decin = document.getElementById('fd-decin') as HTMLInputElement;
  const frac = document.getElementById('fd-frac')!;

  const gcd = (a: number, b: number): number => (b ? gcd(b, a % b) : a);

  function fwd() {
    const w = Number(whole.value) || 0;
    const n = Number(num.value);
    const d = Number(den.value);
    if (!d || isNaN(n)) { dec.textContent = '—'; pct.textContent = ''; note.textContent = 'Enter a numerator and a non-zero denominator.'; return; }
    const sign = (w < 0 || (w === 0 && n < 0)) ? -1 : 1;
    const value = (Math.abs(w) + Math.abs(n) / Math.abs(d)) * sign;
    dec.textContent = String(Math.round(value * 1e10) / 1e10);
    pct.textContent = (Math.round(value * 1e8) / 1e6) + '%';
    const g = gcd(Math.abs(n), Math.abs(d)) || 1;
    note.textContent = (g > 1) ? `Simplified fraction: ${n / g}/${d / g}` : '';
  }

  function dwf() {
    const raw = decin.value.trim();
    if (!raw) { frac.textContent = '—'; return; }
    const repeating = /…$|\.\.\.$/.test(raw);
    const clean = raw.replace(/…$|\.\.\.$/, '');
    const v = Number(clean);
    if (isNaN(v)) { frac.textContent = 'Invalid'; return; }
    let n: number, d: number;
    if (repeating) {
      // treat the digits after the point as the repeating block
      const [, decPart = ''] = clean.split('.');
      const intPart = Math.trunc(v);
      const rep = decPart || '0';
      const denom = Number('9'.repeat(rep.length));
      n = Number(rep); d = denom;
      const g = gcd(n, d) || 1; n /= g; d /= g;
      n += intPart * d;
    } else {
      const decimals = (clean.split('.')[1] || '').length;
      d = Math.pow(10, decimals);
      n = Math.round(v * d);
      const g = gcd(Math.abs(n), d) || 1; n /= g; d /= g;
    }
    frac.textContent = d === 1 ? String(n) : `${n}/${d}`;
  }

  [whole, num, den].forEach((el) => el.addEventListener('input', fwd));
  decin.addEventListener('input', dwf);
  num.value = '1'; den.value = '4'; fwd();
  decin.value = '0.375'; dwf();
</script>

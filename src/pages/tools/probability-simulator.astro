---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="probability-simulator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Experiment
        <select id="ps-exp" class="field">
          <option value="coin">Coin flip (heads / tails)</option>
          <option value="dice">Six-sided dice (1–6)</option>
          <option value="d20">Twenty-sided die (1–20)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Number of trials
        <input id="ps-trials" type="number" min="1" max="1000000" value="1000" class="field" />
      </label>
    </div>

    <div class="flex flex-wrap gap-3">
      <button id="ps-run" class="btn btn-primary">Run trials</button>
      <button id="ps-reset" class="btn btn-secondary">Reset</button>
    </div>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="ps-total" class="font-display text-xl font-semibold text-primary-hover">0</div><div class="mt-1 text-[13px] text-ink-subtle">Trials run</div></div>
      <div class="panel p-4"><div id="ps-outcomes" class="font-mono text-lg text-ink">2</div><div class="mt-1 text-[13px] text-ink-subtle">Outcomes</div></div>
      <div class="panel p-4"><div id="ps-maxdev" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Max deviation</div></div>
    </div>

    <div class="panel panel-lift p-4">
      <div class="mb-3 flex items-center justify-between text-[13px] text-ink-subtle">
        <span>Observed vs theoretical probability</span>
        <span class="flex items-center gap-3">
          <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-2.5 rounded-[2px]" style="background:#5e6ad2"></span>Observed</span>
          <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-2.5 rounded-[2px]" style="background:#8a8f98"></span>Theoretical</span>
        </span>
      </div>
      <div id="ps-chart" class="flex flex-col gap-3 text-[13px]"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free probability simulator runs thousands of coin flips, dice rolls or
      d20 rolls so you can watch the observed frequencies converge on the
      theoretical probability — a hands-on demonstration of the law of large
      numbers and Monte Carlo sampling. Pick an experiment, choose how many trials
      to run, and compare each outcome's observed rate against its expected rate in
      a live frequency table and bar chart. Every trial uses your browser's secure
      random source and runs entirely in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { randInt } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const expSel = $('ps-exp') as HTMLSelectElement;
  const trialsInput = $('ps-trials') as HTMLInputElement;
  const chartEl = $('ps-chart')!;

  interface ExpDef {
    labels: string[];
    /** returns index into labels for a single random trial */
    draw: () => number;
  }

  function currentExp(): ExpDef {
    const kind = expSel.value;
    if (kind === 'coin') {
      return { labels: ['Heads', 'Tails'], draw: () => randInt(0, 1) };
    }
    if (kind === 'd20') {
      return { labels: Array.from({ length: 20 }, (_, i) => String(i + 1)), draw: () => randInt(0, 19) };
    }
    return { labels: ['1', '2', '3', '4', '5', '6'], draw: () => randInt(0, 5) };
  }

  function run() {
    const exp = currentExp();
    const n = Math.max(1, Math.min(1000000, Number(trialsInput.value) || 1));
    const k = exp.labels.length;
    const counts = new Array<number>(k).fill(0);
    for (let i = 0; i < n; i++) counts[exp.draw()]++;

    const theoretical = 1 / k;
    let maxDev = 0;
    const rows = exp.labels.map((label, i) => {
      const observed = counts[i] / n;
      const dev = Math.abs(observed - theoretical);
      if (dev > maxDev) maxDev = dev;
      return { label, count: counts[i], observed };
    });

    $('ps-total').textContent = n.toLocaleString();
    $('ps-outcomes').textContent = String(k);
    $('ps-maxdev').textContent = (maxDev * 100).toFixed(2) + '%';

    const scale = Math.max(theoretical, ...rows.map((r) => r.observed)) || 1;
    chartEl.innerHTML = rows
      .map((r) => {
        const obsPct = (r.observed * 100).toFixed(2);
        const theoPct = (theoretical * 100).toFixed(2);
        const obsW = (r.observed / scale) * 100;
        const theoW = (theoretical / scale) * 100;
        return `<div class="flex flex-col gap-1">
          <div class="flex items-center justify-between text-ink-subtle">
            <span class="text-ink">${r.label}</span>
            <span class="font-mono">${r.count.toLocaleString()} · ${obsPct}% <span class="text-ink-tertiary">(exp ${theoPct}%)</span></span>
          </div>
          <div class="flex flex-col gap-1">
            <div class="h-3 w-full overflow-hidden rounded-[4px] bg-surface-2"><div class="h-full rounded-[4px]" style="width:${obsW}%;background:#5e6ad2"></div></div>
            <div class="h-1.5 w-full overflow-hidden rounded-[4px] bg-surface-2"><div class="h-full rounded-[4px]" style="width:${theoW}%;background:#8a8f98"></div></div>
          </div>
        </div>`;
      })
      .join('');
  }

  function reset() {
    $('ps-total').textContent = '0';
    $('ps-maxdev').textContent = '—';
    chartEl.innerHTML = '';
    renderEmpty();
  }

  function renderEmpty() {
    const exp = currentExp();
    $('ps-outcomes').textContent = String(exp.labels.length);
    const theoPct = (100 / exp.labels.length).toFixed(2);
    chartEl.innerHTML = exp.labels
      .map(
        (label) => `<div class="flex flex-col gap-1">
          <div class="flex items-center justify-between text-ink-subtle">
            <span class="text-ink">${label}</span>
            <span class="font-mono text-ink-tertiary">exp ${theoPct}%</span>
          </div>
          <div class="h-3 w-full overflow-hidden rounded-[4px] bg-surface-2"></div>
        </div>`
      )
      .join('');
  }

  $('ps-run').addEventListener('click', run);
  $('ps-reset').addEventListener('click', reset);
  expSel.addEventListener('change', reset);
  renderEmpty();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { CPI_U, CPI_YEARS, CPI_MIN_YEAR, CPI_MAX_YEAR } from '../../data/cpi';
const years = [...CPI_YEARS].reverse();
---

<ToolLayout slug="inflation-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Mode">
      <button type="button" data-mode="cpi" class="inf-tab btn btn-primary" aria-selected="true">Historical (US CPI)</button>
      <button type="button" data-mode="rate" class="inf-tab btn btn-secondary" aria-selected="false">Flat rate</button>
    </div>

    <div id="inf-cpi" class="flex flex-col gap-4">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Amount ($)
          <input id="cpi-amount" type="number" min="0" step="0.01" class="field" value="100" inputmode="decimal" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">in the year
          <select id="cpi-from" class="field">
            {years.map((y) => <option value={y} selected={y === 1990}>{y}</option>)}
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">is worth, in
          <select id="cpi-to" class="field">
            {years.map((y) => <option value={y} selected={y === CPI_MAX_YEAR}>{y}</option>)}
          </select>
        </label>
      </div>

      <div class="panel panel-lift p-6 text-center">
        <div id="cpi-result" class="font-display text-4xl font-semibold text-primary-hover">—</div>
        <div id="cpi-sub" class="mt-2 text-sm text-ink-muted"></div>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="panel p-5 text-center"><div id="cpi-change" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Cumulative price change</div></div>
        <div class="panel p-5 text-center"><div id="cpi-annual" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Average inflation / year</div></div>
      </div>
      <p class="text-[13px] text-ink-tertiary">Based on US CPI-U annual averages, {CPI_MIN_YEAR}–{CPI_MAX_YEAR} (source: U.S. Bureau of Labor Statistics).</p>
    </div>

    <div id="inf-rate-mode" class="hidden flex-col gap-4">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Amount
          <input id="inf-amount" type="number" min="0" step="0.01" class="field" value="1000" inputmode="decimal" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Average inflation rate (%)
          <input id="inf-rate" type="number" min="0" step="0.1" class="field" value="3" inputmode="decimal" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Number of years
          <input id="inf-years" type="number" min="0" step="1" class="field" value="10" inputmode="decimal" />
        </label>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="panel panel-lift p-5 text-center"><div id="inf-future" class="font-display text-2xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Equivalent future cost</div></div>
        <div class="panel p-5 text-center"><div id="inf-power" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Future purchasing power (today's money)</div></div>
      </div>

      <div class="panel p-5">
        <div class="flex items-center justify-between"><span class="text-ink-subtle">Total inflation over period</span><span id="inf-total" class="font-mono text-ink-muted">—</span></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free inflation calculator has two modes. The historical mode uses real
      US Consumer Price Index (CPI-U) data to show what a dollar amount from one
      year is worth in another — from {CPI_MIN_YEAR} to {CPI_MAX_YEAR} — along
      with the cumulative price change and the average annual inflation rate over
      that span. The flat-rate mode projects how prices and purchasing power
      change at an inflation rate you choose. All calculations run in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { CPI_U } from '../../data/cpi';

  const money = (n: number) => n.toLocaleString(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });

  const cpiAmount = document.getElementById('cpi-amount') as HTMLInputElement;
  const cpiFrom = document.getElementById('cpi-from') as HTMLSelectElement;
  const cpiTo = document.getElementById('cpi-to') as HTMLSelectElement;

  function calcCpi() {
    const amt = Number(cpiAmount.value) || 0;
    const fromY = Number(cpiFrom.value);
    const toY = Number(cpiTo.value);
    const cFrom = CPI_U[fromY];
    const cTo = CPI_U[toY];
    if (!cFrom || !cTo) return;
    const result = (amt * cTo) / cFrom;
    const change = ((cTo - cFrom) / cFrom) * 100;
    const span = toY - fromY;
    const annual = span !== 0 ? (Math.pow(cTo / cFrom, 1 / span) - 1) * 100 : 0;

    document.getElementById('cpi-result')!.textContent = '$' + money(result);
    document.getElementById('cpi-sub')!.textContent = `$${money(amt)} in ${fromY} → ${toY}`;
    document.getElementById('cpi-change')!.textContent =
      (change >= 0 ? '+' : '') + change.toLocaleString(undefined, { maximumFractionDigits: 1 }) + '%';
    document.getElementById('cpi-annual')!.textContent =
      (annual >= 0 ? '+' : '') + annual.toLocaleString(undefined, { maximumFractionDigits: 2 }) + '%';
  }
  [cpiAmount, cpiFrom, cpiTo].forEach((el) => el.addEventListener('input', calcCpi));

  // ---- Flat-rate mode ----
  const amount = document.getElementById('inf-amount') as HTMLInputElement;
  const rate = document.getElementById('inf-rate') as HTMLInputElement;
  const yearsEl = document.getElementById('inf-years') as HTMLInputElement;

  function calcRate() {
    const a = Number(amount.value) || 0;
    const r = (Number(rate.value) || 0) / 100;
    const y = Number(yearsEl.value) || 0;
    const factor = Math.pow(1 + r, y);
    document.getElementById('inf-future')!.textContent = money(a * factor);
    document.getElementById('inf-power')!.textContent = money(factor > 0 ? a / factor : 0);
    document.getElementById('inf-total')!.textContent =
      ((factor - 1) * 100).toLocaleString(undefined, { maximumFractionDigits: 1, minimumFractionDigits: 1 }) + '%';
  }
  [amount, rate, yearsEl].forEach((el) => el.addEventListener('input', calcRate));

  // ---- Mode toggle ----
  document.querySelectorAll<HTMLButtonElement>('.inf-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const mode = tab.dataset.mode;
      document.querySelectorAll('.inf-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('inf-cpi')!.classList.toggle('hidden', mode !== 'cpi');
      document.getElementById('inf-cpi')!.classList.toggle('flex', mode === 'cpi');
      document.getElementById('inf-rate-mode')!.classList.toggle('hidden', mode !== 'rate');
      document.getElementById('inf-rate-mode')!.classList.toggle('flex', mode === 'rate');
    });
  });

  calcCpi();
  calcRate();
</script>

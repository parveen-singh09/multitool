---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="svg-to-png">
  <div class="flex flex-col gap-4">

    <label id="sp-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-6 text-center transition-colors hover:bg-surface-2">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an SVG file or drop it here</span>
      <input id="sp-file" type="file" accept="image/svg+xml,.svg" class="sr-only" />
    </label>

    <div class="flex flex-wrap items-end gap-x-4 gap-y-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Width (px)
        <input id="sp-w" type="number" min="1" max="16000" class="field w-28 py-1" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Height (px)
        <input id="sp-h" type="number" min="1" max="16000" class="field w-28 py-1" />
      </label>
      <label class="flex items-center gap-2 pb-2 text-sm text-ink-subtle">
        <input id="sp-lock" type="checkbox" checked class="h-4 w-4 accent-primary" />
        Lock aspect ratio
      </label>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        Scale
        <div class="flex gap-1">
          <button type="button" data-scale="1" class="sp-scale btn btn-tertiary px-2 py-1 text-[13px]">1Ã—</button>
          <button type="button" data-scale="2" class="sp-scale btn btn-tertiary px-2 py-1 text-[13px]">2Ã—</button>
          <button type="button" data-scale="3" class="sp-scale btn btn-tertiary px-2 py-1 text-[13px]">3Ã—</button>
          <button type="button" data-scale="4" class="sp-scale btn btn-tertiary px-2 py-1 text-[13px]">4Ã—</button>
        </div>
      </div>
      <label class="flex items-center gap-2 pb-2 text-sm text-ink-subtle">
        <input id="sp-transparent" type="checkbox" checked class="h-4 w-4 accent-primary" />
        Transparent background
      </label>
      <label id="sp-color-wrap" class="flex items-center gap-2 pb-2 text-sm text-ink-subtle" style="display:none">
        Background
        <input id="sp-color" type="color" value="#ffffff" class="h-8 w-10 cursor-pointer rounded-md border border-hairline bg-surface-1 p-0.5" />
      </label>
    </div>

    <div id="sp-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>SVG source</span>
          <button id="sp-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
        </span>
        <div class="copy-wrap">
          <div id="sp-edit" class="hl-edit field p-0" style="height:22rem;overflow:hidden">
            <pre class="hl-block" aria-hidden="true"><code id="sp-in-hl" class="hljs" style="background:transparent"></code></pre>
            <textarea id="sp-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="SVG markup"></textarea>
          </div>
          <button type="button" class="copy-icon" data-copy-target="#sp-in" aria-label="Copy"></button>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>PNG preview</span>
          <span class="flex gap-2">
            <button id="sp-copy" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Copy PNG</button>
            <button id="sp-download" type="button" class="btn btn-primary px-2 py-1 text-[13px]">Download PNG</button>
          </span>
        </span>
        <div class="panel flex items-center justify-center overflow-auto p-4" style="height:22rem;background-image:linear-gradient(45deg,#2a2a2e 25%,transparent 25%),linear-gradient(-45deg,#2a2a2e 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#2a2a2e 75%),linear-gradient(-45deg,transparent 75%,#2a2a2e 75%);background-size:16px 16px;background-position:0 0,0 8px,8px -8px,-8px 0">
          <img id="sp-preview" class="max-h-full w-auto max-w-full rounded-md" alt="Converted PNG preview" />
        </div>
      </div>
    </div>

    <p id="sp-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SVG to PNG converter rasterizes scalable vector graphics into
      crisp PNG images, keeping transparency by default. Because SVG is a vector
      format, you can render at any resolution without blur â€” set an exact width
      and height, or use the 1Ã—â€“4Ã— scale presets to export retina-ready
      bitmaps from a single source. It's useful when you need a fixed-size
      raster of an icon or logo for a platform that doesn't accept SVG.
    </p>
    <p>
      Drop or choose an SVG file, or paste and edit the SVG markup directly â€”
      the source pane is syntax-highlighted and the PNG preview updates live.
      Lock the aspect ratio to resize proportionally, or unlock it to stretch.
      Keep a transparent background, or flatten onto any solid color for formats
      and platforms that don't support alpha. Download the result or copy the
      PNG straight to your clipboard. If your SVG has no intrinsic size it
      defaults to 512Ã—512.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl, wireInput } from '../../lib/highlight';

  const fileInput = document.getElementById('sp-file') as HTMLInputElement;
  const drop = document.getElementById('sp-drop')!;
  const editWrap = document.getElementById('sp-edit')!;
  const input = document.getElementById('sp-in') as HTMLTextAreaElement;
  const inHl = document.getElementById('sp-in-hl')!;
  const preview = document.getElementById('sp-preview') as HTMLImageElement;
  const wIn = document.getElementById('sp-w') as HTMLInputElement;
  const hIn = document.getElementById('sp-h') as HTMLInputElement;
  const lock = document.getElementById('sp-lock') as HTMLInputElement;
  const transparent = document.getElementById('sp-transparent') as HTMLInputElement;
  const colorWrap = document.getElementById('sp-color-wrap')!;
  const color = document.getElementById('sp-color') as HTMLInputElement;
  const statusEl = document.getElementById('sp-status')!;
  const err = document.getElementById('sp-error')!;

  const MAX_DIM = 16000; 
  let blob: Blob | null = null;
  let baseName = 'image';
  let intrinsicW = 512, intrinsicH = 512; 

  const fmtSize = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;
  const clampDim = (n: number) => Math.max(1, Math.min(MAX_DIM, Math.round(n)));
  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); if (m) statusEl.classList.add('hidden'); }
  function showStatus(m: string) { statusEl.textContent = m; statusEl.classList.remove('hidden'); statusEl.style.borderColor = '#27a644'; statusEl.style.color = '#27a644'; }

  // Parse an SVG length attribute to px. Returns null for %, em, or unparseable.
  function parseLen(v: string | null): number | null {
    if (!v) return null;
    const m = /^\s*([0-9]*\.?[0-9]+)\s*(px)?\s*$/.exec(v);
    return m ? parseFloat(m[1]) : null;
  }

  // Derive intrinsic width/height from an <svg> element's width/height/viewBox.
  // ponytail: covers px width/height and viewBox aspect; %/other units fall back
  // to the viewBox or 512Â² â€” good enough for rasterizing to a chosen pixel size.
  function intrinsicSize(svg: SVGSVGElement): { w: number; h: number } {
    const w = parseLen(svg.getAttribute('width'));
    const h = parseLen(svg.getAttribute('height'));
    const vb = svg.getAttribute('viewBox')?.split(/[\s,]+/).map(Number);
    const vbOk = vb && vb.length === 4 && vb.every((n) => Number.isFinite(n)) && vb[2] > 0 && vb[3] > 0;
    if (w && h) return { w, h };
    if (vbOk) {
      const aspect = vb![2] / vb![3];
      if (w) return { w, h: w / aspect };
      if (h) return { w: h * aspect, h };
      return { w: vb![2], h: vb![3] };
    }
    if (w) return { w, h: w };
    if (h) return { w: h, h };
    return { w: 512, h: 512 };
  }

  function parseSvg(text: string): SVGSVGElement {
    const doc = new DOMParser().parseFromString(text, 'image/svg+xml');
    const pe = doc.querySelector('parsererror');
    if (pe) throw new Error(pe.textContent?.replace(/\s+/g, ' ').trim() || 'Invalid SVG markup.');
    const svg = doc.querySelector('svg');
    if (!svg) throw new Error('No <svg> element found.');
    return svg as SVGSVGElement;
  }

  // Refresh intrinsic size + default the width/height fields when the source changes.
  function refreshIntrinsic() {
    try {
      const svg = parseSvg(input.value.trim());
      const s = intrinsicSize(svg);
      intrinsicW = Math.max(1, Math.round(s.w));
      intrinsicH = Math.max(1, Math.round(s.h));
      if (!wIn.value || !hIn.value) { wIn.value = String(intrinsicW); hIn.value = String(intrinsicH); }
    } catch {}
  }

  async function convert() {
    setErr('');
    const raw = input.value.trim();
    if (!raw) { blob = null; preview.removeAttribute('src'); statusEl.classList.add('hidden'); return; }

    let svg: SVGSVGElement;
    try { svg = parseSvg(raw); } catch (e) { setErr((e as Error).message); return; }

    const targetW = clampDim(Number(wIn.value) || intrinsicW);
    const targetH = clampDim(Number(hIn.value) || intrinsicH);

    // Rasterize crisply: give the SVG an explicit target size + a viewBox so the
    // browser renders at full output resolution rather than upscaling a bitmap.
    if (!svg.getAttribute('viewBox')) svg.setAttribute('viewBox', `0 0 ${intrinsicW} ${intrinsicH}`);
    svg.setAttribute('width', String(targetW));
    svg.setAttribute('height', String(targetH));
    if (!svg.getAttribute('xmlns')) svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
    const svgStr = new XMLSerializer().serializeToString(svg);
    const url = URL.createObjectURL(new Blob([svgStr], { type: 'image/svg+xml;charset=utf-8' }));

    const img = new Image();
    try {
      await new Promise<void>((resolve, reject) => {
        img.onload = () => resolve();
        img.onerror = () => reject(new Error('Could not render that SVG.'));
        img.src = url;
      });
    } catch (e) {
      URL.revokeObjectURL(url);
      setErr((e as Error).message);
      return;
    }

    const canvas = document.createElement('canvas');
    canvas.width = targetW; canvas.height = targetH;
    const ctx = canvas.getContext('2d')!;
    if (!transparent.checked) { ctx.fillStyle = color.value; ctx.fillRect(0, 0, targetW, targetH); }
    ctx.drawImage(img, 0, 0, targetW, targetH);
    URL.revokeObjectURL(url);

    canvas.toBlob((b) => {
      if (!b) { setErr('Your browser could not encode the PNG.'); return; }
      blob = b;
      preview.src = URL.createObjectURL(b);
      showStatus(`SVG â†’ PNG Â· ${targetW}Ã—${targetH} Â· ${fmtSize(b.size)} âœ“`);
    }, 'image/png');
  }

  function runConvert() { convert().catch(() => ); }

  // Editable highlighted SVG source (XML). Re-derive intrinsic size, then render.
  const rerender = wireInput(input, inHl, () => 'xml', () => { refreshIntrinsic(); runConvert(); });

  // Width/height with optional aspect lock.
  wIn.addEventListener('input', () => {
    if (lock.checked && intrinsicW) hIn.value = String(clampDim((Number(wIn.value) || 0) * intrinsicH / intrinsicW));
    runConvert();
  });
  hIn.addEventListener('input', () => {
    if (lock.checked && intrinsicH) wIn.value = String(clampDim((Number(hIn.value) || 0) * intrinsicW / intrinsicH));
    runConvert();
  });
  lock.addEventListener('change', runConvert);
  transparent.addEventListener('change', () => { colorWrap.style.display = transparent.checked ? 'none' : ''; runConvert(); });
  color.addEventListener('input', runConvert);

  document.querySelectorAll<HTMLButtonElement>('.sp-scale').forEach((btn) =>
    btn.addEventListener('click', () => {
      const n = Number(btn.dataset.scale);
      wIn.value = String(clampDim(intrinsicW * n));
      hIn.value = String(clampDim(intrinsicH * n));
      runConvert();
    }));

  document.getElementById('sp-clear')!.addEventListener('click', () => {
    input.value = ''; wIn.value = ''; hIn.value = ''; blob = null;
    preview.removeAttribute('src'); setErr(''); statusEl.classList.add('hidden');
    baseName = 'image';
    rerender();
  });

  document.getElementById('sp-download')!.addEventListener('click', () => {
    if (!blob) return;
    const a = document.createElement('a');
    a.download = `${baseName}.png`;
    a.href = URL.createObjectURL(blob);
    a.click();
  });

  document.getElementById('sp-copy')!.addEventListener('click', async (e) => {
    if (!blob) return;
    const b = e.currentTarget as HTMLButtonElement;
    try {
      await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
      b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy PNG'), 1400);
    } catch { setErr('Clipboard image copy is not supported in this browser â€” use Download instead.'); }
  });

  function loadFile(file: File) {
    baseName = file.name.replace(/\.svg$/i, '') || 'image';
    const reader = new FileReader();
    reader.onload = () => {
      input.value = String(reader.result ?? '');
      wIn.value = ''; hIn.value = ''; // reset so intrinsic size repopulates
      refreshIntrinsic();
      rerender();
      runConvert();
    };
    reader.onerror = () => setErr('Could not read that file.');
    reader.readAsText(file);
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
  ['dragover', 'dragenter'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((ev) => drop.addEventListener(ev, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (e) => { e.preventDefault(); const f = (e as DragEvent).dataTransfer?.files?.[0]; if (f) loadFile(f); });
  // Allow dropping an .svg onto the source editor too.
  ['dragover', 'dragenter'].forEach((ev) => editWrap.addEventListener(ev, (e) => { e.preventDefault(); editWrap.style.outline = '2px solid #5e6ad2'; }));
  ['dragleave', 'drop'].forEach((ev) => editWrap.addEventListener(ev, () => { editWrap.style.outline = ''; }));
  editWrap.addEventListener('drop', (e) => { e.preventDefault(); const f = (e as DragEvent).dataTransfer?.files?.[0]; if (f?.name.toLowerCase().endsWith('.svg')) loadFile(f); });

  // Sample so the tool renders something on load.
  input.value = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#5e6ad2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">\n  <polygon points="12 2 2 7 12 12 22 7 12 2"/>\n  <polyline points="2 17 12 22 22 17"/>\n  <polyline points="2 12 12 17 22 12"/>\n</svg>';
  refreshIntrinsic();
  rerender();
  runConvert();
</script>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

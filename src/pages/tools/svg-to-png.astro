---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ImageConverter from '../../components/ImageConverter.astro';
---

<ToolLayout slug="svg-to-png">
  <ImageConverter to="image/png" accept="image/svg+xml,.svg" ext="png" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SVG to PNG converter rasterizes scalable vector graphics into
      PNG images, keeping transparency. It's useful when you need a fixed-size
      bitmap of an icon or logo for a platform that doesn't accept SVG. Drop an
      SVG file and download the PNG. If your SVG has no intrinsic size it is
      rendered at 512×512. Everything runs in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

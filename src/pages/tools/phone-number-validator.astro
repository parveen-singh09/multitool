---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="phone-number-validator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Country
        <select id="pnv-country" class="field w-auto">
          <option value="US">United States (+1)</option>
          <option value="CA">Canada (+1)</option>
          <option value="GB">United Kingdom (+44)</option>
          <option value="IN">India (+91)</option>
          <option value="DE">Germany (+49)</option>
          <option value="FR">France (+33)</option>
          <option value="AU">Australia (+61)</option>
          <option value="E164">Generic E.164</option>
        </select>
      </label>
      <label class="flex flex-1 flex-col gap-1 text-sm text-ink-subtle">
        Phone number
        <input id="pnv-in" class="field font-mono text-[13px]" placeholder="(555) 123-4567" spellcheck="false" inputmode="tel" autocomplete="off" value="(202) 555-0143" />
      </label>
    </div>

    <p id="pnv-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-2 gap-3 text-center">
      <div class="panel panel-lift p-4"><div id="pnv-status" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Status</div></div>
      <div class="panel p-4"><div id="pnv-e164" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">E.164</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free phone number validator checks whether a number matches the
      expected digit count and format for a chosen country — the United States,
      United Kingdom, India, Germany, France, Australia and Canada — or against
      the generic E.164 international standard. It normalizes valid numbers to
      E.164 form so they are ready to store or dial. Everything runs entirely in
      your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('pnv-in') as HTMLInputElement;
  const country = document.getElementById('pnv-country') as HTMLSelectElement;
  const err = document.getElementById('pnv-error')!;
  const statusEl = document.getElementById('pnv-status')!;
  const e164El = document.getElementById('pnv-e164')!;

  interface Rule {
    cc: string; // country calling code digits
    // national significant number lengths accepted
    lengths: number[];
    // leading-digit pattern applied to the national number
    pattern?: RegExp;
  }

  const RULES: Record<string, Rule> = {
    US: { cc: '1', lengths: [10], pattern: /^[2-9]\d{2}[2-9]\d{6}$/ },
    CA: { cc: '1', lengths: [10], pattern: /^[2-9]\d{2}[2-9]\d{6}$/ },
    GB: { cc: '44', lengths: [10] },
    IN: { cc: '91', lengths: [10], pattern: /^[6-9]\d{9}$/ },
    DE: { cc: '49', lengths: [10, 11] },
    FR: { cc: '33', lengths: [9] },
    AU: { cc: '61', lengths: [9] },
    E164: { cc: '', lengths: [] },
  };

  function setStatus(text: string, ok: boolean) {
    statusEl.textContent = text;
    statusEl.style.color = ok ? '#27a644' : '#e5484d';
  }

  function reset() {
    setStatus('—', true);
    statusEl.style.color = '';
    e164El.textContent = '—';
  }

  function validate() {
    err.classList.add('hidden');
    const rule = RULES[country.value];
    const raw = input.value.trim();
    if (raw === '') { reset(); return; }

    const hasPlus = raw.startsWith('+');
    const digits = raw.replace(/\D/g, '');
    if (digits === '') {
      err.textContent = 'Enter a phone number.';
      err.classList.remove('hidden');
      reset();
      return;
    }

    if (country.value === 'E164') {
      // E.164: leading digit 1-9, total 8..15 digits.
      const ok = /^[1-9]\d{7,14}$/.test(digits);
      e164El.textContent = '+' + digits;
      setStatus(ok ? 'Valid ✓' : 'Invalid ✕', ok);
      return;
    }

    // Determine the national number by stripping any leading country code / trunk 0.
    let national = digits;
    if (hasPlus || digits.startsWith(rule.cc)) {
      if (digits.startsWith(rule.cc)) national = digits.slice(rule.cc.length);
    }
    // Strip a national trunk prefix "0" (UK, DE, FR, AU) when present.
    if (['GB', 'DE', 'FR', 'AU'].includes(country.value) && national.startsWith('0')) {
      national = national.slice(1);
    }

    const lengthOk = rule.lengths.includes(national.length);
    const patternOk = rule.pattern ? rule.pattern.test(national) : true;
    const ok = lengthOk && patternOk;

    e164El.textContent = '+' + rule.cc + national;
    if (!lengthOk) setStatus('Bad length', false);
    else setStatus(ok ? 'Valid ✓' : 'Invalid ✕', ok);
  }

  input.addEventListener('input', validate);
  country.addEventListener('change', validate);
  validate();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="org-chart-creator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,420px)_1fr]">

    <div class="flex flex-col gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Chart title
        <input id="occ-title" class="field" type="text" value="Org chart" />
      </label>

      <div class="flex flex-wrap gap-1 rounded-md bg-surface-1 p-1" role="tablist">
        <button class="occ-tab btn btn-tertiary" data-tab="people" aria-selected="true">People</button>
        <button class="occ-tab btn btn-tertiary" data-tab="templates">Templates</button>
        <button class="occ-tab btn btn-tertiary" data-tab="style">Style</button>
        <button class="occ-tab btn btn-tertiary" data-tab="import">Import</button>
      </div>

      <section data-panel="people" class="flex flex-col gap-3">
        <div id="occ-rows" class="flex max-h-[62vh] flex-col gap-3 overflow-y-auto pr-1"></div>
        <button id="occ-add" class="btn btn-secondary self-start">Add person</button>
      </section>

      <section data-panel="templates" class="hidden flex-col gap-4">
        <p class="text-sm text-ink-subtle">Pick a starting point. It replaces the current chart.</p>
        <div id="occ-templates" class="flex flex-col gap-4"></div>
      </section>

      <section data-panel="style" class="hidden flex-col gap-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Theme
          <select id="occ-theme" class="field"></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Layout
          <select id="occ-layout" class="field"></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Box size
          <select id="occ-size" class="field"></select>
        </label>
        <div class="flex flex-col gap-2">
          <span class="text-sm text-ink-subtle">Company logo</span>
          <div class="flex items-center gap-2">
            <button id="occ-logo-btn" class="btn btn-secondary">Upload logo</button>
            <button id="occ-logo-clear" class="btn btn-tertiary hidden">Remove</button>
            <input id="occ-logo-file" type="file" accept="image/*" class="hidden" />
          </div>
        </div>
      </section>

      <section data-panel="import" class="hidden flex-col gap-5">
        <div class="flex flex-col gap-2">
          <span class="text-sm text-ink-subtle">Indented role list</span>
          <textarea id="occ-outline" class="field min-h-40 resize-y font-mono text-[13px]" spellcheck="false" placeholder="CEO&#10;  VP Engineering&#10;    Backend Lead&#10;  VP Sales"></textarea>
          <button id="occ-outline-btn" class="btn btn-secondary self-start">Build from list</button>
          <p class="text-[13px] text-ink-tertiary">Indent with spaces or tabs to nest reports. Use "Name, Title" for a job title.</p>
        </div>
        <div class="flex flex-col gap-2">
          <span class="text-sm text-ink-subtle">Paste a CSV (Name, Title, Department, Reports To)</span>
          <textarea id="occ-csv" class="field min-h-28 resize-y font-mono text-[13px]" spellcheck="false" placeholder="Name,Title,Department,Reports To&#10;Alex Morgan,CEO,,&#10;Jordan Lee,VP Engineering,Engineering,Alex Morgan"></textarea>
          <button id="occ-csv-btn" class="btn btn-secondary self-start">Build from CSV</button>
        </div>
        <p id="occ-import-err" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
      </section>
    </div>

    <div class="flex flex-col gap-3">
      <div class="flex flex-wrap gap-2">
        <button id="occ-png" class="btn btn-primary">PNG</button>
        <button id="occ-svg" class="btn btn-secondary">SVG</button>
        <button id="occ-pdf" class="btn btn-secondary">PDF</button>
        <button id="occ-json" class="btn btn-secondary">JSON</button>
        <button id="occ-csv-dl" class="btn btn-secondary">CSV</button>
        <button id="occ-import-btn" class="btn btn-tertiary">Import file</button>
        <input id="occ-file" type="file" accept=".json,.csv,application/json,text/csv" class="hidden" />
        <span class="mx-1 w-px self-stretch bg-hairline"></span>
        <button id="occ-undo" class="btn btn-tertiary px-3" title="Undo (Ctrl+Z)" aria-label="Undo">↶</button>
        <button id="occ-redo" class="btn btn-tertiary px-3" title="Redo (Ctrl+Y)" aria-label="Redo">↷</button>
      </div>
      <p class="text-[13px] text-ink-tertiary">
        Click a box to edit it. Drag a box onto another to make it report there — the
        chart re-arranges automatically. Drag onto empty space to promote to the top.
      </p>
      <div class="panel overflow-auto p-3" style="max-height:80vh">
        <div id="occ-preview" class="touch-none select-none [&>svg]:h-auto [&>svg]:max-w-full [&>svg]:rounded-md" aria-label="Org chart preview"></div>
      </div>
      <p id="occ-status" class="text-sm text-ink-subtle" role="status" aria-live="polite"></p>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free org chart creator is a full visual editor for organization charts.
      Add people with a name, job title and department, then <strong>drag any box
      onto another to change who reports to whom</strong> — the chart re-arranges
      itself and never lets you create an impossible loop. Give each person a
      <strong>photo</strong>, add your <strong>company logo</strong>, and switch
      between top-down, left-to-right, right-to-left and bottom-up layouts with one
      click.
    </p>
    <p>
      Already have your people in a spreadsheet or HR system? Paste or upload a
      <strong>CSV</strong> with a "Reports To" column (the format Workday, BambooHR
      and Excel export) and the whole hierarchy builds instantly. Or type an indented
      list of roles the classic way. Pick from ready-made templates for a company,
      startup, non-profit, school or sales team, restyle with color themes, then
      export a crisp <strong>PNG</strong>, scalable <strong>SVG</strong>, print-ready
      <strong>PDF</strong>, or a reusable <strong>JSON</strong> project you can reopen
      later. Undo and redo any change. Your draft is saved automatically.
    </p>
  </div>
</ToolLayout>

<script>
  import type { OrgChart, Person } from '../../lib/org-chart/types';
  import { newId, rootsOf, childrenOf, wouldCreateCycle } from '../../lib/org-chart/types';
  import { renderSVG, type RenderResult } from '../../lib/org-chart/render';
  import { ORG_THEMES, getTheme, LAYOUTS, SIZE_PRESETS } from '../../lib/org-chart/presets';
  import { templateGroups, templateToChart } from '../../lib/org-chart/templates';
  import { toJSON, fromJSON, toCSV, fromCSV, fromOutline } from '../../lib/org-chart/interop';
  import { saveDraft, loadDraft } from '../../lib/org-chart/storage';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const titleEl = $<HTMLInputElement>('occ-title');
  const rowsEl = $<HTMLDivElement>('occ-rows');
  const preview = $<HTMLDivElement>('occ-preview');
  const statusEl = $<HTMLParagraphElement>('occ-status');

  function defaultChart(): OrgChart {
    const ceo: Person = { id: newId(), name: 'Alex Morgan', title: 'CEO', managerId: null };
    const eng: Person = { id: newId(), name: 'Jordan Lee', title: 'VP Engineering', dept: 'Engineering', managerId: ceo.id };
    const sales: Person = { id: newId(), name: 'Priya Shah', title: 'VP Sales', dept: 'Sales', managerId: ceo.id };
    const be: Person = { id: newId(), name: 'Chris Kim', title: 'Backend Lead', dept: 'Engineering', managerId: eng.id };
    const fe: Person = { id: newId(), name: 'Dana Fox', title: 'Frontend Lead', dept: 'Engineering', managerId: eng.id };
    return { title: 'Org chart', themeId: 'linear-dark', layoutId: 'top-down', sizeId: 'comfortable', people: [ceo, eng, sales, be, fe] };
  }

  let state: OrgChart = loadDraft() ?? defaultChart();
  let last: RenderResult | null = null;
  let selectedId: string | null = null;

  const undoStack: string[] = [];
  const redoStack: string[] = [];
  let restoring = false;
  function snapshot(): void {
    if (restoring) return;
    undoStack.push(JSON.stringify(state));
    if (undoStack.length > 50) undoStack.shift();
    redoStack.length = 0;
    syncUndoButtons();
  }
  function undo(): void {
    if (undoStack.length === 0) return;
    redoStack.push(JSON.stringify(state));
    state = JSON.parse(undoStack.pop()!);
    afterRestore();
  }
  function redo(): void {
    if (redoStack.length === 0) return;
    undoStack.push(JSON.stringify(state));
    state = JSON.parse(redoStack.pop()!);
    afterRestore();
  }
  function afterRestore(): void {
    restoring = true;
    titleEl.value = state.title;
    syncStyleControls();
    renderRows();
    render();
    restoring = false;
    syncUndoButtons();
  }
  function syncUndoButtons(): void {
    $<HTMLButtonElement>('occ-undo').disabled = undoStack.length === 0;
    $<HTMLButtonElement>('occ-redo').disabled = redoStack.length === 0;
  }

  let saveTimer = 0;
  function render(): void {
    state.title = titleEl.value;
    last = renderSVG(state, getTheme(state.themeId));
    preview.innerHTML = last.svg;
    highlightSelection();
    clearTimeout(saveTimer);
    saveTimer = window.setTimeout(() => saveDraft(state), 250);
  }

  function person(id: string): Person | undefined { return state.people.find((p) => p.id === id); }

  function renderRows(): void {
    rowsEl.innerHTML = '';

    for (const { p, depth } of orderedPeople()) {
      rowsEl.appendChild(personRow(p, depth));
    }
  }

  function orderedPeople(): { p: Person; depth: number }[] {
    const out: { p: Person; depth: number }[] = [];
    const visit = (p: Person, depth: number) => {
      out.push({ p, depth });
      childrenOf(state.people, p.id).forEach((c) => visit(c, depth + 1));
    };
    rootsOf(state.people).forEach((r) => visit(r, 0));

    if (out.length < state.people.length) {
      const seen = new Set(out.map((o) => o.p.id));
      state.people.forEach((p) => { if (!seen.has(p.id)) out.push({ p, depth: 0 }); });
    }
    return out;
  }

  function personRow(p: Person, depth: number): HTMLElement {
    const wrap = document.createElement('div');
    wrap.className = 'panel flex flex-col gap-2 p-3';
    wrap.dataset.rowId = p.id;
    wrap.style.marginLeft = `${Math.min(depth, 6) * 12}px`;
    if (p.id === selectedId) wrap.classList.add('border-hairline-strong');

    // name + delete
    const top = document.createElement('div');
    top.className = 'flex items-center gap-2';
    const nameInput = document.createElement('input');
    nameInput.className = 'field';
    nameInput.placeholder = 'Name';
    nameInput.value = p.name;
    nameInput.addEventListener('focus', () => { selectedId = p.id; highlightSelection(); });
    nameInput.addEventListener('input', () => { p.name = nameInput.value; scheduleSnapshot(); render(); });
    const rm = iconBtn('×', 'Remove person', () => {
      snapshot();
      // re-parent this person's reports up to its manager, then remove.
      childrenOf(state.people, p.id).forEach((c) => { c.managerId = p.managerId; });
      state.people = state.people.filter((o) => o.id !== p.id);
      if (selectedId === p.id) selectedId = null;
      renderRows(); render();
    });
    top.append(nameInput, rm);

    // title + department
    const grid = document.createElement('div');
    grid.className = 'grid grid-cols-2 gap-2';
    grid.append(
      field('Title', 'text', p.title ?? '', (v) => { p.title = v || undefined; scheduleSnapshot(); render(); }),
      field('Department', 'text', p.dept ?? '', (v) => { p.dept = v || undefined; scheduleSnapshot(); render(); }),
    );

    // reports-to + color + photo
    const grid2 = document.createElement('div');
    grid2.className = 'flex items-end gap-2';

    const mgrLabel = document.createElement('label');
    mgrLabel.className = 'flex flex-1 flex-col gap-1 text-xs text-ink-subtle';
    mgrLabel.textContent = 'Reports to';
    const mgrSel = document.createElement('select');
    mgrSel.className = 'field';
    mgrSel.add(new Option('— top level —', '', p.managerId === null, p.managerId === null));
    for (const o of state.people) {
      if (o.id === p.id) continue;
      // don't offer a manager that would create a cycle (o is in p's subtree)
      if (wouldCreateCycle(state.people, p.id, o.id)) continue;
      mgrSel.add(new Option(o.name || '(unnamed)', o.id, false, o.id === p.managerId));
    }
    mgrSel.value = p.managerId ?? '';
    mgrSel.addEventListener('change', () => {
      snapshot();
      p.managerId = mgrSel.value || null;
      renderRows(); render();
    });
    mgrLabel.appendChild(mgrSel);

    const color = document.createElement('input');
    color.type = 'color';
    color.className = 'field h-10 w-12 p-1';
    color.value = p.color || '#5e6ad2';
    color.title = 'Accent color';
    color.addEventListener('input', () => { p.color = color.value; scheduleSnapshot(); render(); });

    const photoBtn = iconBtn(p.photo ? '🖼' : '＋', p.photo ? 'Change photo' : 'Add photo', () => {
      pickImage((dataUrl) => { snapshot(); p.photo = dataUrl; renderRows(); render(); });
    });
    photoBtn.classList.add('h-10');

    grid2.append(mgrLabel, color, photoBtn);
    if (p.photo) {
      const clearPhoto = iconBtn('×', 'Remove photo', () => { snapshot(); p.photo = undefined; renderRows(); render(); });
      clearPhoto.classList.add('h-10');
      grid2.append(clearPhoto);
    }

    wrap.append(top, grid, grid2);
    return wrap;
  }

  function field(label: string, type: string, value: string, on: (v: string) => void): HTMLLabelElement {
    const l = document.createElement('label');
    l.className = 'flex flex-col gap-1 text-xs text-ink-subtle';
    l.textContent = label;
    const input = document.createElement('input');
    input.className = 'field';
    input.type = type;
    input.value = value;
    input.addEventListener('input', () => on(input.value));
    l.appendChild(input);
    return l;
  }

  function iconBtn(glyph: string, title: string, on: () => void): HTMLButtonElement {
    const b = document.createElement('button');
    b.className = 'btn btn-tertiary px-2';
    b.textContent = glyph;
    b.title = title;
    b.setAttribute('aria-label', title);
    b.addEventListener('click', on);
    return b;
  }

  // Debounced snapshot for streams of input events (typing) so undo steps are
  // coarse, not per-keystroke.
  let snapTimer = 0;
  function scheduleSnapshot(): void {
    if (restoring) return;
    if (snapTimer) return; // one snapshot per burst
    snapTimer = window.setTimeout(() => { snapTimer = 0; }, 600);
    snapshot();
  }

  // --- image picker (shared by person photo + logo) ---------------------------
  function pickImage(cb: (dataUrl: string) => void): void {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = 'image/*';
    input.addEventListener('change', () => {
      const file = input.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => cb(String(reader.result));
      reader.readAsDataURL(file);
    });
    input.click();
  }

  // --- selection highlight ----------------------------------------------------
  function highlightSelection(): void {
    Array.from(rowsEl.children).forEach((el) => {
      (el as HTMLElement).classList.toggle('border-hairline-strong', (el as HTMLElement).dataset.rowId === selectedId);
    });
    if (!last) return;
    // outline the selected box in the SVG
    const svg = preview.querySelector('svg');
    if (!svg || !selectedId) return;
    const b = last.byId.get(selectedId);
    if (!b) return;
    const ns = 'http://www.w3.org/2000/svg';
    const rect = document.createElementNS(ns, 'rect');
    rect.setAttribute('x', String(b.x - 2));
    rect.setAttribute('y', String(b.y - 2));
    rect.setAttribute('width', String(b.w + 4));
    rect.setAttribute('height', String(b.h + 4));
    rect.setAttribute('rx', '10');
    rect.setAttribute('fill', 'none');
    rect.setAttribute('stroke', '#828fff');
    rect.setAttribute('stroke-width', '2');
    svg.appendChild(rect);
  }

  // --- drag on the SVG preview (re-parent) ------------------------------------
  interface Drag { id: string; moved: boolean; }
  let drag: Drag | null = null;

  function toUser(e: PointerEvent): { x: number; y: number } | null {
    const svg = preview.querySelector('svg');
    if (!svg || !last) return null;
    const rct = svg.getBoundingClientRect();
    return { x: ((e.clientX - rct.left) / rct.width) * last.width, y: ((e.clientY - rct.top) / rct.height) * last.height };
  }
  function boxAt(u: { x: number; y: number }): string | null {
    if (!last) return null;
    for (const b of last.boxes) {
      if (u.x >= b.x && u.x <= b.x + b.w && u.y >= b.y && u.y <= b.y + b.h) return b.id;
    }
    return null;
  }

  preview.addEventListener('pointerdown', (e) => {
    const u = toUser(e);
    if (!u) return;
    const id = boxAt(u);
    if (!id) return;
    drag = { id, moved: false };
    selectedId = id;
    render();
    scrollRowIntoView(id);
    preview.setPointerCapture(e.pointerId);
    e.preventDefault();
  });

  preview.addEventListener('pointermove', (e) => {
    if (!drag || !last) return;
    const u = toUser(e);
    if (!u) return;
    drag.moved = true;
    // live: render + a ghost line from the dragged box to the pointer, and
    // highlight a valid drop target.
    render();
    const from = last.byId.get(drag.id);
    const svg = preview.querySelector('svg');
    if (!from || !svg) return;
    const ns = 'http://www.w3.org/2000/svg';
    const targetId = boxAt(u);
    const validTarget = targetId && targetId !== drag.id && !wouldCreateCycle(state.people, drag.id, targetId);
    if (validTarget) {
      const tb = last.byId.get(targetId!)!;
      const hl = document.createElementNS(ns, 'rect');
      hl.setAttribute('x', String(tb.x - 2)); hl.setAttribute('y', String(tb.y - 2));
      hl.setAttribute('width', String(tb.w + 4)); hl.setAttribute('height', String(tb.h + 4));
      hl.setAttribute('rx', '10'); hl.setAttribute('fill', 'none');
      hl.setAttribute('stroke', '#27a644'); hl.setAttribute('stroke-width', '2.5');
      svg.appendChild(hl);
    }
    const line = document.createElementNS(ns, 'line');
    line.setAttribute('x1', String(from.x + from.w / 2)); line.setAttribute('y1', String(from.y + from.h / 2));
    line.setAttribute('x2', String(u.x)); line.setAttribute('y2', String(u.y));
    line.setAttribute('stroke', '#828fff'); line.setAttribute('stroke-width', '1.5'); line.setAttribute('stroke-dasharray', '4 3');
    svg.appendChild(line);
    setStatus(validTarget ? 'Drop to report here' : targetId ? 'Cannot report there (would create a loop)' : 'Drop on empty space to promote to top');
  });

  preview.addEventListener('pointerup', (e) => {
    if (!drag) return;
    const d = drag; drag = null;
    setStatus('');
    if (!d.moved || !last) { render(); return; }
    const u = toUser(e);
    if (!u) { render(); return; }
    const targetId = boxAt(u);
    const p = person(d.id);
    if (!p) { render(); return; }
    if (targetId === null) {
      // dropped on empty space -> promote to top level
      if (p.managerId !== null) { snapshot(); p.managerId = null; renderRows(); }
    } else if (targetId !== d.id && !wouldCreateCycle(state.people, d.id, targetId)) {
      if (p.managerId !== targetId) { snapshot(); p.managerId = targetId; renderRows(); }
    }
    render();
  });
  preview.addEventListener('pointercancel', () => { drag = null; setStatus(''); render(); });

  function scrollRowIntoView(id: string): void {
    const row = rowsEl.querySelector(`[data-row-id="${id}"]`);
    row?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  // --- tabs -------------------------------------------------------------------
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.occ-tab'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));
  function showTab(name: string): void {
    tabs.forEach((t) => {
      const on = t.dataset.tab === name;
      t.setAttribute('aria-selected', String(on));
      t.classList.toggle('btn-secondary', on);
      t.classList.toggle('btn-tertiary', !on);
    });
    panels.forEach((p) => {
      const on = p.dataset.panel === name;
      p.classList.toggle('hidden', !on);
      p.classList.toggle('flex', on);
    });
  }
  tabs.forEach((t) => t.addEventListener('click', () => showTab(t.dataset.tab!)));

  // --- templates gallery ------------------------------------------------------
  function renderTemplates(): void {
    const host = $<HTMLDivElement>('occ-templates');
    host.innerHTML = '';
    for (const group of templateGroups()) {
      const section = document.createElement('div');
      section.className = 'flex flex-col gap-2';
      const h = document.createElement('span');
      h.className = 'text-xs font-medium uppercase tracking-wide text-ink-subtle';
      h.textContent = group.label;
      const gridw = document.createElement('div');
      gridw.className = 'grid grid-cols-2 gap-2';
      for (const tpl of group.items) {
        const card = document.createElement('button');
        card.className = 'panel flex items-center gap-2 p-3 text-left text-sm text-ink hover:border-hairline-strong';
        const ic = document.createElement('span');
        ic.className = 'text-lg leading-none';
        ic.textContent = tpl.icon;
        const lbl = document.createElement('span');
        lbl.textContent = tpl.label;
        card.append(ic, lbl);
        card.addEventListener('click', () => {
          snapshot();
          state = templateToChart(tpl);
          selectedId = null;
          titleEl.value = state.title;
          syncStyleControls();
          renderRows();
          render();
        });
        gridw.appendChild(card);
      }
      section.append(h, gridw);
      host.appendChild(section);
    }
  }

  // --- style controls ---------------------------------------------------------
  const themeSel = $<HTMLSelectElement>('occ-theme');
  const layoutSel = $<HTMLSelectElement>('occ-layout');
  const sizeSel = $<HTMLSelectElement>('occ-size');
  ORG_THEMES.forEach((t) => themeSel.add(new Option(t.label, t.id)));
  LAYOUTS.forEach((l) => layoutSel.add(new Option(l.label, l.id)));
  SIZE_PRESETS.forEach((s) => sizeSel.add(new Option(s.label, s.id)));

  function syncStyleControls(): void {
    themeSel.value = state.themeId;
    layoutSel.value = state.layoutId;
    sizeSel.value = state.sizeId;
    $<HTMLButtonElement>('occ-logo-clear').classList.toggle('hidden', !state.logo);
  }
  themeSel.addEventListener('change', () => { snapshot(); state.themeId = themeSel.value; render(); });
  layoutSel.addEventListener('change', () => { snapshot(); state.layoutId = layoutSel.value; render(); });
  sizeSel.addEventListener('change', () => { snapshot(); state.sizeId = sizeSel.value; render(); });

  $<HTMLButtonElement>('occ-logo-btn').addEventListener('click', () => {
    pickImage((dataUrl) => { snapshot(); state.logo = dataUrl; syncStyleControls(); render(); });
  });
  $<HTMLButtonElement>('occ-logo-clear').addEventListener('click', () => {
    snapshot(); state.logo = undefined; syncStyleControls(); render();
  });

  // --- import panel (outline + CSV paste) -------------------------------------
  const importErr = $<HTMLParagraphElement>('occ-import-err');
  function showImportError(msg: string): void { importErr.textContent = msg; importErr.classList.remove('hidden'); }
  function clearImportError(): void { importErr.classList.add('hidden'); }

  $<HTMLButtonElement>('occ-outline-btn').addEventListener('click', () => {
    const text = $<HTMLTextAreaElement>('occ-outline').value;
    if (!text.trim()) { showImportError('Type an indented list of roles first.'); return; }
    clearImportError();
    snapshot();
    const built = fromOutline(text);
    built.themeId = state.themeId; built.layoutId = state.layoutId; built.sizeId = state.sizeId;
    state = built; selectedId = null;
    titleEl.value = state.title;
    renderRows(); render(); showTab('people');
  });

  $<HTMLButtonElement>('occ-csv-btn').addEventListener('click', () => {
    const text = $<HTMLTextAreaElement>('occ-csv').value;
    if (!text.trim()) { showImportError('Paste some CSV first.'); return; }
    try {
      const built = fromCSV(text);
      clearImportError();
      snapshot();
      built.themeId = state.themeId; built.layoutId = state.layoutId; built.sizeId = state.sizeId;
      state = built; selectedId = null;
      titleEl.value = state.title;
      renderRows(); render(); showTab('people');
    } catch (err) {
      showImportError(err instanceof Error ? err.message : 'That CSV could not be read.');
    }
  });

  // --- exports ----------------------------------------------------------------
  function setStatus(msg: string): void { statusEl.textContent = msg; }
  function download(blob: Blob, name: string): void {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }
  function rasterize(scale = 2): Promise<HTMLCanvasElement> {
    return new Promise((resolve, reject) => {
      if (!last) return reject(new Error('nothing to render'));
      const svgBlob = new Blob([last.svg], { type: 'image/svg+xml;charset=utf-8' });
      const url = URL.createObjectURL(svgBlob);
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = last!.width * scale;
        canvas.height = last!.height * scale;
        canvas.getContext('2d')!.drawImage(img, 0, 0, canvas.width, canvas.height);
        URL.revokeObjectURL(url);
        resolve(canvas);
      };
      img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('SVG rasterization failed')); };
      img.src = url;
    });
  }

  $<HTMLButtonElement>('occ-svg').addEventListener('click', () => {
    if (last) download(new Blob([last.svg], { type: 'image/svg+xml' }), 'toolsilk-org-chart.svg');
  });
  $<HTMLButtonElement>('occ-png').addEventListener('click', async () => {
    try {
      const canvas = await rasterize();
      canvas.toBlob((b) => b && download(b, 'toolsilk-org-chart.png'), 'image/png');
    } catch { setStatus('PNG export failed.'); }
  });
  $<HTMLButtonElement>('occ-pdf').addEventListener('click', async () => {
    setStatus('Building PDF…');
    try {
      const canvas = await rasterize();
      const pngBytes = await new Promise<Uint8Array>((res) =>
        canvas.toBlob(async (b) => res(new Uint8Array(await b!.arrayBuffer())), 'image/png'));
      const { PDFDocument } = await import('pdf-lib');
      const pdf = await PDFDocument.create();
      const png = await pdf.embedPng(pngBytes);
      const page = pdf.addPage([png.width / 2, png.height / 2]);
      page.drawImage(png, { x: 0, y: 0, width: png.width / 2, height: png.height / 2 });
      const bytes = await pdf.save();
      download(new Blob([bytes.slice()], { type: 'application/pdf' }), 'toolsilk-org-chart.pdf');
      setStatus('');
    } catch { setStatus('PDF export failed.'); }
  });
  $<HTMLButtonElement>('occ-json').addEventListener('click', () => {
    download(new Blob([toJSON(state)], { type: 'application/json' }), 'toolsilk-org-chart.json');
  });
  $<HTMLButtonElement>('occ-csv-dl').addEventListener('click', () => {
    download(new Blob([toCSV(state)], { type: 'text/csv' }), 'toolsilk-org-chart.csv');
  });

  // --- import file (JSON / CSV) -----------------------------------------------
  const fileInput = $<HTMLInputElement>('occ-file');
  $<HTMLButtonElement>('occ-import-btn').addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    const text = await file.text();
    try {
      const trimmed = text.trimStart();
      const next = (file.name.endsWith('.csv') || (!trimmed.startsWith('{') && /,/.test(trimmed.split('\n')[0])))
        ? fromCSV(text)
        : fromJSON(text);
      snapshot();
      state = next; selectedId = null;
      titleEl.value = state.title;
      syncStyleControls();
      renderRows(); render();
      setStatus('Imported chart.');
    } catch {
      setStatus('That file could not be read as JSON or CSV.');
    }
    fileInput.value = '';
  });

  // --- add person -------------------------------------------------------------
  $<HTMLButtonElement>('occ-add').addEventListener('click', () => {
    snapshot();
    // new person reports to the current selection (or a root if none / selection is gone)
    const parent = selectedId && person(selectedId) ? selectedId : (rootsOf(state.people)[0]?.id ?? null);
    const np: Person = { id: newId(), name: 'New person', title: '', managerId: parent };
    state.people.push(np);
    selectedId = np.id;
    renderRows(); render();
    scrollRowIntoView(np.id);
  });

  // --- keyboard: undo/redo, delete selection ----------------------------------
  document.addEventListener('keydown', (e) => {
    const tag = (e.target as HTMLElement)?.tagName;
    const typing = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }
    else if ((e.ctrlKey || e.metaKey) && (e.key.toLowerCase() === 'y' || (e.shiftKey && e.key.toLowerCase() === 'z'))) { e.preventDefault(); redo(); }
    else if (!typing && (e.key === 'Delete' || e.key === 'Backspace') && selectedId) {
      const p = person(selectedId);
      if (p) {
        e.preventDefault();
        snapshot();
        childrenOf(state.people, p.id).forEach((c) => { c.managerId = p.managerId; });
        state.people = state.people.filter((o) => o.id !== p.id);
        selectedId = null;
        renderRows(); render();
      }
    }
  });

  $<HTMLButtonElement>('occ-undo').addEventListener('click', undo);
  $<HTMLButtonElement>('occ-redo').addEventListener('click', redo);
  titleEl.addEventListener('input', () => { scheduleSnapshot(); render(); });

  // --- init -------------------------------------------------------------------
  titleEl.value = state.title;
  syncStyleControls();
  renderTemplates();
  renderRows();
  render();
  showTab('people');
  syncUndoButtons();
</script>

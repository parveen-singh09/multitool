---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="logo-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-[1fr_1.1fr]">
    <div class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Brand name
        <input id="lg-name" class="field" value="Northwind" spellcheck="false" maxlength="24" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Tagline (optional)
        <input id="lg-tag" class="field" value="Build in motion" spellcheck="false" maxlength="36" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Symbol
          <select id="lg-icon" class="field"></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Layout
          <select id="lg-layout" class="field">
            <option value="left">Icon left</option>
            <option value="top">Icon top</option>
            <option value="none">Text only</option>
          </select>
        </label>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Font
          <select id="lg-font" class="field">
            <option value="'Inter',system-ui,sans-serif">Sans (Inter)</option>
            <option value="Georgia,'Times New Roman',serif">Serif</option>
            <option value="'Trebuchet MS',Verdana,sans-serif">Geometric</option>
            <option value="'Courier New',monospace">Mono</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight
          <select id="lg-weight" class="field">
            <option value="800">Heavy</option>
            <option value="700" selected>Bold</option>
            <option value="500">Medium</option>
            <option value="400">Regular</option>
          </select>
        </label>
      </div>
      <div class="flex flex-wrap items-center gap-4 pt-1">
        <label class="flex items-center gap-2 text-sm text-ink-subtle">Accent
          <input id="lg-accent" type="color" value="#5e6ad2" class="field h-9 w-14 cursor-pointer p-1" />
        </label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle">Background
          <select id="lg-bg" class="field">
            <option value="transparent">Transparent</option>
            <option value="#0f1011">Dark</option>
            <option value="#ffffff">White</option>
            <option value="accent">Accent fill</option>
          </select>
        </label>
        <button id="lg-shuffle" class="btn btn-secondary ml-auto">Shuffle</button>
      </div>
    </div>

    <div class="flex flex-col items-center gap-4">
      <div id="lg-stage" class="flex w-full items-center justify-center overflow-hidden rounded-xl border border-hairline" style="min-height:220px;background-image:linear-gradient(45deg,#141516 25%,transparent 25%),linear-gradient(-45deg,#141516 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#141516 75%),linear-gradient(-45deg,transparent 75%,#141516 75%);background-size:16px 16px;background-position:0 0,0 8px,8px -8px,-8px 0;">

      </div>
      <div class="flex flex-wrap justify-center gap-2">
        <button id="lg-svg" class="btn btn-secondary">Download SVG</button>
        <button id="lg-png" class="btn btn-primary">Download PNG</button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free logo generator pairs your brand name with a clean geometric symbol,
      a font, a layout and an accent color to produce a simple, professional wordmark.
      It's ideal for side projects, startups, event branding and placeholder logos while
      you iterate. Because the logo is drawn as vector SVG, you can download it as an
      infinitely scalable SVG file or a high-resolution transparent PNG. Everything is
      rendered in your browser — your brand name never leaves your device.
    </p>
  </div>
</ToolLayout>

<script>
  import { pick, randInt } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const stage = $('lg-stage')!;

  const ICONS: Record<string, string> = {
    Bolt: '<path d="M55 8 25 56h22l-6 36 34-52H52z" fill="currentColor"/>',
    Orbit: '<circle cx="50" cy="50" r="14" fill="currentColor"/><ellipse cx="50" cy="50" rx="42" ry="18" fill="none" stroke="currentColor" stroke-width="6" transform="rotate(30 50 50)"/>',
    Cube: '<path d="M50 8 88 30v40L50 92 12 70V30z" fill="none" stroke="currentColor" stroke-width="7" stroke-linejoin="round"/><path d="M12 30 50 52 88 30M50 52v40" fill="none" stroke="currentColor" stroke-width="7" stroke-linejoin="round"/>',
    Peak: '<path d="M10 82 40 26l18 30 12-18 20 44z" fill="currentColor"/>',
    Leaf: '<path d="M78 18C40 20 20 44 20 82c40 2 62-22 58-64z" fill="currentColor"/><path d="M32 70C46 54 60 42 74 34" fill="none" stroke="#0f1011" stroke-width="5" opacity="0.35"/>',
    Wave: '<path d="M8 60c12-24 22-24 34 0s22 24 34 0 22-24 16 0" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="round"/>',
    Spark: '<path d="M50 6l10 34 34 10-34 10-10 34-10-34L6 50l34-10z" fill="currentColor"/>',
    Ring: '<circle cx="50" cy="50" r="34" fill="none" stroke="currentColor" stroke-width="12"/><circle cx="50" cy="50" r="10" fill="currentColor"/>',
    Shield: '<path d="M50 8 84 22v28c0 26-18 38-34 44-16-6-34-18-34-44V22z" fill="currentColor"/>',
    Grid: '<rect x="12" y="12" width="30" height="30" rx="5" fill="currentColor"/><rect x="58" y="12" width="30" height="30" rx="5" fill="currentColor" opacity="0.6"/><rect x="12" y="58" width="30" height="30" rx="5" fill="currentColor" opacity="0.6"/><rect x="58" y="58" width="30" height="30" rx="5" fill="currentColor"/>',
    Compass: '<circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="7"/><path d="M50 24 62 62 26 50z" fill="currentColor"/>',
  };
  const ICON_NAMES = Object.keys(ICONS);
  ($('lg-icon') as HTMLSelectElement).innerHTML = ICON_NAMES.map((n) => `<option value="${n}">${n}</option>`).join('');

  const get = (id: string) => ($(id) as HTMLInputElement).value;

  function escapeXml(s: string) {
    return s.replace(/[<>&'"]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', "'": '&apos;', '"': '&quot;' }[c]!));
  }

  const measureCtx = document.createElement('canvas').getContext('2d')!;
  function textWidth(text: string, size: number, weight: string, font: string, spacing: number) {
    measureCtx.font = `${weight} ${size}px ${font}`;
    const w = measureCtx.measureText(text).width;
    return text.length > 1 ? w + spacing * (text.length - 1) : w;
  }

  function buildSvg(): { svg: string; w: number; h: number } {
    const name = escapeXml(get('lg-name') || 'Brand');
    const tag = escapeXml(get('lg-tag'));
    const iconName = get('lg-icon');
    const layout = get('lg-layout');
    const font = get('lg-font');
    const weight = get('lg-weight');
    const accent = get('lg-accent');
    const bgChoice = get('lg-bg');

    const onAccent = bgChoice === 'accent';
    const textColor = bgChoice === '#ffffff' ? '#0f1011' : onAccent ? '#ffffff' : '#f7f8f8';
    const iconColor = onAccent ? '#ffffff' : accent;
    const tagColor = bgChoice === '#ffffff' ? '#6b7280' : onAccent ? 'rgba(255,255,255,0.8)' : '#8a8f98';
    const bg = bgChoice === 'accent' ? accent : bgChoice;

    const nameSize = 54;
    const tagSize = 20;
    const nameW = textWidth(name, nameSize, weight, font, -1);
    const tagW = tag ? textWidth(tag, tagSize, '400', font, 1) : 0;
    const textW = Math.max(nameW, tagW);
    const iconBox = 88;
    const gap = 24;
    const pad = 40;
    const showIcon = layout !== 'none';

    let w: number, h: number, iconG = '', textG = '';

    if (layout === 'top' && showIcon) {
      w = Math.max(iconBox, textW) + pad * 2;
      const textBlockH = nameSize + (tag ? tagSize + 12 : 0);
      h = pad * 2 + iconBox + gap + textBlockH;
      const cx = w / 2;
      iconG = `<g transform="translate(${cx - iconBox / 2},${pad}) scale(${iconBox / 100})" color="${iconColor}">${ICONS[iconName]}</g>`;
      const ty = pad + iconBox + gap + nameSize * 0.8;
      textG = `<text x="${cx}" y="${ty}" text-anchor="middle" font-family="${font}" font-weight="${weight}" font-size="${nameSize}" fill="${textColor}" letter-spacing="-1">${name}</text>`;
      if (tag) textG += `<text x="${cx}" y="${ty + tagSize + 10}" text-anchor="middle" font-family="${font}" font-weight="400" font-size="${tagSize}" fill="${tagColor}" letter-spacing="1">${tag}</text>`;
    } else if (layout === 'left' && showIcon) {
      const textX = pad + iconBox + gap;
      w = textX + textW + pad;
      h = pad * 2 + Math.max(iconBox, nameSize + (tag ? tagSize + 12 : 0));
      const cy = h / 2;
      iconG = `<g transform="translate(${pad},${cy - iconBox / 2}) scale(${iconBox / 100})" color="${iconColor}">${ICONS[iconName]}</g>`;
      const ty = tag ? cy - 4 : cy + nameSize * 0.34;
      textG = `<text x="${textX}" y="${ty}" font-family="${font}" font-weight="${weight}" font-size="${nameSize}" fill="${textColor}" letter-spacing="-1" dominant-baseline="${tag ? 'auto' : 'middle'}">${name}</text>`;
      if (tag) textG += `<text x="${textX}" y="${cy + tagSize + 6}" font-family="${font}" font-weight="400" font-size="${tagSize}" fill="${tagColor}" letter-spacing="1">${tag}</text>`;
    } else {
      w = textW + pad * 2;
      h = pad * 2 + nameSize + (tag ? tagSize + 12 : 0);
      const cx = w / 2;
      const ty = pad + nameSize * 0.8;
      textG = `<text x="${cx}" y="${ty}" text-anchor="middle" font-family="${font}" font-weight="${weight}" font-size="${nameSize}" fill="${textColor}" letter-spacing="-1">${name}</text>`;
      if (tag) textG += `<text x="${cx}" y="${ty + tagSize + 10}" text-anchor="middle" font-family="${font}" font-weight="400" font-size="${tagSize}" fill="${tagColor}" letter-spacing="1">${tag}</text>`;
    }

    const rect = bg && bg !== 'transparent' ? `<rect width="${w}" height="${h}" rx="18" fill="${bg}"/>` : '';
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${Math.round(w)} ${Math.round(h)}" width="${Math.round(w)}" height="${Math.round(h)}">${rect}${iconG}${textG}</svg>`;
    return { svg, w: Math.round(w), h: Math.round(h) };
  }

  let current = buildSvg();
  function render() {
    current = buildSvg();
    stage.innerHTML = current.svg.replace('<svg ', '<svg style="max-width:100%;height:auto;max-height:280px" ');
  }

  ['lg-name', 'lg-tag', 'lg-icon', 'lg-layout', 'lg-font', 'lg-weight', 'lg-accent', 'lg-bg'].forEach((id) =>
    $(id).addEventListener('input', render)
  );

  $('lg-shuffle').addEventListener('click', () => {
    ($('lg-icon') as HTMLSelectElement).value = pick(ICON_NAMES);
    const fonts = ["'Inter',system-ui,sans-serif", 'Georgia,\'Times New Roman\',serif', "'Trebuchet MS',Verdana,sans-serif", "'Courier New',monospace"];
    ($('lg-font') as HTMLSelectElement).value = pick(fonts);
    ($('lg-layout') as HTMLSelectElement).value = pick(['left', 'top', 'none', 'left']);
    const hue = randInt(0, 359);
    ($('lg-accent') as HTMLInputElement).value = hslToHex(hue, 60, 58);
    render();
  });

  function hslToHex(h: number, s: number, l: number): string {
    l /= 100; const a = (s * Math.min(l, 1 - l)) / 100;
    const f = (n: number) => {
      const k = (n + h / 30) % 12;
      const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1);
      return Math.round(255 * c).toString(16).padStart(2, '0');
    };
    return `#${f(0)}${f(8)}${f(4)}`;
  }

  function downloadBlob(blob: Blob, filename: string) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  $('lg-svg').addEventListener('click', () => {
    downloadBlob(new Blob([current.svg], { type: 'image/svg+xml' }), 'logo.svg');
  });

  $('lg-png').addEventListener('click', () => {
    const scale = 3;
    const img = new Image();
    const blob = new Blob([current.svg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = current.w * scale;
      canvas.height = current.h * scale;
      const ctx = canvas.getContext('2d')!;
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
      URL.revokeObjectURL(url);
      canvas.toBlob((b) => b && downloadBlob(b, 'logo.png'), 'image/png');
    };
    img.src = url;
  });

  render();
</script>

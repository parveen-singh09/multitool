---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="sitemap-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Page URLs (one per line)
        <textarea id="sm-urls" class="field min-h-48 resize-y font-mono text-[13px]" spellcheck="false">https://example.com/
https://example.com/about
https://example.com/contact</textarea>
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Change frequency
          <select id="sm-freq" class="field"><option value="">(none)</option><option>always</option><option>hourly</option><option selected>daily</option><option>weekly</option><option>monthly</option><option>yearly</option><option>never</option></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Priority
          <select id="sm-priority" class="field"><option value="">(none)</option><option>1.0</option><option selected>0.8</option><option>0.5</option><option>0.3</option></select>
        </label>
      </div>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="sm-lastmod" type="checkbox" class="accent-[#5e6ad2]" checked /> Include today's lastmod</label>
    </div>

    <div class="flex flex-col gap-2">
      <label class="text-sm text-ink-subtle">sitemap.xml</label>
      <textarea id="sm-out" class="field min-h-72 resize-y font-mono text-[12px]" readonly></textarea>
      <div class="flex gap-2">
        <button id="sm-copy" class="btn btn-secondary">Copy</button>
        <button id="sm-dl" class="btn btn-secondary">Download</button>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free sitemap.xml generator turns a plain list of page URLs into a valid
      XML sitemap that search engines use to discover and prioritize your pages.
      Set an optional change frequency, priority and a lastmod date, then copy or
      download the file and reference it from your robots.txt. Generated entirely
      in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const out = $('sm-out') as HTMLTextAreaElement;
  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  function build() {
    const urls = ($('sm-urls') as HTMLTextAreaElement).value.split('\n').map((l) => l.trim()).filter(Boolean);
    const freq = ($('sm-freq') as HTMLSelectElement).value;
    const priority = ($('sm-priority') as HTMLSelectElement).value;
    const lastmod = ($('sm-lastmod') as HTMLInputElement).checked ? new Date().toISOString().slice(0, 10) : '';
    const body = urls.map((u) => {
      const parts = [`    <loc>${esc(u)}</loc>`];
      if (lastmod) parts.push(`    <lastmod>${lastmod}</lastmod>`);
      if (freq) parts.push(`    <changefreq>${freq}</changefreq>`);
      if (priority) parts.push(`    <priority>${priority}</priority>`);
      return `  <url>\n${parts.join('\n')}\n  </url>`;
    }).join('\n');
    out.value = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n${body}\n</urlset>`;
  }

  ['sm-urls', 'sm-freq', 'sm-priority', 'sm-lastmod'].forEach((id) => $(id).addEventListener('input', build));
  $('sm-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
  $('sm-dl').addEventListener('click', () => {
    const url = URL.createObjectURL(new Blob([out.value], { type: 'application/xml' }));
    const a = document.createElement('a'); a.href = url; a.download = 'sitemap.xml'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });
  build();
</script>

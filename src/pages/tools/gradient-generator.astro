---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="gradient-generator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_minmax(0,360px)]">

    <div class="flex flex-col gap-4">
      <div id="gg-preview" class="panel relative h-72 overflow-hidden rounded-lg md:h-96">
        <button
          id="gg-fs"
          type="button"
          class="btn btn-secondary absolute right-3 top-3 px-2 py-1 text-[13px]"
          title="Fullscreen preview"
        >⤢ Fullscreen</button>
      </div>

      <div>
        <span class="text-[13px] text-ink-subtle">Presets</span>
        <div id="gg-presets" class="mt-2 grid grid-cols-6 gap-2 sm:grid-cols-10"></div>
      </div>
    </div>

    <div class="flex flex-col gap-5">
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1">
          <span class="text-[13px] text-ink-subtle">Type</span>
          <select id="gg-type" class="field w-32">
            <option value="linear">Linear</option>
            <option value="radial">Radial</option>
            <option value="conic">Conic</option>
          </select>
        </label>
        <label class="flex flex-col gap-1" id="gg-shape-wrap" style="display:none">
          <span class="text-[13px] text-ink-subtle">Shape</span>
          <select id="gg-shape" class="field w-32">
            <option value="circle">Circle</option>
            <option value="ellipse">Ellipse</option>
          </select>
        </label>
      </div>

      <label class="flex flex-col gap-1" id="gg-angle-wrap">
        <span class="text-[13px] text-ink-subtle">Angle: <span id="gg-angle-val">90</span>°</span>
        <input id="gg-angle" type="range" min="0" max="360" value="90" class="w-full" />
      </label>

      <div class="flex flex-col gap-1" id="gg-pos-wrap" style="display:none">
        <span class="text-[13px] text-ink-subtle">Center position</span>
        <div class="grid grid-cols-2 gap-3">
          <label class="flex items-center gap-2 text-[13px] text-ink-subtle">X
            <input id="gg-posx" type="range" min="0" max="100" value="50" class="flex-1" />
          </label>
          <label class="flex items-center gap-2 text-[13px] text-ink-subtle">Y
            <input id="gg-posy" type="range" min="0" max="100" value="50" class="flex-1" />
          </label>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between">
          <span class="text-[13px] text-ink-subtle">Color stops</span>
          <div class="flex gap-2">
            <button id="gg-add" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">+ Add</button>
            <button id="gg-random" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">🎲 Random</button>
          </div>
        </div>
        <div id="gg-stops" class="mt-2 flex flex-col gap-2"></div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <span class="text-[13px] text-ink-subtle">CSS</span>
        </div>
        <div class="copy-wrap"><pre class="hl-block field p-3 text-[13px]" style="max-height:12rem"><code id="gg-css-hl" class="hljs language-css" style="background:transparent"></code></pre><button type="button" class="copy-icon" data-copy-target="#gg-css-hl" aria-label="Copy"></button></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSS gradient generator builds linear, radial and conic gradients
      with unlimited color stops, live preview, and a curated preset gallery.
      Pick colors, drag each stop's position and opacity, set the angle or radial
      center, then copy production-ready, syntax-highlighted <code>background</code>
      CSS. The preview renders live as you edit.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl } from '../../lib/highlight';

  interface Stop { color: string; alpha: number; pos: number; }

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const preview = $('gg-preview');
  const typeSel = $<HTMLSelectElement>('gg-type');
  const shapeSel = $<HTMLSelectElement>('gg-shape');
  const shapeWrap = $('gg-shape-wrap');
  const angle = $<HTMLInputElement>('gg-angle');
  const angleVal = $('gg-angle-val');
  const angleWrap = $('gg-angle-wrap');
  const posWrap = $('gg-pos-wrap');
  const posX = $<HTMLInputElement>('gg-posx');
  const posY = $<HTMLInputElement>('gg-posy');
  const stopsWrap = $('gg-stops');
  const cssHl = $('gg-css-hl');
  const presetsWrap = $('gg-presets');

  let stops: Stop[] = [
    { color: '#5e6ad2', alpha: 1, pos: 0 },
    { color: '#828fff', alpha: 1, pos: 100 },
  ];

  function toCss(color: string, alpha: number): string {
    if (alpha >= 1) return color;
    const r = parseInt(color.slice(1, 3), 16);
    const g = parseInt(color.slice(3, 5), 16);
    const b = parseInt(color.slice(5, 7), 16);
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  function stopList(): string {
    return [...stops]
      .sort((a, b) => a.pos - b.pos)
      .map((s) => `${toCss(s.color, s.alpha)} ${s.pos}%`)
      .join(', ');
  }

  function gradientCss(): string {
    const list = stopList();
    const t = typeSel.value;
    if (t === 'linear') return `linear-gradient(${angle.value}deg, ${list})`;
    if (t === 'radial')
      return `radial-gradient(${shapeSel.value} at ${posX.value}% ${posY.value}%, ${list})`;
    return `conic-gradient(from ${angle.value}deg at ${posX.value}% ${posY.value}%, ${list})`;
  }

  async function render() {
    const t = typeSel.value;
    angleWrap.style.display = t === 'radial' ? 'none' : '';
    shapeWrap.style.display = t === 'radial' ? '' : 'none';
    posWrap.style.display = t === 'radial' || t === 'conic' ? '' : 'none';

    const css = gradientCss();
    preview.style.background = css;
    angleVal.textContent = angle.value;
    await hl(cssHl, `background: ${css};`, 'css');
  }

  function renderStops() {
    stopsWrap.innerHTML = '';
    stops.forEach((s, i) => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2';
      row.innerHTML = `
        <input type="color" value="${s.color}" class="h-9 w-11 shrink-0 cursor-pointer rounded-sm border border-hairline bg-surface-1" aria-label="Stop color" />
        <input type="range" min="0" max="100" value="${s.pos}" class="flex-1" aria-label="Stop position" title="Position" />
        <input type="range" min="0" max="100" value="${Math.round(s.alpha * 100)}" class="w-16" aria-label="Stop opacity" title="Opacity" />
        <span class="w-9 text-right font-mono text-[12px] text-ink-subtle">${s.pos}%</span>
        <button type="button" class="btn btn-secondary px-2 py-1 text-[13px]" ${stops.length <= 2 ? 'disabled style=opacity:.4' : ''} aria-label="Remove stop">✕</button>`;
      const colorEl = row.children[0] as HTMLInputElement;
      const posEl = row.children[1] as HTMLInputElement;
      const alphaEl = row.children[2] as HTMLInputElement;
      const posLbl = row.children[3] as HTMLElement;
      const delEl = row.children[4] as HTMLButtonElement;

      colorEl.addEventListener('input', () => { stops[i].color = colorEl.value; render(); });
      posEl.addEventListener('input', () => { stops[i].pos = +posEl.value; posLbl.textContent = `${posEl.value}%`; render(); });
      alphaEl.addEventListener('input', () => { stops[i].alpha = +alphaEl.value / 100; render(); });
      delEl.addEventListener('click', () => { if (stops.length > 2) { stops.splice(i, 1); renderStops(); render(); } });
      stopsWrap.appendChild(row);
    });
  }

  const rand = () =>
    '#' + Array.from({ length: 3 }, () => Math.floor(Math.random() * 256).toString(16).padStart(2, '0')).join('');

  // Curated presets — each is [type, angle, [ [color, pos], ... ]].
  const PRESETS: [string, number, [string, number][]][] = [
    ['linear', 90, [['#5e6ad2', 0], ['#828fff', 100]]],
    ['linear', 135, [['#f093fb', 0], ['#f5576c', 100]]],
    ['linear', 120, [['#4facfe', 0], ['#00f2fe', 100]]],
    ['linear', 135, [['#43e97b', 0], ['#38f9d7', 100]]],
    ['linear', 45, [['#fa709a', 0], ['#fee140', 100]]],
    ['linear', 90, [['#30cfd0', 0], ['#330867', 100]]],
    ['linear', 135, [['#667eea', 0], ['#764ba2', 100]]],
    ['linear', 120, [['#f6d365', 0], ['#fda085', 100]]],
    ['linear', 90, [['#a18cd1', 0], ['#fbc2eb', 100]]],
    ['linear', 135, [['#ff9a9e', 0], ['#fecfef', 100]]],
    ['radial', 0, [['#ff6e7f', 0], ['#bfe9ff', 100]]],
    ['linear', 90, [['#0f2027', 0], ['#203a43', 50], ['#2c5364', 100]]],
    ['linear', 135, [['#ee9ca7', 0], ['#ffdde1', 100]]],
    ['conic', 0, [['#ff0000', 0], ['#00ff00', 50], ['#0000ff', 100]]],
    ['linear', 90, [['#f83600', 0], ['#f9d423', 100]]],
    ['linear', 135, [['#c471f5', 0], ['#fa71cd', 100]]],
    ['linear', 90, [['#12c2e9', 0], ['#c471ed', 50], ['#f64f59', 100]]],
    ['linear', 135, [['#3a1c71', 0], ['#d76d77', 50], ['#ffaf7b', 100]]],
    ['linear', 90, [['#00c6ff', 0], ['#0072ff', 100]]],
    ['linear', 135, [['#e0c3fc', 0], ['#8ec5fc', 100]]],
  ];

  function renderPresets() {
    PRESETS.forEach(([type, ang, cols]) => {
      const list = cols.map(([c, p]) => `${c} ${p}%`).join(', ');
      const css =
        type === 'linear' ? `linear-gradient(${ang}deg, ${list})`
        : type === 'radial' ? `radial-gradient(circle, ${list})`
        : `conic-gradient(${list})`;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'aspect-square rounded-md border border-hairline transition-transform hover:scale-110';
      btn.style.background = css;
      btn.title = 'Apply preset';
      btn.addEventListener('click', () => {
        typeSel.value = type;
        if (type !== 'radial') angle.value = String(ang);
        stops = cols.map(([c, p]) => ({ color: c, alpha: 1, pos: p }));
        renderStops();
        render();
      });
      presetsWrap.appendChild(btn);
    });
  }

  $('gg-add').addEventListener('click', () => {
    stops.push({ color: rand(), alpha: 1, pos: 50 });
    renderStops(); render();
  });
  $('gg-random').addEventListener('click', () => {
    const n = stops.length;
    stops = stops.map((_, i) => ({ color: rand(), alpha: 1, pos: Math.round((i / (n - 1)) * 100) }));
    angle.value = String(Math.floor(Math.random() * 360));
    renderStops(); render();
  });
  $('gg-fs').addEventListener('click', () => {
    if (document.fullscreenElement) document.exitFullscreen();
    else preview.requestFullscreen?.();
  });

  typeSel.addEventListener('change', render);
  shapeSel.addEventListener('change', render);
  angle.addEventListener('input', render);
  posX.addEventListener('input', render);
  posY.addEventListener('input', render);

  renderPresets();
  renderStops();
  render();
</script>

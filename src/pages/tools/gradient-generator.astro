---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="gradient-generator">
  <div class="flex flex-col gap-5">
    <div id="gg-preview" class="panel h-48 rounded-[12px]"></div>

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1">
        <span class="text-[13px] text-ink-subtle">Type</span>
        <select id="gg-type" class="field w-40">
          <option value="linear">Linear</option>
          <option value="radial">Radial</option>
          <option value="conic">Conic</option>
        </select>
      </label>
      <label class="flex flex-col gap-1" id="gg-angle-wrap">
        <span class="text-[13px] text-ink-subtle">Angle: <span id="gg-angle-val">90</span>°</span>
        <input id="gg-angle" type="range" min="0" max="360" value="90" class="w-40" />
      </label>
      <button id="gg-add" type="button" class="btn btn-secondary">+ Add stop</button>
      <button id="gg-random" type="button" class="btn btn-secondary">Randomize</button>
    </div>

    <div>
      <span class="text-[13px] text-ink-subtle">Color stops</span>
      <div id="gg-stops" class="mt-2 flex flex-col gap-2"></div>
    </div>

    <label class="flex flex-col gap-1">
      <span class="text-[13px] text-ink-subtle">CSS</span>
      <div class="flex gap-2">
        <textarea id="gg-css" class="field font-mono text-[13px]" rows="2" readonly></textarea>
        <button id="gg-copy" type="button" class="btn btn-primary self-start">Copy</button>
      </div>
    </label>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSS gradient generator builds linear, radial and conic gradients
      with as many color stops as you like. Pick colors, drag each stop's
      position, set the angle, and copy production-ready <code>background</code>
      CSS. Add or remove stops and hit randomize for inspiration. Everything is
      generated live in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  interface Stop { color: string; pos: number; }
  const preview = document.getElementById('gg-preview')!;
  const typeSel = document.getElementById('gg-type') as HTMLSelectElement;
  const angle = document.getElementById('gg-angle') as HTMLInputElement;
  const angleVal = document.getElementById('gg-angle-val')!;
  const angleWrap = document.getElementById('gg-angle-wrap')!;
  const stopsWrap = document.getElementById('gg-stops')!;
  const cssOut = document.getElementById('gg-css') as HTMLTextAreaElement;

  let stops: Stop[] = [
    { color: '#5e6ad2', pos: 0 },
    { color: '#828fff', pos: 100 },
  ];

  function gradientCss(): string {
    const sorted = [...stops].sort((a, b) => a.pos - b.pos);
    const list = sorted.map((s) => `${s.color} ${s.pos}%`).join(', ');
    const t = typeSel.value;
    if (t === 'linear') return `linear-gradient(${angle.value}deg, ${list})`;
    if (t === 'radial') return `radial-gradient(circle, ${list})`;
    return `conic-gradient(from ${angle.value}deg, ${list})`;
  }

  function render() {
    angleWrap.style.display = typeSel.value === 'radial' ? 'none' : '';
    const css = gradientCss();
    preview.style.background = css;
    cssOut.value = `background: ${css};`;
    angleVal.textContent = angle.value;
  }

  function renderStops() {
    stopsWrap.innerHTML = '';
    stops.forEach((s, i) => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2';
      row.innerHTML = `
        <input type="color" value="${s.color}" class="h-9 w-12 shrink-0 cursor-pointer rounded-[6px] border border-hairline bg-surface-1" aria-label="Stop color" />
        <input type="range" min="0" max="100" value="${s.pos}" class="flex-1" aria-label="Stop position" />
        <span class="w-10 text-right font-mono text-[13px] text-ink-subtle">${s.pos}%</span>
        <button type="button" class="btn btn-secondary px-2 py-1 text-[13px]" ${stops.length <= 2 ? 'disabled style=opacity:.4' : ''} aria-label="Remove stop">✕</button>`;
      const [colorEl, posEl, posLbl, delEl] = [
        row.children[0] as HTMLInputElement,
        row.children[1] as HTMLInputElement,
        row.children[2] as HTMLElement,
        row.children[3] as HTMLButtonElement,
      ];
      colorEl.addEventListener('input', () => { stops[i].color = colorEl.value; render(); });
      posEl.addEventListener('input', () => { stops[i].pos = +posEl.value; posLbl.textContent = `${posEl.value}%`; render(); });
      delEl.addEventListener('click', () => { if (stops.length > 2) { stops.splice(i, 1); renderStops(); render(); } });
      stopsWrap.appendChild(row);
    });
  }

  const rand = () => '#' + Array.from({ length: 3 }, () => Math.floor(Math.random() * 256).toString(16).padStart(2, '0')).join('');

  document.getElementById('gg-add')!.addEventListener('click', () => {
    stops.push({ color: rand(), pos: 50 });
    renderStops(); render();
  });
  document.getElementById('gg-random')!.addEventListener('click', () => {
    stops = stops.map((s, i) => ({ color: rand(), pos: Math.round((i / (stops.length - 1)) * 100) }));
    angle.value = String(Math.floor(Math.random() * 360));
    renderStops(); render();
  });
  document.getElementById('gg-copy')!.addEventListener('click', async (e) => {
    await navigator.clipboard.writeText(cssOut.value);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!';
    setTimeout(() => (b.textContent = 'Copy'), 1400);
  });
  typeSel.addEventListener('change', render);
  angle.addEventListener('input', render);

  renderStops();
  render();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="calorie-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Units">
      <button type="button" data-unit="metric" class="cal-tab btn btn-primary" aria-selected="true">Metric</button>
      <button type="button" data-unit="imperial" class="cal-tab btn btn-secondary" aria-selected="false">Imperial</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sex
        <select id="cal-sex" class="field">
          <option value="male">Male</option>
          <option value="female">Female</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Age (years)
        <input id="cal-age" type="number" min="1" class="field" value="30" inputmode="numeric" />
      </label>
    </div>

    <div id="cal-metric" class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (cm)
        <input id="cal-cm" type="number" min="0" class="field" value="175" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight (kg)
        <input id="cal-kg" type="number" min="0" class="field" value="70" inputmode="decimal" />
      </label>
    </div>

    <div id="cal-imperial" class="hidden grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (ft)
        <input id="cal-ft" type="number" min="0" class="field" value="5" inputmode="numeric" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (in)
        <input id="cal-in" type="number" min="0" class="field" value="9" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight (lb)
        <input id="cal-lb" type="number" min="0" class="field" value="154" inputmode="decimal" />
      </label>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Activity level
      <select id="cal-act" class="field">
        <option value="1.2">Sedentary (little or no exercise)</option>
        <option value="1.375">Light (1–3 days/week)</option>
        <option value="1.55" selected>Moderate (3–5 days/week)</option>
        <option value="1.725">Active (6–7 days/week)</option>
        <option value="1.9">Very active (hard training / physical job)</option>
      </select>
    </label>

    <div class="panel panel-lift p-6 text-center">
      <div id="cal-tdee" class="font-display text-4xl font-semibold text-primary-hover">—</div>
      <div class="mt-2 text-sm text-ink-subtle">calories/day to maintain weight (TDEE)</div>
    </div>
    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel p-4"><div id="cal-loss1" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Mild loss</div><div id="cal-loss1-r" class="text-[11px] text-ink-tertiary"></div></div>
      <div class="panel p-4"><div id="cal-loss2" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Weight loss</div><div id="cal-loss2-r" class="text-[11px] text-ink-tertiary"></div></div>
      <div class="panel p-4"><div id="cal-gain1" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Mild gain</div><div id="cal-gain1-r" class="text-[11px] text-ink-tertiary"></div></div>
      <div class="panel p-4"><div id="cal-gain2" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Weight gain</div><div id="cal-gain2-r" class="text-[11px] text-ink-tertiary"></div></div>
    </div>

    <div class="panel p-5">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <span class="text-sm text-ink-muted">Macro split (30% protein / 40% carb / 30% fat)</span>
        <select id="cal-macrotarget" class="field w-auto">
          <option value="0">Maintenance</option>
          <option value="-250">Mild loss (−250)</option>
          <option value="-500">Weight loss (−500)</option>
          <option value="250">Mild gain (+250)</option>
          <option value="500">Weight gain (+500)</option>
        </select>
      </div>
      <div class="grid grid-cols-3 gap-3 text-center">
        <div><div id="cal-p" class="font-mono text-lg text-ink">—</div><div class="text-[13px] text-ink-subtle">Protein</div></div>
        <div><div id="cal-c" class="font-mono text-lg text-ink">—</div><div class="text-[13px] text-ink-subtle">Carbs</div></div>
        <div><div id="cal-f" class="font-mono text-lg text-ink">—</div><div class="text-[13px] text-ink-subtle">Fat</div></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free calorie calculator estimates your total daily energy expenditure
      (TDEE) — the calories you burn per day — from your BMR and activity level,
      in metric or imperial units. It suggests targets for gradual or faster
      weight loss and gain with the expected weekly rate for each, and breaks a
      chosen target into protein, carb and fat grams. Use it as a starting point
      for planning your diet.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const sel = (id: string) => document.getElementById(id) as unknown as HTMLSelectElement;
  let unit: 'metric' | 'imperial' = 'metric';

  function weeklyRate(delta: number): string {
    const kgWeek = (Math.abs(delta) * 7) / 7700;
    const lbWeek = kgWeek / 0.45359237;
    return unit === 'imperial' ? `${lbWeek.toFixed(2)} lb/wk` : `${kgWeek.toFixed(2)} kg/wk`;
  }

  function calc() {
    const sex = sel('cal-sex').value;
    const age = Number($('cal-age').value);
    let cm: number, kg: number;
    if (unit === 'metric') {
      cm = Number($('cal-cm').value);
      kg = Number($('cal-kg').value);
    } else {
      cm = (Number($('cal-ft').value) * 12 + Number($('cal-in').value)) * 2.54;
      kg = Number($('cal-lb').value) * 0.45359237;
    }
    const act = Number(sel('cal-act').value);
    const r = (n: number) => Math.round(n).toLocaleString();

    if (!(age > 0) || !(cm > 0) || !(kg > 0)) {
      ['cal-tdee', 'cal-loss1', 'cal-loss2', 'cal-gain1', 'cal-gain2', 'cal-p', 'cal-c', 'cal-f'].forEach((id) => (document.getElementById(id)!.textContent = '—'));
      return;
    }
    const bmr = 10 * kg + 6.25 * cm - 5 * age + (sex === 'male' ? 5 : -161);
    const tdee = bmr * act;

    document.getElementById('cal-tdee')!.textContent = r(tdee);
    document.getElementById('cal-loss1')!.textContent = r(tdee - 250);
    document.getElementById('cal-loss2')!.textContent = r(tdee - 500);
    document.getElementById('cal-gain1')!.textContent = r(tdee + 250);
    document.getElementById('cal-gain2')!.textContent = r(tdee + 500);
    document.getElementById('cal-loss1-r')!.textContent = '−' + weeklyRate(250);
    document.getElementById('cal-loss2-r')!.textContent = '−' + weeklyRate(500);
    document.getElementById('cal-gain1-r')!.textContent = '+' + weeklyRate(250);
    document.getElementById('cal-gain2-r')!.textContent = '+' + weeklyRate(500);

    // macros for selected target
    const target = tdee + Number(sel('cal-macrotarget').value);
    document.getElementById('cal-p')!.textContent = Math.round((target * 0.3) / 4) + ' g';
    document.getElementById('cal-c')!.textContent = Math.round((target * 0.4) / 4) + ' g';
    document.getElementById('cal-f')!.textContent = Math.round((target * 0.3) / 9) + ' g';
  }

  document.querySelectorAll<HTMLButtonElement>('.cal-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      unit = tab.dataset.unit as 'metric' | 'imperial';
      document.querySelectorAll('.cal-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('cal-metric')!.classList.toggle('hidden', unit !== 'metric');
      document.getElementById('cal-metric')!.classList.toggle('grid', unit === 'metric');
      document.getElementById('cal-imperial')!.classList.toggle('hidden', unit !== 'imperial');
      document.getElementById('cal-imperial')!.classList.toggle('grid', unit === 'imperial');
      calc();
    });
  });

  document.querySelectorAll('#cal-sex, #cal-age, #cal-cm, #cal-kg, #cal-ft, #cal-in, #cal-lb, #cal-act, #cal-macrotarget').forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

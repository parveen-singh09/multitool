---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="compound-interest-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Initial principal
        <input id="ci-p" type="number" min="0" class="field" value="10000" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Monthly contribution
        <input id="ci-pmt" type="number" min="0" class="field" value="200" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Annual interest rate (%)
        <input id="ci-rate" type="number" min="0" step="0.01" class="field" value="7" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Years
        <input id="ci-years" type="number" min="0" step="0.5" class="field" value="10" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Compounding
        <select id="ci-freq" class="field">
          <option value="12">Monthly</option>
          <option value="4">Quarterly</option>
          <option value="1">Annually</option>
          <option value="365">Daily</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Contribution timing
        <select id="ci-timing" class="field">
          <option value="end">End of period</option>
          <option value="begin">Beginning of period</option>
        </select>
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="panel panel-lift p-5 text-center"><div id="ci-final" class="font-display text-2xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Future value</div></div>
      <div class="panel p-5 text-center"><div id="ci-contrib" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Total contributed</div></div>
      <div class="panel p-5 text-center"><div id="ci-earned" class="font-mono text-xl" style="color:var(--color-success)">—</div><div class="mt-1 text-[13px] text-ink-subtle">Interest earned</div></div>
    </div>

    <div class="panel p-5">
      <div class="mb-3 flex flex-wrap gap-x-5 gap-y-1 text-xs text-ink-subtle">
        <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full" style="background:#5e6ad2"></span>Contributed</span>
        <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full" style="background:#828fff"></span>Interest</span>
      </div>
      <svg id="ci-chart" viewBox="0 0 320 140" class="w-full" preserveAspectRatio="none" role="img" aria-label="Balance growth over time"></svg>
      <div id="ci-axis" class="mt-1 flex justify-between font-mono text-[11px] text-ink-tertiary"></div>
    </div>

    <details class="panel p-0">
      <summary class="cursor-pointer list-none px-5 py-4 text-sm font-medium text-ink hover:text-primary-hover">
        <span class="inline-flex items-center gap-2">▸ Year-by-year breakdown</span>
      </summary>
      <div class="overflow-x-auto border-t border-hairline">
        <table class="w-full text-right text-[13px]">
          <thead class="text-ink-subtle">
            <tr class="border-b border-hairline">
              <th class="px-4 py-2 text-left font-medium">Year</th>
              <th class="px-4 py-2 font-medium">Contributions</th>
              <th class="px-4 py-2 font-medium">Interest</th>
              <th class="px-4 py-2 font-medium">Balance</th>
            </tr>
          </thead>
          <tbody id="ci-sched" class="font-mono text-ink-muted"></tbody>
        </table>
      </div>
    </details>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free compound interest calculator shows how savings grow over time as
      interest earns interest. Enter a starting amount, optional monthly
      contributions, an interest rate and how often it compounds to see your
      projected future value, total contributions and interest earned. It runs
      entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const ids = ['ci-p', 'ci-pmt', 'ci-rate', 'ci-years', 'ci-freq', 'ci-timing'];
  const el: Record<string, HTMLInputElement | HTMLSelectElement> = {};
  ids.forEach((id) => (el[id] = document.getElementById(id) as HTMLInputElement));
  const money = (n: number) => n.toLocaleString(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });
  const money0 = (n: number) => Math.round(n).toLocaleString();
  const SVGNS = 'http://www.w3.org/2000/svg';

  function calc() {
    const P = Number(el['ci-p'].value);
    const pmt = Number(el['ci-pmt'].value);
    const annual = Number(el['ci-rate'].value) / 100;
    const t = Number(el['ci-years'].value);
    const nPerYear = Number((el['ci-freq'] as HTMLSelectElement).value);
    const begin = (el['ci-timing'] as HTMLSelectElement).value === 'begin';
    const periods = Math.round(nPerYear * t);
    const rate = annual / nPerYear;

    const contribPerPeriod = pmt * (12 / nPerYear);

    let balance = P;
    let contributed = P;
    const points: { contributed: number; balance: number }[] = [{ contributed: P, balance: P }];
    const yearRows: { year: number; contributions: number; interest: number; balance: number }[] = [];
    let prevBal = P, prevContrib = P;
    for (let i = 1; i <= periods; i++) {
      if (begin) balance += contribPerPeriod;
      balance = balance * (1 + rate);
      if (!begin) balance += contribPerPeriod;
      contributed += contribPerPeriod;
      if (i % nPerYear === 0 || i === periods) {
        const yr = Math.ceil(i / nPerYear);
        yearRows.push({
          year: yr,
          contributions: contributed - prevContrib,
          interest: balance - prevBal - (contributed - prevContrib),
          balance,
        });
        points.push({ contributed, balance });
        prevBal = balance; prevContrib = contributed;
      }
    }

    document.getElementById('ci-final')!.textContent = money(balance);
    document.getElementById('ci-contrib')!.textContent = money(contributed);
    document.getElementById('ci-earned')!.textContent = money(balance - contributed);

    drawChart(points);

    const sched = document.getElementById('ci-sched')!;
    sched.innerHTML = '';
    for (const row of yearRows) {
      const tr = document.createElement('tr');
      tr.className = 'border-b border-hairline/50';
      tr.innerHTML = `<td class="px-4 py-1.5 text-left text-ink-subtle">${row.year}</td><td class="px-4 py-1.5">${money0(row.contributions)}</td><td class="px-4 py-1.5">${money0(Math.max(0, row.interest))}</td><td class="px-4 py-1.5">${money0(row.balance)}</td>`;
      sched.appendChild(tr);
    }
  }

  function drawChart(points: { contributed: number; balance: number }[]) {
    const svg = document.getElementById('ci-chart')!;
    svg.innerHTML = '';
    const W = 320, H = 140;
    const maxV = Math.max(...points.map((p) => p.balance), 1);
    const n = points.length - 1;
    const x = (i: number) => (n === 0 ? 0 : (i / n) * W);
    const y = (v: number) => H - (v / maxV) * H;
    const contribLine = points.map((p, i) => `${x(i).toFixed(1)},${y(p.contributed).toFixed(1)}`);
    const balanceLine = points.map((p, i) => `${x(i).toFixed(1)},${y(p.balance).toFixed(1)}`);

    const interestArea = document.createElementNS(SVGNS, 'polygon');
    interestArea.setAttribute('points', [...balanceLine, ...contribLine.slice().reverse()].join(' '));
    interestArea.setAttribute('fill', '#828fff');
    interestArea.setAttribute('opacity', '0.35');
    svg.appendChild(interestArea);

    const contribArea = document.createElementNS(SVGNS, 'polygon');
    contribArea.setAttribute('points', [`0,${H}`, ...contribLine, `${W},${H}`].join(' '));
    contribArea.setAttribute('fill', '#5e6ad2');
    contribArea.setAttribute('opacity', '0.4');
    svg.appendChild(contribArea);

    const line = document.createElementNS(SVGNS, 'polyline');
    line.setAttribute('points', balanceLine.join(' '));
    line.setAttribute('fill', 'none');
    line.setAttribute('stroke', '#828fff');
    line.setAttribute('stroke-width', '2');
    line.setAttribute('vector-effect', 'non-scaling-stroke');
    svg.appendChild(line);

    document.getElementById('ci-axis')!.innerHTML = `<span>Yr 0</span><span>Yr ${Math.round(n / 2)}</span><span>Yr ${n}</span>`;
  }

  ids.forEach((id) => el[id].addEventListener('input', calc));
  ['ci-freq', 'ci-timing'].forEach((id) => el[id].addEventListener('change', calc));
  calc();
</script>

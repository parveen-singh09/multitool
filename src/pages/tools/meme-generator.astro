---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="meme-generator">
  <div class="flex flex-col gap-4">

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_auto]">
      <label id="mm-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-6 text-center transition-colors hover:bg-surface-2">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
        <span class="text-sm text-ink">Upload an image, drop it here, or paste</span>
        <span class="text-[13px] text-ink-tertiary">Composited in your browser — your image is never uploaded</span>
        <input id="mm-file" type="file" accept="image/*" class="sr-only" />
      </label>
      <button id="mm-tpl-toggle" type="button" class="btn btn-secondary h-full min-h-16 sm:w-44">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Templates
      </button>
    </div>

    <div id="mm-tpl" class="panel panel-lift hidden flex-col gap-3 p-4">
      <div class="flex items-center gap-2">
        <input id="mm-tpl-search" class="field" placeholder="Search popular templates…" />
        <span id="mm-tpl-status" class="whitespace-nowrap text-[13px] text-ink-tertiary">Loading…</span>
      </div>
      <div id="mm-tpl-grid" class="grid max-h-72 grid-cols-3 gap-2 overflow-auto sm:grid-cols-4 md:grid-cols-5"></div>
    </div>

    <div id="mm-panel" class="hidden flex-col gap-4">

      <div class="flex flex-wrap items-center gap-2">
        <button id="mm-add-text" type="button" class="btn btn-secondary">+ Text</button>
        <button id="mm-add-sticker" type="button" class="btn btn-secondary">+ Sticker</button>
        <span class="mx-1 h-5 w-px bg-hairline"></span>
        <button id="mm-rotate" type="button" class="btn btn-secondary" title="Rotate image 90°" aria-label="Rotate image">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
        </button>
        <button id="mm-flip-h" type="button" class="btn btn-secondary" title="Flip horizontal">Flip H</button>
        <button id="mm-flip-v" type="button" class="btn btn-secondary" title="Flip vertical">Flip V</button>
        <span class="mx-1 h-5 w-px bg-hairline"></span>
        <button id="mm-undo" type="button" class="btn btn-secondary" title="Undo (Ctrl+Z)" disabled>Undo</button>
        <button id="mm-redo" type="button" class="btn btn-secondary" title="Redo (Ctrl+Shift+Z)" disabled>Redo</button>
      </div>

      <div class="flex justify-center overflow-auto rounded-lg border border-hairline bg-surface-2 p-4">
        <canvas id="mm-canvas" class="max-w-full touch-none" style="cursor:default"></canvas>
      </div>

      <div id="mm-inspect" class="panel panel-lift hidden flex-col gap-3 p-4">
        <div class="flex items-center justify-between">
          <span id="mm-insp-title" class="eyebrow text-primary-hover">Text layer</span>
          <div class="flex items-center gap-2">
            <button id="mm-layer-back" type="button" class="btn btn-secondary px-2 py-1 text-[13px]" title="Send backward">Back</button>
            <button id="mm-layer-fwd" type="button" class="btn btn-secondary px-2 py-1 text-[13px]" title="Bring forward">Forward</button>
            <button id="mm-layer-dup" type="button" class="btn btn-secondary px-2 py-1 text-[13px]" title="Duplicate (Ctrl+D)">Duplicate</button>
            <button id="mm-layer-del" type="button" class="btn btn-secondary px-2 py-1 text-[13px]" title="Delete (Del)">Delete</button>
          </div>
        </div>

        <div id="mm-text-ctrls" class="flex flex-col gap-3">
          <textarea id="mm-t-text" rows="2" class="field resize-y" placeholder="Enter text…"></textarea>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Font
              <select id="mm-t-font" class="field">
                <option value="Impact, 'Arial Narrow', sans-serif">Impact (classic)</option>
                <option value="Arial, Helvetica, sans-serif">Arial</option>
                <option value="'Comic Sans MS', 'Comic Sans', cursive">Comic Sans</option>
                <option value="'Times New Roman', Times, serif">Times New Roman</option>
                <option value="Verdana, Geneva, sans-serif">Verdana</option>
                <option value="Georgia, serif">Georgia</option>
                <option value="'Courier New', monospace">Courier New</option>
                <option value="Inter, system-ui, sans-serif">Inter</option>
              </select>
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Alignment
              <div class="flex gap-1">
                <button data-align="left" type="button" class="mm-align btn btn-secondary flex-1">Left</button>
                <button data-align="center" type="button" class="mm-align btn btn-secondary flex-1">Center</button>
                <button data-align="right" type="button" class="mm-align btn btn-secondary flex-1">Right</button>
              </div>
            </label>
          </div>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Font size: <span id="mm-t-sizev" class="text-ink">—</span>
            <input id="mm-t-size" type="range" min="2" max="24" step="0.2" value="9" class="w-full accent-primary" />
          </label>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
            <label class="flex items-center justify-between gap-2 text-sm text-ink-subtle">Text color
              <input id="mm-t-fill" type="color" value="#ffffff" class="h-8 w-14 cursor-pointer rounded border border-hairline bg-transparent" />
            </label>
            <label class="flex items-center justify-between gap-2 text-sm text-ink-subtle">Outline color
              <input id="mm-t-stroke" type="color" value="#000000" class="h-8 w-14 cursor-pointer rounded border border-hairline bg-transparent" />
            </label>
          </div>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Outline width: <span id="mm-t-swv" class="text-ink">—</span>
            <input id="mm-t-sw" type="range" min="0" max="20" step="0.5" value="6" class="w-full accent-primary" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Opacity: <span id="mm-t-opv" class="text-ink">100%</span>
            <input id="mm-t-op" type="range" min="10" max="100" value="100" class="w-full accent-primary" />
          </label>
          <div class="flex flex-wrap gap-2">
            <button id="mm-t-bold" type="button" class="btn btn-secondary font-bold">B</button>
            <button id="mm-t-italic" type="button" class="btn btn-secondary italic">I</button>
            <button id="mm-t-upper" type="button" class="btn btn-secondary">UPPER</button>
          </div>
        </div>

        <div id="mm-sticker-ctrls" class="hidden flex-col gap-3">
          <div id="mm-emoji-grid" class="flex flex-wrap gap-1"></div>
          <label class="btn btn-secondary w-fit cursor-pointer">Upload image sticker
            <input id="mm-sticker-file" type="file" accept="image/*" class="sr-only" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Size: <span id="mm-s-sizev" class="text-ink">—</span>
            <input id="mm-s-size" type="range" min="4" max="80" value="20" class="w-full accent-primary" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Rotation: <span id="mm-s-rotv" class="text-ink">0°</span>
            <input id="mm-s-rot" type="range" min="-180" max="180" value="0" class="w-full accent-primary" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Opacity: <span id="mm-s-opv" class="text-ink">100%</span>
            <input id="mm-s-op" type="range" min="10" max="100" value="100" class="w-full accent-primary" />
          </label>
        </div>
      </div>

      <div class="panel panel-lift flex flex-col gap-3 p-4">
        <span class="eyebrow text-ink-subtle">Add white space</span>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Top: <span id="mm-padtv" class="text-ink">0%</span>
            <input id="mm-padt" type="range" min="0" max="60" value="0" class="w-full accent-primary" />
          </label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bottom: <span id="mm-padbv" class="text-ink">0%</span>
            <input id="mm-padb" type="range" min="0" max="60" value="0" class="w-full accent-primary" />
          </label>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <button id="mm-dl-png" type="button" class="btn btn-primary">Download PNG</button>
        <button id="mm-dl-jpg" type="button" class="btn btn-secondary">Download JPEG</button>
        <span id="mm-dl-err" class="hidden text-[13px] text-ink-subtle"></span>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      A full meme editor in your browser. Start from a popular template or upload
      your own image, then add as many text boxes as you want — each with its own
      font, size, color, outline, alignment, and opacity. Drag, resize, and rotate
      text and stickers right on the canvas, rotate or flip the base image, add
      white caption space above or below, and download a full-resolution, unwatermarked
      meme.
    </p>
    <p>
      Hundreds of popular templates are loaded from the public imgflip and
      memegen.link galleries — search by name to filter them. Everything else —
      your uploaded image, text, and stickers — is composited locally on a canvas and
      never uploaded to any server. Keyboard shortcuts: arrow keys nudge the selected
      layer, Ctrl/Cmd+Z / Ctrl/Cmd+Shift+Z undo and redo, Ctrl/Cmd+D duplicates, and
      Delete removes.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .mm-tpl-card { aspect-ratio: 1; overflow: hidden; border-radius: 8px; border: 1px solid var(--color-hairline); cursor: pointer; background: var(--color-surface-2); }
  .mm-tpl-card:hover { border-color: var(--color-hairline-strong); }
  .mm-tpl-card img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .mm-emoji { font-size: 22px; line-height: 1; padding: 4px 6px; border-radius: 6px; border: 1px solid var(--color-hairline); background: var(--color-surface-1); cursor: pointer; }
  .mm-emoji:hover { background: var(--color-surface-2); }
  .mm-toggle-on { background: var(--color-primary) !important; color: var(--color-on-primary) !important; border-color: var(--color-primary) !important; }
</style>

<script>

  type Align = 'left' | 'center' | 'right';
  interface TextLayer {
    id: string; type: 'text';
    text: string;
    cx: number; cy: number;      
    boxW: number;                
    fontFrac: number;            
    fontFamily: string;
    fill: string; stroke: string; strokeW: number; 
    bold: boolean; italic: boolean; upper: boolean;
    align: Align; rotation: number; opacity: number;
  }
  interface StickerLayer {
    id: string; type: 'sticker';
    kind: 'emoji' | 'image';
    emoji?: string; img?: HTMLImageElement; aspect: number; 
    cx: number; cy: number;
    widthFrac: number;           
    rotation: number; opacity: number;
  }
  type Layer = TextLayer | StickerLayer;

  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
  const fileInput = $<HTMLInputElement>('mm-file');
  const drop = $('mm-drop');
  const panel = $('mm-panel');
  const canvas = $<HTMLCanvasElement>('mm-canvas');
  const ctx = canvas.getContext('2d')!;
  const inspect = $('mm-inspect');
  const textCtrls = $('mm-text-ctrls');
  const stickerCtrls = $('mm-sticker-ctrls');

  let img: HTMLImageElement | null = null;
  let baseW = 0, baseH = 0;         
  let rotation = 0;                 
  let flipH = false, flipV = false;
  let padTop = 0, padBottom = 0;    
  let layers: Layer[] = [];
  let selectedId: string | null = null;
  const MAX_SIDE = 2400;
  let uid = 0;
  const newId = () => `l${uid++}`;

  // History
  interface Snap { layers: Layer[]; rotation: number; flipH: boolean; flipV: boolean; padTop: number; padBottom: number; selectedId: string | null; }
  const undoStack: Snap[] = [];
  const redoStack: Snap[] = [];
  const HISTORY_CAP = 50;
  function snap(): Snap {
    return { layers: layers.map((l) => ({ ...l })), rotation, flipH, flipV, padTop, padBottom, selectedId };
  }
  function apply(s: Snap) {
    layers = s.layers.map((l) => ({ ...l }));
    rotation = s.rotation; flipH = s.flipH; flipV = s.flipV;
    padTop = s.padTop; padBottom = s.padBottom; selectedId = s.selectedId;
    syncPadInputs();
  }
  function pushUndo() {
    undoStack.push(snap());
    if (undoStack.length > HISTORY_CAP) undoStack.shift();
    redoStack.length = 0;
    updateHistoryButtons();
  }
  function updateHistoryButtons() {
    ($('mm-undo') as HTMLButtonElement).disabled = undoStack.length === 0;
    ($('mm-redo') as HTMLButtonElement).disabled = redoStack.length === 0;
  }
  function undo() {
    if (!undoStack.length) return;
    redoStack.push(snap());
    apply(undoStack.pop()!);
    updateHistoryButtons(); render(); syncInspector();
  }
  function redo() {
    if (!redoStack.length) return;
    undoStack.push(snap());
    apply(redoStack.pop()!);
    updateHistoryButtons(); render(); syncInspector();
  }

  // ---- Geometry --------------------------------------------------------
  // Effective image draw dims accounting for 90/270 rotation.
  function imgDims() {
    const swap = rotation === 90 || rotation === 270;
    return { w: swap ? baseH : baseW, h: swap ? baseW : baseH };
  }
  function canvasDims() {
    const d = imgDims();
    const pt = d.h * padTop, pb = d.h * padBottom;
    return { w: d.w, h: d.h + pt + pb, imgTop: pt, imgH: d.h };
  }

  const selected = () => layers.find((l) => l.id === selectedId) || null;

  // ---- Text layout (shared by render + hit-test) -----------------------
  function fontStr(l: TextLayer, fontPx: number) {
    return `${l.italic ? 'italic ' : ''}${l.bold ? '700' : '400'} ${fontPx}px ${l.fontFamily}`;
  }
  function layoutText(l: TextLayer, cw: number, ch: number) {
    const fontPx = l.fontFrac * ch;
    const boxWpx = l.boxW * cw;
    ctx.font = fontStr(l, fontPx);
    const raw = l.upper ? l.text.toUpperCase() : l.text;
    const lines: string[] = [];
    for (const para of raw.split('\n')) {
      if (para === '') { lines.push(''); continue; }
      let line = '';
      for (const word of para.split(/\s+/)) {
        const test = line ? line + ' ' + word : word;
        if (ctx.measureText(test).width > boxWpx && line) { lines.push(line); line = word; }
        else line = test;
      }
      if (line) lines.push(line);
    }
    const lh = fontPx * 1.15;
    let maxW = 0;
    for (const ln of lines) maxW = Math.max(maxW, ctx.measureText(ln).width);
    return { lines, fontPx, lh, textW: Math.min(Math.max(maxW, fontPx * 0.5), boxWpx), textH: Math.max(lines.length, 1) * lh };
  }

  function stickerDims(l: StickerLayer, cw: number) {
    const w = l.widthFrac * cw;
    return { w, h: w * l.aspect };
  }

  // ---- Render ----------------------------------------------------------
  let dragging = false, showCenterX = false, showCenterY = false;

  function render() {
    if (!img) return;
    const cd = canvasDims();
    canvas.width = Math.round(cd.w);
    canvas.height = Math.round(cd.h);
    const cw = canvas.width, ch = canvas.height;

    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, cw, ch);

    // Base image with rotation + flip, centered in its band.
    ctx.save();
    ctx.translate(cw / 2, cd.imgTop + cd.imgH / 2);
    ctx.rotate((rotation * Math.PI) / 180);
    ctx.scale(flipH ? -1 : 1, flipV ? -1 : 1);
    ctx.drawImage(img, -baseW / 2, -baseH / 2, baseW, baseH);
    ctx.restore();

    // Layers in z-order.
    for (const l of layers) {
      ctx.save();
      ctx.globalAlpha = l.opacity;
      const px = l.cx * cw, py = l.cy * ch;
      ctx.translate(px, py);
      ctx.rotate((l.rotation * Math.PI) / 180);
      if (l.type === 'text') drawText(l, cw, ch);
      else drawSticker(l, cw);
      ctx.restore();
    }

    // Selection chrome.
    const sel = selected();
    if (sel) drawSelection(sel, cw, ch);

    // Center snap guides.
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.globalAlpha = 1;
    if (dragging && (showCenterX || showCenterY)) {
      ctx.strokeStyle = 'var(--color-primary, #5e6ad2)';
      ctx.lineWidth = Math.max(1, cw / 600);
      ctx.setLineDash([cw / 90, cw / 90]);
      if (showCenterX) { ctx.beginPath(); ctx.moveTo(cw / 2, 0); ctx.lineTo(cw / 2, ch); ctx.stroke(); }
      if (showCenterY) { ctx.beginPath(); ctx.moveTo(0, ch / 2); ctx.lineTo(cw, ch / 2); ctx.stroke(); }
      ctx.setLineDash([]);
    }
  }

  function drawText(l: TextLayer, cw: number, ch: number) {
    const lay = layoutText(l, cw, ch);
    ctx.font = fontStr(l, lay.fontPx);
    ctx.textAlign = l.align;
    ctx.textBaseline = 'top';
    ctx.lineJoin = 'round';
    ctx.miterLimit = 2;
    ctx.strokeStyle = l.stroke;
    ctx.fillStyle = l.fill;
    ctx.lineWidth = (l.strokeW / 100) * lay.fontPx;
    const boxWpx = l.boxW * cw;
    // x offset within the box based on alignment (box centered at origin).
    const ax = l.align === 'left' ? -boxWpx / 2 : l.align === 'right' ? boxWpx / 2 : 0;
    const startY = -lay.textH / 2;
    lay.lines.forEach((ln, i) => {
      const y = startY + i * lay.lh;
      if (l.strokeW > 0) ctx.strokeText(ln, ax, y);
      ctx.fillText(ln, ax, y);
    });
  }

  function drawSticker(l: StickerLayer, cw: number) {
    const d = stickerDims(l, cw);
    if (l.kind === 'emoji' && l.emoji) {
      ctx.font = `${d.w}px "Segoe UI Emoji", "Apple Color Emoji", "Noto Color Emoji", sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(l.emoji, 0, 0);
    } else if (l.img) {
      ctx.drawImage(l.img, -d.w / 2, -d.h / 2, d.w, d.h);
    }
  }

  function selBox(l: Layer, cw: number, ch: number) {
    if (l.type === 'text') {
      const lay = layoutText(l, cw, ch);
      return { w: Math.max(lay.textW, l.boxW * cw * 0.35) + lay.fontPx * 0.3, h: lay.textH };
    }
    const d = stickerDims(l, cw);
    return { w: d.w, h: d.h };
  }

  function drawSelection(l: Layer, cw: number, ch: number) {
    const b = selBox(l, cw, ch);
    const px = l.cx * cw, py = l.cy * ch;
    ctx.save();
    ctx.translate(px, py);
    ctx.rotate((l.rotation * Math.PI) / 180);
    ctx.globalAlpha = 1;
    ctx.strokeStyle = 'var(--color-primary, #5e6ad2)';
    ctx.lineWidth = Math.max(1.5, cw / 400);
    ctx.strokeRect(-b.w / 2, -b.h / 2, b.w, b.h);
    // Corner handles.
    const hr = Math.max(5, cw / 110);
    ctx.fillStyle = 'var(--color-primary, #5e6ad2)';
    for (const sx of [-1, 1]) for (const sy of [-1, 1]) {
      ctx.beginPath(); ctx.arc((sx * b.w) / 2, (sy * b.h) / 2, hr, 0, Math.PI * 2); ctx.fill();
    }
    // Rotate handle above top edge.
    const stalk = Math.max(20, cw / 22);
    ctx.beginPath(); ctx.moveTo(0, -b.h / 2); ctx.lineTo(0, -b.h / 2 - stalk); ctx.stroke();
    ctx.beginPath(); ctx.arc(0, -b.h / 2 - stalk, hr, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
  }

  // ---- Coordinate mapping ---------------------------------------------
  function toCanvas(ev: PointerEvent) {
    const r = canvas.getBoundingClientRect();
    return { x: ((ev.clientX - r.left) / r.width) * canvas.width, y: ((ev.clientY - r.top) / r.height) * canvas.height };
  }
  // Transform a canvas-space point into a layer's local (unrotated, origin-centered) frame.
  function toLocal(l: Layer, x: number, y: number, cw: number, ch: number) {
    const px = l.cx * cw, py = l.cy * ch;
    const dx = x - px, dy = y - py;
    const a = (-l.rotation * Math.PI) / 180;
    return { x: dx * Math.cos(a) - dy * Math.sin(a), y: dx * Math.sin(a) + dy * Math.cos(a) };
  }

  type HandleHit = { kind: 'body' | 'corner' | 'rotate'; corner?: number };
  function hitHandles(l: Layer, x: number, y: number, cw: number, ch: number): HandleHit | null {
    const loc = toLocal(l, x, y, cw, ch);
    const b = selBox(l, cw, ch);
    const hr = Math.max(5, cw / 110) * 1.6;
    const stalk = Math.max(20, cw / 22);
    // Rotate handle.
    if (Math.hypot(loc.x - 0, loc.y - (-b.h / 2 - stalk)) < hr) return { kind: 'rotate' };
    // Corners.
    let ci = 0;
    for (const sx of [-1, 1]) for (const sy of [-1, 1]) {
      if (Math.hypot(loc.x - (sx * b.w) / 2, loc.y - (sy * b.h) / 2) < hr) return { kind: 'corner', corner: ci };
      ci++;
    }
    // Body.
    if (Math.abs(loc.x) <= b.w / 2 && Math.abs(loc.y) <= b.h / 2) return { kind: 'body' };
    return null;
  }
  function layerAt(x: number, y: number, cw: number, ch: number): Layer | null {
    for (let i = layers.length - 1; i >= 0; i--) {
      const loc = toLocal(layers[i], x, y, cw, ch);
      const b = selBox(layers[i], cw, ch);
      if (Math.abs(loc.x) <= b.w / 2 && Math.abs(loc.y) <= b.h / 2) return layers[i];
    }
    return null;
  }

  // ---- Pointer interaction --------------------------------------------
  let mode: 'none' | 'move' | 'resize' | 'rotate' = 'none';
  let startPx = 0, startPy = 0, startCx = 0, startCy = 0;
  let startFont = 0, startWidth = 0, startDist = 0, startAngle = 0, startRot = 0;
  let committed = false;

  function beginChange() { if (!committed) { pushUndo(); committed = true; } }

  canvas.addEventListener('pointerdown', (ev) => {
    if (!img) return;
    const cw = canvas.width, ch = canvas.height;
    const p = toCanvas(ev);
    committed = false;

    const sel = selected();
    if (sel) {
      const h = hitHandles(sel, p.x, p.y, cw, ch);
      if (h && h.kind === 'rotate') {
        mode = 'rotate';
        startRot = sel.rotation;
        startAngle = Math.atan2(p.y - sel.cy * ch, p.x - sel.cx * cw);
        canvas.setPointerCapture(ev.pointerId); dragging = true; return;
      }
      if (h && h.kind === 'corner') {
        mode = 'resize';
        startDist = Math.hypot(p.x - sel.cx * cw, p.y - sel.cy * ch);
        if (sel.type === 'text') startFont = sel.fontFrac; else startWidth = (sel as StickerLayer).widthFrac;
        canvas.setPointerCapture(ev.pointerId); dragging = true; return;
      }
    }

    const hit = layerAt(p.x, p.y, cw, ch);
    if (hit) {
      selectedId = hit.id;
      mode = 'move';
      startPx = p.x; startPy = p.y; startCx = hit.cx; startCy = hit.cy;
      canvas.setPointerCapture(ev.pointerId); dragging = true;
      syncInspector(); render();
    } else {
      selectedId = null; mode = 'none';
      syncInspector(); render();
    }
  });

  canvas.addEventListener('pointermove', (ev) => {
    const cw = canvas.width, ch = canvas.height;
    if (mode === 'none' || !dragging) {
      // Hover cursor feedback.
      if (img && selected()) {
        const p = toCanvas(ev);
        const h = hitHandles(selected()!, p.x, p.y, cw, ch);
        canvas.style.cursor = h?.kind === 'rotate' ? 'grab' : h?.kind === 'corner' ? 'nwse-resize' : h?.kind === 'body' ? 'move' : 'default';
      }
      return;
    }
    const sel = selected(); if (!sel) return;
    const p = toCanvas(ev);
    beginChange();

    if (mode === 'move') {
      let ncx = startCx + (p.x - startPx) / cw;
      let ncy = startCy + (p.y - startPy) / ch;
      // Center snapping.
      const snapT = 0.012;
      showCenterX = Math.abs(ncx - 0.5) < snapT;
      showCenterY = Math.abs(ncy - 0.5) < snapT;
      if (showCenterX) ncx = 0.5;
      if (showCenterY) ncy = 0.5;
      sel.cx = ncx; sel.cy = ncy;
    } else if (mode === 'resize') {
      const dist = Math.hypot(p.x - sel.cx * cw, p.y - sel.cy * ch);
      const ratio = dist / Math.max(startDist, 1);
      if (sel.type === 'text') sel.fontFrac = Math.min(0.6, Math.max(0.01, startFont * ratio));
      else (sel as StickerLayer).widthFrac = Math.min(1.5, Math.max(0.03, startWidth * ratio));
    } else if (mode === 'rotate') {
      const ang = Math.atan2(p.y - sel.cy * ch, p.x - sel.cx * cw);
      let deg = startRot + ((ang - startAngle) * 180) / Math.PI;
      if (Math.abs(deg % 90) < 4 || Math.abs((deg % 90) - 90) < 4) deg = Math.round(deg / 90) * 90; // snap to 90s
      sel.rotation = Math.round(deg);
    }
    render(); syncInspector();
  });

  function endDrag(ev: PointerEvent) {
    if (dragging) { try { canvas.releasePointerCapture(ev.pointerId); } catch {} }
    dragging = false; mode = 'none'; showCenterX = showCenterY = false; committed = false;
    render();
  }
  canvas.addEventListener('pointerup', endDrag);
  canvas.addEventListener('pointercancel', endDrag);

  // ---- Layer creation --------------------------------------------------
  function addText(text: string, cy: number) {
    const l: TextLayer = {
      id: newId(), type: 'text', text,
      cx: 0.5, cy, boxW: 0.92, fontFrac: 0.09,
      fontFamily: "Impact, 'Arial Narrow', sans-serif",
      fill: '#ffffff', stroke: '#000000', strokeW: 6,
      bold: false, italic: false, upper: true,
      align: 'center', rotation: 0, opacity: 1,
    };
    layers.push(l); selectedId = l.id;
    return l;
  }
  function addSticker(emoji: string) {
    const l: StickerLayer = {
      id: newId(), type: 'sticker', kind: 'emoji', emoji, aspect: 1,
      cx: 0.5, cy: 0.5, widthFrac: 0.2, rotation: 0, opacity: 1,
    };
    layers.push(l); selectedId = l.id;
    return l;
  }

  // ---- Inspector sync --------------------------------------------------
  function syncPadInputs() {
    ($('mm-padt') as HTMLInputElement).value = String(Math.round(padTop * 100));
    ($('mm-padb') as HTMLInputElement).value = String(Math.round(padBottom * 100));
    $('mm-padtv').textContent = Math.round(padTop * 100) + '%';
    $('mm-padbv').textContent = Math.round(padBottom * 100) + '%';
  }
  function setToggle(id: string, on: boolean) { $(id).classList.toggle('mm-toggle-on', on); }

  function syncInspector() {
    const sel = selected();
    if (!sel) { inspect.classList.add('hidden'); inspect.classList.remove('flex'); return; }
    inspect.classList.remove('hidden'); inspect.classList.add('flex');
    const isText = sel.type === 'text';
    $('mm-insp-title').textContent = isText ? 'Text layer' : 'Sticker layer';
    textCtrls.classList.toggle('hidden', !isText);
    stickerCtrls.classList.toggle('hidden', isText);
    stickerCtrls.classList.toggle('flex', !isText);

    if (isText) {
      const t = sel as TextLayer;
      ($('mm-t-text') as HTMLTextAreaElement).value = t.text;
      ($('mm-t-font') as HTMLSelectElement).value = t.fontFamily;
      ($('mm-t-size') as HTMLInputElement).value = String(t.fontFrac * 100);
      $('mm-t-sizev').textContent = (t.fontFrac * 100).toFixed(1) + '%';
      ($('mm-t-fill') as HTMLInputElement).value = t.fill;
      ($('mm-t-stroke') as HTMLInputElement).value = t.stroke;
      ($('mm-t-sw') as HTMLInputElement).value = String(t.strokeW);
      $('mm-t-swv').textContent = t.strokeW.toFixed(1);
      ($('mm-t-op') as HTMLInputElement).value = String(Math.round(t.opacity * 100));
      $('mm-t-opv').textContent = Math.round(t.opacity * 100) + '%';
      setToggle('mm-t-bold', t.bold); setToggle('mm-t-italic', t.italic); setToggle('mm-t-upper', t.upper);
      document.querySelectorAll('.mm-align').forEach((b) =>
        b.classList.toggle('mm-toggle-on', (b as HTMLElement).dataset.align === t.align));
    } else {
      const s = sel as StickerLayer;
      ($('mm-s-size') as HTMLInputElement).value = String(s.widthFrac * 100);
      $('mm-s-sizev').textContent = (s.widthFrac * 100).toFixed(0) + '%';
      ($('mm-s-rot') as HTMLInputElement).value = String(s.rotation);
      $('mm-s-rotv').textContent = s.rotation + '°';
      ($('mm-s-op') as HTMLInputElement).value = String(Math.round(s.opacity * 100));
      $('mm-s-opv').textContent = Math.round(s.opacity * 100) + '%';
    }
  }

  // ---- Inspector control wiring ---------------------------------------
  const onText = (fn: (t: TextLayer) => void) => () => { const s = selected(); if (s?.type === 'text') { fn(s); render(); } };
  const onSticker = (fn: (s: StickerLayer) => void) => () => { const s = selected(); if (s?.type === 'sticker') { fn(s); render(); } };

  ($('mm-t-text') as HTMLTextAreaElement).addEventListener('input', onText((t) => { t.text = ($('mm-t-text') as HTMLTextAreaElement).value; }));
  ($('mm-t-text') as HTMLTextAreaElement).addEventListener('focus', () => beginChangeCheckpoint());
  ($('mm-t-font') as HTMLSelectElement).addEventListener('change', () => { pushUndo(); onText((t) => { t.fontFamily = ($('mm-t-font') as HTMLSelectElement).value; })(); });
  ($('mm-t-size') as HTMLInputElement).addEventListener('input', onText((t) => { t.fontFrac = Number(($('mm-t-size') as HTMLInputElement).value) / 100; $('mm-t-sizev').textContent = (t.fontFrac * 100).toFixed(1) + '%'; }));
  ($('mm-t-size') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);
  ($('mm-t-fill') as HTMLInputElement).addEventListener('input', onText((t) => { t.fill = ($('mm-t-fill') as HTMLInputElement).value; }));
  ($('mm-t-fill') as HTMLInputElement).addEventListener('change', beginChangeCheckpoint);
  ($('mm-t-stroke') as HTMLInputElement).addEventListener('input', onText((t) => { t.stroke = ($('mm-t-stroke') as HTMLInputElement).value; }));
  ($('mm-t-stroke') as HTMLInputElement).addEventListener('change', beginChangeCheckpoint);
  ($('mm-t-sw') as HTMLInputElement).addEventListener('input', onText((t) => { t.strokeW = Number(($('mm-t-sw') as HTMLInputElement).value); $('mm-t-swv').textContent = t.strokeW.toFixed(1); }));
  ($('mm-t-sw') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);
  ($('mm-t-op') as HTMLInputElement).addEventListener('input', onText((t) => { t.opacity = Number(($('mm-t-op') as HTMLInputElement).value) / 100; $('mm-t-opv').textContent = Math.round(t.opacity * 100) + '%'; }));
  ($('mm-t-op') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);
  $('mm-t-bold').addEventListener('click', () => { pushUndo(); onText((t) => { t.bold = !t.bold; setToggle('mm-t-bold', t.bold); })(); });
  $('mm-t-italic').addEventListener('click', () => { pushUndo(); onText((t) => { t.italic = !t.italic; setToggle('mm-t-italic', t.italic); })(); });
  $('mm-t-upper').addEventListener('click', () => { pushUndo(); onText((t) => { t.upper = !t.upper; setToggle('mm-t-upper', t.upper); })(); });
  document.querySelectorAll('.mm-align').forEach((b) => b.addEventListener('click', () => {
    pushUndo();
    onText((t) => { t.align = (b as HTMLElement).dataset.align as Align;
      document.querySelectorAll('.mm-align').forEach((x) => x.classList.toggle('mm-toggle-on', x === b)); })();
  }));

  ($('mm-s-size') as HTMLInputElement).addEventListener('input', onSticker((s) => { s.widthFrac = Number(($('mm-s-size') as HTMLInputElement).value) / 100; $('mm-s-sizev').textContent = (s.widthFrac * 100).toFixed(0) + '%'; }));
  ($('mm-s-size') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);
  ($('mm-s-rot') as HTMLInputElement).addEventListener('input', onSticker((s) => { s.rotation = Number(($('mm-s-rot') as HTMLInputElement).value); $('mm-s-rotv').textContent = s.rotation + '°'; }));
  ($('mm-s-rot') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);
  ($('mm-s-op') as HTMLInputElement).addEventListener('input', onSticker((s) => { s.opacity = Number(($('mm-s-op') as HTMLInputElement).value) / 100; $('mm-s-opv').textContent = Math.round(s.opacity * 100) + '%'; }));
  ($('mm-s-op') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);

  // A lightweight checkpoint used for continuous edits (one undo per gesture).
  let checkpointArmed = false;
  function beginChangeCheckpoint() { if (!checkpointArmed) { pushUndo(); checkpointArmed = true; setTimeout(() => (checkpointArmed = false), 400); } }

  // ---- Layer ops -------------------------------------------------------
  $('mm-layer-del').addEventListener('click', () => { const s = selected(); if (!s) return; pushUndo(); layers = layers.filter((l) => l.id !== s.id); selectedId = null; render(); syncInspector(); });
  $('mm-layer-dup').addEventListener('click', duplicateSelected);
  function duplicateSelected() {
    const s = selected(); if (!s) return;
    pushUndo();
    const copy = { ...s, id: newId(), cx: Math.min(0.95, s.cx + 0.04), cy: Math.min(0.95, s.cy + 0.04) } as Layer;
    layers.push(copy); selectedId = copy.id; render(); syncInspector();
  }
  $('mm-layer-fwd').addEventListener('click', () => moveLayer(1));
  $('mm-layer-back').addEventListener('click', () => moveLayer(-1));
  function moveLayer(dir: number) {
    const i = layers.findIndex((l) => l.id === selectedId); if (i < 0) return;
    const j = i + dir; if (j < 0 || j >= layers.length) return;
    pushUndo();
    [layers[i], layers[j]] = [layers[j], layers[i]]; render();
  }

  // ---- Toolbar ---------------------------------------------------------
  $('mm-add-text').addEventListener('click', () => { pushUndo(); addText('New text', 0.5); render(); syncInspector(); });
  $('mm-add-sticker').addEventListener('click', () => { pushUndo(); addSticker('😂'); render(); syncInspector(); });
  $('mm-rotate').addEventListener('click', () => { pushUndo(); rotation = (rotation + 90) % 360; render(); });
  $('mm-flip-h').addEventListener('click', () => { pushUndo(); flipH = !flipH; render(); });
  $('mm-flip-v').addEventListener('click', () => { pushUndo(); flipV = !flipV; render(); });
  $('mm-undo').addEventListener('click', undo);
  $('mm-redo').addEventListener('click', redo);

  ($('mm-padt') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);
  ($('mm-padt') as HTMLInputElement).addEventListener('input', () => { padTop = Number(($('mm-padt') as HTMLInputElement).value) / 100; $('mm-padtv').textContent = Math.round(padTop * 100) + '%'; render(); });
  ($('mm-padb') as HTMLInputElement).addEventListener('pointerdown', beginChangeCheckpoint);
  ($('mm-padb') as HTMLInputElement).addEventListener('input', () => { padBottom = Number(($('mm-padb') as HTMLInputElement).value) / 100; $('mm-padbv').textContent = Math.round(padBottom * 100) + '%'; render(); });

  // ---- Emoji palette ---------------------------------------------------
  const EMOJIS = ['😂','🤣','😭','😍','😎','🥹','😳','🤔','😱','🔥','💀','👀','👍','👎','💯','❤️','🎉','⭐','✨','😡','🤡','🥳','🙌','👑','💩','🚀','⚡','💥','😏','🫡'];
  const emojiGrid = $('mm-emoji-grid');
  EMOJIS.forEach((e) => {
    const b = document.createElement('button');
    b.type = 'button'; b.className = 'mm-emoji'; b.textContent = e;
    b.addEventListener('click', () => {
      const s = selected();
      if (s?.type === 'sticker') { pushUndo(); s.kind = 'emoji'; s.emoji = e; s.img = undefined; s.aspect = 1; render(); }
    });
    emojiGrid.appendChild(b);
  });

  // Image sticker upload.
  ($('mm-sticker-file') as HTMLInputElement).addEventListener('change', (ev) => {
    const f = (ev.target as HTMLInputElement).files?.[0]; if (!f) return;
    const url = URL.createObjectURL(f);
    const im = new Image();
    im.onload = () => {
      const s = selected();
      if (s?.type === 'sticker') { pushUndo(); s.kind = 'image'; s.img = im; s.emoji = undefined; s.aspect = im.naturalHeight / im.naturalWidth; render(); }
      URL.revokeObjectURL(url);
    };
    im.src = url;
  });

  // ---- Image loading ---------------------------------------------------
  function fitDims(w: number, h: number) {
    const longest = Math.max(w, h);
    if (longest <= MAX_SIDE) return { w, h };
    const s = MAX_SIDE / longest;
    return { w: Math.round(w * s), h: Math.round(h * s) };
  }
  function showEditor() { panel.classList.remove('hidden'); panel.classList.add('flex'); }

  function loadImageEl(im: HTMLImageElement, seedCaptions: boolean) {
    const d = fitDims(im.naturalWidth || im.width, im.naturalHeight || im.height);
    img = im; baseW = d.w; baseH = d.h;
    rotation = 0; flipH = false; flipV = false; padTop = 0; padBottom = 0;
    layers = []; selectedId = null;
    undoStack.length = 0; redoStack.length = 0; updateHistoryButtons();
    syncPadInputs();
    if (seedCaptions) { addText('TOP TEXT', 0.11); addText('BOTTOM TEXT', 0.89); selectedId = null; }
    showEditor(); render(); syncInspector();
  }

  function loadFile(file: File) {
    const url = URL.createObjectURL(file);
    const im = new Image();
    im.onload = () => { loadImageEl(im, false); URL.revokeObjectURL(url); };
    im.onerror = () => URL.revokeObjectURL(url);
    im.src = url;
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) loadFile(f); });

  // Paste from clipboard.
  window.addEventListener('paste', (ev) => {
    const items = (ev as ClipboardEvent).clipboardData?.items; if (!items) return;
    for (const it of items) if (it.type.startsWith('image/')) { const f = it.getAsFile(); if (f) { loadFile(f); ev.preventDefault(); break; } }
  });

  // ---- Template gallery -----------------------------------------------
  // Two free, CORS-clean sources merged & deduped by name:
  //   • imgflip get_memes    — 100 most popular (no key)
  //   • memegen.link         — ~213 classic templates (each has a blank image)
  // Both send Access-Control-Allow-Origin:* on API *and* images, so templates
  // draw to the canvas without tainting it (download stays intact). imgflip's
  // "million template" search is a paid, credentialed API and can't run
  // client-side, so this is the practical free ceiling.
  interface Tpl { name: string; url: string; }
  let templates: Tpl[] = [];
  let tplLoaded = false;
  const tplToggle = $('mm-tpl-toggle');
  const tplWrap = $('mm-tpl');
  const tplGrid = $('mm-tpl-grid');
  const tplStatus = $('mm-tpl-status');
  const tplSearch = $<HTMLInputElement>('mm-tpl-search');

  tplToggle.addEventListener('click', () => {
    const open = tplWrap.classList.toggle('hidden');
    tplWrap.classList.toggle('flex', !open);
    if (!open && !tplLoaded) loadTemplates();
  });

  async function fetchImgflip(): Promise<Tpl[]> {
    const res = await fetch('https://api.imgflip.com/get_memes');
    const json = await res.json();
    if (!json?.success || !json.data?.memes) throw new Error('bad imgflip response');
    return json.data.memes.map((m: any) => ({ name: String(m.name), url: String(m.url) }));
  }
  async function fetchMemegen(): Promise<Tpl[]> {
    const res = await fetch('https://api.memegen.link/templates');
    const json = await res.json();
    if (!Array.isArray(json)) throw new Error('bad memegen response');
    return json
      .filter((m: any) => m?.name && m?.blank)
      .map((m: any) => ({ name: String(m.name), url: String(m.blank) }));
  }

  async function loadTemplates() {
    tplLoaded = true;
    tplStatus.textContent = 'Loading…';
    const [a, b] = await Promise.allSettled([fetchImgflip(), fetchMemegen()]);
    const merged: Tpl[] = [];
    if (a.status === 'fulfilled') merged.push(...a.value);
    if (b.status === 'fulfilled') merged.push(...b.value);
    if (!merged.length) {
      tplLoaded = false;
      tplStatus.textContent = 'Could not load templates — upload an image instead.';
      return;
    }
    // Dedupe by normalized name; earlier source (imgflip) wins.
    const seen = new Set<string>();
    templates = merged.filter((t) => {
      const key = t.name.trim().toLowerCase();
      if (seen.has(key)) return false;
      seen.add(key); return true;
    });
    tplStatus.textContent = `${templates.length} templates`;
    renderTemplates('');
  }

  function renderTemplates(q: string) {
    const query = q.trim().toLowerCase();
    const list = query ? templates.filter((t) => t.name.toLowerCase().includes(query)) : templates;
    tplGrid.textContent = '';
    for (const t of list) {
      const card = document.createElement('div');
      card.className = 'mm-tpl-card';
      card.title = t.name;
      const im = document.createElement('img');
      im.loading = 'lazy'; im.alt = t.name; im.src = t.url;
      card.appendChild(im);
      card.addEventListener('click', () => loadTemplate(t));
      tplGrid.appendChild(card);
    }
    if (!list.length) { const p = document.createElement('p'); p.className = 'col-span-full text-[13px] text-ink-tertiary'; p.textContent = 'No matches.'; tplGrid.appendChild(p); }
  }
  tplSearch.addEventListener('input', () => renderTemplates(tplSearch.value));

  function loadTemplate(t: Tpl) {
    const im = new Image();
    im.crossOrigin = 'anonymous';   // both CDNs send ACAO:* — keeps canvas exportable
    im.onload = () => {
      loadImageEl(im, true);
      // Collapse the gallery for focus.
      tplWrap.classList.add('hidden'); tplWrap.classList.remove('flex');
    };
    im.onerror = () => { tplStatus.textContent = 'That template failed to load — try another.'; };
    im.src = t.url;
  }

  // ---- Keyboard shortcuts ---------------------------------------------
  window.addEventListener('keydown', (ev) => {
    const tag = (ev.target as HTMLElement)?.tagName;
    const typing = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
    const meta = ev.ctrlKey || ev.metaKey;
    if (meta && ev.key.toLowerCase() === 'z') { ev.preventDefault(); ev.shiftKey ? redo() : undo(); return; }
    if (meta && ev.key.toLowerCase() === 'y') { ev.preventDefault(); redo(); return; }
    if (meta && ev.key.toLowerCase() === 'd') { ev.preventDefault(); duplicateSelected(); return; }
    if (typing) return;
    const sel = selected(); if (!sel) return;
    if (ev.key === 'Delete' || ev.key === 'Backspace') {
      ev.preventDefault(); pushUndo(); layers = layers.filter((l) => l.id !== sel.id); selectedId = null; render(); syncInspector(); return;
    }
    const step = ev.shiftKey ? 0.02 : 0.004;
    let moved = true;
    if (ev.key === 'ArrowLeft') sel.cx -= step;
    else if (ev.key === 'ArrowRight') sel.cx += step;
    else if (ev.key === 'ArrowUp') sel.cy -= step;
    else if (ev.key === 'ArrowDown') sel.cy += step;
    else moved = false;
    if (moved) { ev.preventDefault(); beginChangeCheckpoint(); render(); }
  });

  // ---- Download --------------------------------------------------------
  function download(type: 'image/png' | 'image/jpeg') {
    if (!img) return;
    const prevSel = selectedId;
    selectedId = null; render(); // hide selection chrome in export
    const errEl = $('mm-dl-err');
    try {
      const url = canvas.toDataURL(type, type === 'image/jpeg' ? 0.92 : undefined);
      const a = document.createElement('a');
      a.href = url; a.download = type === 'image/jpeg' ? 'meme.jpg' : 'meme.png'; a.click();
      errEl.classList.add('hidden');
    } catch {
      errEl.textContent = 'Export blocked by the source image. Try uploading it instead of using a template.';
      errEl.classList.remove('hidden');
    } finally {
      selectedId = prevSel; render(); syncInspector();
    }
  }
  $('mm-dl-png').addEventListener('click', () => download('image/png'));
  $('mm-dl-jpg').addEventListener('click', () => download('image/jpeg'));
</script>

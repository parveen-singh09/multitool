---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="meme-generator">
  <div class="flex flex-col gap-4">
    <label id="mm-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an image or drop it here</span>
      <span class="text-[13px] text-ink-tertiary">Captioned in your browser — never uploaded</span>
      <input id="mm-file" type="file" accept="image/*" class="sr-only" />
    </label>

    <div id="mm-panel" class="hidden flex-col gap-4">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Top text
          <input id="mm-top" class="field" value="ONE DOES NOT SIMPLY" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bottom text
          <input id="mm-bottom" class="field" value="UPLOAD A MEME" />
        </label>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Font size: <span id="mm-fsv" class="text-ink">42px</span>
        <input id="mm-fs" type="range" min="20" max="90" value="42" class="w-full accent-[#5e6ad2]" />
      </label>
      <div class="flex justify-center overflow-auto rounded-[12px] border border-hairline bg-surface-2 p-4">
        <canvas id="mm-canvas" class="max-w-full"></canvas>
      </div>
      <button id="mm-dl" class="btn btn-primary w-fit">Download meme</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free meme generator adds the classic bold, white, black-outlined Impact
      captions to the top and bottom of any image. Drop in a picture, type your
      lines, tune the font size, and download the finished meme. Your image is
      drawn on a canvas entirely in your browser — it is never uploaded to a server.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('mm-file') as HTMLInputElement;
  const drop = $('mm-drop')!;
  const panel = $('mm-panel')!;
  const canvas = $('mm-canvas') as HTMLCanvasElement;
  let img: HTMLImageElement | null = null;

  function drawText(ctx: CanvasRenderingContext2D, text: string, y: number, fs: number, w: number) {
    ctx.font = `700 ${fs}px Impact, "Arial Narrow", sans-serif`;
    ctx.textAlign = 'center';
    ctx.lineWidth = Math.max(2, fs / 12);
    ctx.strokeStyle = '#000';
    ctx.fillStyle = '#fff';
    const words = text.toUpperCase().split(/\s+/);
    const lines: string[] = [];
    let line = '';
    for (const word of words) {
      const test = line ? line + ' ' + word : word;
      if (ctx.measureText(test).width > w * 0.94 && line) { lines.push(line); line = word; }
      else line = test;
    }
    if (line) lines.push(line);
    const lh = fs * 1.1;
    lines.forEach((l, i) => {
      const ly = y < canvas.height / 2 ? y + i * lh : y - (lines.length - 1 - i) * lh;
      ctx.strokeText(l, canvas.width / 2, ly);
      ctx.fillText(l, canvas.width / 2, ly);
    });
  }

  function render() {
    if (!img) return;
    const ctx = canvas.getContext('2d')!;
    canvas.width = img.naturalWidth;
    canvas.height = img.naturalHeight;
    ctx.drawImage(img, 0, 0);
    const fs = Number(($('mm-fs') as HTMLInputElement).value) * (canvas.width / 500);
    ctx.textBaseline = 'top';
    drawText(ctx, ($('mm-top') as HTMLInputElement).value, fs * 0.3, fs, canvas.width);
    ctx.textBaseline = 'bottom';
    drawText(ctx, ($('mm-bottom') as HTMLInputElement).value, canvas.height - fs * 0.3, fs, canvas.width);
  }

  function load(file: File) {
    const url = URL.createObjectURL(file);
    const im = new Image();
    im.onload = () => { img = im; panel.classList.remove('hidden'); panel.classList.add('flex'); render(); URL.revokeObjectURL(url); };
    im.src = url;
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) load(fileInput.files[0]); });
  ['mm-top', 'mm-bottom', 'mm-fs'].forEach((id) => $(id).addEventListener('input', () => {
    $('mm-fsv').textContent = ($('mm-fs') as HTMLInputElement).value + 'px'; render();
  }));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) load(f); });
  $('mm-dl').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = 'meme.png'; a.click();
  });
</script>

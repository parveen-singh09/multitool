---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="cooking-converter">
  <UnitConverter slug="cooking-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free cooking and recipe converter converts recipe measurements between cups, tablespoons, teaspoons, millilitres, litres and fluid ounces, with US and imperial spoons and cups kept separate. Perfect for following recipes from anywhere. Runs in your browser.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="speed-converter">
  <UnitConverter slug="speed-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free speed converter converts speed between kilometres per hour, miles per hour, metres per second, feet per second and knots. Handy for travel, sport and physics. Every calculation runs locally in your browser.
    </p>
  </div>
</ToolLayout>

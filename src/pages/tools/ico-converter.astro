---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ico-converter">
  <div class="flex flex-col gap-4">
    <label id="ico-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an image or drop it here</span>
      <input id="ico-file" type="file" accept="image/*" class="sr-only" />
    </label>

    <div id="ico-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-end gap-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Scaling
          <select id="ico-scale" class="field w-auto py-1">
            <option value="contain" selected>Contain (fit, no crop)</option>
            <option value="cover">Cover (fill, crop edges)</option>
            <option value="stretch">Stretch (ignore ratio)</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Background
          <select id="ico-bg" class="field w-auto py-1">
            <option value="transparent" selected>Transparent</option>
            <option value="#ffffff">White</option>
            <option value="#010102">Black</option>
            <option value="custom">Customâ€¦</option>
          </select>
        </label>
        <label id="ico-bg-custom-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">
          Color
          <input id="ico-bg-custom" type="color" value="#5e6ad2" class="field h-9 w-14 cursor-pointer p-1" />
        </label>
      </div>

      <div>
        <span class="text-[13px] text-ink-subtle">Sizes to include</span>
        <div id="ico-sizes" class="mt-2 flex flex-wrap gap-3"></div>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="ico-download" class="btn btn-primary">Download .ico</button>
        <button id="ico-download-png" class="btn btn-secondary">Download PNGs</button>
        <span id="ico-info" class="text-[13px] text-ink-subtle"></span>
      </div>

      <div>
        <span class="text-[13px] text-ink-subtle">Live preview</span>
        <div id="ico-preview" class="ico-checker panel mt-2 flex flex-wrap items-end justify-center gap-6 p-5"></div>
      </div>

      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span>HTML for your page &lt;head&gt;</span>
        <div class="copy-wrap">
          <pre id="ico-html" class="field m-0 overflow-auto p-3 text-[13px]" style="white-space:pre;font-family:var(--font-mono,ui-monospace,monospace)"></pre>
          <button type="button" class="copy-icon" data-copy-target="#ico-html" aria-label="Copy"></button>
        </div>
      </div>
    </div>

    <p id="ico-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free ICO converter creates Windows icon and favicon <code>.ico</code>
      files from any image â€” PNG, JPG, WebP, GIF or SVG. It renders your image to
      every standard icon size (16, 24, 32, 48, 64, 128 and 256 pixels) and packs
      the ones you choose into a single multi-resolution ICO, using embedded PNG
      data for crisp, lossless results at each size.
    </p>
    <p>
      Control how non-square images are fit with three scaling modes â€” contain
      (letterbox, no crop), cover (fill and crop the edges) or stretch â€” and pick
      a transparent or solid background so your icon looks right on any surface.
      A live preview shows each selected size against a checkerboard so you can
      spot transparency issues before you download.
    </p>
    <p>
      Beyond the ICO, you can download individual PNG favicons for each size and
      copy a ready-to-paste HTML snippet with the correct <code>&lt;link&gt;</code>
      tags for your favicon, PNG icons and Apple touch icon. Use a square source
      image at 256Ã—256 or larger for the sharpest results across every size.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }

  .ico-checker {
    background-image:
      linear-gradient(45deg, #16171a 25%, transparent 25%),
      linear-gradient(-45deg, #16171a 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #16171a 75%),
      linear-gradient(-45deg, transparent 75%, #16171a 75%);
    background-size: 16px 16px;
    background-position: 0 0, 0 8px, 8px -8px, -8px 0;
  }
  .ico-tile { display:flex; flex-direction:column; align-items:center; gap:6px; }
  .ico-tile img { image-rendering:auto; display:block; }
  .ico-tile .ico-dl { font-size:12px; color:var(--color-ink-subtle,#8a8f98); text-decoration:none; }
  .ico-tile .ico-dl:hover { color:var(--color-ink,#f7f8f8); text-decoration:underline; }
</style>

<script>
  const fileInput = document.getElementById('ico-file') as HTMLInputElement;
  const drop = document.getElementById('ico-drop')!;
  const panel = document.getElementById('ico-panel')!;
  const sizesWrap = document.getElementById('ico-sizes')!;
  const info = document.getElementById('ico-info')!;
  const err = document.getElementById('ico-error')!;
  const preview = document.getElementById('ico-preview')!;
  const htmlBlock = document.getElementById('ico-html')!;
  const scaleSel = document.getElementById('ico-scale') as HTMLSelectElement;
  const bgSel = document.getElementById('ico-bg') as HTMLSelectElement;
  const bgCustom = document.getElementById('ico-bg-custom') as HTMLInputElement;
  const bgCustomWrap = document.getElementById('ico-bg-custom-wrap')!;
  const SIZES = [16, 24, 32, 48, 64, 128, 256];
  const DEFAULT_ON = new Set([16, 32, 48, 256]);
  let img: HTMLImageElement | null = null;
  let sourceName = 'favicon';
  const objectUrls: string[] = [];

  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }
  function trackUrl(u: string) { objectUrls.push(u); return u; }
  function revokeAll() { objectUrls.splice(0).forEach(URL.revokeObjectURL); }

  sizesWrap.innerHTML = SIZES.map((s) => `<label class="flex items-center gap-2 text-sm text-ink-subtle"><input type="checkbox" class="ico-size accent-primary" value="${s}" ${DEFAULT_ON.has(s) ? 'checked' : ''}> ${s}Ã—${s}</label>`).join('');

  function selectedSizes(): number[] {
    return Array.from(document.querySelectorAll<HTMLInputElement>('.ico-size:checked')).map((c) => Number(c.value)).sort((a, b) => a - b);
  }

  function currentBg(): string | null {
    if (bgSel.value === 'transparent') return null;
    return bgSel.value === 'custom' ? bgCustom.value : bgSel.value;
  }

  function renderCanvas(size: number): HTMLCanvasElement {
    const canvas = document.createElement('canvas');
    canvas.width = size; canvas.height = size;
    const ctx = canvas.getContext('2d')!;
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = 'high';
    const bg = currentBg();
    if (bg) { ctx.fillStyle = bg; ctx.fillRect(0, 0, size, size); }
    const iw = img!.naturalWidth || size, ih = img!.naturalHeight || size;
    const mode = scaleSel.value;
    if (mode === 'stretch') {
      ctx.drawImage(img!, 0, 0, size, size);
    } else {
      const scale = mode === 'cover' ? Math.max(size / iw, size / ih) : Math.min(size / iw, size / ih);
      const dw = iw * scale, dh = ih * scale;
      ctx.drawImage(img!, (size - dw) / 2, (size - dh) / 2, dw, dh);
    }
    return canvas;
  }

  function pngBlobFor(size: number): Promise<Blob> {
    return new Promise((resolve, reject) => {
      renderCanvas(size).toBlob((b) => (b ? resolve(b) : reject(new Error('encode failed'))), 'image/png');
    });
  }

  async function buildIco(sizes: number[]): Promise<Blob> {
    const pngs = await Promise.all(sizes.map((s) => pngBlobFor(s).then((b) => b.arrayBuffer())));
    const count = sizes.length;
    const headerSize = 6 + count * 16;
    let offset = headerSize;
    const header = new ArrayBuffer(headerSize);
    const dv = new DataView(header);
    dv.setUint16(0, 0, true); 
    dv.setUint16(2, 1, true); 
    dv.setUint16(4, count, true);
    sizes.forEach((s, i) => {
      const base = 6 + i * 16;
      dv.setUint8(base, s >= 256 ? 0 : s);       
      dv.setUint8(base + 1, s >= 256 ? 0 : s);   
      dv.setUint8(base + 2, 0);                  
      dv.setUint8(base + 3, 0);                  
      dv.setUint16(base + 4, 1, true);           
      dv.setUint16(base + 6, 32, true);          
      dv.setUint32(base + 8, pngs[i].byteLength, true); 
      dv.setUint32(base + 12, offset, true);     
      offset += pngs[i].byteLength;
    });
    return new Blob([header, ...pngs], { type: 'image/x-icon' });
  }

  function download(blob: Blob, name: string) {
    const url = trackUrl(URL.createObjectURL(blob));
    const a = document.createElement('a');
    a.download = name; a.href = url; a.click();
  }

  function updateHtml() {
    const sizes = selectedSizes();
    const lines = ['<link rel="icon" type="image/x-icon" href="/favicon.ico">'];
    for (const s of sizes) {
      if (s === 256) continue; 
      lines.push(`<link rel="icon" type="image/png" sizes="${s}x${s}" href="/favicon-${s}x${s}.png">`);
    }
    lines.push('<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">');
    htmlBlock.textContent = lines.join('\n');
  }

  async function refreshPreview() {
    if (!img) return;
    revokeAll();
    const sizes = selectedSizes();
    preview.innerHTML = '';
    if (!sizes.length) { preview.innerHTML = '<span class="text-[13px] text-ink-tertiary">Pick at least one size.</span>'; return; }
    for (const s of sizes) {
      const blob = await pngBlobFor(s);
      const url = trackUrl(URL.createObjectURL(blob));
      const display = Math.min(s, 128);
      const tile = document.createElement('div');
      tile.className = 'ico-tile';
      const image = document.createElement('img');
      image.src = url; image.width = display; image.height = display;
      image.alt = `${s}Ã—${s} preview`;
      const label = document.createElement('span');
      label.className = 'text-[12px] text-ink-tertiary';
      label.textContent = `${s}Ã—${s}`;
      const dl = document.createElement('a');
      dl.className = 'ico-dl'; dl.href = url; dl.download = `${sourceName}-${s}x${s}.png`;
      dl.textContent = 'PNG';
      tile.append(image, label, dl);
      preview.append(tile);
    }
  }

  function refresh() {
    setErr('');
    updateHtml();
    refreshPreview();
  }

  function loadFile(file: File) {
    setErr('');
    if (!file.type.startsWith('image/')) { setErr('Please choose an image file.'); return; }
    sourceName = (file.name.replace(/\.[^.]+$/, '') || 'favicon').replace(/[^\w.-]+/g, '-');
    const reader = new FileReader();
    reader.onerror = () => setErr('Could not read that file.');
    reader.onload = () => {
      const next = new Image();
      next.onload = () => {
        img = next;
        panel.classList.remove('hidden'); panel.classList.add('flex');
        info.textContent = `Source ${next.naturalWidth}Ã—${next.naturalHeight}`;
        if (next.naturalWidth < 256 || next.naturalHeight < 256) {
          info.textContent += ' â€” small source, larger sizes may look soft';
        }
        refresh();
      };
      next.onerror = () => setErr('Could not read that image file. Try PNG, JPG, WebP, GIF or SVG.');
      next.src = reader.result as string;
    };
    reader.readAsDataURL(file);
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) loadFile(f); });

  scaleSel.addEventListener('change', refresh);
  bgSel.addEventListener('change', () => { bgCustomWrap.classList.toggle('hidden', bgSel.value !== 'custom'); bgCustomWrap.classList.toggle('flex', bgSel.value === 'custom'); refresh(); });
  bgCustom.addEventListener('input', () => { if (bgSel.value === 'custom') refresh(); });
  sizesWrap.addEventListener('change', refresh);

  document.getElementById('ico-download')!.addEventListener('click', async () => {
    if (!img) return;
    const sizes = selectedSizes();
    if (!sizes.length) { setErr('Pick at least one size.'); return; }
    setErr('');
    try {
      download(await buildIco(sizes), `${sourceName}.ico`);
    } catch { setErr('Could not build the ICO file.'); }
  });

  document.getElementById('ico-download-png')!.addEventListener('click', async () => {
    if (!img) return;
    const sizes = selectedSizes();
    if (!sizes.length) { setErr('Pick at least one size.'); return; }
    setErr('');
    try {
      // ponytail: sequential downloads, no zip dep. Browsers allow multiple <a>.click().
      for (const s of sizes) download(await pngBlobFor(s), `${sourceName}-${s}x${s}.png`);
    } catch { setErr('Could not export the PNG files.'); }
  });
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="date-format-converter">
  <div class="flex flex-col gap-5">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_auto]">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Enter a date (any common format, or a Unix timestamp)
        <input id="df-in" class="field font-mono" placeholder="2026-07-04 14:30 or 1751640600" spellcheck="false" autocomplete="off" />
      </label>
      <div class="flex items-end">
        <button id="df-now" type="button" class="btn btn-secondary w-full sm:w-auto">Now</button>
      </div>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle sm:max-w-xs">
      Time zone
      <select id="df-tz" class="field w-full"></select>
    </label>

    <p id="df-parsed" class="text-[13px] text-ink-tertiary"></p>
    <p id="df-error" class="hidden text-[13px]" style="color:#e5484d" role="alert">Could not understand that date. Try a format like 2026-07-04, Jul 4 2026, or 07/04/2026.</p>

    <div id="df-out" class="overflow-hidden rounded-md border border-hairline"></div>

    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      <label for="df-fmt">Custom format</label>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_1fr]">
        <input id="df-fmt" class="field font-mono" value="YYYY-MM-DD HH:mm:ss" spellcheck="false" autocomplete="off" />
        <div id="df-fmt-out" class="df-copy field font-mono flex cursor-pointer items-center justify-between text-ink" title="Click to copy"></div>
      </div>
      <details class="mt-1">
        <summary class="cursor-pointer text-[13px] text-ink-tertiary hover:text-ink-subtle">Format tokens</summary>
        <div class="mt-2 grid grid-cols-2 gap-x-6 gap-y-1 font-mono text-[12px] text-ink-subtle sm:grid-cols-3">
          <span><b class="text-ink">YYYY</b> 2026 · <b class="text-ink">YY</b> 26</span>
          <span><b class="text-ink">MMMM/MMM/MM/M</b> month</span>
          <span><b class="text-ink">DD/D/Do</b> day · <b class="text-ink">DDD</b> of year</span>
          <span><b class="text-ink">dddd/ddd</b> weekday</span>
          <span><b class="text-ink">HH/H</b> 24h · <b class="text-ink">hh/h</b> 12h</span>
          <span><b class="text-ink">mm/m</b> min · <b class="text-ink">ss/s</b> sec</span>
          <span><b class="text-ink">SSS</b> ms · <b class="text-ink">A/a</b> AM/PM</span>
          <span><b class="text-ink">Z/ZZ</b> offset · <b class="text-ink">z</b> zone</span>
          <span><b class="text-ink">X</b> unix s · <b class="text-ink">x</b> unix ms</span>
          <span>Wrap literals in <b class="text-ink">[brackets]</b></span>
        </div>
      </details>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free date format converter parses a date you type — in almost any
      common format, or as a Unix timestamp — and shows it in a wide range of
      standard formats at once: ISO 8601, RFC 2822, RFC 3339, US and European
      styles, long written forms, ISO week date, quarter, the Unix timestamp in
      seconds and milliseconds, the UTC offset, day of year and a relative
      "time from now". Click any row to copy it.
    </p>
    <p>
      Pick any time zone from the full IANA list (defaulting to your own) and
      every format re-renders for that zone, so you can read the same instant in
      New York, London or Tokyo. The custom format box turns your date into an
      arbitrary pattern using familiar tokens like <span class="font-mono">YYYY-MM-DD HH:mm:ss</span>,
      matching what tools like moment.js and day.js use.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('df-in') as HTMLInputElement;
  const tzSel = document.getElementById('df-tz') as HTMLSelectElement;
  const fmtIn = document.getElementById('df-fmt') as HTMLInputElement;
  const fmtOut = document.getElementById('df-fmt-out')!;
  const parsed = document.getElementById('df-parsed')!;
  const err = document.getElementById('df-error')!;
  const out = document.getElementById('df-out')!;

  const DAYS = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const MON = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  const p2 = (n: number) => String(n).padStart(2, '0');
  const p3 = (n: number) => String(n).padStart(3, '0');

  const LOCAL_TZ = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';

  function populateZones() {
    const add = (value: string, label: string) => {
      const o = document.createElement('option');
      o.value = value; o.textContent = label; tzSel.appendChild(o);
    };
    add(LOCAL_TZ, `Local — ${LOCAL_TZ}`);
    add('UTC', 'UTC');
    let zones: string[] = [];
    try { zones = (Intl as any).supportedValuesOf?.('timeZone') ?? []; } catch 
    if (!zones.length) {
      // ponytail: fallback shortlist only when supportedValuesOf is unavailable.
      zones = ['America/New_York', 'America/Chicago', 'America/Denver', 'America/Los_Angeles', 'America/Sao_Paulo',
        'Europe/London', 'Europe/Paris', 'Europe/Berlin', 'Europe/Moscow', 'Africa/Cairo',
        'Asia/Dubai', 'Asia/Kolkata', 'Asia/Shanghai', 'Asia/Tokyo', 'Australia/Sydney', 'Pacific/Auckland'];
    }
    for (const z of zones) if (z !== 'UTC') add(z, z);
    tzSel.value = LOCAL_TZ;
  }

  function parse(raw: string): Date | null {
    const v = raw.trim();
    if (!v) return null;
    // pure number => unix timestamp (s: 10 digits, ms: 13). Accept 9–13 for leniency.
    if (/^\d{9,13}$/.test(v)) {
      const n = Number(v);
      return new Date(v.length <= 10 ? n * 1000 : n);
    }
    const d = new Date(v);
    if (!isNaN(d.getTime())) return d;
    // try DD/MM/YYYY (Date() assumes US MM/DD) — swap if day > 12
    const m = v.match(/^(\d{1,2})[/.-](\d{1,2})[/.-](\d{2,4})/);
    if (m && Number(m[1]) > 12) {
      const d2 = new Date(`${m[2]}/${m[1]}/${m[3]}`);
      if (!isNaN(d2.getTime())) return d2;
    }
    return null;
  }

  // Wall-clock components + offset of an instant in a given IANA zone, via Intl.
  interface Zoned { Y: number; Mo: number; D: number; h: number; mi: number; s: number; ms: number; offMin: number; }
  function zoned(d: Date, tz: string): Zoned {
    const dtf = new Intl.DateTimeFormat('en-US', {
      timeZone: tz, hour12: false,
      year: 'numeric', month: '2-digit', day: '2-digit',
      hour: '2-digit', minute: '2-digit', second: '2-digit',
    });
    const parts: Record<string, string> = {};
    for (const p of dtf.formatToParts(d)) if (p.type !== 'literal') parts[p.type] = p.value;
    let hour = Number(parts.hour);
    if (hour === 24) hour = 0; // some engines emit 24 for midnight
    const Y = Number(parts.year), Mo = Number(parts.month) - 1, D = Number(parts.day);
    const mi = Number(parts.minute), s = Number(parts.second);
    // offset (minutes) = wall time interpreted as UTC minus the true instant
    const asUTC = Date.UTC(Y, Mo, D, hour, mi, s, d.getMilliseconds());
    const offMin = Math.round((asUTC - d.getTime()) / 60000);
    return { Y, Mo, D, h: hour, mi, s, ms: d.getMilliseconds(), offMin };
  }

  const offsetStr = (offMin: number, colon = true): string => {
    const sign = offMin >= 0 ? '+' : '-';
    const a = Math.abs(offMin);
    return `${sign}${p2(Math.floor(a / 60))}${colon ? ':' : ''}${p2(a % 60)}`;
  };

  const isoWeek = (Y: number, Mo: number, D: number): [number, number] => {
    const dt = new Date(Date.UTC(Y, Mo, D));
    const day = (dt.getUTCDay() + 6) % 7; // Mon=0
    dt.setUTCDate(dt.getUTCDate() - day + 3); // nearest Thursday
    const isoY = dt.getUTCFullYear();
    const firstThu = new Date(Date.UTC(isoY, 0, 4));
    const firstDay = (firstThu.getUTCDay() + 6) % 7;
    firstThu.setUTCDate(firstThu.getUTCDate() - firstDay + 3);
    const week = 1 + Math.round((dt.getTime() - firstThu.getTime()) / (7 * 86400000));
    return [isoY, week];
  };

  const ordinal = (n: number): string => {
    const s = ['th', 'st', 'nd', 'rd'], v = n % 100;
    return n + (s[(v - 20) % 10] || s[v] || s[0]);
  };

  function relative(d: Date): string {
    const diff = d.getTime() - Date.now();
    const abs = Math.abs(diff);
    const rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });
    const units: [Intl.RelativeTimeFormatUnit, number][] = [
      ['year', 31536000000], ['month', 2592000000], ['week', 604800000],
      ['day', 86400000], ['hour', 3600000], ['minute', 60000], ['second', 1000],
    ];
    for (const [unit, ms] of units) {
      if (abs >= ms || unit === 'second') return rtf.format(Math.round(diff / ms), unit);
    }
    return 'now';
  }

  // day.js / moment-style token formatter. Literals wrap in [brackets].
  function customFormat(d: Date, z: Zoned, tz: string, pattern: string): string {
    const h12 = ((z.h + 11) % 12) + 1;
    const wd = new Date(Date.UTC(z.Y, z.Mo, z.D)).getUTCDay();
    const doy = Math.floor((Date.UTC(z.Y, z.Mo, z.D) - Date.UTC(z.Y, 0, 0)) / 86400000);
    const zoneAbbr = () => {
      try {
        const parts = new Intl.DateTimeFormat('en-US', { timeZone: tz, timeZoneName: 'short' }).formatToParts(d);
        return parts.find((p) => p.type === 'timeZoneName')?.value ?? '';
      } catch { return ''; }
    };
    const map: Record<string, string> = {
      YYYY: String(z.Y), YY: p2(z.Y % 100),
      MMMM: MON[z.Mo], MMM: MON[z.Mo].slice(0, 3), MM: p2(z.Mo + 1), M: String(z.Mo + 1),
      DDD: String(doy), Do: ordinal(z.D), DD: p2(z.D), D: String(z.D),
      dddd: DAYS[wd], ddd: DAYS[wd].slice(0, 3),
      HH: p2(z.h), H: String(z.h), hh: p2(h12), h: String(h12),
      mm: p2(z.mi), m: String(z.mi), ss: p2(z.s), s: String(z.s), SSS: p3(z.ms),
      A: z.h < 12 ? 'AM' : 'PM', a: z.h < 12 ? 'am' : 'pm',
      ZZ: offsetStr(z.offMin, false), Z: offsetStr(z.offMin), z: zoneAbbr(),
      X: String(Math.floor(d.getTime() / 1000)), x: String(d.getTime()),
    };
    // Longest tokens first; [literal] segments pass through verbatim.
    return pattern.replace(/\[([^\]]*)\]|YYYY|YY|MMMM|MMM|MM|M|DDD|Do|DD|D|dddd|ddd|HH|H|hh|h|mm|m|ss|s|SSS|A|a|ZZ|Z|z|X|x/g,
      (t, lit) => (lit !== undefined ? lit : map[t] ?? t));
  }

  function formats(d: Date, z: Zoned, tz: string): [string, string][] {
    const iso = `${z.Y}-${p2(z.Mo + 1)}-${p2(z.D)}T${p2(z.h)}:${p2(z.mi)}:${p2(z.s)}${z.offMin === 0 ? 'Z' : offsetStr(z.offMin)}`;
    const h12 = ((z.h + 11) % 12) + 1, ap = z.h < 12 ? 'AM' : 'PM';
    const wd = new Date(Date.UTC(z.Y, z.Mo, z.D)).getUTCDay();
    const [isoY, wk] = isoWeek(z.Y, z.Mo, z.D);
    const doy = Math.floor((Date.UTC(z.Y, z.Mo, z.D) - Date.UTC(z.Y, 0, 0)) / 86400000);
    const full = new Intl.DateTimeFormat('en-US', { timeZone: tz, dateStyle: 'full', timeStyle: 'long' }).format(d);
    return [
      ['ISO 8601', iso],
      ['ISO 8601 (UTC)', d.toISOString()],
      ['RFC 2822', d.toUTCString()],
      ['RFC 3339', iso],
      ['ISO date', `${z.Y}-${p2(z.Mo + 1)}-${p2(z.D)}`],
      ['US (MM/DD/YYYY)', `${p2(z.Mo + 1)}/${p2(z.D)}/${z.Y}`],
      ['European (DD/MM/YYYY)', `${p2(z.D)}/${p2(z.Mo + 1)}/${z.Y}`],
      ['Long', `${DAYS[wd]}, ${MON[z.Mo]} ${z.D}, ${z.Y}`],
      ['Short', `${MON[z.Mo].slice(0, 3)} ${z.D}, ${z.Y}`],
      ['Localized full', full],
      ['12-hour time', `${h12}:${p2(z.mi)}:${p2(z.s)} ${ap}`],
      ['24-hour time', `${p2(z.h)}:${p2(z.mi)}:${p2(z.s)}`],
      ['Day of week', DAYS[wd]],
      ['Day of year', String(doy)],
      ['ISO week', `${isoY}-W${p2(wk)}`],
      ['Quarter', `Q${Math.floor(z.Mo / 3) + 1} ${z.Y}`],
      ['UTC offset', z.offMin === 0 ? 'UTC±00:00' : `UTC${offsetStr(z.offMin)}`],
      ['Unix timestamp (s)', String(Math.floor(d.getTime() / 1000))],
      ['Unix timestamp (ms)', String(d.getTime())],
      ['Relative', relative(d)],
    ];
  }

  async function copyFrom(el: HTMLElement, text: string) {
    try {
      await navigator.clipboard.writeText(text);
      const old = el.textContent;
      el.textContent = 'Copied!';
      setTimeout(() => { if (el.textContent === 'Copied!') el.textContent = old; }, 1000);
    } catch 
  }

  function render() {
    const d = parse(input.value);
    if (!d) {
      out.innerHTML = ''; parsed.textContent = ''; fmtOut.textContent = '';
      err.classList.toggle('hidden', !input.value.trim());
      return;
    }
    err.classList.add('hidden');
    const tz = tzSel.value || LOCAL_TZ;
    const z = zoned(d, tz);
    parsed.textContent = `Parsed as: ${d.toString()}`;

    out.innerHTML = `<table class="w-full text-[13px]">${
      formats(d, z, tz).map(([label, val]) => `
        <tr class="df-row cursor-pointer border-t border-hairline transition-colors hover:bg-surface-2" data-copy="${val.replace(/"/g, '&quot;')}">
          <td class="px-3 py-2 text-ink-subtle">${label}</td>
          <td class="px-3 py-2 text-right font-mono text-ink">${val.replace(/</g, '&lt;')}</td>
        </tr>`).join('')
    }</table>`;
    out.querySelectorAll<HTMLElement>('.df-row').forEach((row) => {
      row.addEventListener('click', () => {
        const cell = row.querySelector('td:last-child') as HTMLElement;
        copyFrom(cell, row.dataset.copy!);
      });
    });

    renderCustom(d, z, tz);
  }

  function renderCustom(d: Date, z: Zoned, tz: string) {
    fmtOut.textContent = customFormat(d, z, tz, fmtIn.value);
  }

  input.addEventListener('input', render);
  tzSel.addEventListener('change', render);
  fmtIn.addEventListener('input', () => {
    const d = parse(input.value);
    if (d) renderCustom(d, zoned(d, tzSel.value || LOCAL_TZ), tzSel.value || LOCAL_TZ);
  });
  fmtOut.addEventListener('click', () => {
    if (fmtOut.textContent) copyFrom(fmtOut, fmtOut.textContent);
  });

  document.getElementById('df-now')!.addEventListener('click', () => {
    input.value = new Date().toISOString().slice(0, 19).replace('T', ' ');
    render();
  });

  populateZones();
  input.value = new Date().toISOString().slice(0, 19).replace('T', ' ');
  render();
</script>

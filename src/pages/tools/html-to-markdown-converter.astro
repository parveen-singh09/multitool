---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="html-to-markdown-converter">
  <div class="flex flex-col gap-4">

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Headings
        <select id="h2m-heading" class="field w-auto py-1">
          <option value="atx" selected>ATX (# Title)</option>
          <option value="setext">Setext (===)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Bullet
        <select id="h2m-bullet" class="field w-auto py-1">
          <option value="-" selected>- dash</option>
          <option value="*">* asterisk</option>
          <option value="+">+ plus</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Code blocks
        <select id="h2m-code" class="field w-auto py-1">
          <option value="fenced" selected>Fenced (```)</option>
          <option value="indented">Indented (4 spaces)</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Emphasis
        <select id="h2m-em" class="field w-auto py-1">
          <option value="*" selected>*italic* **bold**</option>
          <option value="_">_italic_ __bold__</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Links
        <select id="h2m-link" class="field w-auto py-1">
          <option value="inline" selected>Inline</option>
          <option value="referenced">Referenced</option>
        </select>
      </label>
    </div>

    <div class="flex flex-wrap items-center gap-4 text-[13px] text-ink-subtle">
      <label class="flex items-center gap-2"><input id="h2m-gfm" type="checkbox" checked /> GFM tables, strikethrough &amp; task lists</label>
      <label class="flex items-center gap-2"><input id="h2m-strip" type="checkbox" /> Strip HTML comments &amp; scripts</label>
    </div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>HTML input</span>
          <span class="flex gap-2">
            <button id="h2m-sample" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Sample</button>
            <button id="h2m-upload" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Upload</button>
            <button id="h2m-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
          </span>
        </span>
        <div id="h2m-drop" class="hl-edit field p-0" style="height:22rem;overflow:hidden">
          <pre class="hl-block" aria-hidden="true"><code id="h2m-in-hl" class="hljs" style="background:transparent"></code></pre>
          <textarea id="h2m-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" aria-label="HTML input"></textarea>
        </div>
        <input id="h2m-file" type="file" accept=".html,.htm,text/html,.txt" class="hidden" />
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>Markdown output</span>
          <span class="flex gap-2">
            <button id="h2m-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
          </span>
        </span>
        <div class="copy-wrap"><pre class="hl-block field" style="height:22rem;margin:0;overflow:auto;white-space:pre-wrap"><code id="h2m-out" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#h2m-out" aria-label="Copy"></button></div>
      </div>
    </div>

    <p id="h2m-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
    <p id="h2m-stats" class="text-[13px] text-ink-subtle" aria-live="polite"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free HTML to Markdown converter walks the HTML DOM with the browser's
      DOMParser and emits clean, portable Markdown. It handles headings,
      paragraphs, bold and italic, links and images, ordered and unordered
      (and nested) lists, inline code and fenced code blocks with language
      hints, blockquotes, line breaks and horizontal rules. Unknown tags fall
      back to their text content, and the output updates live as you type.
    </p>
    <p>
      Everything you can tune on the big desktop editors is here: choose ATX
      (<code>#</code>) or Setext (<code>===</code>) headings, pick your bullet
      marker (<code>-</code>, <code>*</code> or <code>+</code>), switch between
      fenced and 4-space indented code blocks, use <code>*</code> or
      <code>_</code> for emphasis, and emit inline or referenced links. Turn on
      GitHub Flavored Markdown to convert HTML tables into pipe tables,
      <code>&lt;del&gt;</code>/<code>&lt;s&gt;</code> into <code>~~strikethrough~~</code>,
      and checkbox list items into <code>- [ ]</code> task lists.
    </p>
    <p>
      Load the sample to see it in action, upload or drag-and-drop an
      <code>.html</code> file, then copy the Markdown or download it as a
      <code>.md</code> file. A live character, word and line count sits under
      the output, and parse problems surface as a clear error message.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl, wireInput } from '../../lib/highlight';

  const inEl = document.getElementById('h2m-in') as HTMLTextAreaElement;
  const inHlEl = document.getElementById('h2m-in-hl')!;
  const outEl = document.getElementById('h2m-out')!;
  const errEl = document.getElementById('h2m-error')!;
  const statsEl = document.getElementById('h2m-stats')!;
  const headingSel = document.getElementById('h2m-heading') as HTMLSelectElement;
  const bulletSel = document.getElementById('h2m-bullet') as HTMLSelectElement;
  const codeSel = document.getElementById('h2m-code') as HTMLSelectElement;
  const emSel = document.getElementById('h2m-em') as HTMLSelectElement;
  const linkSel = document.getElementById('h2m-link') as HTMLSelectElement;
  const gfmChk = document.getElementById('h2m-gfm') as HTMLInputElement;
  const stripChk = document.getElementById('h2m-strip') as HTMLInputElement;
  const fileEl = document.getElementById('h2m-file') as HTMLInputElement;
  const dropEl = document.getElementById('h2m-drop')!;

  interface Opts {
    heading: string; bullet: string; code: string;
    emChar: string; link: string; gfm: boolean; strip: boolean;
  }

  let refs: { text: string; url: string }[] = [];
  let markdown = '';

  function readOpts(): Opts {
    return {
      heading: headingSel.value, bullet: bulletSel.value, code: codeSel.value,
      emChar: emSel.value, link: linkSel.value,
      gfm: gfmChk.checked, strip: stripChk.checked,
    };
  }

  function childrenToMd(node: Node, depth: number, o: Opts): string {
    let out = '';
    node.childNodes.forEach((c) => { out += nodeToMd(c, depth, o); });
    return out;
  }

  function inlineText(el: Element, o: Opts): string {
    return childrenToMd(el, 0, o).replace(/\s*\n\s*/g, ' ').trim();
  }

  function tableToMd(el: Element, o: Opts): string {
    const rows = Array.from(el.querySelectorAll('tr'));
    if (!rows.length) return childrenToMd(el, 0, o);
    const cellsOf = (tr: Element) =>
      Array.from(tr.children)
        .filter((c) => /^(td|th)$/i.test(c.tagName))
        .map((c) => inlineText(c, o).replace(/\|/g, '\\|').replace(/\n/g, ' ') || ' ');

    let headerIdx = rows.findIndex((r) => r.querySelector('th'));
    if (headerIdx < 0) headerIdx = 0;
    const header = cellsOf(rows[headerIdx]);
    const width = header.length;
    const sep = header.map(() => '---');
    const bodyRows = rows.filter((_, i) => i !== headerIdx).map((r) => {
      const cells = cellsOf(r);
      while (cells.length < width) cells.push(' ');
      return `| ${cells.slice(0, width).join(' | ')} |`;
    });
    const lines = [`| ${header.join(' | ')} |`, `| ${sep.join(' | ')} |`, ...bodyRows];
    return `\n\n${lines.join('\n')}\n\n`;
  }

  function nodeToMd(node: Node, depth: number, o: Opts): string {
    if (node.nodeType === Node.TEXT_NODE) return (node.nodeValue ?? '').replace(/\s+/g, ' ');
    if (node.nodeType !== Node.ELEMENT_NODE) return '';

    const el = node as Element;
    const tag = el.tagName.toLowerCase();
    const inner = () => childrenToMd(el, depth, o).trim();
    const bold = o.emChar === '_' ? '__' : '**';
    const italic = o.emChar;

    switch (tag) {
      case 'h1': case 'h2': case 'h3':
      case 'h4': case 'h5': case 'h6': {
        const level = Number(tag[1]);
        const text = inner();
        if (o.heading === 'setext' && level <= 2) {
          const rule = (level === 1 ? '=' : '-').repeat(Math.max(3, text.length));
          return `\n\n${text}\n${rule}\n\n`;
        }
        return `\n\n${'#'.repeat(level)} ${text}\n\n`;
      }
      case 'p':
        return `\n\n${childrenToMd(el, depth, o).trim()}\n\n`;
      case 'br':
        return '  \n';
      case 'hr':
        return '\n\n---\n\n';
      case 'strong': case 'b': {
        const t = inner();
        return t ? `${bold}${t}${bold}` : '';
      }
      case 'em': case 'i': {
        const t = inner();
        return t ? `${italic}${t}${italic}` : '';
      }
      case 'del': case 's': case 'strike': {
        if (!o.gfm) return inner();
        const t = inner();
        return t ? `~~${t}~~` : '';
      }
      case 'code':
        return `\`${el.textContent ?? ''}\``;
      case 'pre': {
        const codeEl = el.querySelector('code');
        const text = ((codeEl ?? el).textContent ?? '').replace(/\n$/, '');
        if (o.code === 'indented') {
          const indented = text.split('\n').map((l) => `    ${l}`).join('\n');
          return `\n\n${indented}\n\n`;
        }
        // Detect a language hint from a `language-xxx` / `lang-xxx` class.
        const cls = codeEl?.getAttribute('class') ?? '';
        const langMatch = cls.match(/(?:language|lang)-(\w+)/);
        const lang = langMatch ? langMatch[1] : '';
        return `\n\n\`\`\`${lang}\n${text}\n\`\`\`\n\n`;
      }
      case 'blockquote': {
        const body = childrenToMd(el, depth, o).trim();
        const quoted = body.split('\n').map((l) => `> ${l}`.replace(/\s+$/, '')).join('\n');
        return `\n\n${quoted}\n\n`;
      }
      case 'a': {
        const href = el.getAttribute('href') ?? '';
        const title = el.getAttribute('title');
        const text = inner();
        if (!href) return text;
        if (o.link === 'referenced') {
          refs.push({ text, url: href + (title ? ` "${title}"` : '') });
          return `[${text}][${refs.length}]`;
        }
        return `[${text}](${href}${title ? ` "${title}"` : ''})`;
      }
      case 'img': {
        const src = el.getAttribute('src') ?? '';
        const alt = el.getAttribute('alt') ?? '';
        const title = el.getAttribute('title');
        return `![${alt}](${src}${title ? ` "${title}"` : ''})`;
      }
      case 'table':
        return o.gfm ? tableToMd(el, o) : childrenToMd(el, depth, o);
      case 'ul': case 'ol': {
        const ordered = tag === 'ol';
        const startAttr = Number(el.getAttribute('start') ?? '1');
        const start = Number.isFinite(startAttr) ? startAttr : 1;
        const items = Array.from(el.children).filter((c) => c.tagName.toLowerCase() === 'li');
        const indent = '  '.repeat(depth);
        const rendered = items.map((li, idx) => {

          const box = li.querySelector(':scope > input[type=checkbox], :scope > p > input[type=checkbox]');
          let marker = ordered ? `${start + idx}.` : o.bullet;
          if (o.gfm && box) marker = `${o.bullet} [${(box as HTMLInputElement).checked || box.hasAttribute('checked') ? 'x' : ' '}]`;
          // Content, with nested blocks indented under the marker.
          const raw = childrenToMd(li, depth + 1, o).trim().replace(/\n{2,}/g, '\n');
          const contIndent = ' '.repeat(marker.length + 1);
          const content = raw.split('\n').map((l, i) => (i === 0 ? l : contIndent + l)).join('\n');
          return `${indent}${marker} ${content}`;
        }).join('\n');
        return `\n\n${rendered}\n\n`;
      }
      case 'li':
        return inner();
      case 'script': case 'style': case 'noscript':
        return '';
      default:
        return childrenToMd(el, depth, o);
    }
  }

  function convert() {
    errEl.classList.add('hidden');
    const src = inEl.value;
    if (!src.trim()) { markdown = ''; render(); return; }
    try {
      const o = readOpts();
      refs = [];
      const doc = new DOMParser().parseFromString(src, 'text/html');
      if (o.strip) {
        doc.querySelectorAll('script, style, noscript').forEach((n) => n.remove());
        const walker = doc.createTreeWalker(doc.body, NodeFilter.SHOW_COMMENT);
        const toRemove: Node[] = [];
        while (walker.nextNode()) toRemove.push(walker.currentNode);
        toRemove.forEach((n) => n.parentNode?.removeChild(n));
      }
      let md = childrenToMd(doc.body, 0, o);
      md = md.replace(/[ \t]+\n/g, '\n').replace(/\n{3,}/g, '\n\n').trim();
      if (o.link === 'referenced' && refs.length) {
        md += '\n\n' + refs.map((r, i) => `[${i + 1}]: ${r.url}`).join('\n');
      }
      markdown = md;
    } catch (e) {
      markdown = '';
      errEl.textContent = `Conversion failed: ${(e as Error).message}`;
      errEl.classList.remove('hidden');
    }
    render();
  }

  async function render() {
    await hl(outEl, markdown, 'markdown');
    const chars = markdown.length;
    const words = markdown.trim() ? markdown.trim().split(/\s+/).length : 0;
    const lines = markdown ? markdown.split('\n').length : 0;
    statsEl.textContent = `${chars} chars · ${words} words · ${lines} lines`;
  }

  const rerender = wireInput(inEl, inHlEl, () => 'xml', convert);

  [headingSel, bulletSel, codeSel, emSel, linkSel].forEach((s) => s.addEventListener('change', convert));
  [gfmChk, stripChk].forEach((c) => c.addEventListener('change', convert));

  document.getElementById('h2m-clear')!.addEventListener('click', () => {
    inEl.value = ''; markdown = ''; errEl.classList.add('hidden');
    rerender(); render();
  });

  const SAMPLE = `<h1>Toolsilk</h1>
<p>A set of <strong>fast</strong>, <em>private</em> converters that run
<a href="https://example.com" title="home">in your browser</a>.</p>
<h2>Features</h2>
<ul>
  <li>Live preview
    <ul><li>with nesting</li></ul>
  </li>
  <li><del>Slow</del> instant</li>
</ul>
<h2>Roadmap</h2>
<ul>
  <li><input type="checkbox" checked> Tables</li>
  <li><input type="checkbox"> More formats</li>
</ul>
<table>
  <thead><tr><th>Tool</th><th>Status</th></tr></thead>
  <tbody>
    <tr><td>HTML → Markdown</td><td>Ready</td></tr>
    <tr><td>JSON → XML</td><td>Ready</td></tr>
  </tbody>
</table>
<pre><code class="language-js">console.log('hi');</code></pre>
<blockquote>Built for people who live in their editor.</blockquote>`;

  document.getElementById('h2m-sample')!.addEventListener('click', () => {
    inEl.value = SAMPLE; rerender(); convert();
  });

  // File upload + drag-and-drop.
  function loadFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => { inEl.value = String(reader.result ?? ''); rerender(); convert(); };
    reader.onerror = () => {
      errEl.textContent = 'Could not read that file.';
      errEl.classList.remove('hidden');
    };
    reader.readAsText(file);
  }
  document.getElementById('h2m-upload')!.addEventListener('click', () => fileEl.click());
  fileEl.addEventListener('change', () => { if (fileEl.files?.[0]) loadFile(fileEl.files[0]); });
  ['dragover', 'dragenter'].forEach((ev) =>
    dropEl.addEventListener(ev, (e) => { e.preventDefault(); dropEl.classList.add('ring-1'); }));
  ['dragleave', 'drop'].forEach((ev) =>
    dropEl.addEventListener(ev, () => dropEl.classList.remove('ring-1')));
  dropEl.addEventListener('drop', (e) => {
    e.preventDefault();
    const f = (e as DragEvent).dataTransfer?.files?.[0];
    if (f) loadFile(f);
  });

  document.getElementById('h2m-copy')!.addEventListener('click', async (e) => {
    if (!markdown) return;
    await navigator.clipboard.writeText(markdown);
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });

  document.getElementById('h2m-download')!.addEventListener('click', () => {
    if (!markdown) return;
    const blob = new Blob([markdown], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'converted.md';
    a.click();
    URL.revokeObjectURL(url);
  });

  convert();
</script>

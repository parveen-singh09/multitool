---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="thumbnail-generator">
  <div class="flex flex-col gap-4">
    <label id="th-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an image or drop it here</span>
      <span class="text-[13px] text-ink-tertiary">Resized in your browser — never uploaded</span>
      <input id="th-file" type="file" accept="image/*" class="sr-only" />
    </label>

    <div id="th-panel" class="hidden flex-col gap-4">
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Width
          <input id="th-w" type="number" min="16" max="2000" value="300" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height
          <input id="th-h" type="number" min="16" max="2000" value="300" class="field" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Fit
          <select id="th-fit" class="field"><option value="cover">Cover (crop)</option><option value="contain">Contain (fit)</option></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Format
          <select id="th-fmt" class="field"><option value="image/png">PNG</option><option value="image/jpeg">JPG</option></select>
        </label>
      </div>
      <div class="flex justify-center rounded-[12px] border border-hairline bg-surface-2 p-4">
        <canvas id="th-canvas" class="max-w-full"></canvas>
      </div>
      <button id="th-dl" class="btn btn-primary w-fit">Download thumbnail</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free thumbnail generator crops and resizes any image to the exact
      dimensions you need. Choose cover to fill the frame and crop the overflow, or
      contain to fit the whole image inside with padding. Download the result as
      PNG or JPG. Your image is resized on a canvas in your browser and never
      uploaded.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('th-file') as HTMLInputElement;
  const drop = $('th-drop')!;
  const panel = $('th-panel')!;
  const canvas = $('th-canvas') as HTMLCanvasElement;
  let img: HTMLImageElement | null = null;

  function render() {
    if (!img) return;
    const w = Math.max(16, Math.min(2000, Number(($('th-w') as HTMLInputElement).value) || 300));
    const h = Math.max(16, Math.min(2000, Number(($('th-h') as HTMLInputElement).value) || 300));
    const fit = ($('th-fit') as HTMLSelectElement).value;
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d')!;
    ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, w, h);
    const ir = img.naturalWidth / img.naturalHeight;
    const cr = w / h;
    let dw = w, dh = h, dx = 0, dy = 0;
    if (fit === 'cover') {
      let sx = 0, sy = 0, sw = img.naturalWidth, sh = img.naturalHeight;
      if (ir > cr) { sw = img.naturalHeight * cr; sx = (img.naturalWidth - sw) / 2; }
      else { sh = img.naturalWidth / cr; sy = (img.naturalHeight - sh) / 2; }
      ctx.drawImage(img, sx, sy, sw, sh, 0, 0, w, h);
    } else {
      if (ir > cr) { dh = w / ir; dy = (h - dh) / 2; } else { dw = h * ir; dx = (w - dw) / 2; }
      ctx.drawImage(img, dx, dy, dw, dh);
    }
  }

  function load(file: File) {
    const url = URL.createObjectURL(file);
    const im = new Image();
    im.onload = () => { img = im; panel.classList.remove('hidden'); panel.classList.add('flex'); render(); URL.revokeObjectURL(url); };
    im.src = url;
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) load(fileInput.files[0]); });
  ['th-w', 'th-h', 'th-fit'].forEach((id) => $(id).addEventListener('input', render));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) load(f); });
  $('th-dl').addEventListener('click', () => {
    const fmt = ($('th-fmt') as HTMLSelectElement).value;
    const a = document.createElement('a');
    a.href = canvas.toDataURL(fmt, 0.92);
    a.download = `thumbnail.${fmt === 'image/jpeg' ? 'jpg' : 'png'}`;
    a.click();
  });
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="uuid-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        How many
        <input id="uu-count" type="number" min="1" max="1000" value="5" class="field w-28" />
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input type="checkbox" id="uu-upper" class="accent-[#5e6ad2]" /> Uppercase
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input type="checkbox" id="uu-braces" class="accent-[#5e6ad2]" /> Wrap in { }
      </label>
      <button id="uu-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="uu-copy" class="btn btn-secondary">Copy all</button>
    </div>

    <textarea id="uu-out" class="field min-h-64 resize-y font-mono text-[13px]" readonly aria-label="Generated UUIDs"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free UUID generator creates random version-4 UUIDs (also called
      GUIDs) that follow the RFC 4122 standard. Generate a single identifier or
      up to a thousand at once, with optional uppercase or curly-brace
      formatting. UUIDs are created with your browser's secure
      <code class="font-mono text-ink">crypto</code> API — nothing is sent to a server.
    </p>
  </div>
</ToolLayout>

<script>
  const countEl = document.getElementById('uu-count') as HTMLInputElement;
  const upper = document.getElementById('uu-upper') as HTMLInputElement;
  const braces = document.getElementById('uu-braces') as HTMLInputElement;
  const out = document.getElementById('uu-out') as HTMLTextAreaElement;

  function uuid(): string {
    if (crypto.randomUUID) return crypto.randomUUID();
    // Fallback for older browsers.
    const b = crypto.getRandomValues(new Uint8Array(16));
    b[6] = (b[6] & 0x0f) | 0x40;
    b[8] = (b[8] & 0x3f) | 0x80;
    const h = [...b].map((x) => x.toString(16).padStart(2, '0'));
    return `${h[0]}${h[1]}${h[2]}${h[3]}-${h[4]}${h[5]}-${h[6]}${h[7]}-${h[8]}${h[9]}-${h[10]}${h[11]}${h[12]}${h[13]}${h[14]}${h[15]}`;
  }

  function generate() {
    const n = Math.max(1, Math.min(1000, Number(countEl.value) || 1));
    const list: string[] = [];
    for (let i = 0; i < n; i++) {
      let id = uuid();
      if (upper.checked) id = id.toUpperCase();
      if (braces.checked) id = `{${id}}`;
      list.push(id);
    }
    out.value = list.join('\n');
  }

  document.getElementById('uu-gen')!.addEventListener('click', generate);
  [upper, braces].forEach((el) => el.addEventListener('change', generate));
  document.getElementById('uu-copy')!.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

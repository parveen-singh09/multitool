---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="lottery-number-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Game
      <select id="lt-game" class="field">
        <option value="5,69,1,26">Powerball (5 of 69 + 1 of 26)</option>
        <option value="5,70,1,25">Mega Millions (5 of 70 + 1 of 25)</option>
        <option value="5,50,2,12">EuroMillions (5 of 50 + 2 of 12)</option>
        <option value="6,49,0,0">Lotto 6/49 (6 of 49)</option>
        <option value="custom">Custom</option>
      </select>
    </label>
    <div id="lt-custom" class="hidden grid-cols-2 gap-3 sm:grid-cols-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Main count
        <input id="lt-mc" type="number" min="1" max="20" value="6" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Main max
        <input id="lt-mm" type="number" min="2" max="99" value="49" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bonus count
        <input id="lt-bc" type="number" min="0" max="5" value="0" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Bonus max
        <input id="lt-bm" type="number" min="0" max="99" value="0" class="field" />
      </label>
    </div>
    <div class="flex flex-wrap items-center gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Lines
        <input id="lt-lines" type="number" min="1" max="20" value="1" class="field w-24" />
      </label>
      <button id="lt-gen" class="btn btn-primary ml-auto">Generate</button>
    </div>
    <div id="lt-out" class="flex flex-col gap-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free lottery number generator produces random number picks for popular
      games — Powerball, Mega Millions, EuroMillions and Lotto 6/49 — or a custom
      game you define, including bonus balls. Main numbers are drawn without
      repeats, just like a real draw, using your browser's secure random source.
      For entertainment only. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { sample, randInt } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const gameEl = $('lt-game') as HTMLSelectElement;
  const out = $('lt-out')!;

  gameEl.addEventListener('change', () => {
    const custom = gameEl.value === 'custom';
    $('lt-custom').classList.toggle('hidden', !custom);
    $('lt-custom').classList.toggle('grid', custom);
    generate();
  });

  function config() {
    if (gameEl.value === 'custom') {
      return {
        mc: Number(($('lt-mc') as HTMLInputElement).value),
        mm: Number(($('lt-mm') as HTMLInputElement).value),
        bc: Number(($('lt-bc') as HTMLInputElement).value),
        bm: Number(($('lt-bm') as HTMLInputElement).value),
      };
    }
    const [mc, mm, bc, bm] = gameEl.value.split(',').map(Number);
    return { mc, mm, bc, bm };
  }

  function ball(n: number, bonus = false): string {
    return `<span class="flex h-11 w-11 items-center justify-center rounded-full font-mono text-[15px] font-semibold ${bonus ? 'bg-[#5e6ad2] text-white' : 'border border-hairline bg-surface-2 text-ink'}">${n}</span>`;
  }

  function line(): string {
    const { mc, mm, bc, bm } = config();
    const pool = Array.from({ length: mm }, (_, i) => i + 1);
    const main = sample(pool, mc).sort((a, b) => a - b);
    let html = main.map((n) => ball(n)).join('');
    if (bc > 0 && bm > 0) {
      const bpool = Array.from({ length: bm }, (_, i) => i + 1);
      const bonus = sample(bpool, bc).sort((a, b) => a - b);
      html += '<span class="mx-1 self-center text-ink-tertiary">+</span>' + bonus.map((n) => ball(n, true)).join('');
    }
    return `<div class="flex flex-wrap gap-2">${html}</div>`;
  }

  function generate() {
    const lines = Math.max(1, Math.min(20, Number(($('lt-lines') as HTMLInputElement).value) || 1));
    const rows: string[] = [];
    for (let i = 0; i < lines; i++) rows.push(line());
    out.innerHTML = rows.join('');
  }

  ['lt-lines', 'lt-mc', 'lt-mm', 'lt-bc', 'lt-bm'].forEach((id) => $(id).addEventListener('input', generate));
  $('lt-gen').addEventListener('click', generate);
  generate();
</script>

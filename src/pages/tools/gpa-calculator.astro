---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="gpa-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex items-center gap-3 text-[13px] text-ink-subtle">
      <span class="flex-1">Course</span>
      <span class="w-28 text-center">Grade</span>
      <span class="w-24 text-center">Credits</span>
      <span class="w-9"></span>
    </div>

    <div id="gpa-rows" class="flex flex-col gap-2"></div>

    <div class="flex gap-2">
      <button id="gpa-add" class="btn btn-secondary">+ Add course</button>
    </div>

    <div class="panel panel-lift p-6 text-center">
      <div id="gpa-value" class="font-display text-4xl font-semibold text-primary-hover">—</div>
      <div id="gpa-sub" class="mt-2 text-[13px] text-ink-subtle"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free GPA calculator computes your grade point average on a 4.0 scale,
      weighted by the credit hours of each course. Add a row per class, choose
      the letter grade and enter its credits, and your GPA updates instantly. Add
      or remove courses as needed. All calculations run in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const GRADES: Record<string, number> = {
    'A+': 4.0, 'A': 4.0, 'A-': 3.7,
    'B+': 3.3, 'B': 3.0, 'B-': 2.7,
    'C+': 2.3, 'C': 2.0, 'C-': 1.7,
    'D+': 1.3, 'D': 1.0, 'F': 0.0,
  };

  const rowsEl = document.getElementById('gpa-rows')!;

  function makeRow(name = '', grade = 'A', credits = '3') {
    const row = document.createElement('div');
    row.className = 'gpa-row flex items-center gap-3';
    const options = Object.keys(GRADES).map((g) => `<option value="${g}"${g === grade ? ' selected' : ''}>${g}</option>`).join('');
    row.innerHTML = `
      <input type="text" class="field flex-1" placeholder="Course name (optional)" value="${name}" />
      <select class="field w-28 gpa-grade">${options}</select>
      <input type="number" min="0" step="0.5" class="field w-24 gpa-credit" value="${credits}" inputmode="decimal" />
      <button type="button" class="btn btn-secondary w-9 gpa-del" aria-label="Remove course">×</button>
    `;
    rowsEl.appendChild(row);
    row.querySelector('.gpa-del')!.addEventListener('click', () => { row.remove(); calc(); });
    row.querySelectorAll('select, input').forEach((el) => el.addEventListener('input', calc));
  }

  function calc() {
    let points = 0, credits = 0;
    document.querySelectorAll('.gpa-row').forEach((row) => {
      const grade = (row.querySelector('.gpa-grade') as HTMLSelectElement).value;
      const cr = Number((row.querySelector('.gpa-credit') as HTMLInputElement).value) || 0;
      points += GRADES[grade] * cr;
      credits += cr;
    });
    const valEl = document.getElementById('gpa-value')!;
    const subEl = document.getElementById('gpa-sub')!;
    if (credits === 0) { valEl.textContent = '—'; subEl.textContent = ''; return; }
    valEl.textContent = (points / credits).toFixed(2);
    subEl.textContent = `${credits} credit hours across ${document.querySelectorAll('.gpa-row').length} courses`;
  }

  document.getElementById('gpa-add')!.addEventListener('click', () => { makeRow(); calc(); });

  // Seed with three example rows.
  makeRow('', 'A', '3');
  makeRow('', 'B+', '4');
  makeRow('', 'A-', '3');
  calc();
</script>

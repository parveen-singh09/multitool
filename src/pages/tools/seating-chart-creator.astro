---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="seating-chart-creator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Event title
        <input id="scc-title" class="field" type="text" value="Wedding Reception" />
      </label>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Guests (one per line)
        <textarea id="scc-guests" class="field min-h-48 resize-y font-mono text-[13px]" spellcheck="false">Alice
Ben
Carla
David
Emma
Frank
Grace
Henry
Isla
Jack
Kira
Liam</textarea>
      </label>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Number of tables
          <input id="scc-tables" class="field" type="number" min="1" max="30" value="3" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Seats per table
          <input id="scc-seats" class="field" type="number" min="1" max="20" value="4" />
        </label>
      </div>

      <div class="flex gap-2">
        <button id="scc-png" class="btn btn-primary">Download PNG</button>
      </div>
      <p id="scc-note" class="hidden text-[13px] text-ink-subtle" role="status"></p>
    </div>

    <div class="flex flex-col gap-2">
      <span class="text-sm text-ink-subtle">Preview</span>
      <div class="panel p-4 overflow-auto">
        <canvas id="scc-canvas" class="max-w-full h-auto rounded-[8px]" aria-label="Seating chart preview"></canvas>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free seating chart creator distributes a guest list across round
      tables and draws each table with its guests' names, ready to download as a
      PNG. Set how many tables and seats per table you need and guests are shared
      out evenly. It is perfect for weddings, banquets, classrooms and events.
      Everything runs in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const titleEl = document.getElementById('scc-title') as HTMLInputElement;
  const guestsEl = document.getElementById('scc-guests') as HTMLTextAreaElement;
  const tablesEl = document.getElementById('scc-tables') as HTMLInputElement;
  const seatsEl = document.getElementById('scc-seats') as HTMLInputElement;
  const noteEl = document.getElementById('scc-note') as HTMLParagraphElement;
  const canvas = document.getElementById('scc-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function guests(): string[] {
    return guestsEl.value.split('\n').map((s) => s.trim()).filter((s) => s !== '');
  }

  function distribute(): string[][] {
    const list = guests();
    const nTables = Math.max(1, Math.min(30, Number(tablesEl.value) || 1));
    const cap = Math.max(1, Math.min(20, Number(seatsEl.value) || 1));
    const tables: string[][] = Array.from({ length: nTables }, () => []);

    let overflow = 0;
    list.forEach((g, i) => {
      // Round-robin placement keeps tables balanced; fall back to any table with room.
      const idx = i % nTables;
      if (tables[idx].length < cap) {
        tables[idx].push(g);
        return;
      }
      const free = tables.find((t) => t.length < cap);
      if (free) free.push(g);
      else overflow++;
    });

    if (overflow > 0) {
      noteEl.textContent = `${overflow} guest(s) could not be seated — add tables or seats.`;
      noteEl.classList.remove('hidden');
    } else {
      noteEl.classList.add('hidden');
    }
    return tables;
  }

  function draw(): void {
    const tables = distribute();
    const scale = 2;
    const cols = Math.min(tables.length, 3);
    const rows = Math.ceil(tables.length / cols);
    const cellW = 220;
    const cellH = 220;
    const padTop = 80;
    const padSide = 20;
    const width = padSide * 2 + cols * cellW;
    const height = padTop + rows * cellH + 20;

    canvas.width = width * scale;
    canvas.height = height * scale;
    canvas.style.width = width + 'px';
    ctx.setTransform(scale, 0, 0, scale, 0, 0);

    ctx.fillStyle = '#0f1011';
    ctx.fillRect(0, 0, width, height);

    ctx.fillStyle = '#f7f8f8';
    ctx.font = '600 24px Inter, system-ui, sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'alphabetic';
    ctx.fillText(titleEl.value || 'Seating Chart', padSide, 50);

    tables.forEach((seats, i) => {
      const col = i % cols;
      const row = Math.floor(i / cols);
      const cx = padSide + col * cellW + cellW / 2;
      const cy = padTop + row * cellH + cellH / 2;
      const radius = 52;

      // table circle
      ctx.beginPath();
      ctx.arc(cx, cy, radius, 0, Math.PI * 2);
      ctx.fillStyle = '#141516';
      ctx.fill();
      ctx.lineWidth = 2;
      ctx.strokeStyle = '#5e6ad2';
      ctx.stroke();

      ctx.fillStyle = '#828fff';
      ctx.font = '600 13px Inter, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(`Table ${i + 1}`, cx, cy - 8);
      ctx.fillStyle = '#8a8f98';
      ctx.font = '11px Inter, system-ui, sans-serif';
      ctx.fillText(`${seats.length} guest${seats.length === 1 ? '' : 's'}`, cx, cy + 10);

      // guest name chips around the circle
      const n = seats.length;
      ctx.font = '11px Inter, system-ui, sans-serif';
      seats.forEach((name, si) => {
        const angle = (si / Math.max(n, 1)) * Math.PI * 2 - Math.PI / 2;
        const gx = cx + Math.cos(angle) * (radius + 30);
        const gy = cy + Math.sin(angle) * (radius + 30);

        let label = name;
        while (ctx.measureText(label).width > 70 && label.length > 1) {
          label = label.slice(0, -2) + '…';
        }
        const tw = ctx.measureText(label).width;

        ctx.fillStyle = '#18191a';
        ctx.strokeStyle = '#34343a';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.roundRect(gx - tw / 2 - 6, gy - 9, tw + 12, 18, 6);
        ctx.fill();
        ctx.stroke();

        ctx.fillStyle = '#f7f8f8';
        ctx.fillText(label, gx, gy);
      });
    });
  }

  [titleEl, guestsEl, tablesEl, seatsEl].forEach((el) => el.addEventListener('input', draw));

  document.getElementById('scc-png')!.addEventListener('click', () => {
    const link = document.createElement('a');
    link.download = 'toolcities-seating-chart.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  });

  draw();
</script>

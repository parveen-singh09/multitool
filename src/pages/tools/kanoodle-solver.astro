---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="kanoodle-solver">
  <div class="flex flex-col gap-6">
    <p class="text-[13px] leading-relaxed text-ink-subtle">
      Recreate your puzzle: click a piece to select it, use its own
      <span class="text-ink">Rotate</span> and <span class="text-ink">Flip</span> buttons to orient
      it, then click an empty hole to drop it in. Click a placed piece to lift it back off. Then hit
      <span class="text-ink">Solve</span> and the remaining pieces snap into the empty holes.
    </p>

    <!-- Board -->
    <div class="flex justify-center">
      <div
        id="kn-board"
        class="inline-grid gap-1 rounded-lg border border-hairline bg-surface-1 p-2 select-none"
        aria-label="Kanoodle board, 5 rows by 11 columns"
      ></div>
    </div>

    <!-- Piece tray -->
    <div class="flex flex-col gap-3">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-ink-tertiary">Pieces</h2>
      <div
        id="kn-tray"
        class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"
        role="listbox"
        aria-label="Available pieces"
      ></div>
    </div>

    <!-- Action row -->
    <div class="flex flex-wrap items-center justify-center gap-2">
      <button id="kn-solvable" class="btn btn-secondary">Solvable?</button>
      <button id="kn-hint" class="btn btn-secondary">Hint</button>
      <button id="kn-solve" class="btn btn-primary">Solve</button>
      <button id="kn-random" class="btn btn-secondary">Random Game</button>
      <button id="kn-reset" class="btn btn-secondary">Reset</button>
    </div>

    <p id="kn-status" class="min-h-6 text-center text-lg font-semibold text-ink" aria-live="polite"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free <strong class="text-ink-muted">Kanoodle solver and player</strong> works the flat
      5×11 Kanoodle board — the 55-hole grid the 2D challenges are built on. Rebuild the puzzle you're
      stuck on by placing its starting pieces, then let the solver finish it. It runs the same
      exact-cover backtracking search the game is designed around: it tries every rotation and
      reflection of each remaining piece, fills the first open hole, and backtracks the moment a piece
      can't fit — so it finds a complete tiling fast when one exists.
    </p>
    <p>
      All twelve pieces are here in their real shapes and colors, from the little corner triangle to
      the plus, the W, the Y and the long I. Each piece has its own
      <strong class="text-ink-muted">Rotate</strong> and <strong class="text-ink-muted">Flip</strong>
      controls — orient it to match your board, then click to drop it in.
      <strong class="text-ink-muted">Solve</strong> completes the board,
      <strong class="text-ink-muted">Hint</strong> places just one more piece to nudge you forward,
      <strong class="text-ink-muted">Solvable?</strong> checks whether your current layout can still be
      finished, and <strong class="text-ink-muted">Random Game</strong> deals a fresh set of clues to
      play from. Everything runs entirely in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import {
    PIECES,
    PIECE_BY_ID,
    transformCells,
    emptyBoard,
    cloneBoard,
    solve,
    hint,
    ROWS,
    COLS,
    type Board,
    type Cell,
  } from '../../lib/kanoodle';

  const CELL = 34; // px board hole
  const boardEl = document.getElementById('kn-board')!;
  const trayEl = document.getElementById('kn-tray')!;
  const statusEl = document.getElementById('kn-status')!;

  boardEl.style.gridTemplateColumns = `repeat(${COLS}, ${CELL}px)`;

  let board: Board = emptyBoard();

  // Per-piece orientation, driven by each card's own Rotate/Flip buttons.
  const pose: Record<string, { rot: number; flip: boolean }> = Object.fromEntries(
    PIECES.map((p) => [p.id, { rot: 0, flip: false }]),
  );

  let selectedId: string | null = null;
  let hoverAnchor: Cell | null = null;

  const posedCells = (id: string): Cell[] =>
    transformCells(PIECE_BY_ID[id].cells, pose[id].rot, pose[id].flip);

  function pieceOnBoard(id: string): boolean {
    for (const row of board) for (const v of row) if (v === id) return true;
    return false;
  }

  // ── Board rendering ────────────────────────────────────────────
  function renderBoard() {
    boardEl.innerHTML = '';
    const preview = computePreview();
    const previewSet = new Set(preview.cells.map(([r, c]) => `${r},${c}`));

    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const v = board[r][c];
        const cell = document.createElement('button');
        cell.type = 'button';
        cell.className = 'kn-cell rounded-full border border-hairline transition-colors';
        cell.style.width = `${CELL}px`;
        cell.style.height = `${CELL}px`;
        cell.dataset.r = String(r);
        cell.dataset.c = String(c);

        if (v) {
          const p = PIECE_BY_ID[v];
          cell.style.background = p.color;
          cell.style.borderColor = 'rgba(0,0,0,0.35)';
          cell.title = `${p.name} — click to remove`;
          cell.setAttribute('aria-label', `${p.name} piece at row ${r + 1}, column ${c + 1}`);
        } else {
          cell.style.background = '#3a3a40';
          cell.setAttribute('aria-label', `Empty hole at row ${r + 1}, column ${c + 1}`);
        }

        if (previewSet.has(`${r},${c}`)) {
          const p = PIECE_BY_ID[selectedId!];
          cell.style.background = preview.valid ? p.color : '#3a1518';
          cell.style.opacity = preview.valid ? '0.55' : '0.85';
          cell.style.borderColor = preview.valid ? p.color : '#B90006';
        }

        cell.addEventListener('click', () => onCellClick(r, c));
        cell.addEventListener('mouseenter', () => onCellHover(r, c));
        boardEl.appendChild(cell);
      }
    }
  }

  function computePreview(): { cells: Cell[]; valid: boolean } {
    if (!selectedId || !hoverAnchor || pieceOnBoard(selectedId)) return { cells: [], valid: false };
    const orient = posedCells(selectedId);
    const [ar, ac] = orient[0];
    const [hr, hc] = hoverAnchor;
    const cells: Cell[] = [];
    let valid = true;
    for (const [pr, pc] of orient) {
      const gr = hr + (pr - ar);
      const gc = hc + (pc - ac);
      cells.push([gr, gc]);
      if (gr < 0 || gr >= ROWS || gc < 0 || gc >= COLS || board[gr][gc] !== null) valid = false;
    }
    return { cells, valid };
  }

  function onCellHover(r: number, c: number) {
    if (!selectedId) return;
    hoverAnchor = [r, c];
    renderBoard();
  }

  boardEl.addEventListener('mouseleave', () => {
    if (hoverAnchor) {
      hoverAnchor = null;
      renderBoard();
    }
  });

  function onCellClick(r: number, c: number) {
    const existing = board[r][c];
    if (existing) {
      removePiece(existing);
      setStatus(`Removed the ${PIECE_BY_ID[existing].name} piece.`);
      return;
    }
    if (!selectedId) {
      setStatus('Select a piece first.');
      return;
    }
    if (pieceOnBoard(selectedId)) {
      setStatus(`The ${PIECE_BY_ID[selectedId].name} piece is already on the board.`);
      return;
    }
    hoverAnchor = [r, c];
    const { cells, valid } = computePreview();
    if (!valid) {
      setStatus("That piece doesn't fit there. Rotate, flip, or pick another spot.");
      renderBoard();
      return;
    }
    for (const [gr, gc] of cells) board[gr][gc] = selectedId;
    setStatus(`Placed the ${PIECE_BY_ID[selectedId].name} piece.`);
    hoverAnchor = null;
    selectNextUnplaced();
    renderTray();
    renderBoard();
  }

  function removePiece(id: string) {
    for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) if (board[r][c] === id) board[r][c] = null;
    renderTray();
    renderBoard();
  }

  function selectNextUnplaced() {
    const next = PIECES.find((p) => !pieceOnBoard(p.id));
    selectedId = next ? next.id : null;
  }

  // ── Tray rendering (each card = shape preview + its own Rotate/Flip) ─────
  function renderTray() {
    trayEl.innerHTML = '';
    for (const p of PIECES) {
      const placed = pieceOnBoard(p.id);
      const active = p.id === selectedId;

      const card = document.createElement('div');
      card.className =
        'kn-card flex flex-col items-center gap-2 rounded-lg border p-3 transition-colors ' +
        (active ? 'border-primary bg-surface-2' : 'border-hairline bg-surface-1') +
        (placed ? ' opacity-40' : '');

      // Clickable shape preview selects the piece.
      const previewBtn = document.createElement('button');
      previewBtn.type = 'button';
      previewBtn.setAttribute('role', 'option');
      previewBtn.setAttribute('aria-selected', String(active));
      previewBtn.setAttribute('aria-label', `Select the ${p.name} piece`);
      previewBtn.title = placed ? `${p.name} (placed) — click to select` : `Select the ${p.name} piece`;
      previewBtn.className = 'flex h-16 items-center justify-center transition-transform hover:scale-105';
      previewBtn.appendChild(blockShape(posedCells(p.id), p.color));
      previewBtn.addEventListener('click', () => {
        selectedId = p.id;
        renderTray();
        renderBoard();
      });
      card.appendChild(previewBtn);

      // Per-piece Rotate / Flip controls.
      const controls = document.createElement('div');
      controls.className = 'flex gap-1.5';
      const rotateBtn = smallBtn('Rotate', `Rotate the ${p.name} piece`);
      const flipBtn = smallBtn('Flip', `Flip the ${p.name} piece`);
      rotateBtn.addEventListener('click', () => {
        selectedId = p.id;
        pose[p.id].rot = (pose[p.id].rot + 1) % 4;
        renderTray();
        renderBoard();
      });
      flipBtn.addEventListener('click', () => {
        selectedId = p.id;
        pose[p.id].flip = !pose[p.id].flip;
        renderTray();
        renderBoard();
      });
      controls.append(rotateBtn, flipBtn);
      card.appendChild(controls);

      trayEl.appendChild(card);
    }
  }

  function smallBtn(label: string, aria: string): HTMLButtonElement {
    const b = document.createElement('button');
    b.type = 'button';
    b.textContent = label;
    b.setAttribute('aria-label', aria);
    b.className =
      'rounded-md border border-hairline bg-surface-1 px-2 py-1 text-[12px] font-medium text-ink-muted ' +
      'transition-colors hover:border-hairline-strong hover:bg-surface-2 hover:text-ink';
    return b;
  }

  // Solid connected-block rendering of a piece (matches the physical piece look).
  function blockShape(cells: Cell[], color: string): HTMLElement {
    const maxR = Math.max(...cells.map((p) => p[0]));
    const maxC = Math.max(...cells.map((p) => p[1]));
    const S = 15; // block px
    const wrap = document.createElement('div');
    wrap.className = 'grid';
    wrap.style.gridTemplateColumns = `repeat(${maxC + 1}, ${S}px)`;
    wrap.style.gridTemplateRows = `repeat(${maxR + 1}, ${S}px)`;
    const filled = new Set(cells.map(([r, c]) => `${r},${c}`));
    for (let r = 0; r <= maxR; r++) {
      for (let c = 0; c <= maxC; c++) {
        const dot = document.createElement('div');
        if (filled.has(`${r},${c}`)) {
          dot.style.background = color;
          dot.style.borderRadius = '3px';
          dot.style.boxShadow = 'inset 0 0 0 1px rgba(0,0,0,0.18)';
        }
        wrap.appendChild(dot);
      }
    }
    return wrap;
  }

  // ── Actions ────────────────────────────────────────────────────
  function setStatus(msg: string) {
    statusEl.textContent = msg;
  }

  function withDefer(label: string, fn: () => void) {
    setStatus(label);
    setTimeout(fn, 20);
  }

  document.getElementById('kn-solve')!.addEventListener('click', () => {
    const empties = board.flat().filter((v) => v === null).length;
    if (empties === 0) {
      setStatus('The board is already full.');
      return;
    }
    withDefer('Solving…', () => {
      const t0 = performance.now();
      const res = solve(board);
      const ms = Math.round(performance.now() - t0);
      if (res.board) {
        board = res.board;
        selectedId = null;
        hoverAnchor = null;
        renderTray();
        renderBoard();
        setStatus(`Solved in ${ms} ms.`);
      } else {
        setStatus(
          res.timedOut
            ? 'Search limit reached without a solution — try removing a piece.'
            : 'No arrangement of the remaining pieces fills these holes.',
        );
      }
    });
  });

  document.getElementById('kn-solvable')!.addEventListener('click', () => {
    withDefer('Checking…', () => {
      const res = solve(board);
      if (res.board) setStatus('✓ Yes — this board can still be completed.');
      else if (res.timedOut) setStatus('Search limit reached — could not decide.');
      else setStatus('✗ No — the remaining pieces cannot fill these holes.');
    });
  });

  document.getElementById('kn-hint')!.addEventListener('click', () => {
    const empties = board.flat().filter((v) => v === null).length;
    if (empties === 0) {
      setStatus('The board is already full.');
      return;
    }
    withDefer('Thinking…', () => {
      const h = hint(board);
      if (!h) {
        setStatus('No hint available — this board can’t be completed.');
        return;
      }
      for (const [r, c] of h.cells) board[r][c] = h.id;
      selectedId = null;
      hoverAnchor = null;
      renderTray();
      renderBoard();
      setStatus(`Hint: placed the ${PIECE_BY_ID[h.id].name} piece.`);
    });
  });

  document.getElementById('kn-random')!.addEventListener('click', () => {
    withDefer('Dealing…', () => {
      const puzzle = makeRandomPuzzle();
      if (puzzle) {
        board = puzzle;
        for (const id of Object.keys(pose)) { pose[id].rot = 0; pose[id].flip = false; }
        selectNextUnplaced();
        renderTray();
        renderBoard();
        setStatus('Good luck!');
      } else {
        setStatus('Could not deal a puzzle — try again.');
      }
    });
  });

  document.getElementById('kn-reset')!.addEventListener('click', () => {
    board = emptyBoard();
    for (const id of Object.keys(pose)) { pose[id].rot = 0; pose[id].flip = false; }
    selectedId = PIECES[0].id;
    hoverAnchor = null;
    renderTray();
    renderBoard();
    setStatus('Board cleared.');
  });

  document.addEventListener('keydown', (e) => {
    const el = document.activeElement;
    if (el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement) return;
    if (!selectedId) return;
    if (e.key === 'r' || e.key === 'R') { e.preventDefault(); pose[selectedId].rot = (pose[selectedId].rot + 1) % 4; renderTray(); renderBoard(); }
    else if (e.key === 'f' || e.key === 'F') { e.preventDefault(); pose[selectedId].flip = !pose[selectedId].flip; renderTray(); renderBoard(); }
    else if (e.key === 'Escape') { selectedId = null; hoverAnchor = null; renderTray(); renderBoard(); }
  });

  // ── Random puzzle generation ───────────────────────────────────
  // Solve an empty board to get a full tiling, then keep a random subset of the
  // pieces as clues (removing the rest). Guarantees the puzzle is solvable.
  function makeRandomPuzzle(): Board | null {
    const order = shuffle(PIECES.map((p) => p.id));
    const full = solve(emptyBoard(), { order });
    if (!full.board) return null;
    const solved = full.board;

    const keepCount = 3 + Math.floor(rand() * 4); // 3–6 clue pieces
    const keep = new Set(shuffle(PIECES.map((p) => p.id)).slice(0, keepCount));

    const puzzle = cloneBoard(solved);
    for (let r = 0; r < ROWS; r++)
      for (let c = 0; c < COLS; c++) if (!keep.has(puzzle[r][c] as string)) puzzle[r][c] = null;
    return puzzle;
  }

  function rand(): number {
    const b = new Uint32Array(1);
    crypto.getRandomValues(b);
    return b[0] / 0x100000000;
  }

  function shuffle<T>(arr: T[]): T[] {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(rand() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  // Init
  selectedId = PIECES[0].id;
  renderTray();
  renderBoard();
  setStatus('Pick a piece and click the board, or deal a Random Game.');
</script>

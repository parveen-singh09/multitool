---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="random-token-generator">
  <div class="flex flex-col gap-5">
    <div class="panel panel-lift flex items-start gap-3 p-4">
      <output
        id="rt-output"
        class="flex-1 select-all break-all font-mono text-lg leading-relaxed text-ink"
      >click generate</output>
      <div class="flex shrink-0 flex-col gap-2 sm:flex-row">
        <button id="rt-copy" class="btn btn-secondary" aria-label="Copy token">Copy</button>
        <button id="rt-refresh" class="btn btn-primary" aria-label="Generate new token">Generate</button>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <label for="rt-length" class="text-sm text-ink-muted">Length</label>
        <span id="rt-length-val" class="font-mono text-sm text-ink">51</span>
      </div>
      <input id="rt-length" type="range" min="1" max="512" value="51" class="w-full accent-[#5e6ad2]" />
    </div>

    <div class="grid grid-cols-2 gap-3">
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="rt-upper" checked class="accent-[#5e6ad2]" />
        Uppercase (A–Z)
      </label>
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="rt-lower" checked class="accent-[#5e6ad2]" />
        Lowercase (a–z)
      </label>
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="rt-numbers" checked class="accent-[#5e6ad2]" />
        Numbers (0–9)
      </label>
      <label class="panel flex cursor-pointer items-center gap-3 p-3 text-sm">
        <input type="checkbox" id="rt-symbols" class="accent-[#5e6ad2]" />
        Symbols (!@#$…)
      </label>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free random token generator creates secure random tokens of any length
      from the character sets you choose — uppercase and lowercase letters, numbers,
      and symbols. Drag the length slider and toggle each set on or off to build a
      token that fits your needs. Use them for CSRF tokens, session identifiers,
      reset links, access tokens and unique references. Every token is drawn
      uniformly from your selected characters using the Web Crypto API and never
      leaves your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const out = document.getElementById('rt-output')!;
  const lengthEl = document.getElementById('rt-length') as HTMLInputElement;
  const lengthVal = document.getElementById('rt-length-val')!;
  const opts = {
    upper: document.getElementById('rt-upper') as HTMLInputElement,
    lower: document.getElementById('rt-lower') as HTMLInputElement,
    numbers: document.getElementById('rt-numbers') as HTMLInputElement,
    symbols: document.getElementById('rt-symbols') as HTMLInputElement,
  };

  const SETS = {
    upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
    lower: 'abcdefghijklmnopqrstuvwxyz',
    numbers: '0123456789',
    symbols: '!@#$%^&*()-_=+[]{};:,.<>?',
  };

  function generate() {
    let pool = '';
    (Object.keys(SETS) as (keyof typeof SETS)[]).forEach((k) => {
      if (opts[k].checked) pool += SETS[k];
    });
    if (!pool) {
      out.textContent = 'select at least one option';
      return;
    }
    const len = Number(lengthEl.value);

    const bytes = new Uint32Array(len);
    crypto.getRandomValues(bytes);
    let token = '';
    for (let i = 0; i < len; i++) token += pool[bytes[i] % pool.length];
    out.textContent = token;
  }

  lengthEl.addEventListener('input', () => {
    lengthVal.textContent = lengthEl.value;
    generate();
  });
  Object.values(opts).forEach((el) => el.addEventListener('change', generate));
  document.getElementById('rt-refresh')!.addEventListener('click', generate);
  document.getElementById('rt-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('rt-copy')!;
    await navigator.clipboard.writeText(out.textContent || '');
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });

  generate();
</script>

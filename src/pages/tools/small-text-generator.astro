---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="small-text-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Your text
      <input id="st-in" class="field text-lg" value="tiny text" placeholder="Type something" spellcheck="false" autocomplete="off" />
    </label>

    <div id="st-out" class="flex flex-col gap-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free small text generator converts normal text into tiny Unicode
      characters вҖ” superscript ЛўбөҗбөғЛЎЛЎ б¶ңбөғбө–Лў, subscript, and small-caps кңұбҙҚбҙҖКҹКҹ бҙӣбҙҮxбҙӣ.
      Because these are real Unicode code points (not shrunken font sizes), the
      output pastes into Instagram bios, X/Twitter posts, Discord, usernames and
      anywhere else that normally ignores font styling. Type once, then copy the
      style you want.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('st-in') as HTMLInputElement;
  const out = document.getElementById('st-out')!;

  const SUPER: Record<string, string> = {
    a: 'бөғ', b: 'бөҮ', c: 'б¶ң', d: 'бөҲ', e: 'бөү', f: 'б¶ ', g: 'бөҚ', h: 'К°', i: 'вҒұ', j: 'КІ',
    k: 'бөҸ', l: 'ЛЎ', m: 'бөҗ', n: 'вҒҝ', o: 'бө’', p: 'бө–', q: 'Ы№', r: 'Кі', s: 'Лў', t: 'бө—',
    u: 'бөҳ', v: 'бөӣ', w: 'К·', x: 'ЛЈ', y: 'Кё', z: 'б¶»',
    '0': 'вҒ°', '1': 'В№', '2': 'ВІ', '3': 'Ві', '4': 'вҒҙ', '5': 'вҒө', '6': 'вҒ¶', '7': 'вҒ·', '8': 'вҒё', '9': 'вҒ№',
    '+': 'вҒә', '-': 'вҒ»', '=': 'вҒј', '(': 'вҒҪ', ')': 'вҒҫ',
  };

  const SUB: Record<string, string> = {
    a: 'вӮҗ', e: 'вӮ‘', h: 'вӮ•', i: 'бөў', j: 'вұј', k: 'вӮ–', l: 'вӮ—', m: 'вӮҳ', n: 'вӮҷ', o: 'вӮ’',
    p: 'вӮҡ', r: 'бөЈ', s: 'вӮӣ', t: 'вӮң', u: 'бөӨ', v: 'бөҘ', x: 'вӮ“',
    '0': 'вӮҖ', '1': 'вӮҒ', '2': 'вӮӮ', '3': 'вӮғ', '4': 'вӮ„', '5': 'вӮ…', '6': 'вӮҶ', '7': 'вӮҮ', '8': 'вӮҲ', '9': 'вӮү',
    '+': 'вӮҠ', '-': 'вӮӢ', '=': 'вӮҢ', '(': 'вӮҚ', ')': 'вӮҺ',
  };

  const SMALLCAPS: Record<string, string> = {
    a: 'бҙҖ', b: 'Кҷ', c: 'бҙ„', d: 'бҙ…', e: 'бҙҮ', f: 'кң°', g: 'Йў', h: 'Кң', i: 'ЙӘ', j: 'бҙҠ',
    k: 'бҙӢ', l: 'Кҹ', m: 'бҙҚ', n: 'Йҙ', o: 'бҙҸ', p: 'бҙҳ', q: 'З«', r: 'КҖ', s: 'кңұ', t: 'бҙӣ',
    u: 'бҙң', v: 'бҙ ', w: 'бҙЎ', x: 'x', y: 'КҸ', z: 'бҙў',
  };

  function convert(text: string, map: Record<string, string>): string {
    return [...text].map((ch) => map[ch.toLowerCase()] ?? ch).join('');
  }

  const STYLES: [string, Record<string, string>][] = [
    ['Superscript', SUPER],
    ['Subscript', SUB],
    ['Small caps', SMALLCAPS],
  ];

  function render() {
    const text = input.value;
    out.innerHTML = STYLES.map(([name, map], i) => {
      const result = convert(text, map);
      return `<div class="panel panel-lift flex items-center gap-3 p-4">
        <div class="flex min-w-0 flex-1 flex-col gap-0.5">
          <span class="text-xs text-ink-tertiary">${name}</span>
          <div class="copy-wrap">
            <span id="st-out-${i}" class="block truncate pr-8 text-lg text-ink" title="${result.replace(/"/g, '&quot;')}">${result}</span>
            <button type="button" class="copy-icon" data-copy-target="#st-out-${i}" aria-label="Copy"></button>
          </div>
        </div>
      </div>`;
    }).join('');
  }

  input.addEventListener('input', render);
  render();
</script>

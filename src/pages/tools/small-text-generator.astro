---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="small-text-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Your text
      <input id="st-in" class="field text-lg" value="tiny text" placeholder="Type something" spellcheck="false" autocomplete="off" />
    </label>

    <div id="st-out" class="flex flex-col gap-3"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free small text generator converts normal text into tiny Unicode
      characters — superscript ˢᵐᵃˡˡ ᶜᵃᵖˢ, subscript, and small-caps ꜱᴍᴀʟʟ ᴛᴇxᴛ.
      Because these are real Unicode code points (not shrunken font sizes), the
      output pastes into Instagram bios, X/Twitter posts, Discord, usernames and
      anywhere else that normally ignores font styling. Type once, then copy the
      style you want. Everything runs in your browser — nothing is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('st-in') as HTMLInputElement;
  const out = document.getElementById('st-out')!;

  // Superscript map (mostly complete for a–z, 0–9).
  const SUPER: Record<string, string> = {
    a: 'ᵃ', b: 'ᵇ', c: 'ᶜ', d: 'ᵈ', e: 'ᵉ', f: 'ᶠ', g: 'ᵍ', h: 'ʰ', i: 'ⁱ', j: 'ʲ',
    k: 'ᵏ', l: 'ˡ', m: 'ᵐ', n: 'ⁿ', o: 'ᵒ', p: 'ᵖ', q: '۹', r: 'ʳ', s: 'ˢ', t: 'ᵗ',
    u: 'ᵘ', v: 'ᵛ', w: 'ʷ', x: 'ˣ', y: 'ʸ', z: 'ᶻ',
    '0': '⁰', '1': '¹', '2': '²', '3': '³', '4': '⁴', '5': '⁵', '6': '⁶', '7': '⁷', '8': '⁸', '9': '⁹',
    '+': '⁺', '-': '⁻', '=': '⁼', '(': '⁽', ')': '⁾',
  };

  const SUB: Record<string, string> = {
    a: 'ₐ', e: 'ₑ', h: 'ₕ', i: 'ᵢ', j: 'ⱼ', k: 'ₖ', l: 'ₗ', m: 'ₘ', n: 'ₙ', o: 'ₒ',
    p: 'ₚ', r: 'ᵣ', s: 'ₛ', t: 'ₜ', u: 'ᵤ', v: 'ᵥ', x: 'ₓ',
    '0': '₀', '1': '₁', '2': '₂', '3': '₃', '4': '₄', '5': '₅', '6': '₆', '7': '₇', '8': '₈', '9': '₉',
    '+': '₊', '-': '₋', '=': '₌', '(': '₍', ')': '₎',
  };

  // Small caps: uppercase A–Z → Unicode small-capital letters.
  const SMALLCAPS: Record<string, string> = {
    a: 'ᴀ', b: 'ʙ', c: 'ᴄ', d: 'ᴅ', e: 'ᴇ', f: 'ꜰ', g: 'ɢ', h: 'ʜ', i: 'ɪ', j: 'ᴊ',
    k: 'ᴋ', l: 'ʟ', m: 'ᴍ', n: 'ɴ', o: 'ᴏ', p: 'ᴘ', q: 'ǫ', r: 'ʀ', s: 'ꜱ', t: 'ᴛ',
    u: 'ᴜ', v: 'ᴠ', w: 'ᴡ', x: 'x', y: 'ʏ', z: 'ᴢ',
  };

  function convert(text: string, map: Record<string, string>): string {
    return [...text].map((ch) => map[ch.toLowerCase()] ?? ch).join('');
  }

  const STYLES: [string, Record<string, string>][] = [
    ['Superscript', SUPER],
    ['Subscript', SUB],
    ['Small caps', SMALLCAPS],
  ];

  function render() {
    const text = input.value;
    out.innerHTML = STYLES.map(([name, map], i) => {
      const result = convert(text, map);
      return `<div class="panel panel-lift flex items-center gap-3 p-4">
        <div class="flex min-w-0 flex-1 flex-col gap-0.5">
          <span class="text-xs text-ink-tertiary">${name}</span>
          <span class="truncate text-lg text-ink" title="${result.replace(/"/g, '&quot;')}">${result || '<span class="text-ink-tertiary">…</span>'}</span>
        </div>
        <button class="btn btn-secondary" data-copy="${i}">Copy</button>
      </div>`;
    }).join('');

    out.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const [, map] = STYLES[Number(btn.dataset.copy)];
        await navigator.clipboard.writeText(convert(input.value, map));
        btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = 'Copy'), 1500);
      });
    });
  }

  input.addEventListener('input', render);
  render();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="html-to-pdf">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">

    <div class="flex flex-col gap-3">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <span class="flex items-center justify-between">
          <span>HTML</span>
          <span class="flex gap-2">
            <button id="hp-sample" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Sample</button>
            <button id="hp-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
          </span>
        </span>
        <div class="copy-wrap">
          <textarea id="hp-in" class="field font-mono text-[13px]" rows="16" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder="Paste HTML here. You can include <style> tags, tables, headings, lists and inline CSS."></textarea>
          <button type="button" class="copy-icon" data-copy-target="#hp-in" aria-label="Copy"></button>
        </div>
      </div>
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Page size
          <select id="hp-size" class="field w-36">
            <option value="A4" selected>A4</option>
            <option value="Letter">Letter</option>
            <option value="Legal">Legal</option>
            <option value="A3">A3</option>
            <option value="A5">A5</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Orientation
          <select id="hp-orient" class="field w-36">
            <option value="portrait" selected>Portrait</option>
            <option value="landscape">Landscape</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Margin
          <select id="hp-margin" class="field w-36">
            <option value="1.6cm" selected>Normal</option>
            <option value="0.8cm">Narrow</option>
            <option value="2.5cm">Wide</option>
            <option value="0">None</option>
          </select>
        </label>
        <button id="hp-pdf" type="button" class="btn btn-primary self-end">Save as PDF</button>
      </div>
      <p class="text-[13px] text-ink-tertiary">
        “Save as PDF” opens your browser’s print dialog — choose <em>Save as PDF</em>
        (or <em>Microsoft Print to PDF</em>) as the destination. The result is a
        real, text-selectable PDF. Page size, orientation and margins above are
        applied automatically.
      </p>
    </div>

    <div class="flex flex-col gap-2 lg:sticky lg:top-6 self-start">
      <label class="text-sm text-ink-subtle">Live preview</label>
      <iframe id="hp-frame" class="w-full rounded-md border border-hairline bg-white" style="height:70vh" title="HTML preview" sandbox="allow-same-origin"></iframe>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free HTML to PDF converter renders your HTML — including
      <code class="font-mono text-ink">&lt;style&gt;</code> rules, tables, headings,
      lists, links and inline CSS — and turns it into a clean, text-selectable PDF.
      It uses your browser’s own high-fidelity print engine, so the PDF looks
      exactly like the preview and keeps real selectable text (not a screenshot).
    </p>
    <p>
      Paste a snippet or a whole page, pick a page size (A4, Letter, Legal, A3 or
      A5), choose portrait or landscape, set the margins, and preview the result
      live on the right. When it looks right, click <strong>Save as PDF</strong> to
      open the print dialog and choose “Save as PDF” as the destination. Because
      rendering is done by the browser, modern CSS, web-safe fonts and page-break
      rules all work as they would when printing any web page.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const input = $('hp-in') as HTMLTextAreaElement;
  const frame = $('hp-frame') as HTMLIFrameElement;
  const sizeSel = $('hp-size') as HTMLSelectElement;
  const orientSel = $('hp-orient') as HTMLSelectElement;
  const marginSel = $('hp-margin') as HTMLSelectElement;

  const SAMPLE = `<style>
  body { font-family: Georgia, serif; color: #222; line-height: 1.5; }
  h1 { color: #5e6ad2; border-bottom: 2px solid #5e6ad2; padding-bottom: 6px; }
  table { border-collapse: collapse; width: 100%; margin-top: 12px; }
  th, td { border: 1px solid #ccc; padding: 8px 12px; text-align: left; }
  th { background: #f2f2f7; }
</style>
<h1>Invoice #1042</h1>
<p><strong>Billed to:</strong> Acme Corporation<br>Date: 13 July 2026</p>
<table>
  <tr><th>Item</th><th>Qty</th><th>Price</th></tr>
  <tr><td>Design work</td><td>10</td><td>$1,200.00</td></tr>
  <tr><td>Hosting (annual)</td><td>1</td><td>$180.00</td></tr>
  <tr><th colspan="2">Total</th><th>$1,380.00</th></tr>
</table>`;

  function render() {
    const doc = frame.contentDocument;
    if (!doc) return;
    const pageCss = `@page { size: ${sizeSel.value} ${orientSel.value}; margin: ${marginSel.value}; }`;
    doc.open();
    doc.write(
      `<!DOCTYPE html><html><head><meta charset="utf-8">` +
      `<style>${pageCss}\nhtml,body{margin:0}body{padding:12px;font-family:system-ui,sans-serif}</style>` +
      `</head><body>${input.value}</body></html>`,
    );
    doc.close();
  }

  function savePdf() {
    render();
    const win = frame.contentWindow;
    if (!win) return;
    win.focus();
    win.print();
  }

  input.addEventListener('input', render);
  [sizeSel, orientSel, marginSel].forEach((el) => el.addEventListener('change', render));
  $('hp-sample').addEventListener('click', () => { input.value = SAMPLE; render(); });
  $('hp-clear').addEventListener('click', () => { input.value = ''; render(); });
  $('hp-pdf').addEventListener('click', savePdf);

  render();
</script>

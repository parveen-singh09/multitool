---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="probability-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Probability of A (%)
        <input id="p-a" type="number" inputmode="decimal" step="any" min="0" max="100" class="field font-mono" value="50" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Probability of B (%)
        <input id="p-b" type="number" inputmode="decimal" step="any" min="0" max="100" class="field font-mono" value="25" />
      </label>
    </div>

    <p id="p-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-5"><div id="p-and" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(A ∩ B)</div></div>
      <div class="panel panel-lift p-5"><div id="p-or" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(A ∪ B)</div></div>
      <div class="panel p-5"><div id="p-nota" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(not A)</div></div>
      <div class="panel p-5"><div id="p-notb" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(not B)</div></div>
      <div class="panel p-5"><div id="p-neither" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(neither)</div></div>
      <div class="panel p-5"><div id="p-onlya" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(A not B)</div></div>
      <div class="panel p-5"><div id="p-agivenb" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(A | B)</div></div>
      <div class="panel p-5"><div id="p-bgivena" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(B | A)</div></div>
      <div class="panel p-5"><div id="p-odds" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">P(A ∩ B) as odds</div></div>
    </div>

    <p class="text-[13px] text-ink-tertiary">
      Results assume events A and B are independent — the outcome of one does not
      affect the other.
    </p>

    <div class="panel p-5">
      <div class="mb-3 text-sm text-ink-muted">Probability of at least one success in repeated trials</div>
      <div class="flex flex-wrap items-center gap-2 text-sm text-ink-subtle">
        With P(event) =
        <input id="p-single" type="number" step="any" min="0" max="100" class="field w-24 font-mono" value="10" /> %, over
        <input id="p-trials" type="number" step="1" min="1" class="field w-24 font-mono" value="10" /> trials →
        <span id="p-atleast" class="font-mono text-lg text-primary-hover">—</span>
        <span class="text-[13px] text-ink-tertiary">at least once</span>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free probability calculator finds the chance of single and combined
      events. Enter the probability of A and B as percentages to get P(A and B),
      P(A or B), the complements, and the probability that neither event occurs.
      It assumes the two events are independent. All calculations run in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  const aEl = document.getElementById('p-a') as HTMLInputElement;
  const bEl = document.getElementById('p-b') as HTMLInputElement;
  const errEl = document.getElementById('p-error')!;

  const pct = (v: number): string => {
    const r = Math.round(v * 1e6) / 1e6;
    return `${r}%`;
  };

  const ids = ['p-and', 'p-or', 'p-nota', 'p-notb', 'p-neither', 'p-onlya', 'p-agivenb', 'p-bgivena', 'p-odds'];
  const setEmpty = () => ids.forEach((id) => (document.getElementById(id)!.textContent = '—'));

  // Format a probability (0–1) as a 1-in-N odds string.
  const asOdds = (p: number): string => (p <= 0 ? '—' : `1 in ${(1 / p).toFixed(p >= 0.1 ? 1 : 0)}`);

  function calc() {
    errEl.classList.add('hidden');
    const av = parseFloat(aEl.value);
    const bv = parseFloat(bEl.value);

    if (isNaN(av) || isNaN(bv)) { setEmpty(); return; }
    if (av < 0 || av > 100 || bv < 0 || bv > 100) {
      errEl.textContent = 'Probabilities must be between 0 and 100%.';
      errEl.classList.remove('hidden');
      setEmpty();
      return;
    }

    const pa = av / 100;
    const pb = bv / 100;
    const both = pa * pb;
    const either = pa + pb - both;
    const neither = (1 - pa) * (1 - pb);
    const onlyA = pa * (1 - pb);

    document.getElementById('p-and')!.textContent = pct(both * 100);
    document.getElementById('p-or')!.textContent = pct(either * 100);
    document.getElementById('p-nota')!.textContent = pct((1 - pa) * 100);
    document.getElementById('p-notb')!.textContent = pct((1 - pb) * 100);
    document.getElementById('p-neither')!.textContent = pct(neither * 100);
    document.getElementById('p-onlya')!.textContent = pct(onlyA * 100);
    // Under independence P(A|B)=P(A) and P(B|A)=P(B), but show the general formula result.
    document.getElementById('p-agivenb')!.textContent = pb > 0 ? pct((both / pb) * 100) : '—';
    document.getElementById('p-bgivena')!.textContent = pa > 0 ? pct((both / pa) * 100) : '—';
    document.getElementById('p-odds')!.textContent = asOdds(both);
  }

  // "At least one" over N independent trials: 1 − (1 − p)^n.
  function calcAtLeast() {
    const p = parseFloat((document.getElementById('p-single') as HTMLInputElement).value) / 100;
    const n = parseInt((document.getElementById('p-trials') as HTMLInputElement).value, 10);
    const out = document.getElementById('p-atleast')!;
    if (isNaN(p) || isNaN(n) || p < 0 || p > 1 || n < 1) { out.textContent = '—'; return; }
    const atLeastOne = 1 - Math.pow(1 - p, n);
    out.textContent = pct(atLeastOne * 100);
  }

  [aEl, bEl].forEach((el) => el.addEventListener('input', calc));
  ['p-single', 'p-trials'].forEach((id) => document.getElementById(id)!.addEventListener('input', calcAtLeast));
  calc();
  calcAtLeast();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="discount-calculator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle sm:max-w-xs">Original price
      <input id="dc-price" type="number" min="0" class="field" value="80" inputmode="decimal" />
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <div class="flex items-center justify-between"><span>First discount</span>
          <select id="dc-t1" class="field w-auto !py-0.5 text-xs"><option value="pct">% off</option><option value="amt">$ off</option></select>
        </div>
        <input id="dc-d1" type="number" min="0" step="1" class="field" value="25" inputmode="decimal" />
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        <div class="flex items-center justify-between"><span>Extra discount (stacked)</span>
          <select id="dc-t2" class="field w-auto !py-0.5 text-xs"><option value="pct">% off</option><option value="amt">$ off</option></select>
        </div>
        <input id="dc-d2" type="number" min="0" step="1" class="field" value="0" inputmode="decimal" />
      </div>
    </div>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle sm:max-w-xs">Sales tax (%) — optional
      <input id="dc-tax" type="number" min="0" step="0.01" class="field" value="0" inputmode="decimal" />
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="panel panel-lift p-6 text-center"><div class="copy-wrap"><div id="dc-final" class="font-display text-3xl font-semibold text-primary-hover">—</div><button type="button" class="copy-icon" data-copy-target="#dc-final" aria-label="Copy"></button></div><div class="mt-1 text-[13px] text-ink-subtle">Final price</div></div>
      <div class="panel p-6 text-center"><div id="dc-saved" class="font-mono text-2xl" style="color:var(--color-success)">—</div><div class="mt-1 text-[13px] text-ink-subtle">You save (<span id="dc-savedpct">0%</span>)</div></div>
      <div class="panel p-6 text-center"><div id="dc-otd" class="font-mono text-2xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Out-the-door (with tax)</div></div>
    </div>

    <div class="panel p-5">
      <div class="mb-3 text-sm text-ink-muted">Reverse: find the original price</div>
      <div class="flex flex-wrap items-center gap-2 text-sm text-ink-subtle">
        <span>Paid</span>
        <input id="dc-r-final" type="number" min="0" class="field w-28" value="60" inputmode="decimal" />
        <span>after</span>
        <input id="dc-r-pct" type="number" min="0" max="99.9" step="1" class="field w-24" value="25" inputmode="decimal" />
        <span>% off →</span>
        <span id="dc-r-out" class="font-mono text-ink">—</span>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free discount calculator shows the final sale price after a percentage
      or fixed-amount discount, how much you save, and the out-the-door price once
      sales tax is added. It handles a stacked second discount (applied to the
      already-reduced price) so you can check "extra 10% off" deals, and can work
      backwards to find the original price from what you paid. Everything is
      calculated instantly in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const sel = (id: string) => document.getElementById(id) as unknown as HTMLSelectElement;
  const money = (n: number) => n.toLocaleString(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });

  const apply = (p: number, val: number, type: string) => (type === 'amt' ? Math.max(0, p - val) : p * (1 - val / 100));

  function calc() {
    const p = Number($('dc-price').value) || 0;
    const afterFirst = apply(p, Number($('dc-d1').value) || 0, sel('dc-t1').value);
    const final = apply(afterFirst, Number($('dc-d2').value) || 0, sel('dc-t2').value);
    const saved = p - final;
    const tax = Number($('dc-tax').value) || 0;
    document.getElementById('dc-final')!.textContent = money(final);
    document.getElementById('dc-saved')!.textContent = money(saved);
    document.getElementById('dc-savedpct')!.textContent = (p > 0 ? Math.round((saved / p) * 100) : 0) + '%';
    document.getElementById('dc-otd')!.textContent = money(final * (1 + tax / 100));
  }

  function reverse() {
    const paid = Number($('dc-r-final').value) || 0;
    const pct = Number($('dc-r-pct').value) || 0;
    const out = document.getElementById('dc-r-out')!;
    out.textContent = pct >= 100 ? '—' : money(paid / (1 - pct / 100));
  }

  ['dc-price', 'dc-d1', 'dc-d2', 'dc-tax'].forEach((id) => $(id).addEventListener('input', calc));
  ['dc-t1', 'dc-t2'].forEach((id) => sel(id).addEventListener('change', calc));
  ['dc-r-final', 'dc-r-pct'].forEach((id) => $(id).addEventListener('input', reverse));
  calc();
  reverse();
</script>

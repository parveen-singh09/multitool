---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="watermark-generator">
  <div class="flex flex-col gap-4">
    <label id="wm-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose an image or drop it here</span>
      <span class="text-[13px] text-ink-tertiary">Watermarked in your browser — never uploaded</span>
      <input id="wm-file" type="file" accept="image/*" class="sr-only" />
    </label>

    <div id="wm-panel" class="hidden flex-col gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Watermark text
        <input id="wm-text" class="field" value="© ToolCities" />
      </label>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Opacity: <span id="wm-ov" class="text-ink">30%</span>
          <input id="wm-opacity" type="range" min="5" max="100" value="30" class="w-full accent-[#5e6ad2]" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Size: <span id="wm-sv" class="text-ink">32px</span>
          <input id="wm-size" type="range" min="10" max="120" value="32" class="w-full accent-[#5e6ad2]" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Angle: <span id="wm-av" class="text-ink">-30°</span>
          <input id="wm-angle" type="range" min="-90" max="90" value="-30" class="w-full accent-[#5e6ad2]" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Color
          <input id="wm-color" type="color" value="#ffffff" class="field h-10 cursor-pointer p-1" />
        </label>
      </div>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="wm-tile" type="checkbox" class="accent-[#5e6ad2]" checked /> Tile across whole image (unchecked = single, centered)</label>
      <div class="flex justify-center overflow-auto rounded-[12px] border border-hairline bg-surface-2 p-4">
        <canvas id="wm-canvas" class="max-w-full"></canvas>
      </div>
      <button id="wm-dl" class="btn btn-primary w-fit">Download</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free watermark generator overlays a text watermark on your photo — tiled
      across the whole image or as a single centered mark — with adjustable
      opacity, size, angle and color. It's ideal for protecting proofs, previews
      and shared images. Your photo is processed on a canvas in your browser and
      is never uploaded to a server.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('wm-file') as HTMLInputElement;
  const drop = $('wm-drop')!;
  const panel = $('wm-panel')!;
  const canvas = $('wm-canvas') as HTMLCanvasElement;
  let img: HTMLImageElement | null = null;

  function render() {
    if (!img) return;
    const ctx = canvas.getContext('2d')!;
    canvas.width = img.naturalWidth; canvas.height = img.naturalHeight;
    ctx.drawImage(img, 0, 0);
    const text = ($('wm-text') as HTMLInputElement).value || '©';
    const opacity = Number(($('wm-opacity') as HTMLInputElement).value) / 100;
    const size = Number(($('wm-size') as HTMLInputElement).value) * (canvas.width / 600);
    const angle = Number(($('wm-angle') as HTMLInputElement).value) * Math.PI / 180;
    const color = ($('wm-color') as HTMLInputElement).value;
    const tile = ($('wm-tile') as HTMLInputElement).checked;
    ctx.save();
    ctx.globalAlpha = opacity;
    ctx.fillStyle = color;
    ctx.font = `600 ${size}px Inter, system-ui, sans-serif`;
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    if (tile) {
      const step = ctx.measureText(text).width + size * 3;
      ctx.rotate(angle);
      const diag = Math.hypot(canvas.width, canvas.height);
      for (let y = -diag; y < diag; y += size * 3) {
        for (let x = -diag; x < diag; x += step) ctx.fillText(text, x, y);
      }
    } else {
      ctx.translate(canvas.width / 2, canvas.height / 2);
      ctx.rotate(angle);
      ctx.fillText(text, 0, 0);
    }
    ctx.restore();
  }

  function load(file: File) {
    const url = URL.createObjectURL(file);
    const im = new Image();
    im.onload = () => { img = im; panel.classList.remove('hidden'); panel.classList.add('flex'); render(); URL.revokeObjectURL(url); };
    im.src = url;
  }

  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) load(fileInput.files[0]); });
  ['wm-text', 'wm-opacity', 'wm-size', 'wm-angle', 'wm-color', 'wm-tile'].forEach((id) => $(id).addEventListener('input', () => {
    $('wm-ov').textContent = ($('wm-opacity') as HTMLInputElement).value + '%';
    $('wm-sv').textContent = ($('wm-size') as HTMLInputElement).value + 'px';
    $('wm-av').textContent = ($('wm-angle') as HTMLInputElement).value + '°';
    render();
  }));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) load(f); });
  $('wm-dl').addEventListener('click', () => {
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = 'watermarked.png'; a.click();
  });
</script>

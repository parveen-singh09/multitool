---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="csv-formatter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="csvf-align" class="btn btn-primary">Align columns</button>
      <button id="csvf-normalize" class="btn btn-secondary">Normalize</button>
      <button id="csvf-copy" class="btn btn-secondary">Copy</button>
      <button id="csvf-clear" class="btn btn-tertiary">Clear</button>
      <label class="ml-auto flex items-center gap-2 text-sm text-ink-subtle">
        Delimiter
        <select id="csvf-delim" class="field w-auto py-1">
          <option value="auto">Auto</option>
          <option value=",">Comma</option>
          <option value=";">Semicolon</option>
          <option value="\t">Tab</option>
        </select>
      </label>
    </div>

    <div id="csvf-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div class="hl-edit field p-0" style="height:18rem;resize:vertical;overflow:hidden">
      <pre class="hl-block" aria-hidden="true"><code id="csvf-input-hl" class="hljs" style="background:transparent"></code></pre>
      <textarea
        id="csvf-input"
        spellcheck="false"
        autocapitalize="off"
        autocomplete="off"
        autocorrect="off"
        placeholder="Paste CSV here, e.g.&#10;name,age,city&#10;Ada, 36 ,London"
        aria-label="CSV input"
      ></textarea>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSV formatter cleans up CSV data by trimming whitespace from
      every field and normalizing the delimiter to your chosen separator, or
      aligns the columns into a neat monospace table for easy reading. Quoted
      fields containing commas, quotes or line breaks are parsed correctly, and
      the delimiter can be auto-detected.
    </p>
  </div>
</ToolLayout>

<script>
  import { wireInput } from '../../lib/highlight';

  const input = document.getElementById('csvf-input') as HTMLTextAreaElement;
  const inHl = document.getElementById('csvf-input-hl')!;
  const status = document.getElementById('csvf-status')!;
  const delimSel = document.getElementById('csvf-delim') as HTMLSelectElement;

  const refresh = wireInput(input, inHl, () => 'plaintext');

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  function detectDelimiter(text: string): string {
    const firstLine = text.replace(/\r\n/g, '\n').split('\n')[0] || '';
    const candidates = [',', ';', '\t'];
    let best = ',';
    let bestCount = -1;
    for (const d of candidates) {
      const count = firstLine.split(d).length - 1;
      if (count > bestCount) {
        bestCount = count;
        best = d;
      }
    }
    return best;
  }

  function getDelimiter(text: string): string {
    const v = delimSel.value;
    if (v === 'auto') return detectDelimiter(text);
    return v === '\\t' ? '\t' : v;
  }

  function parse(text: string, delim: string): string[][] {
    const rows: string[][] = [];
    let row: string[] = [];
    let field = '';
    let inQuotes = false;
    const src = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
    let i = 0;
    const n = src.length;
    while (i < n) {
      const c = src[i];
      if (inQuotes) {
        if (c === '"') {
          if (src[i + 1] === '"') {
            field += '"';
            i += 2;
            continue;
          }
          inQuotes = false;
          i++;
          continue;
        }
        field += c;
        i++;
        continue;
      }
      if (c === '"') {
        inQuotes = true;
        i++;
        continue;
      }
      if (c === delim) {
        row.push(field);
        field = '';
        i++;
        continue;
      }
      if (c === '\n') {
        row.push(field);
        rows.push(row);
        row = [];
        field = '';
        i++;
        continue;
      }
      field += c;
      i++;
    }
    row.push(field);
    rows.push(row);

    if (rows.length > 1 && rows[rows.length - 1].length === 1 && rows[rows.length - 1][0] === '') {
      rows.pop();
    }
    return rows.map((r) => r.map((f) => f.trim()));
  }

  function needsQuote(field: string, delim: string): boolean {
    return field.includes(delim) || field.includes('"') || field.includes('\n');
  }

  function encodeField(field: string, delim: string): string {
    if (needsQuote(field, delim)) return '"' + field.replace(/"/g, '""') + '"';
    return field;
  }

  function normalize(text: string): string {
    const delim = getDelimiter(text);
    const rows = parse(text, delim);
    const out = rows.map((r) => r.map((f) => encodeField(f, delim)).join(delim)).join('\n');
    showStatus(`Normalized (${rows.length} rows) ✓`, true);
    return out;
  }

  function align(text: string): string {
    const delim = getDelimiter(text);
    const rows = parse(text, delim);
    if (!rows.length) return text;
    const cols = Math.max(...rows.map((r) => r.length));
    const widths: number[] = [];
    for (let c = 0; c < cols; c++) {
      widths[c] = Math.max(...rows.map((r) => (r[c] || '').length));
    }
    const out = rows
      .map((r) => {
        const cells: string[] = [];
        for (let c = 0; c < cols; c++) {
          const v = r[c] || '';
          cells.push(c === cols - 1 ? v : v.padEnd(widths[c]));
        }
        return cells.join('  ');
      })
      .join('\n');
    showStatus(`Aligned ${cols} columns ✓`, true);
    return out;
  }

  document.getElementById('csvf-align')!.addEventListener('click', () => {
    if (!input.value.trim()) return;
    input.value = align(input.value);
    refresh();
  });
  document.getElementById('csvf-normalize')!.addEventListener('click', () => {
    if (!input.value.trim()) return;
    input.value = normalize(input.value);
    refresh();
  });
  document.getElementById('csvf-clear')!.addEventListener('click', () => {
    input.value = '';
    refresh();
    status.classList.add('hidden');
  });
  document.getElementById('csvf-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('csvf-copy')!;
    await navigator.clipboard.writeText(input.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
</script>

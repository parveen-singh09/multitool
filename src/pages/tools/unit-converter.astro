---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="unit-converter">
  <div class="flex flex-col gap-5">
    <!-- Category tabs -->
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Unit category">
      <button data-cat="length" class="uc-tab btn btn-secondary" aria-selected="true">Length</button>
      <button data-cat="weight" class="uc-tab btn btn-secondary" aria-selected="false">Weight</button>
      <button data-cat="temp" class="uc-tab btn btn-secondary" aria-selected="false">Temperature</button>
      <button data-cat="area" class="uc-tab btn btn-secondary" aria-selected="false">Area</button>
      <button data-cat="volume" class="uc-tab btn btn-secondary" aria-selected="false">Volume</button>
      <button data-cat="speed" class="uc-tab btn btn-secondary" aria-selected="false">Speed</button>
      <button data-cat="time" class="uc-tab btn btn-secondary" aria-selected="false">Time</button>
      <button data-cat="data" class="uc-tab btn btn-secondary" aria-selected="false">Data</button>
      <button data-cat="pressure" class="uc-tab btn btn-secondary" aria-selected="false">Pressure</button>
      <button data-cat="energy" class="uc-tab btn btn-secondary" aria-selected="false">Energy</button>
      <button data-cat="power" class="uc-tab btn btn-secondary" aria-selected="false">Power</button>
      <button data-cat="angle" class="uc-tab btn btn-secondary" aria-selected="false">Angle</button>
    </div>

    <!-- From / swap / To -->
    <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="uc-from-val">From</label>
        <input id="uc-from-val" type="number" inputmode="decimal" class="field" value="1" />
        <select id="uc-from-unit" class="field mt-1"></select>
      </div>
      <div class="flex items-center justify-center pb-2">
        <button id="uc-swap" type="button" class="btn btn-tertiary px-2 py-2" title="Swap units" aria-label="Swap from and to units">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4"/></svg>
        </button>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="uc-to-val">To</label>
        <div class="flex gap-2">
          <input id="uc-to-val" type="text" class="field flex-1" readonly aria-live="polite" />
          <button id="uc-copy" type="button" class="btn btn-secondary px-3" title="Copy result">Copy</button>
        </div>
        <select id="uc-to-unit" class="field mt-1"></select>
      </div>
    </div>

    <!-- Options: precision + formula -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-subtle">
      <label class="flex items-center gap-2">
        Precision
        <select id="uc-precision" class="field w-auto py-1">
          <option value="auto" selected>Auto</option>
          <option value="0">0 decimals</option>
          <option value="2">2 decimals</option>
          <option value="4">4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="8">8 decimals</option>
        </select>
      </label>
      <span id="uc-formula" class="text-ink-tertiary"></span>
    </div>

    <p id="uc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <!-- Common conversions -->
    <div class="flex flex-col gap-2">
      <span class="eyebrow text-primary-hover">Common conversions</span>
      <div id="uc-presets" class="flex flex-wrap gap-2"></div>
    </div>

    <!-- Live conversion table: the From value in every unit of the category -->
    <div class="flex flex-col gap-2">
      <span class="eyebrow text-primary-hover">Conversion table</span>
      <div class="panel overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-hairline text-left text-ink-subtle">
              <th class="px-4 py-2 font-medium">Unit</th>
              <th class="px-4 py-2 text-right font-medium">Value</th>
            </tr>
          </thead>
          <tbody id="uc-table"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free unit converter handles conversions across twelve categories —
      length, weight and mass, temperature, area, volume, speed, time, digital
      data, pressure, energy, power and angle — covering everything from metres to
      feet, kilograms to pounds and Celsius to Fahrenheit through to gigabytes to
      megabits, pascals to psi and joules to kilowatt-hours. Pick a category,
      choose your units, and the result updates instantly. All calculations happen
      in your browser — nothing is uploaded.
    </p>
    <p>
      Beyond a single from/to pair, a live conversion table shows your value
      expressed in every unit of the chosen category at once, so you can read off
      several equivalents in one glance. Use the swap button to reverse the two
      units, copy the result with one click, and set precision to Auto (which
      trims trailing zeros and switches to scientific notation for very large or
      small numbers) or a fixed number of decimal places. Common conversion
      shortcuts jump straight to popular pairs, and temperature conversions show
      the exact formula used.
    </p>
  </div>
</ToolLayout>

<script>
  // Factor-based units are relative to a base unit per category. Temperature is
  // affine (scale + offset) so it's handled specially.
  // ponytail: only temperature needs affine handling; every other category is a
  // pure multiplicative factor. Add an offset field if a future category (e.g.
  // some pressure gauges) needs one.
  type Cat = { units: Record<string, number>; unit?: string };
  const DATA: Record<string, Cat> = {
    length: { unit: 'm', units: { Nanometre: 1e-9, Micrometre: 1e-6, Millimetre: 0.001, Centimetre: 0.01, Metre: 1, Kilometre: 1000, Inch: 0.0254, Foot: 0.3048, Yard: 0.9144, Mile: 1609.344, 'Nautical mile': 1852 } },
    weight: { unit: 'g', units: { Microgram: 1e-6, Milligram: 0.001, Gram: 1, Kilogram: 1000, Tonne: 1e6, Ounce: 28.349523125, Pound: 453.59237, Stone: 6350.29318, 'US ton': 907184.74, 'Imperial ton': 1016046.9088 } },
    temp: { units: { Celsius: 1, Fahrenheit: 1, Kelvin: 1, Rankine: 1 } },
    area: { unit: 'm²', units: { 'Square millimetre': 1e-6, 'Square centimetre': 1e-4, 'Square metre': 1, Hectare: 1e4, 'Square kilometre': 1e6, 'Square inch': 0.00064516, 'Square foot': 0.09290304, 'Square yard': 0.83612736, Acre: 4046.8564224, 'Square mile': 2589988.110336 } },
    volume: { unit: 'L', units: { Millilitre: 0.001, 'Cubic centimetre': 0.001, Litre: 1, 'Cubic metre': 1000, 'Teaspoon (US)': 0.00492892159, 'Tablespoon (US)': 0.0147867648, 'Fluid ounce (US)': 0.0295735296, 'Cup (US)': 0.2365882365, 'Pint (US)': 0.473176473, 'Quart (US)': 0.946352946, 'Gallon (US)': 3.785411784, 'Gallon (UK)': 4.54609, 'Cubic inch': 0.016387064, 'Cubic foot': 28.316846592 } },
    speed: { unit: 'm/s', units: { 'Metre/second': 1, 'Kilometre/hour': 0.277777778, 'Mile/hour': 0.44704, 'Foot/second': 0.3048, Knot: 0.514444444, Mach: 340.29 } },
    time: { unit: 's', units: { Nanosecond: 1e-9, Microsecond: 1e-6, Millisecond: 0.001, Second: 1, Minute: 60, Hour: 3600, Day: 86400, Week: 604800, Month: 2629746, Year: 31556952 } },
    data: { unit: 'byte', units: { Bit: 0.125, Byte: 1, Kilobit: 125, Kilobyte: 1000, Kibibyte: 1024, Megabit: 125000, Megabyte: 1e6, Mebibyte: 1048576, Gigabit: 1.25e8, Gigabyte: 1e9, Gibibyte: 1073741824, Terabyte: 1e12, Tebibyte: 1099511627776, Petabyte: 1e15 } },
    pressure: { unit: 'Pa', units: { Pascal: 1, Hectopascal: 100, Kilopascal: 1000, Megapascal: 1e6, Bar: 100000, Millibar: 100, Atmosphere: 101325, 'Torr (mmHg)': 133.322368, 'PSI': 6894.757293 } },
    energy: { unit: 'J', units: { Joule: 1, Kilojoule: 1000, 'Calorie (cal)': 4.184, 'Kilocalorie (kcal)': 4184, 'Watt-hour': 3600, 'Kilowatt-hour': 3.6e6, Electronvolt: 1.602176634e-19, 'BTU': 1055.05585262, Therm: 1.05506e8, 'Foot-pound': 1.3558179483 } },
    power: { unit: 'W', units: { Watt: 1, Kilowatt: 1000, Megawatt: 1e6, 'Horsepower (mech)': 745.699872, 'Horsepower (metric)': 735.49875, 'BTU/hour': 0.29307107, 'Foot-pound/second': 1.3558179483 } },
    angle: { unit: 'rad', units: { Degree: 0.0174532925199433, Radian: 1, Gradian: 0.0157079632679, Arcminute: 0.000290888208666, Arcsecond: 0.0000048481368111, Turn: 6.28318530717959 } },
  };

  // Popular presets → [category, fromUnit, toUnit, label]
  const PRESETS: [string, string, string, string][] = [
    ['length', 'Centimetre', 'Inch', 'cm → in'],
    ['length', 'Kilometre', 'Mile', 'km → mi'],
    ['length', 'Metre', 'Foot', 'm → ft'],
    ['weight', 'Kilogram', 'Pound', 'kg → lb'],
    ['weight', 'Gram', 'Ounce', 'g → oz'],
    ['temp', 'Celsius', 'Fahrenheit', '°C → °F'],
    ['temp', 'Fahrenheit', 'Celsius', '°F → °C'],
    ['volume', 'Litre', 'Gallon (US)', 'L → gal'],
    ['speed', 'Kilometre/hour', 'Mile/hour', 'km/h → mph'],
    ['data', 'Gigabyte', 'Megabyte', 'GB → MB'],
  ];

  const fromVal = document.getElementById('uc-from-val') as HTMLInputElement;
  const toVal = document.getElementById('uc-to-val') as HTMLInputElement;
  const fromUnit = document.getElementById('uc-from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('uc-to-unit') as HTMLSelectElement;
  const precisionSel = document.getElementById('uc-precision') as HTMLSelectElement;
  const formulaEl = document.getElementById('uc-formula')!;
  const errEl = document.getElementById('uc-error')!;
  const tableBody = document.getElementById('uc-table')!;
  const presetsEl = document.getElementById('uc-presets')!;
  const copyBtn = document.getElementById('uc-copy') as HTMLButtonElement;
  const swapBtn = document.getElementById('uc-swap') as HTMLButtonElement;
  let cat = 'length';

  function fillUnits() {
    const units = Object.keys(DATA[cat].units);
    for (const sel of [fromUnit, toUnit]) {
      sel.innerHTML = units.map((u) => `<option>${u}</option>`).join('');
    }
    fromUnit.selectedIndex = 0;
    toUnit.selectedIndex = Math.min(1, units.length - 1);
  }

  function toBaseTemp(v: number, u: string) {
    // base = Celsius
    return u === 'Fahrenheit' ? (v - 32) * 5 / 9
      : u === 'Kelvin' ? v - 273.15
      : u === 'Rankine' ? (v - 491.67) * 5 / 9
      : v;
  }
  function fromBaseTemp(c: number, u: string) {
    return u === 'Fahrenheit' ? c * 9 / 5 + 32
      : u === 'Kelvin' ? c + 273.15
      : u === 'Rankine' ? (c + 273.15) * 9 / 5
      : c;
  }

  function convertValue(v: number, from: string, to: string): number {
    if (cat === 'temp') return fromBaseTemp(toBaseTemp(v, from), to);
    return (v * DATA[cat].units[from]) / DATA[cat].units[to];
  }

  // Format a number: fixed decimals, or Auto (trim zeros, exponential for extremes).
  function fmt(n: number): string {
    if (!Number.isFinite(n)) return '—';
    const p = precisionSel.value;
    if (p !== 'auto') return n.toFixed(Number(p));
    if (n === 0) return '0';
    const abs = Math.abs(n);
    if (abs >= 1e15 || abs < 1e-6) return n.toExponential(6).replace(/\.?0+e/, 'e');
    // Round to ~9 significant digits, then strip trailing zeros.
    const s = Number(n.toPrecision(9)).toString();
    return s;
  }

  const TEMP_FORMULA: Record<string, string> = {
    'Celsius→Fahrenheit': '°F = °C × 9/5 + 32',
    'Fahrenheit→Celsius': '°C = (°F − 32) × 5/9',
    'Celsius→Kelvin': 'K = °C + 273.15',
    'Kelvin→Celsius': '°C = K − 273.15',
    'Fahrenheit→Kelvin': 'K = (°F − 32) × 5/9 + 273.15',
    'Kelvin→Fahrenheit': '°F = (K − 273.15) × 9/5 + 32',
    'Celsius→Rankine': '°R = (°C + 273.15) × 9/5',
    'Rankine→Celsius': '°C = (°R − 491.67) × 5/9',
  };

  function updateFormula() {
    if (cat === 'temp') {
      formulaEl.textContent = TEMP_FORMULA[`${fromUnit.value}→${toUnit.value}`] ?? '';
    } else {
      formulaEl.textContent = '';
    }
  }

  function convert() {
    errEl.classList.add('hidden');
    updateFormula();
    const raw = fromVal.value.trim();
    if (raw === '') {
      toVal.value = '';
      renderTable(NaN);
      return;
    }
    const v = Number(raw);
    if (Number.isNaN(v)) {
      toVal.value = '';
      errEl.textContent = `"${raw}" is not a valid number.`;
      errEl.classList.remove('hidden');
      renderTable(NaN);
      return;
    }
    toVal.value = fmt(convertValue(v, fromUnit.value, toUnit.value));
    renderTable(v);
  }

  function renderTable(v: number) {
    const units = Object.keys(DATA[cat].units);
    tableBody.innerHTML = units.map((u) => {
      const val = Number.isNaN(v) ? '' : fmt(convertValue(v, fromUnit.value, u));
      const isActive = u === fromUnit.value || u === toUnit.value;
      const cls = isActive ? ' style="color:#f7f8f8"' : '';
      return `<tr class="border-b border-hairline last:border-0"><td class="px-4 py-2"${cls}>${u}</td><td class="px-4 py-2 text-right font-mono"${cls}>${val}</td></tr>`;
    }).join('');
  }

  function selectCat(next: string) {
    cat = next;
    document.querySelectorAll('.uc-tab').forEach((t) => {
      const active = (t as HTMLButtonElement).dataset.cat === next;
      t.setAttribute('aria-selected', String(active));
      t.classList.toggle('btn-primary', active);
      t.classList.toggle('btn-secondary', !active);
    });
    fillUnits();
    convert();
  }

  document.querySelectorAll<HTMLButtonElement>('.uc-tab').forEach((tab) => {
    tab.addEventListener('click', () => selectCat(tab.dataset.cat!));
  });

  [fromVal, fromUnit, toUnit].forEach((el) => el.addEventListener('input', convert));
  precisionSel.addEventListener('change', convert);

  swapBtn.addEventListener('click', () => {
    const f = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = f;
    // Carry the converted value across so the swap reads naturally.
    const cur = Number(toVal.value.replace(/[^\d.eE+-]/g, ''));
    if (Number.isFinite(cur) && toVal.value !== '') fromVal.value = String(cur);
    convert();
  });

  copyBtn.addEventListener('click', async () => {
    if (!toVal.value) return;
    await navigator.clipboard.writeText(toVal.value);
    copyBtn.textContent = 'Copied!';
    setTimeout(() => (copyBtn.textContent = 'Copy'), 1400);
  });

  // Build preset chips.
  presetsEl.innerHTML = PRESETS.map((p, i) =>
    `<button type="button" data-i="${i}" class="btn btn-tertiary px-3 py-1 text-[13px]">${p[3]}</button>`
  ).join('');
  presetsEl.querySelectorAll<HTMLButtonElement>('button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const [c, from, to] = PRESETS[Number(btn.dataset.i)];
      selectCat(c);
      fromUnit.value = from;
      toUnit.value = to;
      convert();
    });
  });

  // init
  selectCat('length');
</script>

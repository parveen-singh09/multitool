---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="purchase-order-generator">
  <div class="flex flex-col gap-5">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Buyer (your company)
        <textarea id="po-from" class="field min-h-24 resize-y text-[13px]">Acme Corp
123 Main St
Springfield, CA 90000
purchasing@acme.example</textarea>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Vendor / supplier
        <textarea id="po-to" class="field min-h-24 resize-y text-[13px]">Supplier Ltd
456 Industrial Rd
Riverside, NY 10001</textarea>
      </label>
    </div>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">PO #
        <input id="po-number" class="field" value="PO-2001" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Date
        <input id="po-date" type="date" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Currency
        <select id="po-currency" class="field"><option value="$">$ USD</option><option value="€">€ EUR</option><option value="£">£ GBP</option><option value="₹">₹ INR</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Tax %
        <input id="po-tax" type="number" min="0" max="100" step="0.1" value="0" class="field" />
      </label>
    </div>

    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <span class="text-sm text-ink-subtle">Ordered items</span>
        <button id="po-add" class="btn btn-secondary py-1 text-[13px]">+ Add item</button>
      </div>
      <div id="po-items" class="flex flex-col gap-2"></div>
    </div>

    <div class="flex items-center justify-between border-t border-hairline pt-4">
      <span class="text-sm text-ink-subtle">Total</span>
      <span id="po-total" class="font-mono text-xl text-ink"></span>
    </div>
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Notes / terms
      <input id="po-notes" class="field" value="Please confirm delivery date. Net 30 payment terms." />
    </label>

    <button id="po-dl" class="btn btn-primary w-fit">Download PDF</button>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free purchase order generator creates professional POs to send to your
      suppliers. Enter buyer and vendor details, add the items you're ordering with
      quantities and unit prices, and download a clean PDF with automatic totals.
      It's ideal for procurement and small-business ordering. Everything is
      generated in your browser and never uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { buildDocPdf, downloadPdf, subtotal, money, type LineItem } from '../../lib/pdfdoc';

  const $ = (id: string) => document.getElementById(id)!;
  const itemsWrap = $('po-items')!;
  let items: LineItem[] = [
    { description: 'Widget A', qty: 100, price: 2.5 },
    { description: 'Widget B', qty: 50, price: 4.0 },
  ];
  ($('po-date') as HTMLInputElement).value = new Date().toISOString().slice(0, 10);

  function renderItems() {
    itemsWrap.innerHTML = items.map((it, i) => `
      <div class="flex gap-2" data-i="${i}">
        <input class="po-desc field flex-1 text-[13px]" placeholder="Item" value="${it.description.replace(/"/g, '&quot;')}" />
        <input class="po-qty field w-20 text-[13px]" type="number" min="0" value="${it.qty}" />
        <input class="po-price field w-24 text-[13px]" type="number" min="0" step="0.01" value="${it.price}" />
        <button class="po-del btn btn-secondary px-3">×</button>
      </div>`).join('');
    itemsWrap.querySelectorAll<HTMLElement>('[data-i]').forEach((row) => {
      const i = Number(row.dataset.i);
      row.querySelector('.po-desc')!.addEventListener('input', (e) => { items[i].description = (e.target as HTMLInputElement).value; });
      row.querySelector('.po-qty')!.addEventListener('input', (e) => { items[i].qty = Number((e.target as HTMLInputElement).value) || 0; total(); });
      row.querySelector('.po-price')!.addEventListener('input', (e) => { items[i].price = Number((e.target as HTMLInputElement).value) || 0; total(); });
      row.querySelector('.po-del')!.addEventListener('click', () => { items.splice(i, 1); renderItems(); total(); });
    });
  }

  function total() {
    const cur = ($('po-currency') as HTMLSelectElement).value;
    const tax = Number(($('po-tax') as HTMLInputElement).value) || 0;
    const sub = subtotal(items);
    $('po-total').textContent = money(sub + sub * (tax / 100), cur);
  }

  $('po-add').addEventListener('click', () => { items.push({ description: '', qty: 1, price: 0 }); renderItems(); total(); });
  ['po-currency', 'po-tax'].forEach((id) => $(id).addEventListener('input', total));

  $('po-dl').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Generating…';
    try {
      const bytes = await buildDocPdf({
        docType: 'PURCHASE ORDER',
        number: ($('po-number') as HTMLInputElement).value,
        date: ($('po-date') as HTMLInputElement).value,
        fromLabel: 'Buyer', from: ($('po-from') as HTMLTextAreaElement).value.split('\n'),
        toLabel: 'Vendor', to: ($('po-to') as HTMLTextAreaElement).value.split('\n'),
        items, currency: ($('po-currency') as HTMLSelectElement).value,
        taxRate: Number(($('po-tax') as HTMLInputElement).value) || 0,
        notes: ($('po-notes') as HTMLInputElement).value,
      });
      downloadPdf(bytes, `${($('po-number') as HTMLInputElement).value || 'purchase-order'}.pdf`);
    } finally { btn.disabled = false; btn.textContent = 'Download PDF'; }
  });

  renderItems(); total();
</script>

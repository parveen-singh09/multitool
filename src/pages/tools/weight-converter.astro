---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="weight-converter">
  <UnitConverter slug="weight-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free weight and mass converter converts weight and mass between kilograms, grams, tonnes, pounds, ounces and stone. Type a value, pick your units, and the result plus a quick reference table update instantly. All maths happens locally in your browser.
    </p>
  </div>
</ToolLayout>

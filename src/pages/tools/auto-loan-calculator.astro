---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="auto-loan-calculator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Vehicle price
        <input id="al-price" type="number" min="0" step="100" class="field" value="30000" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Down payment
        <input id="al-down" type="number" min="0" step="100" class="field" value="5000" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Trade-in value
        <input id="al-trade" type="number" min="0" step="100" class="field" value="0" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Cash rebate / incentive
        <input id="al-rebate" type="number" min="0" step="100" class="field" value="0" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Sales tax (%)
        <input id="al-tax" type="number" min="0" step="0.01" class="field" value="0" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Title/registration/other fees
        <input id="al-fees" type="number" min="0" step="10" class="field" value="0" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Loan term (months)
        <input id="al-term" type="number" min="1" step="1" class="field" value="60" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Interest rate (APR %)
        <input id="al-rate" type="number" min="0" step="0.01" class="field" value="6" inputmode="decimal" />
      </label>
    </div>

    <label class="flex items-center gap-2 text-sm text-ink-subtle">
      <input id="al-include" type="checkbox" class="accent-primary" checked />
      Include sales tax &amp; fees in the loan (otherwise paid upfront)
    </label>

    <div class="panel panel-lift p-5 text-center">
      <div class="copy-wrap">
        <div id="al-payment" class="font-display text-2xl font-semibold text-primary-hover">—</div>
        <button type="button" class="copy-icon" data-copy-target="#al-payment" aria-label="Copy"></button>
      </div>
      <div class="mt-1 text-[13px] text-ink-subtle">Monthly payment</div>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="panel p-5 text-center"><div id="al-financed" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Amount financed</div></div>
      <div class="panel p-5 text-center"><div id="al-interest" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Total interest</div></div>
      <div class="panel p-5 text-center"><div id="al-total" class="font-mono text-xl text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Total cost</div></div>
    </div>

    <div class="panel p-5">
      <div class="flex flex-col gap-2 text-sm">
        <div class="flex items-center justify-between"><span class="text-ink-subtle">Sales tax</span><span id="al-taxamt" class="font-mono text-ink-muted">—</span></div>
        <div class="flex items-center justify-between border-t border-hairline pt-2"><span class="text-ink-subtle">Upfront payment (cash due at signing)</span><span id="al-upfront" class="font-mono text-ink-muted">—</span></div>
        <div class="flex items-center justify-between border-t border-hairline pt-2"><span class="text-ink-subtle">Total of payments</span><span id="al-totalpay" class="font-mono text-ink-muted">—</span></div>
      </div>
    </div>

    <details class="panel p-0">
      <summary class="cursor-pointer list-none px-5 py-4 text-sm font-medium text-ink hover:text-primary-hover">
        <span class="inline-flex items-center gap-2">▸ Amortization schedule (by year)</span>
      </summary>
      <div class="overflow-x-auto border-t border-hairline">
        <table class="w-full text-right text-[13px]">
          <thead class="text-ink-subtle">
            <tr class="border-b border-hairline">
              <th class="px-4 py-2 text-left font-medium">Year</th>
              <th class="px-4 py-2 font-medium">Principal</th>
              <th class="px-4 py-2 font-medium">Interest</th>
              <th class="px-4 py-2 font-medium">Balance</th>
            </tr>
          </thead>
          <tbody id="al-sched" class="font-mono text-ink-muted"></tbody>
        </table>
      </div>
    </details>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free auto loan calculator estimates your monthly car payment, the amount
      financed, total interest, and the full cost of the loan. It factors in your
      down payment, trade-in value, cash rebate, sales tax and title/registration
      fees — and lets you choose whether taxes and fees are rolled into the loan or
      paid upfront. A full amortization schedule shows how each year's payments
      split between principal and interest.
    </p>
  </div>
</ToolLayout>

<script>
  const ids = ['al-price', 'al-down', 'al-trade', 'al-rebate', 'al-tax', 'al-fees', 'al-term', 'al-rate'];
  const el: Record<string, HTMLInputElement> = {};
  ids.forEach((id) => (el[id] = document.getElementById(id) as HTMLInputElement));
  const includeEl = document.getElementById('al-include') as HTMLInputElement;

  const money = (n: number) => n.toLocaleString(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });
  const money0 = (n: number) => Math.round(n).toLocaleString();

  function reset() {
    ['al-payment', 'al-financed', 'al-interest', 'al-total', 'al-taxamt', 'al-upfront', 'al-totalpay'].forEach(
      (id) => (document.getElementById(id)!.textContent = '—'),
    );
    document.getElementById('al-sched')!.innerHTML = '';
  }

  function calc() {
    const price = Number(el['al-price'].value);
    const down = Number(el['al-down'].value);
    const trade = Number(el['al-trade'].value);
    const rebate = Number(el['al-rebate'].value);
    const taxPct = Number(el['al-tax'].value);
    const fees = Number(el['al-fees'].value);
    const n = Number(el['al-term'].value);
    const apr = Number(el['al-rate'].value);

    const taxable = Math.max(price - trade, 0);
    const taxAmt = taxable * (taxPct / 100);
    const netPrice = price - down - trade - rebate;
    const include = includeEl.checked;

    const financed = include ? netPrice + taxAmt + fees : netPrice;
    const upfront = down + (include ? 0 : taxAmt + fees);

    if (!(financed > 0) || !(n > 0)) { reset(); return; }

    const r = apr / 12 / 100;
    const emi = r === 0 ? financed / n : (financed * r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const totalPaid = emi * n;
    const interest = totalPaid - financed;

    document.getElementById('al-payment')!.textContent = money(emi);
    document.getElementById('al-financed')!.textContent = money(financed);
    document.getElementById('al-interest')!.textContent = money(interest);
    document.getElementById('al-total')!.textContent = money(totalPaid + upfront);
    document.getElementById('al-taxamt')!.textContent = money(taxAmt);
    document.getElementById('al-upfront')!.textContent = money(upfront);
    document.getElementById('al-totalpay')!.textContent = money(totalPaid);

    const sched = document.getElementById('al-sched')!;
    sched.innerHTML = '';
    let bal = financed, yrP = 0, yrI = 0, yr = 1;
    for (let m = 1; m <= n; m++) {
      const intr = bal * r;
      let prin = emi - intr;
      if (prin > bal) prin = bal;
      bal -= prin; yrP += prin; yrI += intr;
      if (m % 12 === 0 || m === n) {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-hairline/50';
        tr.innerHTML = `<td class="px-4 py-1.5 text-left text-ink-subtle">${yr}</td><td class="px-4 py-1.5">${money0(yrP)}</td><td class="px-4 py-1.5">${money0(yrI)}</td><td class="px-4 py-1.5">${money0(Math.max(0, bal))}</td>`;
        sched.appendChild(tr);
        yrP = 0; yrI = 0; yr++;
      }
    }
  }

  [...Object.values(el), includeEl].forEach((e) => e.addEventListener('input', calc));
  calc();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="standard-deviation-calculator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Numbers (separated by commas, spaces or new lines)
      <div class="copy-wrap">
        <textarea id="sd-in" class="field min-h-32 resize-y font-mono text-[13px]" placeholder="e.g. 10, 12, 23, 23, 16, 23, 21, 16" spellcheck="false">10, 12, 23, 23, 16, 23, 21, 16</textarea>
        <button type="button" class="copy-icon" data-copy-target="#sd-in" aria-label="Copy"></button>
      </div>
    </label>

    <p id="sd-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="sd-pop" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Population σ</div></div>
      <div class="panel panel-lift p-4"><div id="sd-sample" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Sample s</div></div>
      <div class="panel p-4"><div id="sd-var" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Variance (pop.)</div></div>
      <div class="panel p-4"><div id="sd-svar" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Variance (sample)</div></div>
      <div class="panel p-4"><div id="sd-sem" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Std error (SEM)</div></div>
      <div class="panel p-4"><div id="sd-mean" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Mean</div></div>
      <div class="panel p-4"><div id="sd-median" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Median</div></div>
      <div class="panel p-4"><div id="sd-min" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Min</div></div>
      <div class="panel p-4"><div id="sd-max" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Max</div></div>
      <div class="panel p-4"><div id="sd-range" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Range</div></div>
      <div class="panel p-4"><div id="sd-sum" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Sum</div></div>
      <div class="panel p-4"><div id="sd-count" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Count</div></div>
    </div>

    <details class="panel p-0">
      <summary class="cursor-pointer list-none px-5 py-4 text-sm font-medium text-ink hover:text-primary-hover">
        <span class="inline-flex items-center gap-2">▸ Step-by-step working</span>
      </summary>
      <div class="border-t border-hairline px-5 py-4">
        <div id="sd-steps" class="flex flex-col gap-2 font-mono text-[13px] text-ink-subtle"></div>
        <div class="mt-3 overflow-x-auto">
          <table class="w-full text-right text-[12px]">
            <thead class="text-ink-subtle"><tr class="border-b border-hairline"><th class="px-3 py-1.5 text-left font-medium">xᵢ</th><th class="px-3 py-1.5 font-medium">xᵢ − x̄</th><th class="px-3 py-1.5 font-medium">(xᵢ − x̄)²</th></tr></thead>
            <tbody id="sd-table" class="text-ink-muted"></tbody>
          </table>
        </div>
      </div>
    </details>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free standard deviation calculator computes both population (σ) and
      sample (s) standard deviation from a list of numbers, along with the
      variance, mean, sum and count. Use population when you have every data
      point, and sample when working from a subset. All calculations run in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('sd-in') as HTMLTextAreaElement;
  const err = document.getElementById('sd-error')!;
  const round = (n: number) => Math.round(n * 1e6) / 1e6;

  function calc() {
    err.classList.add('hidden');
    const nums = input.value.split(/[\s,]+/).filter((s) => s !== '').map(Number);
    const ids = ['sd-pop', 'sd-sample', 'sd-var', 'sd-svar', 'sd-sem', 'sd-mean', 'sd-median', 'sd-min', 'sd-max', 'sd-range', 'sd-sum', 'sd-count'];
    if (!nums.length) { ids.forEach((id) => (document.getElementById(id)!.textContent = '—')); document.getElementById('sd-steps')!.innerHTML = ''; document.getElementById('sd-table')!.innerHTML = ''; return; }
    if (nums.some(isNaN)) { err.textContent = 'Some values are not valid numbers.'; err.classList.remove('hidden'); return; }

    const n = nums.length;
    const sum = nums.reduce((a, b) => a + b, 0);
    const mean = sum / n;
    const sqDiff = nums.reduce((a, b) => a + (b - mean) ** 2, 0);
    const popVar = sqDiff / n;
    const sampleVar = n > 1 ? sqDiff / (n - 1) : 0;
    const sampleSd = Math.sqrt(sampleVar);
    const sem = n > 1 ? sampleSd / Math.sqrt(n) : NaN;

    const sorted = [...nums].sort((a, b) => a - b);
    const mid = Math.floor(n / 2);
    const median = n % 2 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;

    const set = (id: string, v: number | string) => (document.getElementById(id)!.textContent = typeof v === 'number' ? (isNaN(v) ? 'n/a' : String(round(v))) : v);
    set('sd-pop', Math.sqrt(popVar));
    set('sd-sample', n > 1 ? sampleSd : 'n/a');
    set('sd-var', popVar);
    set('sd-svar', n > 1 ? sampleVar : 'n/a');
    set('sd-sem', sem);
    set('sd-mean', mean);
    set('sd-median', median);
    set('sd-min', sorted[0]);
    set('sd-max', sorted[n - 1]);
    set('sd-range', sorted[n - 1] - sorted[0]);
    set('sd-sum', sum);
    set('sd-count', n);

    document.getElementById('sd-steps')!.innerHTML = [
      `Mean x̄ = ${round(sum)} / ${n} = ${round(mean)}`,
      `Σ(xᵢ − x̄)² = ${round(sqDiff)}`,
      `Population variance = ${round(sqDiff)} / ${n} = ${round(popVar)} → σ = √${round(popVar)} = ${round(Math.sqrt(popVar))}`,
      n > 1 ? `Sample variance = ${round(sqDiff)} / ${n - 1} = ${round(sampleVar)} → s = √${round(sampleVar)} = ${round(sampleSd)}` : '',
    ].filter(Boolean).map((s) => `<div>${s}</div>`).join('');
    document.getElementById('sd-table')!.innerHTML = nums
      .map((x) => `<tr class="border-b border-hairline/40"><td class="px-3 py-1 text-left">${round(x)}</td><td class="px-3 py-1">${round(x - mean)}</td><td class="px-3 py-1">${round((x - mean) ** 2)}</td></tr>`)
      .join('');
  }

  input.addEventListener('input', calc);
  calc();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="frequency-converter">
  <UnitConverter slug="frequency-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free frequency converter converts frequency between hertz, kilohertz, megahertz, gigahertz, revolutions per minute and radians per second. Useful for audio, radio and rotational speed. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

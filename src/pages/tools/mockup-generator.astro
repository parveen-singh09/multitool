---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="mockup-generator">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-[1fr_1.2fr]">
    <div class="flex flex-col gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Screenshot
        <input id="mk-file" type="file" accept="image/*" class="field file:mr-3 file:rounded-md file:border-0 file:bg-surface-2 file:px-3 file:py-1 file:text-ink" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Frame
        <select id="mk-frame" class="field">
          <option value="browser">Browser window</option>
          <option value="phone">Phone</option>
          <option value="laptop">Laptop</option>
          <option value="none">No frame (shadow only)</option>
        </select>
      </label>
      <label id="mk-url-row" class="flex flex-col gap-1 text-sm text-ink-subtle">Address bar text
        <input id="mk-url" class="field" value="yoursite.com" spellcheck="false" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Backdrop
          <select id="mk-bg" class="field">
            <option value="grad1">Lavender</option>
            <option value="grad2">Sunset</option>
            <option value="grad3">Ocean</option>
            <option value="grad4">Mint</option>
            <option value="solid">Solid color</option>
            <option value="none">Transparent</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Padding
          <input id="mk-pad" type="range" min="0" max="220" value="90" class="mt-2 w-full accent-primary" />
        </label>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-ink-subtle">Solid / tint
          <input id="mk-color" type="color" value="#5e6ad2" class="field h-9 w-14 cursor-pointer p-1" />
        </label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="mk-shadow" type="checkbox" class="accent-primary" checked /> Drop shadow</label>
        <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="mk-round" type="checkbox" class="accent-primary" checked /> Round corners</label>
      </div>
    </div>

    <div class="flex flex-col items-center gap-4">
      <canvas id="mk-canvas" class="w-full rounded-xl border border-hairline" style="max-height:420px;object-fit:contain"></canvas>
      <button id="mk-dl" class="btn btn-primary">Download PNG</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free mockup generator drops any screenshot into a polished browser window,
      phone or laptop frame, sitting on a clean gradient or solid backdrop with a soft
      shadow — the kind of hero image you'd put on a landing page, app store listing,
      changelog or social post. Adjust the padding, corners, address-bar text and
      backdrop, then export a high-resolution PNG. Your image is processed entirely in
      your browser and never uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const canvas = $('mk-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let img: HTMLImageElement | null = null;

  const GRADS: Record<string, [string, string]> = {
    grad1: ['#7c83ff', '#4048b5'],
    grad2: ['#ff8a5b', '#c74b6d'],
    grad3: ['#3aa4d6', '#1e3a8a'],
    grad4: ['#57d6a6', '#2f9e7e'],
  };

  const get = (id: string) => ($(id) as HTMLInputElement).value;
  const checked = (id: string) => ($(id) as HTMLInputElement).checked;

  function roundRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    r = Math.min(r, w / 2, h / 2);
    c.beginPath();
    c.moveTo(x + r, y);
    c.arcTo(x + w, y, x + w, y + h, r);
    c.arcTo(x + w, y + h, x, y + h, r);
    c.arcTo(x, y + h, x, y, r);
    c.arcTo(x, y, x + w, y, r);
    c.closePath();
  }

  function render() {
    const frame = get('mk-frame');
    const pad = Number(get('mk-pad'));
    const bgChoice = get('mk-bg');
    const shadow = checked('mk-shadow');
    const round = checked('mk-round');
    const color = get('mk-color');


    const iw = img ? img.naturalWidth : 1280;
    const ih = img ? img.naturalHeight : 800;
    const maxContent = 1200;
    const cScale = Math.min(1, maxContent / iw);
    const cw = Math.round(iw * cScale);
    const chrome = frame === 'browser' ? 46 : frame === 'laptop' ? 30 : frame === 'phone' ? 0 : 0;
    const bezel = frame === 'phone' ? 18 : frame === 'laptop' ? 16 : 0;
    const ch = Math.round(ih * cScale);

    const deviceW = cw + bezel * 2;
    const deviceH = ch + chrome + bezel * 2 + (frame === 'laptop' ? 24 : 0);

    const W = deviceW + pad * 2;
    const H = deviceH + pad * 2;
    canvas.width = W;
    canvas.height = H;


    ctx.clearRect(0, 0, W, H);
    if (bgChoice !== 'none') {
      if (bgChoice === 'solid') {
        ctx.fillStyle = color;
      } else {
        const [a, b] = GRADS[bgChoice];
        const g = ctx.createLinearGradient(0, 0, W, H);
        g.addColorStop(0, a); g.addColorStop(1, b);
        ctx.fillStyle = g;
      }
      ctx.fillRect(0, 0, W, H);
    }

    const dx = pad, dy = pad;
    const radius = round ? 16 : 0;


    if (shadow) {
      ctx.save();
      ctx.shadowColor = 'rgba(0,0,0,0.35)';
      ctx.shadowBlur = 60;
      ctx.shadowOffsetY = 30;
      ctx.fillStyle = '#0f1011';
      roundRect(ctx, dx, dy, deviceW, deviceH, radius);
      ctx.fill();
      ctx.restore();
    }

    ctx.save();
    if (frame === 'phone') {

      ctx.fillStyle = '#0b0b0d';
      roundRect(ctx, dx, dy, deviceW, deviceH, round ? 42 : 8);
      ctx.fill();
      ctx.fillStyle = '#000';
      roundRect(ctx, dx + deviceW / 2 - 40, dy + 8, 80, 16, 8);
      ctx.fill();
      drawContent(dx + bezel, dy + bezel, cw, ch, round ? 26 : 0);
    } else if (frame === 'browser') {
      ctx.fillStyle = '#1c1d1f';
      roundRect(ctx, dx, dy, deviceW, deviceH, radius);
      ctx.fill();

      const dots = ['#ff5f57', '#febc2e', '#28c840'];
      dots.forEach((cCol, i) => { ctx.fillStyle = cCol; ctx.beginPath(); ctx.arc(dx + 24 + i * 22, dy + 23, 7, 0, Math.PI * 2); ctx.fill(); });

      ctx.fillStyle = '#2a2b2e';
      roundRect(ctx, dx + 100, dy + 12, Math.max(120, deviceW - 140), 22, 11);
      ctx.fill();
      ctx.fillStyle = '#8a8f98';
      ctx.font = '13px Inter, system-ui, sans-serif';
      ctx.textBaseline = 'middle';
      ctx.fillText(get('mk-url'), dx + 116, dy + 24);
      drawContent(dx, dy + chrome, cw, ch, 0);
    } else if (frame === 'laptop') {
      ctx.fillStyle = '#1c1d1f';
      roundRect(ctx, dx, dy, deviceW, deviceH - 24, radius);
      ctx.fill();
      ctx.fillStyle = '#2a2b2e';
      ctx.fillRect(dx + deviceW / 2 - 6, dy + 8, 12, 12);
      drawContent(dx + bezel, dy + chrome, cw, ch, 6);

      ctx.fillStyle = '#3a3b3e';
      roundRect(ctx, dx - 30, dy + deviceH - 24, deviceW + 60, 24, 8);
      ctx.fill();
    } else {
      drawContent(dx, dy, cw, ch, radius);
    }
    ctx.restore();
  }

  function drawContent(x: number, y: number, w: number, h: number, r: number) {
    ctx.save();
    roundRect(ctx, x, y, w, h, r);
    ctx.clip();
    if (img) {
      ctx.drawImage(img, x, y, w, h);
    } else {
      const g = ctx.createLinearGradient(x, y, x + w, y + h);
      g.addColorStop(0, '#26272b'); g.addColorStop(1, '#141516');
      ctx.fillStyle = g; ctx.fillRect(x, y, w, h);
      ctx.fillStyle = '#8a8f98';
      ctx.font = '600 22px Inter, system-ui, sans-serif';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText('Upload a screenshot', x + w / 2, y + h / 2);
      ctx.textAlign = 'start';
    }
    ctx.restore();
  }

  $('mk-file').addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    const im = new Image();
    im.onload = () => { img = im; URL.revokeObjectURL(url); render(); };
    im.src = url;
  });

  function syncUrlRow() {
    ($('mk-url-row') as HTMLElement).style.display = get('mk-frame') === 'browser' ? '' : 'none';
  }

  ['mk-frame', 'mk-url', 'mk-bg', 'mk-pad', 'mk-color', 'mk-shadow', 'mk-round'].forEach((id) =>
    $(id).addEventListener('input', () => { syncUrlRow(); render(); })
  );

  $('mk-dl').addEventListener('click', () => {
    canvas.toBlob((b) => {
      if (!b) return;
      const url = URL.createObjectURL(b);
      const a = document.createElement('a');
      a.href = url; a.download = 'mockup.png'; a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }, 'image/png');
  });

  syncUrlRow();
  render();
</script>

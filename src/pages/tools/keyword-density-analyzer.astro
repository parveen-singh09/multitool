---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="keyword-density-analyzer">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Paste your content
      <textarea id="kd-in" class="field min-h-32 resize-y font-mono text-[13px]" placeholder="Paste an article or page copy to analyze keyword density…" spellcheck="false"></textarea>
    </label>

    <div class="flex flex-wrap items-center gap-4">
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="kd-stop" type="checkbox" checked /> Ignore common stopwords
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        Min word length
        <select id="kd-min" class="field w-auto py-1">
          <option value="1">1</option>
          <option value="2">2</option>
          <option value="3" selected>3</option>
          <option value="4">4</option>
          <option value="5">5</option>
        </select>
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        Phrase length
        <select id="kd-phrase" class="field w-auto py-1">
          <option value="1" selected>1 word</option>
          <option value="2">2 words</option>
          <option value="3">3 words</option>
        </select>
      </label>
    </div>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="kd-total" class="font-display text-xl font-semibold text-primary-hover">0</div><div class="mt-1 text-[13px] text-ink-subtle">Total words</div></div>
      <div class="panel p-4"><div id="kd-unique" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Unique terms</div></div>
      <div class="panel p-4"><div id="kd-counted" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Counted terms</div></div>
    </div>

    <div id="kd-out" class="text-[13px] text-ink-subtle">Paste content above to see keyword density.</div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free keyword density analyzer shows the most frequent words and
      multi-word phrases in your content, each with a count and a density
      percentage. Toggle common stopwords, set a minimum word length and choose
      one, two or three-word phrases to focus your SEO checks. All processing
      happens in your browser — nothing is sent to a server.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('kd-in') as HTMLTextAreaElement;
  const stopChk = document.getElementById('kd-stop') as HTMLInputElement;
  const minSel = document.getElementById('kd-min') as HTMLSelectElement;
  const phraseSel = document.getElementById('kd-phrase') as HTMLSelectElement;
  const out = document.getElementById('kd-out')!;
  const set = (id: string, val: string) => { document.getElementById(id)!.textContent = val; };

  const STOPWORDS = new Set([
    'a', 'an', 'and', 'are', 'as', 'at', 'be', 'been', 'but', 'by', 'can', 'do',
    'for', 'from', 'had', 'has', 'have', 'he', 'her', 'his', 'i', 'if', 'in',
    'into', 'is', 'it', 'its', 'me', 'my', 'no', 'not', 'of', 'on', 'or', 'our',
    'she', 'so', 'that', 'the', 'their', 'them', 'then', 'there', 'these', 'they',
    'this', 'to', 'up', 'us', 'was', 'we', 'were', 'what', 'when', 'which', 'who',
    'will', 'with', 'would', 'you', 'your', 'about', 'all', 'also', 'am', 'any',
    'because', 'been', 'more', 'most', 'other', 'out', 'over', 'than', 'too', 'very',
  ]);

  function tokenize(text: string): string[] {
    return text.toLowerCase().match(/[a-z0-9']+/g) || [];
  }

  function analyze() {
    const useStop = stopChk.checked;
    const minLen = Number(minSel.value);
    const phraseLen = Number(phraseSel.value);
    const tokens = tokenize(input.value);
    const total = tokens.length;

    set('kd-total', String(total));

    const freq = new Map<string, number>();
    if (phraseLen === 1) {
      for (const t of tokens) {
        if (t.length < minLen) continue;
        if (useStop && STOPWORDS.has(t)) continue;
        freq.set(t, (freq.get(t) || 0) + 1);
      }
    } else {
      for (let i = 0; i <= tokens.length - phraseLen; i++) {
        const slice = tokens.slice(i, i + phraseLen);
        if (slice.some((w) => w.length < minLen)) continue;
        if (useStop && slice.some((w) => STOPWORDS.has(w))) continue;
        const phrase = slice.join(' ');
        freq.set(phrase, (freq.get(phrase) || 0) + 1);
      }
    }

    const rows = [...freq.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
    set('kd-unique', String(freq.size));
    set('kd-counted', String(rows.reduce((s, [, c]) => s + c, 0)));

    if (!rows.length || !total) {
      out.textContent = 'Paste content above to see keyword density.';
      return;
    }

    const top = rows.slice(0, 50);
    const denom = phraseLen === 1 ? total : Math.max(1, total - phraseLen + 1);
    let html = '<div class="panel overflow-hidden"><table class="w-full text-left text-[13px]">';
    html += '<thead><tr class="border-b border-hairline text-ink-subtle">';
    html += '<th class="px-3 py-2 font-medium">Term</th><th class="px-3 py-2 font-medium">Count</th><th class="px-3 py-2 font-medium">Density</th></tr></thead><tbody>';
    for (const [term, count] of top) {
      const pct = ((count / denom) * 100).toFixed(2);
      const safe = term.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      html += `<tr class="border-b border-hairline/50"><td class="px-3 py-1.5 font-mono text-ink">${safe}</td><td class="px-3 py-1.5 font-mono text-ink">${count}</td><td class="px-3 py-1.5 font-mono text-ink-subtle">${pct}%</td></tr>`;
    }
    html += '</tbody></table></div>';
    out.innerHTML = html;
  }

  input.addEventListener('input', analyze);
  stopChk.addEventListener('change', analyze);
  minSel.addEventListener('change', analyze);
  phraseSel.addEventListener('change', analyze);
  analyze();
</script>

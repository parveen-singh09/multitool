---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="readability-checker">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Text to analyze
      <div class="copy-wrap">
        <textarea id="read-in" class="field min-h-32 w-full resize-y font-mono text-[13px]" placeholder="Paste your text here…" spellcheck="false">The quick brown fox jumps over the lazy dog. Readability scores estimate how easy a passage is to understand. Shorter sentences and simpler words generally make text easier to read.</textarea>
        <button type="button" class="copy-icon" data-copy-target="#read-in" aria-label="Copy"></button>
      </div>
    </label>

    <div class="grid grid-cols-1 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="read-flesch" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Flesch Reading Ease</div></div>
      <div class="panel p-4"><div id="read-fk" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Flesch-Kincaid grade</div></div>
      <div class="panel p-4"><div id="read-fog" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Gunning Fog index</div></div>
    </div>

    <div class="panel p-4">
      <div class="text-[13px] text-ink-subtle">Interpretation</div>
      <div id="read-interp" class="mt-1 text-[13px] text-ink">—</div>
      <div id="read-stats" class="mt-3 font-mono text-[13px] text-ink-muted">—</div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free readability checker scores pasted text with three well-known
      formulas: Flesch Reading Ease, the Flesch-Kincaid grade level and the
      Gunning Fog index. It counts sentences, words and syllables — using a
      heuristic for syllables — then reports each score with a plain-language
      interpretation of how hard the text is to read. Use it to make articles,
      emails and documentation clearer.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('read-in') as HTMLTextAreaElement;
  const fleschEl = document.getElementById('read-flesch')!;
  const fkEl = document.getElementById('read-fk')!;
  const fogEl = document.getElementById('read-fog')!;
  const interpEl = document.getElementById('read-interp')!;
  const statsEl = document.getElementById('read-stats')!;

  function countSyllables(word: string): number {
    const w = word.toLowerCase().replace(/[^a-z]/g, '');
    if (w.length === 0) return 0;
    if (w.length <= 3) return 1;
    let s = w
      .replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '')
      .replace(/^y/, '');
    const groups = s.match(/[aeiouy]{1,2}/g);
    const count = groups ? groups.length : 0;
    return Math.max(1, count);
  }

  function fleschLabel(score: number): string {
    if (score >= 90) return 'Very easy — understood by an average 11-year-old.';
    if (score >= 80) return 'Easy — conversational English.';
    if (score >= 70) return 'Fairly easy to read.';
    if (score >= 60) return 'Plain English — understood by 13–15 year olds.';
    if (score >= 50) return 'Fairly difficult to read.';
    if (score >= 30) return 'Difficult — best suited to college readers.';
    return 'Very difficult — best suited to graduates.';
  }

  function reset() {
    fleschEl.textContent = '—';
    fkEl.textContent = '—';
    fogEl.textContent = '—';
    interpEl.textContent = '—';
    statsEl.textContent = '—';
  }

  function round(n: number): number {
    return Math.round(n * 10) / 10;
  }

  function analyze() {
    const text = input.value.trim();
    if (text === '') { reset(); return; }

    const words = text.match(/[A-Za-z0-9']+/g) || [];
    const sentenceCount = Math.max(1, (text.match(/[.!?]+(?=\s|$)/g) || []).length);
    const wordCount = words.length;
    if (wordCount === 0) { reset(); return; }

    let syllableCount = 0;
    let complexWords = 0;
    for (const word of words) {
      const syl = countSyllables(word);
      syllableCount += syl;
      if (syl >= 3) complexWords++;
    }

    const wordsPerSentence = wordCount / sentenceCount;
    const syllablesPerWord = syllableCount / wordCount;

    const flesch = 206.835 - 1.015 * wordsPerSentence - 84.6 * syllablesPerWord;
    const fk = 0.39 * wordsPerSentence + 11.8 * syllablesPerWord - 15.59;
    const fog = 0.4 * (wordsPerSentence + 100 * (complexWords / wordCount));

    fleschEl.textContent = String(round(flesch));
    fkEl.textContent = String(round(fk));
    fogEl.textContent = String(round(fog));
    interpEl.textContent = fleschLabel(flesch);
    statsEl.textContent =
      `${wordCount} words · ${sentenceCount} sentence${sentenceCount === 1 ? '' : 's'} · ` +
      `${syllableCount} syllables · ${round(wordsPerSentence)} words/sentence`;
  }

  input.addEventListener('input', analyze);
  analyze();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="fake-id-generator">
  <div class="flex flex-col gap-4">
    <div class="panel flex items-start gap-3 p-4">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-ink-subtle" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20ZM12 8v5M12 16h.01"/></svg>
      <p class="text-[13px] leading-relaxed text-ink-subtle">This generates <strong class="text-ink">fictional identity fields for software testing</strong> only. It is not a real ID document and must never be used to deceive, impersonate or defraud anyone.</p>
    </div>
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Gender
        <select id="fi-sex" class="field w-32"><option value="any" selected>Any</option><option value="male">Male</option><option value="female">Female</option></select>
      </label>
      <button id="fi-gen" class="btn btn-primary ml-auto">Generate identity</button>
      <button id="fi-copy" class="btn btn-secondary">Copy</button>
    </div>
    <div id="fi-card" class="panel panel-lift grid grid-cols-1 gap-x-6 gap-y-2 p-5 sm:grid-cols-2"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free fake ID data generator assembles a full set of fictional identity
      fields — name, date of birth, address, phone, email and a random ID number —
      in one click, so you can populate test records and demos with a coherent
      persona. Every field is invented and uses safe test ranges. It is strictly
      for QA and development, never for real identification. Runs in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  import { firstName, lastName, email, phoneUS, address, birthDate, type Sex } from '../../lib/fakegen';
  import { randString } from '../../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const sexEl = $('fi-sex') as HTMLSelectElement;
  const card = $('fi-card')!;
  let current: Record<string, string> = {};

  function generate() {
    const sex = sexEl.value as Sex;
    const first = firstName(sex);
    const last = lastName();
    const a = address();
    current = {
      'Full name': `${first} ${last}`,
      'Date of birth': birthDate(21, 75),
      'ID number': randString(9, 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789'),
      'Address': `${a.street}, ${a.city}, ${a.stateAbbr} ${a.zip}`,
      'Phone': phoneUS(),
      'Email': email(first, last),
    };
    card.innerHTML = Object.entries(current).map(([k, v]) =>
      `<div class="flex flex-col gap-0.5"><span class="text-[12px] uppercase tracking-wide text-ink-tertiary">${k}</span><span class="font-mono text-[14px] text-ink">${v}</span></div>`
    ).join('');
  }

  sexEl.addEventListener('input', generate);
  $('fi-gen').addEventListener('click', generate);
  $('fi-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const text = Object.entries(current).map(([k, v]) => `${k}: ${v}`).join('\n');
    await navigator.clipboard.writeText(text);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
  generate();
</script>

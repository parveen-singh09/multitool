---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="terms-conditions-generator">
  <div class="flex flex-col gap-4">
    <div class="panel flex items-start gap-3 p-4">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-ink-subtle" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20ZM12 8v5M12 16h.01"/></svg>
      <p class="text-[13px] leading-relaxed text-ink-subtle">This produces a <strong class="text-ink">starting-point template</strong>, not legal advice. Have a qualified professional review terms before you publish them. Everything is generated in your browser — nothing is uploaded.</p>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Company / site name<input id="tc-name" class="field" value="Acme" /></label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Website URL<input id="tc-url" class="field" value="https://acme.example" /></label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Governing country / state<input id="tc-law" class="field" value="California, USA" /></label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Contact email<input id="tc-email" class="field" value="legal@acme.example" /></label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Effective date<input id="tc-date" class="field" value="July 12, 2026" /></label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Applies to
        <select id="tc-platform" class="field">
          <option value="website">Website</option>
          <option value="app">Mobile app</option>
          <option value="both">Website &amp; app</option>
        </select>
      </label>
    </div>

    <fieldset class="flex flex-wrap gap-x-5 gap-y-3">
      <legend class="w-full pb-1 text-xs uppercase tracking-wide text-ink-tertiary">Clauses to include</legend>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-accounts" type="checkbox" class="accent-[#5e6ad2]" checked /> User accounts</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-payments" type="checkbox" class="accent-[#5e6ad2]" /> Paid services</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-refunds" type="checkbox" class="accent-[#5e6ad2]" /> Refunds &amp; cancellations</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-ugc" type="checkbox" class="accent-[#5e6ad2]" /> User content</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-prohibited" type="checkbox" class="accent-[#5e6ad2]" checked /> Prohibited uses</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-cookies" type="checkbox" class="accent-[#5e6ad2]" checked /> Cookies</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-links" type="checkbox" class="accent-[#5e6ad2]" checked /> Hyperlinking &amp; external links</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-iframes" type="checkbox" class="accent-[#5e6ad2]" /> iFrames</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-age" type="checkbox" class="accent-[#5e6ad2]" /> Age restriction (13+)</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-dmca" type="checkbox" class="accent-[#5e6ad2]" /> DMCA / copyright</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-indemnity" type="checkbox" class="accent-[#5e6ad2]" /> Indemnification</label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle"><input id="tc-warranty" type="checkbox" class="accent-[#5e6ad2]" checked /> Warranty disclaimer</label>
    </fieldset>

    <div class="flex flex-wrap gap-2">
      <button id="tc-gen" class="btn btn-primary">Generate</button>
      <button id="tc-copy" class="btn btn-secondary">Copy</button>
      <button id="tc-dl-txt" class="btn btn-secondary">Download .txt</button>
      <button id="tc-dl-md" class="btn btn-secondary">Download .md</button>
      <button id="tc-dl-html" class="btn btn-secondary">Download .html</button>
    </div>

    <textarea id="tc-out" class="field min-h-96 resize-y text-[13px] leading-relaxed" readonly></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free terms and conditions generator builds a customizable terms of
      service agreement for your website or app. Fill in your company name,
      jurisdiction and contact details, then toggle the clauses that apply —
      user accounts, paid services, refunds, user content, prohibited uses,
      cookies, hyperlinking, iFrames, age restrictions, DMCA, indemnification
      and warranty disclaimers. It assembles a complete, numbered document you
      can copy or download as plain text, Markdown or HTML.
    </p>
    <p>
      Unlike tools that email you a link or redirect you elsewhere, this one
      generates everything instantly in your browser and never uploads your
      details. It's a solid starting point, but not a substitute for legal
      advice — have a professional review your terms before publishing.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const out = $('tc-out') as HTMLTextAreaElement;
  const v = (id: string) => ($(id) as HTMLInputElement | HTMLSelectElement).value.trim();
  const on = (id: string) => ($(id) as HTMLInputElement).checked;

  // Returns the assembled document as an array of {title, body} sections plus a header.
  function build() {
    const name = v('tc-name') || 'the Company';
    const url = v('tc-url') || 'our website';
    const law = v('tc-law') || 'your jurisdiction';
    const email = v('tc-email') || 'us';
    const date = v('tc-date') || new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const platform = v('tc-platform');
    const svc = platform === 'app' ? 'application' : platform === 'both' ? 'website and application' : 'website';
    const Svc = svc.charAt(0).toUpperCase() + svc.slice(1);

    const sections: { title: string; body: string }[] = [];
    sections.push({ title: 'Agreement to Terms', body: `By accessing ${url} (the "Service"), a ${svc} operated by ${name}, you agree to be bound by these Terms and Conditions. If you disagree with any part of these terms, you may not access the Service.` });
    sections.push({ title: 'Use of the Service', body: `You agree to use the Service only for lawful purposes and in a way that does not infringe the rights of others or restrict or inhibit their use and enjoyment of the Service.` });

    if (on('tc-age')) sections.push({ title: 'Age Requirement', body: `You must be at least 13 years old to use the Service. If you are under the age of majority in your jurisdiction, you may only use the Service with the involvement and consent of a parent or legal guardian.` });
    if (on('tc-accounts')) sections.push({ title: 'User Accounts', body: `When you create an account, you must provide accurate and complete information. You are responsible for safeguarding your password and for all activity that occurs under your account. You must notify us immediately of any unauthorized use.` });
    if (on('tc-payments')) sections.push({ title: 'Purchases and Payment', body: `If you purchase a paid service, you agree to provide current, complete and accurate payment information. You authorize us to charge your chosen payment method for the fees due. All fees are stated exclusive of taxes unless otherwise noted.` });
    if (on('tc-refunds')) sections.push({ title: 'Refunds and Cancellations', body: `Except where required by law, fees are non-refundable. You may cancel a subscription at any time; cancellation takes effect at the end of the current billing period and you will retain access until then.` });
    if (on('tc-ugc')) sections.push({ title: 'User Content', body: `You retain ownership of content you submit to the Service, but you grant ${name} a worldwide, non-exclusive, royalty-free license to use, reproduce, display and distribute it in connection with operating the Service. You are solely responsible for the content you post and represent that you have the rights to share it.` });
    if (on('tc-prohibited')) sections.push({ title: 'Prohibited Uses', body: `You may not use the Service to: violate any law or regulation; infringe the intellectual property or privacy rights of others; transmit malware or harmful code; attempt to gain unauthorized access to the Service or its systems; harass, abuse or harm another person; or scrape, data-mine or reverse-engineer any part of the Service.` });
    if (on('tc-cookies')) sections.push({ title: 'Cookies', body: `The Service uses cookies to remember your preferences and understand how it is used. By using the Service you consent to the use of cookies in accordance with our policy. You can instruct your browser to refuse cookies, though some features of the Service may not function properly.` });

    sections.push({ title: 'Intellectual Property', body: `The Service and its original content, features and functionality are and will remain the exclusive property of ${name} and its licensors, and are protected by copyright, trademark and other laws. Our trademarks may not be used without our prior written consent.` });

    if (on('tc-links')) sections.push({ title: 'Hyperlinking and External Links', body: `Government agencies, search engines and news organizations may link to the Service without prior written approval, provided the link is not deceptive and does not falsely imply sponsorship or endorsement. The Service may also contain links to third-party websites that are not owned or controlled by ${name}. We have no control over, and assume no responsibility for, the content or practices of any third-party sites.` });
    if (on('tc-iframes')) sections.push({ title: 'iFrames', body: `Without prior approval and written permission, you may not create frames around the Service's web pages that alter in any way the visual presentation or appearance of the Service.` });
    if (on('tc-dmca')) sections.push({ title: 'Copyright and DMCA Notices', body: `We respect the intellectual property rights of others. If you believe material on the Service infringes your copyright, send a notice to ${email} including a description of the work, its location on the Service, your contact information, and a statement made in good faith. We will respond to valid notices as required by applicable law.` });

    sections.push({ title: 'Content Liability', body: `We are not responsible for any content that appears on third-party sites that link to the Service. You agree to protect and defend us against all claims arising out of or based upon content on any such site.` });

    if (on('tc-warranty')) sections.push({ title: 'Disclaimer of Warranties', body: `The Service is provided on an "AS IS" and "AS AVAILABLE" basis without warranties of any kind, whether express or implied, including but not limited to implied warranties of merchantability, fitness for a particular purpose and non-infringement. We do not warrant that the Service will be uninterrupted, secure or error-free.` });
    if (on('tc-indemnity')) sections.push({ title: 'Indemnification', body: `You agree to indemnify, defend and hold harmless ${name} and its officers, employees and agents from any claim or demand, including reasonable legal fees, arising out of your use of the Service, your violation of these Terms, or your violation of any rights of a third party.` });

    sections.push({ title: 'Limitation of Liability', body: `To the fullest extent permitted by law, in no event shall ${name} be liable for any indirect, incidental, special, consequential or punitive damages, or any loss of profits or revenues, arising from your use of the Service.` });
    sections.push({ title: 'Termination', body: `We may terminate or suspend your access to the Service immediately, without prior notice or liability, for any reason, including if you breach these Terms. Upon termination, your right to use the Service will cease immediately.` });
    sections.push({ title: 'Reservation of Rights', body: `We reserve the right to request that you remove any link to the Service and to amend these Terms and our linking policy at any time. By continuing to use the Service you agree to be bound by these terms.` });
    sections.push({ title: 'Governing Law', body: `These Terms shall be governed by and construed in accordance with the laws of ${law}, without regard to its conflict of law provisions. Any disputes arising under these Terms shall be subject to the exclusive jurisdiction of the courts located there.` });
    sections.push({ title: 'Changes to These Terms', body: `We reserve the right to modify or replace these Terms at any time at our sole discretion. If a revision is material, we will provide reasonable notice. Continued use of the Service after changes become effective constitutes acceptance of the revised Terms.` });
    sections.push({ title: 'Contact Us', body: `If you have any questions about these Terms, please contact us at ${email}.` });

    return { name, date, Svc, url, sections };
  }

  function toText() {
    const { date, sections } = build();
    const parts = [`TERMS AND CONDITIONS\n\nLast updated: ${date}\n`];
    sections.forEach((s, i) => parts.push(`${i + 1}. ${s.title}\n${s.body}`));
    return parts.join('\n\n');
  }

  function toMarkdown() {
    const { date, sections } = build();
    const parts = [`# Terms and Conditions\n\n_Last updated: ${date}_`];
    sections.forEach((s, i) => parts.push(`## ${i + 1}. ${s.title}\n\n${s.body}`));
    return parts.join('\n\n');
  }

  const esc = (t: string) => t.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]!));

  function toHtml() {
    const { name, date, sections } = build();
    const body = sections
      .map((s, i) => `    <section>\n      <h2>${i + 1}. ${esc(s.title)}</h2>\n      <p>${esc(s.body)}</p>\n    </section>`)
      .join('\n');
    return `<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Terms and Conditions — ${esc(name)}</title>
  <style>
    body { max-width: 720px; margin: 3rem auto; padding: 0 1.25rem; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; line-height: 1.6; color: #1a1a1a; }
    h1 { font-size: 1.9rem; margin-bottom: .25rem; }
    h2 { font-size: 1.15rem; margin-top: 2rem; }
    .updated { color: #666; font-size: .9rem; }
    p { margin: .5rem 0 0; }
  </style>
</head>
<body>
  <main>
    <h1>Terms and Conditions</h1>
    <p class="updated">Last updated: ${esc(date)}</p>
${body}
  </main>
</body>
</html>`;
  }

  function render() {
    out.value = toText();
  }

  function download(content: string, filename: string, type: string) {
    const url = URL.createObjectURL(new Blob([content], { type }));
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  const inputs = ['tc-name', 'tc-url', 'tc-law', 'tc-email', 'tc-date', 'tc-platform', 'tc-accounts', 'tc-payments', 'tc-refunds', 'tc-ugc', 'tc-prohibited', 'tc-cookies', 'tc-links', 'tc-iframes', 'tc-age', 'tc-dmca', 'tc-indemnity', 'tc-warranty'];
  inputs.forEach((id) => $(id).addEventListener('input', render));
  $('tc-gen').addEventListener('click', render);
  $('tc-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
  $('tc-dl-txt').addEventListener('click', () => download(toText(), 'terms-and-conditions.txt', 'text/plain'));
  $('tc-dl-md').addEventListener('click', () => download(toMarkdown(), 'terms-and-conditions.md', 'text/markdown'));
  $('tc-dl-html').addEventListener('click', () => download(toHtml(), 'terms-and-conditions.html', 'text/html'));

  render();
</script>

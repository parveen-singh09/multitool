---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="fuel-economy-converter">
  <UnitConverter slug="fuel-economy-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free fuel economy converter converts fuel economy between US MPG, imperial MPG, litres per 100 km and kilometres per litre. Because L/100km is an inverse measure, this converter uses the correct reciprocal maths. Runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

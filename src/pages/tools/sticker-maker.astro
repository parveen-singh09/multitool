---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="sticker-maker">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Image
      <input id="stm-file" type="file" accept="image/*" class="field" />
    </label>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Border thickness (px)
        <input id="stm-border" type="number" min="0" max="120" step="1" value="24" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Corner radius (px)
        <input id="stm-radius" type="number" min="0" max="300" step="1" value="48" class="field" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Border color
        <input id="stm-color" type="color" value="#ffffff" class="field h-10 cursor-pointer p-1" />
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle sm:mt-6">
        <input id="stm-shadow" type="checkbox" checked class="h-4 w-4" />
        Drop shadow
      </label>
    </div>

    <p id="stm-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="panel p-4">
      <canvas id="stm-canvas" class="max-w-full h-auto rounded-[8px]" aria-label="Sticker preview"></canvas>
    </div>

    <div class="flex gap-2">
      <button id="stm-download" class="btn btn-primary">Download PNG</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free sticker maker gives any image the die-cut sticker look. Drop in a
      picture and add an adjustable white (or colored) border, rounded corners and
      an optional drop shadow, then download a transparent PNG ready for chats,
      prints or product mockups. Works best with images that already have a
      transparent background. Everything is composed locally in your browser and is
      never uploaded to a server.
    </p>
  </div>
</ToolLayout>

<script>
  const fileEl = document.getElementById('stm-file') as HTMLInputElement;
  const borderEl = document.getElementById('stm-border') as HTMLInputElement;
  const radiusEl = document.getElementById('stm-radius') as HTMLInputElement;
  const colorEl = document.getElementById('stm-color') as HTMLInputElement;
  const shadowEl = document.getElementById('stm-shadow') as HTMLInputElement;
  const canvas = document.getElementById('stm-canvas') as HTMLCanvasElement;
  const err = document.getElementById('stm-error')!;
  const ctx = canvas.getContext('2d')!;

  let image: HTMLImageElement | null = null;

  function loadFile(file: File): Promise<HTMLImageElement> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = () => reject(new Error('Could not decode that image.'));
        img.src = reader.result as string;
      };
      reader.onerror = () => reject(new Error('Could not read that file.'));
      reader.readAsDataURL(file);
    });
  }

  function roundedRect(c: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, r: number) {
    const rr = Math.max(0, Math.min(r, w / 2, h / 2));
    c.beginPath();
    c.moveTo(x + rr, y);
    c.arcTo(x + w, y, x + w, y + h, rr);
    c.arcTo(x + w, y + h, x, y + h, rr);
    c.arcTo(x, y + h, x, y, rr);
    c.arcTo(x, y, x + w, y, rr);
    c.closePath();
  }

  function render() {
    err.classList.add('hidden');
    if (!image) {
      canvas.width = 1;
      canvas.height = 1;
      return;
    }

    const border = Math.max(0, Number(borderEl.value) || 0);
    const radius = Math.max(0, Number(radiusEl.value) || 0);
    const shadow = shadowEl.checked;
    const margin = shadow ? Math.round(border + 24) : Math.round(border * 0.5) + 2;

    const iw = image.width;
    const ih = image.height;
    const stickerW = iw + border * 2;
    const stickerH = ih + border * 2;

    canvas.width = stickerW + margin * 2;
    canvas.height = stickerH + margin * 2;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const sx = margin;
    const sy = margin;

    // White die-cut border shape with optional shadow.
    ctx.save();
    if (shadow) {
      ctx.shadowColor = 'rgba(0,0,0,0.35)';
      ctx.shadowBlur = 20;
      ctx.shadowOffsetX = 0;
      ctx.shadowOffsetY = 8;
    }
    ctx.fillStyle = colorEl.value;
    roundedRect(ctx, sx, sy, stickerW, stickerH, radius);
    ctx.fill();
    ctx.restore();

    // Clip the image to the inner rounded rectangle.
    const innerRadius = Math.max(0, radius - border);
    ctx.save();
    roundedRect(ctx, sx + border, sy + border, iw, ih, innerRadius);
    ctx.clip();
    ctx.drawImage(image, sx + border, sy + border, iw, ih);
    ctx.restore();
  }

  fileEl.addEventListener('change', async () => {
    const file = fileEl.files && fileEl.files[0];
    if (!file) return;
    try {
      image = await loadFile(file);
      render();
    } catch (e) {
      err.textContent = (e as Error).message;
      err.classList.remove('hidden');
    }
  });

  [borderEl, radiusEl, colorEl, shadowEl].forEach((el) => el.addEventListener('input', render));

  document.getElementById('stm-download')!.addEventListener('click', () => {
    if (!image) {
      err.textContent = 'Add an image first.';
      err.classList.remove('hidden');
      return;
    }
    canvas.toBlob((blob) => {
      if (!blob) return;
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.download = 'toolcities-sticker.png';
      link.href = url;
      link.click();
      URL.revokeObjectURL(url);
    }, 'image/png');
  });

  render();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ssl-csr-generator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Common Name (domain)
        <input id="cs-cn" class="field font-mono text-[13px]" value="example.com" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Organization (O)
        <input id="cs-o" class="field" value="Example Inc" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Organizational Unit (OU)
        <input id="cs-ou" class="field" value="IT" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">City / Locality (L)
        <input id="cs-l" class="field" value="San Francisco" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">State / Province (ST)
        <input id="cs-st" class="field" value="California" spellcheck="false" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Country (2-letter, C)
        <input id="cs-c" class="field font-mono" value="US" maxlength="2" spellcheck="false" />
      </label>
    </div>
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Key size
        <select id="cs-bits" class="field w-36"><option value="2048" selected>RSA 2048</option><option value="3072">RSA 3072</option><option value="4096">RSA 4096</option></select>
      </label>
      <label class="flex flex-1 flex-col gap-1 text-sm text-ink-subtle">Subject Alternative Names (comma-separated)
        <input id="cs-san" class="field font-mono text-[13px]" placeholder="www.example.com, api.example.com" />
      </label>
      <button id="cs-gen" type="button" class="btn btn-primary">Generate CSR</button>
    </div>
    <p id="cs-status" class="text-[13px] text-ink-subtle"></p>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">CSR (PEM)
      <textarea id="cs-csr" class="field min-h-40 resize-y font-mono text-[12px]" readonly></textarea>
    </label>
    <button id="cs-csrcopy" type="button" class="btn btn-secondary w-fit">Copy CSR</button>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Private key (PEM)
      <textarea id="cs-key" class="field min-h-40 resize-y font-mono text-[12px]" readonly></textarea>
    </label>
    <button id="cs-keycopy" type="button" class="btn btn-secondary w-fit">Copy private key</button>
    <p class="text-[13px] text-ink-tertiary">Keep the private key safe — you'll need it to install the certificate your CA issues.</p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SSL CSR generator creates a certificate signing request and its
      matching RSA private key for requesting an SSL/TLS certificate from a
      certificate authority. Fill in your domain and organization details, add any
      Subject Alternative Names, and generate. The CSR is what you submit to your
      CA; the private key stays with you. Both are generated locally in your
      browser with an in-page crypto engine, so your private key never leaves your
      device.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const statusEl = $('cs-status')!;
  const csrEl = $('cs-csr') as HTMLTextAreaElement;
  const keyEl = $('cs-key') as HTMLTextAreaElement;
  const v = (id: string) => ($(id) as HTMLInputElement).value.trim();

  $('cs-gen').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const bits = Number((($('cs-bits')) as HTMLSelectElement).value);
    btn.disabled = true;
    statusEl.textContent = `Generating ${bits}-bit key and CSR… this can take a few seconds.`;
    csrEl.value = ''; keyEl.value = '';
    await new Promise((r) => setTimeout(r, 30));
    try {
      const forge = (await import('node-forge')).default;
      const keys = await new Promise<any>((resolve, reject) => {
        forge.pki.rsa.generateKeyPair({ bits, workers: -1 }, (err: any, kp: any) => (err ? reject(err) : resolve(kp)));
      });
      const csr = forge.pki.createCertificationRequest();
      csr.publicKey = keys.publicKey;
      const attrs = [
        { name: 'commonName', value: v('cs-cn') },
        { name: 'organizationName', value: v('cs-o') },
        { shortName: 'OU', value: v('cs-ou') },
        { name: 'localityName', value: v('cs-l') },
        { shortName: 'ST', value: v('cs-st') },
        { name: 'countryName', value: v('cs-c') },
      ].filter((a) => a.value);
      csr.setSubject(attrs);

      const sans = v('cs-san').split(',').map((s) => s.trim()).filter(Boolean);
      if (sans.length) {
        csr.setAttributes([{
          name: 'extensionRequest',
          extensions: [{ name: 'subjectAltName', altNames: sans.map((dns) => ({ type: 2, value: dns })) }],
        }]);
      }

      csr.sign(keys.privateKey, forge.md.sha256.create());
      csrEl.value = forge.pki.certificationRequestToPem(csr);
      keyEl.value = forge.pki.privateKeyToPem(keys.privateKey);
      statusEl.textContent = 'Done — CSR and private key generated locally.';
    } catch (err) {
      statusEl.textContent = 'CSR generation failed. Please check your inputs and try again.';
    } finally {
      btn.disabled = false;
    }
  });

  const copyBtn = (id: string, src: HTMLTextAreaElement, label: string) =>
    $(id).addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      await navigator.clipboard.writeText(src.value);
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = label), 1500);
    });
  copyBtn('cs-csrcopy', csrEl, 'Copy CSR');
  copyBtn('cs-keycopy', keyEl, 'Copy private key');
</script>

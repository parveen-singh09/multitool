---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="xml-formatter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="xf-beautify" class="btn btn-primary">Beautify</button>
      <button id="xf-minify" class="btn btn-secondary">Minify</button>
      <button id="xf-copy" class="btn btn-secondary">Copy</button>
      <button id="xf-download" class="btn btn-secondary">Download</button>
      <button id="xf-clear" class="btn btn-tertiary">Clear</button>

      <label class="btn btn-secondary cursor-pointer">
        Upload file
        <input id="xf-file" type="file" accept=".xml,.svg,.xsl,.xslt,.rss,.atom,application/xml,text/xml" class="hidden" />
      </label>

      <label class="ml-auto flex items-center gap-2 text-sm text-ink-subtle">
        Indent
        <select id="xf-indent" class="field w-auto py-1">
          <option value="2">2 spaces</option>
          <option value="3">3 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
    </div>

    <div id="xf-status" class="hidden rounded-md border px-3 py-2 text-sm" role="status"></div>

    <div id="xf-caret-wrap" class="hidden">
      <div class="eyebrow">Error location</div>
      <pre id="xf-caret" class="panel p-4 mt-2 overflow-x-auto font-mono text-[13px] text-ink whitespace-pre"></pre>
    </div>

    <div class="hl-edit field p-0" style="height:18rem;resize:vertical;overflow:hidden">
      <pre class="hl-block" aria-hidden="true"><code id="xf-input-hl" class="hljs" style="background:transparent"></code></pre>
      <textarea
        id="xf-input"
        spellcheck="false"
        autocapitalize="off"
        autocomplete="off"
        autocorrect="off"
        placeholder="Paste XML here, drag a file in, or upload — e.g. <root><item>value</item></root>"
        aria-label="XML input"
      ></textarea>
    </div>

    <div id="xf-stats" class="hidden flex flex-wrap gap-2 text-[12px]"></div>

    <div id="xf-view-wrap" class="hidden flex flex-col gap-2">
      <div class="flex items-center gap-2">
        <div class="eyebrow">Tree view</div>
        <div class="ml-auto flex gap-2">
          <button id="xf-expand" class="btn btn-tertiary py-1">Expand all</button>
          <button id="xf-collapse" class="btn btn-tertiary py-1">Collapse all</button>
        </div>
      </div>
      <div id="xf-tree" class="panel p-4 overflow-x-auto font-mono text-[13px] leading-relaxed"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free XML formatter beautifies XML with clean, consistent indentation
      or minifies it to a single line, with an adjustable indent of 2, 3 or 4
      spaces or a tab. Paste text, upload a file, or drag one in. Unlike simple
      regex formatters, it parses your document with the browser's own XML engine
      and pretty-prints from the parse tree, so attributes, comments, CDATA
      sections, processing instructions and mixed content all survive formatting
      intact. Invalid XML is reported with the exact line and column plus a caret
      under the offending character. A collapsible, syntax-highlighted tree view
      lets you explore large documents, and a stats bar shows byte size, element
      and attribute counts, and nesting depth. Everything runs entirely in your
      browser, so your data is never uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { wireInput } from '../../lib/highlight';

  const input = document.getElementById('xf-input') as HTMLTextAreaElement;
  const inputHl = document.getElementById('xf-input-hl') as HTMLElement;
  const status = document.getElementById('xf-status')!;
  const caretWrap = document.getElementById('xf-caret-wrap')!;
  const caret = document.getElementById('xf-caret')!;
  const indentSel = document.getElementById('xf-indent') as HTMLSelectElement;
  const statsEl = document.getElementById('xf-stats')!;
  const viewWrap = document.getElementById('xf-view-wrap')!;
  const treeEl = document.getElementById('xf-tree')!;

  const refresh = wireInput(input, inputHl, () => 'xml');

  function getIndent(): string {
    const v = indentSel.value;
    return v === 'tab' ? '\t' : ' '.repeat(Number(v));
  }

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  function hideResults() {
    caretWrap.classList.add('hidden');
    statsEl.classList.add('hidden');
    viewWrap.classList.add('hidden');
  }

  function parseXml(xml: string): { ok: true; doc: Document } | { ok: false; msg: string } {
    const doc = new DOMParser().parseFromString(xml, 'application/xml');
    const err = doc.querySelector('parsererror');
    if (err) return { ok: false, msg: (err.textContent || 'XML is not well-formed').replace(/\s+/g, ' ').trim() };
    return { ok: true, doc };
  }

  function lineColFromError(msg: string): { line: number; col: number } | null {
    const line = msg.match(/line\s*:?\s*(\d+)/i);
    const col = msg.match(/column\s*:?\s*(\d+)/i);
    if (!line) return null;
    return { line: Number(line[1]), col: col ? Number(col[1]) : 1 };
  }

  function renderCaret(text: string, line: number, col: number) {
    const lines = text.split('\n');
    const target = lines[line - 1] ?? '';
    const shown = target.length > 200 ? target.slice(0, 200) + '…' : target;
    const pointer = ' '.repeat(Math.max(0, col - 1)) + '^';
    caret.textContent = `line ${line}, column ${col}\n\n${shown}\n${pointer}`;
    caretWrap.classList.remove('hidden');
  }

  // ---- Escaping (DOM decodes entities, so re-encode on serialize) ----
  const escText = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const escAttr = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');

  const ELEMENT = 1, TEXT = 3, CDATA = 4, PI = 7, COMMENT = 8;

  // A whitespace-only text node between elements is insignificant layout, drop it.
  // ponytail: this normalizes whitespace inside mixed content, like every
  // pretty-printer does. Round-tripping byte-exact text is a non-goal for a formatter.
  const significant = (n: ChildNode) => !(n.nodeType === TEXT && !(n as Text).data.trim());

  function openTag(el: Element): string {
    const attrs = Array.from(el.attributes)
      .map((a) => ` ${a.name}="${escAttr(a.value)}"`)
      .join('');
    return `<${el.tagName}${attrs}`;
  }

  function serializeNode(node: ChildNode, unit: string, depth: number): string {
    const pad = unit.repeat(depth);
    switch (node.nodeType) {
      case ELEMENT: {
        const el = node as Element;
        const kids = Array.from(el.childNodes).filter(significant);
        if (kids.length === 0) return `${pad}${openTag(el)}/>`;
        const onlyText = kids.every((c) => c.nodeType === TEXT || c.nodeType === CDATA);
        if (onlyText) {
          const inner = kids
            .map((c) => (c.nodeType === CDATA ? `<![CDATA[${(c as CDATASection).data}]]>` : escText((c as Text).data.trim())))
            .join('');
          return `${pad}${openTag(el)}>${inner}</${el.tagName}>`;
        }
        const inner = kids.map((c) => serializeNode(c, unit, depth + 1)).join('\n');
        return `${pad}${openTag(el)}>\n${inner}\n${pad}</${el.tagName}>`;
      }
      case TEXT: return pad + escText((node as Text).data.trim());
      case CDATA: return pad + `<![CDATA[${(node as CDATASection).data}]]>`;
      case COMMENT: return pad + ``;
      case PI: return pad + `<?${(node as ProcessingInstruction).target} ${(node as ProcessingInstruction).data}?>`;
      default: return '';
    }
  }

  function beautify(doc: Document, src: string, unit: string): string {
    // The XML declaration and DOCTYPE aren't reliably in the DOM tree; carry them
    // over from the source verbatim.
    const decl = src.match(/^\s*<\?xml[^>]*\?>/i)?.[0].trim();
    const doctype = src.match(/<!DOCTYPE[^>]*(\[[\s\S]*?\])?\s*>/i)?.[0].trim();
    const body = Array.from(doc.childNodes)
      .filter(significant)
      .map((n) => serializeNode(n, unit, 0))
      .filter(Boolean)
      .join('\n');
    return [decl, doctype, body].filter(Boolean).join('\n');
  }

  function minify(xml: string): string {
    return xml.replace(/\r\n/g, '\n').replace(/>\s+</g, '><').replace(/\n/g, '').trim();
  }

  // ---- Stats ----
  function pill(text: string): HTMLElement {
    const el = document.createElement('span');
    el.className = 'status-badge';
    el.textContent = text;
    return el;
  }

  function depthOf(el: Element): number {
    const kids = Array.from(el.children);
    return 1 + (kids.length ? Math.max(...kids.map(depthOf)) : 0);
  }

  function renderStats(doc: Document, text: string) {
    statsEl.replaceChildren();
    const bytes = new Blob([text]).size;
    const size = bytes < 1024 ? `${bytes} B` : `${(bytes / 1024).toFixed(1)} KB`;
    const all = doc.getElementsByTagName('*');
    let attrCount = 0;
    for (const el of Array.from(all)) attrCount += el.attributes.length;
    statsEl.appendChild(pill(`Size ${size}`));
    statsEl.appendChild(pill(`Elements ${all.length}`));
    statsEl.appendChild(pill(`Attributes ${attrCount}`));
    if (doc.documentElement) statsEl.appendChild(pill(`Depth ${depthOf(doc.documentElement)}`));
    statsEl.classList.remove('hidden');
  }

  // ---- Collapsible, syntax-highlighted tree (built via DOM — safe with untrusted input) ----
  const COLORS: Record<string, string> = {
    tag: 'var(--color-primary-hover)',
    attr: '#e0b978',
    attrval: '#7fd88f',
    text: 'var(--color-ink)',
    punct: 'var(--color-ink-subtle)',
    muted: 'var(--color-ink-subtle)',
  };

  function span(text: string, kind: keyof typeof COLORS): HTMLElement {
    const s = document.createElement('span');
    s.textContent = text;
    s.style.color = COLORS[kind];
    return s;
  }

  function attrSpans(target: HTMLElement, el: Element) {
    for (const a of Array.from(el.attributes)) {
      target.appendChild(span(` ${a.name}`, 'attr'));
      target.appendChild(span('=', 'punct'));
      target.appendChild(span(`"${a.value}"`, 'attrval'));
    }
  }

  function buildTreeNode(el: Element): HTMLElement {
    const childEls = Array.from(el.childNodes).filter(significant);
    const elementKids = childEls.filter((c) => c.nodeType === ELEMENT);
    const textKids = childEls.filter((c) => c.nodeType === TEXT || c.nodeType === CDATA);

    // Leaf: no element children — render on one line.
    if (elementKids.length === 0) {
      const line = document.createElement('div');
      line.style.whiteSpace = 'pre-wrap';
      line.appendChild(span(`<${el.tagName}`, 'tag'));
      attrSpans(line, el);
      if (textKids.length === 0) {
        line.appendChild(span('/>', 'punct'));
      } else {
        line.appendChild(span('>', 'punct'));
        line.appendChild(span(textKids.map((t) => (t as Text).data.trim()).join(''), 'text'));
        line.appendChild(span(`</${el.tagName}>`, 'tag'));
      }
      return line;
    }

    const details = document.createElement('details');
    details.open = true;
    details.className = 'xf-node';

    const summary = document.createElement('summary');
    summary.style.cursor = 'pointer';
    summary.style.listStyle = 'none';
    summary.appendChild(span(`<${el.tagName}`, 'tag'));
    attrSpans(summary, el);
    summary.appendChild(span('>', 'punct'));
    const count = span(`  ${elementKids.length} ${elementKids.length === 1 ? 'child' : 'children'}`, 'muted');
    count.classList.add('xf-count');
    summary.appendChild(count);
    details.appendChild(summary);

    const body = document.createElement('div');
    body.style.paddingLeft = '1.25rem';
    body.style.borderLeft = '1px solid var(--color-hairline)';
    body.style.marginLeft = '0.25rem';
    for (const c of childEls) {
      if (c.nodeType === ELEMENT) body.appendChild(buildTreeNode(c as Element));
      else {
        const t = document.createElement('div');
        t.style.whiteSpace = 'pre-wrap';
        t.appendChild(span((c as Text).data.trim(), 'text'));
        body.appendChild(t);
      }
    }
    details.appendChild(body);

    const closer = document.createElement('div');
    closer.appendChild(span(`</${el.tagName}>`, 'tag'));
    details.appendChild(closer);
    return details;
  }

  function renderTree(doc: Document) {
    if (!doc.documentElement) return;
    treeEl.replaceChildren(buildTreeNode(doc.documentElement));
    viewWrap.classList.remove('hidden');
  }

  // ---- Core process ----
  function process(doMinify: boolean) {
    const src = input.value.trim();
    if (!src) { hideResults(); status.classList.add('hidden'); return; }
    const res = parseXml(src);
    if (!res.ok) {
      hideResults();
      const lc = lineColFromError(res.msg);
      if (lc) {
        showStatus(`Not well-formed at line ${lc.line}, column ${lc.col}: ${res.msg}`, false);
        renderCaret(src, lc.line, lc.col);
      } else {
        showStatus(`Not well-formed: ${res.msg}`, false);
      }
      return;
    }
    input.value = doMinify ? minify(src) : beautify(res.doc, src, getIndent());
    refresh();
    caretWrap.classList.add('hidden');
    showStatus('Well-formed XML ✓', true);
    renderStats(res.doc, input.value);
    renderTree(res.doc);
  }

  document.getElementById('xf-beautify')!.addEventListener('click', () => process(false));
  document.getElementById('xf-minify')!.addEventListener('click', () => process(true));

  document.getElementById('xf-clear')!.addEventListener('click', () => {
    input.value = '';
    refresh();
    status.classList.add('hidden');
    hideResults();
  });

  document.getElementById('xf-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('xf-copy')!;
    await navigator.clipboard.writeText(input.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });

  document.getElementById('xf-download')!.addEventListener('click', () => {
    if (!input.value.trim()) return;
    const blob = new Blob([input.value], { type: 'application/xml' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'data.xml';
    a.click();
    URL.revokeObjectURL(url);
  });

  // File upload + drag & drop
  const fileInput = document.getElementById('xf-file') as HTMLInputElement;
  async function loadFile(file: File) {
    input.value = await file.text();
    refresh();
    process(false);
  }
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) loadFile(fileInput.files[0]); });
  input.addEventListener('dragover', (e) => { e.preventDefault(); });
  input.addEventListener('drop', (e) => {
    const file = (e as DragEvent).dataTransfer?.files?.[0];
    if (file) { e.preventDefault(); loadFile(file); }
  });

  // Tree expand/collapse all
  const setAll = (open: boolean) =>
    treeEl.querySelectorAll('details').forEach((d) => ((d as HTMLDetailsElement).open = open));
  document.getElementById('xf-expand')!.addEventListener('click', () => setAll(true));
  document.getElementById('xf-collapse')!.addEventListener('click', () => setAll(false));
</script>

<style>
  .xf-node > summary::before {
    content: '▸';
    display: inline-block;
    width: 1rem;
    color: var(--color-ink-subtle);
    transition: transform 0.12s ease;
  }
  .xf-node[open] > summary::before { transform: rotate(90deg); }
  .xf-node > summary { user-select: none; }
  .xf-node[open] > summary .xf-count { display: none; }
  .xf-node > summary:hover { background: var(--color-surface-2); border-radius: var(--radius-xs); }
</style>

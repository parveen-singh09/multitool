---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="secret-key-generator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Key size
        <select id="sk-bits" class="field">
          <option value="16">128-bit</option>
          <option value="24">192-bit</option>
          <option value="32" selected>256-bit</option>
          <option value="48">384-bit</option>
          <option value="64">512-bit</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Encoding
        <select id="sk-enc" class="field">
          <option value="hex" selected>hex</option>
          <option value="base64">base64</option>
          <option value="base64url">base64url</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="sk-count" type="number" min="1" max="100" value="3" class="field" />
      </label>
    </div>
    <div class="flex flex-wrap items-center gap-4">
      <button id="sk-gen" class="btn btn-primary ml-auto">Generate</button>
      <button id="sk-copy" class="btn btn-secondary">Copy all</button>
    </div>
    <textarea id="sk-out" class="field min-h-56 resize-y font-mono text-[13px]" readonly aria-label="Generated secret keys"></textarea>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free secret key generator produces cryptographically strong keys from
      128 up to 512 bits, encoded as hex, base64 or base64url. These are ideal for
      JWT signing secrets, session keys, encryption keys and application secrets
      you drop into environment variables. Every key is generated with the Web
      Crypto API.
    </p>
  </div>
</ToolLayout>

<script>
  import { randBytes } from '../../lib/random';
  import { toHex, toBase64, toBase64Url } from '../../lib/encoding';

  const $ = (id: string) => document.getElementById(id)!;
  const bitsEl = $('sk-bits') as HTMLSelectElement;
  const encEl = $('sk-enc') as HTMLSelectElement;
  const countEl = $('sk-count') as HTMLInputElement;
  const out = $('sk-out') as HTMLTextAreaElement;

  function encode(b: Uint8Array): string {
    if (encEl.value === 'base64') return toBase64(b);
    if (encEl.value === 'base64url') return toBase64Url(b);
    return toHex(b);
  }

  function generate() {
    const nbytes = Number(bitsEl.value);
    const n = Math.max(1, Math.min(100, Number(countEl.value) || 1));
    const list: string[] = [];
    for (let i = 0; i < n; i++) list.push(encode(randBytes(nbytes)));
    out.value = list.join('\n');
  }

  ['sk-bits', 'sk-enc', 'sk-count'].forEach((id) => $(id).addEventListener('input', generate));
  $('sk-gen').addEventListener('click', generate);
  $('sk-copy').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    await navigator.clipboard.writeText(out.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy all'), 1500);
  });
  generate();
</script>

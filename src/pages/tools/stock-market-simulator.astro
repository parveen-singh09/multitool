---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="stock-market-simulator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel panel-lift p-4"><div id="sms-price" class="font-display text-xl font-semibold text-primary-hover">$100.00</div><div class="mt-1 text-[13px] text-ink-subtle">Price (SIMCO)</div></div>
      <div class="panel p-4"><div id="sms-cash" class="font-mono text-lg text-ink">$10,000</div><div class="mt-1 text-[13px] text-ink-subtle">Cash</div></div>
      <div class="panel p-4"><div id="sms-shares" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Shares</div></div>
      <div class="panel p-4"><div id="sms-value" class="font-mono text-lg text-ink">$10,000</div><div class="mt-1 text-[13px] text-ink-subtle">Portfolio</div></div>
    </div>

    <div class="panel panel-lift p-4">
      <canvas id="sms-chart" class="h-56 w-full" role="img" aria-label="Simulated stock price over time"></canvas>
    </div>

    <p id="sms-pnl" class="min-h-5 text-center text-[13px] text-ink-subtle" role="status">Profit / loss: $0.00</p>

    <div class="flex flex-wrap items-end justify-center gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Quantity
        <input id="sms-qty" type="number" min="1" value="10" class="field w-28" />
      </label>
      <button id="sms-buy" class="btn btn-primary">Buy</button>
      <button id="sms-sell" class="btn btn-secondary">Sell</button>
      <button id="sms-pause" class="btn btn-tertiary">Pause</button>
      <button id="sms-reset" class="btn btn-secondary">Reset</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free stock market simulator generates a live stock price with a random
      walk that ticks on a timer, so you can practice trading without any risk.
      Start with virtual cash, buy and sell shares of the fictional ticker SIMCO,
      and track your shares, cash and total portfolio value while a canvas line
      chart plots the price history in real time. This is for practice and
      education only — no real money is involved and it is not investment advice.
      Everything runs entirely in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;

  const START_CASH = 10000;
  const START_PRICE = 100;

  let price = START_PRICE;
  let cash = START_CASH;
  let shares = 0;
  const history: number[] = [START_PRICE];
  let timer: number | null = null;

  const canvas = $('sms-chart') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const qtyInput = $('sms-qty') as HTMLInputElement;
  const pnlEl = $('sms-pnl')!;
  const pauseBtn = $('sms-pause') as HTMLButtonElement;

  const fmt = (n: number) => n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  function step() {
    // Random walk with a tiny mean-reversion pull toward the start price so it
    // stays in a plausible range over long sessions.
    const drift = (START_PRICE - price) * 0.002;
    const shock = (Math.random() - 0.5) * price * 0.04;
    price = Math.max(1, price + drift + shock);
    history.push(price);
    if (history.length > 300) history.shift();
    render();
  }

  function portfolioValue() { return cash + shares * price; }

  function render() {
    $('sms-price').textContent = '$' + fmt(price);
    $('sms-cash').textContent = '$' + fmt(cash);
    $('sms-shares').textContent = shares.toLocaleString();
    $('sms-value').textContent = '$' + fmt(portfolioValue());
    const pnl = portfolioValue() - START_CASH;
    pnlEl.textContent = `Profit / loss: ${pnl >= 0 ? '+' : '−'}$${fmt(Math.abs(pnl))}`;
    pnlEl.style.color = pnl >= 0 ? '#27a644' : '#e5484d';
    draw();
  }

  function draw() {
    const dpr = window.devicePixelRatio || 1;
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    if (canvas.width !== w * dpr || canvas.height !== h * dpr) {
      canvas.width = w * dpr;
      canvas.height = h * dpr;
    }
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, w, h);

    const pad = 8;
    const min = Math.min(...history);
    const max = Math.max(...history);
    const range = max - min || 1;
    const n = history.length;
    const x = (i: number) => pad + (i / Math.max(1, n - 1)) * (w - pad * 2);
    const y = (v: number) => h - pad - ((v - min) / range) * (h - pad * 2);

    // baseline grid line at the starting price if in range
    ctx.strokeStyle = '#23252a';
    ctx.lineWidth = 1;
    if (START_PRICE >= min && START_PRICE <= max) {
      ctx.beginPath();
      ctx.moveTo(pad, y(START_PRICE));
      ctx.lineTo(w - pad, y(START_PRICE));
      ctx.stroke();
    }

    // area fill
    ctx.beginPath();
    ctx.moveTo(x(0), y(history[0]));
    for (let i = 1; i < n; i++) ctx.lineTo(x(i), y(history[i]));
    ctx.lineTo(x(n - 1), h - pad);
    ctx.lineTo(x(0), h - pad);
    ctx.closePath();
    ctx.fillStyle = 'rgba(94,106,210,0.12)';
    ctx.fill();

    // price line
    ctx.beginPath();
    ctx.moveTo(x(0), y(history[0]));
    for (let i = 1; i < n; i++) ctx.lineTo(x(i), y(history[i]));
    ctx.strokeStyle = '#5e6ad2';
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  function buy() {
    const qty = Math.floor(Number(qtyInput.value) || 0);
    if (qty <= 0) return;
    const cost = qty * price;
    if (cost > cash) { pnlEl.textContent = 'Not enough cash for that order.'; return; }
    cash -= cost; shares += qty; render();
  }

  function sell() {
    const qty = Math.floor(Number(qtyInput.value) || 0);
    if (qty <= 0) return;
    if (qty > shares) { pnlEl.textContent = 'You do not own that many shares.'; return; }
    cash += qty * price; shares -= qty; render();
  }

  function start() {
    if (timer !== null) return;
    timer = window.setInterval(step, 1000);
    pauseBtn.textContent = 'Pause';
  }

  function pause() {
    if (timer !== null) { window.clearInterval(timer); timer = null; pauseBtn.textContent = 'Resume'; }
    else start();
  }

  function reset() {
    if (timer !== null) { window.clearInterval(timer); timer = null; }
    price = START_PRICE; cash = START_CASH; shares = 0;
    history.length = 0; history.push(START_PRICE);
    start();
    render();
  }

  $('sms-buy').addEventListener('click', buy);
  $('sms-sell').addEventListener('click', sell);
  pauseBtn.addEventListener('click', pause);
  $('sms-reset').addEventListener('click', reset);
  window.addEventListener('resize', draw);
  window.addEventListener('beforeunload', () => { if (timer !== null) window.clearInterval(timer); });

  render();
  start();
</script>

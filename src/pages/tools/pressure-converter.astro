---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="pressure-converter">
  <UnitConverter slug="pressure-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free pressure converter converts pressure between pascals, kilopascals, bar, psi, atmospheres and mmHg (torr). Great for engineering, weather and tyre pressures. Runs entirely in your browser with no server round-trips.
    </p>
  </div>
</ToolLayout>

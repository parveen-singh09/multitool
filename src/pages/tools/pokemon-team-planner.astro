---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="pokemon-team-planner">
  <style is:inline>@import url("/pokemon-planner/style.css");</style>

  <article class="team-planner">
    <template id="team-slot">
      <li class="slot slot_empty" data-slug="" data-type="" data-tera="">
        <div class="slot__remove-button slot__bg-type-1">
          <figure class="slot__bg-type-2"><img class="slot__pokemon-render" src="/pokemon-planner/img/pokemon/0000_000_uk_n.png" alt=""></figure>
        </div>
        <div class="slot__info">
          <div class="slot__name-container">
            <span class="slot__name">???</span>
            <span class="slot__form slot__form_none"></span>
          </div>
          <ol class="slot__type-container">
            <li class="slot__type"></li>
            <li class="slot__type"></li>
          </ol>
        </div>
        <div class="slot__toggle-container">
          <button class="slot__toggle slot__toggle_hidden slot__toggle_female" title="Toggle Gender">&female;</button>
          <button class="slot__toggle slot__toggle_hidden slot__toggle_regular" title="Toggle Shiny">✨</button>
          <button class="slot__toggle slot__toggle_hidden slot__toggle_tera slot__toggle_tera_none" title="Terastallize">🔯</button>
        </div>
      </li>
    </template>
    <template id="tally">
      <li class="tally">
        <span class="tally__type-symbol">???</span>
        <ol class="tally__marks">
          <li class="tally__mark" data-slug="">0</li>
          <li class="tally__mark" data-slug="">0</li>
          <li class="tally__mark" data-slug="">0</li>
          <li class="tally__mark" data-slug="">0</li>
          <li class="tally__mark" data-slug="">0</li>
          <li class="tally__mark" data-slug="">0</li>
        </ol>
      </li>
    </template>

    <div class="head">
      <header class="head__header">
        <p>Select a game, then click a Pokémon below to add it to your team, and click it again to remove it. Share your team with the URL.</p>
      </header>
      <p class="type-analysis__note">Blue tally marks indicate resistances, immunities, or <abbr title="Same-Type Attack Bonus">STAB</abbr> coverage. Red tally marks indicate weakness.</p>
    </div>
    <div class="tail"></div>
  </article>

  <script is:inline type="module" src="/pokemon-planner/js/main.js"></script>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Pokémon team planner helps you build and analyze a six-Pokémon team for
      any mainline game — from Red, Blue and Yellow through Scarlet and Violet, plus
      Legends: Arceus, Let's Go, Colosseum, XD, and HOME. Pick your game and the tool
      shows only the Pokémon actually catchable in that version, region by region.
    </p>
    <p>
      Click a Pokémon to slot it in, toggle gender differences and shiny sprites,
      terastallize in Scarlet/Violet, or hit Randomize to roll a full team. Live type
      analysis tallies your team's combined weaknesses, resistances, and offensive
      coverage as you build. Filter the dex by type, generation, evolution stage, colour,
      body shape, egg group, or HM/field moves, and search by name.
    </p>
    <p>
      Your team is saved in the URL, so you can
      bookmark it or share it with a friend. Type analysis uses type only — abilities like
      Levitate and Wonder Guard are not factored in, and coverage disregards movepools.
    </p>
    <p>
      Pokémon data and sprites are sourced from the open-source
      <a href="https://github.com/richi3f/pokemon-team-planner" class="text-primary-hover underline">richi3f/pokemon-team-planner</a>
      project (MIT). Pokémon is © Nintendo, 1995–2026.
    </p>
  </div>
</ToolLayout>

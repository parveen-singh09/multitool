---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="pdf417-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Data to encode
      <textarea id="pf-text" class="field min-h-24 resize-y font-mono text-[13px]" placeholder="Enter text or data…" spellcheck="false">TOOLCITIES PDF417 SAMPLE</textarea>
    </label>

    <div class="flex justify-center rounded-[8px] border border-hairline bg-white p-6">
      <canvas id="pf-canvas" class="max-w-full"></canvas>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="pf-png" type="button" class="btn btn-primary">Download PNG</button>
      <button id="pf-svg" type="button" class="btn btn-secondary">Download SVG</button>
    </div>
    <p id="pf-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PDF417 generator encodes text and data into a high-capacity
      PDF417 stacked 2D barcode — the wide, multi-row format printed on driver's
      licenses, boarding passes and shipping labels. Enter your content, preview
      it, and download it as a PNG or scalable SVG. Encoding happens entirely in
      your browser, so nothing you type is ever uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import { toCanvas, toSVG } from '../../lib/barcode';

  const textEl = document.getElementById('pf-text') as HTMLTextAreaElement;
  const canvas = document.getElementById('pf-canvas') as HTMLCanvasElement;
  const err = document.getElementById('pf-error')!;
  const BCID = 'pdf417';

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  async function draw() {
    const text = textEl.value.trim();
    if (!text) { setErr('Enter some text to encode.'); return; }
    try {
      await toCanvas(canvas, { bcid: BCID, text, scale: 3 });
      setErr('');
    } catch (e) {
      setErr('Could not encode that data.');
    }
  }

  function download(href: string, name: string) {
    const a = document.createElement('a'); a.href = href; a.download = name; a.click();
  }

  let t: number;
  textEl.addEventListener('input', () => { clearTimeout(t); t = window.setTimeout(draw, 200); });
  document.getElementById('pf-png')!.addEventListener('click', () => download(canvas.toDataURL('image/png'), 'pdf417.png'));
  document.getElementById('pf-svg')!.addEventListener('click', async () => {
    try {
      const svg = await toSVG({ bcid: BCID, text: textEl.value.trim(), scale: 3 });
      const url = URL.createObjectURL(new Blob([svg], { type: 'image/svg+xml' }));
      download(url, 'pdf417.svg');
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch { setErr('Could not encode that data.'); }
  });

  draw();
</script>

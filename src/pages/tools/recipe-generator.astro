---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="recipe-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Cuisine
        <select id="rc-cuisine" class="field w-40"><option value="any">Any</option><option>Italian</option><option>Mexican</option><option>Asian</option><option>Mediterranean</option><option>American</option></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Meal
        <select id="rc-meal" class="field w-36"><option value="any">Any</option><option>Breakfast</option><option>Lunch</option><option>Dinner</option><option>Snack</option></select>
      </label>
      <div class="ml-auto flex flex-wrap items-center gap-2.5">
        <button id="rc-gen" class="btn btn-primary">New idea</button>
        <button id="rc-ai-gen" type="button" class="btn btn-primary bg-linear-to-r from-primary via-[#7c5cff] to-[#a855f7] hover:opacity-90">✦ AI generate</button>
      </div>
    </div>
    <div class="panel flex flex-col gap-3 p-5">
      <h2 class="text-lg font-semibold text-ink">Ask the chef</h2>
      <div id="rc-chat" class="flex max-h-80 flex-col gap-3 overflow-y-auto"></div>
      <form id="rc-chat-form" class="flex gap-2">
        <input id="rc-chat-input" class="field flex-1" placeholder="Make it vegan, or what can I swap for the rice?" autocomplete="off" />
        <button type="submit" class="btn btn-primary">Send</button>
      </form>
    </div>

    <div class="copy-wrap">
      <div id="rc-out" class="panel panel-lift flex flex-col gap-3 p-5"></div>
      <button id="rc-copy-btn" type="button" class="copy-icon" aria-label="Copy"></button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free recipe idea generator gives you a random meal idea — a dish name,
      a handful of key ingredients, and a quick method sketch — filtered by cuisine
      and meal type. It's meant to break you out of a cooking rut and spark
      inspiration, not to be a precise recipe. Adjust quantities to taste.
      Ask the chef to tweak or swap anything.
    </p>
  </div>
</ToolLayout>

<script>
  import { pick, sample } from '../../lib/random';
  import { aiChat } from '../../lib/ai';

  const $ = (id: string) => document.getElementById(id)!;
  const out = $('rc-out')!;
  const esc = (s: string) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));

  const PROTEINS = ['chicken', 'chickpeas', 'salmon', 'tofu', 'beef', 'shrimp', 'eggs', 'black beans', 'lentils'];
  const VEG = ['spinach', 'bell peppers', 'zucchini', 'mushrooms', 'broccoli', 'tomatoes', 'onion', 'kale', 'sweet potato'];
  const CARB = ['rice', 'pasta', 'tortillas', 'quinoa', 'noodles', 'flatbread', 'couscous', 'potatoes'];
  const FLAVOR = ['garlic & herb', 'spicy chili', 'lemon & olive oil', 'soy & ginger', 'smoky paprika', 'creamy parmesan', 'honey & lime'];
  const STYLE = ['stir-fry', 'bowl', 'wrap', 'bake', 'skillet', 'salad', 'soup', 'tacos'];
  const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

  let currentRecipe = '';

  function render(name: string, ingredients: string[], steps: string[]) {
    currentRecipe = `${name}\nIngredients: ${ingredients.join(', ')}\nMethod:\n${steps.map((s, i) => `${i + 1}. ${s}`).join('\n')}`;
    out.innerHTML = `
      <h2 class="text-xl font-semibold text-ink">${esc(name)}</h2>
      <div><div class="text-xs uppercase tracking-wide text-ink-tertiary mb-1">Ingredients</div><ul class="flex flex-wrap gap-2">${ingredients.map((i) => `<li class="status-badge">${esc(i)}</li>`).join('')}</ul></div>
      <div><div class="text-xs uppercase tracking-wide text-ink-tertiary mb-1">Method</div><ol class="flex flex-col gap-1 text-[15px] text-ink-subtle">${steps.map((s, i) => `<li>${i + 1}. ${esc(s)}</li>`).join('')}</ol></div>`;
  }

  const sel = (id: string) => ($(id) as HTMLSelectElement).value;

  function generate() {
    const protein = pick(PROTEINS), style = pick(STYLE), flavor = pick(FLAVOR);
    const veg = sample(VEG, 2), carb = pick(CARB);
    const name = `${cap(flavor.split(' ')[0])} ${cap(protein)} ${cap(style)}`;
    const ingredients = [protein, ...veg, carb, `${flavor} seasoning`];
    const steps = [
      `Prep and chop the ${veg.join(' and ')}.`,
      `Cook the ${protein} until done, seasoning with ${flavor}.`,
      `Add the vegetables and ${carb}; combine over heat.`,
      `Finish, taste, adjust seasoning, and serve as a ${style}.`,
    ];
    render(name, ingredients, steps);
  }

  // AI path: ask the model for a recipe as JSON, fall back to local on any failure.
  async function aiGenerate() {
    const btn = $('rc-ai-gen') as HTMLButtonElement;
    btn.disabled = true;
    out.innerHTML = `<p class="text-[15px] text-ink-subtle">Generating…</p>`;
    try {
      const cuisine = sel('rc-cuisine'), meal = sel('rc-meal');
      const reply = await aiChat([
        { role: 'system', content: 'You are a chef. Output valid JSON only, no prose, no code fences.' },
        { role: 'user', content: `Invent one ${cuisine === 'any' ? '' : cuisine} ${meal === 'any' ? 'meal' : meal} recipe idea. Respond ONLY with JSON of this exact shape: {"name":"...","ingredients":["..."],"steps":["..."]}` },
      ]);
      const r = JSON.parse(reply.replace(/^```(?:json)?\s*|\s*```$/g, '').trim());
      if (!r.name || !Array.isArray(r.ingredients) || !Array.isArray(r.steps)) throw new Error('shape');
      render(r.name, r.ingredients, r.steps);
    } catch {
      generate(); // remote unavailable / bad output — use local generator
    } finally {
      btn.disabled = false;
    }
  }

  ['rc-cuisine', 'rc-meal'].forEach((id) => $(id).addEventListener('change', generate));
  $('rc-gen').addEventListener('click', generate);
  $('rc-ai-gen').addEventListener('click', aiGenerate);
  // Local copy: the formatted recipe lives in the currentRecipe string, not in rc-out's text.
  $('rc-copy-btn').addEventListener('click', async (e) => {
    if (!currentRecipe) return;
    await navigator.clipboard.writeText(currentRecipe);
    const btn = e.currentTarget as HTMLElement;
    btn.classList.add('copied');
    setTimeout(() => btn.classList.remove('copied'), 1500);
  });
  generate();

  // --- Chef chat (browser-side, PUBLIC_ key — no per-user login). ---
  const chatBox = $('rc-chat');
  const chatInput = $('rc-chat-input') as HTMLInputElement;
  const history: { role: 'user' | 'assistant'; content: string }[] = [];

  const ctx = () =>
    `Cuisine: ${($('rc-cuisine') as HTMLSelectElement).value}, meal: ${($('rc-meal') as HTMLSelectElement).value}.` +
    (currentRecipe ? `\nTheir current recipe:\n${currentRecipe}` : '');

  function bubble(role: 'user' | 'assistant', text: string) {
    const mine = role === 'user';
    chatBox.insertAdjacentHTML('beforeend',
      `<div class="w-fit max-w-md whitespace-pre-line rounded-lg px-3 py-2 text-[14px] ${mine ? 'ml-auto bg-primary/15 text-ink' : 'bg-surface-2 text-ink-subtle'}">${esc(text)}</div>`);
    chatBox.scrollTop = chatBox.scrollHeight;
  }

  $('rc-chat-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const msg = chatInput.value.trim();
    if (!msg) return;
    chatInput.value = '';
    bubble('user', msg);
    bubble('assistant', 'Thinking…');
    const pending = chatBox.lastElementChild!;
    try {
      const reply = await aiChat([
        { role: 'system', content: `You are a friendly chef. Give concise, practical cooking advice. Always answer in short bullet points. ${ctx()}` },
        ...history,
        { role: 'user', content: msg },
      ]);
      pending.textContent = reply || '(no reply)';
      history.push({ role: 'user', content: msg }, { role: 'assistant', content: reply });
    } catch {
      pending.textContent = 'Chef is unavailable right now. Try again in a moment.';
    }
  });
</script>

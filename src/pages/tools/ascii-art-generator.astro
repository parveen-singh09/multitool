---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ascii-art-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Text
      <input id="aa-text" class="field" placeholder="HELLO" maxlength="30" spellcheck="false" autocomplete="off" />
    </label>

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Font
        <select id="aa-style" class="field w-56"></select>
      </label>
      <button id="aa-copy" type="button" class="btn btn-secondary">Copy</button>
    </div>

    <div class="overflow-x-auto rounded-md border border-hairline bg-surface-1 p-4">
      <pre id="aa-out" class="font-mono text-[11px] leading-tight text-ink" style="white-space:pre"></pre>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free ASCII art generator turns text into large ASCII letter banners
      — the kind used in code comments, terminal splash screens and README
      headers. Type a word, pick a FIGfont, and copy the monospaced output.
      It uses the same FIGlet fonts as the classic TAAG generator, rendered
      entirely in your browser, so nothing you type is uploaded.
    </p>
  </div>
</ToolLayout>

<script>
  import figlet from 'figlet/browser';

  // Every FIGfont figlet ships (same corpus as patorjk's TAAG). Vite turns each
  // match into a lazily-loaded chunk, so listing all of them costs nothing up
  // front — a font's data is only fetched the first time it's selected.
  const FONT_MODULES = import.meta.glob(
    '/node_modules/figlet/importable-fonts/*.js',
  ) as Record<string, () => Promise<{ default: string }>>;

  // path -> font name (strip directory and .js extension).
  const FONTS: Record<string, () => Promise<{ default: string }>> = {};
  for (const [path, loader] of Object.entries(FONT_MODULES)) {
    const name = path.split('/').pop()!.replace(/\.js$/, '');
    FONTS[name] = loader;
  }

  // Surface the well-known fonts first; the rest follow alphabetically.
  const POPULAR = [
    'Standard', 'ANSI Shadow', 'ANSI Regular', 'ANSI Compact', 'Slant',
    'Small', 'Small Slant', 'Shadow', 'Big', 'Doom', 'Banner3', '3D-ASCII',
    'Ghost', 'Graffiti', 'Isometric1', 'Larry 3D', 'Star Wars', 'Bloody',
  ].filter((n) => n in FONTS);

  const rest = Object.keys(FONTS)
    .filter((n) => !POPULAR.includes(n))
    .sort((a, b) => a.localeCompare(b));

  const textEl = document.getElementById('aa-text') as HTMLInputElement;
  const styleEl = document.getElementById('aa-style') as HTMLSelectElement;
  const out = document.getElementById('aa-out') as HTMLElement;

  // Populate the font picker: a "Popular" group, then all fonts A–Z.
  function addOptions(label: string, names: string[]) {
    if (!names.length) return;
    const group = document.createElement('optgroup');
    group.label = label;
    for (const name of names) {
      const opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      group.appendChild(opt);
    }
    styleEl.appendChild(group);
  }
  addOptions('Popular', POPULAR);
  addOptions(`All fonts (${rest.length + POPULAR.length})`, rest);

  const parsed = new Set<string>();

  async function ensureFont(name: string) {
    if (parsed.has(name)) return;
    const mod = await FONTS[name]();
    figlet.parseFont(name, mod.default);
    parsed.add(name);
  }

  async function render() {
    const raw = textEl.value || 'HELLO';
    const font = styleEl.value;
    try {
      await ensureFont(font);
      out.textContent = figlet.textSync(raw, { font });
    } catch (err) {
      out.textContent = 'Could not render this font.';
      console.error(err);
    }
  }

  textEl.addEventListener('input', render);
  styleEl.addEventListener('change', render);
  document.getElementById('aa-copy')!.addEventListener('click', async (e) => {
    await navigator.clipboard.writeText(out.textContent || '');
    const b = e.currentTarget as HTMLButtonElement;
    b.textContent = 'Copied!'; setTimeout(() => (b.textContent = 'Copy'), 1400);
  });

  textEl.value = 'HELLO';
  render();
</script>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="volume-converter">
  <UnitConverter slug="volume-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free volume converter converts volume between litres, millilitres, cubic metres, US and imperial gallons, quarts, pints, cups and fluid ounces. US and imperial measures differ, and this converter keeps them separate. Runs in your browser.
    </p>
  </div>
</ToolLayout>

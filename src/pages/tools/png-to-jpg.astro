---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ImageConverter from '../../components/ImageConverter.astro';
---

<ToolLayout slug="png-to-jpg">
  <ImageConverter to="image/jpeg" accept="image/png,.png" ext="jpg" quality={true} flatten={true} />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PNG to JPG converter turns PNG images into compact, universally
      compatible JPEG files. JPEG is lossy but far smaller, making it ideal for
      photos, email attachments and web pages where a PNG would be needlessly
      large. Since JPEG has no transparency, any transparent areas are flattened
      to white. Adjust the quality slider to trade file size against detail, then
      download.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="ssh-key-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Key type
        <select id="ss-type" class="field w-48">
          <option value="ed25519" selected>Ed25519 (recommended)</option>
          <option value="2048">RSA 2048</option>
          <option value="3072">RSA 3072</option>
          <option value="4096">RSA 4096</option>
        </select>
      </label>
      <label class="flex flex-1 flex-col gap-1 text-sm text-ink-subtle">Comment
        <input id="ss-comment" class="field" value="user@toolcities" spellcheck="false" />
      </label>
      <button id="ss-gen" type="button" class="btn btn-primary">Generate key pair</button>
    </div>
    <p id="ss-status" class="text-[13px] text-ink-subtle"></p>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Public key (OpenSSH)
      <textarea id="ss-pub" class="field min-h-24 resize-y font-mono text-xs break-all" readonly></textarea>
    </label>
    <button id="ss-pubcopy" type="button" class="btn btn-secondary w-fit">Copy public key</button>

    <label class="flex flex-col gap-1 text-sm text-ink-subtle"><span id="ss-priv-label">Private key (OpenSSH)</span>
      <textarea id="ss-priv" class="field min-h-48 resize-y font-mono text-xs" readonly></textarea>
    </label>
    <div class="flex flex-wrap gap-2">
      <button id="ss-privcopy" type="button" class="btn btn-secondary">Copy private key</button>
      <button id="ss-privdl" type="button" class="btn btn-secondary">Download id_ed25519</button>
    </div>
    <p class="text-[13px] text-ink-tertiary">Keep the private key secret. Anyone with it can authenticate as you.</p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SSH key generator creates a key pair right in your browser and
      gives you the OpenSSH-format public key (ready to paste into
      <code class="font-mono text-ink">authorized_keys</code> or a Git host) and
      the matching private key. Ed25519 is the recommended default — it's fast,
      compact, and secure; RSA (2048–4096 bit) is offered for compatibility with
      older systems, where larger sizes are stronger but slower to generate.
      Ed25519 keys are emitted in the modern
      <code class="font-mono text-ink">openssh-key-v1</code> format and RSA keys as
      a PEM private key. Because everything is created locally with an in-page
      crypto engine, your private key is never transmitted anywhere — but always
      store it securely.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const typeEl = $('ss-type') as HTMLSelectElement;
  const commentEl = $('ss-comment') as HTMLInputElement;
  const statusEl = $('ss-status')!;
  const pubEl = $('ss-pub') as HTMLTextAreaElement;
  const privEl = $('ss-priv') as HTMLTextAreaElement;
  const privLabelEl = $('ss-priv-label')!;
  const dlBtn = $('ss-privdl') as HTMLButtonElement;

  let dlName = 'id_ed25519';

  // --- OpenSSH binary encoding helpers (work on Uint8Array) ---
  const concat = (parts: Uint8Array[]) => {
    const total = parts.reduce((n, p) => n + p.length, 0);
    const out = new Uint8Array(total);
    let o = 0;
    for (const p of parts) { out.set(p, o); o += p.length; }
    return out;
  };
  const u32 = (n: number) => new Uint8Array([(n >>> 24) & 255, (n >>> 16) & 255, (n >>> 8) & 255, n & 255]);
  // SSH "string": 4-byte big-endian length prefix, then the bytes.
  const sshStr = (bytes: Uint8Array) => concat([u32(bytes.length), bytes]);
  const strBytes = (s: string) => new TextEncoder().encode(s);
  const b64 = (bytes: Uint8Array) => {
    let bin = '';
    for (let i = 0; i < bytes.length; i++) bin += String.fromCharCode(bytes[i]);
    return btoa(bin);
  };

  // OpenSSH public-key line: "ssh-ed25519 <base64(blob)> comment"
  const ed25519PublicKeyToOpenSSH = (pub: Uint8Array, comment: string) => {
    const blob = concat([sshStr(strBytes('ssh-ed25519')), sshStr(pub)]);
    return `ssh-ed25519 ${b64(blob)}${comment ? ' ' + comment : ''}`;
  };

  // Unencrypted "openssh-key-v1" private key (cipher/kdf = "none").
  const ed25519PrivateKeyToOpenSSH = (pub: Uint8Array, priv: Uint8Array, comment: string) => {
    const keyType = strBytes('ssh-ed25519');
    const pubBlob = concat([sshStr(keyType), sshStr(pub)]);
    const check = crypto.getRandomValues(new Uint8Array(4));
    let privSection = concat([
      check, check, // two matching check integers
      sshStr(keyType), sshStr(pub), sshStr(priv), sshStr(strBytes(comment)),
    ]);
    // Pad to the cipher block size (8 for "none") with 1,2,3,…
    for (let i = 1; privSection.length % 8 !== 0; i++) privSection = concat([privSection, new Uint8Array([i & 255])]);

    const body = concat([
      strBytes('openssh-key-v1\0'),
      sshStr(strBytes('none')),  // ciphername
      sshStr(strBytes('none')),  // kdfname
      sshStr(new Uint8Array(0)), // kdfoptions
      u32(1),                    // number of keys
      sshStr(pubBlob),
      sshStr(privSection),
    ]);
    const lines = (b64(body).match(/.{1,70}/g) || []).join('\n');
    return `-----BEGIN OPENSSH PRIVATE KEY-----\n${lines}\n-----END OPENSSH PRIVATE KEY-----\n`;
  };

  $('ss-gen').addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const type = typeEl.value;
    const isRsa = type !== 'ed25519';
    btn.disabled = true;
    statusEl.textContent = isRsa
      ? `Generating ${type}-bit RSA key pair… this can take a few seconds.`
      : 'Generating Ed25519 key pair…';
    pubEl.value = ''; privEl.value = '';
    // Let the status paint before the CPU-bound keygen blocks the thread.
    await new Promise((r) => setTimeout(r, 30));
    try {
      const forge = (await import('node-forge')).default;
      if (isRsa) {
        const keypair = await new Promise<any>((resolve, reject) => {
          forge.pki.rsa.generateKeyPair({ bits: Number(type), workers: -1 }, (err: any, kp: any) => (err ? reject(err) : resolve(kp)));
        });
        privEl.value = forge.pki.privateKeyToPem(keypair.privateKey);
        pubEl.value = (forge.ssh.publicKeyToOpenSSH(keypair.publicKey, commentEl.value) as string).trim();
        privLabelEl.textContent = 'Private key (PEM)';
        dlName = 'id_rsa';
      } else {
        const kp = forge.pki.ed25519.generateKeyPair();
        const pub = Uint8Array.from(kp.publicKey as any);
        const priv = Uint8Array.from(kp.privateKey as any);
        pubEl.value = ed25519PublicKeyToOpenSSH(pub, commentEl.value);
        privEl.value = ed25519PrivateKeyToOpenSSH(pub, priv, commentEl.value);
        privLabelEl.textContent = 'Private key (OpenSSH)';
        dlName = 'id_ed25519';
      }
      dlBtn.textContent = `Download ${dlName}`;
      statusEl.textContent = 'Done — key pair generated locally.';
    } catch (err) {
      statusEl.textContent = 'Key generation failed. Please try again.';
    } finally {
      btn.disabled = false;
    }
  });

  const copyBtn = (id: string, src: HTMLTextAreaElement, label: string) =>
    $(id).addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      await navigator.clipboard.writeText(src.value);
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = label), 1500);
    });
  copyBtn('ss-pubcopy', pubEl, 'Copy public key');
  copyBtn('ss-privcopy', privEl, 'Copy private key');

  $('ss-privdl').addEventListener('click', () => {
    if (!privEl.value) return;
    const url = URL.createObjectURL(new Blob([privEl.value], { type: 'application/x-pem-file' }));
    const a = document.createElement('a'); a.href = url; a.download = dlName; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });
</script>

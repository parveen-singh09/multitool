---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="prime-number-checker">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Whole number
      <input id="prime-in" class="field font-mono text-[13px]" type="text" inputmode="numeric" placeholder="e.g. 97" spellcheck="false" value="97" />
    </label>

    <p id="prime-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-1 gap-3 text-center sm:grid-cols-3">
      <div class="panel panel-lift p-4"><div id="prime-verdict" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Verdict</div></div>
      <div class="panel p-4"><div id="prime-lower" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Nearest lower prime</div></div>
      <div class="panel p-4"><div id="prime-higher" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Nearest higher prime</div></div>
    </div>

    <div id="prime-detail-wrap" class="hidden panel p-4">
      <div class="text-[13px] text-ink-subtle">Prime factorization</div>
      <div id="prime-factorization" class="mt-1 font-mono text-[13px] text-ink break-all">—</div>
      <div class="mt-3 text-[13px] text-ink-subtle">Factor pairs</div>
      <div id="prime-pairs" class="mt-1 font-mono text-[13px] text-ink break-all">—</div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free prime number checker tells you whether a whole number is prime —
      a number greater than 1 whose only divisors are 1 and itself. Enter a
      value and it uses trial division up to the square root to test primality
      quickly. If the number is not prime it shows the factor pairs and prime
      factorization, and either way it reports the nearest lower and higher
      primes.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('prime-in') as HTMLInputElement;
  const err = document.getElementById('prime-error')!;
  const verdictEl = document.getElementById('prime-verdict')!;
  const lowerEl = document.getElementById('prime-lower')!;
  const higherEl = document.getElementById('prime-higher')!;
  const detailWrap = document.getElementById('prime-detail-wrap')!;
  const factorizationEl = document.getElementById('prime-factorization')!;
  const pairsEl = document.getElementById('prime-pairs')!;

  function isPrime(n: number): boolean {
    if (n < 2) return false;
    if (n < 4) return true;
    if (n % 2 === 0) return false;
    const limit = Math.floor(Math.sqrt(n));
    for (let i = 3; i <= limit; i += 2) {
      if (n % i === 0) return false;
    }
    return true;
  }

  function factorPairs(n: number): string {
    const pairs: string[] = [];
    const limit = Math.floor(Math.sqrt(n));
    for (let i = 1; i <= limit; i++) {
      if (n % i === 0) pairs.push(`${i} × ${n / i}`);
    }
    return pairs.join(',  ');
  }

  function primeFactorization(n: number): string {
    const factors: number[] = [];
    let m = n;
    for (let d = 2; d * d <= m; d++) {
      while (m % d === 0) {
        factors.push(d);
        m /= d;
      }
    }
    if (m > 1) factors.push(m);
    const counts = new Map<number, number>();
    factors.forEach((f) => counts.set(f, (counts.get(f) || 0) + 1));
    return [...counts.entries()]
      .map(([base, exp]) => (exp === 1 ? `${base}` : `${base}^${exp}`))
      .join(' × ');
  }

  function nearestLower(n: number): number | null {
    for (let i = n - 1; i >= 2; i--) {
      if (isPrime(i)) return i;
    }
    return null;
  }

  function nearestHigher(n: number): number {
    let i = n + 1;
    if (i < 2) i = 2;
    while (!isPrime(i)) i++;
    return i;
  }

  function reset(msg?: string) {
    verdictEl.textContent = '—';
    verdictEl.className = 'font-display text-xl font-semibold text-primary-hover';
    lowerEl.textContent = '—';
    higherEl.textContent = '—';
    detailWrap.classList.add('hidden');
    if (msg) {
      err.textContent = msg;
      err.classList.remove('hidden');
    } else {
      err.classList.add('hidden');
    }
  }

  function check() {
    const raw = input.value.trim();
    if (raw === '') { reset(); return; }
    if (!/^-?\d+$/.test(raw)) { reset('Please enter a whole number.'); return; }
    const n = Number(raw);
    if (!Number.isSafeInteger(n)) { reset('Number is too large to check accurately.'); return; }
    err.classList.add('hidden');

    const prime = isPrime(n);
    verdictEl.textContent = prime ? 'Prime' : 'Not prime';
    verdictEl.className = prime
      ? 'font-display text-xl font-semibold text-primary-hover'
      : 'font-display text-xl font-semibold text-ink';

    const lo = nearestLower(n);
    lowerEl.textContent = lo === null ? 'none' : String(lo);
    higherEl.textContent = String(nearestHigher(n));

    if (!prime && n >= 2) {
      detailWrap.classList.remove('hidden');
      factorizationEl.textContent = primeFactorization(n);
      pairsEl.textContent = factorPairs(n);
    } else {
      detailWrap.classList.add('hidden');
    }
  }

  input.addEventListener('input', check);
  check();
</script>

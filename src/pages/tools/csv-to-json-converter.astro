---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="csv-to-json-converter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <button id="c2j-convert" class="btn btn-primary">Convert to JSON</button>
      <button id="c2j-copy" class="btn btn-secondary">Copy</button>
      <button id="c2j-clear" class="btn btn-tertiary">Clear</button>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        Delimiter
        <select id="c2j-delim" class="field w-auto py-1">
          <option value="auto">Auto-detect</option>
          <option value=",">Comma</option>
          <option value=";">Semicolon</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <label class="ml-auto flex items-center gap-2 text-sm text-ink-subtle">
        <input id="c2j-header" type="checkbox" checked class="h-4 w-4" />
        First row is header
      </label>
    </div>

    <div id="c2j-status" class="hidden rounded-[8px] border px-3 py-2 text-sm" role="status"></div>

    <div class="grid gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        CSV input
        <textarea
          id="c2j-input"
          class="field min-h-72 resize-y font-mono text-[13px]"
          placeholder={"name,age,active\nAda,36,true\nGrace,45,false"}
          spellcheck="false"
          aria-label="CSV input"
        ></textarea>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        JSON output
        <textarea
          id="c2j-output"
          class="field min-h-72 resize-y font-mono text-[13px]"
          placeholder="Formatted JSON appears here"
          spellcheck="false"
          readonly
          aria-label="JSON output"
        ></textarea>
      </label>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSV to JSON converter turns CSV with a header row into an array
      of JSON objects. It detects the delimiter automatically — comma, semicolon
      or tab — handles quoted fields and escaped quotes, and coerces obvious
      numbers and booleans. Toggle off the header option to get plain rows of
      arrays instead. Conversion runs entirely in your browser, so your data
      never leaves your machine.
    </p>
  </div>
</ToolLayout>

<script>
  import { csvToJson, detectDelimiter } from '../../lib/dataformats';

  const input = document.getElementById('c2j-input') as HTMLTextAreaElement;
  const output = document.getElementById('c2j-output') as HTMLTextAreaElement;
  const status = document.getElementById('c2j-status')!;
  const delimSel = document.getElementById('c2j-delim') as HTMLSelectElement;
  const headerBox = document.getElementById('c2j-header') as HTMLInputElement;

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.classList.remove('hidden');
    status.style.borderColor = ok ? '#27a644' : '#d14d4d';
    status.style.color = ok ? '#27a644' : '#e08585';
  }

  function resolveDelimiter(): string {
    const v = delimSel.value;
    if (v === 'tab') return '\t';
    if (v === 'auto') return detectDelimiter(input.value);
    return v;
  }

  function convert() {
    if (!input.value.trim()) {
      output.value = '';
      status.classList.add('hidden');
      return;
    }
    try {
      const delim = resolveDelimiter();
      const parsed = csvToJson(input.value, delim, headerBox.checked);
      output.value = JSON.stringify(parsed, null, 2);
      const label = delim === '\t' ? 'tab' : delim === ';' ? 'semicolon' : 'comma';
      showStatus(`Converted using ${label} delimiter ✓`, true);
    } catch (e) {
      output.value = '';
      showStatus(`CSV error: ${(e as Error).message}`, false);
    }
  }

  document.getElementById('c2j-convert')!.addEventListener('click', convert);
  delimSel.addEventListener('change', () => { if (output.value) convert(); });
  headerBox.addEventListener('change', () => { if (output.value) convert(); });
  document.getElementById('c2j-clear')!.addEventListener('click', () => {
    input.value = '';
    output.value = '';
    status.classList.add('hidden');
  });
  document.getElementById('c2j-copy')!.addEventListener('click', async () => {
    const btn = document.getElementById('c2j-copy')!;
    await navigator.clipboard.writeText(output.value);
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = 'Copy'), 1500);
  });
</script>

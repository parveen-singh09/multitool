---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout slug="random-word-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Word type
        <select id="rw-type" class="field w-40">
          <option value="mix" selected>All / mix</option>
          <option value="noun">Nouns</option>
          <option value="verb">Verbs</option>
          <option value="adjective">Adjectives</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="rw-count" type="number" min="1" max="500" value="10" class="field w-28" />
      </label>
      <button id="rw-gen" class="btn btn-primary ml-auto">Generate</button>
    </div>

    <details class="rounded-lg border border-hairline bg-surface-2 px-4 py-3">
      <summary class="cursor-pointer text-sm text-ink-subtle select-none">More options</summary>
      <div class="mt-3 flex flex-wrap items-end gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">First letter
          <input id="rw-first" type="text" maxlength="1" placeholder="any" class="field w-24" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Last letter
          <input id="rw-last" type="text" maxlength="1" placeholder="any" class="field w-24" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Word size by
          <select id="rw-sizeby" class="field w-36">
            <option value="none" selected>Any size</option>
            <option value="letters">Letters</option>
            <option value="syllables">Syllables</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Compare
          <select id="rw-cmp" class="field w-36">
            <option value="eq">Equals</option>
            <option value="lt">Less than</option>
            <option value="gt">Greater than</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Value
          <input id="rw-size" type="number" min="1" max="30" value="5" class="field w-24" />
        </label>
        <button id="rw-reset" class="btn btn-secondary">Reset</button>
      </div>
    </details>

    <p id="rw-msg" class="hidden text-sm text-ink-subtle"></p>
    <div class="copy-wrap">
      <textarea id="rw-out" class="field min-h-56 resize-y font-mono text-sm" readonly aria-label="Generated words"></textarea>
      <button type="button" class="copy-icon" data-copy-target="#rw-out" aria-label="Copy"></button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free random word generator produces random English words by type —
      nouns, verbs, adjectives, or a mix drawn from thousands of common words.
      Narrow the results with filters: force a first or last letter, or limit
      words by length or syllable count (equals, less than, greater than). Handy
      for brainstorming, word games, Pictionary, writing prompts, creative
      exercises and picking memorable project names. Generate a single word or a
      list of up to 500 at once.
    </p>
  </div>
</ToolLayout>

<script>
  import { shuffle } from '../../lib/random';
  import { NOUNS, VERBS, ADJECTIVES } from '../../lib/fakedata';
  import { WORDS } from '../../lib/wordlist';
  import { WORDS5 } from '../../lib/words5';

  const $ = (id: string) => document.getElementById(id)!;
  const typeEl = $('rw-type') as HTMLSelectElement;
  const countEl = $('rw-count') as HTMLInputElement;
  const firstEl = $('rw-first') as HTMLInputElement;
  const lastEl = $('rw-last') as HTMLInputElement;
  const sizeByEl = $('rw-sizeby') as HTMLSelectElement;
  const cmpEl = $('rw-cmp') as HTMLSelectElement;
  const sizeEl = $('rw-size') as HTMLInputElement;
  const msg = $('rw-msg') as HTMLParagraphElement;
  const out = $('rw-out') as HTMLTextAreaElement;

  const ALL = [...new Set([...WORDS, ...WORDS5, ...NOUNS, ...VERBS, ...ADJECTIVES])];

  function bank(): string[] {
    if (typeEl.value === 'noun') return NOUNS;
    if (typeEl.value === 'verb') return VERBS;
    if (typeEl.value === 'adjective') return ADJECTIVES;
    return ALL;
  }

  function syllables(w: string): number {
    const m = w.toLowerCase().replace(/e$/, '').match(/[aeiouy]+/g);
    return Math.max(1, m ? m.length : 1);
  }

  function passesSize(w: string): boolean {
    if (sizeByEl.value === 'none') return true;
    const n = sizeByEl.value === 'syllables' ? syllables(w) : w.length;
    const v = Number(sizeEl.value) || 0;
    if (cmpEl.value === 'lt') return n < v;
    if (cmpEl.value === 'gt') return n > v;
    return n === v;
  }

  function generate() {
    const n = Math.max(1, Math.min(500, Number(countEl.value) || 10));
    const first = firstEl.value.trim().toLowerCase();
    const last = lastEl.value.trim().toLowerCase();

    const pool = bank().filter((w) => {
      if (first && !w.toLowerCase().startsWith(first)) return false;
      if (last && !w.toLowerCase().endsWith(last)) return false;
      return passesSize(w);
    });

    if (pool.length === 0) {
      out.value = '';
      msg.textContent = 'No words match those filters. Loosen them and try again.';
      msg.classList.remove('hidden');
      return;
    }
    msg.classList.add('hidden');

    const list: string[] = [];
    let deck = shuffle(pool);
    for (let i = 0; i < n; i++) {
      if (deck.length === 0) deck = shuffle(pool);
      list.push(deck.pop()!);
    }
    out.value = list.join('\n');
  }

  function reset() {
    firstEl.value = '';
    lastEl.value = '';
    sizeByEl.value = 'none';
    cmpEl.value = 'eq';
    sizeEl.value = '5';
    generate();
  }

  [typeEl, countEl, firstEl, lastEl, sizeByEl, cmpEl, sizeEl].forEach((el) =>
    el.addEventListener('input', generate),
  );
  $('rw-gen').addEventListener('click', generate);
  $('rw-reset').addEventListener('click', reset);
  generate();
</script>

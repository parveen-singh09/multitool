---
import ToolLayout from '../../layouts/ToolLayout.astro';

---

<ToolLayout slug="mkv-to-mp4">
  <div id="mc-root" class="flex flex-col gap-4">
    <label id="mc-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose MKV files or drop them here</span>
      <input id="mc-file" type="file" accept=".mkv,video/x-matroska,video/*" multiple class="sr-only" />
    </label>

    <div id="mc-panel" class="hidden flex-col gap-4">

      <div id="mc-files" class="flex flex-col gap-2"></div>

      <div class="panel flex flex-col gap-4 p-4">
        <div class="flex flex-col gap-2">
          <span class="eyebrow text-ink-subtle">Conversion mode</span>
          <div class="flex flex-wrap gap-2">
            <label class="flex flex-1 cursor-pointer items-start gap-2 rounded-md border border-hairline p-3 text-sm has-[:checked]:border-hairline-strong has-[:checked]:bg-surface-2" style="min-width:220px">
              <input id="mode-copy" type="radio" name="mc-mode" value="copy" checked class="mt-0.5 accent-primary" />
              <span class="flex flex-col gap-0.5">
                <span class="text-ink">Fast remux Â· lossless</span>
                <span class="text-[13px] text-ink-tertiary">Copies the existing video/audio into an MP4 in seconds with no quality loss. Best when the MKV already uses H.264/H.265/AV1 (most do).</span>
              </span>
            </label>
            <label class="flex flex-1 cursor-pointer items-start gap-2 rounded-md border border-hairline p-3 text-sm has-[:checked]:border-hairline-strong has-[:checked]:bg-surface-2" style="min-width:220px">
              <input id="mode-encode" type="radio" name="mc-mode" value="encode" class="mt-0.5 accent-primary" />
              <span class="flex flex-col gap-0.5">
                <span class="text-ink">Re-encode Â· H.264</span>
                <span class="text-[13px] text-ink-tertiary">Full re-encode to H.264 + AAC. Slower but lets you resize, change frame rate, rotate, adjust volume and set quality. Use if remux fails.</span>
              </span>
            </label>
          </div>
        </div>

        <div id="mc-encode-opts" class="hidden flex-col gap-4">
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Quality
              <select id="mc-crf" class="field">
                <option value="18">Very high (larger)</option>
                <option value="20">High</option>
                <option value="23" selected>Balanced</option>
                <option value="28">Smaller</option>
                <option value="32">Smallest</option>
              </select>
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Max width
              <select id="mc-scale" class="field">
                <option value="0" selected>Keep original</option>
                <option value="3840">4K (3840)</option>
                <option value="2560">1440p (2560)</option>
                <option value="1920">1080p (1920)</option>
                <option value="1280">720p (1280)</option>
                <option value="854">480p (854)</option>
                <option value="640">360p (640)</option>
              </select>
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Frame rate
              <select id="mc-fps" class="field">
                <option value="0" selected>Keep original</option>
                <option value="60">60 fps</option>
                <option value="30">30 fps</option>
                <option value="24">24 fps</option>
                <option value="15">15 fps</option>
              </select>
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Rotate
              <select id="mc-rotate" class="field">
                <option value="0" selected>None</option>
                <option value="90">90Â° right</option>
                <option value="180">180Â°</option>
                <option value="270">90Â° left</option>
              </select>
            </label>
          </div>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Audio
              <select id="mc-audio" class="field">
                <option value="192" selected>AAC 192 kbps</option>
                <option value="256">AAC 256 kbps</option>
                <option value="128">AAC 128 kbps</option>
                <option value="96">AAC 96 kbps</option>
                <option value="mute">Remove audio</option>
              </select>
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Volume (%)
              <input id="mc-volume" type="number" min="0" max="1000" step="5" placeholder="100" class="field" />
            </label>
          </div>
        </div>

        <details class="group">
          <summary class="cursor-pointer select-none text-[13px] text-ink-subtle hover:text-ink">Trim options</summary>
          <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Trim start (s)
              <input id="mc-trimstart" type="number" min="0" step="0.5" placeholder="0" class="field" />
            </label>
            <label class="flex flex-col gap-1 text-sm text-ink-subtle">Trim end (s)
              <input id="mc-trimend" type="number" min="0" step="0.5" placeholder="end" class="field" />
            </label>
          </div>
          <p class="mt-2 text-xs text-ink-tertiary">Trim applies to every file in the queue. Leave blank to keep the full length. In remux mode, trimming snaps to the nearest keyframe for speed.</p>
        </details>

        <p id="mc-mode-hint" class="text-[13px] text-ink-tertiary"></p>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="mc-go" class="btn btn-primary">Convert to MP4</button>
        <button id="mc-clear" class="btn btn-secondary">Clear</button>
        <span id="mc-summary" class="text-[13px] text-ink-subtle"></span>
      </div>

      <div id="mc-batch-dl" class="hidden">
        <button id="mc-zip" class="btn btn-primary">Download all as ZIP</button>
      </div>
    </div>
    <p id="mc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free MKV to MP4 converter turns Matroska MKV video into MP4, which more players, phones, TVs and editors accept.
      There is no file-size limit and no queue, unlike server-based tools.
    </p>
    <p>
      Two modes cover every case. <strong class="text-ink">Fast remux</strong> copies the existing video and audio streams
      straight into an MP4 container in seconds, with zero quality loss â€” the right choice when your MKV already holds an
      MP4-compatible codec such as H.264, H.265/HEVC or AV1 (the vast majority of files). If a stream is incompatible, switch to
      <strong class="text-ink">re-encode</strong> mode, which rebuilds the video as H.264 + AAC and adds full control over quality
      (CRF), resolution up to 4K, frame rate, rotation, volume and audio bitrate. Both modes support trimming and batch conversion,
      with a live preview, per-file download and a one-click ZIP of the whole batch.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import { getFFmpeg, fetchFile } from '../../lib/ffmpeg';
  import { makeZip } from '../../lib/zip';

  const MIME = 'video/mp4';

  interface Opts {
    mode: 'copy' | 'encode';
    crf: number;
    scale: number;
    fps: number;
    rotate: number;
    audio: string; 
    volume: number; 
    trimStart: number;
    trimEnd: number;
  }

  function buildArgs(o: Opts, input: string, output: string): string[] {
    const start = o.trimStart > 0 ? o.trimStart : 0;
    const args: string[] = [];
    if (start > 0) args.push('-ss', String(start)); 
    args.push('-i', input);
    if (o.trimEnd > start) args.push('-to', String(o.trimEnd - start));

    if (o.mode === 'copy') {

      args.push('-map', '0:v:0?', '-map', '0:a?', '-c', 'copy', '-movflags', '+faststart', output);
      return args;
    }

    const vf: string[] = [];
    if (o.scale > 0) vf.push(`scale='min(${o.scale},iw)':-2`);
    if (o.rotate === 90) vf.push('transpose=1');
    else if (o.rotate === 270) vf.push('transpose=2');
    else if (o.rotate === 180) vf.push('transpose=1,transpose=1');

    args.push('-c:v', 'libx264', '-preset', 'veryfast', '-crf', String(o.crf), '-pix_fmt', 'yuv420p');
    if (vf.length) args.push('-vf', vf.join(','));
    if (o.fps > 0) args.push('-r', String(o.fps));

    if (o.audio === 'mute') {
      args.push('-an');
    } else {
      args.push('-c:a', 'aac', '-b:a', o.audio + 'k');
      if (o.volume > 0 && o.volume !== 100) args.push('-af', `volume=${(o.volume / 100).toFixed(3)}`);
    }
    args.push('-movflags', '+faststart', output);
    return args;
  }

  // Dev-only self-check for the arg builder (zero cost in production).
  if (import.meta.env.DEV) {
    const eq = (a: string[], b: string[]) => a.length === b.length && a.every((x, i) => x === b[i]);
    const copy = buildArgs({ mode: 'copy', crf: 23, scale: 0, fps: 0, rotate: 0, audio: '192', volume: 0, trimStart: 0, trimEnd: 0 }, 'in', 'out');
    console.assert(eq(copy, ['-i', 'in', '-map', '0:v:0?', '-map', '0:a?', '-c', 'copy', '-movflags', '+faststart', 'out']), 'remux args', copy);
    const enc = buildArgs({ mode: 'encode', crf: 28, scale: 1280, fps: 30, rotate: 90, audio: 'mute', volume: 0, trimStart: 2, trimEnd: 10 }, 'in', 'out');
    console.assert(enc.includes('-crf') && enc[enc.indexOf('-crf') + 1] === '28', 'crf', enc);
    console.assert(enc.includes('transpose=1') === false && enc.join(' ').includes('transpose=1'), 'rotate present', enc);
    console.assert(enc.includes('-an') && !enc.includes('-c:a'), 'mute drops audio', enc);
    console.assert(enc[0] === '-ss' && enc[1] === '2' && enc.includes('-to'), 'trim seek', enc);
  }

  const $ = (id: string) => document.getElementById(id);
  const fileInput = $('mc-file') as HTMLInputElement;
  const drop = $('mc-drop')!;
  const panel = $('mc-panel')!;
  const filesEl = $('mc-files')!;
  const encodeOpts = $('mc-encode-opts')!;
  const modeHint = $('mc-mode-hint')!;
  const goBtn = $('mc-go') as HTMLButtonElement;
  const clearBtn = $('mc-clear') as HTMLButtonElement;
  const summary = $('mc-summary')!;
  const batchDl = $('mc-batch-dl')!;
  const zipBtn = $('mc-zip') as HTMLButtonElement;
  const err = $('mc-error')!;

  interface Job {
    file: File;
    row: HTMLElement;
    statusEl: HTMLElement;
    bar: HTMLElement;
    actionsEl: HTMLElement;
    outUrl?: string;
    outData?: Uint8Array;
    outName?: string;
    done: boolean;
  }
  let jobs: Job[] = [];
  let current: Job | null = null;

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const fmtSize = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;
  const num = (id: string) => { const v = Number(($(id) as HTMLInputElement)?.value); return Number.isFinite(v) && v > 0 ? v : 0; };
  const outNameFor = (f: File) => f.name.replace(/\.[^.]+$/, '') + '.mp4';
  const getMode = (): 'copy' | 'encode' => (document.querySelector('input[name="mc-mode"]:checked') as HTMLInputElement).value as 'copy' | 'encode';

  function syncMode() {
    const mode = getMode();
    encodeOpts.classList.toggle('hidden', mode !== 'encode');
    encodeOpts.classList.toggle('flex', mode === 'encode');
    modeHint.textContent = mode === 'copy'
      ? 'Remux is near-instant and lossless. If it fails on a file, that stream is not MP4-compatible â€” switch to re-encode.'
      : 'Re-encoding is CPU-intensive â€” expect roughly real-time speed.';
  }
  document.querySelectorAll('input[name="mc-mode"]').forEach((el) => el.addEventListener('change', syncMode));

  function addFiles(list: FileList | File[]) {
    setErr('');
    const arr = Array.from(list);
    if (!arr.length) return;
    for (const file of arr) {
      const row = document.createElement('div');
      row.className = 'panel flex flex-col gap-2 p-3';
      const top = document.createElement('div');
      top.className = 'flex flex-wrap items-center gap-2';
      const name = document.createElement('span');
      name.className = 'text-[13px] text-ink truncate';
      name.textContent = `${file.name} Â· ${fmtSize(file.size)}`;
      const statusEl = document.createElement('span');
      statusEl.className = 'text-xs text-ink-tertiary ml-auto';
      const actionsEl = document.createElement('span');
      actionsEl.className = 'flex items-center gap-2';
      top.append(name, statusEl, actionsEl);
      const barWrap = document.createElement('div');
      barWrap.className = 'h-1 w-full overflow-hidden rounded-full bg-surface-3';
      const bar = document.createElement('div');
      bar.className = 'h-full w-0 rounded-full transition-all';
      bar.style.background = 'var(--color-primary)';
      barWrap.appendChild(bar);
      row.append(top, barWrap);
      filesEl.appendChild(row);
      jobs.push({ file, row, statusEl, bar, actionsEl, done: false });
    }
    panel.classList.remove('hidden'); panel.classList.add('flex');
    syncMode();
    refreshSummary();
  }

  function refreshSummary() {
    const doneCount = jobs.filter((j) => j.done).length;
    summary.textContent = jobs.length ? `${jobs.length} file${jobs.length === 1 ? '' : 's'}${doneCount ? ` Â· ${doneCount} done` : ''}` : '';
    batchDl.classList.toggle('hidden', !(doneCount > 1));
  }

  function readOptions(): Opts {
    return {
      mode: getMode(),
      crf: Number(($('mc-crf') as HTMLSelectElement).value),
      scale: Number(($('mc-scale') as HTMLSelectElement).value),
      fps: Number(($('mc-fps') as HTMLSelectElement).value),
      rotate: Number(($('mc-rotate') as HTMLSelectElement).value),
      audio: ($('mc-audio') as HTMLSelectElement).value,
      volume: num('mc-volume'),
      trimStart: num('mc-trimstart'),
      trimEnd: num('mc-trimend'),
    };
  }

  function download(data: Uint8Array, name: string) {
    const blob = new Blob([data as BlobPart], { type: MIME });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 2000);
  }

  async function convertAll() {
    const pending = jobs.filter((j) => !j.done);
    if (!pending.length) return;
    setErr(''); goBtn.disabled = true; clearBtn.disabled = true;
    const opts = readOptions();
    try {
      const ff = await getFFmpeg({
        onDownload: (n) => { if (n) summary.textContent = n; },
        onProgress: (r) => { if (current) current.bar.style.width = Math.min(100, Math.round(r * 100)) + '%'; },
      });
      for (const job of pending) {
        current = job;
        job.bar.style.width = '0%';
        job.statusEl.textContent = opts.mode === 'copy' ? 'Remuxingâ€¦' : 'Re-encodingâ€¦';
        job.statusEl.style.color = '';
        const inName = 'in_' + Math.random().toString(36).slice(2) + '.mkv';
        const outName = 'out.mp4';
        await ff.writeFile(inName, await fetchFile(job.file));
        try {
          await ff.exec(buildArgs(opts, inName, outName));
          const data = (await ff.readFile(outName)) as Uint8Array;
          if (!data || data.length === 0) throw new Error('empty output');
          job.outData = data;
          job.outName = outNameFor(job.file);
          job.done = true;
          job.bar.style.width = '100%';
          job.statusEl.textContent = fmtSize(data.length);
          job.statusEl.style.color = 'var(--color-success)';
          renderActions(job);
        } catch (inner) {
          job.bar.style.width = '0%';
          job.statusEl.textContent = opts.mode === 'copy' ? 'Incompatible â€” try re-encode' : 'Failed';
          job.statusEl.style.color = '#e5484d';
          if (opts.mode === 'copy') {
            setErr('Remux failed for "' + job.file.name + '": its codec is not MP4-compatible. Switch to re-encode mode and convert again.');
          } else {
            setErr('Conversion failed for "' + job.file.name + '": ' + (inner as Error).message);
          }
        } finally {
          try { await ff.deleteFile(inName); } catch {}
          try { await ff.deleteFile(outName); } catch {}
        }
        refreshSummary();
      }
    } catch (e) {
      setErr('Conversion failed: ' + (e as Error).message);
    } finally {
      goBtn.disabled = false; clearBtn.disabled = false;
      current = null;
    }
  }

  function renderActions(job: Job) {
    job.actionsEl.replaceChildren();
    const dl = document.createElement('button');
    dl.className = 'btn btn-secondary';
    dl.style.minHeight = '28px'; dl.style.padding = '2px 10px'; dl.style.fontSize = '12px';
    dl.textContent = 'Download';
    dl.addEventListener('click', () => job.outData && download(job.outData, job.outName!));
    job.actionsEl.appendChild(dl);

    const pv = document.createElement('button');
    pv.className = 'btn btn-tertiary';
    pv.style.minHeight = '28px'; pv.style.padding = '2px 10px'; pv.style.fontSize = '12px';
    pv.textContent = 'Preview';
    let shown = false;
    let holder: HTMLElement | null = null;
    pv.addEventListener('click', () => {
      if (shown) { holder?.remove(); holder = null; shown = false; pv.textContent = 'Preview'; return; }
      const blob = new Blob([job.outData as BlobPart], { type: MIME });
      job.outUrl && URL.revokeObjectURL(job.outUrl);
      job.outUrl = URL.createObjectURL(blob);
      holder = document.createElement('div');
      holder.className = 'mt-1';
      holder.innerHTML = `<video src="${job.outUrl}" controls class="max-h-80 w-auto max-w-full rounded-md"></video>`;
      job.row.appendChild(holder);
      shown = true; pv.textContent = 'Hide';
    });
    job.actionsEl.appendChild(pv);
  }

  zipBtn.addEventListener('click', () => {
    const done = jobs.filter((j) => j.done && j.outData);
    if (!done.length) return;
    const zip = makeZip(done.map((j) => ({ name: j.outName!, data: j.outData! })));
    const url = URL.createObjectURL(zip);
    const a = document.createElement('a'); a.href = url; a.download = 'mkv-to-mp4-output.zip'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 2000);
  });

  clearBtn.addEventListener('click', () => {
    jobs.forEach((j) => { j.outUrl && URL.revokeObjectURL(j.outUrl); j.row.remove(); });
    jobs = []; refreshSummary();
    panel.classList.add('hidden'); panel.classList.remove('flex');
    fileInput.value = '';
    setErr('');
  });

  fileInput.addEventListener('change', () => fileInput.files && addFiles(fileInput.files));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files; if (f?.length) addFiles(f); });
  goBtn.addEventListener('click', convertAll);
</script>

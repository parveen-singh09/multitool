---
import ToolLayout from '../../layouts/ToolLayout.astro';
import UnitConverter from '../../components/UnitConverter.astro';
---

<ToolLayout slug="data-storage-converter">
  <UnitConverter slug="data-storage-converter" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free data storage converter converts digital storage between bits, bytes, kilobytes, megabytes, gigabytes and terabytes, in both SI (1000-based) and binary (1024-based) units — so you can see the difference marketing and operating systems create. Runs in your browser.
    </p>
  </div>
</ToolLayout>

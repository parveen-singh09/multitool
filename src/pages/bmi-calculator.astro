---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="bmi-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Units">
      <button data-unit="metric" class="bmi-tab btn btn-primary" aria-selected="true">Metric</button>
      <button data-unit="imperial" class="bmi-tab btn btn-secondary" aria-selected="false">Imperial</button>
    </div>

    <div id="bmi-metric" class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (cm)
        <input id="bmi-cm" type="number" min="0" class="field" value="175" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight (kg)
        <input id="bmi-kg" type="number" min="0" class="field" value="70" inputmode="decimal" />
      </label>
    </div>

    <div id="bmi-imperial" class="hidden grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (ft)
        <input id="bmi-ft" type="number" min="0" class="field" value="5" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Height (in)
        <input id="bmi-in" type="number" min="0" class="field" value="9" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weight (lb)
        <input id="bmi-lb" type="number" min="0" class="field" value="154" inputmode="decimal" />
      </label>
    </div>

    <div class="panel panel-lift p-6 text-center">
      <div class="copy-wrap">
        <div id="bmi-value" class="font-display text-4xl font-semibold text-primary-hover">—</div>
        <button type="button" class="copy-icon" data-copy-target="#bmi-value" aria-label="Copy"></button>
      </div>
      <div id="bmi-cat" class="mt-2 text-sm text-ink-muted"></div>
    </div>

    <div class="flex flex-col gap-3">
      <span class="text-[13px] text-ink-subtle">Where you sit on the BMI scale</span>
      <div class="relative pt-6">

        <div id="bmi-marker" class="absolute top-0 -translate-x-1/2 transition-[left] duration-300 ease-out" style="left:0">
          <span class="block rounded-xs bg-ink px-1.5 py-0.5 font-mono text-[11px] font-medium text-canvas" id="bmi-marker-val">—</span>
          <span class="mx-auto block h-0 w-0 border-x-4 border-t-4 border-x-transparent" style="border-top-color:var(--color-ink)"></span>
        </div>

        <div class="flex h-3 overflow-hidden rounded-full">
          <span style="width:14%;background:#5e9fd2" title="Underweight"></span>
          <span style="width:26%;background:#27a644" title="Normal"></span>
          <span style="width:20%;background:#d2a05e" title="Overweight"></span>
          <span style="width:40%;background:#e5484d" title="Obese"></span>
        </div>

        <div class="relative mt-1 h-4 text-[11px] text-ink-tertiary">
          <span class="absolute -translate-x-1/2" style="left:14%">18.5</span>
          <span class="absolute -translate-x-1/2" style="left:40%">25</span>
          <span class="absolute -translate-x-1/2" style="left:60%">30</span>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-2 text-xs sm:grid-cols-4">
        <span class="flex items-center gap-1.5 text-ink-subtle"><span class="h-2.5 w-2.5 rounded-full" style="background:#5e9fd2"></span>Underweight &lt; 18.5</span>
        <span class="flex items-center gap-1.5 text-ink-subtle"><span class="h-2.5 w-2.5 rounded-full" style="background:#27a644"></span>Normal 18.5–24.9</span>
        <span class="flex items-center gap-1.5 text-ink-subtle"><span class="h-2.5 w-2.5 rounded-full" style="background:#d2a05e"></span>Overweight 25–29.9</span>
        <span class="flex items-center gap-1.5 text-ink-subtle"><span class="h-2.5 w-2.5 rounded-full" style="background:#e5484d"></span>Obese 30+</span>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-3 text-center sm:grid-cols-3">
      <div class="panel p-4"><div id="bmi-range" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Healthy weight for your height</div></div>
      <div class="panel p-4"><div id="bmi-prime" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">BMI Prime</div></div>
      <div class="panel p-4"><div id="bmi-ponderal" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Ponderal Index</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free BMI calculator finds your Body Mass Index from your height and
      weight in metric or imperial units, then shows which category it falls into
      — underweight, normal, overweight or obese, using standard WHO ranges. BMI
      is a quick screening figure, not a diagnosis. All calculations run in your
      browser.
    </p>
  </div>
</ToolLayout>

<script>
  let unit: 'metric' | 'imperial' = 'metric';
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const valueEl = document.getElementById('bmi-value')!;
  const catEl = document.getElementById('bmi-cat')!;

  function category(bmi: number): [string, string] {
    if (bmi < 18.5) return ['Underweight', '#5e9fd2'];
    if (bmi < 25) return ['Normal weight', '#27a644'];
    if (bmi < 30) return ['Overweight', '#d2a05e'];
    return ['Obese', '#e5484d'];
  }

  function calc() {
    let m = 0, kg = 0;
    if (unit === 'metric') {
      m = Number($('bmi-cm').value) / 100;
      kg = Number($('bmi-kg').value);
    } else {
      const totalIn = Number($('bmi-ft').value) * 12 + Number($('bmi-in').value);
      m = totalIn * 0.0254;
      kg = Number($('bmi-lb').value) * 0.45359237;
    }
    const marker = document.getElementById('bmi-marker')!;
    const markerVal = document.getElementById('bmi-marker-val')!;
    const rangeEl = document.getElementById('bmi-range')!;
    const primeEl = document.getElementById('bmi-prime')!;
    const ponderalEl = document.getElementById('bmi-ponderal')!;
    if (!(m > 0) || !(kg > 0)) {
      valueEl.textContent = '—'; catEl.textContent = '';
      markerVal.textContent = '—'; marker.style.left = '0';
      rangeEl.textContent = primeEl.textContent = ponderalEl.textContent = '—';
      return;
    }
    const bmi = kg / (m * m);
    valueEl.textContent = bmi.toFixed(1);
    const [label, color] = category(bmi);
    catEl.textContent = label;
    catEl.style.color = color;

    const loKg = 18.5 * m * m;
    const hiKg = 25 * m * m;
    if (unit === 'imperial') {
      rangeEl.textContent = `${(loKg / 0.45359237).toFixed(0)}–${(hiKg / 0.45359237).toFixed(0)} lb`;
    } else {
      rangeEl.textContent = `${loKg.toFixed(1)}–${hiKg.toFixed(1)} kg`;
    }
    primeEl.textContent = (bmi / 25).toFixed(2);
    ponderalEl.textContent = (kg / (m * m * m)).toFixed(1) + ' kg/m³';

    // Chart scale spans BMI 15–40 (4% per unit; ticks at 18.5→14%, 25→40%, 30→60%).
    const pos = Math.max(0, Math.min(100, 14 + (bmi - 18.5) * 4));
    marker.style.left = pos + '%';
    markerVal.textContent = bmi.toFixed(1);
    markerVal.style.background = color;
    (marker.querySelector('span:last-child') as HTMLElement).style.borderTopColor = color;
  }

  document.querySelectorAll<HTMLButtonElement>('.bmi-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      unit = tab.dataset.unit as 'metric' | 'imperial';
      document.querySelectorAll('.bmi-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('bmi-metric')!.classList.toggle('hidden', unit !== 'metric');
      document.getElementById('bmi-metric')!.classList.toggle('grid', unit === 'metric');
      document.getElementById('bmi-imperial')!.classList.toggle('hidden', unit !== 'imperial');
      document.getElementById('bmi-imperial')!.classList.toggle('grid', unit === 'imperial');
      calc();
    });
  });
  document.querySelectorAll('#bmi-metric input, #bmi-imperial input').forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="freelance-rate-estimator">
  <div class="flex flex-col gap-4">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Target annual income
        <input id="fre-income" type="number" min="0" step="any" class="field" value="80000" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Annual business expenses
        <input id="fre-expenses" type="number" min="0" step="any" class="field" value="12000" inputmode="decimal" />
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Billable days per week
        <input id="fre-days" type="number" min="0" max="7" step="any" class="field" value="4" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Weeks off per year
        <input id="fre-weeksoff" type="number" min="0" max="52" step="any" class="field" value="6" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Billable hours per day
        <input id="fre-hours" type="number" min="0" max="24" step="any" class="field" value="6" inputmode="decimal" />
      </label>
    </div>

    <p id="fre-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel p-4"><div id="fre-revenue" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Revenue needed</div></div>
      <div class="panel p-4"><div id="fre-billable-days" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Billable days/yr</div></div>
      <div class="panel panel-lift p-4"><div id="fre-day-rate" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Day rate</div></div>
      <div class="panel panel-lift p-4"><div id="fre-hour-rate" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Hourly rate</div></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free freelance rate estimator turns your goals into a day rate and an
      hourly rate. It adds your target take-home income to your annual business
      expenses to find the revenue you need, then divides by the number of days
      you can actually bill each year — accounting for weeks off and the fact
      that not every working day is billable. Dividing the day rate by your
      billable hours gives the hourly figure. Use it as a floor for pricing, not
      a ceiling. Everything is calculated in your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const income = document.getElementById('fre-income') as HTMLInputElement;
  const expenses = document.getElementById('fre-expenses') as HTMLInputElement;
  const days = document.getElementById('fre-days') as HTMLInputElement;
  const weeksOff = document.getElementById('fre-weeksoff') as HTMLInputElement;
  const hours = document.getElementById('fre-hours') as HTMLInputElement;
  const err = document.getElementById('fre-error')!;

  const money = (n: number) =>
    n.toLocaleString(undefined, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

  function calc() {
    err.classList.add('hidden');
    const revenue = (Number(income.value) || 0) + (Number(expenses.value) || 0);
    const daysPerWeek = Math.max(0, Number(days.value) || 0);
    const off = Math.max(0, Number(weeksOff.value) || 0);
    const hrsPerDay = Math.max(0, Number(hours.value) || 0);

    const workingWeeks = Math.max(0, 52 - off);
    const billableDays = daysPerWeek * workingWeeks;

    const ids = ['fre-revenue', 'fre-billable-days', 'fre-day-rate', 'fre-hour-rate'];
    if (billableDays <= 0) {
      ids.forEach((id) => (document.getElementById(id)!.textContent = '—'));
      err.textContent = 'Enter billable days per week and fewer than 52 weeks off to get a rate.';
      err.classList.remove('hidden');
      return;
    }

    const dayRate = revenue / billableDays;
    const hourRate = hrsPerDay > 0 ? dayRate / hrsPerDay : 0;

    document.getElementById('fre-revenue')!.textContent = money(revenue);
    document.getElementById('fre-billable-days')!.textContent =
      billableDays.toLocaleString(undefined, { maximumFractionDigits: 0 });
    document.getElementById('fre-day-rate')!.textContent = money(dayRate);
    document.getElementById('fre-hour-rate')!.textContent = hrsPerDay > 0 ? money(hourRate) : '—';
  }

  [income, expenses, days, weeksOff, hours].forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

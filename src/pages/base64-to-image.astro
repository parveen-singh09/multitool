---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="base64-to-image">
  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-1 text-sm text-ink-subtle">
      <span class="flex items-center justify-between">
        <span>Base64 or data URI</span>
        <span class="flex gap-2">
          <button id="b2i-sample" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Sample</button>
          <button id="b2i-load" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Load file</button>
          <button id="b2i-clear" type="button" class="btn btn-tertiary px-2 py-1 text-[13px]">Clear</button>
        </span>
      </span>
      <div class="copy-wrap">
        <textarea id="b2i-in" class="field font-mono text-[13px]" rows="6" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder="Paste or drop a data:image/png;base64,iVBORw0KGgo… URI, or just the raw Base64. Type is auto-detected."></textarea>
        <button type="button" class="copy-icon" data-copy-target="#b2i-in" aria-label="Copy"></button>
      </div>
      <input id="b2i-file" type="file" accept=".txt,text/plain" class="hidden" />
    </div>

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        If type can't be detected, assume
        <select id="b2i-type" class="field w-40">
          <option value="image/png">PNG</option>
          <option value="image/jpeg">JPEG</option>
          <option value="image/webp">WebP</option>
          <option value="image/gif">GIF</option>
          <option value="image/bmp">BMP</option>
          <option value="image/x-icon">ICO</option>
          <option value="image/svg+xml">SVG</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Download filename
        <input id="b2i-name" class="field w-48" value="image" spellcheck="false" />
      </label>
      <button id="b2i-download" type="button" class="btn btn-primary self-end" disabled>Download</button>
      <button id="b2i-copy-uri" type="button" class="btn btn-secondary self-end" disabled>Copy data URI</button>
    </div>

    <p id="b2i-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="b2i-wrap" class="hidden flex-col gap-4">
      <div class="flex flex-col gap-1">
        <span class="text-[13px] text-ink-subtle" id="b2i-info"></span>
        <div class="panel flex justify-center overflow-hidden p-4" style="background-image:linear-gradient(45deg,#2a2a2e 25%,transparent 25%),linear-gradient(-45deg,#2a2a2e 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#2a2a2e 75%),linear-gradient(-45deg,transparent 75%,#2a2a2e 75%);background-size:16px 16px;background-position:0 0,0 8px,8px -8px,-8px 0">
          <img id="b2i-preview" class="max-h-96 w-auto max-w-full rounded-md" alt="Decoded image preview" />
        </div>
      </div>

      <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
        <div class="flex flex-col gap-1 text-sm text-ink-subtle">
          <span>HTML &lt;img&gt;</span>
          <div class="copy-wrap">
            <pre class="hl-block field" style="height:8rem;margin:0;overflow:auto;white-space:pre-wrap;word-break:break-all"><code id="b2i-html" class="hljs" style="background:transparent;padding:0"></code></pre>
            <button type="button" class="copy-icon" data-copy-target="#b2i-html" aria-label="Copy"></button>
          </div>
        </div>
        <div class="flex flex-col gap-1 text-sm text-ink-subtle">
          <span>CSS background</span>
          <div class="copy-wrap">
            <pre class="hl-block field" style="height:8rem;margin:0;overflow:auto;white-space:pre-wrap;word-break:break-all"><code id="b2i-css" class="hljs" style="background:transparent;padding:0"></code></pre>
            <button type="button" class="copy-icon" data-copy-target="#b2i-css" aria-label="Copy"></button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Base64 to image converter decodes a Base64 string or data URI
      back into a viewable image you can download. Paste a full
      <code>data:image/…;base64,…</code> URI or just the raw Base64 — the image
      type is <strong>auto-detected from the decoded bytes</strong> (magic
      numbers), so PNG, JPEG, WebP, GIF, BMP, ICO and SVG all just work without
      picking a format. If detection ever fails, the fallback selector lets you
      force a type.
    </p>
    <p>
      Beyond a live preview with a transparency checkerboard, it shows the
      decoded image's dimensions, MIME type and byte size, and generates ready
      to paste <code>&lt;img&gt;</code> HTML and CSS <code>background-image</code>
      snippets — both syntax-highlighted and one click to copy. You can also copy
      the normalized data URI, set a custom download filename, load Base64 from a
      text file, or drop a file onto the input. It's the counterpart to encoding
      an image as Base64 for CSS or HTML.
    </p>
  </div>
</ToolLayout>

<script>
  import { hl } from '../lib/highlight';

  const input = document.getElementById('b2i-in') as HTMLTextAreaElement;
  const typeSel = document.getElementById('b2i-type') as HTMLSelectElement;
  const nameEl = document.getElementById('b2i-name') as HTMLInputElement;
  const preview = document.getElementById('b2i-preview') as HTMLImageElement;
  const wrap = document.getElementById('b2i-wrap')!;
  const info = document.getElementById('b2i-info')!;
  const err = document.getElementById('b2i-error')!;
  const htmlOut = document.getElementById('b2i-html')!;
  const cssOut = document.getElementById('b2i-css')!;
  const dlBtn = document.getElementById('b2i-download') as HTMLButtonElement;
  const copyUri = document.getElementById('b2i-copy-uri') as HTMLButtonElement;
  const fileInput = document.getElementById('b2i-file') as HTMLInputElement;
  let currentType = 'image/png';
  let currentUri = '';

  const EXT: Record<string, string> = {
    'image/png': 'png', 'image/jpeg': 'jpg', 'image/webp': 'webp', 'image/gif': 'gif',
    'image/bmp': 'bmp', 'image/x-icon': 'ico', 'image/svg+xml': 'svg',
  };

  function setErr(m: string) {
    err.textContent = m;
    err.classList.toggle('hidden', !m);
    if (m) { wrap.classList.add('hidden'); wrap.classList.remove('flex'); dlBtn.disabled = copyUri.disabled = true; }
  }

  function detectMime(bytes: Uint8Array): string {
    const b = bytes;
    if (b[0] === 0x89 && b[1] === 0x50 && b[2] === 0x4e && b[3] === 0x47) return 'image/png';
    if (b[0] === 0xff && b[1] === 0xd8 && b[2] === 0xff) return 'image/jpeg';
    if (b[0] === 0x47 && b[1] === 0x49 && b[2] === 0x46) return 'image/gif';
    if (b[0] === 0x42 && b[1] === 0x4d) return 'image/bmp';
    if (b[0] === 0x00 && b[1] === 0x00 && b[2] === 0x01 && b[3] === 0x00) return 'image/x-icon';
    if (b[0] === 0x52 && b[1] === 0x49 && b[2] === 0x46 && b[3] === 0x46 && b[8] === 0x57 && b[9] === 0x45 && b[10] === 0x42 && b[11] === 0x50) return 'image/webp';
    let s = '';
    for (let i = 0; i < Math.min(b.length, 256); i++) s += String.fromCharCode(b[i]);
    if (/^\s*(<\?xml|<svg)/i.test(s)) return 'image/svg+xml';
    return '';
  }

  function fmtSize(n: number): string {
    if (n < 1024) return n + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
    return (n / (1024 * 1024)).toFixed(2) + ' MB';
  }

  async function render() {
    const raw = input.value.trim();
    if (!raw) { setErr(''); wrap.classList.add('hidden'); wrap.classList.remove('flex'); dlBtn.disabled = copyUri.disabled = true; return; }

    let declaredType = '';
    let b64: string;
    let isUrlEncoded = false;
    if (raw.startsWith('data:')) {
      const m = raw.match(/^data:([^;,]+)?(;base64)?,(.*)$/s);
      if (!m) { setErr('That does not look like a valid data URI.'); return; }
      declaredType = m[1] || '';
      isUrlEncoded = !m[2]; 
      b64 = m[3].replace(/\s/g, '');
    } else {
      b64 = raw.replace(/\s/g, '');
    }

    if (isUrlEncoded) {
      currentType = declaredType || 'image/svg+xml';
      currentUri = raw.replace(/^(data:[^,]*,)([\s\S]*)$/, (_x, h, p) => h + p.replace(/\s/g, ''));
      await load(currentUri, 0, null);
      return;
    }

    if (!/^[A-Za-z0-9+/]*={0,2}$/.test(b64)) { setErr('The Base64 data contains invalid characters.'); return; }

    let bin: string;
    try { bin = atob(b64); } catch { setErr('The Base64 data is malformed (bad length or padding).'); return; }
    const bytes = new Uint8Array(Math.min(bin.length, 32));
    for (let i = 0; i < bytes.length; i++) bytes[i] = bin.charCodeAt(i);

    currentType = detectMime(bytes) || declaredType || typeSel.value;
    currentUri = `data:${currentType};base64,${b64}`;
    await load(currentUri, bin.length, currentType);
  }

  function load(dataUri: string, byteLen: number, detected: string | null) {
    return new Promise<void>((resolve) => {
      const test = new Image();
      test.onload = async () => {
        setErr('');
        preview.src = dataUri;
        const ext = EXT[currentType] || currentType.split('/')[1] || 'img';
        const dim = currentType === 'image/svg+xml' && !test.naturalWidth ? 'scalable' : `${test.naturalWidth}×${test.naturalHeight}`;
        const detNote = detected ? ' · detected' : '';
        info.textContent = `${dim} · ${currentType}${detNote}${byteLen ? ' · ' + fmtSize(byteLen) : ''}`;
        wrap.classList.remove('hidden'); wrap.classList.add('flex');
        dlBtn.disabled = copyUri.disabled = false;
        const fname = (nameEl.value.trim() || 'image') + '.' + ext;
        await hl(htmlOut, `<img src="${dataUri}" alt="${fname}" />`, 'xml');
        await hl(cssOut, `.element {\n  background-image: url("${dataUri}");\n}`, 'css');
        resolve();
      };
      test.onerror = () => { setErr('Could not decode that as an image. Check the data and the assumed type.'); resolve(); };
      test.src = dataUri;
    });
  }

  async function copyBtn(btn: HTMLButtonElement, text: string) {
    if (!text) return;
    await navigator.clipboard.writeText(text);
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = orig), 1400);
  }

  input.addEventListener('input', render);
  typeSel.addEventListener('change', render);
  nameEl.addEventListener('input', render);

  dlBtn.addEventListener('click', () => {
    if (!currentUri) return;
    const ext = EXT[currentType] || currentType.split('/')[1] || 'img';
    const a = document.createElement('a');
    a.download = (nameEl.value.trim() || 'image') + '.' + ext;
    a.href = currentUri;
    a.click();
  });

  copyUri.addEventListener('click', () => copyBtn(copyUri, currentUri));

  document.getElementById('b2i-clear')!.addEventListener('click', () => { input.value = ''; render(); });
  document.getElementById('b2i-sample')!.addEventListener('click', () => {
    // 1×1 red PNG — small, valid, exercises detection + download.
    input.value = 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAC0lEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==';
    render();
  });

  document.getElementById('b2i-load')!.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', async () => {
    const f = fileInput.files?.[0];
    if (!f) return;
    input.value = (await f.text()).trim();
    render();
  });

  // Drag & drop a text file onto the input.
  input.addEventListener('dragover', (e) => { e.preventDefault(); });
  input.addEventListener('drop', async (e) => {
    const f = e.dataTransfer?.files?.[0];
    if (!f) return; // let plain-text drops fall through to the textarea
    e.preventDefault();
    input.value = (await f.text()).trim();
    render();
  });
</script>

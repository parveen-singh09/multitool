---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="hashtag-generator">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">Topic or keywords (comma or space separated)
      <input id="hg-input" class="field" value="coffee, morning, cafe" spellcheck="false" />
    </label>
    <div class="flex flex-wrap items-end gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Platform
        <select id="hg-platform" class="field w-44">
          <option value="instagram">Instagram</option>
          <option value="tiktok">TikTok</option>
          <option value="youtube">YouTube</option>
          <option value="x">X / Twitter</option>
          <option value="facebook">Facebook</option>
          <option value="linkedin">LinkedIn</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">How many
        <input id="hg-count" type="number" min="5" max="60" value="30" class="field w-28" />
      </label>
      <button id="hg-gen" class="btn btn-primary ml-auto">Generate</button>
    </div>

    <div class="flex flex-wrap items-center gap-3 border-t border-hairline pt-4">
      <span id="hg-selcount" class="text-sm text-ink-subtle">0 selected</span>
      <button id="hg-copy-sel" class="btn btn-secondary">Copy selected</button>
      <button id="hg-copy-all" class="btn btn-secondary">Copy all</button>
      <button id="hg-clear" class="btn btn-secondary">Clear selection</button>
    </div>

    <div id="hg-out" class="flex flex-col gap-5"></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free hashtag generator turns your topic and keywords into a ready-to-post
      set of hashtags for Instagram, TikTok, YouTube, X, Facebook and LinkedIn. Unlike a
      flat list, it groups tags by <strong class="text-ink">reach tier</strong> — broad,
      popular and niche — which mirrors the strategy of mixing high-competition and
      low-competition tags to get discovered without drowning in a crowded feed.
    </p>
    <p>
      Enter one or more keywords and pick a platform. The generator injects that
      platform's native discovery tags, matches your topic against a curated niche
      lexicon (food, fitness, travel, photography, gaming and more) for relevance, and
      builds keyword combinations in both lowercase and CamelCase for accessibility.
      Click any tag to select it, then copy just your picks, a whole group, or everything.
    </p>
  </div>
</ToolLayout>

<script>
  import { shuffle, sample } from '../lib/random';

  const $ = (id: string) => document.getElementById(id)!;
  const input = $('hg-input') as HTMLInputElement;
  const platformEl = $('hg-platform') as HTMLSelectElement;
  const countEl = $('hg-count') as HTMLInputElement;
  const out = $('hg-out')!;
  const selCountEl = $('hg-selcount')!;

  const PLATFORM: Record<string, string[]> = {
    instagram: ['instagood', 'photooftheday', 'instadaily', 'love', 'picoftheday', 'reels', 'explore', 'viral', 'trending', 'instamood', 'bestoftheday', 'igdaily'],
    tiktok: ['fyp', 'foryou', 'foryoupage', 'tiktok', 'viral', 'trending', 'tiktokviral', 'trend', 'capcut', 'duet', 'foryourpage'],
    youtube: ['youtube', 'shorts', 'subscribe', 'youtuber', 'newvideo', 'contentcreator', 'vlog', 'video', 'youtubechannel'],
    x: ['trending', 'viral', 'news', 'follow', 'thread', 'breaking', 'retweet'],
    facebook: ['facebook', 'share', 'community', 'follow', 'like', 'fbreels', 'viral'],
    linkedin: ['linkedin', 'networking', 'career', 'business', 'leadership', 'professional', 'growth', 'hiring', 'success'],
  };

  const MODIFIERS = ['love', 'life', 'daily', 'lover', 'community', 'lifestyle', 'inspo', 'goals', 'vibes', 'oftheday', 'addict', 'world', 'tips', 'ideas'];

  const NICHE: Record<string, string[]> = {
    coffee: ['coffee', 'coffeelover', 'coffeetime', 'coffeeaddict', 'baristalife', 'coffeegram', 'espresso', 'latteart', 'coffeeshop', 'caffeine'],
    food: ['foodie', 'foodporn', 'instafood', 'foodphotography', 'yummy', 'delicious', 'homemade', 'foodblogger', 'foodstagram', 'tasty'],
    fitness: ['fitness', 'gym', 'workout', 'fitfam', 'fitlife', 'training', 'motivation', 'gymlife', 'healthylifestyle', 'bodybuilding'],
    travel: ['travel', 'travelgram', 'wanderlust', 'instatravel', 'travelphotography', 'adventure', 'vacation', 'traveltheworld', 'trip', 'explore'],
    fashion: ['fashion', 'ootd', 'style', 'fashionista', 'fashionblogger', 'outfit', 'streetstyle', 'instafashion', 'fashionstyle', 'trendy'],
    photography: ['photography', 'photographer', 'naturephotography', 'portrait', 'photoshoot', 'streetphotography', 'capture', 'photographylovers', 'photoart'],
    business: ['business', 'entrepreneur', 'marketing', 'success', 'startup', 'smallbusiness', 'hustle', 'branding', 'growth', 'mindset'],
    art: ['art', 'artist', 'artwork', 'drawing', 'illustration', 'digitalart', 'painting', 'creative', 'artoftheday', 'sketch'],
    music: ['music', 'musician', 'newmusic', 'hiphop', 'producer', 'song', 'musicproducer', 'singer', 'livemusic', 'spotify'],
    beauty: ['beauty', 'makeup', 'skincare', 'makeupartist', 'mua', 'beautyblogger', 'cosmetics', 'glam', 'selfcare', 'makeuptutorial'],
    nature: ['nature', 'naturelovers', 'landscape', 'wildlife', 'outdoors', 'earth', 'mountains', 'sunset', 'hiking', 'naturephotography'],
    pet: ['dog', 'cat', 'pets', 'dogsofinstagram', 'catsofinstagram', 'puppy', 'petstagram', 'doglover', 'cute', 'animals'],
    dog: ['dog', 'dogsofinstagram', 'puppy', 'doglover', 'dogstagram', 'doglife', 'puppylove', 'ilovemydog', 'dogoftheday', 'pets'],
    game: ['gaming', 'gamer', 'videogames', 'gamingcommunity', 'twitch', 'streamer', 'esports', 'gamerlife', 'pcgaming', 'gamingsetup'],
    wedding: ['wedding', 'bride', 'weddingphotography', 'weddinginspiration', 'bridal', 'weddingday', 'engaged', 'weddingdress', 'groom', 'love'],
    home: ['homedecor', 'interiordesign', 'home', 'decor', 'interior', 'homedesign', 'homesweethome', 'homestyle', 'homeinspo', 'design'],
    book: ['books', 'bookstagram', 'reading', 'booklover', 'bookworm', 'bookish', 'reader', 'booksofinstagram', 'amreading', 'bibliophile'],
    car: ['cars', 'carsofinstagram', 'carlifestyle', 'automotive', 'carphotography', 'jdm', 'supercars', 'carporn', 'carlovers', 'motor'],
  };

  const cap = (w: string) => w.charAt(0).toUpperCase() + w.slice(1);
  const H = (w: string) => '#' + w;

  function parseWords(): string[] {
    return input.value
      .split(/[\s,]+/)
      .map((w) => w.trim().toLowerCase().replace(/[^a-z0-9]/g, ''))
      .filter(Boolean);
  }

  function nicheTags(words: string[]): string[] {
    const out: string[] = [];
    for (const [key, bank] of Object.entries(NICHE)) {
      if (words.some((w) => w.includes(key) || key.includes(w))) out.push(...bank);
    }
    return out;
  }

  const selected = new Set<string>();

  function updateSelCount() {
    selCountEl.textContent = `${selected.size} selected`;
  }

  function generate() {
    const words = parseWords();
    const platform = platformEl.value;
    const total = Math.max(5, Math.min(60, Number(countEl.value) || 30));
    const seen = new Set<string>();

    // Take up to `n` fresh (unseen) tags from a candidate pool.
    const take = (pool: string[], n: number): string[] => {
      const picked: string[] = [];
      for (const raw of pool) {
        const t = H(raw);
        if (seen.has(t)) continue;
        seen.add(t);
        picked.push(t);
        if (picked.length >= n) break;
      }
      return picked;
    };

    // Keyword tags (raw + CamelCase) — highest intent, always relevant.
    const kwPool = words.flatMap((w) => [w, cap(w)]);

    // Broad reach: platform-native + generic engagement (high competition).
    const broadPool = shuffle([...(PLATFORM[platform] || []), 'love', 'viral', 'trending', 'explore', 'follow', 'instagram']);

    // Popular: niche lexicon + keyword×modifier combos (medium competition).
    const niche = nicheTags(words);
    const combos = words.flatMap((w) => sample(MODIFIERS, 4).map((m) => w + m));
    const popularPool = shuffle([...niche, ...combos]);

    // Niche & specific: CamelCase keyword pairs + long-tail combos (low competition, high intent).
    const nichePool: string[] = [];
    for (let i = 0; i < words.length; i++)
      for (let j = i + 1; j < words.length; j++) nichePool.push(cap(words[i]) + cap(words[j]));
    for (const w of words) nichePool.push(cap(w) + 'OfInstagram', 'the' + cap(w) + 'life');

    // Distribute the total budget across tiers (keywords always included first).
    const kw = take(kwPool, words.length * 2);
    const remaining = Math.max(0, total - kw.length);
    const broad = take(broadPool, Math.round(remaining * 0.3));
    const popular = take(popularPool, Math.round(remaining * 0.4));
    const niched = take(shuffle(nichePool), Math.max(0, total - kw.length - broad.length - popular.length));

    const groups: [string, string[]][] = [
      ['Your keywords', kw],
      ['Broad reach', broad],
      ['Popular', popular],
      ['Niche & specific', niched],
    ].filter(([, tags]) => tags.length > 0) as [string, string[]][];

    render(groups);
  }

  function render(groups: [string, string[]][]) {
    out.innerHTML = groups
      .map(
        ([title, tags]) => `
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-3">
          <h3 class="font-display text-sm font-semibold text-ink">${title}</h3>
          <span class="text-xs text-ink-tertiary">${tags.length} tags</span>
          <button class="hg-copy-group text-xs text-primary-hover hover:underline ml-auto" data-tags="${tags.join(' ')}">Copy group</button>
        </div>
        <div class="flex flex-wrap gap-2">
          ${tags
            .map(
              (t) =>
                `<button class="status-badge cursor-pointer hover:border-hairline-strong ${
                  selected.has(t) ? 'hg-on' : ''
                }" data-t="${t}">${t}</button>`,
            )
            .join('')}
        </div>
      </div>`,
      )
      .join('');

    // Toggle-select a tag on click.
    out.querySelectorAll<HTMLElement>('button[data-t]').forEach((b) => {
      b.addEventListener('click', () => {
        const t = b.dataset.t!;
        if (selected.has(t)) {
          selected.delete(t);
          b.classList.remove('hg-on');
        } else {
          selected.add(t);
          b.classList.add('hg-on');
        }
        updateSelCount();
      });
    });

    // Per-group copy.
    out.querySelectorAll<HTMLElement>('.hg-copy-group').forEach((b) => {
      b.addEventListener('click', async () => {
        await navigator.clipboard.writeText(b.dataset.tags!);
        const orig = b.textContent;
        b.textContent = 'Copied!';
        setTimeout(() => (b.textContent = orig), 1000);
      });
    });
  }

  async function copyTo(btn: HTMLButtonElement, text: string, label: string) {
    if (!text) return;
    await navigator.clipboard.writeText(text);
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => (btn.textContent = label), 1200);
  }

  $('hg-gen').addEventListener('click', generate);
  [input, platformEl, countEl].forEach((el) => el.addEventListener('input', generate));

  $('hg-copy-sel').addEventListener('click', (e) =>
    copyTo(e.currentTarget as HTMLButtonElement, [...selected].join(' '), 'Copy selected'),
  );
  $('hg-copy-all').addEventListener('click', (e) => {
    const all = [...out.querySelectorAll<HTMLElement>('button[data-t]')].map((b) => b.dataset.t).join(' ');
    copyTo(e.currentTarget as HTMLButtonElement, all, 'Copy all');
  });
  $('hg-clear').addEventListener('click', () => {
    selected.clear();
    out.querySelectorAll('.hg-on').forEach((b) => b.classList.remove('hg-on'));
    updateSelCount();
  });

  generate();
</script>

<style>
  .hg-on {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border-color: var(--color-primary);
  }
</style>

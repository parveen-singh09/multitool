---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="time-converter">
  <div id="tc-root" class="flex flex-col gap-5">

    <div class="flex flex-wrap items-end justify-between gap-3">
      <div class="flex flex-wrap items-end gap-2">
        <span class="text-[13px] text-ink-subtle">Popular:</span>
        <button type="button" class="btn btn-tertiary px-2 py-1 text-[13px]" data-preset="Hour|Minute">Hours → Minutes</button>
        <button type="button" class="btn btn-tertiary px-2 py-1 text-[13px]" data-preset="Day|Hour">Days → Hours</button>
        <button type="button" class="btn btn-tertiary px-2 py-1 text-[13px]" data-preset="Minute|Second">Minutes → Seconds</button>
        <button type="button" class="btn btn-tertiary px-2 py-1 text-[13px]" data-preset="Week|Day">Weeks → Days</button>
        <button type="button" class="btn btn-tertiary px-2 py-1 text-[13px]" data-preset="Year (365 days)|Day">Years → Days</button>
      </div>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Precision
        <select id="tc-prec" class="field w-auto py-1">
          <option value="auto" selected>Auto</option>
          <option value="0">0 decimals</option>
          <option value="2">2 decimals</option>
          <option value="4">4 decimals</option>
          <option value="6">6 decimals</option>
          <option value="10">10 decimals</option>
        </select>
      </label>
    </div>

    <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="tc-from-val">From</label>
        <input id="tc-from-val" type="number" class="field" value="1" inputmode="decimal" autocomplete="off" />
        <select id="tc-from-unit" class="field mt-1"></select>
      </div>
      <button
        id="tc-swap"
        type="button"
        class="btn btn-secondary mb-1 h-10 w-10 shrink-0 justify-self-center p-0"
        aria-label="Swap units"
        title="Swap units"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4"/></svg>
      </button>
      <div class="flex flex-col gap-1">
        <label class="text-sm text-ink-subtle" for="tc-to-val">To</label>
        <div class="copy-wrap">
          <input id="tc-to-val" type="text" class="field font-mono" readonly aria-live="polite" />
          <button type="button" class="copy-icon" data-copy-target="#tc-to-val" aria-label="Copy"></button>
        </div>
        <select id="tc-to-unit" class="field mt-1"></select>
      </div>
    </div>

    <p id="tc-formula" class="text-[13px] text-ink-tertiary"></p>
    <p id="tc-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="panel p-4">
      <p class="eyebrow mb-2 text-ink-subtle">Human-readable breakdown</p>
      <p id="tc-human" class="font-mono text-[15px] text-ink"></p>
    </div>

    <div>
      <p class="mb-2 text-[13px] text-ink-subtle">
        <span id="tc-allhead">1 Hour</span> in every unit
      </p>
      <div id="tc-all" class="overflow-hidden rounded-md border border-hairline"></div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free time converter converts durations between nanoseconds, microseconds,
      milliseconds, seconds, minutes, hours, days, weeks, fortnights, months, years,
      decades, centuries and millennia. Enter a value, pick the units, and the result
      updates live — with a swap button, adjustable precision (auto, or a fixed 0–10
      decimal places), and one-click copy. Useful for scheduling, timeouts, rate limits
      and quick estimates.
    </p>
    <p>
      Beyond a single from/to conversion, the tool shows a human-readable breakdown that
      splits any duration into years, days, hours, minutes, seconds and milliseconds
      (for example, 5000 seconds is 1 hour, 23 minutes, 20 seconds), plus a reference
      grid expressing your input in every supported unit at once. Months default to 30
      days and years to 365 days, with average-length variants (30.44-day month,
      365.25-day Julian year) also available so calendar estimates stay accurate. Invalid
      input is flagged with a clear message rather than failing silently.
    </p>
  </div>
</ToolLayout>

<script>

  const UNITS: [string, number][] = [
    ['Nanosecond', 1e-9],
    ['Microsecond', 1e-6],
    ['Millisecond', 1e-3],
    ['Second', 1],
    ['Minute', 60],
    ['Hour', 3600],
    ['Day', 86400],
    ['Week', 604800],
    ['Fortnight', 1209600],
    ['Month (30 days)', 2592000],
    ['Month (average 30.44 days)', 2629746],
    ['Year (365 days)', 31536000],
    ['Year (365.25 days)', 31557600],
    ['Decade', 315576000],
    ['Century', 3155760000],
    ['Millennium', 31557600000],
  ];
  const FACTOR: Record<string, number> = Object.fromEntries(UNITS);

  const fromVal = document.getElementById('tc-from-val') as HTMLInputElement;
  const toVal = document.getElementById('tc-to-val') as HTMLInputElement;
  const fromUnit = document.getElementById('tc-from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('tc-to-unit') as HTMLSelectElement;
  const prec = document.getElementById('tc-prec') as HTMLSelectElement;
  const swap = document.getElementById('tc-swap') as HTMLButtonElement;
  const formula = document.getElementById('tc-formula') as HTMLElement;
  const errEl = document.getElementById('tc-error') as HTMLElement;
  const human = document.getElementById('tc-human') as HTMLElement;
  const allHead = document.getElementById('tc-allhead') as HTMLElement;
  const allTable = document.getElementById('tc-all') as HTMLElement;

  function fmt(n: number): string {
    if (!isFinite(n)) return '∞';
    if (n === 0) return '0';
    const abs = Math.abs(n);
    const p = prec.value;
    if (p === 'auto') {
      if (abs >= 1e15 || abs < 1e-6) return n.toExponential(6);
      const r = Math.round(n * 1e9) / 1e9;
      return r.toLocaleString('en-US', { maximumFractionDigits: 9 });
    }
    const dp = Number(p);
    if (abs >= 1e15 || (abs < Math.pow(10, -dp) / 2 && dp < 12)) {
      return n.toExponential(Math.min(dp, 6));
    }
    return n.toLocaleString('en-US', { minimumFractionDigits: dp, maximumFractionDigits: dp });
  }

  function convert(value: number, from: string, to: string): number {
    return (value * FACTOR[from]) / FACTOR[to];
  }

  function humanize(totalSeconds: number): string {
    if (!isFinite(totalSeconds)) return '∞';
    if (totalSeconds === 0) return '0 seconds';
    const neg = totalSeconds < 0;
    let s = Math.abs(totalSeconds);
    const steps: [string, number][] = [
      ['year', 31536000], ['day', 86400], ['hour', 3600], ['minute', 60], ['second', 1],
    ];
    const parts: string[] = [];
    for (const [name, sec] of steps) {
      if (s >= sec) {
        const q = Math.floor(s / sec);
        s -= q * sec;
        parts.push(`${q.toLocaleString('en-US')} ${name}${q === 1 ? '' : 's'}`);
      }
    }
    if (s > 1e-9) {
      const ms = Math.round(s * 1e6) / 1e3;
      parts.push(`${ms} ms`);
    }
    return (neg ? '-' : '') + (parts.length ? parts.join(', ') : '0 seconds');
  }

  function fillUnits() {
    const opts = UNITS.map(([u]) => `<option>${u}</option>`).join('');
    fromUnit.innerHTML = opts;
    toUnit.innerHTML = opts;
    fromUnit.value = 'Hour';
    toUnit.value = 'Minute';
  }

  function renderAll(baseSeconds: number, from: string) {
    const rows = UNITS
      .filter(([u]) => u !== from)
      .map(([u]) => {
        const r = baseSeconds / FACTOR[u];
        return `<tr class="border-t border-hairline">
          <td class="px-3 py-2 text-ink-subtle">${u}</td>
          <td class="px-3 py-2 text-right font-mono text-ink">${fmt(r)}</td>
        </tr>`;
      })
      .join('');
    allTable.innerHTML = `<table class="w-full text-[13px]">${rows}</table>`;
  }

  function run() {
    errEl.classList.add('hidden');
    const from = fromUnit.value, to = toUnit.value;
    allHead.textContent = `${fromVal.value.trim() || '1'} ${from}`;

    const raw = fromVal.value.trim();
    if (raw === '' || isNaN(Number(raw))) {
      toVal.value = '';
      formula.textContent = '';
      human.textContent = '';
      allTable.innerHTML = '';
      if (raw !== '') {
        errEl.textContent = `"${raw}" is not a valid number.`;
        errEl.classList.remove('hidden');
      }
      return;
    }

    const v = Number(raw);
    const result = convert(v, from, to);
    const baseSeconds = v * FACTOR[from];
    toVal.value = fmt(result);
    formula.textContent = `${fmt(v)} ${from} = ${fmt(result)} ${to}`;
    human.textContent = humanize(baseSeconds);
    renderAll(baseSeconds, from);
  }

  fromVal.addEventListener('input', run);
  fromUnit.addEventListener('change', run);
  toUnit.addEventListener('change', run);
  prec.addEventListener('change', run);

  swap.addEventListener('click', () => {
    const a = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = a;
    if (toVal.value !== '') {
      const n = Number(toVal.value.replace(/,/g, ''));
      if (!isNaN(n)) fromVal.value = String(n);
    }
    run();
  });

  document.querySelectorAll<HTMLButtonElement>('[data-preset]').forEach((b) => {
    b.addEventListener('click', () => {
      const [f, t] = b.dataset.preset!.split('|');
      if (FACTOR[f] !== undefined) fromUnit.value = f;
      if (FACTOR[t] !== undefined) toUnit.value = t;
      run();
    });
  });

  fillUnits();
  run();
</script>

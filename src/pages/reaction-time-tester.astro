---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="reaction-time-tester">
  <div class="flex flex-col gap-4">
    <div
      id="rt-box"
      class="panel flex min-h-64 cursor-pointer select-none items-center justify-center rounded-lg p-8 text-center text-lg font-medium text-ink"
      style="background:#3a3a52"
      role="button"
      tabindex="0"
      aria-label="Reaction test area"
    >
      Click to start
    </div>

    <div class="grid grid-cols-2 gap-3 text-center sm:grid-cols-4">
      <div class="panel panel-lift p-4"><div id="rt-last" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Last</div></div>
      <div class="panel p-4"><div id="rt-best" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Best</div></div>
      <div class="panel p-4"><div id="rt-avg" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Average</div></div>
      <div class="panel p-4"><div id="rt-rounds" class="font-mono text-lg text-ink">0</div><div class="mt-1 text-[13px] text-ink-subtle">Rounds</div></div>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="rt-reset" class="btn btn-secondary">Reset stats</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free reaction time tester measures how quickly your reflexes fire.
      Click the box to arm a round, wait for it to turn green, then click again as
      fast as you can — your time appears in milliseconds. Click too early and the
      round resets. Play several rounds and the tool tracks your best and average
      times so you can benchmark your reflexes.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;
  const box = $('rt-box');
  const lastEl = $('rt-last');
  const bestEl = $('rt-best');
  const avgEl = $('rt-avg');
  const roundsEl = $('rt-rounds');

  type State = 'idle' | 'waiting' | 'ready';
  let state: State = 'idle';
  let timeoutId: number | null = null;
  let greenTime = 0;
  const times: number[] = [];

  const COLORS = {
    idle: '#3a3a52',
    waiting: '#c9432f',
    ready: '#27a644',
  };

  function setBox(bg: string, text: string) {
    box.style.background = bg;
    box.textContent = text;
  }

  function toIdle(msg: string) {
    if (timeoutId !== null) { clearTimeout(timeoutId); timeoutId = null; }
    state = 'idle';
    setBox(COLORS.idle, msg);
  }

  function arm() {
    state = 'waiting';
    setBox(COLORS.waiting, 'Wait for green…');
    const delay = 1000 + Math.random() * 2000;
    timeoutId = window.setTimeout(() => {
      state = 'ready';
      greenTime = performance.now();
      setBox(COLORS.ready, 'Click!');
    }, delay);
  }

  function record(ms: number) {
    times.push(ms);
    lastEl.textContent = ms + ' ms';
    bestEl.textContent = Math.min(...times) + ' ms';
    avgEl.textContent = Math.round(times.reduce((a, b) => a + b, 0) / times.length) + ' ms';
    roundsEl.textContent = String(times.length);
  }

  function handle() {
    if (state === 'idle') {
      arm();
    } else if (state === 'waiting') {
      toIdle('Too soon! Click to try again.');
    } else if (state === 'ready') {
      const ms = Math.round(performance.now() - greenTime);
      record(ms);
      state = 'idle';
      setBox(COLORS.idle, `${ms} ms — click to go again`);
    }
  }

  box.addEventListener('click', handle);
  box.addEventListener('keydown', (e) => {
    if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); handle(); }
  });

  $('rt-reset').addEventListener('click', () => {
    times.length = 0;
    lastEl.textContent = '—';
    bestEl.textContent = '—';
    avgEl.textContent = '—';
    roundsEl.textContent = '0';
    toIdle('Click to start');
  });
</script>

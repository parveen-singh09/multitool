---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="timeline-creator">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">

    <div class="flex flex-col gap-4">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Timeline title
        <input id="tlc-title" class="field" type="text" value="Company Roadmap" />
      </label>

      <div class="flex flex-wrap gap-1 rounded-md bg-surface-1 p-1" role="tablist">
        <button class="tlc-tab btn btn-tertiary" data-tab="events" aria-selected="true">Events</button>
        <button class="tlc-tab btn btn-tertiary" data-tab="templates">Templates</button>
        <button class="tlc-tab btn btn-tertiary" data-tab="style">Style</button>
        <button class="tlc-tab btn btn-tertiary" data-tab="autofill">Auto-fill</button>
      </div>

      <section data-panel="events" class="flex flex-col gap-3">
        <div id="tlc-rows" class="flex max-h-[60vh] flex-col gap-3 overflow-y-auto pr-1"></div>
        <button id="tlc-add" class="btn btn-secondary self-start">Add event</button>
      </section>

      <section data-panel="templates" class="hidden flex-col gap-4">
        <p class="text-sm text-ink-subtle">Pick a starting point. It replaces the current events.</p>
        <div id="tlc-templates" class="flex flex-col gap-4"></div>
      </section>

      <section data-panel="style" class="hidden flex-col gap-4">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Layout
          <select id="tlc-layout" class="field">
            <option value="vertical">Vertical</option>
            <option value="horizontal">Horizontal (time-scaled)</option>
            <option value="alternating">Alternating (infographic)</option>
          </select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Theme
          <select id="tlc-theme" class="field"></select>
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Size
          <select id="tlc-size" class="field"></select>
        </label>
      </section>

      <section data-panel="autofill" class="hidden flex-col gap-5">
        <div class="panel flex flex-col gap-3 p-4">
          <span class="text-sm font-medium text-ink">On this day in history</span>
          <p class="text-xs text-ink-subtle">Historical events from Wikipedia for a given date.</p>
          <div class="flex gap-2">
            <input id="tlc-otd-month" class="field w-full" type="number" min="1" max="12" placeholder="Month" value="7" />
            <input id="tlc-otd-day" class="field w-full" type="number" min="1" max="31" placeholder="Day" value="10" />
          </div>
          <button id="tlc-otd-go" class="btn btn-secondary self-start">Add events</button>
        </div>
        <div class="panel flex flex-col gap-3 p-4">
          <span class="text-sm font-medium text-ink">Public holidays</span>
          <p class="text-xs text-ink-subtle">Official holidays for a country and year (Nager.Date).</p>
          <div class="flex gap-2">
            <input id="tlc-hol-cc" class="field w-full" type="text" maxlength="2" placeholder="US" value="US" />
            <input id="tlc-hol-year" class="field w-full" type="number" placeholder="Year" value="2026" />
          </div>
          <button id="tlc-hol-go" class="btn btn-secondary self-start">Add holidays</button>
        </div>
        <p id="tlc-status" class="text-sm text-ink-subtle" role="status" aria-live="polite"></p>
      </section>
    </div>

    <div class="flex flex-col gap-3 lg:sticky lg:top-24 lg:self-start">
      <div class="flex flex-wrap gap-2">
        <button id="tlc-png" class="btn btn-primary">PNG</button>
        <button id="tlc-svg" class="btn btn-secondary">SVG</button>
        <button id="tlc-pdf" class="btn btn-secondary">PDF</button>
        <button id="tlc-copy" class="btn btn-secondary">Copy</button>
        <button id="tlc-json" class="btn btn-secondary">Export JSON</button>
        <button id="tlc-tljs" class="btn btn-secondary">TimelineJS</button>
        <button id="tlc-import" class="btn btn-tertiary">Import</button>
        <input id="tlc-file" type="file" accept=".json,application/json" class="hidden" />
      </div>
      <div class="panel overflow-auto p-3" style="max-height:80vh">
        <div id="tlc-preview" class="[&>svg]:h-auto [&>svg]:max-w-full [&>svg]:rounded-md" aria-label="Timeline preview"></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free timeline maker turns dated events into a polished graphic you can
      download. Choose a <strong>vertical</strong>, <strong>horizontal</strong>
      (time-scaled) or <strong>alternating infographic</strong> layout, add point
      events or date ranges, and pick from ready-made templates for company
      history, roadmaps, biographies, historical eras, projects, weddings and
      more. Dates parse and sort automatically — even BC dates for ancient
      history.
    </p>
    <p>
      Auto-fill a timeline from real data: pull historical events from Wikipedia's
      "on this day" or official public holidays for any country. Import and export
      the <strong>TimelineJS</strong> JSON format for interoperability, save your
      own JSON, and export as PNG, SVG, or PDF — or copy straight to the clipboard.
      Your draft is saved on this device.
    </p>
  </div>
</ToolLayout>

<script>
  import type { Timeline, TimelineEvent } from '../lib/timeline/types';
  import { parseDate } from '../lib/timeline/types';
  import { renderSVG } from '../lib/timeline/render';
  import { TIMELINE_THEMES, getTheme, SIZE_PRESETS, getSize } from '../lib/timeline/presets';
  import { templateGroups, templateToTimeline } from '../lib/timeline/templates';
  import { onThisDay, holidays } from '../lib/timeline/apis';
  import { toJSON, fromJSON, toTimelineJS, fromTimelineJS } from '../lib/timeline/interop';
  import { saveDraft, loadDraft } from '../lib/timeline/storage';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const titleEl = $<HTMLInputElement>('tlc-title');
  const rowsEl = $<HTMLDivElement>('tlc-rows');
  const preview = $<HTMLDivElement>('tlc-preview');
  const statusEl = $<HTMLParagraphElement>('tlc-status');

  const DEFAULT: Timeline = {
    title: 'Company Roadmap',
    layout: 'vertical', themeId: 'linear-dark', sizeId: 'portrait',
    events: [
      mkEvent('2024 Q1', 'Kickoff', 'Project scoped and team assembled.'),
      mkEvent('2024 Q3', 'Beta launch', 'First public beta released to users.'),
      mkEvent('2025 Q1', 'General availability', 'Full launch across all regions.'),
    ],
  };

  function mkEvent(date: string, title: string, desc = ''): TimelineEvent {
    return { id: `e${Math.random().toString(36).slice(2, 9)}`, start: parseDate(date)!, displayDate: date, title, desc };
  }

  let state: Timeline = loadDraft() ?? DEFAULT;
  let lastSVG = '';

  // --- render (the single path) ---------------------------------------------
  let saveTimer = 0;
  function render(): void {
    const theme = getTheme(state.themeId) ?? TIMELINE_THEMES[0];
    const size = getSize(state.sizeId);
    state.title = titleEl.value;
    lastSVG = renderSVG({ tl: state, theme, w: size.w, h: size.h }).svg;
    preview.innerHTML = lastSVG;
    clearTimeout(saveTimer);
    saveTimer = window.setTimeout(() => saveDraft(state), 250);
  }

  // --- events editor --------------------------------------------------------
  function renderRows(): void {
    rowsEl.innerHTML = '';
    state.events.forEach((ev, i) => {
      const wrap = document.createElement('div');
      wrap.className = 'panel flex flex-col gap-2 p-3';

      const dates = document.createElement('div');
      dates.className = 'grid grid-cols-2 gap-2';
      dates.append(
        field('Date', ev.displayDate ?? ev.start.raw, (v) => { setDate(i, 'start', v); }),
        field('End (optional)', ev.end?.raw ?? '', (v) => { setDate(i, 'end', v); }),
      );

      const title = field('Title', ev.title, (v) => { state.events[i].title = v; render(); });
      const desc = field('Description', ev.desc ?? '', (v) => { state.events[i].desc = v; render(); });

      const extras = document.createElement('div');
      extras.className = 'grid grid-cols-2 gap-2';
      extras.append(
        field('Group (optional)', ev.group ?? '', (v) => { state.events[i].group = v || undefined; render(); }),
        colorField(ev.color, (v) => { state.events[i].color = v; render(); }),
      );

      const actions = document.createElement('div');
      actions.className = 'flex gap-2';

      const duplicate = document.createElement('button');
      duplicate.className = 'btn btn-tertiary';
      duplicate.textContent = 'Duplicate';
      duplicate.addEventListener('click', () => {
        state.events.splice(i + 1, 0, { ...state.events[i], id: `e${Math.random().toString(36).slice(2, 9)}` });
        renderRows(); render();
      });

      const remove = document.createElement('button');
      remove.className = 'btn btn-tertiary';
      remove.textContent = 'Remove';
      remove.addEventListener('click', () => { state.events.splice(i, 1); renderRows(); render(); });

      actions.append(duplicate, remove);
      wrap.append(dates, title, desc, extras, actions);
      rowsEl.appendChild(wrap);
    });
  }

  function setDate(i: number, key: 'start' | 'end', raw: string): void {
    if (key === 'end') {
      state.events[i].end = raw.trim() ? (parseDate(raw) ?? undefined) : undefined;
    } else {
      const d = parseDate(raw);
      if (d) { state.events[i].start = d; state.events[i].displayDate = raw; }
    }
    render();
  }

  function field(placeholder: string, value: string, on: (v: string) => void): HTMLLabelElement {
    const label = document.createElement('label');
    label.className = 'flex flex-col gap-1 text-xs text-ink-subtle';
    label.textContent = placeholder;
    const input = document.createElement('input');
    input.className = 'field';
    input.value = value;
    input.addEventListener('input', () => on(input.value));
    label.appendChild(input);
    return label;
  }

  function colorField(value: string | undefined, on: (v: string) => void): HTMLLabelElement {
    const label = document.createElement('label');
    label.className = 'flex flex-col gap-1 text-xs text-ink-subtle';
    label.textContent = 'Color';
    const input = document.createElement('input');
    input.type = 'color';
    input.className = 'field h-9 p-1';
    input.value = value || '#5e6ad2';
    input.addEventListener('input', () => on(input.value));
    label.appendChild(input);
    return label;
  }

  // --- tabs -----------------------------------------------------------------
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.tlc-tab'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));
  function showTab(name: string): void {
    tabs.forEach((t) => {
      const on = t.dataset.tab === name;
      t.setAttribute('aria-selected', String(on));
      t.classList.toggle('btn-secondary', on);
      t.classList.toggle('btn-tertiary', !on);
    });
    panels.forEach((p) => {
      const on = p.dataset.panel === name;
      p.classList.toggle('hidden', !on);
      p.classList.toggle('flex', on);
    });
  }
  tabs.forEach((t) => t.addEventListener('click', () => showTab(t.dataset.tab!)));

  // --- templates gallery ----------------------------------------------------
  function renderTemplates(): void {
    const host = $<HTMLDivElement>('tlc-templates');
    host.innerHTML = '';
    for (const group of templateGroups()) {
      const section = document.createElement('div');
      section.className = 'flex flex-col gap-2';
      const h = document.createElement('span');
      h.className = 'text-xs font-medium uppercase tracking-wide text-ink-subtle';
      h.textContent = group.label;
      const grid = document.createElement('div');
      grid.className = 'grid grid-cols-2 gap-2';
      for (const tpl of group.items) {
        const card = document.createElement('button');
        card.className = 'panel flex items-center gap-2 p-3 text-left text-sm text-ink hover:border-hairline-strong';
        const ic = document.createElement('span');
        ic.className = 'text-lg leading-none';
        ic.textContent = tpl.icon;
        const lbl = document.createElement('span');
        lbl.textContent = tpl.label;
        card.append(ic, lbl);
        card.addEventListener('click', () => {
          state = templateToTimeline(tpl);
          titleEl.value = state.title;
          syncStyleControls();
          renderRows();
          render();
        });
        grid.appendChild(card);
      }
      section.append(h, grid);
      host.appendChild(section);
    }
  }

  // --- style controls -------------------------------------------------------
  const layoutSel = $<HTMLSelectElement>('tlc-layout');
  const themeSel = $<HTMLSelectElement>('tlc-theme');
  const sizeSel = $<HTMLSelectElement>('tlc-size');
  TIMELINE_THEMES.forEach((t) => themeSel.add(new Option(t.label, t.id)));
  SIZE_PRESETS.forEach((s) => sizeSel.add(new Option(s.label, s.id)));

  function syncStyleControls(): void {
    layoutSel.value = state.layout;
    themeSel.value = state.themeId;
    sizeSel.value = state.sizeId;
  }
  layoutSel.addEventListener('change', () => { state.layout = layoutSel.value as Timeline['layout']; render(); });
  themeSel.addEventListener('change', () => { state.themeId = themeSel.value; render(); });
  sizeSel.addEventListener('change', () => { state.sizeId = sizeSel.value; render(); });

  // --- auto-fill ------------------------------------------------------------
  function setStatus(msg: string): void { statusEl.textContent = msg; }

  $<HTMLButtonElement>('tlc-otd-go').addEventListener('click', async () => {
    const m = +$<HTMLInputElement>('tlc-otd-month').value;
    const d = +$<HTMLInputElement>('tlc-otd-day').value;
    setStatus('Fetching historical events…');
    const events = await onThisDay(m, d);
    if (!events.length) { setStatus("Couldn't reach the history API — check your connection and try again."); return; }
    state.events.push(...events);
    renderRows(); render();
    setStatus(`Added ${events.length} events.`);
  });

  $<HTMLButtonElement>('tlc-hol-go').addEventListener('click', async () => {
    const cc = $<HTMLInputElement>('tlc-hol-cc').value;
    const year = +$<HTMLInputElement>('tlc-hol-year').value;
    setStatus('Fetching holidays…');
    const events = await holidays(cc, year);
    if (!events.length) { setStatus("Couldn't fetch holidays — check the country code and your connection."); return; }
    state.events.push(...events);
    renderRows(); render();
    setStatus(`Added ${events.length} holidays.`);
  });

  // --- exports --------------------------------------------------------------
  function download(blob: Blob, name: string): void {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = name; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  // Rasterize the current SVG to a canvas at 2x for crisp PNG/PDF/clipboard.
  function rasterize(scale = 2): Promise<HTMLCanvasElement> {
    return new Promise((resolve, reject) => {
      const svgBlob = new Blob([lastSVG], { type: 'image/svg+xml;charset=utf-8' });
      const url = URL.createObjectURL(svgBlob);
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = img.width * scale;
        canvas.height = img.height * scale;
        const ctx = canvas.getContext('2d')!;
        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
        URL.revokeObjectURL(url);
        resolve(canvas);
      };
      img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('SVG rasterization failed')); };
      img.src = url;
    });
  }

  $<HTMLButtonElement>('tlc-svg').addEventListener('click', () => {
    download(new Blob([lastSVG], { type: 'image/svg+xml' }), 'toolsilk-timeline.svg');
  });

  $<HTMLButtonElement>('tlc-png').addEventListener('click', async () => {
    const canvas = await rasterize();
    canvas.toBlob((b) => b && download(b, 'toolsilk-timeline.png'), 'image/png');
  });

  $<HTMLButtonElement>('tlc-copy').addEventListener('click', async () => {
    try {
      const canvas = await rasterize();
      canvas.toBlob(async (b) => {
        if (!b) return;
        await navigator.clipboard.write([new ClipboardItem({ 'image/png': b })]);
        setStatus('Copied to clipboard.');
      }, 'image/png');
    } catch {
      setStatus('Clipboard copy not supported in this browser.');
    }
  });

  $<HTMLButtonElement>('tlc-pdf').addEventListener('click', async () => {
    setStatus('Building PDF…');
    try {
      const canvas = await rasterize();
      const pngBytes = await new Promise<Uint8Array>((res) =>
        canvas.toBlob(async (b) => res(new Uint8Array(await b!.arrayBuffer())), 'image/png'));
      const { PDFDocument } = await import('pdf-lib');
      const pdf = await PDFDocument.create();
      const png = await pdf.embedPng(pngBytes);
      const page = pdf.addPage([png.width / 2, png.height / 2]);
      page.drawImage(png, { x: 0, y: 0, width: png.width / 2, height: png.height / 2 });
      const bytes = await pdf.save();
      download(new Blob([bytes.slice()], { type: 'application/pdf' }), 'toolsilk-timeline.pdf');
      setStatus('');
    } catch {
      setStatus('PDF export failed.');
    }
  });

  $<HTMLButtonElement>('tlc-json').addEventListener('click', () => {
    download(new Blob([toJSON(state)], { type: 'application/json' }), 'toolsilk-timeline.json');
  });

  $<HTMLButtonElement>('tlc-tljs').addEventListener('click', () => {
    const json = JSON.stringify(toTimelineJS(state), null, 2);
    download(new Blob([json], { type: 'application/json' }), 'toolsilk-timeline.timelinejs.json');
  });

  // --- import (native JSON or TimelineJS) -----------------------------------
  const fileInput = $<HTMLInputElement>('tlc-file');
  $<HTMLButtonElement>('tlc-import').addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    const text = await file.text();
    try {
      const obj = JSON.parse(text);
      // Detect TimelineJS by its shape; otherwise treat as our native format.
      state = Array.isArray(obj.events) && obj.events[0]?.start_date
        ? fromTimelineJS(obj) : fromJSON(text);
      titleEl.value = state.title;
      syncStyleControls();
      renderRows(); render();
      setStatus('Imported timeline.');
      showTab('events');
    } catch {
      setStatus('That file is not a valid timeline JSON.');
    }
    fileInput.value = '';
  });

  // --- init -----------------------------------------------------------------
  $<HTMLButtonElement>('tlc-add').addEventListener('click', () => {
    state.events.push(mkEvent('', 'New event', ''));
    renderRows(); render();
  });
  titleEl.addEventListener('input', render);

  titleEl.value = state.title;
  syncStyleControls();
  renderTemplates();
  renderRows();
  render();
  showTab('events');
</script>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="dwg-to-dxf">
  <ArchiveConvert slug="dwg-to-dxf" from="dwg" to="dxf" noun="CAD file" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free DWG to DXF converter converts AutoCAD DWG drawings to the interchange DXF format that more CAD programs can open.
    </p>
    <p>
      DWG, DXF and DWF are proprietary CAD formats no browser can read on its own,
      so conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="ppt-to-odp">
  <ArchiveConvert slug="ppt-to-odp" from="ppt" to="odp" noun="presentation" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PPT to ODP converter converts legacy PowerPoint PPT files to OpenDocument ODP.
    </p>
    <p>
      Conversion is handled on our servers, because these
      presentation formats can't be read reliably in a browser. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="mobi-to-epub">
  <ArchiveConvert slug="mobi-to-epub" from="mobi" to="epub" noun="ebook" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free MOBI to EPUB converter converts Kindle MOBI ebooks to the open EPUB format read by most e-readers and apps.
    </p>
    <p>
      Conversion is handled on our servers, because these
      ebook formats can't be read reliably in a browser. Your file is uploaded to
      our servers, converted, and returned as a
      download link.
    </p>
  </div>
</ToolLayout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
---

<ToolLayout slug="iso-to-zip">
  <ArchiveConvert slug="iso-to-zip" from="iso" to="zip" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free ISO to ZIP converter Convert ISO disk images to ZIP archives to browse and extract their contents without mounting.
    </p>
    <p>
      Conversion is handled on our servers. Your file is
      uploaded to our servers, converted, and
      returned as a download link.
    </p>
  </div>
</ToolLayout>

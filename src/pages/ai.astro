---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AiToolChat from '../components/AiToolChat.astro';
---

<Layout bare title="AI assistant" description="Describe what you need and the AI picks the best free tool — common image conversions run right in the chat.">
  <div class="flex h-svh flex-col overflow-hidden">
    <Header landing />
    <main class="container-page flex w-full min-h-0 flex-1 flex-col py-6">
      <div class="flex w-full min-h-0 flex-1 flex-col">
        <AiToolChat fullPage />
      </div>
    </main>
  </div>
</Layout>

---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="csv-test-data-generator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-center gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Rows
        <input id="cv-count" type="number" min="1" max="5000" value="25" class="field w-28" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Delimiter
        <select id="cv-delim" class="field w-28"><option value=",">comma</option><option value=";">semicolon</option><option value="\t">tab</option></select>
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle mt-5">
        <input id="cv-header" type="checkbox" class="accent-primary" checked /> Header row
      </label>
    </div>
    <fieldset class="flex flex-wrap items-center gap-x-4 gap-y-1">
      <legend class="w-full text-xs uppercase tracking-wide text-ink-tertiary">Columns</legend>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="id" checked /> id</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="first_name" checked /> first_name</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="last_name" checked /> last_name</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="email" checked /> email</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="phone" /> phone</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="city" /> city</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="state" /> state</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="zip" /> zip</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="company" /> company</label>
      <label class="flex items-center gap-1.5 text-sm text-ink-subtle"><input type="checkbox" class="cv-f accent-primary" value="birthday" /> birthday</label>
    </fieldset>
    <div class="flex flex-wrap gap-2">
      <button id="cv-gen" class="btn btn-primary">Generate</button>
      <button id="cv-dl" class="btn btn-secondary">Download .csv</button>
    </div>
    <div class="copy-wrap"><pre class="hl-block field min-h-72" style="resize:vertical;overflow:auto" aria-label="Generated CSV"><code id="cv-out" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#cv-out" aria-label="Copy"></button></div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSV test data generator produces rows of realistic fake records
      with the columns you pick and downloads them as a ready-to-use CSV file —
      ideal for spreadsheet imports, database seeding and testing data pipelines.
      Choose the delimiter, toggle the header row, and generate up to thousands of
      rows. Values are correctly quoted when needed.
    </p>
  </div>
</ToolLayout>

<script>
  import { firstName, lastName, email, phoneUS, companyName, address, birthDate } from '../lib/fakegen';

  import { hl } from '../lib/highlight';

  const $ = (id: string) => document.getElementById(id)!;
  const countEl = $('cv-count') as HTMLInputElement;
  const delimEl = $('cv-delim') as HTMLSelectElement;
  const headerEl = $('cv-header') as HTMLInputElement;
  const out = $('cv-out') as HTMLElement;
  let rawOutput = '';

  const cols = () => [...document.querySelectorAll<HTMLInputElement>('.cv-f:checked')].map((el) => el.value);
  const delim = () => (delimEl.value === '\\t' ? '\t' : delimEl.value);

  function esc(v: string, d: string): string {
    if (v.includes(d) || v.includes('"') || v.includes('\n')) return '"' + v.replace(/"/g, '""') + '"';
    return v;
  }

  function row(id: number, cs: string[]) {
    const first = firstName();
    const last = lastName();
    const a = address();
    const map: Record<string, string> = {
      id: String(id), first_name: first, last_name: last, email: email(first, last),
      phone: phoneUS(), city: a.city, state: a.stateAbbr, zip: a.zip,
      company: companyName(), birthday: birthDate(),
    };
    return cs.map((c) => map[c] ?? '');
  }

  function generate() {
    const n = Math.max(1, Math.min(5000, Number(countEl.value) || 1));
    const cs = cols();
    const d = delim();
    const lines: string[] = [];
    if (headerEl.checked) lines.push(cs.join(d));
    for (let i = 0; i < n; i++) lines.push(row(i + 1, cs).map((v) => esc(v, d)).join(d));
    rawOutput = lines.join('\n');
    hl(out, rawOutput, 'plaintext');
  }

  [countEl, delimEl, headerEl].forEach((el) => el.addEventListener('input', generate));
  document.querySelectorAll('.cv-f').forEach((el) => el.addEventListener('change', generate));
  $('cv-gen').addEventListener('click', generate);
  $('cv-dl').addEventListener('click', () => {
    const url = URL.createObjectURL(new Blob([rawOutput], { type: 'text/csv' }));
    const a = document.createElement('a'); a.href = url; a.download = 'test-data.csv'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });
  generate();
</script>

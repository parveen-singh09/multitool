---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="keyboard-tester">
  <div class="flex flex-col gap-4">
    <p class="text-[13px] text-ink-subtle">Press any key — it lights up below and its details appear. Keys stay green once tested so you can confirm every one registers.</p>

    <div class="grid grid-cols-3 gap-3 text-center">
      <div class="panel panel-lift p-4"><div id="kb-key" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">key</div></div>
      <div class="panel p-4"><div id="kb-code" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">code</div></div>
      <div class="panel p-4"><div id="kb-which" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">keyCode</div></div>
    </div>

    <div id="kb-board" class="flex flex-col gap-1 overflow-x-auto"></div>

    <div class="flex flex-wrap items-center gap-3">
      <button id="kb-reset" class="btn btn-secondary">Reset tested keys</button>
      <div class="text-[13px] text-ink-subtle"><span id="kb-count">0</span> keys tested</div>
    </div>

    <div>
      <div class="mb-1 text-[13px] text-ink-subtle">Keys pressed so far</div>
      <p id="kb-list" class="min-h-6 break-words font-mono text-[13px] text-ink-tertiary"></p>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free keyboard tester lets you check that every key on your keyboard
      registers. Press a key and it lights up on the on-screen QWERTY layout while
      the tool shows the key value, physical code and legacy keyCode. Tested keys
      turn green so you can quickly find one that isn't responding — useful for
      diagnosing sticky or dead keys and modifier issues. Everything runs in your
      browser and nothing is recorded.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id)!;

  interface KeyDef { code: string; label: string; w?: number; }

  const rows: KeyDef[][] = [
    [
      { code: 'Escape', label: 'Esc' },
      { code: 'F1', label: 'F1' }, { code: 'F2', label: 'F2' }, { code: 'F3', label: 'F3' }, { code: 'F4', label: 'F4' },
      { code: 'F5', label: 'F5' }, { code: 'F6', label: 'F6' }, { code: 'F7', label: 'F7' }, { code: 'F8', label: 'F8' },
      { code: 'F9', label: 'F9' }, { code: 'F10', label: 'F10' }, { code: 'F11', label: 'F11' }, { code: 'F12', label: 'F12' },
    ],
    [
      { code: 'Backquote', label: '`' },
      { code: 'Digit1', label: '1' }, { code: 'Digit2', label: '2' }, { code: 'Digit3', label: '3' }, { code: 'Digit4', label: '4' },
      { code: 'Digit5', label: '5' }, { code: 'Digit6', label: '6' }, { code: 'Digit7', label: '7' }, { code: 'Digit8', label: '8' },
      { code: 'Digit9', label: '9' }, { code: 'Digit0', label: '0' }, { code: 'Minus', label: '-' }, { code: 'Equal', label: '=' },
      { code: 'Backspace', label: 'Backspace', w: 2 },
    ],
    [
      { code: 'Tab', label: 'Tab', w: 1.5 },
      { code: 'KeyQ', label: 'Q' }, { code: 'KeyW', label: 'W' }, { code: 'KeyE', label: 'E' }, { code: 'KeyR', label: 'R' },
      { code: 'KeyT', label: 'T' }, { code: 'KeyY', label: 'Y' }, { code: 'KeyU', label: 'U' }, { code: 'KeyI', label: 'I' },
      { code: 'KeyO', label: 'O' }, { code: 'KeyP', label: 'P' }, { code: 'BracketLeft', label: '[' }, { code: 'BracketRight', label: ']' },
      { code: 'Backslash', label: '\\', w: 1.5 },
    ],
    [
      { code: 'CapsLock', label: 'Caps', w: 1.75 },
      { code: 'KeyA', label: 'A' }, { code: 'KeyS', label: 'S' }, { code: 'KeyD', label: 'D' }, { code: 'KeyF', label: 'F' },
      { code: 'KeyG', label: 'G' }, { code: 'KeyH', label: 'H' }, { code: 'KeyJ', label: 'J' }, { code: 'KeyK', label: 'K' },
      { code: 'KeyL', label: 'L' }, { code: 'Semicolon', label: ';' }, { code: 'Quote', label: "'" },
      { code: 'Enter', label: 'Enter', w: 2.25 },
    ],
    [
      { code: 'ShiftLeft', label: 'Shift', w: 2.25 },
      { code: 'KeyZ', label: 'Z' }, { code: 'KeyX', label: 'X' }, { code: 'KeyC', label: 'C' }, { code: 'KeyV', label: 'V' },
      { code: 'KeyB', label: 'B' }, { code: 'KeyN', label: 'N' }, { code: 'KeyM', label: 'M' }, { code: 'Comma', label: ',' },
      { code: 'Period', label: '.' }, { code: 'Slash', label: '/' },
      { code: 'ShiftRight', label: 'Shift', w: 2.75 },
    ],
    [
      { code: 'ControlLeft', label: 'Ctrl', w: 1.5 },
      { code: 'MetaLeft', label: 'Meta', w: 1.25 },
      { code: 'AltLeft', label: 'Alt', w: 1.25 },
      { code: 'Space', label: 'Space', w: 6 },
      { code: 'AltRight', label: 'Alt', w: 1.25 },
      { code: 'MetaRight', label: 'Meta', w: 1.25 },
      { code: 'ControlRight', label: 'Ctrl', w: 1.5 },
      { code: 'ArrowLeft', label: '←' }, { code: 'ArrowUp', label: '↑' },
      { code: 'ArrowDown', label: '↓' }, { code: 'ArrowRight', label: '→' },
    ],
  ];

  const board = $('kb-board');
  const keyEls = new Map<string, HTMLElement>();
  const tested = new Set<string>();
  const pressedOrder: string[] = [];

  const BASE_BG = '#1a1a26';
  const BASE_BORDER = '#2a2a3a';

  for (const row of rows) {
    const rowEl = document.createElement('div');
    rowEl.className = 'flex gap-1';
    for (const key of row) {
      const el = document.createElement('div');
      el.className = 'flex h-9 items-center justify-center rounded-sm border px-1 font-mono text-xs text-ink-subtle';
      el.style.flex = `${key.w ?? 1} 0 0`;
      el.style.minWidth = '26px';
      el.style.background = BASE_BG;
      el.style.borderColor = BASE_BORDER;
      el.textContent = key.label;
      keyEls.set(key.code, el);
      rowEl.appendChild(el);
    }
    board.appendChild(rowEl);
  }

  const scrollKeys = new Set([
    'Space', 'ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight',
    'PageUp', 'PageDown', 'Home', 'End', 'Tab',
  ]);

  function highlight(code: string, active: boolean) {
    const el = keyEls.get(code);
    if (!el) return;
    if (active) {
      el.style.background = '#5e6ad2';
      el.style.borderColor = '#7c86e0';
      el.style.color = '#fff';
    } else {
      const done = tested.has(code);
      el.style.background = done ? 'rgba(39,166,68,0.18)' : BASE_BG;
      el.style.borderColor = done ? '#27a644' : BASE_BORDER;
      el.style.color = done ? '#7fd598' : '';
    }
  }

  window.addEventListener('keydown', (e) => {
    if (scrollKeys.has(e.code)) e.preventDefault();
    $('kb-key').textContent = e.key === ' ' ? 'Space' : e.key;
    $('kb-code').textContent = e.code || '(none)';
    $('kb-which').textContent = String(e.keyCode);
    if (!tested.has(e.code) && keyEls.has(e.code)) {
      tested.add(e.code);
      pressedOrder.push(e.code);
      $('kb-count').textContent = String(tested.size);
      $('kb-list').textContent = pressedOrder.join(' · ');
    }
    highlight(e.code, true);
  });

  window.addEventListener('keyup', (e) => {
    highlight(e.code, false);
  });

  $('kb-reset').addEventListener('click', () => {
    tested.clear();
    pressedOrder.length = 0;
    $('kb-count').textContent = '0';
    $('kb-list').textContent = '';
    keyEls.forEach((_, code) => highlight(code, false));
  });
</script>

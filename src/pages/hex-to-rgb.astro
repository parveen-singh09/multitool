---
import ToolLayout from '../layouts/ToolLayout.astro';
import ColorFormats from '../components/ColorFormats.astro';

const extraFormats = [
  { id: 'rgb-norm', label: 'RGB (0–1 normalized)' },
  { id: 'rgb-pct', label: 'RGB (0%–100%)' },
  { id: 'rgba', label: 'RGBA' },
  { id: 'hex8', label: 'HEX (8-digit, with alpha)' },
  { id: 'hwb', label: 'HWB' },
  { id: 'dec', label: 'Decimal integer' },
  { id: 'android', label: 'Android (0xAARRGGBB)' },
  { id: 'swiftui', label: 'SwiftUI Color' },
];

const harmonies = [
  { id: 'complementary', label: 'Complementary' },
  { id: 'analogous', label: 'Analogous' },
  { id: 'triadic', label: 'Triadic' },
  { id: 'tetradic', label: 'Tetradic' },
  { id: 'split', label: 'Split complementary' },
];
---

<ToolLayout slug="hex-to-rgb">
  <ColorFormats focus="rgb" />

  <div class="mt-6 flex flex-col gap-8">

    <p id="xf-err" class="hidden rounded-md border border-hairline-strong bg-surface-2 px-3 py-2 text-[14px] text-ink-muted" role="status" aria-live="polite"></p>

    <section class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <span class="text-[13px] text-ink-subtle">Alpha / opacity</span>
        <span id="xf-alpha-val" class="font-mono text-[13px] text-ink-muted">100%</span>
      </div>
      <input id="xf-alpha" type="range" min="0" max="100" value="100" step="1"
        class="w-full cursor-pointer accent-primary" aria-label="Alpha / opacity percentage" />
      <p class="text-[12px] text-ink-tertiary">Feeds the RGBA and 8-digit HEX outputs below. Leave at 100% for a fully opaque color.</p>
    </section>

    <section class="flex flex-col gap-3">
      <div class="flex items-center justify-between gap-3">
        <span class="eyebrow text-primary-hover">More formats</span>
        <button id="xf-copy-all" class="btn btn-secondary" type="button">Copy all</button>
      </div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {extraFormats.map((f) => (
          <div class="flex items-center justify-between gap-3 rounded-md border border-hairline bg-surface-1 px-3 py-2">
            <div class="min-w-0">
              <div class="text-[12px] text-ink-subtle">{f.label}</div>
              <div id={`xf-${f.id}`} class="truncate font-mono text-[14px] text-ink">—</div>
            </div>
            <button class="btn btn-secondary xf-copy shrink-0" data-target={`xf-${f.id}`} type="button">Copy</button>
          </div>
        ))}
      </div>
    </section>

    <section class="flex flex-col gap-3">
      <span class="eyebrow text-primary-hover">Channel breakdown</span>
      <div class="overflow-x-auto rounded-md border border-hairline bg-surface-1">
        <table class="w-full border-collapse text-[14px]">
          <thead>
            <tr class="text-left text-ink-subtle">
              <th class="px-3 py-2 font-medium">Channel</th>
              <th class="px-3 py-2 font-medium">Decimal (0–255)</th>
              <th class="px-3 py-2 font-medium">Hex</th>
              <th class="px-3 py-2 font-medium">Fraction (0–1)</th>
              <th class="px-3 py-2 font-medium">Percent</th>
            </tr>
          </thead>
          <tbody id="xf-channels" class="font-mono text-ink"></tbody>
        </table>
      </div>
    </section>

    <section class="flex flex-col gap-3">
      <span class="eyebrow text-primary-hover">Contrast &amp; luminance</span>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
        <div class="rounded-md border border-hairline bg-surface-1 px-3 py-3">
          <div class="text-[12px] text-ink-subtle">Relative luminance</div>
          <div id="xf-lum" class="mt-1 font-mono text-[15px] text-ink">—</div>
        </div>
        <div class="rounded-md border border-hairline bg-surface-1 px-3 py-3">
          <div class="text-[12px] text-ink-subtle">Contrast vs white</div>
          <div class="mt-1 flex items-center gap-2">
            <span id="xf-con-white" class="font-mono text-[15px] text-ink">—</span>
            <span id="xf-con-white-badge" class="status-badge"></span>
          </div>
        </div>
        <div class="rounded-md border border-hairline bg-surface-1 px-3 py-3">
          <div class="text-[12px] text-ink-subtle">Contrast vs black</div>
          <div class="mt-1 flex items-center gap-2">
            <span id="xf-con-black" class="font-mono text-[15px] text-ink">—</span>
            <span id="xf-con-black-badge" class="status-badge"></span>
          </div>
        </div>
      </div>
      <p class="text-[12px] text-ink-tertiary">WCAG 2.1 contrast ratios for this color used as text. AA needs 4.5:1 (3:1 for large text); AAA needs 7:1.</p>
    </section>

    <section class="flex flex-col gap-3">
      <span class="eyebrow text-primary-hover">Color harmonies</span>
      <div class="flex flex-col gap-3">
        {harmonies.map((h) => (
          <div class="flex flex-col gap-1.5">
            <span class="text-[13px] text-ink-subtle">{h.label}</span>
            <div id={`xf-harm-${h.id}`} class="flex flex-wrap gap-2"></div>
          </div>
        ))}
      </div>
      <p class="text-[12px] text-ink-tertiary">Click any swatch to load it into the converter above.</p>
    </section>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free HEX to RGB converter turns any hex color code into its red,
      green and blue values instantly. Type a hex code like <code>#5e6ad2</code>
      (or use the picker) and read the matching <code>rgb()</code> string, ready
      to paste into CSS. Both shorthand (<code>#5e6</code>) and full six-digit
      hex are accepted, with a clear message when the code can't be parsed.
    </p>
    <p>
      Beyond plain RGB it exports every format you're likely to need: HSL, HSV,
      CMYK and the nearest CSS color name up top, plus normalized RGB (0–1),
      percentage RGB, RGBA, 8-digit HEX with alpha, HWB, the decimal integer,
      Android <code>0xAARRGGBB</code> and SwiftUI values below. An alpha slider
      feeds the RGBA and hex-with-alpha outputs, a per-channel breakdown shows
      each component in decimal, hex, fraction and percent, and one click copies
      any value — or all of them at once.
    </p>
    <p>
      It also goes further than a plain lookup: WCAG 2.1 contrast ratios against
      white and black (with AA/AAA pass badges) help you check readability, and
      the color-harmony swatches (complementary, analogous, triadic, tetradic
      and split-complementary) suggest matching colors you can load with a
      single click. Use the tints &amp; shades strip for lighter and darker
      variants of the same hue.
    </p>
  </div>
</ToolLayout>

<script>
  import { hexToRgb, rgbToHex, rgbToHsl, hslToRgb, clamp, type RGB } from '../lib/colors';

  const $ = (id: string) => document.getElementById(id);
  const root = document.getElementById('cf-root');
  const hexEl = () => document.getElementById('cf-hex') as HTMLInputElement | null;
  const errEl = $('xf-err')!;
  const alphaEl = $('xf-alpha') as HTMLInputElement;
  const alphaVal = $('xf-alpha-val')!;

  const toHex2 = (n: number) => clamp(Math.round(n)).toString(16).padStart(2, '0');
  const stripZero = (n: number) => String(parseFloat(n.toFixed(3)));

  function luminance({ r, g, b }: RGB): number {
    const lin = [r, g, b].map((v) => {
      const s = v / 255;
      return s <= 0.03928 ? s / 12.92 : ((s + 0.055) / 1.055) ** 2.4;
    });
    return 0.2126 * lin[0] + 0.7152 * lin[1] + 0.0722 * lin[2];
  }
  const contrast = (l1: number, l2: number) =>
    (Math.max(l1, l2) + 0.05) / (Math.min(l1, l2) + 0.05);

  function ratingFor(ratio: number): { text: string; ok: boolean } {
    if (ratio >= 7) return { text: `${ratio.toFixed(2)}:1 · AAA`, ok: true };
    if (ratio >= 4.5) return { text: `${ratio.toFixed(2)}:1 · AA`, ok: true };
    if (ratio >= 3) return { text: `${ratio.toFixed(2)}:1 · AA large`, ok: true };
    return { text: `${ratio.toFixed(2)}:1 · Fail`, ok: false };
  }

  function rgbToHwb(rgb: RGB) {
    const h = rgbToHsl(rgb).h;
    const w = Math.min(rgb.r, rgb.g, rgb.b) / 255;
    const bl = 1 - Math.max(rgb.r, rgb.g, rgb.b) / 255;
    return { h, w: Math.round(w * 100), b: Math.round(bl * 100) };
  }

  const set = (id: string, text: string) => { const el = $(id); if (el) el.textContent = text; };

  let allText = '';

  function render(rgb: RGB) {
    const a = clamp(+alphaEl.value, 0, 100) / 100;
    const aHex = toHex2(a * 255);
    const hex = rgbToHex(rgb);
    const hsl = rgbToHsl(rgb);
    const hwb = rgbToHwb(rgb);

    const rgbNorm = `${stripZero(rgb.r / 255)}, ${stripZero(rgb.g / 255)}, ${stripZero(rgb.b / 255)}`;
    const rgbPct = `rgb(${(rgb.r / 255 * 100).toFixed(1)}%, ${(rgb.g / 255 * 100).toFixed(1)}%, ${(rgb.b / 255 * 100).toFixed(1)}%)`;
    const rgba = `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${stripZero(a)})`;
    const hex8 = `${hex}${aHex}`;
    const hwbStr = `hwb(${hwb.h} ${hwb.w}% ${hwb.b}%)`;
    const dec = String(rgb.r * 65536 + rgb.g * 256 + rgb.b);
    const android = `0x${(aHex + toHex2(rgb.r) + toHex2(rgb.g) + toHex2(rgb.b)).toUpperCase()}`;
    const swiftui = `Color(red: ${stripZero(rgb.r / 255)}, green: ${stripZero(rgb.g / 255)}, blue: ${stripZero(rgb.b / 255)})`;

    set('xf-rgb-norm', rgbNorm);
    set('xf-rgb-pct', rgbPct);
    set('xf-rgba', rgba);
    set('xf-hex8', hex8);
    set('xf-hwb', hwbStr);
    set('xf-dec', dec);
    set('xf-android', android);
    set('xf-swiftui', swiftui);

    const tbody = $('xf-channels')!;
    const rows: [string, number][] = [['Red', rgb.r], ['Green', rgb.g], ['Blue', rgb.b]];
    tbody.innerHTML = '';
    for (const [name, v] of rows) {
      const tr = document.createElement('tr');
      tr.className = 'border-t border-hairline';
      tr.innerHTML =
        `<td class="px-3 py-2 text-ink-subtle">${name}</td>` +
        `<td class="px-3 py-2">${v}</td>` +
        `<td class="px-3 py-2">${toHex2(v)}</td>` +
        `<td class="px-3 py-2">${stripZero(v / 255)}</td>` +
        `<td class="px-3 py-2">${(v / 255 * 100).toFixed(1)}%</td>`;
      tbody.appendChild(tr);
    }

    const l = luminance(rgb);
    const cWhite = contrast(l, 1);
    const cBlack = contrast(l, 0);
    set('xf-lum', l.toFixed(4));
    const rw = ratingFor(cWhite);
    const rb = ratingFor(cBlack);
    set('xf-con-white', rw.text.split(' · ')[0]);
    set('xf-con-black', rb.text.split(' · ')[0]);
    for (const [badgeId, rating] of [['xf-con-white-badge', rw], ['xf-con-black-badge', rb]] as const) {
      const badge = $(badgeId)!;
      const label = rating.text.split(' · ')[1];
      badge.textContent = label;
      badge.style.color = rating.ok ? 'var(--color-success)' : 'var(--color-ink-subtle)';
    }

    const rotate = (d: number) => rgbToHex(hslToRgb({ h: (hsl.h + d + 360) % 360, s: hsl.s, l: hsl.l }));
    const schemes: Record<string, number[]> = {
      complementary: [0, 180],
      analogous: [-30, 0, 30],
      triadic: [0, 120, 240],
      tetradic: [0, 90, 180, 270],
      split: [0, 150, 210],
    };
    for (const [id, offsets] of Object.entries(schemes)) {
      const wrap = $(`xf-harm-${id}`);
      if (!wrap) continue;
      wrap.innerHTML = '';
      for (const off of offsets) {
        const c = rotate(off);
        const sw = document.createElement('button');
        sw.type = 'button';
        sw.className = 'h-10 w-10 cursor-pointer rounded-md border border-hairline';
        sw.style.background = c;
        sw.title = `${c} — click to use`;
        sw.setAttribute('aria-label', `Use ${c}`);
        sw.addEventListener('click', () => {
          const he = hexEl();
          if (!he) return;
          he.value = c;
          he.dispatchEvent(new Event('input', { bubbles: true }));
        });
        wrap.appendChild(sw);
      }
    }

    const core = (id: string) => (document.getElementById(id) as HTMLInputElement | null)?.value ?? '';
    allText = [
      `HEX: ${core('cf-hex')}`,
      `RGB: ${core('cf-rgb')}`,
      `RGB (0–1): ${rgbNorm}`,
      `RGB (%): ${rgbPct}`,
      `RGBA: ${rgba}`,
      `HEX8: ${hex8}`,
      `HSL: ${core('cf-hsl')}`,
      `HSV: ${core('cf-hsv')}`,
      `HWB: ${hwbStr}`,
      `CMYK: ${core('cf-cmyk')}`,
      `Decimal: ${dec}`,
      `Android: ${android}`,
      `SwiftUI: ${swiftui}`,
    ].join('\n');
  }

  function update() {
    const he = hexEl();
    if (!he) return;
    const raw = he.value.trim();
    const rgb = hexToRgb(raw);
    if (!rgb) {
      if (raw) {
        errEl.textContent = `"${raw}" is not a valid hex color. Use #RGB or #RRGGBB — for example #5e6ad2.`;
        errEl.classList.remove('hidden');
      } else {
        errEl.classList.add('hidden');
      }
      return;
    }
    errEl.classList.add('hidden');
    render(rgb);
  }

  if (root) {
    ['input', 'change', 'click'].forEach((ev) =>
      root.addEventListener(ev, () => setTimeout(update, 0)),
    );
  }
  alphaEl.addEventListener('input', () => {
    alphaVal.textContent = `${alphaEl.value}%`;
    update();
  });

  document.querySelectorAll<HTMLButtonElement>('.xf-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const target = document.getElementById(btn.dataset.target!);
      if (!target) return;
      await navigator.clipboard.writeText(target.textContent || '');
      const old = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = old), 1400);
    });
  });

  const copyAllBtn = $('xf-copy-all') as HTMLButtonElement;
  copyAllBtn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(allText);
    const old = copyAllBtn.textContent;
    copyAllBtn.textContent = 'Copied!';
    setTimeout(() => (copyAllBtn.textContent = old), 1400);
  });

  setTimeout(update, 0);
</script>

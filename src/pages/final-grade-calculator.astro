---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="final-grade-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Mode">
      <button type="button" data-mode="required" class="fg-tab btn btn-primary" aria-selected="true">Score I need</button>
      <button type="button" data-mode="result" class="fg-tab btn btn-secondary" aria-selected="false">Grade I'll get</button>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Current grade (%)
        <input id="fg-current" type="number" min="0" step="0.1" class="field" value="88" inputmode="decimal" />
      </label>
      <label id="fg-desired-wrap" class="flex flex-col gap-1 text-sm text-ink-subtle">Desired course grade (%)
        <input id="fg-desired" type="number" min="0" step="0.1" class="field" value="90" inputmode="decimal" />
      </label>
      <label id="fg-score-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">Final exam score (%)
        <input id="fg-score" type="number" min="0" step="0.1" class="field" value="85" inputmode="decimal" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Final exam weight (%)
        <input id="fg-weight" type="number" min="0" max="100" step="0.1" class="field" value="30" inputmode="decimal" />
      </label>
    </div>

    <div class="panel panel-lift p-6 text-center">
      <div id="fg-required" class="font-display text-4xl font-semibold text-primary-hover">—</div>
      <div id="fg-note" class="mt-2 text-sm text-ink-muted"></div>
    </div>

    <div class="panel p-5">
      <div class="mb-3 text-sm text-ink-muted">If you score… on the final, you finish with:</div>
      <div class="overflow-x-auto">
        <table class="w-full text-center text-[13px]">
          <thead class="text-ink-subtle"><tr class="border-b border-hairline">
            <th class="px-3 py-2 font-medium">Final score</th>
            <th class="px-3 py-2 font-medium">Course grade</th>
          </tr></thead>
          <tbody id="fg-whatif" class="font-mono text-ink-muted"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free final grade calculator works two ways: find exactly what score you
      need on your final exam to hit a target course grade, or enter a hypothetical
      final score to see the course grade you'd end up with. It flags targets that
      are already secured or out of reach, and shows a what-if table of final
      scores mapped to resulting grades.
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  let mode: 'required' | 'result' = 'required';

  const courseGrade = (current: number, finalScore: number, w: number) => current * (1 - w) + finalScore * w;

  function calc() {
    const c = Number($('fg-current').value) || 0;
    const wPct = Number($('fg-weight').value) || 0;
    const w = wPct / 100;
    const out = document.getElementById('fg-required')!;
    const note = document.getElementById('fg-note')!;
    const whatif = document.getElementById('fg-whatif')!;

    if (w <= 0) {
      out.textContent = '—'; out.style.color = '';
      note.textContent = 'Enter a final exam weight greater than 0%.';
      whatif.innerHTML = '';
      return;
    }

    if (mode === 'result') {
      const s = Number($('fg-score').value) || 0;
      const grade = courseGrade(c, s, w);
      out.textContent = grade.toFixed(1) + '%';
      out.style.color = '';
      note.textContent = `Scoring ${s.toFixed(1)}% on the final gives a course grade of ${grade.toFixed(1)}%.`;
    } else {
      const d = Number($('fg-desired').value) || 0;
      const required = (d - c * (1 - w)) / w;
      if (required <= 0) {
        out.textContent = '0%'; out.style.color = 'var(--color-success)';
        note.textContent = "You've already secured it — you need 0% on the final.";
      } else if (required > 100) {
        out.textContent = required.toFixed(1) + '%'; out.style.color = '#e5484d';
        note.textContent = `Not achievable with the final alone. Even a perfect 100% only reaches ${courseGrade(c, 100, w).toFixed(1)}%.`;
      } else {
        out.textContent = required.toFixed(1) + '%'; out.style.color = '';
        note.textContent = `Score ${required.toFixed(1)}% on the final to finish with ${d.toFixed(1)}%.`;
      }
    }

    // what-if table (shared by both modes)
    whatif.innerHTML = [100, 90, 80, 70, 60, 50]
      .map((s) => `<tr class="border-b border-hairline/50"><td class="px-3 py-1.5">${s}%</td><td class="px-3 py-1.5">${courseGrade(c, s, w).toFixed(1)}%</td></tr>`)
      .join('');
  }

  document.querySelectorAll<HTMLButtonElement>('.fg-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      mode = tab.dataset.mode as 'required' | 'result';
      document.querySelectorAll('.fg-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('fg-desired-wrap')!.classList.toggle('hidden', mode !== 'required');
      document.getElementById('fg-desired-wrap')!.classList.toggle('flex', mode === 'required');
      document.getElementById('fg-score-wrap')!.classList.toggle('hidden', mode !== 'result');
      document.getElementById('fg-score-wrap')!.classList.toggle('flex', mode === 'result');
      calc();
    });
  });

  ['fg-current', 'fg-desired', 'fg-score', 'fg-weight'].forEach((id) => $(id).addEventListener('input', calc));
  calc();
</script>

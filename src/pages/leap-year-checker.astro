---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="leap-year-checker">
  <div class="flex flex-col gap-4">
    <label class="flex flex-col gap-1 text-sm text-ink-subtle">
      Year
      <input id="leap-in" class="field font-mono text-[13px]" type="text" inputmode="numeric" placeholder="e.g. 2024" spellcheck="false" value="2024" />
    </label>

    <p id="leap-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div class="grid grid-cols-1 gap-3 text-center sm:grid-cols-2">
      <div class="panel panel-lift p-4"><div id="leap-verdict" class="font-display text-xl font-semibold text-primary-hover">—</div><div class="mt-1 text-[13px] text-ink-subtle">Verdict</div></div>
      <div class="panel p-4"><div id="leap-days" class="font-mono text-lg text-ink">—</div><div class="mt-1 text-[13px] text-ink-subtle">Days in year</div></div>
    </div>

    <div class="panel p-4">
      <div class="text-[13px] text-ink-subtle">Reasoning</div>
      <div id="leap-reason" class="mt-1 text-[13px] text-ink">—</div>
      <div class="mt-3 text-[13px] text-ink-subtle">Next 5 leap years</div>
      <div id="leap-next" class="mt-1 font-mono text-[13px] text-ink">—</div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free leap year checker tells you whether a year is a leap year under
      the Gregorian calendar. The rule: a year is a leap year if it is divisible
      by 4, except years divisible by 100, unless they are also divisible by
      400. So 2000 was a leap year but 1900 was not. The tool shows the verdict,
      the step-by-step reasoning and the next five leap years. Everything runs in
      your browser.
    </p>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('leap-in') as HTMLInputElement;
  const err = document.getElementById('leap-error')!;
  const verdictEl = document.getElementById('leap-verdict')!;
  const daysEl = document.getElementById('leap-days')!;
  const reasonEl = document.getElementById('leap-reason')!;
  const nextEl = document.getElementById('leap-next')!;

  function isLeap(y: number): boolean {
    return y % 4 === 0 && (y % 100 !== 0 || y % 400 === 0);
  }

  function reason(y: number): string {
    if (y % 4 !== 0) return `${y} is not divisible by 4, so it is a common year.`;
    if (y % 100 !== 0) return `${y} is divisible by 4 and not by 100, so it is a leap year.`;
    if (y % 400 !== 0) return `${y} is divisible by 100 but not by 400, so it is a common year.`;
    return `${y} is divisible by 400, so it is a leap year.`;
  }

  function reset(msg?: string) {
    verdictEl.textContent = '—';
    verdictEl.className = 'font-display text-xl font-semibold text-primary-hover';
    daysEl.textContent = '—';
    reasonEl.textContent = '—';
    nextEl.textContent = '—';
    if (msg) {
      err.textContent = msg;
      err.classList.remove('hidden');
    } else {
      err.classList.add('hidden');
    }
  }

  function check() {
    const raw = input.value.trim();
    if (raw === '') { reset(); return; }
    if (!/^-?\d+$/.test(raw)) { reset('Please enter a whole year.'); return; }
    const y = Number(raw);
    if (!Number.isSafeInteger(y)) { reset('Year is out of range.'); return; }
    err.classList.add('hidden');

    const leap = isLeap(y);
    verdictEl.textContent = leap ? 'Leap year' : 'Common year';
    verdictEl.className = leap
      ? 'font-display text-xl font-semibold text-primary-hover'
      : 'font-display text-xl font-semibold text-ink';
    daysEl.textContent = leap ? '366' : '365';
    reasonEl.textContent = reason(y);

    const upcoming: number[] = [];
    let n = y + 1;
    while (upcoming.length < 5) {
      if (isLeap(n)) upcoming.push(n);
      n++;
    }
    nextEl.textContent = upcoming.join(', ');
  }

  input.addEventListener('input', check);
  check();
</script>

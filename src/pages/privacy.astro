---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `Privacy Policy — ${SITE.name}`,
  url: `${SITE.url}/privacy`,
};
---

<Layout
  title="Privacy Policy"
  description={`${SITE.name}'s privacy policy: our tools run entirely in your browser. We do not collect, store, or transmit the data you enter.`}
  jsonLd={jsonLd}
>
  <Header />

  <main class="container-page py-14">
    <div class="mx-auto max-w-3xl">
      <span class="eyebrow text-primary-hover">Legal</span>
      <h1 class="display-md mt-3 text-ink">Privacy Policy</h1>

      <div class="mt-8 flex flex-col gap-4 text-[15px] leading-relaxed text-ink-muted">
        <p>
          {SITE.name} is built to be private by design. This policy explains what
          that means in practice.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">The data you enter stays on your device</h2>
        <p>
          Every tool on {SITE.name} runs entirely in your web browser. The text,
          numbers, colors, passwords, and other content you enter are processed
          locally on your own computer or phone. This information is never
          transmitted to our servers, because there is no server-side processing.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">No accounts, no personal data</h2>
        <p>
          You do not need to create an account to use any tool. We do not ask for
          your name, email address, or any other personal information, and we have
          no database of user content.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Tools that fetch live public data</h2>
        <p>
          A small number of tools need up-to-the-minute public information to
          work — for example the currency and cryptocurrency converters, which
          fetch current exchange rates and market prices. For those tools only,
          your browser makes a direct request to a reputable public data
          provider to retrieve rates. These requests carry no account
          information and none of the amounts or values you type — only the
          request for the latest public rates. Every such tool is clearly
          labelled in its interface, and all conversion still happens locally on
          your device. Every other tool on {SITE.name} runs fully offline in
          your browser with no network requests at all.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">The AI summarizer</h2>
        <p>
          One tool is an exception to the rules above: the PDF Summarizer. Summarizing
          needs an AI model that runs on a server, so when you click Summarize, the
          <strong>text extracted from your PDF</strong> is sent to our server and on to
          an AI provider to generate the summary, which is sent back to you. The original
          PDF file is never uploaded — only the text it contains, and only when you
          choose to summarize. We do not store the text or the summary after the request
          completes. This tool is clearly labelled in its interface; because your content
          does leave your device, avoid using it for confidential or sensitive documents.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Analytics and cookies</h2>
        <p>
          {SITE.name} does not use tracking cookies or third-party advertising
          networks. If privacy-respecting, aggregate analytics are ever added,
          they will never capture the content you type into a tool.
        </p>

        <h2 class="mt-4 font-display text-xl font-semibold text-ink">Contact</h2>
        <p>
          Questions about this policy? Reach out via the details listed on the
          {SITE.name} website.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

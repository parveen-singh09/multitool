?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="pdf-to-word">
  <div class="flex flex-col gap-4">
    <label id="pw-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose a PDF or drop it here</span>
      <input id="pw-file" type="file" accept="application/pdf" class="sr-only" />
    </label>

    <div id="pw-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-center gap-3">
        <button id="pw-convert" class="btn btn-primary">Convert to Word</button>
        <button id="pw-download" class="btn btn-secondary" disabled>Download .docx</button>
        <span id="pw-status" class="text-[13px] text-ink-subtle" aria-live="polite"></span>
      </div>
      <p class="text-[13px] text-ink-tertiary">
        This extracts the PDF’s text into an editable Word document. Text and
        paragraph breaks are preserved; original fonts, images and page layout
        are not reproduced. Scanned (image-only) PDFs have no text to extract —
        use <a class="underline" href="/pdf-to-text/">PDF to Text (OCR)</a> first.
      </p>
      <div class="copy-wrap">
        <textarea id="pw-preview" class="field text-[13px]" rows="12" spellcheck="false" placeholder="Extracted text preview will appear here — edit it before downloading if you like."></textarea>
        <button type="button" class="copy-icon" data-copy-target="#pw-preview" aria-label="Copy"></button>
      </div>
    </div>
    <p id="pw-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free PDF to Word converter extracts the text from a PDF and packages
      it as an editable Word (<code class="font-mono text-ink">.docx</code>)
      document you can open in Microsoft Word, Google Docs, LibreOffice or Pages.
    </p>
    <p>
      Because it works from the PDF’s embedded text, it preserves your words and
      paragraph breaks but does not reproduce the original page layout, fonts,
      columns or images — you get clean, editable text rather than a pixel-perfect
      copy. You can review and edit the extracted text right here before
      downloading. For scanned or image-only PDFs that contain no text layer, run
      them through our OCR-capable PDF to Text tool first, then paste the result.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import * as pdfjsLib from 'pdfjs-dist';
  import workerUrl from 'pdfjs-dist/build/pdf.worker.min.mjs?url';
  import { makeDocx } from '../lib/docx';
  pdfjsLib.GlobalWorkerOptions.workerSrc = workerUrl;

  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('pw-file') as HTMLInputElement;
  const drop = $('pw-drop');
  const panel = $('pw-panel');
  const preview = $('pw-preview') as HTMLTextAreaElement;
  const status = $('pw-status');
  const err = $('pw-error');
  const dlBtn = $('pw-download') as HTMLButtonElement;

  let bytes: ArrayBuffer | null = null;
  let baseName = 'document';
  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };

  function load(file: File) {
    setErr('');
    baseName = file.name.replace(/\.pdf$/i, '') || 'document';
    file.arrayBuffer().then((b) => {
      bytes = b;
      panel.classList.remove('hidden'); panel.classList.add('flex');
      status.textContent = `${file.name} ready.`;
      preview.value = ''; dlBtn.disabled = true;
    });
  }

  async function extractText(): Promise<string> {
    const pdf = await pdfjsLib.getDocument({ data: bytes!.slice(0) }).promise;
    const pages: string[] = [];
    for (let n = 1; n <= pdf.numPages; n++) {
      status.textContent = `Reading page ${n} / ${pdf.numPages}…`;
      const page = await pdf.getPage(n);
      const content = await page.getTextContent();
      let last = 0;
      const line = (content.items as any[]).map((it) => {
        const y = it.transform?.[5] ?? 0;
        let prefix = '';
        if (last && Math.abs(y - last) > 5) prefix = '\n';
        last = y;
        return prefix + it.str + (it.hasEOL ? '\n' : '');
      }).join('');
      pages.push(line.trim());
    }
    return pages.join('\n\n');
  }

  async function convert() {
    if (!bytes) return;
    setErr(''); dlBtn.disabled = true;
    const btn = $('pw-convert') as HTMLButtonElement;
    btn.disabled = true;
    try {
      const text = await extractText();
      if (text.replace(/\s/g, '').length < 3) {
        setErr('No embedded text found. This looks like a scanned PDF — run it through PDF to Text (OCR) first.');
        status.textContent = '';
        return;
      }
      preview.value = text;
      status.textContent = `Done — ${text.length.toLocaleString()} characters. Edit if needed, then download.`;
      dlBtn.disabled = false;
    } catch (e) {
      setErr('Could not read this PDF: ' + (e as Error).message);
      status.textContent = '';
    } finally { btn.disabled = false; }
  }

  function downloadDocx() {
    const paragraphs = preview.value.split(/\n/);
    const blob = makeDocx(paragraphs);
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `${baseName}.docx`;
    a.click();
    setTimeout(() => URL.revokeObjectURL(a.href), 1000);
  }

  fileInput.addEventListener('change', () => fileInput.files?.[0] && load(fileInput.files[0]));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) load(f); });
  $('pw-convert').addEventListener('click', convert);
  dlBtn.addEventListener('click', downloadDocx);
</script>

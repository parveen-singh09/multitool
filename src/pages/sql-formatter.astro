---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="sql-formatter">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Database
        <select id="sf-dialect" class="field w-40">
          <option value="sql">Standard SQL</option>
          <option value="mysql">MySQL</option>
          <option value="mariadb">MariaDB</option>
          <option value="postgresql">PostgreSQL</option>
          <option value="transactsql">SQL Server (T-SQL)</option>
          <option value="plsql">Oracle (PL/SQL)</option>
          <option value="db2">DB2</option>
          <option value="sqlite">SQLite</option>
          <option value="bigquery">BigQuery</option>
          <option value="redshift">Redshift</option>
          <option value="snowflake">Snowflake</option>
          <option value="spark">Spark SQL</option>
          <option value="hive">Hive</option>
          <option value="trino">Trino / Presto</option>
          <option value="duckdb">DuckDB</option>
          <option value="clickhouse">ClickHouse</option>
          <option value="tidb">TiDB</option>
          <option value="singlestoredb">SingleStore</option>
          <option value="n1ql">Couchbase N1QL</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Output
        <select id="sf-output" class="field w-40">
          <option value="sql">Plain SQL</option>
          <option value="csharp">C# string</option>
          <option value="csharp-sb">C# StringBuilder</option>
          <option value="java">Java string</option>
          <option value="java-sb">Java StringBuilder</option>
          <option value="php">PHP string</option>
          <option value="python">Python string</option>
          <option value="js">JS template literal</option>
        </select>
      </label>
      <button id="sf-format" type="button" class="btn btn-primary">Format</button>
      <button id="sf-minify" type="button" class="btn btn-secondary">Minify</button>
    </div>

    <div class="flex flex-wrap items-end gap-3">
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Keyword case
        <select id="sf-kw" class="field w-32">
          <option value="upper">UPPER</option>
          <option value="lower">lower</option>
          <option value="preserve">Keep</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Data type case
        <select id="sf-dt" class="field w-32">
          <option value="upper">UPPER</option>
          <option value="lower">lower</option>
          <option value="preserve">Keep</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Function case
        <select id="sf-fn" class="field w-32">
          <option value="upper">UPPER</option>
          <option value="lower">lower</option>
          <option value="preserve">Keep</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Identifier case
        <select id="sf-id" class="field w-32">
          <option value="preserve">Keep</option>
          <option value="upper">UPPER</option>
          <option value="lower">lower</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Indent
        <select id="sf-indent" class="field w-28">
          <option value="2">2 spaces</option>
          <option value="4">4 spaces</option>
          <option value="tab">Tab</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        AND / OR
        <select id="sf-logical" class="field w-36">
          <option value="before">Before line</option>
          <option value="after">After line</option>
        </select>
      </label>
    </div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        SQL input
        <div class="copy-wrap">
          <div class="hl-edit field p-0" style="height:24rem;resize:vertical;overflow:hidden">
            <pre class="hl-block" aria-hidden="true"><code id="sf-in-hl" class="hljs" style="background:transparent"></code></pre>
            <textarea id="sf-in" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder="select id, name from users where age > 21 order by name"></textarea>
          </div>
          <button type="button" class="copy-icon" data-copy-target="#sf-in" aria-label="Copy"></button>
        </div>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-subtle">
        Output
        <div class="copy-wrap">
          <pre class="hl-block field" style="height:24rem;overflow:auto"><code id="sf-out" class="hljs" style="background:transparent;padding:0"></code></pre>
          <button type="button" class="copy-icon" data-copy-target="#sf-out" aria-label="Copy"></button>
        </div>
      </div>
    </div>
    <p id="sf-err" class="hidden text-sm text-danger"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free SQL formatter beautifies and minifies queries for 19 database
      dialects — MySQL, PostgreSQL, SQL Server, Oracle, BigQuery, Snowflake,
      Redshift, Spark and more. Control keyword, data-type, function and
      identifier casing independently, pick your indent width, and choose where
      AND/OR breaks fall. Export the result as plain SQL or wrapped in a C#,
      Java, PHP, Python or JavaScript string literal to paste straight into your
      code.
    </p>
  </div>
</ToolLayout>

<script>
  import { format, type FormatOptionsWithLanguage, type SqlLanguage } from 'sql-formatter';

  import { hl, wireInput } from '../lib/highlight';

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const input = $<HTMLTextAreaElement>('sf-in');
  const inHl = $<HTMLElement>('sf-in-hl');
  const output = $<HTMLElement>('sf-out');
  const err = $<HTMLParagraphElement>('sf-err');
  let rawOutput = '';

  const OUT_HL: Record<string, string> = {
    sql: 'sql', csharp: 'csharp', 'csharp-sb': 'csharp',
    java: 'java', 'java-sb': 'java', php: 'php', python: 'python', js: 'javascript',
  };
  const dialect = $<HTMLSelectElement>('sf-dialect');
  const outputType = $<HTMLSelectElement>('sf-output');
  const kw = $<HTMLSelectElement>('sf-kw');
  const dt = $<HTMLSelectElement>('sf-dt');
  const fn = $<HTMLSelectElement>('sf-fn');
  const idCase = $<HTMLSelectElement>('sf-id');
  const indent = $<HTMLSelectElement>('sf-indent');
  const logical = $<HTMLSelectElement>('sf-logical');

  type Case = 'upper' | 'lower' | 'preserve';

  function options(): FormatOptionsWithLanguage {
    return {
      language: dialect.value as SqlLanguage,
      keywordCase: kw.value as Case,
      dataTypeCase: dt.value as Case,
      functionCase: fn.value as Case,
      identifierCase: idCase.value as Case,
      indentStyle: 'standard',
      useTabs: indent.value === 'tab',
      tabWidth: indent.value === 'tab' ? 1 : Number(indent.value),
      logicalOperatorNewline: logical.value as 'before' | 'after',
    };
  }

  function wrap(sql: string): string {
    const type = outputType.value;
    if (type === 'sql') return sql;
    const lines = sql.split('\n');
    const esc = (s: string, q: string) =>
      s.replace(/\\/g, '\\\\').replace(new RegExp(q, 'g'), '\\' + q);

    switch (type) {
      case 'csharp':
        return 'string sql =\n' +
          lines.map((l, i) => `    "${esc(l, '"')} "${i === lines.length - 1 ? ';' : ' +'}`).join('\n');
      case 'csharp-sb':
        return 'var sql = new StringBuilder();\n' +
          lines.map((l) => `sql.AppendLine("${esc(l, '"')}");`).join('\n');
      case 'java':
        return 'String sql =\n' +
          lines.map((l, i) => `    "${esc(l, '"')} "${i === lines.length - 1 ? ';' : ' +'}`).join('\n');
      case 'java-sb':
        return 'StringBuilder sql = new StringBuilder();\n' +
          lines.map((l) => `sql.append("${esc(l, '"')} ");`).join('\n');
      case 'php':
        return '$sql = "' + lines.map((l) => esc(l, '"')).join('\\n') + '";';
      case 'python':
        return 'sql = """\n' + sql + '\n"""';
      case 'js':
        return 'const sql = `\n' + sql.replace(/`/g, '\\`').replace(/\$\{/g, '\\${') + '\n`;';
      default:
        return sql;
    }
  }

  function showErr(msg: string | null) {
    if (msg) { err.textContent = msg; err.classList.remove('hidden'); }
    else err.classList.add('hidden');
  }

  function run(minify = false) {
    if (!input.value.trim()) { rawOutput = ''; output.textContent = ''; showErr(null); return; }
    try {
      const opts = options();
      let sql = format(input.value, opts);
      if (minify) sql = sql.replace(/\s+/g, ' ').trim();
      rawOutput = wrap(sql);
      hl(output, rawOutput, OUT_HL[outputType.value] ?? 'sql');
      showErr(null);
    } catch (e) {
      showErr((e as Error).message);
    }
  }

  $('sf-format').addEventListener('click', () => run(false));
  $('sf-minify').addEventListener('click', () => run(true));
  [dialect, outputType, kw, dt, fn, idCase, indent, logical].forEach((el) =>
    el.addEventListener('change', () => run(false)));

  input.value ="select u.id, u.name, u.email, count(o.id) as order_count from users u left join orders o on o.user_id = u.id where u.age > 21 and u.status = 'active' group by u.id, u.name, u.email having count(o.id) > 0 order by order_count desc limit 10";
  // Highlight the SQL input as you type; run() feeds the output panel.
  wireInput(input, inHl, () => 'sql', () => run(false));
  run(false);
</script>

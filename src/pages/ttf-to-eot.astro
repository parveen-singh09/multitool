---
import ToolLayout from '../layouts/ToolLayout.astro';
import FontConvert from '../components/FontConvert.astro';
---

<ToolLayout slug="ttf-to-eot">
  <FontConvert slug="ttf-to-eot" from="ttf" to="eot" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free TTF to EOT converter converts TrueType TTF fonts to EOT for embedding in legacy Internet Explorer.
    </p>
    <p>
      Everything runs entirely in your browser — your fonts are never uploaded to a
      server. Convert one font or a whole batch and download the results
      individually or as a ZIP.
    </p>
  </div>
</ToolLayout>

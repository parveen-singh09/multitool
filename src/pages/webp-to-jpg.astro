?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="webp-to-jpg">
  <div id="wj-root" class="flex flex-col gap-4">

    <label id="wj-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose WebP images or drop them here</span>
      <input id="wj-file" type="file" accept="image/webp,.webp" multiple class="sr-only" />
    </label>

    <div id="wj-panel" class="hidden flex-col gap-4">
      <div class="flex flex-wrap items-end gap-4">
        <label class="flex min-w-[160px] flex-col gap-1 text-sm text-ink-subtle">
          Quality: <span id="wj-qval" class="text-ink">90%</span>
          <input id="wj-q" type="range" min="10" max="100" value="90" class="w-full accent-primary" />
        </label>

        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Background
          <span class="flex items-center gap-2">
            <input id="wj-bg" type="color" value="#ffffff" class="h-8 w-10 cursor-pointer rounded-md border border-hairline bg-surface-1 p-0.5" aria-label="Background color for transparent areas" />
            <span id="wj-bgval" class="font-mono text-[13px] text-ink">#ffffff</span>
          </span>
        </label>

        <label class="flex flex-col gap-1 text-sm text-ink-subtle">
          Resize
          <select id="wj-resize" class="field w-auto py-1">
            <option value="0" selected>Original size</option>
            <option value="50">Scale 50%</option>
            <option value="25">Scale 25%</option>
            <option value="max">Max dimension…</option>
          </select>
        </label>
        <label id="wj-max-wrap" class="hidden flex-col gap-1 text-sm text-ink-subtle">
          Max width/height (px)
          <input id="wj-max" type="number" min="1" value="1920" class="field w-32 py-1" />
        </label>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <button id="wj-download-all" type="button" class="btn btn-primary">Download all</button>
        <button id="wj-clear" type="button" class="btn btn-tertiary">Clear</button>
        <span id="wj-summary" class="text-[13px] text-ink-subtle"></span>
      </div>

      <div id="wj-list" class="flex flex-col gap-3"></div>
    </div>

    <p id="wj-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free WebP to JPG converter turns WebP images into widely compatible
      JPEG files — handy when an app or service won't accept WebP. Drop in one
      image or a whole batch at once; each file is converted independently and
      can be downloaded on its own or all together.
    </p>
    <p>
      Because JPEG has no transparency, transparent areas are flattened onto a
      background color of your choice (white by default — pick any color with the
      swatch). Tune the JPEG quality from 10% to 100% to balance file size
      against fidelity, and optionally resize output by a percentage or a maximum
      width/height while preserving aspect ratio. Re-encoding through the canvas
      also strips EXIF and other embedded metadata, so converted files are
      lighter and don't carry hidden camera or location data. Animated WebP files
      convert to a still image from their first frame.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const drop = document.getElementById('wj-drop')!;
  const fileInput = document.getElementById('wj-file') as HTMLInputElement;
  const panel = document.getElementById('wj-panel')!;
  const list = document.getElementById('wj-list')!;
  const err = document.getElementById('wj-error')!;
  const summary = document.getElementById('wj-summary')!;
  const q = document.getElementById('wj-q') as HTMLInputElement;
  const qval = document.getElementById('wj-qval')!;
  const bg = document.getElementById('wj-bg') as HTMLInputElement;
  const bgval = document.getElementById('wj-bgval')!;
  const resizeSel = document.getElementById('wj-resize') as HTMLSelectElement;
  const maxWrap = document.getElementById('wj-max-wrap')!;
  const maxInput = document.getElementById('wj-max') as HTMLInputElement;

  type Item = {
    name: string;
    img: HTMLImageElement;
    originalSize: number;
    blob: Blob | null;
    url: string;      
    row: HTMLElement;
    infoEl: HTMLElement;
    dlBtn: HTMLButtonElement;
    imgEl: HTMLImageElement;
  };
  const items: Item[] = [];

  const fmtSize = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;
  const jpgName = (name: string) => name.replace(/\.[^./\\]+$/, '') + '.jpg';

  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }

  // Target draw dimensions from the resize option. Keeps aspect ratio; never upscales for the "max" mode.
  function targetSize(w: number, h: number): [number, number] {
    const mode = resizeSel.value;
    if (mode === '0') return [w, h];
    if (mode === 'max') {
      const m = Math.max(1, Number(maxInput.value) || 0);
      const scale = Math.min(1, m / Math.max(w, h));
      return [Math.max(1, Math.round(w * scale)), Math.max(1, Math.round(h * scale))];
    }
    const pct = Number(mode) / 100;
    return [Math.max(1, Math.round(w * pct)), Math.max(1, Math.round(h * pct))];
  }

  function convertItem(it: Item): Promise<void> {
    return new Promise((resolve) => {
      const [w, h] = targetSize(it.img.naturalWidth || 512, it.img.naturalHeight || 512);
      const canvas = document.createElement('canvas');
      canvas.width = w; canvas.height = h;
      const ctx = canvas.getContext('2d')!;
      ctx.fillStyle = bg.value;            // JPEG has no alpha — flatten onto chosen color
      ctx.fillRect(0, 0, w, h);
      ctx.drawImage(it.img, 0, 0, w, h);
      canvas.toBlob((b) => {
        if (it.url) URL.revokeObjectURL(it.url);
        if (!b) { it.infoEl.textContent = 'Encoding failed'; resolve(); return; }
        it.blob = b;
        it.url = URL.createObjectURL(b);
        it.imgEl.src = it.url;
        it.dlBtn.disabled = false;
        it.dlBtn.dataset.url = it.url;
        it.dlBtn.dataset.name = jpgName(it.name);
        it.infoEl.textContent = `${w}×${h} · ${fmtSize(it.originalSize)} → ${fmtSize(b.size)}`;
        resolve();
      }, 'image/jpeg', Number(q.value) / 100);
    });
  }

  async function convertAll() {
    if (!items.length) return;
    await Promise.all(items.map(convertItem));
    const outTotal = items.reduce((s, it) => s + (it.blob?.size ?? 0), 0);
    const inTotal = items.reduce((s, it) => s + it.originalSize, 0);
    summary.textContent = `${items.length} image${items.length === 1 ? '' : 's'} · ${fmtSize(inTotal)} → ${fmtSize(outTotal)}`;
  }

  function makeRow(it: Item) {
    const row = document.createElement('div');
    row.className = 'panel flex items-center gap-3 p-3';
    const thumb = document.createElement('img');
    thumb.className = 'h-14 w-14 shrink-0 rounded-md object-cover';
    thumb.alt = 'Converted preview';
    const meta = document.createElement('div');
    meta.className = 'flex min-w-0 flex-1 flex-col gap-0.5';
    const nameEl = document.createElement('span');
    nameEl.className = 'truncate text-sm text-ink';
    nameEl.textContent = jpgName(it.name);
    const infoEl = document.createElement('span');
    infoEl.className = 'text-[13px] text-ink-subtle';
    infoEl.textContent = 'Converting…';
    meta.append(nameEl, infoEl);
    const dl = document.createElement('button');
    dl.type = 'button';
    dl.className = 'btn btn-secondary px-3 py-1 text-[13px]';
    dl.textContent = 'Download';
    dl.disabled = true;
    dl.addEventListener('click', () => {
      if (!dl.dataset.url) return;
      const a = document.createElement('a');
      a.href = dl.dataset.url; a.download = dl.dataset.name || 'converted.jpg';
      a.click();
    });
    row.append(thumb, meta, dl);
    it.row = row; it.infoEl = infoEl; it.dlBtn = dl; it.imgEl = thumb;
    list.append(row);
  }

  function addFiles(files: FileList | File[]) {
    setErr('');
    const arr = Array.from(files);
    const webps = arr.filter((f) => f.type === 'image/webp' || /\.webp$/i.test(f.name));
    const rejected = arr.length - webps.length;
    if (!webps.length) { setErr('Please choose WebP (.webp) images.'); return; }
    if (rejected) setErr(`Skipped ${rejected} non-WebP file${rejected === 1 ? '' : 's'}.`);

    panel.classList.remove('hidden'); panel.classList.add('flex');
    let pending = webps.length;
    for (const file of webps) {
      const it: Item = { name: file.name, img: new Image(), originalSize: file.size, blob: null, url: '', row: null as any, infoEl: null as any, dlBtn: null as any, imgEl: null as any };
      items.push(it);
      makeRow(it);
      const reader = new FileReader();
      reader.onload = () => {
        it.img.onload = () => { if (--pending === 0) void convertAll(); };
        it.img.onerror = () => { it.infoEl.textContent = 'Could not read this image'; if (--pending === 0) void convertAll(); };
        it.img.src = reader.result as string;
      };
      reader.onerror = () => { it.infoEl.textContent = 'Could not read this file'; if (--pending === 0) void convertAll(); };
      reader.readAsDataURL(file);
    }
  }

  function clearAll() {
    for (const it of items) if (it.url) URL.revokeObjectURL(it.url);
    items.length = 0;
    list.innerHTML = '';
    summary.textContent = '';
    setErr('');
    panel.classList.add('hidden'); panel.classList.remove('flex');
    fileInput.value = '';
  }

  // Live re-convert on option change.
  q.addEventListener('input', () => { qval.textContent = q.value + '%'; void convertAll(); });
  bg.addEventListener('input', () => { bgval.textContent = bg.value; void convertAll(); });
  resizeSel.addEventListener('change', () => {
    maxWrap.classList.toggle('hidden', resizeSel.value !== 'max');
    maxWrap.classList.toggle('flex', resizeSel.value === 'max');
    void convertAll();
  });
  maxInput.addEventListener('input', () => { void convertAll(); });

  fileInput.addEventListener('change', () => { if (fileInput.files?.length) addFiles(fileInput.files); });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files; if (f?.length) addFiles(f); });

  document.getElementById('wj-clear')!.addEventListener('click', clearAll);
  document.getElementById('wj-download-all')!.addEventListener('click', () => {
    // ponytail: sequential anchor clicks — no zip dep. Small stagger so browsers don't drop rapid downloads.
    items.filter((it) => it.url).forEach((it, i) => setTimeout(() => {
      const a = document.createElement('a');
      a.href = it.url; a.download = jpgName(it.name);
      a.click();
    }, i * 150));
  });
</script>

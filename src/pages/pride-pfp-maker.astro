---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="pride-pfp-maker">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div class="flex flex-col gap-3">
      <div id="pp-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-6 text-center transition-colors hover:bg-surface-2">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-ink-subtle"><path d="M4 16l4-4 4 4 4-6 4 6M4 20h16M6 8a2 2 0 1 0 0-.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="text-sm text-ink">Upload your photo</span>
        <span class="text-xs text-ink-tertiary">JPG or PNG</span>
        <input id="pp-file" type="file" accept="image/*" class="hidden" />
      </div>

      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Flag
        <select id="pp-flag" class="field"></select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">Style
        <select id="pp-style" class="field">
          <option value="ring">Ring around edge</option>
          <option value="overlay">Full overlay (tinted)</option>
          <option value="background">Flag background</option>
          <option value="corner">Corner banner</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Ring / overlay strength <span id="pp-strength-val" class="text-ink-tertiary">18%</span>
        <input id="pp-strength" type="range" min="6" max="40" value="18" class="accent-primary" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Zoom <span id="pp-zoom-val" class="text-ink-tertiary">100%</span>
        <input id="pp-zoom" type="range" min="100" max="300" value="100" class="accent-primary" />
      </label>
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Rotate <span id="pp-rotate-val" class="text-ink-tertiary">0°</span>
        <input id="pp-rotate" type="range" min="-180" max="180" value="0" class="accent-primary" />
      </label>
      <div class="flex items-center gap-4 text-sm text-ink-subtle">
        <label class="flex items-center gap-2"><input id="pp-circle" type="checkbox" checked class="accent-primary" /> Circle crop</label>
        <button id="pp-reset" class="btn btn-secondary">Reset position</button>
      </div>
    </div>

    <div class="flex flex-col items-center gap-4">
      <canvas id="pp-canvas" width="512" height="512" class="h-56 w-56 cursor-grab touch-none rounded-full bg-surface-2 active:cursor-grabbing"></canvas>
      <span class="text-xs text-ink-tertiary">Drag the photo to reposition</span>
      <button id="pp-dl" class="btn btn-primary">Download PNG</button>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free Pride PFP maker adds a Pride flag to your profile picture. Upload a
      photo, drag to reposition, zoom and rotate to frame it, then choose from the
      Rainbow, Progress, Trans, Bisexual, Pansexual, Lesbian, Nonbinary, Asexual and
      many other flags. Pick a ring, a tinted overlay, a flag background or a corner
      banner, and export as a circle or square. It downloads as a PNG ready for
      any social profile.
    </p>
  </div>
</ToolLayout>

<script>

  const FLAGS: { name: string; colors: string[] }[] = [
    { name: 'Rainbow (6-color)', colors: ['#e40303', '#ff8c00', '#ffed00', '#008026', '#004dff', '#750787'] },
    { name: 'Progress', colors: ['#e40303', '#ff8c00', '#ffed00', '#008026', '#004dff', '#750787', '#ffffff', '#ffafc7', '#74d7ee', '#613915', '#000000'] },
    { name: 'Transgender', colors: ['#5bcefa', '#f5a9b8', '#ffffff', '#f5a9b8', '#5bcefa'] },
    { name: 'Bisexual', colors: ['#d60270', '#d60270', '#9b4f96', '#0038a8', '#0038a8'] },
    { name: 'Pansexual', colors: ['#ff218c', '#ffd800', '#21b1ff'] },
    { name: 'Lesbian', colors: ['#d52d00', '#ff9a56', '#ffffff', '#d362a4', '#a30262'] },
    { name: 'Nonbinary', colors: ['#fcf434', '#ffffff', '#9c59d1', '#2c2c2c'] },
    { name: 'Asexual', colors: ['#000000', '#a3a3a3', '#ffffff', '#800080'] },
    { name: 'Genderfluid', colors: ['#ff75a2', '#ffffff', '#be18d6', '#000000', '#333ebd'] },
    { name: 'Genderqueer', colors: ['#b57edc', '#ffffff', '#4a8123'] },
    { name: 'Agender', colors: ['#000000', '#b9b9b9', '#ffffff', '#b8f483', '#ffffff', '#b9b9b9', '#000000'] },
    { name: 'Demisexual', colors: ['#000000', '#ffffff', '#6e0070', '#d2d2d2'] },
    { name: 'Gay men (mlm)', colors: ['#078d70', '#98e8c1', '#ffffff', '#7bade2', '#3d1a78'] },
    { name: 'Aromantic', colors: ['#3da542', '#a7d379', '#ffffff', '#a9a9a9', '#000000'] },
    { name: 'Aroace', colors: ['#e28c00', '#eccd00', '#ffffff', '#62aedc', '#203856'] },
    { name: 'Polysexual', colors: ['#f61cb9', '#07d569', '#1c92f6'] },
    { name: 'Omnisexual', colors: ['#fe9ace', '#ff53bf', '#200044', '#6760fe', '#8ea6ff'] },
    { name: 'Intersex', colors: ['#ffd800'] },
  ];

  const $ = (id: string) => document.getElementById(id)!;
  const canvas = $('pp-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const flagSel = $('pp-flag') as HTMLSelectElement;
  const styleSel = $('pp-style') as HTMLSelectElement;
  const strength = $('pp-strength') as HTMLInputElement;
  const strengthVal = $('pp-strength-val');
  const zoom = $('pp-zoom') as HTMLInputElement;
  const zoomVal = $('pp-zoom-val');
  const rotate = $('pp-rotate') as HTMLInputElement;
  const rotateVal = $('pp-rotate-val');
  const circle = $('pp-circle') as HTMLInputElement;

  flagSel.innerHTML = FLAGS.map((f, i) => `<option value="${i}">${f.name}</option>`).join('');

  let img: HTMLImageElement | null = null;
  const SIZE = 512;
  let offX = 0, offY = 0; 

  function drawPlaceholder() {
    ctx.fillStyle = '#141516';
    ctx.fillRect(0, 0, SIZE, SIZE);
    ctx.fillStyle = '#62666d';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = '500 22px Inter, system-ui, sans-serif';
    ctx.fillText('Upload a photo', SIZE / 2, SIZE / 2);
  }

  function draw() {
    const flag = FLAGS[Number(flagSel.value)];
    const style = styleSel.value;
    const s = Number(strength.value) / 100;
    const z = Number(zoom.value) / 100;
    const rad = (Number(rotate.value) * Math.PI) / 180;
    const stripes = flag.colors;

    ctx.clearRect(0, 0, SIZE, SIZE);

    if (style === 'background') {
      const per = SIZE / stripes.length;
      stripes.forEach((c, i) => { ctx.fillStyle = c; ctx.fillRect(0, i * per, SIZE, per + 1); });
    }

    if (img) {
      const base = Math.max(SIZE / img.width, SIZE / img.height);
      const scale = base * z;
      const w = img.width * scale, h = img.height * scale;
      ctx.save();

      if (style === 'background') {
        const inset = SIZE * (0.5 - s);
        ctx.beginPath();
        ctx.arc(SIZE / 2, SIZE / 2, inset, 0, Math.PI * 2);
        ctx.clip();
      }
      ctx.translate(SIZE / 2 + offX, SIZE / 2 + offY);
      ctx.rotate(rad);
      ctx.drawImage(img, -w / 2, -h / 2, w, h);
      ctx.restore();
    } else if (style !== 'background') {
      drawPlaceholder();
    }

    if (style === 'ring') {
      const ringW = SIZE * s;
      const outer = SIZE / 2;
      const per = ringW / stripes.length;
      stripes.forEach((c, i) => {
        ctx.beginPath();
        ctx.arc(SIZE / 2, SIZE / 2, outer - i * per, 0, Math.PI * 2);
        ctx.arc(SIZE / 2, SIZE / 2, outer - (i + 1) * per, 0, Math.PI * 2, true);
        ctx.fillStyle = c;
        ctx.fill('evenodd');
      });
    } else if (style === 'overlay') {
      const per = SIZE / stripes.length;
      ctx.globalAlpha = s * 2.2;
      stripes.forEach((c, i) => { ctx.fillStyle = c; ctx.fillRect(0, i * per, SIZE, per + 1); });
      ctx.globalAlpha = 1;
    } else if (style === 'corner') {
      const band = SIZE * s * 1.6;
      const per = band / stripes.length;
      ctx.save();
      ctx.translate(SIZE * 0.5, -SIZE * 0.5);
      ctx.rotate(Math.PI / 4);
      stripes.forEach((c, i) => { ctx.fillStyle = c; ctx.fillRect(0, SIZE * 0.9 + i * per, SIZE * 1.5, per + 1); });
      ctx.restore();
    }

    if (circle.checked) {
      ctx.save();
      ctx.globalCompositeOperation = 'destination-in';
      ctx.beginPath();
      ctx.arc(SIZE / 2, SIZE / 2, SIZE / 2, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }

  function handleFile(file: File) {
    const url = URL.createObjectURL(file);
    const image = new Image();
    image.onload = () => { img = image; offX = 0; offY = 0; draw(); URL.revokeObjectURL(url); };
    image.src = url;
  }

  $('pp-drop').addEventListener('click', () => ($('pp-file') as HTMLInputElement).click());
  ($('pp-file') as HTMLInputElement).addEventListener('change', (e) => {
    const f = (e.target as HTMLInputElement).files?.[0]; if (f) handleFile(f);
  });
  $('pp-drop').addEventListener('dragover', (e) => { e.preventDefault(); $('pp-drop').classList.add('bg-surface-2'); });
  $('pp-drop').addEventListener('dragleave', () => $('pp-drop').classList.remove('bg-surface-2'));
  $('pp-drop').addEventListener('drop', (e) => {
    e.preventDefault(); $('pp-drop').classList.remove('bg-surface-2');
    const f = e.dataTransfer?.files?.[0]; if (f) handleFile(f);
  });

  let dragging = false, lastX = 0, lastY = 0;
  const toCanvas = (e: PointerEvent) => {
    const r = canvas.getBoundingClientRect();
    return { x: ((e.clientX - r.left) / r.width) * SIZE, y: ((e.clientY - r.top) / r.height) * SIZE };
  };
  canvas.addEventListener('pointerdown', (e) => {
    if (!img) return;
    dragging = true; canvas.setPointerCapture(e.pointerId);
    const p = toCanvas(e); lastX = p.x; lastY = p.y;
  });
  canvas.addEventListener('pointermove', (e) => {
    if (!dragging) return;
    const p = toCanvas(e);
    offX += p.x - lastX; offY += p.y - lastY; lastX = p.x; lastY = p.y;
    draw();
  });
  canvas.addEventListener('pointerup', () => { dragging = false; });

  flagSel.addEventListener('change', draw);
  styleSel.addEventListener('change', draw);
  circle.addEventListener('change', draw);
  strength.addEventListener('input', () => { strengthVal.textContent = `${strength.value}%`; draw(); });
  zoom.addEventListener('input', () => { zoomVal.textContent = `${zoom.value}%`; draw(); });
  rotate.addEventListener('input', () => { rotateVal.textContent = `${rotate.value}°`; draw(); });
  $('pp-reset').addEventListener('click', () => {
    offX = 0; offY = 0; zoom.value = '100'; rotate.value = '0';
    zoomVal.textContent = '100%'; rotateVal.textContent = '0°'; draw();
  });

  $('pp-dl').addEventListener('click', () => {
    const a = document.createElement('a');
    a.href = canvas.toDataURL('image/png');
    a.download = 'pride-pfp.png';
    a.click();
  });

  drawPlaceholder();
</script>

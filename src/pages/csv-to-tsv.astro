---
import ToolLayout from '../layouts/ToolLayout.astro';
import DocConvert from '../components/DocConvert.astro';
---

<ToolLayout slug="csv-to-tsv">
  <DocConvert slug="csv-to-tsv" outLabel="TSV" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSV to TSV converter converts CSV data into a tab-separated file. Everything runs entirely in your browser, so your files are never uploaded to a server.
    </p>
    <p>
      Paste your content or attach a file, click Convert, then download or copy the result.
      Conversions happen offline through your browser, so the tool works without a network
      connection and nothing leaves your device.
    </p>
  </div>
</ToolLayout>

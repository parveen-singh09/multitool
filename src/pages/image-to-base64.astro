?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="image-to-base64">
  <div class="flex flex-col gap-4">
    <label id="ib-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      <span class="text-sm text-ink">Choose images, drop them here, or paste from clipboard</span>
      <input id="ib-file" type="file" accept="image/*" multiple class="sr-only" />
    </label>

    <div id="ib-panel" class="hidden flex-col gap-4">

      <div id="ib-strip" class="hidden flex-wrap items-center gap-2"></div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

        <div class="flex flex-col gap-3">
          <div class="panel flex min-h-48 items-center justify-center overflow-hidden p-4">
            <img id="ib-preview" class="max-h-64 w-auto max-w-full rounded-md" alt="Selected image preview" />
          </div>
          <dl id="ib-meta" class="grid grid-cols-2 gap-x-4 gap-y-1 text-[13px]"></dl>
        </div>

        <div class="flex flex-col gap-3 text-sm text-ink-subtle">
          <div class="flex flex-wrap items-end gap-3">
            <label class="flex flex-col gap-1">
              Output
              <select id="ib-format" class="field w-auto py-1">
                <option value="datauri" selected>Data URI</option>
                <option value="raw">Raw Base64</option>
                <option value="css">CSS background</option>
                <option value="html">HTML &lt;img&gt;</option>
                <option value="favicon">HTML favicon</option>
                <option value="markdown">Markdown</option>
                <option value="json">JSON</option>
              </select>
            </label>
            <label class="flex items-center gap-2 pb-2 text-ink-subtle">
              <input id="ib-wrap" type="checkbox" class="accent-primary" />
              Wrap lines
            </label>
            <label id="ib-chunk-wrap" class="hidden flex-col gap-1">
              Chunk
              <select id="ib-chunk" class="field w-auto py-1">
                <option value="64">64</option>
                <option value="76" selected>76 (MIME)</option>
                <option value="120">120</option>
              </select>
            </label>
          </div>

          <span class="flex items-center justify-between">
            <span id="ib-out-label" class="text-ink-subtle">Data URI output</span>
            <span class="flex gap-2">
              <button id="ib-download" type="button" class="btn btn-secondary px-2 py-1 text-[13px]">Download</button>
            </span>
          </span>
          <div class="copy-wrap"><pre class="hl-block field" style="height:18rem;margin:0;overflow:auto;white-space:pre-wrap;word-break:break-all"><code id="ib-out" class="hljs" style="background:transparent;padding:0"></code></pre><button type="button" class="copy-icon" data-copy-target="#ib-out" aria-label="Copy"></button></div>
        </div>
      </div>

      <button id="ib-reset" type="button" class="btn btn-tertiary self-start px-2 py-1 text-[13px]">Clear all</button>
    </div>

    <p id="ib-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free image to Base64 converter encodes JPG, PNG, GIF, WebP, SVG, BMP,
      ICO and AVIF images into Base64 strings you can embed directly in HTML or
      CSS. Choose the output that fits your workflow: a ready-to-use data URI,
      the raw Base64, a CSS <code>background-image</code> snippet, an HTML
      <code>&lt;img&gt;</code> tag, an HTML favicon <code>&lt;link&gt;</code>,
      a Markdown image, or a JSON payload with the MIME type and data.
    </p>
    <p>
      Load several images at once and switch between them from the thumbnail
      strip, or paste an image straight from your clipboard. Each file shows its
      MIME type, dimensions, original size and encoded length. Optionally wrap
      the output into fixed-width lines (76 characters is the classic MIME
      standard) for email or config files. Copy any result with one click or
      download it as a text file.
    </p>
  </div>
</ToolLayout>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  .ib-thumb { width:3rem; height:3rem; object-fit:cover; border-radius:6px; border:2px solid transparent; cursor:pointer; }
  .ib-thumb[data-active="true"] { border-color: var(--color-primary); }
</style>

<script>
  import { hl } from '../lib/highlight';

  const fileInput = document.getElementById('ib-file') as HTMLInputElement;
  const drop = document.getElementById('ib-drop')!;
  const panel = document.getElementById('ib-panel')!;
  const strip = document.getElementById('ib-strip')!;
  const preview = document.getElementById('ib-preview') as HTMLImageElement;
  const metaEl = document.getElementById('ib-meta')!;
  const outEl = document.getElementById('ib-out')!;
  const outLabel = document.getElementById('ib-out-label')!;
  const formatSel = document.getElementById('ib-format') as HTMLSelectElement;
  const wrapChk = document.getElementById('ib-wrap') as HTMLInputElement;
  const chunkWrap = document.getElementById('ib-chunk-wrap')!;
  const chunkSel = document.getElementById('ib-chunk') as HTMLSelectElement;
  const errEl = document.getElementById('ib-error')!;

  type Item = { name: string; dataUri: string; mime: string; bytes: number; w: number; h: number };
  const items: Item[] = [];
  let active = -1;
  let outputText = '';

  const OUT_LANG: Record<string, string> = {
    datauri: 'plaintext', raw: 'plaintext', css: 'css',
    html: 'xml', favicon: 'xml', markdown: 'markdown', json: 'json',
  };
  const OUT_LABEL: Record<string, string> = {
    datauri: 'Data URI output', raw: 'Raw Base64 output', css: 'CSS output',
    html: 'HTML output', favicon: 'HTML favicon output', markdown: 'Markdown output', json: 'JSON output',
  };
  const OUT_EXT: Record<string, string> = {
    datauri: 'txt', raw: 'txt', css: 'css', html: 'html', favicon: 'html', markdown: 'md', json: 'json',
  };

  function showError(msg: string) {
    errEl.textContent = msg;
    errEl.classList.remove('hidden');
  }

  function fmtBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
    return `${(n / (1024 * 1024)).toFixed(2)} MB`;
  }

  function chunk(s: string, size: number): string {
    return s.replace(new RegExp(`.{1,${size}}`, 'g'), '$&\n').trimEnd();
  }

  function loadFiles(files: File[]) {
    errEl.classList.add('hidden');
    const images = files.filter((f) => f.type.startsWith('image/') || /\.(svg|ico|bmp|avif)$/i.test(f.name));
    if (!images.length) { showError('No image files found. Choose JPG, PNG, GIF, WebP, SVG, BMP, ICO or AVIF.'); return; }
    let pending = images.length;
    images.forEach((file) => {
      const reader = new FileReader();
      reader.onerror = () => { if (--pending === 0) afterLoad(); showError(`Could not read “${file.name}”.`); };
      reader.onload = () => {
        const dataUri = reader.result as string;
        const item: Item = { name: file.name, dataUri, mime: file.type || 'image/*', bytes: file.size, w: 0, h: 0 };
        const probe = new Image();
        probe.onload = () => { item.w = probe.naturalWidth; item.h = probe.naturalHeight; if (active === items.indexOf(item)) render(); };
        probe.src = dataUri;
        items.push(item);
        if (--pending === 0) afterLoad();
      };
      reader.readAsDataURL(file);
    });
  }

  function afterLoad() {
    panel.classList.remove('hidden');
    panel.classList.add('flex');
    if (active < 0) active = 0;
    renderStrip();
    render();
  }

  function renderStrip() {
    if (items.length <= 1) { strip.classList.add('hidden'); strip.classList.remove('flex'); strip.innerHTML = ''; return; }
    strip.classList.remove('hidden');
    strip.classList.add('flex');
    strip.innerHTML = '';
    items.forEach((it, i) => {
      const img = document.createElement('img');
      img.src = it.dataUri;
      img.className = 'ib-thumb';
      img.alt = it.name;
      img.title = it.name;
      img.dataset.active = String(i === active);
      img.addEventListener('click', () => { active = i; renderStrip(); render(); });
      strip.appendChild(img);
    });
  }

  function currentOutput(it: Item): string {
    const b64 = it.dataUri.split(',')[1] ?? '';
    const size = Number(chunkSel.value);
    const wrap = (s: string) => (wrapChk.checked ? chunk(s, size) : s);
    switch (formatSel.value) {
      case 'raw': return wrap(b64);
      case 'css': return `background-image: url("${it.dataUri}");`;
      case 'html': return `<img src="${it.dataUri}" alt="${it.name}" />`;
      case 'favicon': return `<link rel="icon" type="${it.mime}" href="${it.dataUri}" />`;
      case 'markdown': return `![${it.name}](${it.dataUri})`;
      case 'json': return JSON.stringify({ name: it.name, mime: it.mime, data: b64 }, null, 2);
      default: return wrap(it.dataUri);
    }
  }

  async function render() {
    if (active < 0 || !items[active]) return;
    const it = items[active];
    preview.src = it.dataUri;
    outLabel.textContent = OUT_LABEL[formatSel.value];
    const wrappable = formatSel.value === 'raw' || formatSel.value === 'datauri';
    (wrapChk.closest('label') as HTMLElement).style.display = wrappable ? '' : 'none';
    chunkWrap.classList.toggle('hidden', !(wrappable && wrapChk.checked));
    chunkWrap.classList.toggle('flex', wrappable && wrapChk.checked);

    metaEl.innerHTML = '';
    const rows: [string, string][] = [
      ['File', it.name],
      ['Type', it.mime],
      ['Dimensions', it.w ? `${it.w} × ${it.h}px` : '—'],
      ['Original size', fmtBytes(it.bytes)],
      ['Base64 length', `${(it.dataUri.split(',')[1] ?? '').length.toLocaleString()} chars`],
    ];
    for (const [k, v] of rows) {
      const dt = document.createElement('dt');
      dt.className = 'text-ink-tertiary';
      dt.textContent = k;
      const dd = document.createElement('dd');
      dd.className = 'text-ink truncate';
      dd.textContent = v;
      dd.title = v;
      metaEl.append(dt, dd);
    }

    outputText = currentOutput(it);
    await hl(outEl, outputText, OUT_LANG[formatSel.value] ?? 'plaintext');
  }

  function reset() {
    items.length = 0;
    active = -1;
    outputText = '';
    outEl.textContent = '';
    panel.classList.add('hidden');
    panel.classList.remove('flex');
    fileInput.value = '';
    errEl.classList.add('hidden');
  }

  formatSel.addEventListener('change', render);
  wrapChk.addEventListener('change', render);
  chunkSel.addEventListener('change', render);
  fileInput.addEventListener('change', () => { if (fileInput.files?.length) loadFiles(Array.from(fileInput.files)); });

  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => {
    ev.preventDefault();
    const f = (ev as DragEvent).dataTransfer?.files;
    if (f?.length) loadFiles(Array.from(f));
  });

  window.addEventListener('paste', (ev) => {
    const files = Array.from((ev as ClipboardEvent).clipboardData?.files ?? []).filter((f) => f.type.startsWith('image/'));
    if (files.length) { ev.preventDefault(); loadFiles(files); }
  });

  document.getElementById('ib-reset')!.addEventListener('click', reset);

  document.getElementById('ib-download')!.addEventListener('click', () => {
    if (!outputText || active < 0) return;
    const base = (items[active].name.replace(/\.[^.]+$/, '') || 'image') + '.base64';
    const blob = new Blob([outputText], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${base}.${OUT_EXT[formatSel.value] ?? 'txt'}`;
    a.click();
    URL.revokeObjectURL(url);
  });
</script>

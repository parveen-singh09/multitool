---
import ToolLayout from '../layouts/ToolLayout.astro';
import ArchiveConvert from '../components/ArchiveConvert.astro';
const CAD_TARGETS = ['dwg', 'dxf', 'dwf', 'pdf', 'svg'];
---

<ToolLayout slug="cad-converter">
  <ArchiveConvert slug="cad-converter" targets={CAD_TARGETS} noun="CAD file" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free online CAD converter converts between AutoCAD drawing formats —
      DWG, DXF and DWF — and can also export drawings to PDF or SVG. Upload a file,
      pick your target format, and convert.
    </p>
    <p>
      DWG, DXF and DWF are proprietary CAD formats that no browser can read on its
      own, so conversion is handled on our servers. Your
      file is uploaded to our servers, converted on their
      servers, and returned as a download link.
    </p>
  </div>
</ToolLayout>

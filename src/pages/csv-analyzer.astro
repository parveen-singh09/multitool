?---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="csv-analyzer">
  <div class="flex flex-col gap-5">

    <div class="flex flex-wrap gap-1 rounded-lg border border-hairline bg-surface-1 p-1 text-[13px]">
      <button data-tab="file" class="csva-tab btn btn-tertiary flex-1 py-1.5">Upload file</button>
      <button data-tab="paste" class="csva-tab btn btn-tertiary flex-1 py-1.5">Paste text</button>
      <button data-tab="url" class="csva-tab btn btn-tertiary flex-1 py-1.5">From URL</button>
    </div>

    <div id="csva-pane-file" class="csva-pane">
      <div id="csva-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-ink-subtle"><path d="M12 16V4m0 0L8 8m4-4 4 4M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="text-sm text-ink">Drop a <span class="font-mono">.csv</span> / <span class="font-mono">.tsv</span> file here or click to choose</span>
        <input id="csva-file" type="file" accept=".csv,.tsv,.txt,text/csv,text/plain" class="hidden" />
      </div>
    </div>

    <div id="csva-pane-paste" class="csva-pane hidden">
      <textarea id="csva-in" class="field min-h-32 w-full resize-y font-mono text-[13px]" placeholder="name,age,active&#10;Ada,36,true&#10;Grace,42,false" spellcheck="false"></textarea>
    </div>

    <div id="csva-pane-url" class="csva-pane hidden">
      <div class="flex flex-wrap gap-2">
        <input id="csva-url" type="url" class="field min-w-0 flex-1 font-mono text-[13px]" placeholder="https://example.com/data.csv" spellcheck="false" />
        <button id="csva-fetch" class="btn btn-primary px-4">Load</button>
      </div>
      <p class="mt-1.5 text-xs text-ink-tertiary">The remote server must allow cross-origin requests (CORS), or the fetch will be blocked by your browser.</p>
    </div>

    <div class="flex flex-wrap items-center gap-4">
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        Delimiter
        <select id="csva-delim" class="field w-auto py-1">
          <option value="auto" selected>Auto-detect</option>
          <option value=",">Comma</option>
          <option value=";">Semicolon</option>
          <option value="\t">Tab</option>
          <option value="|">Pipe</option>
        </select>
      </label>
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        <input id="csva-header" type="checkbox" checked /> First row is header
      </label>
      <span id="csva-detected" class="text-[13px] text-ink-muted"></span>
    </div>

    <p id="csva-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>

    <div id="csva-report" class="hidden flex-col gap-5">

      <div id="csva-summary" class="grid grid-cols-2 gap-3 sm:grid-cols-4"></div>

      <div class="flex flex-wrap items-center gap-2">
        <span class="eyebrow mr-1">Export</span>
        <button data-exp="json" class="csva-exp btn btn-secondary px-3 py-1 text-[13px]">JSON</button>
        <button data-exp="tsv" class="csva-exp btn btn-secondary px-3 py-1 text-[13px]">TSV</button>
        <button data-exp="csv" class="csva-exp btn btn-secondary px-3 py-1 text-[13px]">Clean CSV</button>
        <button data-exp="copyjson" class="csva-exp btn btn-secondary px-3 py-1 text-[13px]">Copy JSON</button>
        <span id="csva-copied" class="text-[13px] text-primary-hover opacity-0 transition-opacity">Copied</span>
      </div>

      <div class="flex flex-col gap-2">
        <div class="eyebrow">Column profile</div>
        <div class="panel overflow-x-auto">
          <table class="w-full text-left text-[13px]">
            <thead class="text-ink-tertiary">
              <tr class="border-b border-hairline">
                <th class="px-3 py-2 font-medium">Column</th>
                <th class="px-3 py-2 font-medium">Type</th>
                <th class="px-3 py-2 text-right font-medium">Non-empty</th>
                <th class="px-3 py-2 text-right font-medium">Unique</th>
                <th class="px-3 py-2 text-right font-medium">Min</th>
                <th class="px-3 py-2 text-right font-medium">Max</th>
                <th class="px-3 py-2 text-right font-medium">Mean</th>
              </tr>
            </thead>
            <tbody id="csva-profile" class="text-ink"></tbody>
          </table>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <div class="flex flex-wrap items-center gap-2">
          <div class="eyebrow">Data</div>
          <input id="csva-search" type="search" class="field ml-auto w-full py-1 text-[13px] sm:w-64" placeholder="Search all cells…" />
        </div>
        <div class="panel max-h-[32rem] overflow-auto">
          <table class="w-full text-left text-[13px]">
            <thead id="csva-grid-head" class="sticky top-0 bg-surface-1 text-ink-subtle"></thead>
            <tbody id="csva-grid-body" class="font-mono"></tbody>
          </table>
        </div>
        <div class="flex flex-wrap items-center justify-between gap-2 text-[13px] text-ink-subtle">
          <span id="csva-count"></span>
          <div class="flex items-center gap-2">
            <button id="csva-prev" class="btn btn-secondary px-3 py-1">Prev</button>
            <span id="csva-page"></span>
            <button id="csva-next" class="btn btn-secondary px-3 py-1">Next</button>
          </div>
        </div>
      </div>
    </div>

    <div id="csva-empty" class="text-[13px] text-ink-subtle">Upload, paste, or link a CSV to view, profile, and convert it.</div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free CSV analyzer lets you view, profile, and convert CSV or TSV data
      without uploading it anywhere. Load data three ways — drop or choose a file,
      paste text, or fetch a public URL — and it renders an interactive table you
      can search and sort by any column, paged for large files. For every column
      it infers the type (number, date, boolean or string) and reports non-empty
      and unique counts, plus min, max and mean for numeric columns. Delimiters
      (comma, semicolon, tab or pipe) are auto-detected, quoted fields with embedded
      commas and newlines are handled correctly, and you can export the parsed data
      as JSON, TSV or a cleaned, normalized CSV.
    </p>
  </div>
</ToolLayout>

<script>
  import { parseMatrix, detectDelimiter, stringify } from '../lib/csv';

  const $ = (id: string) => document.getElementById(id)!;
  const delimSel = $('csva-delim') as HTMLSelectElement;
  const headerChk = $('csva-header') as HTMLInputElement;
  const detected = $('csva-detected');
  const err = $('csva-error');
  const report = $('csva-report');
  const empty = $('csva-empty');
  const search = $('csva-search') as HTMLInputElement;

  const NUM_RE = /^-?(?:\d+\.?\d*|\.\d+)(?:[eE][+-]?\d+)?$/;
  const BOOL_RE = /^(true|false|yes|no|y|n)$/i;
  const PAGE_SIZE = 50;

  let headers: string[] = [];
  let rows: string[][] = [];        
  let view: string[][] = [];        
  let page = 0;
  let sortCol = -1;
  let sortDir: 1 | -1 = 1;
  let lastText = '';

  function showError(msg: string) {
    err.textContent = msg;
    err.classList.remove('hidden');
    report.classList.add('hidden');
    empty.classList.add('hidden');
  }

  function resolveDelim(text: string): string {
    let d = delimSel.value;
    if (d === '\\t') return '\t';
    if (d !== 'auto') return d;
    const guess = detectDelimiter(text);
    const label = guess === '\t' ? 'tab' : guess === ',' ? 'comma' : guess === ';' ? 'semicolon' : guess === '|' ? 'pipe' : guess;
    detected.textContent = `Detected: ${label}`;
    return guess;
  }

  function inferType(values: string[]): string {
    const nonEmpty = values.filter((v) => v.trim() !== '');
    if (!nonEmpty.length) return 'empty';
    let num = 0, bool = 0, date = 0;
    for (const raw of nonEmpty) {
      const v = raw.trim();
      if (NUM_RE.test(v)) num++;
      else if (BOOL_RE.test(v)) bool++;
      else if (!isNaN(Date.parse(v)) && /[-/:]/.test(v)) date++;
    }
    const n = nonEmpty.length;
    if (num === n) return 'number';
    if (bool === n) return 'boolean';
    if (date === n) return 'date';
    return 'string';
  }

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function statTile(label: string, value: string): string {
    return `<div class="panel panel-lift flex flex-col gap-1 p-4">
      <span class="text-xs text-ink-tertiary">${label}</span>
      <span class="font-display text-2xl font-semibold text-ink">${value}</span>
    </div>`;
  }

  function parse(text: string) {
    err.classList.add('hidden');
    detected.textContent = '';
    lastText = text;
    if (!text.trim()) { reset(); return; }

    const delim = resolveDelim(text);
    let grid: string[][];
    try {
      grid = parseMatrix(text, { separator: delim })
        .filter((r) => !(r.length === 1 && r[0] === ''));
    } catch (e) {
      showError('Could not parse this data as CSV.');
      return;
    }
    if (!grid.length) { showError('No rows found.'); return; }

    const colCount = Math.max(...grid.map((r) => r.length));
    const hasHeader = headerChk.checked;
    headers = hasHeader
      ? Array.from({ length: colCount }, (_, i) => (grid[0][i] || '').trim() || `Column ${i + 1}`)
      : Array.from({ length: colCount }, (_, i) => `Column ${i + 1}`);
    rows = (hasHeader ? grid.slice(1) : grid).map((r) =>
      Array.from({ length: colCount }, (_, i) => r[i] ?? ''));

    sortCol = -1;
    page = 0;
    empty.classList.add('hidden');
    report.classList.remove('hidden');
    renderSummary();
    renderProfile();
    applyView();
  }

  function reset() {
    report.classList.add('hidden');
    empty.classList.remove('hidden');
    detected.textContent = '';
    headers = []; rows = []; view = [];
  }

  function renderSummary() {
    $('csva-summary').innerHTML =
      statTile('Data rows', rows.length.toLocaleString()) +
      statTile('Columns', String(headers.length)) +
      statTile('Total cells', (rows.length * headers.length).toLocaleString()) +
      statTile('Empty cells', rows.reduce((a, r) => a + r.filter((c) => c.trim() === '').length, 0).toLocaleString());
  }

  function renderProfile() {
    let html = '';
    for (let c = 0; c < headers.length; c++) {
      const col = rows.map((r) => r[c] ?? '');
      const nonEmpty = col.filter((v) => v.trim() !== '');
      const type = inferType(col);
      const unique = new Set(nonEmpty.map((v) => v.trim())).size;
      let min = '—', max = '—', mean = '—';
      if (type === 'number') {
        const nums = nonEmpty.map((v) => Number(v.trim())).filter((n) => !isNaN(n));
        if (nums.length) {
          min = String(Math.min(...nums));
          max = String(Math.max(...nums));
          mean = (nums.reduce((a, n) => a + n, 0) / nums.length).toFixed(2);
        }
      }
      html += `<tr class="border-b border-hairline/50">
        <td class="px-3 py-1.5 font-mono">${esc(headers[c])}</td>
        <td class="px-3 py-1.5 text-ink-subtle">${type}</td>
        <td class="px-3 py-1.5 text-right font-mono">${nonEmpty.length.toLocaleString()}</td>
        <td class="px-3 py-1.5 text-right font-mono">${unique.toLocaleString()}</td>
        <td class="px-3 py-1.5 text-right font-mono text-ink-subtle">${esc(min)}</td>
        <td class="px-3 py-1.5 text-right font-mono text-ink-subtle">${esc(max)}</td>
        <td class="px-3 py-1.5 text-right font-mono text-ink-subtle">${mean}</td>
      </tr>`;
    }
    $('csva-profile').innerHTML = html;
  }

  function applyView() {
    const q = search.value.trim().toLowerCase();
    view = q ? rows.filter((r) => r.some((c) => c.toLowerCase().includes(q))) : rows.slice();
    if (sortCol >= 0) {
      const numeric = view.every((r) => r[sortCol].trim() === '' || NUM_RE.test(r[sortCol].trim()));
      view.sort((a, b) => {
        const x = a[sortCol] ?? '', y = b[sortCol] ?? '';
        const cmp = numeric ? Number(x || 0) - Number(y || 0) : x.localeCompare(y);
        return cmp * sortDir;
      });
    }
    page = Math.min(page, Math.max(0, Math.ceil(view.length / PAGE_SIZE) - 1));
    renderGrid();
  }

  function renderGrid() {
    $('csva-grid-head').innerHTML = '<tr class="border-b border-hairline">' +
      headers.map((h, i) => {
        const arrow = i === sortCol ? (sortDir === 1 ? ' ▲' : ' ▼') : '';
        return `<th class="csva-sort cursor-pointer select-none whitespace-nowrap px-3 py-2 font-medium hover:text-ink" data-col="${i}">${esc(h)}${arrow}</th>`;
      }).join('') + '</tr>';

    const start = page * PAGE_SIZE;
    const slice = view.slice(start, start + PAGE_SIZE);
    $('csva-grid-body').innerHTML = slice.map((r) =>
      '<tr class="border-b border-hairline/50">' +
      r.map((c) => `<td class="max-w-80 truncate px-3 py-1.5 text-ink-subtle" title="${esc(c)}">${esc(c)}</td>`).join('') +
      '</tr>').join('') || `<tr><td class="px-3 py-4 text-ink-tertiary" colspan="${headers.length}">No matching rows.</td></tr>`;

    const totalPages = Math.max(1, Math.ceil(view.length / PAGE_SIZE));
    $('csva-count').textContent = view.length === rows.length
      ? `${rows.length.toLocaleString()} rows`
      : `${view.length.toLocaleString()} of ${rows.length.toLocaleString()} rows`;
    $('csva-page').textContent = `${page + 1} / ${totalPages}`;
    ($('csva-prev') as HTMLButtonElement).disabled = page === 0;
    ($('csva-next') as HTMLButtonElement).disabled = page >= totalPages - 1;
  }

  function objects(): Record<string, string>[] {
    return rows.map((r) => Object.fromEntries(headers.map((h, i) => [h, r[i] ?? ''])));
  }
  function download(name: string, text: string, mime: string) {
    const url = URL.createObjectURL(new Blob([text], { type: mime }));
    const a = document.createElement('a');
    a.href = url; a.download = name; a.click();
    URL.revokeObjectURL(url);
  }
  function doExport(kind: string) {
    if (!rows.length) return;
    if (kind === 'json' || kind === 'copyjson') {
      const json = JSON.stringify(objects(), null, 2);
      if (kind === 'copyjson') {
        navigator.clipboard?.writeText(json).then(() => {
          const c = $('csva-copied'); c.style.opacity = '1';
          setTimeout(() => (c.style.opacity = '0'), 1200);
        });
      } else download('data.json', json, 'application/json');
    } else if (kind === 'tsv') {
      download('data.tsv', stringify(objects(), { separator: '\t', columns: headers }), 'text/tab-separated-values');
    } else if (kind === 'csv') {
      download('data.csv', stringify(objects(), { columns: headers }), 'text/csv');
    }
  }

  document.querySelectorAll<HTMLElement>('.csva-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const name = tab.dataset.tab!;
      document.querySelectorAll('.csva-tab').forEach((t) => t.classList.toggle('btn-secondary', t === tab));
      document.querySelectorAll('.csva-pane').forEach((p) => p.classList.toggle('hidden', p.id !== `csva-pane-${name}`));
    });
  });
  (document.querySelector('.csva-tab[data-tab="file"]') as HTMLElement).classList.add('btn-secondary');

  const drop = $('csva-drop');
  const fileInput = $('csva-file') as HTMLInputElement;
  function handleFile(file: File) {
    const reader = new FileReader();
    reader.onload = () => parse(String(reader.result));
    reader.onerror = () => showError('Could not read that file.');
    reader.readAsText(file);
  }
  drop.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) handleFile(fileInput.files[0]); });
  drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('bg-surface-2'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('bg-surface-2'));
  drop.addEventListener('drop', (e) => {
    e.preventDefault(); drop.classList.remove('bg-surface-2');
    const f = e.dataTransfer?.files?.[0]; if (f) handleFile(f);
  });

  const pasteIn = $('csva-in') as HTMLTextAreaElement;
  pasteIn.addEventListener('input', () => parse(pasteIn.value));

  $('csva-fetch').addEventListener('click', async () => {
    const url = ($('csva-url') as HTMLInputElement).value.trim();
    if (!url) return;
    err.classList.add('hidden');
    try {
      const res = await fetch(url);
      if (!res.ok) throw new Error(String(res.status));
      parse(await res.text());
    } catch {
      showError('Could not fetch that URL. The server may not allow cross-origin requests.');
    }
  });

  delimSel.addEventListener('change', () => lastText && parse(lastText));
  headerChk.addEventListener('change', () => lastText && parse(lastText));
  search.addEventListener('input', () => { page = 0; applyView(); });

  $('csva-grid-head').addEventListener('click', (e) => {
    const th = (e.target as HTMLElement).closest('.csva-sort') as HTMLElement | null;
    if (!th) return;
    const col = Number(th.dataset.col);
    if (col === sortCol) sortDir = sortDir === 1 ? -1 : 1;
    else { sortCol = col; sortDir = 1; }
    applyView();
  });

  $('csva-prev').addEventListener('click', () => { if (page > 0) { page--; renderGrid(); } });
  $('csva-next').addEventListener('click', () => { page++; renderGrid(); });
  document.querySelectorAll<HTMLElement>('.csva-exp').forEach((b) =>
    b.addEventListener('click', () => doExport(b.dataset.exp!)));
</script>

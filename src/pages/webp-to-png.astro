---
import ToolLayout from '../layouts/ToolLayout.astro';
import ImageConverter from '../components/ImageConverter.astro';
---

<ToolLayout slug="webp-to-png">
  <ImageConverter to="image/png" accept="image/webp,.webp" ext="png" />

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free WebP to PNG converter turns WebP images into lossless PNG files,
      preserving transparency. PNG is ideal when you need a lossless copy, want to
      edit the image further, or are working with a platform or app that doesn't
      accept WebP. Drop a WebP image, preview the result on a transparency
      checkerboard, and download.
    </p>
  </div>
</ToolLayout>

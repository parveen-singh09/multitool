---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout slug="time-calculator">
  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Mode">
      <button type="button" data-mode="duration" class="tc-tab btn btn-primary" aria-selected="true">Add/subtract durations</button>
      <button type="button" data-mode="clock" class="tc-tab btn btn-secondary" aria-selected="false">Add to a time of day</button>
    </div>

    <div id="tc-duration">
      <div class="panel panel-lift flex flex-col gap-3 p-5">
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Days<input id="t1-d" type="number" min="0" class="field font-mono" value="0" inputmode="numeric" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Hours<input id="t1-h" type="number" min="0" class="field font-mono" value="2" inputmode="numeric" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Minutes<input id="t1-m" type="number" min="0" class="field font-mono" value="45" inputmode="numeric" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Seconds<input id="t1-s" type="number" min="0" class="field font-mono" value="30" inputmode="numeric" /></label>
        </div>
        <div class="flex justify-center">
          <select id="t-op" class="field w-28 text-center"><option value="+">+</option><option value="-">−</option></select>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Days<input id="t2-d" type="number" min="0" class="field font-mono" value="0" inputmode="numeric" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Hours<input id="t2-h" type="number" min="0" class="field font-mono" value="1" inputmode="numeric" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Minutes<input id="t2-m" type="number" min="0" class="field font-mono" value="30" inputmode="numeric" /></label>
          <label class="flex flex-col gap-1 text-sm text-ink-subtle">Seconds<input id="t2-s" type="number" min="0" class="field font-mono" value="45" inputmode="numeric" /></label>
        </div>
      </div>

      <div class="panel panel-lift mt-4 p-6 text-center">
        <div class="copy-wrap">
          <div id="t-out" class="font-display text-3xl font-semibold text-primary-hover">—</div>
          <button type="button" class="copy-icon" data-copy-target="#t-out" aria-label="Copy"></button>
        </div>
        <div id="t-dhms" class="mt-2 text-sm text-ink-muted"></div>
        <div id="t-total" class="mt-1 text-[13px] text-ink-subtle"></div>
      </div>
    </div>

    <div id="tc-clock" class="hidden flex-col gap-4">
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Start time
          <input id="tc-start" type="time" step="1" class="field font-mono" />
        </label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Operation
          <select id="tc-op" class="field"><option value="+">Add</option><option value="-">Subtract</option></select>
        </label>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Hours<input id="tc-h" type="number" min="0" class="field font-mono" value="3" inputmode="numeric" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Minutes<input id="tc-m" type="number" min="0" class="field font-mono" value="40" inputmode="numeric" /></label>
        <label class="flex flex-col gap-1 text-sm text-ink-subtle">Seconds<input id="tc-s" type="number" min="0" class="field font-mono" value="0" inputmode="numeric" /></label>
      </div>
      <div class="panel panel-lift p-6 text-center">
        <div id="tc-out" class="font-display text-3xl font-semibold text-primary-hover">—</div>
        <div id="tc-note" class="mt-2 text-[13px] text-ink-subtle"></div>
      </div>
    </div>
  </div>

  <div slot="about" class="flex flex-col gap-4 text-[15px] leading-relaxed text-ink-subtle">
    <p>
      This free time calculator adds or subtracts durations in days, hours,
      minutes and seconds, showing the result as days:hours:minutes:seconds plus
      totals in hours, minutes and seconds. A second mode adds or subtracts a
      duration from a time of day to tell you the resulting clock time (and whether
      it rolls into the next day).
    </p>
  </div>
</ToolLayout>

<script>
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const secsOf = (d: string, h: string, m: string, s: string) =>
    (Number($(d).value) || 0) * 86400 + (Number($(h).value) || 0) * 3600 + (Number($(m).value) || 0) * 60 + (Number($(s).value) || 0);

  function calcDuration() {
    const op = (document.getElementById('t-op') as HTMLSelectElement).value;
    let total = secsOf('t1-d', 't1-h', 't1-m', 't1-s') + (op === '+' ? 1 : -1) * secsOf('t2-d', 't2-h', 't2-m', 't2-s');
    const neg = total < 0;
    total = Math.abs(total);
    const d = Math.floor(total / 86400);
    const h = Math.floor((total % 86400) / 3600);
    const m = Math.floor((total % 3600) / 60);
    const s = total % 60;
    const sign = neg ? '−' : '';
    document.getElementById('t-out')!.textContent = `${sign}${h + d * 24}h ${m}m ${s}s`;
    document.getElementById('t-dhms')!.textContent = `${sign}${d}d ${h}h ${m}m ${s}s`;
    document.getElementById('t-total')!.textContent =
      `= ${sign}${total.toLocaleString()} s · ${sign}${(total / 60).toFixed(2)} min · ${sign}${(total / 3600).toFixed(2)} h`;
  }

  function calcClock() {
    const start = $('tc-start').value;
    const out = document.getElementById('tc-out')!;
    const note = document.getElementById('tc-note')!;
    if (!start) { out.textContent = '—'; note.textContent = ''; return; }
    const parts = start.split(':').map(Number);
    const startSec = parts[0] * 3600 + parts[1] * 60 + (parts[2] || 0);
    const op = (document.getElementById('tc-op') as HTMLSelectElement).value;
    const delta = (Number($('tc-h').value) || 0) * 3600 + (Number($('tc-m').value) || 0) * 60 + (Number($('tc-s').value) || 0);
    let result = startSec + (op === '+' ? delta : -delta);
    const dayShift = Math.floor(result / 86400);
    result = ((result % 86400) + 86400) % 86400;
    const h = Math.floor(result / 3600);
    const m = Math.floor((result % 3600) / 60);
    const s = result % 60;
    const ampm = h >= 12 ? 'pm' : 'am';
    const h12 = h % 12 === 0 ? 12 : h % 12;
    out.textContent = `${h12}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')} ${ampm}`;
    note.textContent = dayShift === 0 ? 'same day' : dayShift > 0 ? `${dayShift} day(s) later` : `${Math.abs(dayShift)} day(s) earlier`;
  }

  document.querySelectorAll<HTMLButtonElement>('.tc-tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      const mode = tab.dataset.mode;
      document.querySelectorAll('.tc-tab').forEach((t) => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('btn-primary', active);
        t.classList.toggle('btn-secondary', !active);
      });
      document.getElementById('tc-duration')!.classList.toggle('hidden', mode !== 'duration');
      document.getElementById('tc-clock')!.classList.toggle('hidden', mode !== 'clock');
      document.getElementById('tc-clock')!.classList.toggle('flex', mode === 'clock');
    });
  });

  document.querySelectorAll('#t1-d, #t1-h, #t1-m, #t1-s, #t2-d, #t2-h, #t2-m, #t2-s, #t-op').forEach((el) => el.addEventListener('input', calcDuration));
  document.querySelectorAll('#tc-start, #tc-op, #tc-h, #tc-m, #tc-s').forEach((el) => el.addEventListener('input', calcClock));

  // Seed clock start with now.
  const now = new Date();
  $('tc-start').value = `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`;
  calcDuration();
  calcClock();
</script>

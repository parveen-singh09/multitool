---
import type { Tool } from '../data/tools';
import { toolHaystack } from '../lib/toolSearch';
interface Props {
  tool: Tool;
}
const { tool } = Astro.props;

const searchText = toolHaystack(tool);

// ponytail: category-keyed tints keep the palette controlled vs. per-tool random.
// Diverges from DESIGN.md's single-accent rule — requested to match the colorful reference.
const tints: Record<string, { bg: string; ring: string; fg: string }> = {
  Text: { bg: 'bg-sky-500/12', ring: 'ring-sky-500/20', fg: 'text-sky-400' },
  Developer: { bg: 'bg-violet-500/12', ring: 'ring-violet-500/20', fg: 'text-violet-400' },
  Image: { bg: 'bg-emerald-500/12', ring: 'ring-emerald-500/20', fg: 'text-emerald-400' },
  Converters: { bg: 'bg-amber-500/12', ring: 'ring-amber-500/20', fg: 'text-amber-400' },
  Calculators: { bg: 'bg-rose-500/12', ring: 'ring-rose-500/20', fg: 'text-rose-400' },
  Generators: { bg: 'bg-fuchsia-500/12', ring: 'ring-fuchsia-500/20', fg: 'text-fuchsia-400' },
  Security: { bg: 'bg-teal-500/12', ring: 'ring-teal-500/20', fg: 'text-teal-400' },
  PDF: { bg: 'bg-red-500/12', ring: 'ring-red-500/20', fg: 'text-red-400' },
  'Audio & Video': { bg: 'bg-indigo-500/12', ring: 'ring-indigo-500/20', fg: 'text-indigo-400' },
  'Device & Sensors': { bg: 'bg-cyan-500/12', ring: 'ring-cyan-500/20', fg: 'text-cyan-400' },
};
const tint = tints[tool.category] ?? { bg: 'bg-surface-2', ring: 'ring-hairline', fg: 'text-ink-muted' };
---

<a
  href={`/tools/${tool.slug}`}
  data-tool-card
  data-search={searchText}
  data-name={tool.name}
  class="panel panel-lift group flex flex-col gap-3 p-6 transition-colors duration-150 hover:bg-surface-2 hover:border-hairline-strong"
>
  <span class={`flex h-10 w-10 items-center justify-center rounded-lg ring-1 transition-colors ${tint.bg} ${tint.ring} ${tint.fg}`}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d={tool.icon} />
    </svg>
  </span>

  <div class="flex flex-col gap-1">
    <h3 class="font-display text-[17px] font-medium tracking-[-0.01em] text-ink">
      {tool.name}
    </h3>
    <p class="text-sm leading-relaxed text-ink-subtle">{tool.tagline}</p>
  </div>

  <span class="mt-auto inline-flex items-center gap-1 pt-2 text-[13px] font-medium text-ink-tertiary transition-colors group-hover:text-primary-hover">
    Open tool
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </span>
</a>

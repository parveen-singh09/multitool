---
import type { Tool } from '../data/tools';
interface Props {
  tool: Tool;
}
const { tool } = Astro.props;

const searchText = [tool.name, tool.tagline, tool.category, ...tool.keywords]
  .join(' ')
  .toLowerCase();
---

<a
  href={`/tools/${tool.slug}`}
  data-tool-card
  data-search={searchText}
  class="panel panel-lift group flex flex-col gap-3 p-6 transition-colors duration-150 hover:bg-surface-2 hover:border-hairline-strong"
>
  <span class="flex h-10 w-10 items-center justify-center rounded-md border border-hairline bg-surface-2 text-ink-muted transition-colors group-hover:text-primary-hover">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d={tool.icon} />
    </svg>
  </span>

  <div class="flex flex-col gap-1">
    <h3 class="font-display text-[17px] font-medium tracking-[-0.01em] text-ink">
      {tool.name}
    </h3>
    <p class="text-sm leading-relaxed text-ink-subtle">{tool.tagline}</p>
  </div>

  <span class="mt-auto inline-flex items-center gap-1 pt-2 text-[13px] font-medium text-ink-tertiary transition-colors group-hover:text-primary-hover">
    Open tool
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </span>
</a>

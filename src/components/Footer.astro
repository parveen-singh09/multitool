---
import Logo from './Logo.astro';
import { tools, categories, toolsByCategory } from '../data/tools';
import { SITE } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-hairline bg-canvas">
  <div class="container-page py-16">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-6">
      <!-- Brand column -->
      <div class="col-span-2">
        <Logo />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-ink-subtle">
          {SITE.tagline}. No sign-up, no uploads — every tool runs privately in your browser.
        </p>
      </div>

      <!-- Category columns -->
      {categories.map((category) => (
        <nav class="flex flex-col gap-2" aria-label={category}>
          <span class="eyebrow text-ink-tertiary">{category}</span>
          {toolsByCategory(category).map((tool) => (
            <a
              href={`/tools/${tool.slug}`}
              class="text-sm text-ink-subtle transition-colors hover:text-ink"
            >
              {tool.name}
            </a>
          ))}
        </nav>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-hairline pt-6 text-sm text-ink-tertiary sm:flex-row sm:items-center">
      <p>© {year} {SITE.name}. All tools are free and run client-side.</p>
      <div class="flex items-center gap-4">
        <a href="/about" class="transition-colors hover:text-ink">About</a>
        <a href="/privacy" class="transition-colors hover:text-ink">Privacy</a>
        <a href="/#tools" class="transition-colors hover:text-ink">{tools.length} tools</a>
      </div>
    </div>
  </div>
</footer>

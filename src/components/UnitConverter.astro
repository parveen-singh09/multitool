---
// Reusable single-category unit converter. Drives all 13 unit-converter
// pages from the shared UNIT_CATEGORIES data. The client script reads the
// active slug from #uc-root[data-slug] and builds the right unit list.
import { getCategory } from '../lib/units';

export interface Props {
  slug: string;
}
const { slug } = Astro.props;
const cat = getCategory(slug);
if (!cat) throw new Error(`Unknown unit category: ${slug}`);
---

<div id="uc-root" data-slug={slug} class="flex flex-col gap-4">
  <div class="grid grid-cols-1 items-end gap-3 sm:grid-cols-[1fr_auto_1fr]">
    <div class="flex flex-col gap-1">
      <label class="text-sm text-ink-subtle" for="uc-from-val">From</label>
      <input id="uc-from-val" type="number" class="field" value="1" inputmode="decimal" />
      <select id="uc-from-unit" class="field mt-1"></select>
    </div>
    <button
      id="uc-swap"
      type="button"
      class="btn btn-secondary mb-1 h-10 w-10 shrink-0 justify-self-center p-0"
      aria-label="Swap units"
      title="Swap units"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3 4 7l4 4M4 7h16M16 21l4-4-4-4M20 17H4"/></svg>
    </button>
    <div class="flex flex-col gap-1">
      <label class="text-sm text-ink-subtle" for="uc-to-val">To</label>
      <input id="uc-to-val" type="number" class="field" readonly />
      <select id="uc-to-unit" class="field mt-1"></select>
    </div>
  </div>

  <p id="uc-formula" class="text-[13px] text-ink-tertiary"></p>

  <div>
    <p class="mb-2 text-[13px] text-ink-subtle">Common conversions</p>
    <div id="uc-table" class="overflow-hidden rounded-md border border-hairline"></div>
  </div>
</div>

<script>
  import {
    getCategory, tempTo, tempFrom, TEMP_UNITS,
    FUEL_UNITS, fuelToKmPerL, fuelFromKmPerL,
  } from '../lib/units';

  const root = document.getElementById('uc-root') as HTMLElement;
  const slug = root.dataset.slug!;
  const cat = getCategory(slug)!;

  const fromVal = document.getElementById('uc-from-val') as HTMLInputElement;
  const toVal = document.getElementById('uc-to-val') as HTMLInputElement;
  const fromUnit = document.getElementById('uc-from-unit') as HTMLSelectElement;
  const toUnit = document.getElementById('uc-to-unit') as HTMLSelectElement;
  const swap = document.getElementById('uc-swap') as HTMLButtonElement;
  const formula = document.getElementById('uc-formula') as HTMLElement;
  const table = document.getElementById('uc-table') as HTMLElement;

  const unitNames: string[] =
    cat.special === 'temp' ? TEMP_UNITS
    : cat.special === 'fuel' ? FUEL_UNITS
    : Object.keys(cat.units!);

  // round to a sensible number of significant figures without trailing noise
  function fmt(n: number): string {
    if (!isFinite(n)) return '∞';
    if (n === 0) return '0';
    const abs = Math.abs(n);
    let out: string;
    if (abs >= 1e15 || abs < 1e-6) out = n.toExponential(6);
    else out = String(Math.round(n * 1e9) / 1e9);
    return out;
  }

  function toBase(value: number, unit: string): number {
    if (cat.special === 'temp') return tempFrom(value, unit);
    if (cat.special === 'fuel') return fuelToKmPerL(value, unit);
    return value * cat.units![unit];
  }
  function fromBase(base: number, unit: string): number {
    if (cat.special === 'temp') return tempTo(base, unit);
    if (cat.special === 'fuel') return fuelFromKmPerL(base, unit);
    return base / cat.units![unit];
  }
  function directConvert(value: number, from: string, to: string): number {
    return fromBase(toBase(value, from), to);
  }

  function fillUnits() {
    for (const sel of [fromUnit, toUnit]) {
      sel.innerHTML = unitNames.map((u) => `<option>${u}</option>`).join('');
    }
    fromUnit.value = cat.from && unitNames.includes(cat.from) ? cat.from : unitNames[0];
    toUnit.value = cat.to && unitNames.includes(cat.to) ? cat.to : unitNames[Math.min(1, unitNames.length - 1)];
  }

  function convert() {
    const v = Number(fromVal.value);
    if (fromVal.value.trim() === '' || isNaN(v)) { toVal.value = ''; formula.textContent = ''; renderTable(NaN); return; }
    const result = directConvert(v, fromUnit.value, toUnit.value);
    toVal.value = fmt(result);
    formula.textContent = `${fmt(v)} ${fromUnit.value} = ${fmt(result)} ${toUnit.value}`;
    renderTable(v);
  }

  // Reference table: 1 of the "from" unit expressed in every other unit.
  function renderTable(_v: number) {
    const rows = unitNames
      .filter((u) => u !== fromUnit.value)
      .slice(0, 8)
      .map((u) => {
        const r = directConvert(1, fromUnit.value, u);
        return `<tr class="border-t border-hairline">
          <td class="px-3 py-2 text-ink-subtle">1 ${fromUnit.value}</td>
          <td class="px-3 py-2 text-right font-mono text-ink">${fmt(r)} <span class="text-ink-tertiary">${u}</span></td>
        </tr>`;
      })
      .join('');
    table.innerHTML = `<table class="w-full text-[13px]">${rows}</table>`;
  }

  fromVal.addEventListener('input', convert);
  fromUnit.addEventListener('change', convert);
  toUnit.addEventListener('change', convert);
  swap.addEventListener('click', () => {
    const a = fromUnit.value;
    fromUnit.value = toUnit.value;
    toUnit.value = a;
    if (toVal.value !== '') fromVal.value = toVal.value;
    convert();
  });

  fillUnits();
  convert();
</script>

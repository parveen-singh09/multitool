---
// ToolCities brand mark: a stacked-blocks "city" glyph in lavender accent
// (the one place accent is allowed to be decorative) + wordmark.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a href="/" class={`inline-flex items-center gap-2 no-underline ${className}`} aria-label="ToolCities home">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <rect x="3" y="10" width="5" height="11" rx="1.2" fill="#5e6ad2" />
    <rect x="9.5" y="5" width="5" height="16" rx="1.2" fill="#828fff" />
    <rect x="16" y="13" width="5" height="8" rx="1.2" fill="#5e6ad2" />
  </svg>
  <span class="font-display font-semibold text-[15px] tracking-[-0.01em] text-ink">
    Tool<span class="text-ink-subtle">Cities</span>
  </span>
</a>

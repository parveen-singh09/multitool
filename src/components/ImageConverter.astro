---
export interface Props {

  to: string;

  accept?: string;

  ext: string;

  quality?: boolean;

  flatten?: boolean;
}
const { to, accept = 'image/*', ext, quality = false, flatten = false } = Astro.props;
---

<div id="im-root" data-to={to} data-ext={ext} data-quality={String(quality)} data-flatten={String(flatten)} class="flex flex-col gap-4">
  <label id="im-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
    <span class="text-sm text-ink">Choose images or drop them here</span>
    <input id="im-file" type="file" accept={accept} multiple class="sr-only" />
  </label>

  <div id="im-panel" class="hidden flex-col gap-4">
    {quality && (
      <label class="flex flex-col gap-1 text-sm text-ink-subtle">
        Quality: <span id="im-qval" class="text-ink">90%</span>
        <input id="im-q" type="range" min="10" max="100" value="90" class="w-full accent-primary" />
      </label>
    )}
    <div class="flex flex-wrap items-center gap-3">
      <button id="im-download" class="btn btn-primary">Download</button>
      <span id="im-info" class="text-[13px] text-ink-subtle"></span>
    </div>
    <div class="panel flex justify-center overflow-hidden p-4" style="background-image:linear-gradient(45deg,#2a2a2e 25%,transparent 25%),linear-gradient(-45deg,#2a2a2e 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#2a2a2e 75%),linear-gradient(-45deg,transparent 75%,#2a2a2e 75%);background-size:16px 16px;background-position:0 0,0 8px,8px -8px,-8px 0">
      <img id="im-preview" class="max-h-96 w-auto max-w-full rounded-md" alt="Converted preview" />
    </div>
  </div>
  <p id="im-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
</div>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  const root = document.getElementById('im-root') as HTMLElement;
  const to = root.dataset.to!;
  const ext = root.dataset.ext!;
  const useQuality = root.dataset.quality === 'true';
  const flatten = root.dataset.flatten === 'true';

  const fileInput = document.getElementById('im-file') as HTMLInputElement;
  const drop = document.getElementById('im-drop')!;
  const panel = document.getElementById('im-panel')!;
  const preview = document.getElementById('im-preview') as HTMLImageElement;
  const info = document.getElementById('im-info')!;
  const err = document.getElementById('im-error')!;
  const q = document.getElementById('im-q') as HTMLInputElement | null;
  const qval = document.getElementById('im-qval');

  let img = new Image();
  let blob: Blob | null = null;
  let originalSize = 0;
  const fmtSize = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n / 1024).toFixed(1)} KB` : `${(n / 1048576).toFixed(2)} MB`;

  function setErr(m: string) { err.textContent = m; err.classList.toggle('hidden', !m); }

  function loadFile(file: File) {
    setErr('');
    originalSize = file.size;
    const reader = new FileReader();
    reader.onload = () => {
      img = new Image();
      img.onload = () => { panel.classList.remove('hidden'); panel.classList.add('flex'); convert(); };
      img.onerror = () => setErr('Could not read that image file.');
      img.src = reader.result as string;
    };
    reader.onerror = () => setErr('Could not read that file.');
    reader.readAsDataURL(file);
  }

  function convert() {
    const canvas = document.createElement('canvas');
    let w = img.naturalWidth || 512, h = img.naturalHeight || 512;
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d')!;
    if (flatten) { ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, w, h); }
    ctx.drawImage(img, 0, 0, w, h);
    const quality = useQuality && q ? Number(q.value) / 100 : undefined;
    canvas.toBlob((b) => {
      if (!b) { setErr('Your browser could not encode this format.'); return; }
      blob = b;
      preview.src = URL.createObjectURL(b);
      info.textContent = `${w}×${h} · ${fmtSize(originalSize)} → ${fmtSize(b.size)}`;
    }, to, quality);
  }

  // Convert one file to an encoded blob off-screen (no shared state) — used by the multi path.
  function convertOne(file: File): Promise<Blob> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const im = new Image();
        im.onload = () => {
          const canvas = document.createElement('canvas');
          const w = im.naturalWidth || 512, h = im.naturalHeight || 512;
          canvas.width = w; canvas.height = h;
          const ctx = canvas.getContext('2d')!;
          if (flatten) { ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, w, h); }
          ctx.drawImage(im, 0, 0, w, h);
          const quality = useQuality && q ? Number(q.value) / 100 : undefined;
          canvas.toBlob((b) => b ? resolve(b) : reject(new Error(`Could not encode "${file.name}".`)), to, quality);
        };
        im.onerror = () => reject(new Error(`Could not read "${file.name}".`));
        im.src = reader.result as string;
      };
      reader.onerror = () => reject(new Error(`Could not read "${file.name}".`));
      reader.readAsDataURL(file);
    });
  }

  let multiUrl: string | null = null;
  async function loadMany(files: File[]) {
    setErr('');
    panel.classList.remove('flex'); panel.classList.add('hidden'); // hide single-image preview UI
    blob = null;
    const dl = document.getElementById('im-download') as HTMLAnchorElement;
    info.classList.remove('hidden');
    try {
      const { makeZip } = await import('../lib/zip');
      const seen = new Set<string>();
      const entries = [];
      for (let i = 0; i < files.length; i++) {
        info.textContent = `Converting ${i + 1}/${files.length}…`;
        const b = await convertOne(files[i]);
        let name = (files[i].name.replace(/\.[^.]+$/, '') || `image-${i + 1}`) + '.' + ext;
        while (seen.has(name)) name = name.replace(/(\.[^.]+)$/, `-${i}$1`);
        seen.add(name);
        entries.push({ name, data: new Uint8Array(await b.arrayBuffer()) });
      }
      if (multiUrl) URL.revokeObjectURL(multiUrl);
      multiUrl = URL.createObjectURL(makeZip(entries));
      panel.classList.remove('hidden'); panel.classList.add('flex');
      preview.classList.add('hidden');
      dl.textContent = `Download ${entries.length} files (ZIP)`;
      dl.dataset.multi = multiUrl;
      info.textContent = `${entries.length} images · ZIP`;
    } catch (e) {
      setErr((e as Error).message);
    }
  }

  function dispatch(files: File[]) {
    if (files.length > 1) loadMany(files);
    else {
      preview.classList.remove('hidden');
      const dl = document.getElementById('im-download') as HTMLAnchorElement;
      delete dl.dataset.multi; dl.textContent = 'Download';
      loadFile(files[0]);
    }
  }

  q?.addEventListener('input', () => { if (qval) qval.textContent = q.value + '%'; convert(); });
  fileInput.addEventListener('change', () => { if (fileInput.files?.length) dispatch(Array.from(fileInput.files)); });
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const fs = (ev as DragEvent).dataTransfer?.files; if (fs?.length) dispatch(Array.from(fs)); });

  document.getElementById('im-download')!.addEventListener('click', (e) => {
    const dl = e.currentTarget as HTMLAnchorElement;
    const url = dl.dataset.multi || (blob && URL.createObjectURL(blob));
    if (!url) return;
    const a = document.createElement('a');
    a.download = dl.dataset.multi ? `converted-${ext}.zip` : `converted.${ext}`;
    a.href = url;
    a.click();
  });
</script>

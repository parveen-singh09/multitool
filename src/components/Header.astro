---
import Logo from './Logo.astro';
import { categories } from '../data/tools';
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/85 backdrop-blur-md">
  <nav class="container-page flex h-14 items-center justify-between gap-4">
    <Logo />

    <!-- Desktop nav -->
    <div class="hidden items-center gap-1 lg:flex">
      <a href="/" class="btn btn-tertiary">Home</a>
      <a href="/#tools" class="btn btn-tertiary">All Tools</a>
      <a href="/about" class="btn btn-tertiary">About</a>
    </div>

    <div class="hidden items-center gap-2 md:flex">
      <button
        type="button"
        class="theme-toggle btn btn-secondary"
        aria-label="Toggle color theme"
        title="Toggle light / dark theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4" />
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
        </svg>
      </button>
      <a href="/#tools" class="btn btn-primary">Browse tools</a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      class="btn btn-secondary md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div id="mobile-nav" class="hidden border-t border-hairline bg-canvas md:hidden">
    <div class="container-page flex flex-col gap-1 py-3">
      <a href="/" class="btn btn-tertiary justify-start">Home</a>
      <a href="/#tools" class="btn btn-tertiary justify-start">All Tools</a>
      <a href="/about" class="btn btn-tertiary justify-start">About</a>
      <span class="eyebrow px-3 pt-3 text-ink-tertiary">Categories</span>
      {categories.map((c) => (
        <a href={`/#${c.toLowerCase()}`} class="btn btn-tertiary justify-start">{c}</a>
      ))}
      <button
        type="button"
        class="theme-toggle btn btn-secondary mt-2 justify-start"
        aria-label="Toggle color theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4" />
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
        </svg>
        <span>Light / dark</span>
      </button>
    </div>
  </div>
</header>

<style>
  /* Show the icon for the theme you'd switch TO: sun in dark, moon in light. */
  .theme-toggle .icon-moon { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-sun { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-moon { display: inline; }
</style>

<script>
  // Mobile nav drawer
  const navToggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  navToggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    navToggle.setAttribute('aria-expanded', String(open));
  });

  // Theme toggle — flip data-theme, persist, and update theme-color meta.
  const root = document.documentElement;
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const applyMeta = (theme: string) =>
    themeMeta?.setAttribute('content', theme === 'light' ? '#ffffff' : '#010102');

  applyMeta(root.dataset.theme || 'dark');

  document.querySelectorAll('.theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = root.dataset.theme === 'light' ? 'dark' : 'light';
      root.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (_) {}
      applyMeta(next);
    });
  });
</script>

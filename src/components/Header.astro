---
import Logo from './Logo.astro';
import ToolSearch from './ToolSearch.astro';
import { categories, toolsByCategory } from '../data/tools';

interface Props {
  landing?: boolean;
}
const { landing = false } = Astro.props;

const catSlug = (c: string) => c.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const CAT_BLURB: Record<string, string> = {
  Text: 'Count, convert, compare and transform text.',
  Developer: 'Format, encode, validate and generate code.',
  Image: 'Edit, resize, compress and convert images.',
  PDF: 'Merge, split, convert and extract from PDFs.',
  'Audio & Video': 'Convert, compress and extract media.',
  Converters: 'Convert between hundreds of file formats.',
  Calculators: 'Crunch numbers for finance, health and math.',
  Generators: 'Create passwords, QR codes, data and more.',
  Security: 'Hashes, keys, passwords and validation.',
  'Device & Sensors': 'Test your device, input and connection.',
};
const CAT_FG: Record<string, string> = {
  Text: 'text-sky-400',
  Developer: 'text-violet-400',
  Image: 'text-emerald-400',
  Converters: 'text-amber-400',
  Calculators: 'text-rose-400',
  Generators: 'text-fuchsia-400',
  Security: 'text-teal-400',
  PDF: 'text-red-400',
  'Audio & Video': 'text-indigo-400',
  'Device & Sensors': 'text-cyan-400',
};
const CAT_MENU = categories.map((c) => {
  const all = toolsByCategory(c);
  return {
    name: c,
    slug: catSlug(c),
    count: all.length,
    blurb: CAT_BLURB[c] ?? '',
    fg: CAT_FG[c] ?? 'text-ink-tertiary',
    featured: all.slice(0, 4),
    tools: all,
  };
});
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/85 backdrop-blur-md">
  <nav class="container-page flex h-14 items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      {landing ? (
        <a href="/" class="inline-flex items-center gap-2 no-underline" aria-label="ToolSilk home">
          <img src="/favicon.svg" width="24" height="24" alt="" aria-hidden="true" class="rounded-[5px]" />
          <span class="font-display font-semibold text-[15px] tracking-[-0.01em] text-ink">
            Tool<span class="text-ink-subtle">Silk</span>
          </span>
        </a>
      ) : (
        <>
          <button
            id="sidebar-toggle-btn"
            class="btn btn-tertiary p-2 cursor-pointer"
            aria-label="Toggle sidebar"
            title="Toggle sidebar"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
          </button>
          <Logo />
        </>
      )}
    </div>

    <div class="hidden items-center gap-1 lg:flex">
      <a href="/about" class="btn btn-tertiary">About</a>
      <a href="/feedback" class="btn btn-tertiary">Feedback</a>
      <a href="/contact" class="btn btn-tertiary">Contact Us</a>

      <div class="nav-tools">
        <a href="/tools" class="btn btn-tertiary inline-flex items-center gap-1">
          Tools
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </a>

        
        <div class="nav-mega">
          <div class="container-page pt-0 pb-5">
            <div class="nav-mega-card flex gap-6 rounded-xl border border-hairline bg-surface-2 shadow-2xl">
              
              <div class="w-44 flex-none border-r border-hairline p-2">
                {CAT_MENU.map((cat, i) => (
                  <button type="button" class="nav-rail flex w-full items-center justify-between gap-2 rounded-lg px-3 py-2 text-left text-sm text-ink-subtle hover:bg-surface-3 hover:text-ink" data-cat={i} aria-controls={`mega-${i}`}>
                    <span>{cat.name}</span>
                  </button>
                ))}
              </div>

              
              <div class="min-w-0 flex-1 p-4 pr-5">
                {CAT_MENU.map((cat, i) => (
                  <div class="nav-panel h-80 overflow-y-auto" id={`mega-${i}`} data-panel={i} hidden={i !== 0}>
                    <div class="grid grid-cols-2 gap-x-5 gap-y-0.5 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
                      {cat.tools.map((tool) => (
                        <a href={`/${tool.slug}`} class="flex items-center gap-2 truncate rounded-md px-2 py-1.5 text-[13px] text-ink-subtle hover:bg-surface-3 hover:text-ink">
                          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={`flex-none ${cat.fg}`}><path d={tool.icon}/></svg>
                          <span class="truncate">{tool.name}</span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-6">
      <button
        type="button"
        class="bg-toggle btn btn-tertiary"
        aria-label="Toggle background image"
        title="Toggle background image"
        aria-pressed="false"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <path d="m21 15-5-5L5 21" />
        </svg>
      </button>
      <button
        type="button"
        class="theme-toggle btn btn-tertiary"
        aria-label="Toggle color theme"
        title="Toggle light / dark theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4" />
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
        </svg>
      </button>
      <div class="hidden md:block">
        <ToolSearch variant="compact" id="tool-search-header" />
      </div>
    </div>
  </nav>

</header>

<style>

  .theme-toggle, .bg-toggle, #sidebar-toggle-btn {
    padding: 0;
    min-height: 0;
    border: 0;
    background: transparent;
  }
  .theme-toggle:hover, .bg-toggle:hover, #sidebar-toggle-btn:hover { background: transparent; color: var(--color-ink-muted); }
  #sidebar-toggle-btn:focus-visible { outline: none; }
  .bg-toggle[aria-pressed='true'] { color: var(--color-primary); }
  .theme-toggle .icon-moon { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-sun { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-moon { display: inline; }

  
  .nav-tools { position: static; }
  .nav-mega {
    display: none;
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    z-index: 60;
  }
  .nav-mega.open { display: block; }
  .nav-rail[aria-current="true"] {
    background: var(--color-surface-3, #18191a);
    color: var(--color-ink, #f7f8f8);
  }
</style>

<script>

  const dispatchToggle = () => {
    window.dispatchEvent(new CustomEvent('toggle-sidebar'));
  };

  document.getElementById('sidebar-toggle-btn')?.addEventListener('click', dispatchToggle);
  document.getElementById('nav-toggle')?.addEventListener('click', dispatchToggle);

  const rails = document.querySelectorAll<HTMLElement>('.nav-rail');
  const panels = document.querySelectorAll<HTMLElement>('.nav-panel');
  const showPanel = (idx: string) => {
    rails.forEach((r) => r.setAttribute('aria-current', String(r.dataset.cat === idx)));
    panels.forEach((p) => { p.hidden = p.dataset.panel !== idx; });
  };
  rails.forEach((r) => {
    r.addEventListener('mouseenter', () => showPanel(r.dataset.cat!));
    r.addEventListener('focus', () => showPanel(r.dataset.cat!));
  });
  if (rails[0]) rails[0].setAttribute('aria-current', 'true');

  const navTools = document.querySelector<HTMLElement>('.nav-tools');
  const mega = document.querySelector<HTMLElement>('.nav-mega');
  const megaCard = document.querySelector<HTMLElement>('.nav-mega-card');
  if (navTools && mega && megaCard) {
    let closeTimer: ReturnType<typeof setTimeout> | null = null;
    const open = () => { if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; } mega.classList.add('open'); };
    const scheduleClose = () => { if (closeTimer) clearTimeout(closeTimer); closeTimer = setTimeout(() => mega.classList.remove('open'), 220); };
    [navTools, megaCard].forEach((el) => {
      el.addEventListener('mouseenter', open);
      el.addEventListener('mouseleave', scheduleClose);
    });
    navTools.addEventListener('focusin', open);
    navTools.addEventListener('focusout', scheduleClose);
  }

  const root = document.documentElement;
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const applyMeta = (theme: string) =>
    themeMeta?.setAttribute('content', theme === 'light' ? '#ffffff' : '#010102');

  applyMeta(root.dataset.theme || 'dark');

  const setBg = (on: boolean) => {
    if (on) root.dataset.bg = 'image';
    else delete root.dataset.bg;
    try {
      localStorage.setItem('bgImage', on ? 'on' : 'off');
    } catch (_) {}
    document
      .querySelectorAll('.bg-toggle')
      .forEach((b) => b.setAttribute('aria-pressed', String(on)));
  };

  const setTheme = (theme: string) => {
    root.dataset.theme = theme;
    try {
      localStorage.setItem('theme', theme);
    } catch (_) {}
    applyMeta(theme);
  };

  if (root.dataset.bg === 'image') setBg(true);

  document.querySelectorAll('.bg-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      setBg(root.dataset.bg !== 'image');
    });
  });

  document.querySelectorAll('.theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      setTheme(root.dataset.theme === 'light' ? 'dark' : 'light');
    });
  });
</script>

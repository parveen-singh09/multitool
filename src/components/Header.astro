---
import Logo from './Logo.astro';
import ToolSearch from './ToolSearch.astro';
import { categories } from '../data/tools';

interface Props {
  // landing = text-only wordmark, no hamburger, no search (used by the landing page)
  landing?: boolean;
}
const { landing = false } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/85 backdrop-blur-md">
  <nav class="container-page flex h-14 items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      {landing ? (
        <a href="/" class="inline-flex items-center gap-2 no-underline" aria-label="ToolSilk home">
          <img src="/favicon.svg" width="24" height="24" alt="" aria-hidden="true" class="rounded-[5px]" />
          <span class="font-display font-semibold text-[15px] tracking-[-0.01em] text-ink">
            Tool<span class="text-ink-subtle">Silk</span>
          </span>
        </a>
      ) : (
        <>
          <button
            id="sidebar-toggle-btn"
            class="btn btn-tertiary p-2 cursor-pointer"
            aria-label="Toggle sidebar"
            title="Toggle sidebar"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
          </button>
          <Logo />
        </>
      )}
    </div>

    <div class="hidden items-center gap-1 lg:flex">
      <a href="/about" class="btn btn-tertiary">About</a>
      <a href="/feedback" class="btn btn-tertiary">Feedback</a>
      <a href="/contact" class="btn btn-tertiary">Contact Us</a>
      <a href="/privacy" class="btn btn-tertiary">Privacy</a>
    </div>

    <div class="flex items-center gap-6">
      <button
        type="button"
        class="bg-toggle btn btn-tertiary"
        aria-label="Toggle background image"
        title="Toggle background image"
        aria-pressed="false"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <path d="m21 15-5-5L5 21" />
        </svg>
      </button>
      <button
        type="button"
        class="theme-toggle btn btn-tertiary"
        aria-label="Toggle color theme"
        title="Toggle light / dark theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M6.3 17.7l-1.4 1.4M19.1 4.9l-1.4 1.4" />
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
        </svg>
      </button>
      <div class="hidden md:block">
        <ToolSearch variant="compact" id="tool-search-header" />
      </div>
    </div>
  </nav>

</header>

<style>

  .theme-toggle, .bg-toggle {
    padding: 0;
    min-height: 0;
    border: 0;
    background: transparent;
  }
  .theme-toggle:hover, .bg-toggle:hover { background: transparent; color: var(--color-ink-muted); }
  .bg-toggle[aria-pressed='true'] { color: var(--color-primary); }
  .theme-toggle .icon-moon { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-sun { display: none; }
  :global(html[data-theme='light']) .theme-toggle .icon-moon { display: inline; }
</style>

<script>

  const dispatchToggle = () => {
    window.dispatchEvent(new CustomEvent('toggle-sidebar'));
  };

  document.getElementById('sidebar-toggle-btn')?.addEventListener('click', dispatchToggle);
  document.getElementById('nav-toggle')?.addEventListener('click', dispatchToggle);

  const root = document.documentElement;
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const applyMeta = (theme: string) =>
    themeMeta?.setAttribute('content', theme === 'light' ? '#ffffff' : '#010102');

  applyMeta(root.dataset.theme || 'dark');

  const setBg = (on: boolean) => {
    if (on) root.dataset.bg = 'image';
    else delete root.dataset.bg;
    try {
      localStorage.setItem('bgImage', on ? 'on' : 'off');
    } catch (_) {}
    document
      .querySelectorAll('.bg-toggle')
      .forEach((b) => b.setAttribute('aria-pressed', String(on)));
  };

  const setTheme = (theme: string) => {
    root.dataset.theme = theme;
    try {
      localStorage.setItem('theme', theme);
    } catch (_) {}
    applyMeta(theme);
  };

  if (root.dataset.bg === 'image') setBg(true); // sync button states on load

  document.querySelectorAll('.bg-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      setBg(root.dataset.bg !== 'image');
    });
  });

  document.querySelectorAll('.theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      setTheme(root.dataset.theme === 'light' ? 'dark' : 'light');
    });
  });
</script>

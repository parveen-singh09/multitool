---
export interface Props { slug: string; from?: string; to?: string; }
const { from, to } = Astro.props;
const TARGETS: Record<string, { label: string; ext: string }> = {
  mp3:  { label: 'MP3',  ext: 'mp3' },
  wav:  { label: 'WAV',  ext: 'wav' },
  flac: { label: 'FLAC', ext: 'flac' },
  aac:  { label: 'AAC (M4A)', ext: 'm4a' },
  ogg:  { label: 'OGG',  ext: 'ogg' },
  opus: { label: 'Opus', ext: 'opus' },
  aiff: { label: 'AIFF', ext: 'aiff' },
  ac3:  { label: 'AC3',  ext: 'ac3' },
};
const accept = from ? `.${from},audio/*` : 'audio/*';
---

<div id="au-root" class="flex flex-col gap-4" data-to={to ?? ''}>
  <label id="au-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M9 18V5l12-2v13M9 13l12-2M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM18 19a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/></svg>
    <span class="text-sm text-ink">{from ? `Choose .${from} files or drop them here` : 'Choose audio files or drop them here'}</span>
    <input id="au-file" type="file" accept={accept} multiple class="sr-only" />
  </label>

  <div class="flex flex-wrap items-center gap-3">
    {!to && (
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        Convert to
        <select id="au-target" class="field w-auto">
          {Object.entries(TARGETS).map(([k, v]) => <option value={k}>{v.label}</option>)}
        </select>
      </label>
    )}
    <button id="au-run" class="btn btn-primary" disabled>Convert</button>
    <button id="au-zip" class="btn btn-secondary hidden">Download all as ZIP</button>
    <span id="au-status" class="text-[13px] text-ink-subtle" aria-live="polite"></span>
  </div>

  <div id="au-files" class="flex flex-col gap-2"></div>

  <p class="text-[13px] text-ink-tertiary">Everything runs in your browser — your audio is never uploaded to a server.</p>
  <p id="au-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
</div>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import { getFFmpeg, fetchFile } from '../lib/ffmpeg';
  import { buildArgs, defaultQuality, type ConvertOptions, type OutFamily, type MediaConversion } from '../lib/media';
  import { makeZip } from '../lib/zip';

  const TARGETS: Record<string, { ext: string; mime: string }> = {
    mp3:  { ext: 'mp3',  mime: 'audio/mpeg' },
    wav:  { ext: 'wav',  mime: 'audio/wav' },
    flac: { ext: 'flac', mime: 'audio/flac' },
    aac:  { ext: 'm4a',  mime: 'audio/mp4' },
    ogg:  { ext: 'ogg',  mime: 'audio/ogg' },
    opus: { ext: 'opus', mime: 'audio/opus' },
    aiff: { ext: 'aiff', mime: 'audio/aiff' },
    ac3:  { ext: 'ac3',  mime: 'audio/ac3' },
  };

  const root = document.getElementById('au-root') as HTMLElement;
  const presetTo = root.dataset.to || '';
  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('au-file') as HTMLInputElement;
  const drop = $('au-drop');
  const target = document.getElementById('au-target') as HTMLSelectElement | null;
  const runBtn = $('au-run') as HTMLButtonElement;
  const zipBtn = $('au-zip') as HTMLButtonElement;
  const status = $('au-status');
  const filesEl = $('au-files');
  const err = $('au-error');

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const fmt = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n/1024).toFixed(1)} KB` : `${(n/1048576).toFixed(2)} MB`;

  interface Job { file: File; row: HTMLElement; statusEl: HTMLElement; data?: Uint8Array; outName?: string; done: boolean; }
  let jobs: Job[] = [];

  function addFiles(list: FileList | File[]) {
    setErr('');
    for (const file of Array.from(list)) {
      const row = document.createElement('div');
      row.className = 'panel flex flex-wrap items-center gap-2 p-3';
      const name = document.createElement('span');
      name.className = 'text-[13px] text-ink truncate';
      name.textContent = `${file.name} · ${fmt(file.size)}`;
      const statusEl = document.createElement('span');
      statusEl.className = 'text-xs text-ink-tertiary ml-auto';
      row.append(name, statusEl);
      filesEl.appendChild(row);
      jobs.push({ file, row, statusEl, done: false });
    }
    runBtn.disabled = jobs.length === 0;
  }

  async function convertAll() {
    const target_ = presetTo || target?.value || 'mp3';
    const t = TARGETS[target_];
    const pending = jobs.filter((j) => !j.done);
    if (!pending.length) return;
    setErr(''); runBtn.disabled = true;
    const conv = { out: target_ as OutFamily, kind: 'audio', ext: t.ext } as MediaConversion;
    const opts: ConvertOptions = { quality: defaultQuality(target_ as OutFamily) };
    try {
      const ff = await getFFmpeg({ onDownload: (n) => { if (n) status.textContent = n; } });
      for (const job of pending) {
        job.statusEl.textContent = 'Converting…';
        const inName = 'in_' + Math.random().toString(36).slice(2) + '.' + (job.file.name.split('.').pop() || 'dat');
        const outName = 'out.' + t.ext;
        await ff.writeFile(inName, await fetchFile(job.file));
        await ff.exec(buildArgs(conv, opts, inName, outName));
        const data = (await ff.readFile(outName)) as Uint8Array;
        try { await ff.deleteFile(inName); await ff.deleteFile(outName); } catch {}
        job.data = data;
        job.outName = job.file.name.replace(/\.[^.]+$/, '') + '.' + t.ext;
        job.done = true;
        job.statusEl.textContent = fmt(data.length);
        job.statusEl.style.color = 'var(--color-success)';
        const dl = document.createElement('button');
        dl.className = 'btn btn-secondary'; dl.style.minHeight = '28px'; dl.style.padding = '2px 10px'; dl.style.fontSize = '12px';
        dl.textContent = 'Download';
        dl.addEventListener('click', () => {
          const url = URL.createObjectURL(new Blob([data as BlobPart], { type: t.mime }));
          const a = document.createElement('a'); a.href = url; a.download = job.outName!; a.click();
          setTimeout(() => URL.revokeObjectURL(url), 2000);
        });
        job.row.appendChild(dl);
      }
      status.textContent = 'Done.';
      zipBtn.classList.toggle('hidden', jobs.filter((j) => j.done).length < 2);
    } catch (e) {
      setErr('Conversion failed: ' + (e as Error).message);
      status.textContent = '';
    } finally { runBtn.disabled = false; }
  }

  zipBtn.addEventListener('click', () => {
    const done = jobs.filter((j) => j.done && j.data);
    if (!done.length) return;
    const url = URL.createObjectURL(makeZip(done.map((j) => ({ name: j.outName!, data: j.data! }))));
    const a = document.createElement('a'); a.href = url; a.download = 'audio-output.zip'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 2000);
  });

  fileInput.addEventListener('change', () => fileInput.files && addFiles(fileInput.files));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files; if (f?.length) addFiles(f); });
  runBtn.addEventListener('click', convertAll);
</script>

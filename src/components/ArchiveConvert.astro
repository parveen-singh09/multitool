---
export interface Props {
  slug: string;
  from?: string;
  to?: string;
  targets?: string[];
  noun?: string;
  smart?: boolean;
  syncTarget?: boolean;
}
const ARCHIVE_TARGETS = [
  'zip', '7z', 'tar',
  'tar.gz', 'tgz', 'tar.bz2', 'tbz2', 'tbz', 'tar.xz', 'txz',
  'tar.7z', 'tar.z', 'tz', 'tar.lzo', 'tzo',
  'gz', 'bz2', 'xz', 'z', 'lzo', 'rz',
];
const { from, to, targets = ARCHIVE_TARGETS, noun = 'archive', smart = false, syncTarget = false } = Astro.props;
const TARGETS = targets;
const accept = from ? `.${from}` : '';
---

<div id="ac-root" class="flex flex-col gap-4" data-from={from ?? ''} data-to={to ?? ''} data-smart={String(smart)} data-sync={String(syncTarget)}>
  <div id="ac-drop" class="ac-drop flex cursor-pointer flex-col items-center justify-center gap-3 rounded-2xl border border-hairline bg-surface-1 px-6 py-11 text-center transition-colors hover:border-hairline-strong hover:bg-surface-2">
    <span id="ac-drop-label" class="text-lg font-medium text-ink">
      {from ? `Drop your .${from} file here to convert` : 'Drop your file here to convert'}
    </span>
    <span class="text-sm text-ink-subtle">choose a source below, or drag a file in</span>

    <div class="relative mt-1 inline-flex items-stretch">
      <button id="ac-pick" type="button" class="btn btn-primary inline-flex items-center gap-2" style="border-top-right-radius:0;border-bottom-right-radius:0">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M12 12v6M9 15h6"/></svg>
        Select File
      </button>
      <button id="ac-pick-more" type="button" aria-label="Choose upload source" class="btn btn-primary px-2" style="border-top-left-radius:0;border-bottom-left-radius:0;border-left:1px solid rgba(255,255,255,0.22)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div id="ac-src-menu" class="hidden absolute left-1/2 bottom-[calc(100%+6px)] z-30 w-[min(13rem,calc(100vw-2rem))] -translate-x-1/2 overflow-hidden rounded-lg border border-hairline bg-surface-2 text-left shadow-xl">
        <button type="button" data-src="device" class="ac-src flex w-full items-center gap-2.5 px-3 py-2.5 text-sm text-ink hover:bg-surface-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-ink-subtle"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M8 21h8M12 18v3"/></svg>
          From this device
        </button>
        <button type="button" data-src="gdrive" class="ac-src flex w-full items-center gap-2.5 px-3 py-2.5 text-sm text-ink hover:bg-surface-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-ink-subtle"><path d="M8 3h8l5 9-4 7H7l-4-7z"/></svg>
          Google Drive
        </button>
        <button type="button" data-src="dropbox" class="ac-src flex w-full items-center gap-2.5 px-3 py-2.5 text-sm text-ink hover:bg-surface-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-ink-subtle"><path d="m7 3 5 3-5 3-5-3zM17 3l5 3-5 3-5-3zM2 12l5 3 5-3-5-3zM17 9l5 3-5 3-5-3zM7 18l5-3 5 3-5 3z"/></svg>
          Dropbox
        </button>
      </div>
    </div>

    <span id="ac-src-note" class="hidden text-[13px] text-ink-tertiary"></span>
    <input id="ac-file" type="file" accept={accept} class="sr-only" />
  </div>

  <div class="flex flex-wrap items-center gap-3">
    {!to && !syncTarget && (
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        Convert to
        <select id="ac-target" class="field w-auto">
          {TARGETS.map((f) => <option value={f}>{f.toUpperCase()}</option>)}
        </select>
      </label>
    )}
    <button id="ac-run" class:list={["btn btn-primary", syncTarget && "hidden"]} disabled>Convert</button>
    <a id="ac-download" class="btn btn-secondary hidden" download>Download</a>
    <span id="ac-status" class="text-[13px] text-ink-subtle" aria-live="polite"></span>
    <span id="ac-error" class="hidden text-[15px] font-medium" style="color:#e5484d" role="alert"></span>
    <span id="ac-error-hint" class="hidden text-[13px] font-medium text-ink-subtle">
      <a href="/ai" class="text-primary-hover underline underline-offset-2">Try our AI assistant</a>
      or <a href="/tools" class="text-primary-hover underline underline-offset-2">browse tools</a> →
    </span>
  </div>

  {!syncTarget && (
    <p class="text-[13px] text-ink-tertiary">
      Files are securely uploaded to our servers for conversion and returned as a download link.
    </p>
  )}
</div>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
  
  :global(html), :global(body) { overflow-anchor: none; }
  
  .ac-drop { box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 10px 45px -8px rgba(255,255,255,0.14); }
  .ac-drop:hover { box-shadow: 0 0 0 1px rgba(255,255,255,0.10), 0 12px 55px -8px rgba(255,255,255,0.20); }
  
  :global(html[data-theme='light']) .ac-drop { box-shadow: 0 1px 2px rgba(16,18,20,0.08), 0 12px 40px -8px rgba(16,18,20,0.22); }
  :global(html[data-theme='light']) .ac-drop:hover { box-shadow: 0 2px 4px rgba(16,18,20,0.10), 0 16px 48px -8px rgba(16,18,20,0.30); }
  
  :global(.picker-dialog-bg) {
    backdrop-filter: blur(8px) !important;
    -webkit-backdrop-filter: blur(8px) !important;
    background: rgba(1, 1, 2, 0.5) !important;
  }
</style>

<script>
  import { driveReady, pickFromDrive } from '../lib/drivePickers';
  import { backendFor, chainPath } from '../data/formatCatalog';

  const root = document.getElementById('ac-root') as HTMLElement;
  const presetTo = root.dataset.to || '';
  const smart = root.dataset.smart === 'true';
  const sync = root.dataset.sync === 'true';

  const syncTargetFmt = () => (document.getElementById('fmt-to')?.textContent || 'pdf').trim().toLowerCase();

  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('ac-file') as HTMLInputElement;
  const drop = $('ac-drop');
  const dropLabel = $('ac-drop-label');
  const target = document.querySelector<HTMLSelectElement>('#ac-target');
  const runBtn = $('ac-run') as HTMLButtonElement;
  const dlBtn = $('ac-download') as HTMLAnchorElement;
  const status = $('ac-status');
  const err = $('ac-error');

  let picked: File | null = null;
  let lastOutUrl: string | null = null;
  const errHint = document.getElementById('ac-error-hint');
  const setErr = (m: string) => {
    err.textContent = m;
    err.classList.toggle('hidden', !m);
    // ponytail: only nudge to the AI assistant when the service is down, not on bad-file errors
    errHint?.classList.toggle('hidden', !/temporarily unavailable/i.test(m));
  };

  const CATEGORY: Record<string, string[]> = {
    image: ['jpg', 'jpeg', 'png', 'webp', 'gif', 'bmp', 'tiff', 'tif', 'svg', 'ico', 'avif', 'heic', 'psd', 'eps'],
    document: ['pdf', 'docx', 'doc', 'odt', 'rtf', 'txt', 'html', 'md', 'pages', 'wpd'],
    audio: ['mp3', 'wav', 'flac', 'aac', 'm4a', 'ogg', 'opus', 'aiff', 'wma'],
    video: ['mp4', 'webm', 'mkv', 'mov', 'avi', 'flv', 'ogv', 'wmv', '3gp', 'mpeg', 'mpg', 'ts', 'vob'],
    spreadsheet: ['xlsx', 'xls', 'ods', 'csv', 'numbers'],
    presentation: ['pptx', 'ppt', 'odp', 'key', 'pps'],
    ebook: ['epub', 'mobi', 'azw', 'azw3', 'fb2', 'lit', 'pdb'],
    archive: ['zip', '7z', 'tar', 'gz', 'bz2', 'xz', 'rar'],
  };
  const ALLOWED: Record<string, string[]> = {
    image: ['image', 'document'],
    document: ['document', 'image'],
    audio: ['audio'],
    video: ['video', 'audio', 'image'],
    spreadsheet: ['spreadsheet', 'document'],
    presentation: ['presentation', 'document'],
    ebook: ['ebook', 'document'],
    archive: ['archive'],
  };
  const catOf = (ext: string) => Object.keys(CATEGORY).find((c) => CATEGORY[c].includes(ext));
  const targetCat = (fmt: string) => catOf(fmt.split('.').pop() || fmt);

  function narrowTargets(inExt: string) {
    if (!smart || !target) return;
    const inCat = catOf(inExt);
    const allowedCats = inCat ? ALLOWED[inCat] : null;
    let firstVisible: HTMLOptionElement | null = null;
    for (const opt of Array.from(target.options)) {
      const oc = targetCat(opt.value);
      const show = (!allowedCats || (oc && allowedCats.includes(oc))) && opt.value !== inExt;
      opt.hidden = !show;
      if (show && !firstVisible) firstVisible = opt;
    }
    if (firstVisible) target.value = firstVisible.value;
  }

  function load(file: File) {
    setErr('');
    picked = file;
    dropLabel.textContent = file.name;
    runBtn.disabled = false;
    dlBtn.classList.add('hidden');
    status.textContent = '';
    narrowTargets((file.name.split('.').pop() || '').toLowerCase());
    if (sync) {
      runBtn.classList.remove('hidden');
      const inExt = (file.name.split('.').pop() || '').toLowerCase();
      document.dispatchEvent(new CustomEvent('fmt-lock', { detail: { from: inExt } }));
    }
  }


  const MAX_BYTES = 100 * 1024 * 1024;

  async function convert() {
    if (!picked) return;
    setErr('');
    if (picked.size > MAX_BYTES) {
      setErr('File is too large (max 100 MB for online conversion). Try a smaller file.');
      return;
    }
    runBtn.disabled = true;
    runBtn.textContent = 'Converting…';
    dlBtn.classList.add('hidden');
    const outFormat = sync ? syncTargetFmt() : (presetTo || target?.value || 'zip');
    const inFormat = (picked.name.split('.').pop() || '').toLowerCase();

    if (lastOutUrl) { URL.revokeObjectURL(lastOutUrl); lastOutUrl = null; }

    try {
      const backend = backendFor(inFormat);
      if (backend === 'ffmpeg') await convertMedia(picked, inFormat, outFormat);
      else if (backend === 'font') await convertFont(picked, outFormat);
      else if (backend === 'archive') await convertArchiveFile(picked, inFormat, outFormat);
      else await convertApi(picked, inFormat, outFormat);
    } catch (e) {
      setErr((e as Error).message);
      status.textContent = '';
    } finally {
      runBtn.disabled = false;
      runBtn.textContent = 'Convert';
    }
  }

  function offerDownload(data: Uint8Array, mime: string, outFormat: string) {
    if (!data || data.length === 0) throw new Error('Conversion produced an empty file — the input may be unsupported or corrupt.');
    lastOutUrl = URL.createObjectURL(new Blob([data as BlobPart], { type: mime }));
    dlBtn.href = lastOutUrl;
    dlBtn.setAttribute('download', (picked!.name.replace(/\.[^.]+$/, '') || 'converted') + '.' + outFormat);
    dlBtn.classList.remove('hidden');
    status.textContent = (data.length / 1048576).toFixed(2) + ' MB';
  }

  async function convertApi(file: File, inFormat: string, outFormat: string) {
    const path = chainPath(inFormat, outFormat) || [inFormat, outFormat];
    const { convertViaApi } = await import('../lib/ccConvert');
    let pct = 0;
    let step = '';
    const tick = setInterval(() => {
      pct = Math.min(95, pct + (96 - pct) * 0.06);
      runBtn.textContent = `Converting…${step} ${Math.round(pct)}%`;
    }, 250);
    let out;
    try {
      out = await convertViaApi(file, path, (hop, total) => {
        step = total > 1 ? ` ${hop}/${total}` : '';
      });
    } finally {
      clearInterval(tick);
    }
    runBtn.textContent = 'Converting… 100%';
    if (lastOutUrl) { URL.revokeObjectURL(lastOutUrl); lastOutUrl = null; }
    const proxy = (f: { url: string; filename: string }, fallback: string) =>
      `/api/cc-job?download=${encodeURIComponent(f.url)}&name=${encodeURIComponent(f.filename || fallback)}`;
    if (out.length === 1) {
      dlBtn.href = proxy(out[0], `converted.${outFormat}`);
      dlBtn.setAttribute('download', out[0].filename || `converted.${outFormat}`);
    } else {
      const { makeZip } = await import('../lib/zip');
      const entries = await Promise.all(out.map(async (f, i) => {
        const r = await fetch(proxy(f, `page-${i + 1}.${outFormat}`));
        if (!r.ok) throw new Error('Could not download a converted page.');
        return { name: f.filename || `page-${i + 1}.${outFormat}`, data: new Uint8Array(await r.arrayBuffer()) };
      }));
      lastOutUrl = URL.createObjectURL(makeZip(entries));
      dlBtn.href = lastOutUrl;
      dlBtn.setAttribute('download', `${(picked!.name.replace(/\.[^.]+$/, '') || 'converted')}-${outFormat}.zip`);
    }
    dlBtn.classList.remove('hidden');
    status.textContent = out.length > 1 ? `${out.length} files · ZIP` : '';
  }

  const AUDIO_MIME: Record<string, string> = {
    mp3: 'audio/mpeg', m4a: 'audio/mp4', wav: 'audio/wav', flac: 'audio/flac',
    ogg: 'audio/ogg', opus: 'audio/opus', aiff: 'audio/aiff', ac3: 'audio/ac3',
  };

  async function convertMedia(file: File, inFormat: string, outFormat: string) {
    const { getFFmpeg, fetchFile } = await import('../lib/ffmpeg');
    const { VIDEO_MIME, videoArgs } = await import('../lib/videoConvert');
    const isVideo = outFormat in VIDEO_MIME;
    status.textContent = '';
    runBtn.textContent = 'Loading engine…';
    const ff = await getFFmpeg({
      onDownload: (n) => { if (n) runBtn.textContent = 'Downloading…'; },
      onProgress: (r) => { runBtn.textContent = `Converting… ${Math.min(100, Math.round(r * 100))}%`; },
    });
    runBtn.textContent = 'Converting… 0%';
    const token = Math.random().toString(36).slice(2);
    const inName = 'in_' + token + '.' + inFormat;
    const outName = 'out_' + token + '.' + outFormat;
    let args: string[];
    let mime: string;
    if (isVideo) {
      args = videoArgs(outFormat, 'balanced', inName, outName);
      mime = VIDEO_MIME[outFormat];
    } else {
      const { buildArgs, defaultQuality } = await import('../lib/media');
      const outFamily = (outFormat === 'm4a' ? 'aac' : outFormat) as any;
      const conv = { out: outFamily, kind: 'audio', ext: outFormat } as any;
      args = buildArgs(conv, { quality: defaultQuality(outFamily) }, inName, outName);
      mime = AUDIO_MIME[outFormat] || 'application/octet-stream';
    }
    await ff.writeFile(inName, await fetchFile(file));
    try {
      await ff.exec(args);
      const data = (await ff.readFile(outName)) as Uint8Array;
      offerDownload(data, mime, outFormat);
    } finally {
      try { await ff.deleteFile(inName); } catch {}
      try { await ff.deleteFile(outName); } catch {}
    }
  }

  const FONT_MIME: Record<string, string> = {
    ttf: 'font/ttf', woff: 'font/woff', woff2: 'font/woff2', eot: 'application/vnd.ms-fontobject',
  };

  async function convertFont(file: File, outFormat: string) {
    const { createFont, woff2 } = await import('fonteditor-core');
    const inType = (file.name.split('.').pop() || '').toLowerCase();
    if (outFormat === 'woff2' || inType === 'woff2') {
      status.textContent = 'Loading WOFF2 support…';
      await woff2.init('/woff2.wasm');
    }
    status.textContent = 'Converting…';
    const buf = await file.arrayBuffer();
    const font = createFont(buf, { type: inType as any, hinting: true, kerning: true });
    const out = font.write({ type: outFormat as any, hinting: true, kerning: true });
    const data = out instanceof ArrayBuffer ? new Uint8Array(out) : (out as Uint8Array);
    offerDownload(data, FONT_MIME[outFormat] || 'application/octet-stream', outFormat);
  }

  async function convertArchiveFile(file: File, inFormat: string, outFormat: string) {
    const { convertArchive, archiveFormatOf, ARCHIVE_MIME } = await import('../lib/archive');
    const to = archiveFormatOf(outFormat);
    if (!to) throw new Error(`Can't write ${outFormat.toUpperCase()} archives in the browser.`);
    status.textContent = 'Extracting…';
    const data = await convertArchive(file, to);
    const ext = to === 'tgz' ? 'tar.gz' : to;
    offerDownload(data, ARCHIVE_MIME[to], ext);
  }

  const pickBtn = $('ac-pick') as HTMLButtonElement;
  const moreBtn = $('ac-pick-more') as HTMLButtonElement;
  const srcMenu = $('ac-src-menu');
  const srcNote = $('ac-src-note');
  const openPicker = () => { fileInput.click(); };
  const toggleMenu = (show?: boolean) => srcMenu.classList.toggle('hidden', show === undefined ? undefined : !show);

  let lockedY = 0;
  let scrollLocked = false;
  function lockScroll() {
    if (scrollLocked) return;
    lockedY = window.scrollY;
    const b = document.body.style;
    b.position = 'fixed';
    b.top = `-${lockedY}px`;
    b.left = '0';
    b.right = '0';
    b.width = '100%';
    scrollLocked = true;
  }
  function unlockScroll() {
    if (!scrollLocked) return;
    const b = document.body.style;
    b.position = ''; b.top = ''; b.left = ''; b.right = ''; b.width = '';
    scrollLocked = false;
    window.scrollTo(0, lockedY);
  }


  fileInput.addEventListener('change', () => fileInput.files?.[0] && load(fileInput.files[0]));

  drop.addEventListener('click', (ev) => {
    if ((ev.target as HTMLElement).closest('#ac-pick, #ac-pick-more, #ac-src-menu')) return;
    openPicker();
  });
  pickBtn.addEventListener('click', (e) => { e.stopPropagation(); toggleMenu(false); openPicker(); });
  moreBtn.addEventListener('click', (e) => { e.stopPropagation(); srcMenu.classList.toggle('hidden'); });
  document.addEventListener('click', (e) => { if (!(e.target as HTMLElement).closest('#ac-src-menu, #ac-pick-more')) toggleMenu(false); });

  srcMenu.querySelectorAll<HTMLButtonElement>('.ac-src').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      toggleMenu(false);
      const src = btn.dataset.src!;
      const label = btn.textContent!.trim();
      if (src === 'device') { srcNote.classList.add('hidden'); openPicker(); return; }

      if (!driveReady(src)) {
        srcNote.textContent = `${label} isn't set up yet — use “From this device” for now.`;
        srcNote.classList.remove('hidden');
        return;
      }
      srcNote.classList.add('hidden');
      dropLabel.textContent = `Opening ${label}…`;
      lockScroll();
      try {
        await pickFromDrive(src, (file) => load(file));
      } catch (err) {
        setErr(`Couldn't get the file from ${label}: ${(err as Error).message}`);
        dropLabel.textContent = 'Drop your file here to convert';
      } finally {
        unlockScroll();
      }
    });
  });

  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files?.[0]; if (f) load(f); });
  runBtn.addEventListener('click', convert);
</script>

---
import { tools } from '../data/tools';

interface Props {
  variant?: 'hero' | 'compact';
  id?: string;
  class?: string;
}
const { variant = 'hero', id, class: className = '' } = Astro.props;
const inputId = id ?? `tool-search-${variant}`;

// Dropdown index only needed for the compact (header) variant.
const toolIndex =
  variant === 'compact'
    ? tools.map((t) => ({
        n: t.name,
        s: t.slug,
        c: t.category,
        i: t.icon,
        k: (t.keywords ?? []).join(' '),
      }))
    : null;
---

<form
  class={`tool-search tool-search--${variant} ${className}`}
  role="search"
  data-tool-search
  action="/#tools"
>
  <label for={inputId} class="sr-only">Search tools</label>
  <div class="relative flex items-center">
    <svg
      class="pointer-events-none absolute left-3 text-ink-tertiary"
      width="18" height="18" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
    </svg>
    <input
      id={inputId}
      name="q"
      type="search"
      class="field pl-10"
      placeholder="Search tools…"
      autocomplete="off"
      aria-label="Search tools by name or keyword"
      role={variant === 'compact' ? 'combobox' : undefined}
      aria-expanded={variant === 'compact' ? 'false' : undefined}
      aria-controls={variant === 'compact' ? `${inputId}-results` : undefined}
      aria-autocomplete={variant === 'compact' ? 'list' : undefined}
      data-tool-search-input
    />
    {variant === 'compact' && (
      <ul
        id={`${inputId}-results`}
        class="search-results hidden"
        role="listbox"
        data-tool-search-results
      />
    )}
  </div>
</form>

{toolIndex && (
  <script
    type="application/json"
    data-tool-search-index
    set:html={JSON.stringify(toolIndex)}
  />
)}

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0);
    white-space: nowrap; border: 0;
  }
  .tool-search--hero { width: 100%; max-width: 30rem; margin-inline: auto; }
  .tool-search--compact { width: 16rem; }
  .tool-search--compact .field { padding-block: 0.3rem; }

  .tool-search input::-webkit-search-cancel-button { -webkit-appearance: none; }

  .search-results {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    z-index: 60;
    max-height: 20rem;
    overflow-y: auto;
    margin: 0;
    padding: 0.25rem;
    list-style: none;
    background-color: var(--color-surface-1);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.45);
  }
  .search-results:empty { display: none; }
  .search-results :global(li) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.625rem;
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    font-size: 0.875rem;
    line-height: 1.3;
    cursor: pointer;
  }
  .search-results :global(li[aria-selected='true']),
  .search-results :global(li:hover) {
    background-color: var(--color-surface-2);
  }
  .search-results :global(li .ico) {
    flex: none;
    width: 1.5rem;
    height: 1.5rem;
    padding: 0.3rem;
    border-radius: var(--radius-sm);
    background-color: var(--color-surface-2);
    color: var(--color-ink-muted);
    box-sizing: border-box;
  }
  .search-results :global(li[aria-selected='true'] .ico),
  .search-results :global(li:hover .ico) {
    background-color: var(--color-surface-3);
  }
  .search-results :global(li .txt) {
    min-width: 0;
  }
  .search-results :global(li .cat) {
    display: block;
    color: var(--color-ink-tertiary);
    font-size: 0.75rem;
  }
</style>

<script>
  const inputs = Array.from(
    document.querySelectorAll<HTMLInputElement>('[data-tool-search-input]'),
  );
  if (inputs.length) {
    const grid = document.getElementById('tools');
    const norm = (s: string) => s.toLowerCase().trim();

    function applyFilter(raw: string) {
      if (!grid) return;
      const q = norm(raw);
      const cards = grid.querySelectorAll<HTMLElement>('[data-tool-card]');
      let visible = 0;
      cards.forEach((card) => {
        const hay = card.dataset.search || '';
        const match = !q || hay.includes(q);
        card.classList.toggle('hidden', !match);
        if (match) visible++;
      });

      grid.querySelectorAll<HTMLElement>('[data-category-section]').forEach((sec) => {
        const anyVisible = sec.querySelectorAll('[data-tool-card]:not(.hidden)').length > 0;
        sec.classList.toggle('hidden', !anyVisible);
      });
      const empty = document.getElementById('search-empty');
      const count = document.getElementById('search-count');
      if (empty) empty.classList.toggle('hidden', visible !== 0);
      if (count) {
        count.textContent = q
          ? `${visible} tool${visible === 1 ? '' : 's'} match “${raw.trim()}”`
          : '';
      }
    }

    function sync(value: string, from: HTMLInputElement) {
      inputs.forEach((i) => {
        if (i !== from) i.value = value;
      });
    }

    // Autocomplete dropdown (compact/header variant only).
    type Entry = { n: string; s: string; c: string; i: string; k: string };
    let index: Entry[] = [];
    try {
      const raw = document.querySelector('[data-tool-search-index]')?.textContent;
      if (raw) index = JSON.parse(raw) as Entry[];
    } catch (_) {}

    function setupDropdown(input: HTMLInputElement) {
      const list = document.getElementById(
        `${input.id}-results`,
      ) as HTMLUListElement | null;
      if (!list || !index.length) return;

      const SVG_NS = 'http://www.w3.org/2000/svg';
      // Category → icon hue, mirroring ToolCard's tints (Tailwind *-400 shades).
      const CAT_COLOR: Record<string, string> = {
        Text: '#38bdf8',
        Developer: '#a78bfa',
        Image: '#34d399',
        Converters: '#fbbf24',
        Calculators: '#fb7185',
        Generators: '#e879f9',
        Security: '#2dd4bf',
        PDF: '#f87171',
        'Audio & Video': '#818cf8',
        'Device & Sensors': '#22d3ee',
      };
      let active = -1;
      let items: Entry[] = [];

      const close = () => {
        list.replaceChildren();
        list.classList.add('hidden');
        input.setAttribute('aria-expanded', 'false');
        active = -1;
      };

      const setActive = (i: number) => {
        const lis = list.querySelectorAll('li');
        lis.forEach((li) => li.setAttribute('aria-selected', 'false'));
        active = i;
        if (i >= 0 && lis[i]) {
          lis[i].setAttribute('aria-selected', 'true');
          lis[i].scrollIntoView({ block: 'nearest' });
        }
      };

      const go = (slug: string) => {
        window.location.href = `/tools/${slug}`;
      };

      const render = (raw: string) => {
        const q = norm(raw);
        if (!q) return close();
        const terms = q.split(/\s+/).filter(Boolean);
        // Match each term at a word start, so "dom" doesn't hit "ran*dom*".
        const esc = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const res = terms.map((t) => new RegExp(`\\b${esc(t)}`, 'i'));
        // Names starting with the query rank first, each tier alphabetical.
        const starts = (n: string) => norm(n).startsWith(terms[0]);
        items = index
          .filter((t) => res.every((re) => re.test(t.n)))
          .sort((a, b) => {
            const d = Number(starts(b.n)) - Number(starts(a.n));
            return d || a.n.localeCompare(b.n);
          });
        if (!items.length) return close();
        list.replaceChildren(
          ...items.map((t) => {
            const li = document.createElement('li');
            li.setAttribute('role', 'option');
            li.setAttribute('aria-selected', 'false');
            li.dataset.slug = t.s;

            const icon = document.createElementNS(SVG_NS, 'svg');
            icon.setAttribute('class', 'ico');
            icon.setAttribute('viewBox', '0 0 24 24');
            icon.setAttribute('fill', 'none');
            icon.setAttribute('stroke', 'currentColor');
            icon.setAttribute('stroke-width', '1.75');
            icon.setAttribute('stroke-linecap', 'round');
            icon.setAttribute('stroke-linejoin', 'round');
            icon.setAttribute('aria-hidden', 'true');
            const hue = CAT_COLOR[t.c];
            if (hue) {
              icon.style.color = hue;
              icon.style.backgroundColor = `color-mix(in srgb, ${hue} 12%, transparent)`;
            }
            const path = document.createElementNS(SVG_NS, 'path');
            path.setAttribute('d', t.i);
            icon.appendChild(path);

            const text = document.createElement('span');
            text.className = 'txt';
            const name = document.createElement('span');
            name.textContent = t.n;
            const cat = document.createElement('span');
            cat.className = 'cat';
            cat.textContent = t.c;
            text.append(name, cat);
            li.append(icon, text);
            li.addEventListener('mousedown', (e) => {
              e.preventDefault();
              go(t.s);
            });
            return li;
          }),
        );
        list.classList.remove('hidden');
        input.setAttribute('aria-expanded', 'true');
        active = -1;
      };

      input.addEventListener('input', () => render(input.value));
      input.addEventListener('focus', () => {
        if (input.value.trim()) render(input.value);
      });
      input.addEventListener('keydown', (e) => {
        if (list.classList.contains('hidden')) return;
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(Math.min(active + 1, items.length - 1));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(Math.max(active - 1, 0));
        } else if (e.key === 'Enter' && active >= 0) {
          e.preventDefault();
          go(items[active].s);
        }
      });
      input.addEventListener('blur', () => setTimeout(close, 120));
    }

    inputs.forEach((input) => {
      input.addEventListener('input', () => {
        sync(input.value, input);
        applyFilter(input.value);
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          input.value = '';
          sync('', input);
          applyFilter('');
        }
      });
      // On pages without the grid, submit navigates home with the query.
      const form = input.closest('form');
      form?.addEventListener('submit', (e) => {
        if (!grid) {
          e.preventDefault();
          const q = encodeURIComponent(input.value.trim());
          window.location.href = q ? `/?q=${q}#tools` : '/#tools';
        } else {
          e.preventDefault();
        }
      });

      if (document.getElementById(`${input.id}-results`)) setupDropdown(input);
    });

    // Prefill + apply from ?q= on load (home page deep-link from header search).
    if (grid) {
      const params = new URLSearchParams(window.location.search);
      const q = params.get('q');
      if (q) {
        inputs.forEach((i) => (i.value = q));
        applyFilter(q);
      }
    }
  }
</script>

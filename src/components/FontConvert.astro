---
export interface Props { slug: string; from?: string; to?: string; }
const { from, to } = Astro.props;
const TARGETS: Record<string, string> = { ttf: 'TTF', woff: 'WOFF', woff2: 'WOFF2', eot: 'EOT' };
const accept = from ? `.${from}` : '.ttf,.otf,.woff,.woff2,.eot';
---

<div id="ft-root" class="flex flex-col gap-4" data-to={to ?? ''}>
  <label id="ft-drop" class="panel panel-lift flex cursor-pointer flex-col items-center justify-center gap-2 border-dashed p-8 text-center transition-colors hover:bg-surface-2">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-ink-tertiary" aria-hidden="true"><path d="M4 7V4h16v3M9 20h6M12 4v16"/></svg>
    <span class="text-sm text-ink">{from ? `Choose .${from} files or drop them here` : 'Choose font files or drop them here'}</span>
    <input id="ft-file" type="file" accept={accept} multiple class="sr-only" />
  </label>

  <div class="flex flex-wrap items-center gap-3">
    {!to && (
      <label class="flex items-center gap-2 text-sm text-ink-subtle">
        Convert to
        <select id="ft-target" class="field w-auto">
          {Object.entries(TARGETS).map(([k, v]) => <option value={k}>{v}</option>)}
        </select>
      </label>
    )}
    <button id="ft-run" class="btn btn-primary" disabled>Convert</button>
    <button id="ft-zip" class="btn btn-secondary hidden">Download all as ZIP</button>
    <span id="ft-status" class="text-[13px] text-ink-subtle" aria-live="polite"></span>
  </div>

  <div id="ft-files" class="flex flex-col gap-2"></div>

  <p class="text-[13px] text-ink-tertiary">Everything runs in your browser — your fonts are never uploaded to a server.</p>
  <p id="ft-error" class="hidden text-[13px]" style="color:#e5484d" role="alert"></p>
</div>

<style>
  .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
</style>

<script>
  import { createFont, woff2 } from 'fonteditor-core';
  import { makeZip } from '../lib/zip';

  const woff2WasmUrl = '/woff2.wasm';

  type FontType = 'ttf' | 'otf' | 'woff' | 'woff2' | 'eot';
  const MIME: Record<string, string> = {
    ttf: 'font/ttf', woff: 'font/woff', woff2: 'font/woff2', eot: 'application/vnd.ms-fontobject',
  };

  const root = document.getElementById('ft-root') as HTMLElement;
  const presetTo = root.dataset.to || '';
  const $ = (id: string) => document.getElementById(id)!;
  const fileInput = $('ft-file') as HTMLInputElement;
  const drop = $('ft-drop');
  const target = document.querySelector<HTMLSelectElement>('#ft-target');
  const runBtn = $('ft-run') as HTMLButtonElement;
  const zipBtn = $('ft-zip') as HTMLButtonElement;
  const status = $('ft-status');
  const filesEl = $('ft-files');
  const err = $('ft-error');

  const setErr = (m: string) => { err.textContent = m; err.classList.toggle('hidden', !m); };
  const fmt = (n: number) => n < 1024 ? `${n} B` : n < 1048576 ? `${(n/1024).toFixed(1)} KB` : `${(n/1048576).toFixed(2)} MB`;
  const extOf = (name: string) => (name.split('.').pop() || '').toLowerCase() as FontType;

  interface Job { file: File; row: HTMLElement; statusEl: HTMLElement; data?: Uint8Array; outName?: string; done: boolean; }
  let jobs: Job[] = [];
  let woff2Ready = false;

  function addFiles(list: FileList | File[]) {
    setErr('');
    for (const file of Array.from(list)) {
      const row = document.createElement('div');
      row.className = 'panel flex flex-wrap items-center gap-2 p-3';
      const name = document.createElement('span');
      name.className = 'text-[13px] text-ink truncate';
      name.textContent = `${file.name} · ${fmt(file.size)}`;
      const statusEl = document.createElement('span');
      statusEl.className = 'text-xs text-ink-tertiary ml-auto';
      row.append(name, statusEl);
      filesEl.appendChild(row);
      jobs.push({ file, row, statusEl, done: false });
    }
    runBtn.disabled = jobs.length === 0;
  }

  async function convertAll() {
    const outType = (presetTo || target?.value || 'ttf') as FontType;
    const pending = jobs.filter((j) => !j.done);
    if (!pending.length) return;
    setErr(''); runBtn.disabled = true;

    const needsWoff2 = outType === 'woff2' || pending.some((j) => extOf(j.file.name) === 'woff2');
    if (needsWoff2 && !woff2Ready) {
      status.textContent = 'Loading WOFF2 support…';
      try { await woff2.init(woff2WasmUrl); woff2Ready = true; }
      catch (e) { setErr('Could not load WOFF2 support: ' + (e as Error).message); runBtn.disabled = false; return; }
    }

    try {
      for (const job of pending) {
        job.statusEl.textContent = 'Converting…';
        const inType = extOf(job.file.name);
        const buf = await job.file.arrayBuffer();
        const font = createFont(buf, { type: inType, hinting: true, kerning: true });
        const out = font.write({ type: outType, hinting: true, kerning: true });
        const data = out instanceof ArrayBuffer ? new Uint8Array(out) : (out as Uint8Array);
        job.data = data;
        job.outName = job.file.name.replace(/\.[^.]+$/, '') + '.' + outType;
        job.done = true;
        job.statusEl.textContent = fmt(data.length);
        job.statusEl.style.color = 'var(--color-success)';
        const dl = document.createElement('button');
        dl.className = 'btn btn-secondary'; dl.style.minHeight = '28px'; dl.style.padding = '2px 10px'; dl.style.fontSize = '12px';
        dl.textContent = 'Download';
        dl.addEventListener('click', () => {
          const url = URL.createObjectURL(new Blob([data as BlobPart], { type: MIME[outType] }));
          const a = document.createElement('a'); a.href = url; a.download = job.outName!; a.click();
          setTimeout(() => URL.revokeObjectURL(url), 2000);
        });
        job.row.appendChild(dl);
      }
      status.textContent = 'Done.';
      zipBtn.classList.toggle('hidden', jobs.filter((j) => j.done).length < 2);
    } catch (e) {
      setErr('Conversion failed: ' + (e as Error).message);
      status.textContent = '';
    } finally { runBtn.disabled = false; }
  }

  zipBtn.addEventListener('click', () => {
    const done = jobs.filter((j) => j.done && j.data);
    if (!done.length) return;
    const url = URL.createObjectURL(makeZip(done.map((j) => ({ name: j.outName!, data: j.data! }))));
    const a = document.createElement('a'); a.href = url; a.download = 'fonts-output.zip'; a.click();
    setTimeout(() => URL.revokeObjectURL(url), 2000);
  });

  fileInput.addEventListener('change', () => fileInput.files && addFiles(fileInput.files));
  ['dragover', 'dragenter'].forEach((e) => drop.addEventListener(e, (ev) => { ev.preventDefault(); drop.classList.add('bg-surface-2'); }));
  ['dragleave', 'drop'].forEach((e) => drop.addEventListener(e, () => drop.classList.remove('bg-surface-2')));
  drop.addEventListener('drop', (ev) => { ev.preventDefault(); const f = (ev as DragEvent).dataTransfer?.files; if (f?.length) addFiles(f); });
  runBtn.addEventListener('click', convertAll);
</script>
